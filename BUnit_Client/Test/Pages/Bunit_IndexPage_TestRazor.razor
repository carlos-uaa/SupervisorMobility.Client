@inherits TestContext

@code
{
    public IndexPage_Instance ctxLocal = new IndexPage_Instance();

    [Fact]
    public void RendersCorrectly_without_instantiating()
    {
        // Act
        var cut = Render(@<SupervisorMobility.Client.Pages.Index />);

        // Assert
        Assert.Contains("Hello world from Blazor", cut.Markup);
    }

    [Fact]
    public void Index_Razor_RendersCorrectly()
    {
        // Arrange
        // using var ctx = new IndexPage_instantiating();

        // Act
        var cut = ctxLocal.Render(@<SupervisorMobility.Client.Pages.Index />);

        // Assert
        Assert.NotNull(cut);
    }


    [Fact]
    public void Login_False_Razor_RendersCorrectly()
    {
        // Arrange
        using var ctx = new IndexPage_Instance(false); // Usuario NO logueado

        // Act
        var cut = ctx.Render(@<SupervisorMobility.Client.Pages.Index/>);


        // Assert
        Assert.NotNull(cut.Find("form"));
        Assert.NotEmpty(cut.FindAll("input[type='text']"));
        Assert.NotEmpty(cut.FindAll("input[type='password']"));
        Assert.NotEmpty(cut.FindAll("button[type='submit']"));
    }

    [Fact]

    public void Login_True_Razor_RendersCorrectly()
    {
        // Arrange
        using var ctx = new IndexPage_Instance(true); // Usuario logueado
 
        // Act
        var cut = ctx.Render(@<SupervisorMobility.Client.Pages.Index />);
      

        // Assert
        Assert.NotEmpty(cut.FindAll(".menu-card"));
        Assert.Empty(cut.FindAll("form"));
    }


}