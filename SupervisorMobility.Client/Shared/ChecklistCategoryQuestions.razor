@inject IChecklistService ChecklistService
@inject NavigationManager NavigationManager

<MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
    <MudTabPanel Icon="@Icons.Material.Filled.Checklist" Text="Questions">
        @if (_checklistCategory.ChecklistQuestions.Count > 0)
        {
            <MudTable Items="_checklistCategory.ChecklistQuestions" Hover="true" T="ChecklistQuestion">
                <ToolBarContent>
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.Add" aria-label="add" @onclick="(() => CreateQuestion(CategoryId))"></MudIconButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudText Align="Align.Center">Question Id</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Code</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Description</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Sequence</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Status</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Actions</MudText>
                    </MudTh>
                </HeaderContent>                <RowTemplate>
                    <MudTd DataLabel="QuestionId">
                        <MudText Align="Align.Center">@context.QuestionID</MudText>
                    </MudTd>
                    <MudTd DataLabel="Code">
                        <MudText Align="Align.Center">@context.Code</MudText>
                    </MudTd>
                    <MudTd DataLabel="Description">
                        <MudText Align="Align.Center">@context.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel="Sequence">
                        <MudText Align="Align.Center">@context.CategorySequence</MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsActive == true)
                        {
                            <MudText Align="Align.Center">
                                <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                            </MudText>
                        }
                        else
                        {
                            <MudText Align="Align.Center">
                                <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                            </MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudText Align="Align.Center">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit" @onclick="(() => UpdateQuestion(CategoryId, context.QuestionID))"></MudIconButton>
                            <CascadingValue Value="context.ChecklistCategoryId" Name="CategoryId">
                                <CascadingValue Value="context.QuestionID" Name="QuestionId">
                                    <DeleteQuestionButton />
                                </CascadingValue>
                            </CascadingValue>
                        </MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">There are no questions created for this category.</MudText>
            <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">
                <MudButton Color="Color.Info" @onclick="(() => CreateQuestion(CategoryId))">Create a new question</MudButton>
            </MudText>
        }
    </MudTabPanel>
</MudTabs>