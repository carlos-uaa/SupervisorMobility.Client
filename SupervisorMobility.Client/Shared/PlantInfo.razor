@inject IPlantService PlantService

<MudCard>
    <MudCardContent Style="justify-content:center">
        <MudText Align="Align.Center"><MudIcon Icon="@Icons.Filled.Business"></MudIcon></MudText>
        <MudText Align="Align.Center">@_plant.Code</MudText>
        <MudText Typo="Typo.h5" Align="Align.Center">@_plant.Description</MudText>
        @if (_plant.IsActive == true)
        {
            <MudText Align="Align.Center" Class="pt-2">
                <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
            </MudText>
        }
        else
        {
            <MudText Align="Align.Center" Class="pa-4">
                <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
            </MudText>
        }
    </MudCardContent>
@*    <MudCardActions Style="justify-content:center">
        <MudGrid>
            <MudItem xs="12">
                <MudText Align="Align.Center" Typo="Typo.h6">Areas</MudText>
