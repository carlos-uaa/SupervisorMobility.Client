@inject NavigationManager NavigationManager

@inject IDialogService DialogService
@inject IJobObservationService JobObservationService
@inject IGlosaryService GlosaryService
@inject ILupService LupService
@inject ISnackbar Snackbar
@inject IUserService UsersService


<MudNavMenu Color="Color.Info">
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
    <MudNavLink Href="/jobobservationschedule" Icon="@Icons.Material.Filled.CalendarMonth">Job Observations Schedule</MudNavLink>
    <MudNavLink Href="/jobobservation" Icon="@Icons.Material.Filled.CalendarToday">Job Observations</MudNavLink>
    <MudNavLink Href="/lup" Icon="@Icons.Material.Filled.ChecklistRtl">LUP</MudNavLink>
    <MudNavLink Href="/configuration" Icon="@Icons.Material.Filled.Settings">Configuration</MudNavLink>
    <MudTreeView T="string" Style="margin-top: 5vh">
        <MudTreeViewItem Value="@("To do")">
            <MudTreeViewItem Value="@("Late")" Expanded=true>
                @foreach(var jobobs in lateObservations)
                {
                    var date = jobobs.DateStart?.ToShortDateString() + " - " + jobobs.DateEnd?.ToShortDateString();
                    //Late job observations
                    if (jobobs.Status == 3)
                    {
                        <MudTooltip Text="@date" Color="Color.Error" Placement="Placement.Top" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Error">
                                <span style="font-weight: bold; color: black">@jobobs.JobObservationId</span>
                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px">@jobobs.DateStart?.ToShortTimeString() - @jobobs.DateEnd?.ToShortTimeString()</MudChip>
                                <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" />
                            </MudButton>
                        </MudTooltip>
                    }
                }

            </MudTreeViewItem>
            <MudTreeViewItem Value="@("Today")" Expanded=true>
                @foreach (var jobobs in todayObservations)
                {
                    var date = jobobs.DateStart?.ToShortDateString() + " - " + jobobs.DateEnd?.ToShortDateString();
                    //Programmed
                    if (jobobs.Status == 1)
                    {
                        <MudTooltip Text="@date" Color="Color.Success" Placement="Placement.Top" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Success">
                                <span style="font-weight: bold; color: black">@jobobs.JobObservationId</span>
                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="font-size: 10px">@jobobs.DateStart?.ToShortTimeString() - @jobobs.DateEnd?.ToShortTimeString()</MudChip>
                                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" />
                            </MudButton>
                        </MudTooltip>
                    }
                    //In Progress
                    else if (jobobs.Status == 2)
                    {
                        <MudTooltip Text="@date" Color="Color.Info" Placement="Placement.Top" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Info">
                                <span style="font-weight: bold; color: black">@jobobs.JobObservationId</span>
                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@jobobs.DateStart?.ToShortTimeString() - @jobobs.DateEnd?.ToShortTimeString()</MudChip>
                                <MudIcon Icon="@Icons.Material.Filled.StopCircle" />
                            </MudButton>
                        </MudTooltip>
                    }
                }
            </MudTreeViewItem>
            <MudTreeViewItem Value="@("This week")" Expanded=true>
                @foreach (var jobobs in thisWeekObservations)
                {
                    var date = jobobs.DateStart?.ToShortDateString() + " - " + jobobs.DateEnd?.ToShortDateString();
                    //Programmed
                    if (jobobs.Status == 1)
                    {
                        <MudTooltip Text="@date" Color="Color.Success" Placement="Placement.Top" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Success">
                                <span style="font-weight: bold; color: black">@jobobs.JobObservationId</span>
                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="font-size: 10px">@jobobs.DateStart?.ToShortTimeString() - @jobobs.DateEnd?.ToShortTimeString()</MudChip>
                                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" />
                            </MudButton>
                        </MudTooltip>
                    }
                    //In Progress
                    else if (jobobs.Status == 2)
                    {
                        <MudTooltip Text="@date" Color="Color.Info" Placement="Placement.Top" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Info">
                                <span style="font-weight: bold; color: black">@jobobs.JobObservationId</span>
                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@jobobs.DateStart?.ToShortTimeString() - @jobobs.DateEnd?.ToShortTimeString()</MudChip>
                                <MudIcon Icon="@Icons.Material.Filled.StopCircle" />
                            </MudButton>
                        </MudTooltip>
                    }

                }
            </MudTreeViewItem>
        </MudTreeViewItem>
    </MudTreeView>
</MudNavMenu>



<MudDialog DisableSidePadding="false" @bind-IsVisible="visible" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 75vh; overflow-y: scroll">
            <SupervisorMobility.Client.Pages.JobObservationPage.JobObservationDetails JobObservationId="jobId"></SupervisorMobility.Client.Pages.JobObservationPage.JobObservationDetails>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudIconButton @onclick="(() => JobObservationUpdate(jobId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>
        <MudButton Color="Color.Info" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>