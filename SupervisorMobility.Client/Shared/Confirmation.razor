<style>
    .header {
        display: flex;
        align-items: center
    }
</style>

<MudDialog>
    <TitleContent>
        <MudItem Class="header">
            <MudIcon Icon="@Icon" Color="@IconColor" Class="me-2"/>
            <MudText Typo="Typo.h6">@Title</MudText>
        </MudItem>
    </TitleContent>
    <DialogContent>
        <MudText>@((MarkupString)ContentText)</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel"><MudText>Cancel</MudText></MudButton>
        <MudButton Color="@Color" Variant="Variant.Filled" OnClick="Submit"><MudText>@ButtonText</MudText></MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public string Title { get; set; } = "Confirmation";
    [Parameter] public string ContentText { get; set; } = "Are you sure you want to proceed?";
    [Parameter] public string ButtonText { get; set; } = "Ok";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Help;
    [Parameter] public Color IconColor { get; set; } = Color.Primary;

    void Submit() => MudDialog.Close(DialogResult.Ok(true));
    void Cancel() => MudDialog.Cancel();
}