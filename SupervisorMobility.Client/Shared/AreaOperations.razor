@inject IAreaService AreaService
@inject NavigationManager NavigationManager

<MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
    <MudTabPanel Icon="@Icons.Material.Filled.Build" Text="Operations">
        @if (_area.Operations.Count > 0)
        {
            <MudTable Items="_area.Operations" Hover="true" T="Operation">
                <ToolBarContent>
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.Add" aria-label="add" @onclick="(() => CreateOperation(plantId, areaId))"></MudIconButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudText Align="Align.Center">Area Id</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Code</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Description</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Status</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Actions</MudText>
                    </MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="PlantId">
                        <MudText Align="Align.Center">@context.OperationId</MudText>
                    </MudTd>
                    <MudTd DataLabel="Code">
                        <MudText Align="Align.Center">@context.Code</MudText>
                    </MudTd>
                    <MudTd DataLabel="Code">
                        <MudText Align="Align.Center">@context.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsActive == true)
                        {
                            <MudText Align="Align.Center">
                                <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                            </MudText>
                        }
                        else
                        {
                            <MudText Align="Align.Center">
                                <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                            </MudText>
                        }
                    </MudTd>
                    <MudTd>
                        <MudText Align="Align.Center">
                            <MudIconButton Icon="@Icons.Material.Filled.Info" aria-label="info" ></MudIconButton>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit" ></MudIconButton>
                            <CascadingValue Value="plantId" Name="PlantId">
                                <CascadingValue Value="context.AreaId" Name="AreaId">
                                    <DeleteAreaButton />
                                </CascadingValue>
                            </CascadingValue>
                        </MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">There are no operations created for this area.</MudText>
            <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">
                <MudButton Color="Color.Info">Create a new operation</MudButton>
            </MudText>
        }
    </MudTabPanel>
</MudTabs>