    private async void LanguageSwitch(bool languageoption)
    {

        languageCheck = languageoption;

        bool result = await OpenMessageConfirmation();
        if (result)
        {
            var cultureInfo = languageCheck ? new CultureInfo("es-ES") : new CultureInfo("en-US");

            CultureInfo.DefaultThreadCurrentCulture = cultureInfo;
            CultureInfo.DefaultThreadCurrentUICulture = cultureInfo;


            switch (CultureInfo.CurrentCulture.Name)
            {
                case "es-ES":
                    js.InvokeVoidAsync("localStorage.setItem", "i18nextLng", "es-ES");
                    break;
                case "en-US":
                    js.InvokeVoidAsync("localStorage.setItem", "i18nextLng", "en-US");
                    break;
            }

            NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);

        }
        else
        {
            languageCheck = !languageCheck;
            StateHasChanged();
        }



        // Aquí puedes realizar cualquier acción adicional que desees cuando se cambie el estado del mudSwitch
    }

