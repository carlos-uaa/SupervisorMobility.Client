    <MudDialog DisableSidePadding="false" IsVisible="DisplayDialogErrorAPI" Options="dialogErrorNetworkOptions">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">
                <MudItem Class="mud-width-full d-flex flex-column flex-column justify-center" style="height:100%">

                    <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto" Typo="Typo.h3">¡Conexión Perdida!</MudText>
                    <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">
                        <strong>Estado del Servidor:</strong> La conexión al servidor se ha perdido. 😱<br>
                        Estamos trabajando duro para restablecerla y tenerlo de nuevo en línea pronto. 💼💻
                    </MudText>

                    <MudItem class="d-flex flex-column justify-center align-self-center mt-3">
                        <div class="hourglass"></div>
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                    </MudItem>


                    <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">
                        <strong>Recomendaciones para ti:</strong><br>
                        - Verifica tu conexión a Internet. 🌐<br>
                        - Asegúrate de que los cables estén conectados y que tu Wi-Fi esté encendido. 🔌📶<br>
                        - Intenta refrescar la página o volver a iniciar la aplicación en unos momentos. 🔄
                    </MudText>

                    <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto" Typo="Typo.subtitle1"><p>Próximo intento de reconexión en <strong> @timeLeft segundos. </strong></p></MudText>
            </MudItem>

        </MudContainer>
    </DialogContent>
</MudDialog>

