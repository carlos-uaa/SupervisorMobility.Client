<MudDialog DisableSidePadding="true" @bind-IsVisible="NoifyDialog" Options="dialogOptions">
    <DialogContent>
        <MudContainer Class="gap-4" Style="height: 73vh;">

            @if (AllNotifications == null)
            {
                <MudMenu AnchorOrigin="Origin.BottomCenter" Icon="@Icons.Material.Filled.Campaign">
                    <MudMenuItem>
                        <MudProgressCircular Indeterminate="true"></MudProgressCircular>
                    </MudMenuItem>
                </MudMenu>
            }
            else if (AllNotifications.Count == 0)
            {

                <MudCard Elevation="3" Class="ma-1" Style="max-height: 500px; overflow-y: scroll; width: 800px; overflow-x: scroll">
                    <MudCardHeader>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText>@Localizer1["youDontHaveAnyNoficationsYet"]</MudText>
                        </MudCardContent>
                    </MudCard>
            }
            else
            {
                <MudTabs Outlined="true" Rounded="true" Centered="true">

                    <MudTabPanel Text="@Localizer1["notifyNew"]" BadgeData="@NewNotifications.Count" Icon="@Icons.Material.Filled.MarkEmailUnread">
                        <MudItem Class="ma-1 small-scroll" Style="max-height: 70vh; overflow-y: scroll; width: 800px; overflow-x: scroll;">
                            @if (NewNotifications.Count > 0)
                            {
                                @foreach (var notification in NewNotifications)
                                {
                                    <MudCard Elevation="3" Class="ma-1 pl-2">
                                        <MudCardContent>
                                            <MudItem Style="display:flex; justify-content: space-between;">
                                                <MudText Typo="Typo.h6" Class="mb-3">@notification.NotificationType</MudText>
                                                    <MudIcon Icon="@Icons.Material.Filled.Notifications"></MudIcon>
                                                </MudItem>
                                                <MudText Typo="Typo.body1">@notification.NotificationText</MudText>
                                                <MudText Typo="Typo.caption">@notification.MadeBy ~ @notification.EntryDate.ToString("dd/MM/yy")</MudText>
                                            </MudCardContent>
                                            <MudCardActions>
                                                <MudButton Style="border-radius: 20px" Class="mr-4" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Check" Color="Color.Primary" @onclick="@(() => updateStatus(notification))">@Localizer1["notifyRead"]</MudButton>
                                                <MudButton Style="border-radius: 20px" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="@(() => Delete(notification))">@Localizer1["notifyDelete"]</MudButton>
                                            </MudCardActions>
                                        </MudCard>
                                }
                            }
                            else
                            {
                                <MudCard Elevation="3" Class="ma-1">
                                    <MudCardHeader>
                                    </MudCardHeader>
                                    <MudCardContent>
                                        <MudItem Style="display:flex; justify-content:center">
                                            <MudText>@Localizer1["youDontHaveAnyNoficationsYet"]</MudText>
                                                <MudIcon Icon="@Icons.Material.Filled.EmojiEmotions"></MudIcon>
                                            </MudItem>
                                        </MudCardContent>
                                    </MudCard>
                            }

                        </MudItem>

                    </MudTabPanel>
                    <MudTabPanel Text="@Localizer1["notifyReadTitle"]" BadgeData="@ReadNotifications.Count" Icon="@Icons.Material.Filled.MarkEmailRead">
                        <MudItem Class="ma-1 small-scroll" Style="max-height: 70vh; overflow-y: scroll; width: 800px; overflow-x: scroll;">
                            @if (ReadNotifications.Count > 0)
                            {
                                @foreach (var notification in ReadNotifications)
                                {
                                    <MudCard Elevation="3" Class="ma-1 pl-2">
                                        <MudCardContent>
                                            <MudItem Style="display:flex; justify-content: space-between;">
                                                <MudText Typo="Typo.h6" Class="mb-3">@notification.NotificationType</MudText>
                                                    <MudIcon Icon="@Icons.Material.Filled.Notifications"></MudIcon>
                                                </MudItem>
                                                <MudText Typo="Typo.body1">@notification.NotificationText</MudText>
                                                <MudText Typo="Typo.caption">@notification.MadeBy ~ @notification.EntryDate.ToString("dd/MM/yy")</MudText>
                                            </MudCardContent>
                                            <MudCardActions>
                                                @*<MudButton Style="border-radius: 20px" Class="mr-4" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Check" Color="Color.Primary" @onclick="@(() => updateStatus(notification))">@Localizer1["notifyRead"]</MudButton>*@
                                                <MudButton Style="border-radius: 20px" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="@(() => Delete(notification))">@Localizer1["notifyDelete"]</MudButton>
                                            </MudCardActions>
                                        </MudCard>
                                }
                            }
                            else
                            {
                                <MudCard Elevation="3" Class="ma-1">
                                    <MudCardHeader>
                                    </MudCardHeader>
                                    <MudCardContent>
                                        <MudItem Style="display:flex; justify-content:center">
                                            <MudText>@Localizer1["youDontHaveAnyNoficationsYet"]</MudText>
                                                <MudIcon Icon="@Icons.Material.Filled.EmojiEmotions"></MudIcon>
                                            </MudItem>
                                        </MudCardContent>
                                    </MudCard>
                            }
                        </MudItem>

                    </MudTabPanel>
                    <MudTabPanel Text="@Localizer1["notifyAll"]" BadgeData="@AllNotifications.Count" Icon="@Icons.Material.Filled.MarkunreadMailbox">
                        <MudItem Class="ma-1 small-scroll" Style="max-height: 70vh; overflow-y: scroll; width: 800px; overflow-x: scroll;">
                            @foreach (var notification in AllNotifications)
                            {
                                @if (notification.IsAccepted && notification.IsActive)
                                {
                                    // accepted=true active=true
                                    <MudCard Elevation="3" Class="ma-1 pl-2">
                                        <MudCardContent>
                                            <MudItem Style="display:flex; justify-content: space-between;">
                                                <MudText Typo="Typo.h6" Class="mb-3">@notification.NotificationType</MudText>
                                                    <MudIcon Icon="@Icons.Material.Filled.Notifications"></MudIcon>
                                                </MudItem>
                                                <MudText Typo="Typo.body1">@notification.NotificationText</MudText>
                                                <MudText Typo="Typo.caption">@notification.MadeBy ~ @notification.EntryDate.ToString("dd/MM/yy")</MudText>
                                            </MudCardContent>
                                            <MudCardActions>
                                                <MudButton Style="border-radius: 20px" Class="mr-4" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Check" Color="Color.Primary" @onclick="@(() => updateStatus(notification))">@Localizer1["notifyRead"]</MudButton>
                                                <MudButton Style="border-radius: 20px" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="@(() => Delete(notification))">@Localizer1["notifyDelete"]</MudButton>
                                            </MudCardActions>
                                        </MudCard>
                                }
                                else if (!notification.IsAccepted && notification.IsActive)
                                {
                                    // accepted=false active=true
                                    <MudCard Elevation="3" Class="ma-1 pl-2">
                                        <MudCardContent>
                                            <MudItem Style="display:flex; justify-content: space-between;">
                                                <MudText Typo="Typo.h6" Class="mb-3">@notification.NotificationType</MudText>
                                                    <MudIcon Icon="@Icons.Material.Filled.Notifications"></MudIcon>
                                                </MudItem>
                                                <MudText Typo="Typo.body1">@notification.NotificationText</MudText>
                                                <MudText Typo="Typo.caption">@notification.MadeBy ~ @notification.EntryDate.ToString("dd/MM/yy")</MudText>
                                            </MudCardContent>
                                            <MudCardActions>
                                                @*<MudButton Style="border-radius: 20px" Class="mr-4" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Check" Color="Color.Primary" @onclick="@(() => updateStatus(notification))">@Localizer1["notifyRead"]</MudButton>*@
                                                <MudButton Style="border-radius: 20px" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="@(() => Delete(notification))">@Localizer1["notifyDelete"]</MudButton>
                                            </MudCardActions>
                                        </MudCard>
                                }
                                else if (notification.IsActive && !notification.IsAccepted)
                                {
                                    // accepted=true active=false
                                    <MudCard Elevation="3" Class="ma-1 pl-2">
                                        <MudCardContent>
                                            <MudItem Style="display:flex; justify-content: space-between;">
                                                <MudText Typo="Typo.h6" Class="mb-3">@notification.NotificationType</MudText>
                                                    <MudIcon Icon="@Icons.Material.Filled.Notifications"></MudIcon>
                                                </MudItem>
                                                <MudText Typo="Typo.body1">@notification.NotificationText</MudText>
                                                <MudText Typo="Typo.caption">@notification.MadeBy ~ @notification.EntryDate.ToString("dd/MM/yy")</MudText>
                                            </MudCardContent>
                                            <MudCardActions>
                                                <MudButton Style="border-radius: 20px" Class="mr-4" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Check" Color="Color.Primary" @onclick="@(() => updateStatus(notification))">@Localizer1["notifyRead"]</MudButton>
                                                @*<MudButton Style="border-radius: 20px" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="@(() => Delete(notification))">@Localizer1["notifyDelete"]</MudButton>*@
                                            </MudCardActions>
                                        </MudCard>
                                }
                                else
                                {
                                    // accepted=false active=false
                                    <MudCard Elevation="3" Class="ma-1 pl-2">
                                        <MudCardContent>
                                            <MudItem Style="display:flex; justify-content: space-between;">
                                                <MudText Typo="Typo.h6" Class="mb-3">@notification.NotificationType</MudText>
                                                    <MudIcon Icon="@Icons.Material.Filled.Notifications"></MudIcon>
                                                </MudItem>
                                                <MudText Typo="Typo.body1">@notification.NotificationText</MudText>
                                                <MudText Typo="Typo.caption">@notification.MadeBy ~ @notification.EntryDate.ToString("dd/MM/yy")</MudText>
                                            </MudCardContent>
                                            <MudCardActions>
                                                @*   <MudButton Style="border-radius: 20px" Class="mr-4" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Check" Color="Color.Primary" @onclick="@(() => updateStatus(notification))">@Localizer1["notifyRead"]</MudButton>
                                <MudButton Style="border-radius: 20px" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="@(() => Delete(notification))">@Localizer1["notifyDelete"]</MudButton>*@
                                            </MudCardActions>
                                        </MudCard>
                                }

                            }
                        </MudItem>
                    </MudTabPanel>


                </MudTabs>

            }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Ok" Class="mt-4">@Localizer1["closeLanguage"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudMessageBox @ref="mbox" Title="@Localizer1["warningLanguage"]" CancelText="Cancel">
        <MessageContent>

            @if (currentLanguage == "en-US")
        {
            <MudText Typo="Typo.h5">
                <b><i>@Localizer1["question1Language"] Español <MudIcon Icon="@MX"></MudIcon> ?</i></b>
            </MudText>
            <MudText>
                @Localizer1["msg1Language"]
            </MudText>
