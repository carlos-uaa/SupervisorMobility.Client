    private async void Delete(Notification notification)
    {
        bool confirm = await js.InvokeAsync<bool>("confirm", $"Are you sure you want delete this notification?");

        if (confirm)
        {

            var result = await NotifyServices.DeleteNotification(notification.NotificationID);

            if (result != null)
            {
                await updatenotifications();
            }
        }

        StateHasChanged();
    }

    private async void updateStatus(Notification notifyread)
    {

        bool confirm = await js.InvokeAsync<bool>("confirm", $"Are you sure you want to mark as read this notification?");

        if (confirm)
        {
            notifyread.IsAccepted = false;
            var result = await NotifyServices.ReadNotification(notifyread.NotificationID, notifyread);

            if (result != null)
            {
                await updatenotifications();
            }
        }

        StateHasChanged();
    }

