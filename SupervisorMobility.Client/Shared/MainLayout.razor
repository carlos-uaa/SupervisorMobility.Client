                await js.InvokeVoidAsync("localStorage.setItem", "i18nextLng", "en-US");
                currentLanguage = await js.InvokeAsync<string>("localStorage.getItem", "i18nextLng");
                NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
            }

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception Load Language: {ex.Message}");
        }

        switch (currentLanguage)
        {
            case "es-ES":
            case "es-419":
                var cultureInfo = new CultureInfo("es-ES");
                languageCheck = true;
                CultureInfo.DefaultThreadCurrentCulture = cultureInfo;
                CultureInfo.DefaultThreadCurrentUICulture = cultureInfo;
                break;
            case "en-US":
                var cultureInfous = new CultureInfo("en-US");
                CultureInfo.DefaultThreadCurrentCulture = cultureInfous;
                CultureInfo.DefaultThreadCurrentUICulture = cultureInfous;
                languageCheck = false;
                break;

        }

        CultureInfo currentCulture = Thread.CurrentThread.CurrentCulture;
        currentCulture.NumberFormat.NumberDecimalSeparator = ".";
        Dispose();

        while (!isApiConnected)
        {
            try
            {
                logged = await HasPropertyAsync();
                if (logged)
                {
                    await GetUserAsync();
                    GlobalData.LoggedUser = user.Name;
                    StateHasChanged();
                }

                isApiConnected = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Exception Api Connected: {ex.Message}");
                DisplayDialogErrorAPI = true;
                connection_attempt++;
                StateHasChanged();
                waitInterval += TimeSpan.FromSeconds(10);
            }
            if (user.UserId != 0)
            {
                Notificationtimer = new Timer(async state =>
                   {
                       try
                       {
                           Console.WriteLine($"try GetNotifications");
                           //GetNotifications(state);
                           await updatenotifications();
                           DisplayDialogErrorAPI = false;
                           StateHasChanged();
                           Notificationtimer.Change(StartInterval, StartInterval);
                           connection_attempt = 0;
                           waitInterval = TimeSpan.FromSeconds(0);
                       }
                       catch (Exception ex)
                       {
                           DisplayDialogErrorAPI = false;
                           StateHasChanged();
                           connection_attempt++;
                           waitInterval += TimeSpan.FromSeconds(10);
                           Notificationtimer.Change(waitInterval, waitInterval);
                           timeLeft = (int)(waitInterval.TotalMinutes * 60) + 3;
                           DisplayDialogErrorAPI = true;
                           StateHasChanged();
                       }
                   }, null, TimeSpan.Zero, TimeSpan.FromMinutes(10));

            }
            await Task.Delay(waitInterval);

        }






        //attendanceTimer = new Timer(GetAttendance, null, TimeSpan.Zero, TimeSpan.FromMinutes(60));




        StateHasChanged();
    }


