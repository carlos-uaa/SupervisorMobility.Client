@inject IAreaService AreaService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="delete" @onclick="DeleteArea"></MudIconButton>

@code {
    [CascadingParameter(Name = "PlantId")]
    public int Id { get; set; }

    [CascadingParameter(Name = "AreaId")]
    public int AreaId { get; set; }

    async void DeleteArea()
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this area?");

        if (confirm)
        {
            await AreaService.DeleteArea(Id, AreaId);
            NavigationManager.NavigateTo($"plants/plant/{Id}", forceLoad: true);
        }
    }
}