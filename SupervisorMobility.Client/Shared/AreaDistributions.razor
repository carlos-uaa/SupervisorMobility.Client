@inject IDistributionService DistributionService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
    <MudTabPanel Icon="@Icons.Material.Filled.ContentPaste" Text="Distributions">
        @if (_distributions.Count > 0)
        {
            <MudTable Items="_distributions" Hover="true" T="Distribution">
                <ToolBarContent>
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.Add" aria-label="add" @onclick="(() => CreateDistribution())"></MudIconButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudText Align="Align.Center">Distribution Id</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Code</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Description</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Status</MudText>
                    </MudTh>
                    <MudTh>
                        <MudText Align="Align.Center">Actions</MudText>
                    </MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="DistributionId">
                        <MudText Align="Align.Center">@context.DistributionId</MudText>
                    </MudTd>
                    <MudTd DataLabel="Code">
                        <MudText Align="Align.Center">@context.Code</MudText>
                    </MudTd>
                    <MudTd DataLabel="Description">
                        <MudText Align="Align.Center">@context.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsActive == true)
                        {
                            <MudText Align="Align.Center">
                                <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                            </MudText>
                        }
                        else
                        {
                            <MudText Align="Align.Center">
                                <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                            </MudText>
                        }
                    </MudTd>
                    <MudTd>
                        <MudText Align="Align.Center">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit" @onclick="(() => EditDistribution(context.DistributionId))"></MudIconButton>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="edit" @onclick="(() => DeleteDistribution(context.DistributionId))"></MudIconButton>
                        </MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">There are no distributions created for this area.</MudText>
            <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">
                <MudButton Color="Color.Info" @onclick="(() => CreateDistribution())">Create a new distribution</MudButton>
            </MudText>
        }
    </MudTabPanel>
</MudTabs>