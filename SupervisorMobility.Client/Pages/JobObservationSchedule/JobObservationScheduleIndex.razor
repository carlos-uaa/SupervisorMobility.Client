                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    @*Mud select of Groups *@
                                    <MudSelect T="int" Label="Group" Variant="Variant.Text" Placeholder="Select a Group" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@groupId" For="@(() => groupId)">
                                        @foreach (var type in _groups)
                                        {
                                            if (type.GroupId == user.GroupId)
                                            {
                                                <MudSelectItem Value="type.GroupId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                }
                            </td>
                            <td>

                                @if (user.UserType == 1)
                                {
                                    @if (plantId != 0 && areaId != 0)
                                    {
                                        @*Mud select for SSV for Admin *@
                                        <MudSelect T="int" Label="SSV" Variant="Variant.Text" Placeholder="All SSV" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)" SelectedValuesChanged="ShowSupervisors">
                                            <MudSelectItem Disabled="true" Value="0">All SSV</MudSelectItem>
                                            @foreach (var ssv in _SSVs)
                                            {
                                                <MudSelectItem Value="ssv.UserId">@($"{ssv.Name}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        @*Mud select for SSV *@
                                        <MudSelect T="int" Label="SSV" Variant="Variant.Text" Disabled Placeholder="Select an SSV" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)" >
                                            <MudSelectItem Disabled="true" Value="0">First Select an Area</MudSelectItem>
                                        </MudSelect>
                                    }

                                }
                                else if (user.UserType == 2)
                                {
                                    <MudTextField T="string" @bind-Value="ssv" Label="SSV" Required="true" RequiredError="SSV is required!" OnlyValidateIfDirty="true" ReadOnly/>
                                }
                                else if (user.UserType == 3)
                                {

                                    <MudTextField T="string" @bind-Value="ssv" Label="SSV" Required="true" RequiredError="SSV is required!" OnlyValidateIfDirty="true" ReadOnly />
                                }

                            </td>
                        </tr>
                        <tr>
                            <td>
                                @if (user.UserType == 1)
                                {

                                    @if (ssvId != 0 && plantId != 0)
                                    {
                                        @if (_supervisors.Count > 0)
                                        {
                                            <MudSelect T="int" Label="Supervisor" Variant="Variant.Text" Placeholder="All Supervisors" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@supervisorId" For="@(() => supervisorId)" SelectedValuesChanged="JobObservationsBySupervisor">
                                                <MudSelectItem Disabled="true" Value="0">All Supervisors</MudSelectItem>
                                                @foreach (var sv in _supervisors)
                                                {
                                                    <MudSelectItem Value="sv.UserId">
                                                        @($"{sv.Name}")
                                                    </MudSelectItem>
