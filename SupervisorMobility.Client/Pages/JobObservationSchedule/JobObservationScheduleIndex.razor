@page "/jobobservationschedule"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using System.Globalization;
@using System.Net.Http.Json;

@inject IJSRuntime JSRuntime
@inject IGroupService GroupService
@inject IChecklistService ChecklistService
@inject IDialogService DialogService
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IJobObservationService JobObservationService
@inject IUserService UsersService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager

<style>

    .scroll1::-webkit-scrollbar {
        width: 4px;
    }

</style>

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["jobObservationSchedule"]</PageTitle>
@*Breadcrumb links*@
<div style="display: flex; align-items: center; justify-content: space-between;">
    <MudItem>
        <MudBreadcrumbs Items="_links">
            <ItemTemplate Context="item">
                <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
            </ItemTemplate>
        </MudBreadcrumbs>
    </MudItem>
    <MudItem Style="text-align: end">
        <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
            <ActivatorContent>
                <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">@Localizer["showAllSymbols"]</MudButton>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Warning">@Localizer["programmed"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.PlayCircle" IconColor="Color.Warning">@Localizer["planned"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Block" IconColor="Color.Info">@Localizer["plannedWithSSVCoaching"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.StopCircle" IconColor="Color.Info">@Localizer["inProgress"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.RemoveCircle" IconColor="Color.Error">@Localizer["late"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.IncompleteCircle" IconColor="Color.Info">@Localizer["underReview"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Cancel" IconColor="Color.Error">@Localizer["rejected"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Circle" IconColor="Color.Success">@Localizer["finished"]</MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudItem>
</div>

@*Form*@
<MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
            <MudText Typo="Typo.h6">@Localizer["jobObservationSchedule"]</MudText>
            <MudToggleIconButton @bind-Toggled="@displayInfo" Class="ml-auto"
                                 Icon="@Icons.Material.Filled.KeyboardArrowDown" Title="Display Info"
                                 ToggledIcon="@Icons.Material.Filled.KeyboardArrowUp" ToggledTitle="Hide Info"/>
        </MudItem>
        @if(displayInfo){
        <MudPaper Class="d-flex align-center justify-center mud-width-full pl-4 pr-4" Elevation="0">
            <MudItem xs="12" sm="6" md="4" lg="4" Class="mr-4">
                <MudSimpleTable Style="overflow-x: auto;" Dense=true>
                    <tbody>
                        <tr>
                                <th colspan="2" style="text-align: center;">@Localizer["programmedJobObservation"] (@totalProgrammed)</th>
                        </tr>
                        <tr>
                            <td>
                                <div style="min-height: 15vh; overflow-y: scroll; max-height: 15vh; scroll-behavior: smooth; text-align:center;" class="scroll scroll1">
                                @if(totalProgrammed > 0){
                                    @foreach(var jobobs in _jobObservations){
                                        if (jobobs.Status == 7)
                                        {
                                            if(jobobs.StartDate?.Month == _yearMonth?.Month && jobobs.StartDate?.Year == _yearMonth?.Year){
                                                <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog3(jobobs.JobObservationId))">
                                                    <MudButton @onclick="(() => OpenDialog3(jobobs.JobObservationId))" Style="padding: 0px;" Class="ml-5 mr-5" Color="Color.Warning" FullWidth>
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" Style="font-size: 10px">@jobobs.Distribution?.Description</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.Info" />
                                                        <span style="font-weight: bold; font-size: 13px; cursor:pointer">@jobobs.JobObservationId</span>
                                                    </MudButton>
                                                </MudTooltip>
                                            }

                                        }
                                    }

                                }
                                else{
                                    if(plantId != 0 && areaId != 0 && ssvId != 0 && supervisorId != 0){
                                                                   <MudAlert Severity="Severity.Info" Class="mt-5">
                                            @Localizer["ThereAreNoJobObservationsProgrammedInSOSForThisSupervisor"]
                                        </MudAlert>
                                    }
                                    else if(plantId != 0 && areaId != 0 && ssvId != 0){
                                                                   <MudAlert Severity="Severity.Info" Class="mt-5">
                                            @Localizer["ThereAreNoJobObservationsProgrammedInSOSForThisSSV"]
                                        </MudAlert>
                                    }
                                    else if(plantId != 0 && areaId != 0){
                                                                   <MudAlert Severity="Severity.Info" Class="mt-5">
                                            @Localizer["ThereAreNoJobObservationsProgrammedInSOSForThisArea"]
                                        </MudAlert>
                                    }
                                    else if(plantId != 0){
                                                                   <MudAlert Severity="Severity.Info" Class="mt-5">
                                            @Localizer["ThereAreNoJobObservationsProgrammedInSOSForThisPlant"]
                                        </MudAlert>
                                    } 
                                    else{

                                        <MudAlert Severity="Severity.Info" Class="mt-5">
                                                @Localizer["ThereAreNoJobObservationsProgrammedInSOSForThisMonth"]
                                        </MudAlert>
                                    }


                                }
                                </div>
                            </td>

                        </tr>
                        <tr>
                            <td colspan="2">
                                <div class="pt-1 pb-4 pr-2">
                                    <MudDatePicker Label=@Localizer["monthYear"] OpenTo="OpenTo.Month" FixDay="1" DateFormat="MMMM / yyyy" PickerVariant="PickerVariant.Dialog" Color="Color.Info" AdornmentColor="Color.Info" DateChanged=@OnDateChanged Date="_yearMonth" />
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem xs="12" sm="6" md="7" lg="7" Class="ml-2 mb-4">
                <MudSimpleTable Style="overflow-x: auto;" Dense=true Class="pt-3 pb-3">
                    <tbody>
                        <tr>
                            <td width="50%">
                                @if (user.UserType == 1)
                                {
                                    @*Mud select of Plants for Admin*@
                                    <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text"  Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@plantId" For="@(() => plantId)" SelectedValuesChanged="ShowAreas">
                                        <MudSelectItem Value="0">@Localizer["allPlants"]</MudSelectItem>
                                        @foreach (var type in _plants)
                                        {
                                            <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    @*Mud select of Plants*@
                                    <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text"  Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@plantId" For="@(() => plantId)" SelectedValuesChanged="ShowAreas">
                                        @foreach (var type in _plants)
                                        {
                                            if (type.PlantId == user.PlantId)
                                            {
                                                <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                }

                            </td>
                            <td>
                                @if (user.UserType == 1 || user.UserType == 5)
                                {
                                    @if (plantId != 0)
                                    {
                                        @*Mud select of Areas for Admin*@
                                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowSSV">
                                            <MudSelectItem Value="0">@Localizer["allAreas"]</MudSelectItem>
                                            @foreach (var type in _areas)
                                            {
                                                <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        @*Mud select for SSV *@
                                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Disabled  Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAPlant"]</MudSelectItem>
                                        </MudSelect>
                                    }

                                }
                                else if (user.UserType == 2)
                                {
                                    @*Mud select of Areas for SSV *@
                                    <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text"  Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowSSV">
                                        <MudSelectItem Value="0">@Localizer["allAreas"]</MudSelectItem>
                                        @foreach (var type in user.Areas)
                                        {
                                            <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    @*Mud select of Areas for SV *@
                                    <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowSSV">
                                        @foreach (var type in _areas)
                                        {
                                            if (type.AreaId == user.AreaId)
                                            {

                                                <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @if (user.UserType == 1 || user.UserType == 5)
                                {
                                    @*Mud select of Groups for Admin*@
                                    <MudSelect T="int" Label=@Localizer["group"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@groupId" For="@(() => groupId)">
                                        <MudSelectItem Disabled="true" Value="0">@Localizer["selectAGroup"]</MudSelectItem>
                                        @foreach (var type in _groups)
                                        {
                                            <MudSelectItem Value="type.GroupId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    @*Mud select of Groups *@
                                    <MudSelect T="int" Label=@Localizer["group"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@groupId" For="@(() => groupId)">
                                        @foreach (var type in _groups)
                                        {
                                            if (type.GroupId == user.GroupId)
                                            {
                                                <MudSelectItem Value="type.GroupId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                }
                            </td>
                            <td>

                                @if (user.UserType == 1)
                                {
                                    @if (plantId != 0 && areaId != 0)
                                    {
                                        @*Mud select for SSV for Admin *@
                                        <MudSelect T="int" Label="SSV" Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)" SelectedValuesChanged="ShowSupervisors">
                                            <MudSelectItem Value="0">@Localizer["allSSV"]</MudSelectItem>
                                            @foreach (var ssv in _SSVs)
                                            {
                                                <MudSelectItem Value="ssv.UserId">@($"{ssv.Name}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        @*Mud select for SSV *@
                                        <MudSelect T="int" Label="SSV" Variant="Variant.Text" Disabled Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)" >
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnArea"]</MudSelectItem>
                                        </MudSelect>
                                    }

                                }
                                else if (user.UserType == 2)
                                {
                                    <MudTextField T="string" @bind-Value="ssv" Label="SSV" Required="true" OnlyValidateIfDirty="true" ReadOnly/>
                                }
                                else if (user.UserType == 3)
                                {

                                    <MudTextField T="string" @bind-Value="ssv" Label="SSV" Required="true" OnlyValidateIfDirty="true" ReadOnly />
                                }
                                else if (user.UserType == 5)
                                {
                                    @if (plantId != 0 && areaId != 0)
                                    {
                                        @if(user.Subordinates!.Count > 0){
                                            @*Mud select for SSV for Admin *@
                                            <MudSelect T="int" Label="SSV" Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)" SelectedValuesChanged="ShowSupervisors">
                                                <MudSelectItem Value="0">@Localizer["allSSV"]</MudSelectItem>
                                                @foreach (var ssv in user.Subordinates)
                                                {
                                                    @*if (ssv.PlantId == plantId && ssv.Areas?.ToList().FindIndex(a => a.AreaId == areaId) != -1){*@
                                                        <MudSelectItem Value="ssv.UserId">@($"{ssv.Name}")</MudSelectItem>
                                                    @*}*@
                                                }
                                            </MudSelect>
                                        }
                                        else
                                        {
                                            <MudAlert Severity="Severity.Info" Class="mt-5">
                                                @Localizer["ssvHasNoSupervisors"]
                                            </MudAlert>
                                        }
                                    }
                                    else
                                    {
                                        @*Mud select for SSV *@
                                        <MudSelect T="int" Label="SSV" Variant="Variant.Text" Disabled Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)" >
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnArea"]</MudSelectItem>
                                        </MudSelect>
                                    }

                                }

                            </td>
                        </tr>
                        <tr>
                            <td>
                                @if (user.UserType == 1 || user.UserType == 5)
                                {
                                    @if (ssvId != 0 && plantId != 0)
                                    {
                                        @if (_supervisors.Count > 0)
                                        {
                                            <MudSelect T="int" Label="Supervisor" Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@supervisorId" For="@(() => supervisorId)" SelectedValuesChanged="JobObservationsBySupervisor">
                                                <MudSelectItem Value="0">@Localizer["allSupervisors"]</MudSelectItem>
                                                @foreach (var sv in _supervisors)
                                                {
                                                    <MudSelectItem Value="sv.UserId">
                                                        @($"{sv.Name}")
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        }
                                        else
                                        {
                                            <MudAlert Severity="Severity.Info" Class="mt-5">
                                                @Localizer["ssvHasNoSupervisors"]
                                            </MudAlert>
                                        }
                                    }
                                    else
                                    {
                                        <MudSelect T="int" Label="Supervisor" Disabled Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="supervisorId" For="@(() => supervisorId)">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnSSV"]</MudSelectItem>
                                        </MudSelect>
                                    }
                                }
                                else if (user.UserType == 2)
                                {
                                    @if (areaId != 0)
                                    {
                                        @if (_supervisors.Count > 0)
                                        {
                                            <MudSelect T="int" Label="Supervisor" Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@supervisorId" For="@(() => supervisorId)" SelectedValuesChanged="JobObservationsBySupervisor">
                                                <MudSelectItem Value="0">@Localizer["allSupervisors"]</MudSelectItem>
                                                @foreach (var sv in _supervisors)
                                                {
                                                    <MudSelectItem Value="sv.UserId">
                                                        @($"{sv.Name}")
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        }
                                        else
                                        {
                                            <MudAlert Severity="Severity.Info" Class="mt-5">
                                                @Localizer["ssvAreaHasNoSupervisors"]
                                            </MudAlert>
                                        }
                                    }
                                    else
                                    {
                                        <MudSelect T="int" Label="Supervisor" Disabled Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="supervisorId" For="@(() => supervisorId)">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnArea"]</MudSelectItem>
                                        </MudSelect>
                                    }
                                }
                                else if (user.UserType == 3)
                                {
                                    <MudTextField T="string" @bind-Value="supervisor" Label="Supervisor" Required="true"  OnlyValidateIfDirty="true" ReadOnly/>

                                }
                            </td>
                            <td>
                                @*Mud select of Status *@
                                <MudSelect T="int" Label=@Localizer["status"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@optionStatus">
                                    <MudSelectItem Value="0">@Localizer["allStatus"]</MudSelectItem>
                                    <MudSelectItem Value="1">@Localizer["planned"]</MudSelectItem>
                                    <MudSelectItem Value="2">@Localizer["inProgress"]</MudSelectItem>
                                    <MudSelectItem Value="3">@Localizer["late"]</MudSelectItem>
                                    <MudSelectItem Value="4">@Localizer["underReview"]</MudSelectItem>
                                    <MudSelectItem Value="5">@Localizer["rejected"]</MudSelectItem>
                                    <MudSelectItem Value="6">@Localizer["finished"]</MudSelectItem>
                                </MudSelect>
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
        </MudPaper>
        }
</MudGrid>
<MudGrid Justify="Justify.Center" Class="overflow-x-auto mb-12">
    <MudItem lg="12" md="12" sm="12" xs="12" Class="text-align: center;">
        <MudItem Style="display: flex; justify-content: space-evenly;">
            <MudText Typo="Typo.h6">
            <MudTooltip Text=@Localizer["lastMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Color="Color.Info" @onclick="@(()=>LastMonth())" Class="mr-4"></MudIconButton>
            </MudTooltip>
                @showMonth @year
            <MudTooltip Text=@Localizer["nextMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowForwardIos" Color="Color.Info" @onclick="@(()=>NextMonth())" Class="ml-4"></MudIconButton>
            </MudTooltip>
            </MudText>
        </MudItem>
        @*FixedHeader=true Style="height:70vh" *@
        <MudSimpleTable Striped=true Bordered=true Elevation="6" Class="calendar-table rounded">
            <thead>
                <tr style="cursor:default">
                    @for (var dayIndex = 0; dayIndex < days.Count(); dayIndex++)
                    {
                        <th style="text-align: center; width:14.28%">
                            @days[dayIndex].ToString().ToUpper()
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @for (var weekIndex = 0; weekIndex < weeks.Count(); weekIndex++)
                {
                    <tr>
                        @for (var dayIndex = 0; dayIndex < weeks[weekIndex].Dates.Count(); dayIndex++)
                        {
                            var day = weeks[weekIndex].Dates[dayIndex].DayName;
                            var wIndex = weekIndex;
                            var dIndex = dayIndex;

                            @if (weekIndex == 0 && (day == "31" || day == "30" || day == "29" || day == "28" || day == "27" || day == "26" || day == "25"))
                            {
                                <td style="text-align: end; width:14.28%;">
                                    <span style="color: #DDDDDD">@weeks[weekIndex].Dates[dayIndex].DayName</span>
                                    <div style="min-height: 16vh"></div>
                                </td>
                            }
                            else
                            {
                                var date = @weeks[weekIndex].Dates[dayIndex].DateValue;

                                var dayName = @weeks[weekIndex].Dates[dayIndex].DayName;

                                var compare = DateTime.ParseExact(date, "d/M/yyyy", null);
                                <td style="text-align: end; width:14.28%;">
                                    @if (CultureInfo.CurrentCulture.Name == "en-US" || CultureInfo.CurrentCulture.Name == "en")
                                    {
                                        var todayFormatedDay = DateTime.ParseExact(date, "d/M/yyyy", CultureInfo.InvariantCulture);
                                        var todayEnglish = todayFormatedDay.Month.ToString() + "/" + todayFormatedDay.Day.ToString() + "/" + todayFormatedDay.Year.ToString();

                                        @if (DateTime.Now.ToShortDateString() == todayEnglish)
                                        {
                                            <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                                <MudMenuItem Icon="@Icons.Material.Filled.PlaylistAdd" @onclick="@(()=>OpenDialog4(date))" @ontouchstart="@(()=>OpenDialog4(date))">
                                                    @Localizer["programmedJobObservation"]
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="@(()=>PlanJobObservation(date))" @ontouchstart="@(()=>PlanJobObservation(date))">
                                                    @Localizer["planJobObservation"]
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Add" @onclick="@(()=>CreateJobObservation(date))" @ontouchstart="@(()=>CreateJobObservation(date))">
                                                    @Localizer["createJobObservation"]
                                                </MudMenuItem>
                                            </MudMenu>
                                        }
                                        else
                                        {
                                            <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName AnchorOrigin="Origin.BottomCenter">
                                                 <MudMenuItem Icon="@Icons.Material.Filled.PlaylistAdd" @onclick="@(()=>OpenDialog4(date))" @ontouchstart="@(()=>OpenDialog4(date))">
                                                    @Localizer["programmedJobObservation"]
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="@(()=>PlanJobObservation(date))" @ontouchstart="@(()=>PlanJobObservation(date))">
                                                    @Localizer["planJobObservation"]
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Add" @onclick="@(()=>CreateJobObservation(date))" @ontouchstart="@(()=>CreateJobObservation(date))">
                                                    @Localizer["createJobObservation"]
                                                </MudMenuItem>
                                            </MudMenu>
                                        }
                                    }
                                    else
                                    {
                                        @if (DateTime.Now.ToShortDateString() == date)
                                        {
                                            <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                                <MudMenuItem Icon="@Icons.Material.Filled.PlaylistAdd" @onclick="@(()=>OpenDialog4(date))" @ontouchstart="@(()=>OpenDialog4(date))">
                                                    @Localizer["programmedJobObservation"]
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="@(()=>PlanJobObservation(date))" @ontouchstart="@(()=>PlanJobObservation(date))">
                                                    @Localizer["planJobObservation"]
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Add" @onclick="@(()=>CreateJobObservation(date))" @ontouchstart="@(()=>CreateJobObservation(date))">
                                                    @Localizer["createJobObservation"]
                                                </MudMenuItem>
                                            </MudMenu>
                                        }
                                        else
                                        {
                                            <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName AnchorOrigin="Origin.BottomCenter">
                                                <MudMenuItem Icon="@Icons.Material.Filled.PlaylistAdd" @onclick="@(()=>OpenDialog4(date))" @ontouchstart="@(()=>OpenDialog4(date))">
                                                    @Localizer["programmedJobObservation"]
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="@(()=>PlanJobObservation(date))" @ontouchstart="@(()=>PlanJobObservation(date))">
                                                    @Localizer["planJobObservation"]
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Add" @onclick="@(()=>CreateJobObservation(date))" @ontouchstart="@(()=>CreateJobObservation(date))">
                                                    @Localizer["createJobObservation"]
                                                </MudMenuItem>
                                            </MudMenu>
                                        }
                                    }
