@page "/jobobservationschedule"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using System.Globalization;
@using System.Net.Http.Json;

@inject IJSRuntime JSRuntime
@inject IGroupService GroupService
@inject IChecklistService ChecklistService
@inject IDialogService DialogService
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IJobObservationService JobObservationService
@inject IUserService UsersService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager

<style>

    .scroll1::-webkit-scrollbar {
        width: 4px;
    }

</style>

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["jobObservationSchedule"]</PageTitle>
@*Breadcrumb links*@
<div style="display: flex; align-items: center; justify-content: space-between;">
    <MudItem>
        <MudBreadcrumbs Items="_links">
            <ItemTemplate Context="item">
                <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
            </ItemTemplate>
        </MudBreadcrumbs>
    </MudItem>
    <MudItem Style="text-align: end">
        <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
            <ActivatorContent>
                <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">@Localizer["showAllSymbols"]</MudButton>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Icon="@Icons.Material.Filled.PlayCircle" IconColor="Color.Warning">@Localizer["planned"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Block" IconColor="Color.Info">@Localizer["plannedWithSSVCoaching"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.StopCircle" IconColor="Color.Info">@Localizer["inProgress"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.RemoveCircle" IconColor="Color.Error">@Localizer["late"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.IncompleteCircle" IconColor="Color.Info">@Localizer["underReview"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Cancel" IconColor="Color.Error">@Localizer["rejected"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Circle" IconColor="Color.Success">@Localizer["finished"]</MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudItem>
</div>

@*Form*@
