</MudGrid>
<MudGrid Justify="Justify.Center" Class="overflow-x-auto mb-12">
    <MudItem lg="12" md="12" sm="12" xs="12">
        <MudItem Style="text-align: center">
            <MudText Typo="Typo.h6">@showMonth @year</MudText>
        </MudItem>
        @*FixedHeader=true Style="height:70vh" *@
        <MudSimpleTable Striped=true Bordered=true Elevation="6" Class="calendar-table rounded">
            <thead>
                <tr style="cursor:default">
                    @for (var dayIndex = 0; dayIndex < days.Count(); dayIndex++)
                    {
                        <th style="text-align: center; width:14.28%">
                            @days[dayIndex]
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @for (var weekIndex = 0; weekIndex < weeks.Count(); weekIndex++)
                {
                    <tr>
                        @for (var dayIndex = 0; dayIndex < weeks[weekIndex].Dates.Count(); dayIndex++)
                        {
                            var day = weeks[weekIndex].Dates[dayIndex].DayName;
                            var wIndex = weekIndex;
                            var dIndex = dayIndex;
                            @if (weekIndex == 0 && (day == "31" || day == "30" || day == "29" || day == "28" || day == "27" || day == "26" || day == "25"))
                            {
                                <td style="text-align: end; width:14.28%;">
                                    <span style="color: #DDDDDD">@weeks[weekIndex].Dates[dayIndex].DayName</span>
                                    <div style="min-height: 16vh"></div>
                                </td>
                            }
                            else
                            {
                                var date = @weeks[weekIndex].Dates[dayIndex].DateValue;

                                var dayName = @weeks[weekIndex].Dates[dayIndex].DayName;
                                <td style="text-align: end; width:14.28%;">
                                    @if (CultureInfo.CurrentCulture.Name == "en-US" || CultureInfo.CurrentCulture.Name == "en")
                                    {
                                        var todayFormatedDay = DateTime.ParseExact(date, "d/M/yyyy", CultureInfo.InvariantCulture);
                                        var todayEnglish = todayFormatedDay.Month.ToString() + "/" + todayFormatedDay.Day.ToString() + "/" + todayFormatedDay.Year.ToString();

                                        @if (DateTime.Now.ToShortDateString() == todayEnglish)
                                        {
                                            <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                                <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="@(()=>PlanJobObservation(date))" @ontouchstart="@(()=>PlanJobObservation(date))">
                                                    Plan job observation
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Add" @onclick="@(()=>CreateJobObservation(date))" @ontouchstart="@(()=>CreateJobObservation(date))">
                                                    Create new job observation
                                                </MudMenuItem>
                                            </MudMenu>
                                        }
                                        else
                                        {
                                            <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName AnchorOrigin="Origin.BottomCenter">
                                                <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="@(()=>PlanJobObservation(date))" @ontouchstart="@(()=>PlanJobObservation(date))">
                                                    Plan job observation
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Add" @onclick="@(()=>CreateJobObservation(date))" @ontouchstart="@(()=>CreateJobObservation(date))">
                                                    Create new job observation
                                                </MudMenuItem>
                                            </MudMenu>
                                        }
                                    }
                                    else
                                    {
                                        @if (DateTime.Now.ToShortDateString() == date)
                                        {
                                            <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                                <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="@(()=>PlanJobObservation(date))" @ontouchstart="@(()=>PlanJobObservation(date))">
                                                    Plan job observation
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Add" @onclick="@(()=>CreateJobObservation(date))" @ontouchstart="@(()=>CreateJobObservation(date))">
                                                    Create new job observation
                                                </MudMenuItem>
                                            </MudMenu>
                                        }
                                        else
                                        {
                                            <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName AnchorOrigin="Origin.BottomCenter">
                                                <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="@(()=>PlanJobObservation(date))" @ontouchstart="@(()=>PlanJobObservation(date))">
                                                    Plan job observation
                                                </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Add" @onclick="@(()=>CreateJobObservation(date))" @ontouchstart="@(()=>CreateJobObservation(date))">
                                                    Create new job observation
                                                </MudMenuItem>
                                            </MudMenu>
                                        }
                                    }

                                    <div style="min-height: 16vh; overflow-y: scroll; max-height: 16vh; scroll-behavior: smooth;" class="scroll scroll1">
                                        @foreach (var jobobs in _jobObservations)
                                        {
                                            var compare = DateTime.ParseExact(date, "d/M/yyyy", null);
                                            var time1 = jobobs.StartDate?.ToString("HH:mm");
                                            var time2 = jobobs.EndDate?.ToString("HH:mm");

                                            if (Convert.ToDateTime(jobobs.StartDate?.ToShortDateString()).Date <= Convert.ToDateTime(compare.ToShortDateString()).Date && Convert.ToDateTime(compare.ToShortDateString()).Date <= Convert.ToDateTime(jobobs.EndDate?.ToShortDateString()).Date && plantId == jobobs.PlantId && areaId == jobobs.AreaId)
                                            {
                                                //Ends the same day
                                                if (Convert.ToDateTime(compare.ToShortDateString()).Date == Convert.ToDateTime(jobobs.StartDate?.ToShortDateString()).Date && Convert.ToDateTime(compare.ToShortDateString()).Date == Convert.ToDateTime(jobobs.EndDate?.ToShortDateString()).Date)
                                                {
                                                    //Status filter
                                                    switch (optionStatus)
                                                    {
                                                        case 0:

                                                            //Programmed
                                                            if (jobobs.Status == 1)
                                                            {
                                                                <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                    <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Warning">
                                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                        <MudIcon Icon="@Icons.Material.Filled.PlayCircle" />
                                                                    </MudButton>
                                                                    <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Operator.Name</span>
                                                                </MudTooltip>
                                                            }
                                                            //In Progress
                                                            else if (jobobs.Status == 2)
                                                            {
                                                                <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                    <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Info">
                                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                        <MudIcon Icon="@Icons.Material.Filled.StopCircle" />
                                                                    </MudButton>
                                                                    <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Operator.Name</span>
                                                                </MudTooltip>
                                                            }

                                                            //Late job observations
                                                            else if (jobobs.Status == 3)
                                                            {
                                                                <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                    <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Error">
                                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                        <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" />
                                                                    </MudButton>
                                                                    <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Operator.Name</span>
                                                                </MudTooltip>
                                                            }

                                                            //Under Review job observations
                                                            else if (jobobs.Status == 4)
                                                            {
                                                                <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                    <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Info">
                                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                        <MudIcon Icon="@Icons.Material.Filled.IncompleteCircle" />
