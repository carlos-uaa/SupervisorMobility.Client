                                    {
                                        <MudSelect T="int" Label="Supervisor" Disabled Variant="Variant.Text" Placeholder="Select a Supervisor" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="supervisorId" For="@(() => supervisorId)">
                                            <MudSelectItem Disabled="true" Value="0">First Select an Area</MudSelectItem>
                                        </MudSelect>
                                    }
                                }
                                else if (user.UserType == 3)
                                {
                                    <MudTextField T="string" @bind-Value="supervisor" Label="Supervisor" Required="true" RequiredError="User name is required!" OnlyValidateIfDirty="true" />

                                }
                            </td>
                            <td>
                                @*Mud select of Status *@
                                <MudSelect T="int" Label="Status" Variant="Variant.Text" Placeholder="Select a Group" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@optionStatus">
                                    <MudSelectItem Value="0">All Status</MudSelectItem>
                                    <MudSelectItem Value="1">Planned</MudSelectItem>
                                    <MudSelectItem Value="2">In Progress</MudSelectItem>
                                    <MudSelectItem Value="3">Late</MudSelectItem>
                                    <MudSelectItem Value="4">Under Review</MudSelectItem>
                                    <MudSelectItem Value="5">Rejected</MudSelectItem>
