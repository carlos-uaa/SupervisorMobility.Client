@page "/hrischedule"

@using System.Globalization
@using SupervisorMobility.Client.Data.Entities

@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService

<style>
	.hri-calendar-wrap {
		width: 100%;
	}

	.scroll1::-webkit-scrollbar {
		width: 2px;
	}

	.hri-calendar-table {
		table-layout: fixed;
	}

	.hri-calendar-table th,
	.hri-calendar-table td {
		width: 14.28%;
	}

	.hri-day-cell {
		min-height: 11vh;
		max-height: 15vh;
		overflow-y: auto;
		padding: 0.2rem 0.35rem;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.hri-day-num {
		font-size: 0.85rem;
		font-weight: 600;
		text-align: end;
		padding-right: 0.8rem;
	}

	.hri-day-head {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		min-height: 28px;
	}

	.hri-day-num-muted {
		color: #b8b8b8;
	}

	.hri-event-chip {
		font-size: 0.72rem;
		line-height: 1.15;
		justify-content: flex-start;
		height: auto;
		padding: 2px 6px;
		margin: 0 0.25rem;
	}

	.hri-scroll {
		scroll-behavior: smooth;
		scrollbar-width: none;
	}

	.hri-scroll::-webkit-scrollbar {
		width: 2px;
	}

	.calendar-item {
		font-size: 10px;
		color: black;
		cursor: pointer;
		width: 14vh;
	}
</style>

<PageTitle>Supervisor Mobility | HRI Schedule</PageTitle>

<MudGrid Justify="Justify.Center" Class="hri-calendar-wrap overflow-x-auto">
	<MudItem xs="12" Class="d-flex justify-space-between align-center mb-3">
		<MudText Typo="Typo.h6" Class="d-flex align-center">
			<MudTooltip Text="Mes anterior" Arrow="true" Placement="Placement.Top" Color="Color.Info">
				<MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Color="Color.Info" OnClick="LastMonth" Class="mr-3" />
			</MudTooltip>

			<span style="min-width: 11rem; max-width: 14rem;">
				<MudDatePicker OpenTo="OpenTo.Month" FixDay="1" DateFormat="MMMM / yyyy" PickerVariant="PickerVariant.Dialog" Color="Color.Info" Date="@_yearMonth" DateChanged="OnDateChangedAsync" />
			</span>

			<MudTooltip Text="Mes siguiente" Arrow="true" Placement="Placement.Top" Color="Color.Info">
				<MudIconButton Icon="@Icons.Material.Filled.ArrowForwardIos" Color="Color.Info" OnClick="NextMonth" Class="ml-3" />
			</MudTooltip>
		</MudText>

		<MudItem Class="d-flex align-center">
			<MudButton StartIcon="@Icons.Material.Filled.AddTask" Color="Color.Primary" Href="/hri/form" Class="mr-3">
				Nuevo HRI
			</MudButton>

			<MudSelect T="string" Label="NameOfItem" Variant="Variant.Text" Style="width: 14vw; min-width: 12rem" AnchorOrigin="Origin.BottomCenter" @bind-Value="_nameOfItemFilter" Dense Class="mr-2">
				<MudSelectItem Value='@("ALL")'>Todos</MudSelectItem>
				@foreach (var hri in _hris)
				{
					<MudSelectItem Value="@hri.NameOfItem">@hri.NameOfItem</MudSelectItem>
				}
			</MudSelect>

			<MudSelect T="int" Label="HriScheduleItem" Variant="Variant.Text" Style="width: 18vw; min-width: 16rem" AnchorOrigin="Origin.BottomCenter" @bind-Value="_scheduleItemFilter" Dense Class="mr-2" Disabled="@(_nameOfItemFilter == "ALL")">
				<MudSelectItem Value="0">Todos</MudSelectItem>
				@foreach (var template in HRIScheduleCatalog.Templates.OrderBy(t => t.ItemNumber))
				{
					<MudSelectItem Value="@template.ItemNumber">@($"{template.ItemNumber}. {template.Title}")</MudSelectItem>
				}
			</MudSelect>

			<MudSelect T="int" Label="Turno" Variant="Variant.Text" Style="width: 10vw; min-width: 9rem" AnchorOrigin="Origin.BottomCenter" @bind-Value="_shiftFilter" Dense Class="mr-2">
				<MudSelectItem Value="0">Todos</MudSelectItem>
				<MudSelectItem Value="1">1er T</MudSelectItem>
				<MudSelectItem Value="2">2do T</MudSelectItem>
				<MudSelectItem Value="3">3er T</MudSelectItem>
			</MudSelect>

			<MudSelect T="int" Label="@Localizer["status"]" Variant="Variant.Text" Style="width: 13vw; min-width: 12rem" AnchorOrigin="Origin.BottomCenter" @bind-Value="_statusFilter" Dense>
				<MudSelectItem Value="0">
					<span style="display: flex; align-items: center;">
						<MudIcon Icon="@Icons.Material.Filled.BubbleChart" Class="mr-2"></MudIcon>
						@Localizer["allStatus"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="8" Disabled>@Localizer["SOS Program"]</MudSelectItem>
				<MudSelectItem Value="7">
