						<MudIconButton Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Class="mr-2" Variant="Variant.Filled" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["inProgress"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="13">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Class="mr-2" Variant="Variant.Filled" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["late"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="14">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Class="mr-2" Variant="Variant.Filled" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["underReview"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="15">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Class="mr-2" Variant="Variant.Filled" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["rejected"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="16">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Class="mr-2" Variant="Variant.Filled" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["finished"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="18" Disabled>@Localizer["PAT"]</MudSelectItem>
				<MudSelectItem Value="27">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Class="mr-2" Variant="Variant.Outlined" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["programmed"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="21">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Class="mr-2" Variant="Variant.Outlined" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["planned"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="22">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Class="mr-2" Variant="Variant.Outlined" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["inProgress"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="23">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Class="mr-2" Variant="Variant.Outlined" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["late"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="24">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Class="mr-2" Variant="Variant.Outlined" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["underReview"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="25">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Class="mr-2" Variant="Variant.Outlined" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["rejected"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="26">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Class="mr-2" Variant="Variant.Outlined" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["finished"]
					</span>
				</MudSelectItem>
			</MudSelect>
