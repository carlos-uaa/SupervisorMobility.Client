						<MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Class="mr-2" Variant="Variant.Filled" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["programmed"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="11">
					<span style="display: flex; align-items: center;">
						<MudIconButton Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Class="mr-2" Variant="Variant.Filled" Size="Size.Small" Style="margin-top: -6px"></MudIconButton>
						@Localizer["planned"]
					</span>
				</MudSelectItem>
				<MudSelectItem Value="12">
