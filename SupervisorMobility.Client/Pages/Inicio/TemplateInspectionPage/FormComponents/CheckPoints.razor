<tr>
    <td style="width:2.5vw;">1</td>
    <td colspan="2" style="width:13.75vw;">
        APILAMIENTO CORRECTO<br /> <span style="font-size:10px;">(sin desplazamiento)</span>
        @if (pilingImage != null)
        {
            <br />
            <MudImage Src="@pilingImage" Alt="Image" Elevation="25" Height="50" Width="75" />
        }
    </td>
    <td style="width:13.75vw;">Acero: Max 5mm</td>
    @for (int i = 0; i < 7; i++)
    {
        <td>
            <MudText>A</MudText>
        </td>
    }
</tr>
<tr>
    <td rowspan="@(Dimensions.Count+1)" style="width:2.5vw;">2</td>
    <td colspan="2" rowspan="@(Dimensions.Count+1)" style="width:13.75vw;">DIMENSIONAL</td>
</tr>
@foreach (var item in Dimensions)
{
    <tr>
        <td class="CheckElement" style="text-align:center;width:13.75vw;">
            <MudText>@item.Value.Item1</MudText>
            @if (!string.IsNullOrEmpty(item.Value.Item2))
            {
                <br />
                <MudImage Src="@item.Value.Item2" Alt="Image" Elevation="25" Height="50" Width="75" />
            }
        </td>
        @for (int i = 0; i < 7; i++)
        {
            <td>
            </td>
        }
    </tr>
}
<tr>
    <td style="width:2.5vw;">3</td>
    <td colspan="2" style="width:13.75vw;">PLANTILLA NO DEBE PRESENTAR DEFECTO</td>
    <td style="width:13.75vw;"> </td>
    @for (int i = 0; i < 7; i++)
    {
        <td>
        </td>
    }
</tr>
<tr>
    <td style="width:2.5vw;">4</td>
    <td colspan="2" style="width:13.75vw;">ESPESOR</td>
    <td style="width:13.75vw;"> </td>
    @for (int i = 0; i < 7; i++)
    {
        <td>
        </td>
    }
</tr>
<tr>
    <td style="width:2.5vw;">5</td>
    <td colspan="2" style="width:13.75vw;">ALTURA DE REBABA</td>
    <td style="width:13.75vw;"> </td>
    @for (int i = 0; i < 7; i++)
    {
        <td>
        </td>
    }
</tr>
<tr>
    <td style="width:2.5vw;">6</td>
    <td colspan="2" style="width:13.75vw;">CANTIDAD DE BARRENOS</td>
    <td style="width:13.75vw;">
        <h4><b>N/A</b></h4>
    </td>
    @for (int i = 0; i < 7; i++)
    {
        <td>
            N/A
        </td>
    }
</tr>
<tr>
    <td style="width:2.5vw;">7</td>
    <td colspan="2" style="width:13.75vw;">ESPECIFICACION DE LA LAMINA</td>
    <td style="width:13.75vw;">
        SP 781 BE<br />
        SP 783 BE
    </td>
    @for (int i = 0; i < 7; i++)
    {
        <td>
        </td>
    }
</tr>
<tr>
    <td style="width:2.5vw;">8</td>
    <td colspan="2" style="width:13.75vw;">
        PLANICIDAD<br />
        <span style="font-size:10px;">(Solo cuando se solicite y/o a criterio del inspector)</span>
    </td>
    <td style="width:13.75vw;">
        11mm (MAXIMO)
    </td>
    @for (int i = 0; i < 7; i++)
    {
        <td>
        </td>
    }
</tr>
<tr>
    <td rowspan="@(MechanicalPrpts.Count+1)" style="width:2.5vw;">9</td>
    <td rowspan="@(MechanicalPrpts.Count+1)" style="width:5vw;overflow-x:clip;padding:0px;align-items:center;">
        <div style="text-align:center; max-inline-size:30ch; writing-mode: vertical-rl; transform: rotate(180deg);">
            PROPIEDADES MECANICAS
        </div>
    </td>
    <td rowspan="@(MechanicalPrpts.Count+1)" style="width:8.75vw;padding:0px;align-items:center;text-align:center;">
        <div>
            SP 783 BQ
        </div>
    </td>
</tr>
@foreach (var item in MechanicalPrpts)
{
    <tr>
        <td class="CheckElement" style="width:13.75vw;"><MudText>@item.Value</MudText></td>
        @for (int i = 0; i < 7; i++)
        {
            <td>
            </td>
        }
    </tr>
}
<tr>
    <td style="width:2.5vw;">10</td>
    <td colspan="2" style="width:13.75vw;">CANTIDAD DE ACEITE</td>
    <td style="width:13.75vw;">PARTES DE NISSAN<br />ACERO: NO SE ESPECIFICA ESTANDAR DE CANTIDAD DE ACEITE.</td>
    @for (int i = 0; i < 7; i++)
    {
        <td>
        </td>
    }
</tr>
<tr>
    <td style="width:2.5vw;">11</td>
    <td colspan="2" style="width:13.75vw;">FECHA DE TRATAMIENTO TERMICO (SOLO ALUMINIO & BAKE HARDENING)</td>
    <td style="width:13.75vw;">&lt 6 meses</td>
    @for (int i = 0; i < 7; i++)
    {
        <td style="width:10%;">
        </td>
    }
</tr>

@code {
    private string? pilingImage { get; set; } = "data:image/jpeg;base64,";
    private Dictionary<int,(string,string)> Dimensions { get; set; } = new Dictionary<int, (string, string)>
    {
        [0] = ("SP 783 BE:ANCHO 1520 mm -0mm +10mm\nSP 781 BE:ANCHO 1311 mm -0mm +7mm",""),
        [1] = ("SP 783 BE: AVANCE 964 ±1mm\nSP 781 BE: AVANCE 475 ±1mm", ""),
        [2] = ("SP 783 BE vs SP 781 BE: DISTANCIA ZONA INFERIOR 12mm ±1mm. (Medir 3 puntos de referencia \"arriba, en medio, abajo\")", "data:image/jpeg;base64,")
    };
    private Dictionary<int, string> MechanicalPrpts { get; set; } = new Dictionary<int, string>
    {
        [0] = "Yield point\n120 - 185 MPa",
        [1] = "% Elongation\n45 - 53 %",
        [2] = "Tensile Strength\n≥270 Mpa"
    };
}
