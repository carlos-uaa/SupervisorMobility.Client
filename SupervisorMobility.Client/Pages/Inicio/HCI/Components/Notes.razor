<MudSimpleTable Elevation="0">
    <thead>
        <tr>
            <th style="text-align:center">Special notes</th>
        </tr>
    </thead>
    <tbody>
        @for (int i =0; i< NotesTable.Count; i++)
        {
            <tr>
                <td>
                    <MudTextField @bind-Value="NotesTable[i]" Variant="Variant.Text" FullWidth></MudTextField>
                </td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

@code {
    [Parameter]
    public List<string> NotesTable { get; set; } = new List<string>();

    protected async override Task OnInitializedAsync()
    {
        if (!NotesTable.Any())
        {
            for (int i = 0; i < 5; i++)
            {
                NotesTable.Add(string.Empty);
            }
        }
    }
}
