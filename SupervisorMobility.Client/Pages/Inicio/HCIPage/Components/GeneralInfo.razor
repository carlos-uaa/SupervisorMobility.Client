@inject IStringLocalizer<Resource> Localizer

<div class="d-flex flex-column flex-md-row gap-6 align-center align-md-start pa-2">

    <div class="d-flex flex-column align-center justify-center pa-4 rounded-xl mud-elevation-2"
         style="background-color: var(--mud-palette-background-grey); min-width: 220px;">

        <MudAvatar Image="@image" Style="height: 140px; width: 140px;" Elevation="4" Class="mb-4" />

        <div class="d-flex align-center mb-1">
            <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Color="Color.Primary" Class="mr-1" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight: 600; text-transform: uppercase;">
                @Localizer["EntryDate"]
            </MudText>
        </div>
        <MudText Typo="Typo.body1" Style="font-weight: 700;">
            @(_hci.User?.IncomesDate?.ToString("dd/MMM/yyyy") ?? "-")
        </MudText>
    </div>

    <div class="flex-grow-1 w-100 mt-4 mt-md-0">

        <div class="mb-4">
            <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700; letter-spacing: -0.5px;">
                @(_hci.User?.Name ?? "Usuario sin nombre")
            </MudText>
            <div class="d-flex align-center mt-1">
                <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Secondary" Class="mr-2" />
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    @Localizer["payroll"]: <span style="font-weight: 600; color: var(--mud-palette-text-primary);">@(_hci.User?.Payroll)</span>
                </MudText>
            </div>
        </div>

        <MudDivider Class="mb-5" />

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6" md="4">
                <MudField Label="@Localizer["BirthDate"]" Variant="Variant.Text" InnerPadding="false" Class="pt-0">
                    <div class="d-flex align-center mt-1">
                        <MudIcon Icon="@Icons.Material.Filled.Cake" Size="Size.Small" Color="Color.Warning" Class="mr-2" />
                        @(_hci.User?.BirthDate?.ToString("dd/MMM/yyyy") ?? "-")
                    </div>
                </MudField>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudField Label="@Localizer["Management"]" Variant="Variant.Text" InnerPadding="false" Class="pt-0">
                    <div class="d-flex align-center mt-1">
                        <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Color="Color.Info" Class="mr-2" />
                        @(_hci.User?.Management ?? "-")
                    </div>
                </MudField>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudField Label="@Localizer["department"]" Variant="Variant.Text" InnerPadding="false" Class="pt-0">
                    <div class="d-flex align-center mt-1">
                        <MudIcon Icon="@Icons.Material.Filled.Domain" Size="Size.Small" Color="Color.Info" Class="mr-2" />
                        @(_hci.User?.Department?.Description ?? "-")
                    </div>
                </MudField>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudField Label="@Localizer["SectionProcess"]" Variant="Variant.Text" InnerPadding="false" Class="pt-0">
                    <div class="d-flex align-center mt-1">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Success" Class="mr-2" />
                        @(_hci.User?.Process ?? "-")
                    </div>
                </MudField>
            </MudItem>
        </MudGrid>
    </div>
</div>

@code {
    public string management;
    [Parameter]
    public Data.Entities.HCI _hci { get; set; }
    [Parameter]
    public string image { get; set; }
}