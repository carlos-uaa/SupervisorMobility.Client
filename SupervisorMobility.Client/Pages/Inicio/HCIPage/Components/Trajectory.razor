@inject IStringLocalizer<Resource> Localizer

<MudExpansionPanel Style="min-width: 100%; border-radius: 12px; overflow: hidden;" IsInitiallyExpanded="false" Class="mt-4 elevation-1">
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Primary" Class="mr-3" />
            <MudText Typo="Typo.h6" Style="font-weight: 600;">@Localizer["TrajectoryTitle"]</MudText>
        </div>
    </TitleContent>
    <ChildContent>
        <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="px-2 pb-4">
            <thead>
                <tr>
                    <th style="width: 60px; text-align:center; color: var(--mud-palette-text-secondary);">No.</th>
                    <th style="width: 180px;">@Localizer["DateChange"]</th>
                    <th>@Localizer["department"]</th>
                    <th>@Localizer["Process"]</th>
                    <th>@Localizer["OperationDescription"]</th>
                    <th style="width: 120px; text-align: right;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in TrajectoryTable.Select((value, index) => new { index, value }))
                {
                    if (item.value.IsActive ?? false)
                    {
                        <tr>
                            <td class="text-center">
                                <MudChip Size="Size.Small" Variant="Variant.Text" Color="Color.Default">
                                    @item.value.CareerPathNo
                                </MudChip>
                            </td>
                            <td>
                                <MudDatePicker Date="item.value.ChangeDate"
                                               DateChanged="(d) => DateChanged(d, item.index)"
                                               Clearable="true"
                                               ReadOnly="@details"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense" />
                            </td>
                            <td>
                                <MudTextField Value="item.value.Department"
                                              ValueChanged="(string? val) => TextChanged(val, item.index, 0)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="@details" />
                            </td>
                            <td>
                                <MudTextField Value="item.value.Process"
                                              ValueChanged="(string? val) => TextChanged(val, item.index, 1)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="@details" />
                            </td>
                            <td>
                                <MudTextField Value="item.value.OperationDescription"
                                              ValueChanged="(string? val) => TextChanged(val, item.index, 2)"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly="@details" />
                            </td>
                            <td>
                                <div class="d-flex justify-end align-center">
                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="() => Delete(item.index)"
                                                   Title="Eliminar" />

                                    @if (item.value.Equals(TrajectoryTable.LastOrDefault(p => p.IsActive == true)))
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.AddCircle"
                                                       Color="Color.Primary"
                                                       Size="Size.Medium"
                                                       OnClick="() => AddHere()"
                                                       Title="Agregar fila" />
                                    }
                                    else
                                    {
                                        @* Espacio reservado para mantener la alineación si no es el último *@
                                        <div style="width: 48px;"></div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    </ChildContent>
</MudExpansionPanel>

<style>
    /* Estilo para suavizar los bordes de los inputs dentro de la tabla */
    .mud-table-cell .mud-input-control {
        margin-top: 4px;
        margin-bottom: 4px;
    }

    /* Eliminar la línea de subrayado si prefieres un look más minimalista */
    .mud-input.mud-input-underline:before {
        display: none;
    }
</style>