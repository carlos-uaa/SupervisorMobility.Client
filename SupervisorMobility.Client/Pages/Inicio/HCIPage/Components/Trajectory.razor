<MudExpansionPanel Style="min-width: 100%;" IsInitiallyExpanded=true>
    <TitleContent>
        <div Style="align-items: center; display: flex;">
            <MudText>Professional trajectory within the company</MudText>
        </div>
    </TitleContent>
    <ChildContent>
        <MudSimpleTable Elevation="0">
            <thead>
                <tr>
                    <th style="text-align:center">No.</th>
                    <th style="text-align:center">Date of change</th>
                    <th style="text-align:center">Deparment</th>
                    <th style="text-align:center">Process name</th>
                    <th style="text-align:center">Operation Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in TrajectoryTable)
                {
                    <tr>
                        <td style="width:5%">
                            <MudNumericField Style="text-align:center;" @bind-Value="item.CareerPathNo" Variant="Variant.Text" HideSpinButtons=true/>
                        </td>
                        <td style="width:17%">
                            <MudDatePicker @bind-Date="item.ChangeDate" Clearable="true"/>
                        </td>
                        <td style="width:20%">
                            <MudTextField @bind-Value="item.OperationDescription" Variant="Variant.Text" FullWidth></MudTextField>
                        </td>
                        <td style="width:25%">
                            <MudTextField @bind-Value="item.OperationDescription" Variant="Variant.Text" FullWidth></MudTextField>
                        </td>
                        <td>
                            <MudTextField @bind-Value="item.OperationDescription" Variant="Variant.Text" FullWidth></MudTextField>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </ChildContent>
</MudExpansionPanel>
