@inject IStringLocalizer<Resource> Localizer
@inject IAreaService AreaServices

<style>
    .mud-table-cell .mud-input-control { margin-top: 4px; margin-bottom: 4px; }
    .mud-input.mud-input-underline:before { display: none; }
</style>

<MudExpansionPanel Style="min-width: 100%; border-radius: 12px; overflow: hidden;" IsInitiallyExpanded="false" Class="mt-4 elevation-1">
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Primary" Class="mr-3" />
            <MudText Typo="Typo.h6" Style="font-weight: 600;">@Localizer["TrajectoryTitle"]</MudText>
        </div>
    </TitleContent>
    <ChildContent>
        <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="px-2 pb-4">
            <thead>
                <tr>
                    <th style="width: 60px; text-align:center; color: var(--mud-palette-text-secondary);">No.</th>
                    <th style="width: 180px;">@Localizer["DateChange"]</th>
                    <th>@Localizer["department"]</th>
                    <th>@Localizer["Process"]</th>
                    <th>@Localizer["OperationDescription"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in TrajectoryTable)
                {
                    if (item.IsActive ?? false)
                    {
                        <tr>
                            <td class="text-center">
                                <MudChip Size="Size.Small" Variant="Variant.Text" Color="Color.Default">
                                    @item.CareerPathNo
                                </MudChip>
                            </td>
                            <td>
                                <MudDatePicker Date="item.ChangeDate"
                                               Clearable="true"
                                               ReadOnly
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense" />
                            </td>
                            <td>
                                <MudTextField Value="item.Department"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly />
                            </td>
                            <td>
                                <MudTextField Value="item.Process"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly />
                            </td>
                            <td>
                                <MudTextField Value="item.OperationDescription"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              ReadOnly />
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    </ChildContent>
</MudExpansionPanel>