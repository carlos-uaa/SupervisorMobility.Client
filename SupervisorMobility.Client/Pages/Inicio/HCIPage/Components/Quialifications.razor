@inject IStringLocalizer<Resource> Localizer
<MudSimpleTable Elevation="0">
    <thead>
        <tr>
            <th style="text-align:center">@Localizer["AcquisitionDate"]</th>
            <th style="text-align:center">@Localizer["name"]</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in QualificationsTable.Select((value, index) => new { index, value }))
        {
            if (item.value.IsActive.Value)
            {
                <tr>
                    <td style="width:30%">
                        <MudDatePicker Date="item.value.DateEnd" DateChanged="(d)=>DateChanged(d,item.index)" Clearable="true" ReadOnly="@details" />
                    </td>
                    <td>
                        <MudTextField T="string" Value="item.value.Description" ValueChanged="(val)=>TextChanged(val,item.index)" Variant="Variant.Text" FullWidth ReadOnly="@details"></MudTextField>
                    </td>
                    <td style="width:10%">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="()=>Delete(item.index)"></MudIconButton>
                        @if (item.value.Equals(QualificationsTable.LastOrDefault(p => p.IsActive == true)))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Success" OnClick="()=>AddHere()"></MudIconButton>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</MudSimpleTable>