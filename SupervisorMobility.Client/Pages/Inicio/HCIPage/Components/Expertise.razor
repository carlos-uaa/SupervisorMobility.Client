@inject IStringLocalizer<Resource> Localizer
@inject IILUService ILUServices
@inject ISnackbar Snackbar

@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionService

<MudExpansionPanel Style="min-width: 100%; border-radius: 12px;" IsInitiallyExpanded="false" Class="mt-4 elevation-1">
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Color="Color.Info" Class="mr-3" />
            <MudText Typo="Typo.h6" Style="font-weight: 600;">@Localizer["ExperienceTitle"]</MudText>
        </div>
    </TitleContent>
    <ChildContent>
        @if (_expertiseItems == null || !_expertiseItems.Any())
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="ma-4"> No experience Records Found </MudAlert>
        }
        else
        {
            <div class="pa-4 mx-2 mb-3 rounded-lg" style="background-color: var(--mud-palette-background-grey);">
                <div class="d-flex align-center mb-2">
                    <MudToggleIconButton ToggledChanged="(() => ActiveFilters())"
                                         Icon="@Icons.Material.Filled.FilterAltOff" Color="@color"
                                         ToggledIcon="@Icons.Material.Filled.FilterAlt" ToggledColor="Color.Success"
                                         Variant="Variant.Filled" Size="Size.Small" ToggledSize="Size.Small" Class="mr-3" />
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">@Localizer["showHideFilters"]</MudText>
                    <MudSpacer />
                    @if (filters)
                    {
                        <MudButton StartIcon="@Icons.Material.Filled.ClearAll" Color="Color.Error"
                                   Size="Size.Small" OnClick="(() => ClearFilters())">@Localizer["clearFilters"]</MudButton>
                    }
                </div>

                @if (!filters)
                {
                    <MudTextField @bind-Value="searchString" Clearable Placeholder="@Localizer["searchHCI"]"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="bg-white" />
                }
                else
                {
                    <MudGrid Spacing="2">
                        @* Fila 1: Planta y Área *@
                        <MudItem xs="12" sm="6" md="4">
                            <MudSelect T="int" Label="@Localizer["plant"]" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       @bind-Value="@plantId" SelectedValuesChanged="ShowAreas" Dense="true" Class="bg-white">
                                <MudSelectItem Value="0">@Localizer["allPlants"]</MudSelectItem>
                                @foreach (var type in _plants)
                                {
                                    <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" sm="6" md="4">
                            <MudSelect T="int" Label="@Localizer["area"]" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       @bind-Value="@areaId" Disabled="@(plantId == 0)" SelectedValuesChanged="ShowDist" Dense="true" Class="bg-white">
                                <MudSelectItem Value="0">@(plantId == 0 ? Localizer["firstSelectAPlant"] : Localizer["allAreas"])</MudSelectItem>
                                @foreach (var type in _areas)
                                {
                                    var count = ExpertiseTable.Count(p => p.Distribution.AreaId == type.AreaId);
                                    <MudSelectItem Value="type.AreaId" Disabled="@(count == 0)">
                                        <div class="d-flex align-center">
                                            <MudChip Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="mr-1">@count</MudChip>
                                            @($"{type.Code} - {type.Description}")
                                        </div>
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        @* Fila 2: Distribución, Fecha e ILU *@
                        <MudItem xs="12" sm="6" md="4">
                            <MudSelect T="int" Label="@Localizer["distribution"]" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       @bind-Value="@distributionId" Disabled="@(areaId == 0)" Dense="true" Class="bg-white" Clearable>
                                <MudSelectItem Value="0">@(areaId == 0 ? Localizer["firstSelectArea"] : Localizer["notSelected"])</MudSelectItem>
                                @foreach (var type in _distributions)
                                {
                                    var count = ExpertiseTable.Count(p => p.DistributionId == type.DistributionId);
                                    <MudSelectItem Value="type.DistributionId" Disabled="@(count == 0)">
                                        <div class="d-flex align-center">
                                            <MudChip Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Class="mr-1">@count</MudChip>
                                            @type.Description
                                        </div>
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" sm="6" md="4">
                            <MudDatePicker Label="@Localizer["date"]" Date="@filterDate" DateChanged="OnDateChange"
                                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="bg-white" Clearable
                                           Placeholder="dd/mm/yyyy" />
                        </MudItem>

                        <MudItem xs="12" sm="12" md="4">
                            <MudSelect T="int" Label="Nivel ILU" Variant="Variant.Outlined" Margin="Margin.Dense"
                                       @bind-Value="statusId" Dense="true" Class="bg-white">
                                <MudSelectItem T="int" Value="0">@Localizer["selectALevel"]</MudSelectItem>
                                @foreach (var type in _LevelsILU)
                                {
                                    <MudSelectItem T="int" Value="type.ILULevelId">
                                        <div class="d-flex align-center">
                                            <img src="@GetIluImage(type.ILULevelId)" height="20" class="mr-2" style="border-radius:2px" />
                                            <MudText Typo="Typo.caption">@type.ILULevelCode</MudText>
                                        </div>
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                }
            </div>

            <MudSimpleTable Hover="true" Dense="true" Elevation="0" Class="mx-2 pb-4">
                <thead>
                    <tr>
                        <th style="width:280px">@Localizer["Period"]</th>
                        <th>@Localizer["OperationDescription"]</th>
                        <th style="width:120px" class="text-center">@Localizer["level"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _expertiseItems)
                    {
                        var period = new DateRange(item.AcquisitionDate, item.EndDate);
                        <tr>
                            <td>
                                <MudDateRangePicker DateRange="period" ReadOnly Variant="Variant.Text"
                                                    Margin="Margin.Dense" DisableToolbar="true" />
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">@item.Distribution?.Description</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Distribution?.Code</MudText>
                                </div>
                            </td>
                            <td class="text-center">
                                <img src="@GetIluImage(item.ILULevelId)" height="28" style="border-radius: 4px;" title="Nivel ILU" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </ChildContent>
</MudExpansionPanel>