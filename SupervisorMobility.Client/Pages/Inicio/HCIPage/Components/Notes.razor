<MudSimpleTable Elevation="0" Hover="false" Dense="true" Class="mud-width-full bg-transparent">
    <tbody>
        @foreach (var item in NotesTable.Select((value, index) => new { index, value }))
        {
            if (item.value.IsActive ?? true) // Manejo de nulos por seguridad
            {
                <tr style="border-bottom: none;">
                    <td class="pa-2">
                        <MudPaper Elevation="0" Outlined="true"
                                  Class="@($"pa-3 rounded-lg {(details ? "bg-light-grey" : "bg-white")}")"
                                  Style="@(details ? "border-style: dashed;" : "border-color: var(--mud-palette-primary-lighten);")">

                            <div class="d-flex align-start">
                                <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline"
                                         Color="Color.Primary" Size="Size.Small" Class="mt-2 mr-3" />

                                <MudTextField T="string"
                                              Label="@(details ? "" : "Comentario")"
                                              Value="item.value.Comment"
                                              ValueChanged="(val) => TextChanged(val, item.index)"
                                              Variant="Variant.Outlined"
                                              Lines="2"
                                              FullWidth
                                              ReadOnly="@details"
                                              Placeholder="Escribe una nota aquí..."
                                              Underline="false" />

                                @if (!details)
                                {
                                    <div class="d-flex flex-column ml-2">
                                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="() => Delete(item.index)"
                                                       Class="pa-1" />

                                        @if (item.value.Equals(NotesTable.LastOrDefault(p => p.IsActive == true)))
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.AddCircle"
                                                           Color="Color.Success"
                                                           Size="Size.Small"
                                                           OnClick="() => AddHere()"
                                                           Class="pa-1" />
                                        }
                                    </div>
                                }
                            </div>
                        </MudPaper>
                    </td>
                </tr>
            }
        }
    </tbody>
</MudSimpleTable>

<style>
    .bg-light-grey {
        background-color: var(--mud-palette-background-grey);
    }

    .mud-table-row:hover {
        background-color: transparent !important;
    }
</style>

@code {
    [Parameter]
    public bool details { get; set; }
    [Parameter]
    public List<Commentary> NotesTable { get; set; }
    [Parameter]
    public EventCallback<Commentary> Add { get; set; }
    [Parameter]
    public EventCallback<int> Del { get; set; }
    [Parameter]
    public EventCallback<(Commentary, int)> Upd { get; set; }

    protected async override Task OnInitializedAsync()
    {
        if (!NotesTable.Any())
                NotesTable.Add(new Commentary { Comment = string.Empty });
    }

    private void TextChanged(string val, int idx)
    {
        NotesTable[idx].Comment = val;
        Upd.InvokeAsync((NotesTable[idx], idx));
    }

    private void Delete(int index)
    {
        //KnowledgeTable.RemoveAt(index);
        Del.InvokeAsync(index);
    }

    private void AddHere()
    {
        Commentary niu = new Commentary();
        //KnowledgeTable.Add(niu);
        Add.InvokeAsync(niu);
    }
}
