@inject ISnackbar Snackbar
@using SupervisorMobility.Client.Data.Entities;

<MudExpansionPanel Style="min-width: 100%; border-radius: 12px;" IsInitiallyExpanded="false" Class="mt-4 elevation-1">
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.CastForEducation" Color="Color.Secondary" Class="mr-3" />
            <MudText Typo="Typo.h6" Style="font-weight: 600;">Courses taken by the user</MudText>
        </div>
    </TitleContent>
    <ChildContent>
        <MudTable Items="@Courses"
                  Hover="true"
                  Breakpoint="Breakpoint.Sm"
                  Elevation="0"
                  Dense="true"
                  Striped="true"
                  RowsPerPage="10">
            <HeaderContent>
                <MudTh>Study Plan</MudTh>
                <MudTh>Date</MudTh>
                <MudTh Style="text-align:center">Score</MudTh>
                <MudTh>Type</MudTh>
            </HeaderContent>
            <RowTemplate Context="course">
                <MudTd DataLabel="Study Plan">@course.Reticulate</MudTd>
                <MudTd DataLabel="Date">@course.Date.ToShortDateString()</MudTd>
                <MudTd DataLabel="Score" Style="text-align:center">
                    <MudChip Size="Size.Small" Variant="Variant.Text" Color="@(course.Calification >= 7 ? Color.Success : Color.Default)">
                        @course.Calification
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Type">
                    <MudChip Size="Size.Small" Label="true" Color="Color.Info" Variant="Variant.Outlined">
                        @course.Type
                    </MudChip>
                </MudTd>
            </RowTemplate>

            <PagerContent>
                <MudTablePager InfoFormat="@("{first_item}-{last_item} de {all_items}")"
                               RowsPerPageString="Rows per page:" />
            </PagerContent>

            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="pa-4 text-center">No courses were found.</MudText>
            </NoRecordsContent>
        </MudTable>
    </ChildContent>
</MudExpansionPanel>

<MudExpansionPanel Style="min-width: 100%; border-radius: 12px;" IsInitiallyExpanded="false" Class="mt-4 elevation-1">
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.NoteAdd" Color="Color.Tertiary" Class="mr-3" />
            <MudText Typo="Typo.h6" Style="font-weight: 600;">Extra courses of user</MudText>
        </div>
    </TitleContent>
    <ChildContent>
        <div class="pa-4">
            @if(!isDetails)
            {
                <MudText Typo="Typo.subtitle1" Class="mb-4" Style="font-weight: 500;">Add new courses</MudText>

                <MudGrid Spacing="2" Class="align-end">
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_newCourse.Reticulate"
                                      Label="Study Plan"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudDatePicker Label="Date"
                                       Date="_newCourse.Date"
                                       DateChanged="SetDate"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Editable="true" />
                    </MudItem>
                    <MudItem xs="6" sm="2">
                        <MudNumericField @bind-Value="_newCourse.Calification"
                                         Label="Calification"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0" Max="10" />
                    </MudItem>
                    <MudItem xs="6" sm="2">
                        <MudSelect @bind-Value="_newCourse.Type"
                                   Label="Type"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            <MudSelectItem Value="@("Presencial")">On Site</MudSelectItem>
                            <MudSelectItem Value="@("En linea")">Online</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="1">
                        <MudIconButton Variant="Variant.Text"
                                       Color="Color.Success"
                                       Icon="@Icons.Material.Filled.AddCircleOutline"
                                       OnClick="AddCourseToList"
                                       Size="Size.Small">
                        </MudIconButton>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-6" />
            }

            @if (_pendingCourses != null && _pendingCourses.Any())
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Info" Class="mb-2">Cursos por confirmar (@_pendingCourses.Count)</MudText>
                <MudTable Items="@_pendingCourses" Dense="true" Hover="true" Elevation="0" Class="border-all border-solid mud-border-lines-default">
                    <HeaderContent>
                        <MudTh>Study Plan</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh Style="text-align:center">Score</MudTh>
                        <MudTh>Type</MudTh>
                        @if(!isDetails){<MudTh></MudTh>}
                    </HeaderContent>
                    <RowTemplate Context="pending">
                        <MudTd>@pending.Reticulate</MudTd>
                        <MudTd>@pending.Date.Value.ToShortDateString()</MudTd>
                        <MudTd DataLabel="Score" Style="text-align:center">
                            <MudChip Size="Size.Small" Variant="Variant.Text" Color="@(pending.Calification >= 7 ? Color.Success : Color.Default)">
                                @pending.Calification
                            </MudChip>
                        </MudTd>
                        <MudTd>@pending.Type</MudTd>
                        @if (!isDetails)
                        {
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="@(() => onRemoveCourse.InvokeAsync(pending))" />
                            </MudTd>
                        }
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <div class="d-flex flex-column align-center py-8">
                    <MudIcon Icon="@Icons.Material.Filled.PlaylistAdd" Color="Color.Default" Style="font-size: 3rem;" />
                    <MudText Color="Color.Default" Typo="Typo.body2">No has agregado cursos a la lista todavía.</MudText>
                </div>
            }
        </div>
    </ChildContent>
</MudExpansionPanel>

@code {
    [Parameter] public List<UserCourse> Courses { get; set; } 
    [Parameter] public List<LocalUserCourses> _pendingCourses { get; set; } = new();
    [Parameter] public bool isDetails { get; set; } = false;
    [Parameter] public EventCallback<LocalUserCourses> onAddCourse { get; set; }
    [Parameter] public EventCallback<LocalUserCourses> onRemoveCourse { get; set; }

    private LocalUserCourses _newCourse = new() { Date = DateTime.Now };

    private void AddCourseToList()
    {
        if (!validateCourse())
            return;

        onAddCourse.InvokeAsync(_newCourse);
        StateHasChanged();
        _newCourse = new LocalUserCourses();
    }

    private bool validateCourse()
    {
        if(string.IsNullOrEmpty(_newCourse.Reticulate))
        {
            Snackbar.Add("The Study plan can't be empty", Severity.Warning);
            return false;
        }
        if(_newCourse.Date == new DateTime())
        {
            Snackbar.Add("The Date can't be empty", Severity.Warning);
            return false;
        }
        if(_newCourse.Calification <= 0)
        {
            Snackbar.Add("Please add a calification", Severity.Warning);
            return false;
        }
        if(string.IsNullOrEmpty(_newCourse.Type))
        {
            Snackbar.Add("The Type can't be empty", Severity.Warning);
            return false;
        }

        return true;
    }

    private void SetDate(DateTime? date)
    {
        _newCourse.Date = date;
    }
}