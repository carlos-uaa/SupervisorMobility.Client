<MudTable Items="@Courses"
          Hover="true"
          Breakpoint="Breakpoint.Sm"
          Elevation="0"
          Dense="true"
          Striped="true"
          RowsPerPage="10">
    <HeaderContent>
        <MudTh>Study Plan</MudTh>
        <MudTh>Date</MudTh>
        <MudTh Style="text-align:center">Score</MudTh>
        <MudTh>Type</MudTh>
    </HeaderContent>
    <RowTemplate Context="course">
        <MudTd DataLabel="Study Plan">@course.Reticulate</MudTd>
        <MudTd DataLabel="Date">@course.Date.ToShortDateString()</MudTd>
        <MudTd DataLabel="Score" Style="text-align:center">
            <MudChip Size="Size.Small" Variant="Variant.Text" Color="@(course.Calification >= 7 ? Color.Success : Color.Default)">
                @course.Calification
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Type">
            <MudChip Size="Size.Small" Label="true" Color="Color.Info" Variant="Variant.Outlined">
                @course.Type
            </MudChip>
        </MudTd>
    </RowTemplate>

    <PagerContent>
        <MudTablePager InfoFormat="@("{first_item}-{last_item} de {all_items}")"
                       RowsPerPageString="Rows per page:" />
    </PagerContent>

    <NoRecordsContent>
        <MudText Typo="Typo.body2" Class="pa-4 text-center">No courses were found.</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    [Parameter]
    public List<UserCourse> Courses { get; set; } 
}