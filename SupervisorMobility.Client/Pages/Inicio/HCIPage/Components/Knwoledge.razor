
<MudExpansionPanel Style="min-width: 100%;" IsInitiallyExpanded=true>
    <TitleContent>
        <div Style="align-items: center; display: flex;">
            <MudText>@Title</MudText>
        </div>
    </TitleContent>
    <ChildContent>
        <MudSimpleTable Elevation="0">
            <thead>
                <tr>
                    <th style="text-align:center">Time period</th>
                    <th style="text-align:center">Topic</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in KnowledgeTable)
                {
                    int i = 0;
                    var period = new DateRange(item.DateStart, item.DateEnd);
                    <tr>
                        <td style="width:30%">
                            <MudDateRangePicker DateRange="period" DateRangeChanged="(d)=>DateChanged(d,i)" Clearable="true"/>
                        </td>
                        <td>
                            <MudTextField @bind-Value="item.Description" Variant="Variant.Text" FullWidth></MudTextField>
                        </td>
                    </tr>
                    i++;
                }
            </tbody>
        </MudSimpleTable>
    </ChildContent>
</MudExpansionPanel>

