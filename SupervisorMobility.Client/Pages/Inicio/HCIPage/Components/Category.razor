@inject IHCIService HCIService
@inject IStringLocalizer<Resource> Localizer
<MudSimpleTable Elevation="0">
    <thead>
        <tr>
            <th style="text-align:center">@Localizer["CatOrLvl"]</th>
            <th style="text-align:center">@Localizer["date"]</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in CategoryTable.Select((value, index) => new { index, value }))
        {
            if(item.value.IsActive.Value){
                <tr>
                    <td>
                        @if (!details)
                        {
                            @* <MudSelect T="int" Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" Value="item.value.HCICategoryId" SelectedValuesChanged="ShowAreas">
                                <MudSelectItem Disabled="true" Value="0">Select a category</MudSelectItem>
                                @foreach (var ctgr in ExistingCategories)
                                {
                                    <MudSelectItem Value="ctgr.HCICategoryId">@($"{ctgr.Name} - {ctgr.Description}")</MudSelectItem>
                                }
                            </MudSelect> *@
                            <MudTextField Value="item.value.Name" ValueChanged="(string? val)=>OptionChanged(val,item.index)" Variant="Variant.Text" FullWidth></MudTextField>
                        }
                        else
                        {
                            <MudTextField Value="item.value.Name" ValueChanged="(string? val)=>OptionChanged(val,item.index)" Variant="Variant.Text" FullWidth ReadOnly></MudTextField>
                        }
                    </td>
                    <td>
                        <MudDatePicker Date="item.value.Date" DateChanged="(d)=>DateChanged(d,item.index)" Clearable="true" ReadOnly="@details"/>
                    </td>
                    <td style="width:20%">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="()=>Delete(item.index)"></MudIconButton>
                        @if (item.value.Equals(CategoryTable.LastOrDefault(p => p.IsActive == true)))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Success" OnClick="()=>AddHere()"></MudIconButton>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</MudSimpleTable>
