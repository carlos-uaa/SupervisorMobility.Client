@page "/HCI/Create"
@page "/HCI/Update/{HCIID:int?}"
@page "/HCI/Details/{HCIID:int?}"
@using SupervisorMobility.Client.Pages.Inicio.HCIPage.Components
@inject NavigationManager NavManager
@inject IUserService UsrsService
@inject IUserCoursesService UserCoursesService
@inject IHCIService HCIService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> Localizer
@inject IExportationService Exportation
@inject IJSRuntime JSRuntime

@if (dataloaded)
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-10">

        <div class="d-flex justify-space-between align-center mb-8 px-2">
            <div>
                <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">
                    @Localizer["HCITitle"]
                </MudText>
                <MudText Typo="Typo.subtitle1" Class="mud-text-secondary mt-1">
                    @(HCIID == null ? "Creación de un nuevo registro profesional" : "Gestión y visualización de perfil profesional")
                </MudText>
            </div>

            @if (Details)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Success"
                           StartIcon="@Icons.Custom.FileFormats.FileExcel"
                           OnClick="DownloadExcel"
                           Class="rounded-lg">Exportar</MudButton>
            }
        </div>

        <MudGrid Spacing="4">
            
            <MudItem xs="12">
                <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4" Style="border-left: 5px solid var(--mud-palette-primary)">
                    <div class="d-flex align-center mb-4">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        </MudAvatar>
                        <MudText Typo="Typo.h6">@Localizer["HCIGeneralInfo"]</MudText>
                    </div>
                    <GeneralInfo _hci="_hci" image="/Images/profile picture.png" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="7">
                <MudStack Spacing="4">
                    <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4">
                        <div class="d-flex align-center mb-4">
                            <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Small" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">I. Professional Development and Courses</MudText>
                        </div>
                        <Knwoledge Courses="courses" />
                    </MudPaper>

                    <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4">
                        <div class="d-flex align-center mb-2">
                            <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">III. @Localizer["TechnicalSkill"]</MudText>
                        </div>
                        <div style="width: 100%">
                            <Trajectory TrajectoryTable="careers"
                                        Add="AddCareer" Del="RemoveCareer" Upd="@((args)=>ModifyCareerEntry(args.Item1, args.Item2))" details="Details" />
                            <Expertise ExpertiseTable="expertise" user="user"
                                        Add="AddExpert" Del="RemoveExpert" Upd="@((args)=>ModifyExpertEntry(args.Item1, args.Item2))" details="Details" />
                        </div>
                    </MudPaper>

                </MudStack>
            </MudItem>

            <MudItem xs="12" md="5">
                <MudStack Spacing="4">

                    <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4">
                        <div class="d-flex align-center mb-4">
                            <MudAvatar Color="Color.Tertiary" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Size="Size.Small" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">II. @Localizer["Titles"]</MudText>
                        </div>
                        <Quialifications QualificationsTable="titles"
                                         Add="AddQualif" Del="RemoveQualif" Upd="@((args)=>ModifyQualifEntry(args.Item1, args.Item2))" details="Details" />
                    </MudPaper>

                    <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4">
                         <div class="d-flex align-center mb-4">
                            <MudAvatar Color="Color.Success" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Small" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">IV. @Localizer["CategoryTitle"]</MudText>
                        </div>
                        <Category CategoryTable="categories"
                                  Add="AddCateg" Del="RemoveCateg" Upd="@((args)=>ModifyCategEntry(args.Item1, args.Item2))" details="Details" />
                    </MudPaper>

                    <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4 bg-grey-lighten-5">
                        <div class="d-flex align-center mb-4">
                            <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                                <MudIcon Icon="@Icons.Material.Filled.Note" Size="Size.Small" />
                            </MudAvatar>
                            <MudText Typo="Typo.h6">V. @Localizer["SpNotes"]</MudText>
                        </div>
                        <Notes NotesTable="comments"
                               Add="AddNote" Del="RemoveNote" Upd="@((args)=>ModifyNoteEntry(args.Item1, args.Item2))" details="Details" />
                    </MudPaper>

                </MudStack>
            </MudItem>

            <MudItem xs="12">
                <MudSpacer />
                <div>
                    @if (!Details)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Error">Cancelar</MudButton>
                        <MudButton StartIcon="@Icons.Material.Filled.Save"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="(() => Complete())">
                            @(HCIID == null ? "Crear Registro" : "Guardar Cambios")
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Color="Color.Success"
                                   StartIcon="@Icons.Custom.FileFormats.FileExcel"
                                   Variant="Variant.Filled"
                                   OnClick="DownloadExcel">
                            Exportar a Excel
                        </MudButton>
                    }
                </div>
            </MudItem>
        </MudGrid>
    </MudContainer>
}