@inject IStringLocalizer<Resource> Localizer
@inject IPartServices PartService
<MudSimpleTable Elevation="0" Style="width:100%; text-align:center;" Bordered=true>
    <tbody>
        <tr>
            <td style="width:30%">
                <MudSimpleTable Elevation="0" Bordered=true>
                    <tr>
                        <td>
                            <MudSimpleTable Elevation="0" Bordered=true>
                                <tbody>
                                    <tr>
                                        <td style="width:50%; text-align:center;">
                                            <MudText Typo="Typo.h6">Nombre de la parte</MudText>
                                        </td>
                                        <td style="width:50%; text-align:center;">
                                            <MudText Typo="Typo.h6">Modelo</MudText>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="text-align:center;">
                                            <MudText Typo="Typo.h4">@part.PartName</MudText>
                                        </td>
                                        <td style="text-align:center;">
                                            <MudText Typo="Typo.h4">@part.Model.Description</MudText>
                                        </td>
                                    </tr>
                                </tbody>
                            </MudSimpleTable>
                        </td>
                    </tr>
                    <tr>
                        <td style="text-align:center;">
                            <MudText Typo="Typo.h4">NUMERO DE PARTE</MudText>
                        </td>
                    </tr>
                    <tr>
                        <td style="text-align:center;">
                            <MudText Typo="Typo.h4" Style="font-weight:bold;">@part.PartNumber</MudText>
                        </td>
                    </tr>
                </MudSimpleTable>
            </td>
            <td>
                <MudSimpleTable Elevation="0" Bordered=true>
                    <tbody>
                        <tr>
                            <td style="text-align:center;">
                                <MudText Typo="Typo.h5">CROQUIS</MudText>
                            </td>
                        </tr>
                        <tr>
                            <td style="text-align:center;">
                                @foreach (var file in Sketches) {
                                    <MudImage Src="@file" Alt="Image" Elevation="25" Height="300" Width="450" />
                                }
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </td>
        </tr>
    </tbody>
</MudSimpleTable>

@code {
    [Parameter]
    public Part part { get; set; }

    public List<string?> Sketches { get; set; } = new();

    protected async override Task OnInitializedAsync()
    {
        foreach(var item in part.Sketches)
        {
            var imageUrl = await PartService.ShowImagePart(item.FileUploadId);
            Sketches.Add(imageUrl);
        }
    }

    private string image { get; set; } = "data:image/png;base64,";
}
