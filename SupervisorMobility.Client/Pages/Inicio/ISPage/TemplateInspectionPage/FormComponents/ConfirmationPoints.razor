<h5>PUNTOS A CONFIRMAR</h5>

<div class="mud-table mud-simple-table mud-table-dense mud-table-hover mud-table-bordered mud-table-outlined" style="width:100%;height:100%">
    <div class="mud-table-container">
        <table id="CheckPointsTable">
            <thead>
                <tr>
                    <td class="CheckElement" colspan="4" style="width:30vw;">
                        <MudText Typo="Typo.h6">FECHA</MudText>
                    </td>
                    @foreach (CheckpointAnswerColumn column in logbookTemplate.CheckpointsResults)
                    {
                        <td class="CheckElement">
                            <MudDatePicker Margin="Margin.Dense" @bind-Date="column.Date" />
                        </td>
                    }
                </tr>
                <tr>
                    <td class="CheckElement" colspan="4" style="width:30vw;">
                        <MudText Typo="Typo.h6">No. DE RAN</MudText>
                    </td>
                    @foreach (CheckpointAnswerColumn column in logbookTemplate.CheckpointsResults)
                    {
                        <td class="CheckElement">
                            <MudInput @bind-Value="column.RAN" Variant="Variant.Text" Margin="Margin.Dense" Style="font-size: 13px;" />
                        </td>
                    }
                </tr>
                <tr>
                    <th class="CheckElement" style="width:2.5vw;"><b>No.</b></th>
                    <th class="CheckElement" colspan="2" style="width:13.75vw;"><b>PUNTOS DE CHEQUEO</b></th>
                    <th class="CheckElement" style="width:13.75vw;"><b>NORMA</b></th>
                    <th class="CheckElement" colspan="7"><b>REAL</b></th>
                </tr>
            </thead>
            <tbody>
                <CheckPoints ColumnAnswers="logbookTemplate.CheckpointsResults" checkPoints="checkPoints"/>
                <InspectorSignatures ColumnAnswers="logbookTemplate.CheckpointsResults"/>
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter]
    public LogbookTemplate logbookTemplate { get; set; }

    [Parameter]
    public List<Checkpoint> checkPoints { get; set; }

    private string programmed { get; set; } = "15.00";
    private DateTime? programmedDate { get; set; }
}
