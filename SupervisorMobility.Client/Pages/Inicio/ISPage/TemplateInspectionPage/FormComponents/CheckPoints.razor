
@for (int fstLayer = 0; fstLayer < checkPoints.Count; fstLayer++)
{
    if (checkPoints[fstLayer].Standars.Count > 1)
    {
        <tr>
            <td rowspan="@(checkPoints[fstLayer].Standars.Count+1)" style="width:2.5vw;">@(fstLayer + 1)</td>
            <td rowspan="@(checkPoints[fstLayer].Standars.Count+1)" style="width:13.75vw;">
                @checkPoints[fstLayer].CheckpointTitle
                <br />
                @checkPoints[fstLayer].CheckpointDescription
                @if (checkPoints[fstLayer].Sketches != null && checkPoints[fstLayer].Sketches.Any())
                {
                    <br />
                    foreach (var item in CPSketches[checkPoints[fstLayer].CheckpointId])
                    {
                        <MudImage Src="@item" Alt="Image" Elevation="25" Height="50" Width="75" />
                    }
                }
            </td>
        </tr>
        foreach (var Norm in checkPoints[fstLayer].Standars)
        {
            <tr>
                <td style="width:13.75vw;">
                    @Norm.Standard
                    @if (Norm.Sketches != null && Norm.Sketches.Any())
                    {
                        <br />
                        foreach (var item in CPASketches[Norm.CheckpointNormId])
                        {
                            <MudImage Src="@item" Alt="Image" Elevation="25" Height="50" Width="75" />
                        }
                    }
                </td>
                @for(int i=0; i<ColumnAnswers.Count; i++)
                {
                    foreach (var item in ColumnAnswers[i].CheckpointsResults.Where(p=>p.CheckpointNormId == Norm.CheckpointNormId))
                    {
                        <td><MudInput T="string" @bind-Value="item.Result"/></td>
                    }
                }
            </tr>
        }
    }
    else
    {
        <tr>
            <td style="width:2.5vw;">@(fstLayer + 1)</td>
            <td style="width:13.75vw;">
                @checkPoints[fstLayer].CheckpointTitle
                <br />
                @checkPoints[fstLayer].CheckpointDescription
                @if (checkPoints[fstLayer].Sketches != null && checkPoints[fstLayer].Sketches.Any())
                {
                    <br />
                    foreach (var item in CPSketches[checkPoints[fstLayer].CheckpointId])
                    {
                        <MudImage Src="@item" Alt="Image" Elevation="25" Height="50" Width="75" />
                    }
                }
            </td>
            <td style="width:13.75vw;">
                @checkPoints[fstLayer].Standars[0].Standard
                @if (checkPoints[fstLayer].Standars[0].Sketches != null && checkPoints[fstLayer].Standars[0].Sketches.Any())
                {
                    <br />
                    foreach (var item in CPASketches[checkPoints[fstLayer].Standars[0].CheckpointNormId])
                    {
                        <MudImage Src="@item" Alt="Image" Elevation="25" Height="50" Width="75" />
                    }
                }
            </td>
            @for (int i = 0; i < ColumnAnswers.Count; i++)
            {
                foreach (var item in ColumnAnswers[i].CheckpointsResults.Where(p => p.CheckpointNormId == checkPoints[fstLayer].Standars[0].CheckpointNormId))
                {
                    <td><MudInput T="string" @bind-Value="item.Result" /></td>
                }
            }
        </tr>
    }
}

@code {
    [Parameter]
    public List<CheckpointAnswerColumn> ColumnAnswers { get; set; }

    [Parameter]
    public Dictionary<int, List<string>> CPSketches { get; set; } = new();
    [Parameter]
    public Dictionary<int, List<string>> CPASketches { get; set; } = new Dictionary<int, List<string>> {
        {
            2,
            new List<string>
            {
                "data:image/jpeg;base64,"
            }
        }

    };

    [Parameter]
    public List<Checkpoint> checkPoints { get; set; }

}
