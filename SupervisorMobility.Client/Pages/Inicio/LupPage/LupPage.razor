            <MudTabs Elevation="4" Rounded="true" Color="Color.Info" Centered="true">
                <MudTabPanel Icon="@Icons.Material.Filled.ContentPaste" Text=@Localizer["allLup"]>
                    @if (_lup.Count > 0)
                    {
                        <MudTable Items="_lup" Hover="true" T="LupWithDistribution" Filter="new Func<LupWithDistribution,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true Height="400px" OnRowClick="RowClickEvent" RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent"
                                  HorizontalScrollbar="true">
                            <ToolBarContent>
                                <MudGrid class="d-flex flex-column justify-center align-self-center">
                                    <MudItem Class="d-flex">
                                        <MudSpacer />
                                        <MudTextField @bind-Value="searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                                        <MudSpacer />
                                    </MudItem>
                                </MudGrid>
                            </ToolBarContent>
                            <HeaderContent>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.LupId)">Lup Id</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Distribution)" InitialDirection="SortDirection.Ascending">@Localizer["distribution"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Status)">@Localizer["status"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x.Lup.Pillar)">@Localizer["pillar"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Oportunity)">@Localizer["opportunity"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudText Align="Align.Center">@Localizer["actions"]</MudText>
                                </MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="LupId" @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Lup.LupId</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["distribution"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Distribution</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["status"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">
                                        @switch (context.Lup?.Status)
                                        {
                                            case 1:
                                                <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["new"]</MudChip>
                                                break;
                                            case 2:
                                                <MudChip Variant="Variant.Text" Color="Color.Info" Size="Size.Small">@Localizer["inProgress"]</MudChip>
                                                break;
                                            case 3:
                                                <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small">@Localizer["finished"]</MudChip>
                                                break;
                                            case 4:
                                                <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small">@Localizer["canceled"]</MudChip>
                                                break;
                                        }
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["pillar"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">
                                        @switch (context.Lup.Pillar)
                                        {
                                            case 1:
                                                <MudText>S</MudText>
                                                break;
                                            case 2:
                                                <MudText>Q</MudText>
                                                break;
                                            case 3:
                                                <MudText>D</MudText>
                                                break;
                                            case 4:
                                                <MudText>C</MudText>
                                                break;
                                            case 5:
                                                <MudText>@Localizer["other"]</MudText>
                                                break;
                                        }
                                    </MudText>
                                </MudTd>
