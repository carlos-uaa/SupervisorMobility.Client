@page "/lup"

@inject ILupService LupServices
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IJobObservationService JobObservationServices
@inject IDepartmentService DepartmentServices
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> Localizer
@inject IDistributionService DistributionService

@if (logged == true)
{

    @*Title*@
    <PageTitle>Supervisor Mobility | LUP</PageTitle>
    @*Breadcrumb links*@
    <MudBreadcrumbs Items="_links">
        <ItemTemplate Context="item">
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        </ItemTemplate>
    </MudBreadcrumbs>
    @*Dashboard grid*@
    <MudGrid>
        <MudItem xs="12" sm="12" md="12">
            <MudItem Class="d-flex justify-content-between" Style="align-items: center;">
                <MudText Typo="Typo.h6">@Localizer["areasOfOpportunityDetected"]</MudText>
                <MudItem Style="justify-content: end" Class="ml-auto">
                    <MudItem Class="d-flex">
                        @if (user.UserType == 1 || user.UserType == 6)
                        {
                            @*Mud select of Plants for Admin*@
                            <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text" Class="mb-3 mr-8" AnchorOrigin="Origin.BottomCenter" @bind-Value="@plantId" For="@(() => plantId)" SelectedValuesChanged="ShowAreas" Style="width: 15rem;">
                                <MudSelectItem Value="0">@Localizer["allPlants"]</MudSelectItem>
                                @foreach (var type in _plants)
                                {
                                    <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            </MudSelect>

                            @if (plantId != 0)
                            {
                                @*Mud select of Areas for Admin*@
                                <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mb-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowLups" Style="width: 15rem;">
                                    <MudSelectItem Value="0">@Localizer["allAreas"]</MudSelectItem>
                                    @foreach (var type in _areas)
                                    {
                                        <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            else
                            {
                                @*Mud select for SSV *@
                                <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Disabled Class="mb-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" Style="width: 15rem;">
                                    <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAPlant"]</MudSelectItem>
                                </MudSelect>
                            }
                            @*<MudButton Href="/lupReport" StartIcon="@Icons.Material.Filled.Assignment" Class="ml-8">@Localizer["lupReport"]</MudButton>*@
                        }
                        else if (user.UserType == 2)
                        {
                            @*Mud select of Areas for Admin*@
                            <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mb-3 mr-8" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowLups" Style="width: 15rem;">
                                <MudSelectItem Value="0">@Localizer["allAreas"]</MudSelectItem>
                                @foreach (var type in _areas)
                                {
                                    <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        else if (user.UserType == 5)
                        {
                            @*Mud select of Areas for Admin*@
                            <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mb-3 mr-8" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowLups" Style="width: 15rem;">
                                <MudSelectItem Value="0">@Localizer["allAreas"]</MudSelectItem>
                                @foreach (var type in _areas)
                                {
                                    <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }
                    </MudItem>
                </MudItem>
            </MudItem>
            <MudTabs Elevation="4" Rounded="true" Color="Color.Info" Centered="true">
                <MudTabPanel Icon="@Icons.Material.Filled.ContentPaste" Text=@Localizer["allLup"]>

                    <MudTable Items="_filterlups" Hover="true" T="LupWithDistribution" Filter="new Func<LupWithDistribution,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true Height="400px" OnRowClick="RowClickEvent" RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent"
                              HorizontalScrollbar="true">
                        <ToolBarContent>
                            @if (plantId == new int())
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="my-2" Style="text-align:center;"> @Localizer["firstSelectAPlant"]</MudAlert>
                                <MudSpacer />
                                <MudTextField @bind-Value="searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5" Clearable></MudTextField>
                                <MudSpacer />
                            }
                            else if (_filterlups.Count == 0 && !filters)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="my-2" Style="text-align:center;">@Localizer["thereAreStillNoAreasOfOpportunityDetectedForThisPillar"]</MudAlert>
                            }
                            else
                            {
                                <MudTooltip Text=@Localizer["showHideFilters"] Arrow="true" Placement="Placement.Right" Color="Color.Info">
                                    <MudIconButton Icon="@Icons.Material.Filled.FilterAlt" Color="@color" @onclick="(() => ActiveFilters())" Class="mr-0"></MudIconButton>
                                </MudTooltip>
                                @if (filters == false)
                                {
                                    <MudSpacer />
                                    <MudTextField @bind-Value="searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5" Clearable></MudTextField>
                                }
                                <MudSpacer />
                                @if (filters == true)
                                {
                                    <MudSelect T="int" Label=@Localizer["distribution"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@distributionId" SelectedValuesChanged="Filters">
                                        <MudSelectItem Disabled="true" Value="0">@Localizer["notSelected"]</MudSelectItem>
                                        @foreach (var type in _distributions)
                                        {
                                            <MudSelectItem Value="type.DistributionId">@($"{type.Description}")</MudSelectItem>
                                        }
                                    </MudSelect>
                                    <MudSpacer />
                                    <MudSelect T="int" Label=@Localizer["department"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@departmentId" SelectedValuesChanged="Filters">
                                        <MudSelectItem Disabled="true" Value="0">@Localizer["notSelected"]</MudSelectItem>
                                        @foreach (var type in _departments)
                                        {
                                            <MudSelectItem Value="type.DepartmentId">@($"{type.Description}")</MudSelectItem>
                                        }
                                    </MudSelect>

                                    <MudSpacer />
                                    @*Mud select of Status *@
                                    <MudSelect T="int" Label=@Localizer["status"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@statusId" SelectedValuesChanged="Filters">
                                        <MudSelectItem Value="0" Disabled>@Localizer["notSelected"]</MudSelectItem>
                                    <MudSelectItem Value="1">@Localizer["new"]</MudSelectItem>
                                    <MudSelectItem Value="2">@Localizer["inProgress"]</MudSelectItem>
                                    <MudSelectItem Value="3">@Localizer["cancel"]</MudSelectItem>
                                    <MudSelectItem Value="4">@Localizer["finished"]</MudSelectItem>
                                </MudSelect>
                                    <MudSpacer />
