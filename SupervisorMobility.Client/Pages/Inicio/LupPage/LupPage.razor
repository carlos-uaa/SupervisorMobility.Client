@page "/lup"

@inject ILupService LupServices
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IJobObservationService JobObservationServices
@inject IDepartmentService DepartmentServices
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> Localizer
@inject IDistributionService DistributionService

@if (logged == true)
{

    @*Title*@
    <PageTitle>Supervisor Mobility | LUP</PageTitle>
    @*Breadcrumb links*@
    <MudBreadcrumbs Items="_links">
        <ItemTemplate Context="item">
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
            </ItemTemplate>
        </MudBreadcrumbs>
    @*Dashboard grid*@
    <MudGrid>
        <MudItem xs="12" sm="12" md="12">
            <MudItem Class="d-flex justify-content-between" Style="align-items: center;">
                <MudText Typo="Typo.h6">@Localizer["areasOfOpportunityDetected"]</MudText>
                    <MudItem Style="justify-content: end" Class="ml-auto">
                        <MudItem Class="d-flex">
                            @if (user.UserType == 1 || user.UserType == 6)
                        {
                            @*Mud select of Plants for Admin*@
                            <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text" Class="mb-3 mr-8" AnchorOrigin="Origin.BottomCenter" @bind-Value="@plantId" For="@(() => plantId)" SelectedValuesChanged="ShowAreas" Style="width: 15vw;">
                                <MudSelectItem Value="0">@Localizer["allPlants"]</MudSelectItem>
                                    @foreach (var type in _plants)
                                {
                                    <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            </MudSelect>

                            @if (plantId != 0)
                            {
                                @*Mud select of Areas for Admin*@
                                <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mb-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowLups" Style="width: 15vw;">
                                    <MudSelectItem Value="0">@Localizer["allAreas"]</MudSelectItem>
                                        @foreach (var type in _areas)
                                    {
                                        <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            else
                            {
                                @*Mud select for SSV *@
                                <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Disabled Class="mb-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" Style="width: 15vw;">
                                     <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAPlant"]</MudSelectItem>
                                    </MudSelect>
                            }
                            @*<MudButton Href="/lupReport" StartIcon="@Icons.Material.Filled.Assignment" Class="ml-8">@Localizer["lupReport"]</MudButton>*@
                        }
                        else if (user.UserType == 2)
                        {
                            @*Mud select of Areas for Admin*@
                            <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mb-3 mr-8" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowLups" Style="width: 15vw;">
                                <MudSelectItem Value="0">@Localizer["allAreas"]</MudSelectItem>
                                    @foreach (var type in _areas)
                                {
                                    <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        else if (user.UserType == 5)
                        {
                            @*Mud select of Areas for Admin*@
                            <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mb-3 mr-8" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowLups" Style="width: 15vw;">
                                <MudSelectItem Value="0">@Localizer["allAreas"]</MudSelectItem>
                                    @foreach (var type in _areas)
                                {
                                    <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }
                    </MudItem>
                </MudItem>
            </MudItem>
            <MudTabs Elevation="4" Rounded="true" Color="Color.Info" Centered="true">
                <MudTabPanel Icon="@Icons.Material.Filled.ContentPaste" Text=@totalLups>

                    <MudTable Items="_filterlups" Hover="true" T="LupWithDistribution" Filter="new Func<LupWithDistribution,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true Height="62vh" OnRowClick="RowClickEvent" RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent"
                              HorizontalScrollbar="true">
                        <ToolBarContent>
                            @if (plantId == new int())
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="my-2" Style="text-align:center;"> @Localizer["firstSelectAPlant"]</MudAlert>
                                <MudSpacer />
                                <MudTextField @bind-Value="searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5" Clearable></MudTextField>
                                <MudSpacer />
                            }
                            else if (_filterlups.Count == 0 && !filters)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="my-2" Style="text-align:center;">@Localizer["thereAreStillNoAreasOfOpportunityDetectedForThisPillar"]</MudAlert>
                            }
                            else
                            {
                                <MudTooltip Text=@Localizer["showHideFilters"] Arrow="true" Placement="Placement.Right" Color="Color.Info">
                                    <MudIconButton Icon="@Icons.Material.Filled.FilterAlt" Color="@color" @onclick="(() => ActiveFilters())" Class="mr-0"></MudIconButton>
                                </MudTooltip>
                                @if (filters == false)
                                {
                                    <MudSpacer />
                                    <MudTextField @bind-Value="searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5" Clearable></MudTextField>
                                    <MudSpacer />
                                }
                                @if (filters == true)
                                {
                                    <MudSelect Clearable T="int" Label=@Localizer["distribution"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3 mr-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@distributionId" SelectedValuesChanged="Filters">
                                         <MudSelectItem Disabled="true" Value="0">@Localizer["notSelected"]</MudSelectItem>
                                            @foreach (var type in _distributions)
                                        {
                                            var statusCount = _lups.Where(l => l.DistributionId == type.DistributionId).ToList().Count;
                                            var isDisabled = statusCount == 0;

                                            <MudSelectItem Value="type.DistributionId" Disabled="@isDisabled">
                                                <MudChip Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Style="margin: 0px">@statusCount</MudChip>
                                                    @($"{type.Description}")

                                                </MudSelectItem>
                                        }
                                    </MudSelect>
                                    <MudSelect Clearable T="int" Label=@Localizer["department"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3 mr-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@departmentId" SelectedValuesChanged="Filters">
                                         <MudSelectItem Disabled="true" Value="0">@Localizer["notSelected"]</MudSelectItem>

                                            @foreach (var type in _departments)
                                        {
                                            var statusCount = _filterlups.Where(l => l.Lup.DepartmentId == type.DepartmentId).ToList().Count;
                                            var isDisabled = statusCount == 0;
                                            <MudSelectItem Value="type.DepartmentId" Disabled="@isDisabled">
                                                <MudChip Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Style="margin: 0px">@statusCount</MudChip>
                                                    @($"{type.Description}")

                                                </MudSelectItem>
                                        }
                                    </MudSelect>

                                    @*Mud select of Status *@
                                    <MudSelect Clearable T="int" Label="@Localizer["status"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3 mr-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@statusId" SelectedValuesChanged="Filters">
                                         <MudSelectItem Value="0" Disabled>@Localizer["notSelected"]</MudSelectItem>

                                            @foreach (var status in new[] { 1, 2, 3, 4 })
                                        {
                                            var statusCount = _filterlups.Where(l => l.Lup.Status == status).ToList().Count;
                                            var isDisabled = statusCount == 0;

                                            <MudSelectItem Value="@status" Disabled="@isDisabled">
                                                <MudChip Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Style="margin: 0px">@statusCount</MudChip>
                                                    @Localizer[GetStatusLabel(status)]
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                    <MudTooltip Text=@Localizer["clearFilters"] Arrow="true" Placement="Placement.Left" Color="Color.Error">
                                        <MudIconButton Icon="@Icons.Material.Filled.Clear" Color="Color.Error" @onclick="(() => ClearFilters())" Class="mr-0"></MudIconButton>
                                    </MudTooltip>
                                }
                            }
                        </ToolBarContent>
                        <HeaderContent>
                            @if (user.UserType == 1)
                            {
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.LupId)">Lup Id</MudTableSortLabel>
                                </MudTh>
                            }
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x.Lup.Pillar)">@Localizer["pillar"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Distribution)" InitialDirection="SortDirection.Ascending">@Localizer["distribution"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.JobObservation.ModelsSpecification)" InitialDirection="SortDirection.Ascending">@Localizer["model"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Oportunity)">@Localizer["opportunity"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Q3)">@Localizer["Q3"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Q4)">@Localizer["Q4"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Observer)">@Localizer["observer"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Observer)">@Localizer["startDate"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Observer)">@Localizer["endDate"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Department?.Description)">@Localizer["department"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.StatusOKNG)">@Localizer["status"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.StdChange)">@Localizer["StdChange"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.StdUpdate)">@Localizer["StdUpdate"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudText Align="Align.Center">@Localizer["actions"]</MudText>
                                </MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                @if (user.UserType == 1)
                            {
                                <MudTd DataLabel="LupId" @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Lup.LupId</MudText>
                                    </MudTd>
                            }
                            <MudTd DataLabel=@Localizer["pillar"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">
                                    @switch (context.Lup.Pillar)
                                    {
                                        case 1:
                                            <MudText>S & E</MudText>
                                            break;
                                        case 2:
                                            <MudText>Q</MudText>
                                            break;
                                        case 3:
                                            <MudText>D</MudText>
                                            break;
                                        case 4:
                                            <MudText>C</MudText>
                                            break;
                                        case 5:
                                            <MudText>@Localizer["other"]</MudText>
                                            break;
                                    }
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel=@Localizer["distribution"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">@context.Distribution</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["model"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Lup.JobObservation?.ProductId</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["opportunity"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    @if (context.Lup?.Oportunity?.Length > 27)
                                {

                                    <MudText Align="Align.Center">@context.Lup.Oportunity.Substring(0, 27) ...</MudText>
                                }
                                else
                                {
                                    <MudText Align="Align.Center">@context.Lup.Oportunity </MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel=@Localizer["Q3"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                @if (context.Lup?.Q3?.Length > 27)
                                {

                                    <MudText Align="Align.Center">@context.Lup.Q3.Substring(0, 27) ...</MudText>
                                }
                                else
                                {
                                    <MudText Align="Align.Center">@context.Lup.Q3 </MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel=@Localizer["Q4"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                @if (context.Lup?.Q4?.Length > 27)
                                {

                                    <MudText Align="Align.Center">@context.Lup.Q4.Substring(0, 27) ...</MudText>
                                }
                                else
                                {
                                    <MudText Align="Align.Center">@context.Lup.Q4 </MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel=@Localizer["observer"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">@context.Lup.Observer</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["startDate"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Lup.CreatedDate</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["endDate"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Lup.EndDate</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["department"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Lup.Department?.Description</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["status"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">
                                        @switch (context.Lup?.StatusOKNG)
                                    {
                                        case LUPStatus.Percent25:
                                            <MudChart ChartType="ChartType.Pie" InputData="@data[1]" ChartOptions="chartOptions" Width="40px" Height="40px" />
                                            break;
                                        case LUPStatus.Percent50:
                                            <MudChart ChartType="ChartType.Pie" InputData="@data[2]"  ChartOptions="chartOptions" Width="40px" Height="40px" />
                                            break;
                                        case LUPStatus.Percent75:
                                            <MudChart ChartType="ChartType.Pie" InputData="@data[3]" ChartOptions="chartOptions" Width="40px" Height="40px" />
                                            break;
                                        case LUPStatus.Percent100:
                                            <MudChart ChartType="ChartType.Pie" InputData="@data[4]" ChartOptions="chartOptions" Width="40px" Height="40px" />
                                            break;
                                        default:
                                            <MudChart ChartType="ChartType.Pie" InputData="@data[0]" ChartOptions="chartOptions" Width="40px" Height="40px" />
                                            break;
                                    }
                                </MudText>
                            </MudTd>

                            <MudTd DataLabel=@Localizer["StdChange"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">
                                    @switch (context.Lup?.StdChange)
                                    {
                                        case 1:
                                            <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["yes"]</MudChip>
                                            break;
                                        case 0:
                                            <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["Noo"]</MudChip>
                                            break;
                                    }
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel=@Localizer["StdUpdate"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">
                                    @switch (context.Lup?.StdUpdate)
                                    {
                                        case 1:
                                            <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["yes"]</MudChip>
                                            break;
                                        case 2:
                                            <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["Noo"]</MudChip>
                                            break;
                                    }
                                </MudText>
                            </MudTd>
                            <MudTd @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">

                                    <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                        <ActivatorContent>
                                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                        </ActivatorContent>
                                        <ChildContent>
                                            <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => OpenDialog2(context.Lup.LupId))">@Localizer["lupDetails"]</MudMenuItem>
                                                @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                            {
                                                <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => EditLup(context.Lup.LupId))" @ontouchstart="(() => EditLup(context.Lup.LupId))">@Localizer["editLup"] </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => OpenDeleteDialog(context.Lup.LupId))" @ontouchstart="(() => OpenDeleteDialog(context.Lup.LupId))">@Localizer["deleteLup"]</MudMenuItem>
                                            }
                                        </ChildContent>
                                    </MudMenu>
                                    @*                                        <MudIconButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Icon="@Icons.Material.Filled.Info" aria-label="info" @onclick="(() => OpenDialog2(context.Lup.LupId))"></MudIconButton>
                                <MudIconButton Variant="Variant.Filled" Color="Color.Info" Size="Size.Small" Icon="@Icons.Material.Filled.Edit" aria-label="edit" @onclick="(() => EditLup(context.Lup.LupId))"></MudIconButton>
                                <MudIconButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.Delete" aria-label="delete" @onclick="(() => OpenDeleteDialog(context.Lup.LupId))"></MudIconButton>*@
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                    </MudTable>

                    @*                    else
                {
                <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">@Localizer["thereAreStillNoAreasOfOpportunityDetectedForThisPillar"]</MudText>
                }*@

                </MudTabPanel>
                <MudTabPanel Icon="@Icons.Material.Filled.ContentPaste" Text=@totalSE>

                    <MudTable Items="_filterlups.Where(l => l.Lup.Pillar == 1)" Hover="true" T="LupWithDistribution" Filter="new Func<LupWithDistribution,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true Height="50vh" OnRowClick="RowClickEvent" RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent"
                              HorizontalScrollbar="true">
                        <ToolBarContent>
                            @if (plantId == new int())
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="my-2" Style="text-align:center;"> @Localizer["firstSelectAPlant"]</MudAlert>
                                <MudSpacer />
                                <MudTextField @bind-Value="searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5" Clearable></MudTextField>
                                <MudSpacer />
                            }
                            else if (_filterlups.Where(l => l.Lup.Pillar == 1).ToList().Count == 0 && !filters)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="my-2" Style="text-align:center;">@Localizer["thereAreStillNoAreasOfOpportunityDetectedForThisPillar"]</MudAlert>
                            }
                            else
                            {
                                <MudTooltip Text=@Localizer["showHideFilters"] Arrow="true" Placement="Placement.Right" Color="Color.Info">
                                    <MudIconButton Icon="@Icons.Material.Filled.FilterAlt" Color="@color" @onclick="(() => ActiveFilters())" Class="mr-0"></MudIconButton>
                                </MudTooltip>
                                @if (filters == false)
                                {
                                    <MudSpacer />
                                    <MudTextField @bind-Value="searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5" Clearable></MudTextField>
                                    <MudSpacer />
                                }
                                @if (filters == true)
                                {
                                    <MudSelect Clearable T="int" Label=@Localizer["distribution"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3 mr-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@distributionId" SelectedValuesChanged="Filters">
                                         <MudSelectItem Disabled="true" Value="0">@Localizer["notSelected"]</MudSelectItem>
                                            @foreach (var type in _distributions)
                                        {
                                            var statusCount = _lups.Where(l => l.DistributionId == type.DistributionId && l.Lup.Pillar == 1).ToList().Count;
                                            var isDisabled = statusCount == 0;

