                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Q4)">@Localizer["Q4"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Observer)">@Localizer["observer"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Observer)">@Localizer["startDate"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Observer)">@Localizer["endDate"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.Department?.Description)">@Localizer["department"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.StatusOKNG)">@Localizer["status"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.StdChange)">@Localizer["StdChange"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<LupWithDistribution, object>(x=>x?.Lup.StdUpdate)">@Localizer["StdUpdate"]</MudTableSortLabel>
                                </MudTh>
                                <MudTh>
                                    <MudText Align="Align.Center">@Localizer["actions"]</MudText>
                                </MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                @if (user.UserType == 1)
                            {
                                <MudTd DataLabel="LupId" @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Lup.LupId</MudText>
                                    </MudTd>
                            }
                            <MudTd DataLabel=@Localizer["pillar"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">
                                    @switch (context.Lup.Pillar)
                                    {
                                        case 1:
                                            <MudText>S & E</MudText>
                                            break;
                                        case 2:
                                            <MudText>Q</MudText>
                                            break;
                                        case 3:
                                            <MudText>D</MudText>
                                            break;
                                        case 4:
                                            <MudText>C</MudText>
                                            break;
                                        case 5:
                                            <MudText>@Localizer["other"]</MudText>
                                            break;
                                    }
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel=@Localizer["distribution"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">@context.Distribution</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["model"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Lup.JobObservation?.ProductId</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["opportunity"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    @if (context.Lup?.Oportunity?.Length > 27)
                                {

                                    <MudText Align="Align.Center">@context.Lup.Oportunity.Substring(0, 27) ...</MudText>
                                }
                                else
                                {
                                    <MudText Align="Align.Center">@context.Lup.Oportunity </MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel=@Localizer["Q3"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                @if (context.Lup?.Q3?.Length > 27)
                                {

                                    <MudText Align="Align.Center">@context.Lup.Q3.Substring(0, 27) ...</MudText>
                                }
                                else
                                {
                                    <MudText Align="Align.Center">@context.Lup.Q3 </MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel=@Localizer["Q4"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                @if (context.Lup?.Q4?.Length > 27)
                                {

                                    <MudText Align="Align.Center">@context.Lup.Q4.Substring(0, 27) ...</MudText>
                                }
                                else
                                {
                                    <MudText Align="Align.Center">@context.Lup.Q4 </MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel=@Localizer["observer"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">@context.Lup.Observer</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["startDate"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Lup.CreatedDate</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["endDate"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Lup.EndDate</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["department"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">@context.Lup.Department?.Description</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["status"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                    <MudText Align="Align.Center">
                                        @switch (context.Lup?.StatusOKNG)
                                    {
                                        case LUPStatus.Percent25:
                                            <MudChart ChartType="ChartType.Pie" InputData="@data[1]" Width="40px" Height="40px" />
                                            break;
                                        case LUPStatus.Percent50:
                                            <MudChart ChartType="ChartType.Pie" InputData="@data[2]" Width="40px" Height="40px" />

                                            break;
                                        case LUPStatus.Percent75:
                                            <MudChart ChartType="ChartType.Pie" InputData="@data[3]" Width="40px" Height="40px" />

                                            break;
                                        case LUPStatus.Percent100:
                                            <MudChart ChartType="ChartType.Pie" InputData="@data[4]" Width="40px" Height="40px" />

                                            break;
                                        default:
                                            <MudChart ChartType="ChartType.Pie" InputData="@data[0]" Width="40px" Height="40px" />
                                            break;
                                    }
                                </MudText>
                            </MudTd>

                            <MudTd DataLabel=@Localizer["StdChange"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">
                                    @switch (context.Lup?.StdChange)
                                    {
                                        case 1:
                                            <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["yes"]</MudChip>
                                            break;
                                        case 0:
                                            <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["Noo"]</MudChip>
                                            break;
                                    }
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel=@Localizer["StdUpdate"] @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">
                                    @switch (context.Lup?.StdUpdate)
                                    {
                                        case 1:
                                            <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["yes"]</MudChip>
                                            break;
                                        case 0:
                                            <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["Noo"]</MudChip>
                                            break;
                                    }
                                </MudText>
                            </MudTd>
                            <MudTd @ondblclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => HandleTouchStart(context.Lup.LupId))">
                                <MudText Align="Align.Center">

                                    <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                        <ActivatorContent>
                                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                        </ActivatorContent>
                                        <ChildContent>
                                            <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => OpenDialog2(context.Lup.LupId))" @ontouchstart="(() => OpenDialog2(context.Lup.LupId))">@Localizer["lupDetails"]</MudMenuItem>
                                                @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                            {
                                                <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => EditLup(context.Lup.LupId))" @ontouchstart="(() => EditLup(context.Lup.LupId))">@Localizer["editLup"] </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => OpenDeleteDialog(context.Lup.LupId))" @ontouchstart="(() => OpenDeleteDialog(context.Lup.LupId))">@Localizer["deleteLup"]</MudMenuItem>
                                            }
                                        </ChildContent>
                                    </MudMenu>
                                    @*                                        <MudIconButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Icon="@Icons.Material.Filled.Info" aria-label="info" @onclick="(() => OpenDialog2(context.Lup.LupId))"></MudIconButton>
                                <MudIconButton Variant="Variant.Filled" Color="Color.Info" Size="Size.Small" Icon="@Icons.Material.Filled.Edit" aria-label="edit" @onclick="(() => EditLup(context.Lup.LupId))"></MudIconButton>
                                <MudIconButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.Delete" aria-label="delete" @onclick="(() => OpenDeleteDialog(context.Lup.LupId))"></MudIconButton>*@
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager />
                        </PagerContent>
                    </MudTable>

                </MudTabPanel>
            </MudTabs>
        </MudItem>
    </MudGrid>

    @*Delete lup modal*@
    <MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
        <DialogContent>
            <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
                <MudText Class="mt-4 mb-4">
                    <span style="color: #2196f3; text-align:justify">@user.Name</span>,
                @Localizer["areYouSureYouWantToDeleteThisLup"]
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
                <MudButton @onclick="(() => DeleteLup(deleteLupId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">@Localizer["delete"]</MudButton>
            </DialogActions>
        </MudDialog>


    <MudDialog DisableSidePadding="false" @bind-IsVisible="visible" Options="dialogOptions">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">
                <SupervisorMobility.Client.Pages.Inicio.LupPage.LupDetails LupId="lupId"></SupervisorMobility.Client.Pages.Inicio.LupPage.LupDetails>
            </MudContainer>
        </DialogContent>
        <DialogActions>
            @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
            {
                <MudIconButton @onclick="(() => EditLup(lupId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>
            }
            <MudButton Color="Color.Info" OnClick="Close">@Localizer["close"]</MudButton>
            </DialogActions>
        </MudDialog>

}