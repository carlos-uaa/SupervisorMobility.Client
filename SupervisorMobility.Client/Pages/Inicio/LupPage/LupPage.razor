                                <MudSpacer />
                                <MudTextField @bind-Value="searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5" Clearable></MudTextField>
                                <MudSpacer />
                            }
                            else if (_filterlups.Where(l => l.Lup.Pillar == 1).ToList().Count == 0 && !filters)
