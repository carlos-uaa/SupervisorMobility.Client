    <MudDialog DisableSidePadding="false" @bind-IsVisible="visible3" Options="dialogOptions">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">

                <MudTable Items="_SOSJobobservation" T="JobObservationNulls" Hover Filter="new Func<JobObservationNulls,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true Height="400px"
                       HorizontalScrollbar="true">
                 <ToolBarContent>
                     <MudText Typo="Typo.h6">@Localizer["sosProgram"]</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5"></MudTextField>
                        <MudSpacer />
                    </ToolBarContent>
                    <ColGroup>
                        <col style="width: 60px;" />
                        <col />
                        <col />
                        <col />
                        <col />
                        <col />
                    </ColGroup>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<JobObservationNulls, object>(x=>x.JobObservationId)">Id</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<JobObservationNulls, object>(x=>x?.Distribution?.Description)">@Localizer["distribution"]</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<JobObservationNulls, object>(x=>x.StartDate)">@Localizer["startDate"]</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<JobObservationNulls, object>(x=>x?.Status)">@Localizer["status"]</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: center">@Localizer["actions"]</MudTh>
                    </HeaderContent>
                    <GroupHeaderTemplate>
                    </GroupHeaderTemplate>
                    <RowTemplate>
                        <MudTd DataLabel="Id">
                            <MudText Align="Align.Center">@context.JobObservationId</MudText>
                        </MudTd>
                        <MudTd DataLabel=@Localizer["distribution"]>
                            <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
                        </MudTd>
                        <MudTd DataLabel=@Localizer["startDate"]>
                            <MudText Align="Align.Center">@context.StartDate?.ToShortDateString()</MudText>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudText Align="Align.Center">
                                @switch (context.Status)
                            {
                                case 1:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Style="cursor:pointer">@Localizer["planned"]</MudChip>
                                    break;
                                case 2:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                    break;
                                case 3:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                    break;
                                case 4:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                    break;
                                case 5:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                    break;
                                case 6:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                    break;
                                case 7:
                                    @if (context.StartDate?.Month >= DateTime.Now.Month && context.StartDate?.Year >= DateTime.Now.Year)
                                    {
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Style="cursor:pointer">@Localizer["programmed"]</MudChip>

                                    }
                                    else
                                    {
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Info" Color="Color.Error" Style="cursor:pointer">@Localizer["programmed"]</MudChip>
                                    }
                                    break;
                            }
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Align="Align.Center">
                            @if (context.Status != 7)
                            {
                                <MudButton @onclick="(() =>  OpenDialog2(context.JobObservationId))" StartIcon="@Icons.Material.Filled.Info" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                                    @Localizer["details"]
                                </MudButton>
                            }
                            else
                            {
                                @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                {
                                    <MudButton @onclick="(() =>  OpenDialog3(context.JobObservationId))" StartIcon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Variant="Variant.Filled" Size="Size.Small">
                                        @Localizer["planIt"]
                                    </MudButton>
                                }
                                else
                                {
                                    <MudButton @onclick="(() =>  OpenDialog3(context.JobObservationId))" StartIcon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Variant="Variant.Filled" Size="Size.Small">
                                        @Localizer["details"]
                                    </MudButton>
                                }
                            }
                        </MudText>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudContainer>
