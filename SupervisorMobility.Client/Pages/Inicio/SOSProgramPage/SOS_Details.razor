@page "/SOSDetails/{sosId:int}"

@using System.Net.Http.Json
@using AutoMapper;
@using MudBlazor
@using MudBlazor.Utilities;
@using System.Globalization;
@using System.Text.RegularExpressions;
@using System.Runtime.CompilerServices;

@inject NavigationManager NavigationManager
@inject IUserService UsersServices
@inject IAreaService AreasServices
@inject IOperationService OperationsServices
@inject IJobObservationService JobObsServices
@inject IPATService PATsServices
@inject IJSRuntime JSRuntime
@inject IJSRuntime JS
@inject IILUService ILUServices
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject IDistributionService DistributionServices
@inject ISOSReviewService SOSServices
@inject IJobStructureService JobStructureCategoriesService
@inject IAssyChartService AssyChartsServices
@inject IBridgeCDMSService CDMSServices
@inject IMapper _mapper;

<style>

    .vertical-text {
        vertical-align: middle;
    }

    .vertical-content {
        writing-mode: vertical-lr;
        white-space: nowrap;
        word-wrap: break-word;
        max-width: 100%;
    }
   

    .mud-simple-table.mud-table-sticky-header * table thead * th {
    background-color: var(--mud-palette-surface);
    position: sticky;
    z-index: 2;
    top: 0;
}

    .scroll1::-webkit-scrollbar {
        width: 4px;
        touch-action: pan-y;
    }

    .mud-tabs-header.mud-tabs-header-after {
        width: 100%;
    }

    .mud-tabs-toolbar-content {
        width: 50%;
        display: flex;
        position: relative;
        justify-content: center;
    }

    .mud-tabs-header.mud-tabs-header-before {
        display: flex;
        width: 50%;
    }

    .table-container {
        box-shadow: var(--mud-elevation-1);
        overflow-x: auto;
        border-radius: var(--mud-default-borderradius);
    }

        .table-container:hover {
            box-shadow: var(--mud-elevation-2);
        }


    .fixed-column {
        position: sticky;
        left: 0;
        z-index: 2 ;
        background-color: #f0f0f0;
    }

    .dynamic-left {
        left: 0;
    }

    table {
        border-collapse: collapse;
        min-width: 100%;
        border-radius: var(--mud-default-borderradius);
    }

    th,
    td {
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .fixed-row {
    position: sticky;
    top: 0; /* Las filas fijas se ubicarán en la parte superior de la tabla */
    z-index: 2; /* Asegura que las filas fijas estén por encima del contenido desplazable */
}
</style>


@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["sosDetails"]</PageTitle>
    @*Breadcrumb links*@
    @*  <div style="display: flex; align-items: center; justify-content: space-between;">
        <MudItem>
            <MudBreadcrumbs Class="mb-2" Items="_links">
                <ItemTemplate Context="item">
                    <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
                </ItemTemplate>
            </MudBreadcrumbs>
        </MudItem>
        <MudItem Style="text-align: end">
            <img src="Images/logo.png" Height="50" />
        </MudItem>
    </div> *@
    @if (ShowTable)
{

    <MudTabs @ref="tabs" Border="true" Outlined="true" ApplyEffectsToContainer="true" Class="mt-0 mx-0" HeaderPosition="TabHeaderPosition.Before" PrevIcon="@Icons.Material.Filled.SkipPrevious" NextIcon="@Icons.Material.Filled.SkipNext">
        <Header>
            <MudItem style="display:flex; width: 200%; justify-content: space-around">
                <MudItem>
                    <MudItem>
                        <MudItem Class="d-flex">
                            <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
                            <MudText Class="ml-2">@Localizer["plant"]: </MudText>
                            <MudText Class="ml-2"> @_sos_plan.Plant?.Description</MudText>
                            </MudItem>
                        </MudItem>
                        <MudItem>
                            <MudItem Class="d-flex">
                                <MudIcon Icon="@Icons.Material.Filled.BusinessCenter"> </MudIcon>
                                <MudText Class="ml-2">@Localizer["area"]: </MudText>
                            <MudText Class="ml-2"> @_sos_plan.Area?.Description</MudText>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                    @if (MonthlyView)
                {
                    <MudItem Style="display: flex;  align-items: center">
                        <MudTooltip Text=@Localizer["lastMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info">
                            @if (SuggestionMode)
                            {
                                if (_yearMonth.Value.Month >= 2 && (_yearMonth.Value.Month - 1) > DateTime.Now.Month)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Color="Color.Info" @onclick="@(()=>LastMonth())" Class="mr-4"></MudIconButton>
                                }
                            }
                            else
                            {
                                if (_yearMonth.Value.Month >= 2)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Color="Color.Info" @onclick="@(()=>LastMonth())" Class="mr-4"></MudIconButton>
                                }
                            }
                        </MudTooltip>
                        <MudDatePicker Style="width: 150px; margin-top: -8px" OpenTo="OpenTo.Month" MinDate="@date" MaxDate="@LastdayYear" FixDay="1" DateFormat="MMMM / yyyy" PickerVariant="PickerVariant.Dialog" Color="Color.Info" AdornmentColor="Color.Info" DateChanged=@OnDateChanged Date="_yearMonth" />
                        <MudTooltip Text=@Localizer["nextMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info">
                            @if (_yearMonth.Value.Month <= 11)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowForwardIos" Color="Color.Info" @onclick="@(()=>NextMonth())" Class="ml-4"></MudIconButton>
                            }
                        </MudTooltip>
                    </MudItem>
                }
            </MudItem>
        </Header>
        <ChildContent>

            <MudTabPanel Text="@Localizer["yearly"]" Icon="@Icons.Material.Filled.CalendarViewDay" ID='"pn_one"' OnClick="@( () => YearlyTab())">
                <ChildContent>
                    @if (ShowTable)
                    {
                        <div class="table-container">
                            <div class="scrollable-columns">
                                <MudSimpleTable Class="mb-5 calendar-table rounded" Dense FixedHeader="true" Style="overflow-x: auto; height: 82vh">
                                     <thead>
                                         <tr>
                                             <th rowspan="2">
                                                 <MudItem Class="d-flex">
                                                     <MudIcon Icon="@Icons.Material.Filled.AccountTree"> </MudIcon>
                                                     <MudText Class="ml-2">@Localizer["distribution"]</MudText>
                                                    </MudItem>
                                                </th>
                                                <th rowspan="2" class="fixed-column dynamic-left">
                                                    No. HOE
                                                </th>
                                                <th rowspan="2">
                                                    @Localizer["HOEName"]
                                            </th>
                                            <th rowspan="2" Style="min-width: 350px" class="fixed-column dynamic-left">
                                                @Localizer["whoReviews"]
                                            </th>
                                            <th rowspan="2">
                                                @Localizer["directories"]
                                            </th>
                                            <th rowspan="2" class="vertical-text fixed-column dynamic-left">
                                                <div class="vertical-content">
                                                    @Localizer["scheduling"]
                                                </div>
                                            </th>
                                            @for (var i = 1; i <= 12; i++)
                                            {
                                                <th style="text-align: center" rowspan="2">
                                                    @textInfo.ToTitleCase(CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(i))
                                                </th>
                                            }
                                            <th colspan="3" rowspan="2">
                                                @Localizer["notes"]
                                            </th>

                                        </tr>

                                    </thead>
                                    <tbody style="width: 100%;">
                                        @foreach (Distribution Distribution_Item in _distributions)
                                        {
                                            var rowTotal = Distribution_Item.Operations.Count() != 0 ? Distribution_Item.Operations.Count() * 2 + 1 : 2;
                                            var _ = OperationsInDistributionCount.TryGetValue(Distribution_Item.DistributionId, out SosJobCount opInDist);

                                            @if(Distribution_Item.ShowDetails){
                                                <MudTr Class="fixed-row">
                                                    <MudTd colspan="20" DataLabel="Distribution" @onclick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">
                                                        @if (opInDist != null)
                                                        {
                                                            <MudButton Style=" display: -webkit-box; max-width: 650px" Variant="Variant.Text" Class="fixed-column dynamic-left" Size="Size.Small" OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">
                                                                <MudButton Size="Size.Small" Style="width: 500px;" Class="fixed-column dynamic-left" EndIcon="@(Distribution_Item.ShowDetails ? @Icons.Material.Filled.KeyboardArrowUp : @Icons.Material.Filled.KeyboardArrowDown)" OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">
                                                                    @Distribution_Item.Description
                                                                </MudButton>
                                                                @if (opInDist != null)
                                                                {
                                                                    @if (@opInDist.sosfinished == @opInDist.TotalJobs)
                                                                    {
                                                                        <MudChip Color="Color.Success" Variant="Variant.Text" Size="Size.Small">@opInDist.sosfinished of @opInDist.TotalJobs</MudChip>
                                                                    }
                                                                    else
                                                                    {
                                                                        <MudChip Color="Color.Warning" Variant="Variant.Text" Size="Size.Small">@opInDist.sosfinished of @opInDist.TotalJobs</MudChip>
                                                                    }
                                                                }
                                                                <MudButton Style=" display: -webkit-box;" Class="fixed-column dynamic-left" FullWidth="true" Color="Color.Primary" Variant="Variant.Text" Size="Size.Small" EndIcon="@Icons.Material.Filled.BarChart" OnClick="@(() => OpenGraphicDonnut(@opInDist))">
                                                                </MudButton>
                                                            </MudButton>
                                                        }
                                                        else
                                                        {
                                                            <MudButton Style=" display: -webkit-box; width: 650px" Variant="Variant.Text" Class="fixed-column dynamic-left" Size="Size.Small" OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">
                                                                <MudButton Size="Size.Small" Style="width: 500px;" Class="fixed-column dynamic-left" EndIcon="@(Distribution_Item.ShowDetails ? @Icons.Material.Filled.KeyboardArrowUp : @Icons.Material.Filled.KeyboardArrowDown)" OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">
                                                                    @Distribution_Item.Description
                                                                </MudButton>
                                                            </MudButton>
                                                        }
                                                    </MudTd>
                                                </MudTr>
                                            }else{
                                                <MudTr>
                                                <MudTd colspan="20" DataLabel="Distribution" @onclick="@(() => ShowBtnPress(Distribution_Item.DistributionId))"> 
                                                 @if (opInDist != null)
                                                {
                                                    <MudButton Style=" display: -webkit-box; max-width: 650px" Variant="Variant.Text" Class="fixed-column dynamic-left" Size="Size.Small"  OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">
                                                        <MudButton Size="Size.Small" Style="width: 500px;" Class="fixed-column dynamic-left" EndIcon="@(Distribution_Item.ShowDetails ? @Icons.Material.Filled.KeyboardArrowUp : @Icons.Material.Filled.KeyboardArrowDown)" OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">
                                                            @Distribution_Item.Description
                                                        </MudButton>
                                                        @if (opInDist != null)
                                                        {
                                                            @if (@opInDist.sosfinished == @opInDist.TotalJobs)
                                                            {
                                                                <MudChip Color="Color.Success" Variant="Variant.Text" Size="Size.Small">@opInDist.sosfinished of @opInDist.TotalJobs</MudChip>
                                                            }
                                                            else
                                                            {
                                                                <MudChip Color="Color.Warning" Variant="Variant.Text" Size="Size.Small">@opInDist.sosfinished of @opInDist.TotalJobs</MudChip>
                                                            }
                                                        }
                                                            <MudButton Style=" display: -webkit-box;" Class="fixed-column dynamic-left" FullWidth="true" Color="Color.Primary" Variant="Variant.Text" Size="Size.Small" EndIcon="@Icons.Material.Filled.BarChart" OnClick="@(() => OpenGraphicDonnut(@opInDist))">
                                                            </MudButton>
                                                    </MudButton>
                                                }else{
                                                     <MudButton Style=" display: -webkit-box; width: 650px" Variant="Variant.Text" Class="fixed-column dynamic-left" Size="Size.Small"  OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">
                                                        <MudButton Size="Size.Small" Style="width: 500px;" Class="fixed-column dynamic-left" EndIcon="@(Distribution_Item.ShowDetails ? @Icons.Material.Filled.KeyboardArrowUp : @Icons.Material.Filled.KeyboardArrowDown)" OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">
                                                            @Distribution_Item.Description
                                                    </MudButton>
                                                    </MudButton>
                                                }
                                                </MudTd>
                                            </MudTr>
                                            }
                                            
                                            @if (Distribution_Item.ShowDetails)
                                            {

                                               @if(Distribution_Item.Operations.Count > 0){
                                                    <tr>
                                                        <td rowspan="@rowTotal"><MudButton Style="height: 100%" Variant="Variant.Outlined" EndIcon="@Icons.Material.Filled.KeyboardArrowUp" FullWidth=true OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">@((Distribution_Item.ShowDetails == true) ? "Hide" : "Show")  @Distribution_Item.Description </MudButton></td>
                                                        </tr>
                                                    @foreach (var op in Distribution_Item.Operations)
                                                {
                                                    <tr>
                                                        <td rowspan="2" class="fixed-column dynamic-left">@op.Code</td>
                                                        <td rowspan="2">@op.Description</td>
                                                        <td rowspan="2" Style="min-width: 350px" class="fixed-column dynamic-left">

                                                                @if (SOS_Registers_UserOperationRelationship.TryGetValue(op.OperationId, out var context))
                                                            {
                                                                if (context.Exist)
                                                                {
                                                                    if (context.StateUpdate)
                                                                    {
                                                                        <MudAutocomplete Margin="Margin.Dense" Clearable T="User" Label="@Localizer1["UsersSupervisor"]" @bind-Value="context.Register.Supervisor"
                                                                                          SearchFunc="@SearchSV" ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer1["UsersPHSupervisor"]}" : $"[{e.UserId}] - {e.Name} - {e.Group?.Description}")"
                                                                                          Variant="Variant.Outlined" AdornmentIcon="@(context.StateUpdate ? @Icons.Material.Filled.Save : @Icons.Material.Filled.Person)"
                                                                                          ShowProgressIndicator="true" MaxItems="null"
                                                                                                                      ResetValueOnEmptyText
                                                                                          OnAdornmentClick="@( () =>  BtnSupervisorsEdit(op.OperationId))">
                                                                             <ItemTemplate Context="e">
                                                                                 <MudItem Style="text-align: center">
                                                                                     @switch (e.UserType)
                                                                                    {
                                                                                        case 3:
                                                                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary" Class="mr-15 mt-5"> @Localizer1["UsersSupervisor"] </MudChip>
                                                                                            break;
                                                                                    }
                                                                                </MudItem>
                                                                                <div class="font-weight-bold"><b>@Localizer1["UserId"]:</b>  @e.UserId</div>
                                                                                <div class="font-weight-bold"><b>@Localizer1["UsersName"]:</b>  @e.Name</div>
                                                                                <div class="font-weight-bold"><b>@Localizer1["UsersGroup"]:</b>  @e.Group?.Description</div>
                                                                                <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@e.Area?.Code - @e.Area?.Description </MudChip>

                                                                                </ItemTemplate>
                                                                            </MudAutocomplete>

                                                                    }
                                                                    else
                                                                    {
                                                                        <MudTextField Margin="Margin.Dense" ReadOnly="true" Label="Supervisor" Value="context.Register.Supervisor?.Name" Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentIcon="@(context.StateUpdate ? @Icons.Material.Filled.Save : @Icons.Material.Filled.Edit)" OnAdornmentClick="@( () =>  BtnSupervisorsEdit(op.OperationId))" AdornmentAriaLabel="Upate" />
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    <MudAutocomplete Margin="Margin.Dense" Clearable T="User" Label="@Localizer1["UsersSupervisor"]" @bind-Value="context.Register.Supervisor"
                                                                                      SearchFunc="@SearchSV" ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer1["UsersPHSupervisor"]}" : $"[{e.UserId}] - {e.Name} - {e.Group?.Description}")"
                                                                                      Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.SaveAs"
                                                                                                                  ResetValueOnEmptyText
                                                                                      ShowProgressIndicator="true" MaxItems="null"
                                                                                      OnAdornmentClick="@( () =>  BtnSupervisorsEdit(op.OperationId))">
                                                                         <ItemTemplate Context="e">
                                                                             <MudItem Style="text-align: center">
                                                                                 @switch (e.UserType)
                                                                                {
                                                                                    case 3:
                                                                                        <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary" Class="mr-15 mt-5"> @Localizer1["UsersSupervisor"] </MudChip>
                                                                                        break;
                                                                                }
                                                                            </MudItem>
                                                                            <div class="font-weight-bold"><b>@Localizer1["UserId"]:</b>  @e.UserId</div>
                                                                            <div class="font-weight-bold"><b>@Localizer1["UsersName"]:</b>  @e.Name</div>
                                                                            <div class="font-weight-bold"><b>@Localizer1["UsersGroup"]:</b>  @e.Group?.Description</div>
                                                                            <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@e.Area?.Code - @e.Area?.Description </MudChip>

                                                                            </ItemTemplate>
                                                                        </MudAutocomplete>
                                                                }

                                                            }


                                                        </td>
                                                            <MudTd rowspan="2">
                                                                @if (_assyCharts.Any(r => r.DistributionId == Distribution_Item.DistributionId))
                                                                {
                                                                    var _assychart = _assyCharts?.Where(r => r.DistributionId == Distribution_Item.DistributionId).FirstOrDefault();

                                                                    <MudItem Style="text-align: start">
                                                                        @if (_assychart != null)
                                                                        {
                                                                            <MudItem Class="d-flex flex-row align-start justify-center">

                                                                                @if (_assychart.RoutesProductsAssyChart?.Count > 0 && _assychart.RoutesProductsAssyChart.Any(r => r.Code.ToLower().Contains(op.Code.ToLower(), StringComparison.InvariantCultureIgnoreCase)))
                                                                                {
                                                                                    var RoutesCode = _assychart.RoutesProductsAssyChart.Where(r => r.Code.ToLower().Contains(op.Code.ToLower(), StringComparison.InvariantCultureIgnoreCase)).ToList();
                                                                                    <MudMenu Dense=true AnchorOrigin="Origin.BottomCenter" Style="display: flex" TransformOrigin="Origin.TopCenter">
                                                                                        <ActivatorContent>
                                                                                            <MudButton FullWidth="true" StartIcon="@Icons.Material.Filled.Folder" Color="Color.Warning" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                                                        </ActivatorContent>
                                                                                        <ChildContent>
                                                                                            <MudExpansionPanels Elevation="0">
                                                                                                @foreach (SOSCodePath item in RoutesCode)
                                                                                                {

                                                                                                    <MudExpansionPanel Style="width: auto;">
                                                                                                        <TitleContent>
                                                                                                            <div Style="align-items: center; display: flex;">
                                                                                                                <MudText>@item.Code</MudText>
                                                                                                                    <MudChip Icon="@Icons.Material.Filled.DirectionsCar" IconColor="Color.Info" Variant="Variant.Text" Color="Color.Success">@item.Product?.Code - @item.Product?.Description</MudChip>
                                                                                                                </div>
                                                                                                            </TitleContent>
                                                                                                            <ChildContent>
                                                                                                                <MudItem class="d-flex flex-column justify-center ma-1">
                                                                                                                    <MudItem class="d-flex d-flex-column justify-center">

                                                                                                                        <MudItem Style="flex-direction: column;">
                                                                                                                            @if (item.HOE != "")
                                                                                                                        {
                                                                                                                            <MudPaper Elevation="0">
                                                                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, HOE))" @ontouchstart="(() => OpenDialogCodePath(item,HOE))" Style="padding: 0px;" Color="Color.Error">
                                                                                                                                    <MudTooltip Text=@Localizer["openHOEFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                                                                        <MudTooltip Text="@Regex.Replace(item.HOE, @"/(.*?)§", "/").Replace('§', ' ')" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.HOE.Split('§').Last()</MudChip>
                                                                                                                                            </MudTooltip>
                                                                                                                                        </MudTooltip>
                                                                                                                                    </MudButton>
                                                                                                                                </MudPaper>
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            <MudPaper Elevation="0">
                                                                                                                                <MudAlert Severity="Severity.Info">@Localizer["noHOEPath"]</MudAlert>
                                                                                                                                </MudPaper>
                                                                                                                        }

                                                                                                                        @if (item.CommonDirectionHOE != "")
                                                                                                                        {
                                                                                                                            <MudPaper Elevation="0">
                                                                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, HOECD))" @ontouchstart="(() => OpenDialogCodePath(item, HOECD))" Style="padding: 0px;" Color="Color.Error">
                                                                                                                                    <MudTooltip Text=@Localizer["openHOEFolderCD"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                                                                        <MudTooltip Text="@Regex.Replace(item.CommonDirectionHOE, @"/(.*?)§", "/").Replace('§', ' ')" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CommonDirectionHOE.Split('§').Last()</MudChip>
                                                                                                                                            </MudTooltip>
                                                                                                                                        </MudTooltip>
                                                                                                                                    </MudButton>
                                                                                                                                </MudPaper>
                                                                                                                        }

                                                                                                                    </MudItem>

                                                                                                                    <MudItem Style="flex-direction: column;">
                                                                                                                        @if (@item.CCP != "")
                                                                                                                        {
                                                                                                                            <MudPaper Elevation="0">
                                                                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, CCP))" @ontouchstart="(() => OpenDialogCodePath(item, CCP))" Style="padding: 0px;" Color="Color.Error">
                                                                                                                                    <MudTooltip Text=@Localizer["openCCPFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                                                                        <MudTooltip Text="@item.CCP" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CCP.Split('/').Last()</MudChip>
                                                                                                                                            </MudTooltip>
                                                                                                                                        </MudTooltip>
                                                                                                                                    </MudButton>
                                                                                                                                </MudPaper>
                                                                                                                        }
                                                                                                                        else
                                                                                                                        {
                                                                                                                            <MudPaper Elevation="0">
                                                                                                                                <MudAlert Severity="Severity.Info">@Localizer["noCCPPath"]</MudAlert>
                                                                                                                                </MudPaper>
                                                                                                                        }
                                                                                                                        @if (@item.CommonDirectionCCP != "")
                                                                                                                        {
                                                                                                                            <MudPaper Elevation="0">
                                                                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, CCPCD))" @ontouchstart="(() => OpenDialogCodePath(item, CCPCD))" Style="padding: 0px;" Color="Color.Error">
                                                                                                                                    <MudTooltip Text=@Localizer["openCCPFolderCD"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                                                                        <MudTooltip Text="@item.CommonDirectionCCP" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CommonDirectionCCP.Split('/').Last()</MudChip>
                                                                                                                                            </MudTooltip>
                                                                                                                                        </MudTooltip>
                                                                                                                                    </MudButton>
                                                                                                                                </MudPaper>
                                                                                                                        }
                                                                                                                    </MudItem>

                                                                                                                    <MudItem Style="flex-direction: column;">
                                                                                                                        @if (item.GOS != "")
                                                                                                                        {
