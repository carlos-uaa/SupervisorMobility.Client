    private async Task<AsyncVoidMethodBuilder> CreateSuggestion()
    {
        Console.WriteLine($" Entro a CreateSuggestion");
        int Suggestday = 1;
        int SuggestMonth = 9;
        try
        {
            ShowLoading = true;
            base.StateHasChanged();

            foreach (var op in _All_Operations)
            {

                string dateString = "";
                DateTime parsedDate = new();
                if (SuggestMonth < 10)
                {
                    if (Suggestday < 10)
                    {
                        dateString = $"0{Suggestday}/0{SuggestMonth}/{(int)SOS_Review.AplicationYear}";
                    }
                    else
                    {
                        dateString = $"{Suggestday}/0{SuggestMonth}/{(int)SOS_Review.AplicationYear}";
                    }
                }
                else
                {
                    if (Suggestday < 10)
                    {
                        dateString = $"0{Suggestday}/{SuggestMonth}/{(int)SOS_Review.AplicationYear}";
                    }
                    else
                    {
                        dateString = $"{Suggestday}/{SuggestMonth}/{(int)SOS_Review.AplicationYear}";
                    }
                }

                parsedDate = DateTime.ParseExact(dateString, "dd/MM/yyyy", CultureInfo.InvariantCulture);

                JobObservationNulls _newSuggestion = new();


                _newSuggestion.PlantId = (int)SOS_Review.PlantId;
                _newSuggestion.Plant = SOS_Review.Plant;
                _newSuggestion.AreaId = (int)SOS_Review.AreaId;
                _newSuggestion.Area = SOS_Review.Area;

                _newSuggestion.Distribution = _distributions.Find(d => d.Operations.Any(o => o.OperationId == op.OperationId));
                _newSuggestion.DistributionId = _newSuggestion.Distribution.DistributionId;

                _newSuggestion.SupervisorId = (int)SOS_Review.Supervisorid;
                _newSuggestion.Supervisor = SOS_Review.Supervisor;


                _newSuggestion.Option = 2;
                _newSuggestion.Type = 3;
                _newSuggestion.Status = 7;
                _newSuggestion.IsActive = true;
                _newSuggestion.StartDate = parsedDate;


                _All_Suggested_SOSJobobservation.Add(_newSuggestion);
                 Console.WriteLine($"Operacion Unitaria: {parsedDate}");

                if(Suggestday == 20)
                    break;

                Suggestday++;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error CreateSuggestion: {ex.Message}");

        }
        finally
        {
            ShowLoading = false;
            base.StateHasChanged();
        }



        return new AsyncVoidMethodBuilder();

    }


