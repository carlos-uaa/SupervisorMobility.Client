                                                  InputData="@Sosdata" InputLabels="@labels" XAxisLabels="@labels">
                                            <CustomGraphics>
                                                <text class="donut-inner-text" x="47%" y="35%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="2">Total SOS</text>
                                                <text class="donut-inner-text" x="47%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="5">@Sosdata.Sum().ToString()</text>
                                            </CustomGraphics>
                                        </MudChart>
                                    </MudItem>
                                </td>
                                <td colspan="9" rowspan="4">
                                    <MudItem style="display: flex">

                                        <MudChart ChartType="ChartType.Donut" LegendPosition="Position.Left" Width="300px" Height="300px"
                                                  InputData="@AnotherData" InputLabels="@labels" XAxisLabels="@labels">
                                            <CustomGraphics>
                                                <text class="donut-inner-text" x="47%" y="35%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="2">Total Another</text>
                                                <text class="donut-inner-text" x="47%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="5">@AnotherData.Sum().ToString()</text>
                                            </CustomGraphics>
                                        </MudChart>
                                    </MudItem>
                                </td>


                            </tr>
                        </MudSimpleTable>
                   
            }
        </MudContainer>
        </DialogContent>
        <DialogActions>
        <MudButton Color="Color.Info" OnClick="CloseGraphicDonnut">@Localizer["close"]</MudButton>
        </DialogActions>
    </MudDialog>


