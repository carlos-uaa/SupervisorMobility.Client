    private IEnumerable<string> ValidateStartDay(int? startDay)
    {
        if (!startDay.HasValue)
        {
            yield return "Ingrese un número válido.";
            yield break;
        }

        if (startDay < 3 || startDay >= 25)
        {
            yield return "El día debe ser mayor o igual a 3 y menor a 25.";
        }
    }
