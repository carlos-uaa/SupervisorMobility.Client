                                                <MudSelectItem Disabled="true" Value="@_Selected_Suggested_SOSJobobservation.AreaId">@_Selected_Suggested_SOSJobobservation.Area?.Code - @_Selected_Suggested_SOSJobobservation.Area?.Description</MudSelectItem>
                                            </MudSelect>

                                        </div>
                                    </td>
                                    <td class="d-flex">
                                        <MudDatePicker DateChanged="@(dt => OnStartDateChanged((DateTime)dt))" Date="_Selected_Suggested_SOSJobobservation.StartDate" Label=@Localizer["startDate"] Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4 pt-2" MinDate="@DateTime.Now.AddDays(-1)" MaxDate="LastdayYear" />
                                        <MudDatePicker @bind-Date="_Selected_Suggested_SOSJobobservation.EndDate" Label=@Localizer["endDate"] Color="Color.Info" AdornmentColor="Color.Info" MinDate="_Selected_Suggested_SOSJobobservation.StartDate" MaxDate="LastdayYear" Class="pt-2" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        @*Mud select of Distribution *@
                                        <MudSelect T="int" Label=@Localizer["distribution"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_Selected_Suggested_SOSJobobservation.DistributionId">
                                            <MudSelectItem Disabled="true" Value="@_Selected_Suggested_SOSJobobservation.DistributionId">@_Selected_Suggested_SOSJobobservation.Distribution?.Code - @_Selected_Suggested_SOSJobobservation.Distribution?.Description</MudSelectItem>
                                        </MudSelect>
                                    </td>
                                    <td>
                                        <MudTextField T="string" @bind-Value="_Selected_Suggested_SOSJobobservation.Supervisor.Name" Label=@Localizer["observer"] Class="mr-4" />
                                        @*                              <MudTimePicker Label="Start hour" @bind-Time="startHour" Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4 pt-2" ReadOnly/>
                                        <MudTimePicker Label="End hour" @bind-Time="endHour" Color="Color.Info" AdornmentColor="Color.Info" Class="pt-2" ReadOnly />*@
                                    </td>
                                </tr>
                                <tr>
                                    <MudCard Elevation="0">
                                        <MudCardContent>
                                            <MudText>Operations</MudText>
                                            <div class="toggle-group-container">

                                                @foreach (Operation operation in _Selected_Suggested_SOSJobobservation.Operations)
                                                {
                                                    <MudChip T="string" Variant="Variant.Text" Color="Color.Info" Class="toggle-column">
                                                        @($"{operation.Code} - {operation.Description}")
                                                        @switch (operation.CriticalType)
                                                        {
                                                            case 1:
                                                                <MudItem>
                                                                    <img src="Images/A.png" Height="25" Width="25" />
                                                                </MudItem>
                                                                break;
                                                            case 2:
                                                                <MudItem>
                                                                    <img src="Images/B.png" Height="25" Width="25" />
                                                                </MudItem>
                                                                break;
                                                            case 3:
                                                                <MudItem>
                                                                    <img src="Images/C.png" Height="25" Width="25" />
                                                                </MudItem>
                                                                break;
                                                        }
                                                    </MudChip>
                                                }
                                            </div>
                                        </MudCardContent>
                                    </MudCard>

                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudItem>
                </MudPaper>

                <MudCardActions>
                    @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                    {
                        <MudItem Class="ml-auto">
                            <MudButton StartIcon="@Icons.Material.Filled.DateRange" Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => CloseToReprogramSuggestion())">@Localizer["save"]</MudButton>
                        </MudItem>
                    }
                </MudCardActions>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        @* <MudButton OnClick="CloseToReprogramSuggestion" Variant="Variant.Filled">@Localizer["Close"]</MudButton> *@
    </DialogActions>
</MudDialog>


<MudDialog @bind-IsVisible="visibleApplySuggest" Options="dialogDeleteOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
        <MudText Class="mt-4 mb-4">
            @Localizer["areYouSueYourWantToConfirmThisSOS"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseApplySuggesModal" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
        <MudButton @onclick="(() => ApplySuggest())" Color="Color.Success" StartIcon="@Icons.Material.Filled.Check" Variant="Variant.Filled">@Localizer["confirm"]</MudButton>
    </DialogActions>
</MudDialog>