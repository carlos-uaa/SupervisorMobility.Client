<MudDialog DisableSidePadding="false" @bind-IsVisible="visible3" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 75vh; overflow-y: scroll">

                <MudTable Items="_All_SOSJobobservation" T="JobObservationNulls" Hover Filter="new Func<JobObservationNulls,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true Height="400px"
                       HorizontalScrollbar="true">
                 <ToolBarContent>
                     <MudText Typo="Typo.h6">@Localizer["sosProgram"]</MudText>
                     <MudSpacer />
                     <MudTextField @bind-Value="searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5"></MudTextField>
                     <MudSpacer />
                 </ToolBarContent>
                 <ColGroup>
                     <col style="width: 60px;" />
                     <col />
                     <col />
                     <col />
                     <col />
                     <col />
                 </ColGroup>
                 <HeaderContent>
                     <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.JobObservationId)">Id</MudTableSortLabel></MudTh>
                     <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Distribution?.Description)">@Localizer["distribution"]</MudTableSortLabel></MudTh>
                     <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operation?.Description)">@Localizer["operation"]</MudTableSortLabel></MudTh>
                     <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.StartDate)">@Localizer["startDate"]</MudTableSortLabel></MudTh>
                     <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operator?.Name)">@Localizer["operator"]</MudTableSortLabel></MudTh>
                     <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Status)">@Localizer["status"]</MudTableSortLabel></MudTh>
                     <MudTh Style="text-align: center">@Localizer["actions"]</MudTh>
                 </HeaderContent>
                 <GroupHeaderTemplate>
                 </GroupHeaderTemplate>
                 <RowTemplate>
                     <MudTd DataLabel="Id">
                         <MudText Align="Align.Center">@context.JobObservationId</MudText>
                     </MudTd>
                     <MudTd DataLabel=@Localizer["distribution"]>
                         <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
                     </MudTd>
                     <MudTd DataLabel=@Localizer["operation"]>
                         <MudText Align="Align.Center">@context.Operation?.Description</MudText>
                     </MudTd>
                     <MudTd DataLabel=@Localizer["startDate"]>
                         <MudText Align="Align.Center">@context.StartDate?.ToShortDateString()</MudText>
                     </MudTd>
                     <MudTd DataLabel=@Localizer["operator"]>
                         <MudText Align="Align.Center">@context.Operator?.Name</MudText>
                     </MudTd>
                     <MudTd DataLabel="Status">
                         @if (context.StartDate?.Month >= DateTime.Now.Month && context.StartDate?.Year >= DateTime.Now.Year)
                        {
                            <MudText Align="Align.Center">
                                <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">@Localizer["programmed"]</MudChip>
                            </MudText>
                        }
                        else
                        {
                            <MudText Align="Align.Center">
                                <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Info" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">@Localizer["programmed"]</MudChip>
                            </MudText>
                        }
                    </MudTd>
                    <MudTd>
                        <MudText Align="Align.Center">
                            <MudButton @onclick="(() =>  OpenDialog3(context.JobObservationId,  context.PlannedStartDate.Value.Date))" FullWidth=true StartIcon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Variant="Variant.Filled" Size="Size.Small">
                                @Localizer["planIt"]
                            </MudButton>
                        </MudText>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="Close3">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>

