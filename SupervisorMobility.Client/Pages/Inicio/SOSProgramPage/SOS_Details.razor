    @if (ShowTable)
{
    <MudTabs @ref="tabs" Border="true" Outlined="true" ApplyEffectsToContainer="true" Class="mt-0 mx-0" HeaderPosition="TabHeaderPosition.Before" PrevIcon="@Icons.Material.Filled.SkipPrevious" NextIcon="@Icons.Material.Filled.SkipNext">
        <Header>
            <MudItem style="display:flex; width: 200%; justify-content: space-around">
                <MudItem>
                    <MudItem>
                        <MudItem Class="d-flex">
                            <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
                            <MudText Class="ml-2">@Localizer["plant"]: </MudText>
                            <MudText Class="ml-2"> @_sos_plan.Plant?.Description</MudText>
                            </MudItem>
                        </MudItem>
                        <MudItem>
                            <MudItem Class="d-flex">
                                <MudIcon Icon="@Icons.Material.Filled.BusinessCenter"> </MudIcon>
                                <MudText Class="ml-2">@Localizer["area"]: </MudText>
                            <MudText Class="ml-2"> @_sos_plan.Area?.Description</MudText>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                    @if (MonthlyView)
                {
                    <MudItem Style="display: flex;  align-items: center">
                        <MudTooltip Text=@Localizer["lastMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info">
                            @if (SuggestionMode)
                            {
                                if (_yearMonth.Value.Month >= 2 && (_yearMonth.Value.Month - 1) > DateTime.Now.Month)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Color="Color.Info" @onclick="@(()=>LastMonth())" Class="mr-4"></MudIconButton>
                                }
                            }
                            else
                            {
                                if (_yearMonth.Value.Month >= 2)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Color="Color.Info" @onclick="@(()=>LastMonth())" Class="mr-4"></MudIconButton>
                                }
                            }
                        </MudTooltip>
                        <MudDatePicker Style="width: 150px; margin-top: -8px" OpenTo="OpenTo.Month" MinDate="@date" MaxDate="@LastdayYear" FixDay="1" DateFormat="MMMM / yyyy" PickerVariant="PickerVariant.Dialog" Color="Color.Info" AdornmentColor="Color.Info" DateChanged=@OnDateChanged Date="_yearMonth" />
                        <MudTooltip Text=@Localizer["nextMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info">
                            @if (_yearMonth.Value.Month <= 11)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowForwardIos" Color="Color.Info" @onclick="@(()=>NextMonth())" Class="ml-4"></MudIconButton>
                            }
                        </MudTooltip>
                    </MudItem>
                }
            </MudItem>
        </Header>
        <ChildContent>
            <MudTabPanel Text="@Localizer["yearly"]" Icon="@Icons.Material.Filled.CalendarViewDay" ID='"pn_one"' OnClick="@( () => YearlyTab())">
                <ChildContent>
                    @if (ShowTable)
                    {
                        <div class="table-container">
                            <div class="scrollable-columns">
