                                        <div class="font-weight-bold"><b>@Localizer1["UsersName"]:</b>  @e.Name</div>
                                        <div class="font-weight-bold"><b>@Localizer1["UsersGroup"]:</b>  @e.Group?.Description</div>


                                        <div class="font-weight-bold"><b>@Localizer["UsersArea"]:</b>  </div>
                                        <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@e.Area?.Code - @e.Area?.Description </MudChip>

                                        </ItemTemplate>
                                    </MudAutocomplete>
                                </MudItem>
                            <MudButton Disabled="@ActiveAddSubordinated" OnClick="@(() => AddSupervisor(selectedSupervisorOfList))" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" IconColor="Color.Secondary" Size="Size.Large"> Add Supervisor </MudButton>
                        }
                        <MudSpacer />
                    </MudItem>


                    @if (ShowTable)
                    {
                        <MudDropContainer T="User" Items="SV_Manager" ItemsSelector="@((item,dropzone) => item.Container == dropzone)" ItemDropped="ItemUpdated" Class="d-flex flex-wrap flex-grow-1">
                            <ChildContent>
                                <MudDropZone T="User" Identifier="CategoryContainer" Class="rounded mud-background-gray pa-6 ma-8 flex-grow-1" AllowReorder="true">
                                    <MudText Typo="Typo.h6" Class="mb-4">
                                        @Localizer["reorderSupervisors"]
                                    </MudText>
                                </MudDropZone>
                            </ChildContent>
                            <ItemRenderer>
                                <MudPaper Elevation="25" Class="pa-4 my-4" Style="    display: flex;    justify-content: space-between;">
                                    @($"{context.Name}")

                                    <MudTooltip Text="Delete SV" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                        <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="() => DeleteSupervisorList(context)" OnTouch="() => DeleteSupervisorList(context)"></MudIcon>
                                    </MudTooltip>
                                </MudPaper>

                            </ItemRenderer>
                        </MudDropContainer>
                    }
                </MudItem>

            </MudItem>

        }


    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="() => StartCreateSuggestion()" Disabled="@enableCreateSuggestion">@Localizer["generateSuggestion"]</MudButton>
        </DialogActions>
    </MudDialog>
