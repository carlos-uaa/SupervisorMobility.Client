                                    <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@_Users.Find(u => u.UserId == RegSelect.Register.Supervisor.UserId)?.Area?.Code - @_Users.Find(u => u.UserId == RegSelect.Register.Supervisor.UserId)?.Area.Description </MudChip>


                                    </MudCardContent>
                                    <MudCardActions Style="justify-content: flex-end;">
                                    </MudCardActions>
                                </MudCard>
                        }
                        else
                        {
                            <MudChip Icon="@Icons.Material.Filled.CrisisAlert" Class="mt=10" Style="display: flex;" Color="Color.Info">Select SV from list</MudChip>
                        }
                    </ChildContent>
                </MudTabPanel>
            }

        </MudTabs>
    </DialogContent>
    <DialogActions>
        @if (selectedSVPanel == 0)
        {
            <MudButton OnClick="CloseSuggestSVPanelDialog" Disabled="RegSelect.Register.Supervisor == null && !RegSelect.StateUpdate" Variant="Variant.Filled">@Localizer["Close"]</MudButton>
        }
        else if (RegSelect.Register.Supervisor != null)
        {
            @if (RegSelect.Exist)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Save" OnClick="@( () =>  UpdateSuggesSv(selectedSOPPanel))" Color="Color.Default" />
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.SaveAs" OnClick="@( () =>  UpdateSuggesSv(selectedSOPPanel))" Color="Color.Default" />
            }

        }


    </DialogActions>
</MudDialog>
