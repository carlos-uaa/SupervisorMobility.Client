                </MudTextField>

                <MudSpacer />
                <MudTextField @bind-Value="diasSeparate" T="int" Validation="@(new Func<int?, IEnumerable<string>>(ValidateStartDay))" Label="@Localizer["separationDays"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" Clearable="true">

