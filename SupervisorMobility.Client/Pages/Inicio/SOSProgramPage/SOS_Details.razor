                    <MudItem Class="d-flex justify-space-between pa-1 ma-1 mt-6">


                        <MudItem Style="text-align: end">
                            <MudChip Variant="Variant.Text" Color="Color.Info" Class="pl-3" Icon="@Icons.Material.Filled.History">@Localizer["historyVersions"]</MudChip>
                        </MudItem>
                    </MudItem>
                    <MudText Typo="Typo.h6" Class="mt-5">
                        @Localizer["jobObservacionCiclycalCard"] @_Selected_Suggested_SOSJobobservation.JobObservationId
                        <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">@Localizer["sosReviewProgram"]</MudChip>
                        @if (_Selected_Suggested_SOSJobobservation.StartDate < DateTime.Now)
                        {

                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Info" Color="Color.Error" Style="cursor:pointer">@Localizer["programmed"]</MudChip>
                        }
                        else
                        {

                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Style="cursor:pointer">@Localizer["programmed"]</MudChip>
