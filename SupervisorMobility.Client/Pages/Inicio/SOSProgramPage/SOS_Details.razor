<MudDialog DisableSidePadding="false" @bind-IsVisible="SeeDialogCreateJobObservation" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap; flex-direction:row" Class="gap-4">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    @Localizer["createJobObservation"]
                </MudText>
            </MudItem>
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    Details
                </MudText>
                @*<MudSimpleTable Dense="@dense" Hover="@hover" ReadOnly="@ronly"*@
                <MudSimpleTable HorizontalScrollbar="true">
                    <tbody>
                        <tr>
                            <MudTd style="width:50%">
                                @*Mud select of Plants*@
                                <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_NewJobObservation.PlantId">
                                    <MudSelectItem Disabled="true" Value="@_NewJobObservation.PlantId">@_NewJobObservation.Plant?.Code - @_NewJobObservation.Plant?.Description</MudSelectItem>
                                </MudSelect>
                            </MudTd>
                            <MudTd>
                                <MudItem Class="d-flex">
                                    <MudIcon Icon="@Icons.Material.Filled.Today" Color="Color.Info" Class="mr-2"></MudIcon>
                                    <MudText> @textInfo.ToTitleCase(CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName((int)_NewJobObservation.StartDate?.Month))</MudText>
                                </MudItem>
                            </MudTd>
                            @* <MudTd class="d-flex">
                            <MudDatePicker @bind-Date="_NewJobObservation.StartDate" Label=@Localizer["startDate"] Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4 pt-2" ReadOnly />
                            <MudDatePicker @bind-Date="_NewJobObservation.EndDate" Label=@Localizer["endDate"] Color="Color.Info" AdornmentColor="Color.Info" MinDate="_NewJobObservation.StartDate" Class="pt-2" ReadOnly/>
                            </MudTd>*@
                        </tr>
                        <tr>
                            <MudTd>
                                @*Mud select of Areas *@
                                <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_NewJobObservation.AreaId">
                                    <MudSelectItem Disabled="true" Value="@_NewJobObservation.AreaId">@_NewJobObservation.Area?.Code - @_NewJobObservation.Area?.Description</MudSelectItem>
                                </MudSelect>
                            </MudTd>
                            <MudTd>
                                <MudTextField T="string" @bind-Value="_NewJobObservation.Supervisor.Name" Label=@Localizer["observer"] Class="mr-4" />
                                @*                              <MudTimePicker Label="Start hour" @bind-Time="startHour" Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4 pt-2" ReadOnly/>
                                <MudTimePicker Label="End hour" @bind-Time="endHour" Color="Color.Info" AdornmentColor="Color.Info" Class="pt-2" ReadOnly />*@
                            </MudTd>
                        </tr>
                        <tr>
                            @* <MudTd class="d-flex">

                            <MudSelect T="int" Label=@Localizer["distribution"] Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_NewJobObservation.DistributionId">
                            <MudSelectItem Disabled="true" Value="@_NewJobObservation.DistributionId">@_NewJobObservation.Distribution?.Code - @_NewJobObservation.Distribution?.Description</MudSelectItem>
                            </MudSelect>

                            <MudSelect T="int" Label=@Localizer["operation"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_NewJobObservation.OperationId">
                            <MudSelectItem Disabled="true" Value="@_NewJobObservation.OperationId">@_NewJobObservation.Operation?.Code - @_NewJobObservation.Operation?.Description</MudSelectItem>
                            </MudSelect>
                            </MudTd>

                            <MudTd>
                            <MudTextField T="string" @bind-Value="_NewJobObservation.Operator.Name" Label=@Localizer["operator"] Class="mr-4" />
                            </MudTd>
                            *@
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>

            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    Options
                </MudText>
                <MudSwitch Class="ma-1" Label="Set Operation" @bind-Checked="@AddOperation" @onclick="@(() => SwitchOperations())" Color="Color.Primary" UnCheckedColor="Color.Dark" />
                <MudSwitch Class="ma-1" Label="Set Operator" @bind-Checked="@AddOperator" @onclick="@(() => SwitchOperators())" Color="Color.Primary" UnCheckedColor="Color.Dark" />

            </MudItem>
            @if (AddOperation)
            {

                <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                    <MudText Typo="Typo.h6">
                        Select Operation
                    </MudText>
                    <MudItem xs="12" sm="12" lg="12" md="12" Style="display: flex; flex-wrap: wrap; flex-direction:row">
                        <MudItem xs="9" sm="9" lg="9" md="9">

                            <MudSelect T="int" Label="@Localizer1["ACLabelOperation"]" Placeholder="@Localizer1["ACPHOperation"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_NewJobObservation.OperationId" For="@(() => _NewJobObservation.OperationId)">
                                <MudSelectItem Disabled="true" Value="0">@Localizer1["ACPHOperation"]</MudSelectItem>
                                @foreach (var type in _Operations)
                                {
                                    <MudSelectItem Value="type.OperationId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            </MudSelect>



                        </MudItem>
                        <MudItem xs="3" sm="3" lg="3" md="3">
                            @if (_NewJobObservation.OperationId != 0)
                            {

                                @switch (_Operations?.Find(op => op.OperationId == _NewJobObservation.OperationId).CriticalType)
                                {
                                    case 1:
                                        <MudTextField ReadOnly Value="'A'" Class="mt-3" AnchorOrigin="Origin.BottomCenter" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                                        break;
                                    case 2:
                                        <MudTextField ReadOnly Value="'B'" Class="mt-3" AnchorOrigin="Origin.BottomCenter" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                                        break;
                                    case 3:
                                        <MudTextField ReadOnly Value="'C'" Class="mt-3" AnchorOrigin="Origin.BottomCenter" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                                        break;
                                    default:
                                        <MudTextField ReadOnly Value="@Localizer["OPCritical"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                                        break;
                                }

                            }
                        </MudItem>
                    </MudItem>
                </MudItem>

            }

            @if (AddOperator)
            {

                <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                    <MudText Typo="Typo.h6">
                        Select Operator
                    </MudText>
                    <MudSelect T="int" Label=@Localizer["operator"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_NewJobObservation.OperatorId" For="@(() => _NewJobObservation.OperatorId)">
                        <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnOperator"]</MudSelectItem>
                        @foreach (var type in _Subordinates)
                        {
                            <MudSelectItem Value="type.UserId">@($"{type.Name}")</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            }



        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="CloseCreateJobObservation">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>

