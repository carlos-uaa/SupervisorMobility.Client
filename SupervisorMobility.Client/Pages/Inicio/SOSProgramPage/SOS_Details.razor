                                                        <MudTooltip Text="@Localizer["rejected"]" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">@jobobs.StartDate?.ToString("dd")</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.Cancel" />
                                                        <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["rejected"]</span>.</span>
                                                        </MudTooltip>
                                                        }
                                                        //Finalized
                                                        else if (jobobs.Status == 6)
                                                        {
                                                        <MudTooltip Text="@Localizer["finished"]" Color="Color.Success" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="font-size: 10px" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">@jobobs.StartDate?.ToString("dd")</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Success" />
                                                        <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["finished"]</span>.</span>
                                                        </MudTooltip>
                                                        }
                                                        }
                                                        //lasts more than one day
                                                        else
                                                        {
                                                        if (jobobs.Status == 1)
                                                        {
                                                        <MudTooltip Text="@Localizer["planned"]" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                        <MudButton Color="Color.Warning" Style="padding: 0px;" Variant="Variant.Outlined">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" Style="font-size: 10px" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">@jobobs.StartDate?.ToString("dd")</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.PlayCircle" />
                                                        </MudButton>
                                                        <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["planned"]</span>.</span>
                                                        </MudTooltip>
                                                        }
                                                        //In Progress
                                                        else if (jobobs.Status == 2)
                                                        {
                                                        <MudTooltip Text="@Localizer["inProgress"]" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                        <MudButton Color="Color.Info" Style="padding: 0px;" Variant="Variant.Outlined">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">@jobobs.StartDate?.ToString("dd")</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.StopCircle" />
                                                        </MudButton>
                                                        <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["inProgress"]</span>.</span>
                                                        </MudTooltip>
                                                        }

                                                        //Late job observations
                                                        else if (jobobs.Status == 3)
                                                        {
                                                        <MudTooltip Text="@Localizer["late"]" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                        <MudButton Color="Color.Error" Style="padding: 0px;" Variant="Variant.Outlined">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">@jobobs.StartDate?.ToString("dd")</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" />
                                                        </MudButton>
                                                        <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["late"]</span>.</span>
                                                        </MudTooltip>
                                                        }

                                                        //Under Review job observations
                                                        else if (jobobs.Status == 4)
                                                        {
                                                        <MudTooltip Text="@Localizer["underReview"]" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                        <MudButton Color="Color.Info" Style="padding: 0px;" Variant="Variant.Outlined">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">@jobobs.StartDate?.ToString("dd")</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.IncompleteCircle" />
                                                        </MudButton>
                                                        <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["underReview"]</span>.</span>
                                                        </MudTooltip>
                                                        }

                                                        //Rejected job observations
                                                        else if (jobobs.Status == 5)
                                                        {
                                                        <MudTooltip Text="@Localizer["rejected"]" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                        <MudButton Color="Color.Error" Style="padding: 0px;" Variant="Variant.Outlined">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">@jobobs.StartDate?.ToString("dd")</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.Cancel" />
                                                        </MudButton>
                                                        <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["rejected"]</span>.</span>
                                                        </MudTooltip>
                                                        }
                                                        //Finalized
                                                        else if (jobobs.Status == 6)
                                                        {
                                                        <MudTooltip Text="@Localizer["finished"]" Color="Color.Success" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                        <MudButton Color="Color.Success" Style="padding: 0px;" Variant="Variant.Outlined">

                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="font-size: 10px" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">@jobobs.StartDate?.ToString("dd")</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Success" />
                                                        </MudButton>
                                                        <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["finished"]</span>.</span>
                                                        </MudTooltip>
                                                        }
                                                        }
                                                        }
                                                        }
                                                        </div>
                                                        } *@
                                                                                    </MudTd>
                                                                                }
                                                                            </MudTr>
                                                                        }
                                                                    }
                                                                }



                                                            }

                                                        </tbody>
                                                    </MudSimpleTable>

                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <MudItem Style="text-align:center;">
                                                <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
                                                <MudText Typo="Typo.h6">Cargando...</MudText>
                                            </MudItem>
                                            <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
                                                <ItemTemplate>
                                                    <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                                                        <MudItem class="d-flex flex-column justify-center align-self-center">
                                                            <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                                                        </MudItem>

                                                        <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
                                                        </div>
                                                    </ItemTemplate>
                                                </MudCarousel>
                                        }

                                    </ChildContent>
                                </MudTabPanel>
                            </ChildContent>
                        </MudTabs>
                    </ChildContent>
                </MudTabPanel>
            }
        </ChildContent>
    </MudTabs>
}
else
{
    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
        <ItemTemplate>
            <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                <MudItem class="d-flex flex-column justify-center align-self-center">
                    <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                </MudItem>
                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
                </div>
            </ItemTemplate>
        </MudCarousel>
}
<MudDialog DisableSidePadding="false" @bind-IsVisible="SVSinCharge" Options="dialogOptions">
    <DialogContent>
        @if (enableCreateSuggestion)
        {
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">

                <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
                    <ItemTemplate>
                        <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                            <MudItem class="d-flex flex-column justify-center align-self-center">
                                <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                            </MudItem>
                            @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                            <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
                            </div>
                        </ItemTemplate>
                    </MudCarousel>
                </MudContainer>
        }
        else
        {
            <MudItem Style="display: flex; justify-content: space-evenly;">
                <MudSpacer />
                <MudDatePicker MinDate="@FirstdayYear" MaxDate="@LastdayYear" DateChanged="@(dt => OnFirstDateChanged(dt))" PickerVariant="PickerVariant.Dialog" Label="@Localizer["startingDay"]" HelperText="Select Date" Class="mt-2" Clearable="true" />
                <MudSpacer />
                <MudTextField @bind-Value="JobsPorDia" T="int" Validation="@(new Func<int?, IEnumerable<string>>(ValidateStartDay))" Label="@Localizer["jobsXDay"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" Clearable="true">

                </MudTextField>

                <MudSpacer />
                <MudTextField @bind-Value="diasSeparate" T="int" Validation="@(new Func<int?, IEnumerable<string>>(ValidateStartDay))" Label="@Localizer["separationDays"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" Clearable="true">

                </MudTextField>

                <MudSpacer />
                <MudSelect T="int" Label="@Localizer["sorting"]" Style="z-index:40;" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" AnchorOrigin="Origin.BottomCenter" @bind-Value="OptionRandom">
                    <MudSelectItem Value="0">@Localizer["sequential"]</MudSelectItem>
                        <MudSelectItem Value="1">@Localizer["randomOperations"]</MudSelectItem>
                        <MudSelectItem Value="2">@Localizer["randomDistributions"]</MudSelectItem>
                    </MudSelect>
                    <MudSpacer />
                </MudItem>

            <MudItem Style="display: flex; justify-content: space-evenly;">
                <MudSpacer />
                @if (_distributionsSuggest?.Count > 0)
                {
                    <MudItem>
                        <MudButton FullWidth=true OnClick="(() => SelectUnselect())" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@(Dist_Manager.Any(i => i.isSelected) ? @Icons.Material.Filled.IndeterminateCheckBox : @Icons.Material.Filled.CheckBoxOutlineBlank)">@(Dist_Manager.Any(i => i.isSelected) ? "Un-Select" : "Select") All Distributions</MudButton>
                    </MudItem>
                    <MudItem Style="display: flex; flex-wrap: wrap; justify-content: space-between; ">
                        @foreach (var item in Dist_Manager)
                        {
                            <MudButton Style="width: calc(20% - 10px); margin-bottom: 10px;" Variant="Variant.Outlined" Color="Color.Primary" OnClick="( () => UpdateMultiDistribution(item))" StartIcon="@(item.isSelected ? @Icons.Material.Filled.CheckBox : @Icons.Material.Filled.CheckBoxOutlineBlank)">@item.distribution.Code</MudButton>
                        }
                    </MudItem>

                }

                <MudSpacer />
            </MudItem>
            <MudItem Style="display: flex; justify-content: space-evenly;">
                <MudSpacer />
                @if (_UsersSV_Copy?.Count > 0)
                {
                    <MudItem xs="12" sm="12" md="12">
                        <MudAutocomplete Clearable T="User" Label="@Localizer1["UsersSupervisor"]" ValueChanged="@(selectedUser => OnSelectedSuperiorFunction(selectedUser, 4))"
                                          SearchFunc="@SearchSuggestSV" ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer["UsersPHSupervisor"]}" : $"[{e.UserId}] - {e.Name} Group:[{e.Group?.Description}]")"
                                          Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.Person"
                                                  ResetValueOnEmptyText
                                          ShowProgressIndicator="true" MaxItems="null">
                             <ItemTemplate Context="e">
                                 <MudItem Style="text-align: center">
                                     @switch (e.UserType)
                                    {
                                        case 3:
                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary" Class="mr-15 mt-5"> @Localizer1["UsersSupervisor"] </MudChip>
                                            break;
                                    }
                                </MudItem>
                                <div class="font-weight-bold"><b>@Localizer1["UserId"]:</b>  @e.UserId</div>
                                <div class="font-weight-bold"><b>@Localizer1["UsersName"]:</b>  @e.Name</div>
                                <div class="font-weight-bold"><b>@Localizer1["UsersGroup"]:</b>  @e.Group?.Description</div>


                                <div class="font-weight-bold"><b>@Localizer["UsersArea"]:</b>  </div>
                                <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@e.Area?.Code - @e.Area?.Description </MudChip>

                                </ItemTemplate>
                            </MudAutocomplete>
                        </MudItem>
                    <MudButton Disabled="@ActiveAddSubordinated" OnClick="@(() => AddSupervisor(selectedSupervisorOfList))" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" IconColor="Color.Secondary" Size="Size.Large"> Add Supervisor </MudButton>
                }
                <MudSpacer />
            </MudItem>


            @if (ShowTable)
            {
                <MudDropContainer T="User" Items="SV_Manager" ItemsSelector="@((item,dropzone) => item.Container == dropzone)" ItemDropped="ItemUpdated" Class="d-flex flex-wrap flex-grow-1">
                    <ChildContent>
                        <MudDropZone T="User" Identifier="CategoryContainer" Class="rounded mud-background-gray pa-6 ma-8 flex-grow-1" AllowReorder="true">
                            <MudText Typo="Typo.h6" Class="mb-4">
                                @Localizer["reorderSupervisors"]
                            </MudText>
                        </MudDropZone>
                    </ChildContent>
                    <ItemRenderer>
                        <MudPaper Elevation="25" Class="pa-4 my-4" Style="    display: flex;    justify-content: space-between;">
                            @($"{context.Name}")

                            <MudTooltip Text="Delete SV" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="() => DeleteSupervisorList(context)" @ontouchstart="() => DeleteSupervisorList(context)"></MudIcon>
                            </MudTooltip>
                        </MudPaper>

                    </ItemRenderer>
                </MudDropContainer>
            }
        }


    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="CreateSuggestion" Disabled="@enableCreateSuggestion">@Localizer["generateSuggestion"]</MudButton>
        </DialogActions>
    </MudDialog>



    <MudDialog DisableSidePadding="false" @bind-IsVisible="visible" Options="dialogOptions">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">
                <SupervisorMobility.Client.Pages.Inicio.JobObservationPage.JobObservationDetails JobObservationId="jobId"></SupervisorMobility.Client.Pages.Inicio.JobObservationPage.JobObservationDetails>
            </MudContainer>
        </DialogContent>
        <DialogActions>
            @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
        {
            <MudButton  @onclick="(() => JobObservationUpdate(jobId))" Color="Color.Info" StartIcon="@Icons.Material.Filled.Edit">@Localizer["edit"]</MudButton>
        }
        <MudButton Color="Color.Info" OnClick="Close">@Localizer["close"]</MudButton>
        </DialogActions>
    </MudDialog>


    <MudDialog DisableSidePadding="false" @bind-IsVisible="ShowLoading" Options="dialogOptions">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">

                <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
                    <ItemTemplate>
                        <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                            <MudItem class="d-flex flex-column justify-center align-self-center">
                                <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                            </MudItem>
                            @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                            <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
                        </div>
                    </ItemTemplate>
                </MudCarousel>
            </MudContainer>
        </DialogContent>
        <DialogActions>

        </DialogActions>
    </MudDialog>

    <MudDialog DisableSidePadding="false" @bind-IsVisible="visible2" Options="dialogOptions">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">
                <SupervisorMobility.Client.Pages.Inicio.JobObservationPage.ProgrammedJobObservationDetails JobObservationId="jobId2" LoggedUser="user" ProgrammedStartDate="@programmedStartDate"
                                                                                                           IsVisible="@visible2" IsVisibleChanged="HandleVisibleChanged"></SupervisorMobility.Client.Pages.Inicio.JobObservationPage.ProgrammedJobObservationDetails>
            </MudContainer>
        </DialogContent>
        <DialogActions>
            <MudButton Color="Color.Info" OnClick="Close2">@Localizer["close"]</MudButton>
        </DialogActions>
    </MudDialog>

    <MudDialog DisableSidePadding="false" @bind-IsVisible="ShowGraphicDonnut" Options="dialogOptions">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">
                @if (opInDistDialog.isActive)
            {
                double[] Sosdata = { opInDistDialog.sosplanned, opInDistDialog.sosinProgress, opInDistDialog.soslate, opInDistDialog.sosunderReview, opInDistDialog.sosrejected, opInDistDialog.sosfinished, opInDistDialog.sosprogramed };
                double[] AnotherData = { opInDistDialog.planned, opInDistDialog.inProgress, opInDistDialog.late, opInDistDialog.underReview, opInDistDialog.rejected, opInDistDialog.finished, opInDistDialog.programed };


                <MudSimpleTable Class="table-striped">
                    <tr>
                        <th colspan="19">
                            <MudText Class="ml-2" Typo="Typo.h5">Operations resume </MudText>
                        </th>
                    </tr>
                    <tr>
                        <td colspan="10" rowspan="1">
                            Total SOS Anual Jobs @opInDistDialog.TotalSosJobs
                        </td>
                        <td colspan="9" rowspan="1">
                            Total Another @opInDistDialog.TotalOutSosJobs
                        </td>
                    </tr>
                    <tr>

                        <td colspan="10" rowspan="4">
                            <MudItem style="display: flex">

                                <MudChart ChartType="ChartType.Donut" LegendPosition="Position.Left" Width="300px" Height="300px"
                                          InputData="@Sosdata" InputLabels="@labels" XAxisLabels="@labels">
                                    <CustomGraphics>
                                        <text class="donut-inner-text" x="47%" y="35%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="2">Total SOS</text>
                                        <text class="donut-inner-text" x="47%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="5">@Sosdata.Sum().ToString()</text>
                                    </CustomGraphics>
                                </MudChart>
                            </MudItem>
                        </td>
                        <td colspan="9" rowspan="4">
                            <MudItem style="display: flex">

                                <MudChart ChartType="ChartType.Donut" LegendPosition="Position.Left" Width="300px" Height="300px"
                                          InputData="@AnotherData" InputLabels="@labels" XAxisLabels="@labels">
                                    <CustomGraphics>
                                        <text class="donut-inner-text" x="47%" y="35%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="2">Total Another</text>
                                        <text class="donut-inner-text" x="47%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="5">@AnotherData.Sum().ToString()</text>
                                    </CustomGraphics>
                                </MudChart>
                            </MudItem>
                        </td>


                    </tr>
                </MudSimpleTable>

            }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="CloseGraphicDonnut">@Localizer["close"]</MudButton>
        </DialogActions>
    </MudDialog>


    <MudDialog DisableSidePadding="false" @bind-IsVisible="visible5" Options="dialogOptions">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">

                <MudTable Items="_DayJobObservations" T="JobObservationNulls" Hover Filter="new Func<JobObservationNulls,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true Height="400px"
                       HorizontalScrollbar="true">
                 <ToolBarContent>
                     <MudText Typo="Typo.h6">@Localizer["jobObservations"]</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5"></MudTextField>
                        <MudSpacer />
                    </ToolBarContent>
                    <ColGroup>
                        <col style="width: 60px;" />
                        <col />
                        <col />
                        <col />
                        <col />
                        <col />
                    </ColGroup>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<JobObservationNulls, object>(x=>x.JobObservationId)">Id</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<JobObservationNulls, object>(x=>x?.Distribution?.Description)">@Localizer["distribution"]</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<JobObservationNulls, object>(x=>x.StartDate)">@Localizer["startDate"]</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<JobObservationNulls, object>(x=>x?.Status)">@Localizer["status"]</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align: center">@Localizer["actions"]</MudTh>
                    </HeaderContent>
                    <GroupHeaderTemplate>
                    </GroupHeaderTemplate>
                    <RowTemplate>
                        <MudTd DataLabel="Id">
                            <MudText Align="Align.Center">@context.JobObservationId</MudText>
                        </MudTd>
                        <MudTd DataLabel=@Localizer["distribution"]>
                            <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
                        </MudTd>
                        <MudTd DataLabel=@Localizer["startDate"]>
                            <MudText Align="Align.Center">@context.StartDate?.ToShortDateString()</MudText>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudText Align="Align.Center">
                                @switch (context.Status)
                            {
                                case 1:
