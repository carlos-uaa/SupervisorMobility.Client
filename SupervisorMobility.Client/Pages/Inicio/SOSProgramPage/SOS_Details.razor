                                                                                var time1 = jobobs.JobObservation.StartDate?.ToString("HH:mm");
                                                                                var time2 = jobobs.JobObservation.EndDate?.ToString("HH:mm");

                                                                                if (Convert.ToDateTime(jobobs.JobObservation.StartDate?.ToShortDateString()).Date <= Convert.ToDateTime(compare.ToShortDateString()).Date && Convert.ToDateTime(compare.ToShortDateString()).Date <= Convert.ToDateTime(jobobs.JobObservation.EndDate?.ToShortDateString()).Date)
                                                                                {
                                                                                    //Ends the same day
                                                                                    if (Convert.ToDateTime(compare.ToShortDateString()).Date == Convert.ToDateTime(jobobs.JobObservation.StartDate?.ToShortDateString()).Date && Convert.ToDateTime(compare.ToShortDateString()).Date == Convert.ToDateTime(jobobs.JobObservation.EndDate?.ToShortDateString()).Date)
