                                            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Success" />
                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["finished"]</span>.</span>
                                            </MudTooltip>
                                            }
                                            }
                                            //lasts more than one day
                                            else
                                            {
                                            if (jobobs.JobObservation?.Status == 1)
                                            {
                                            <MudTooltip Text="@Localizer["planned"]" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                            <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" Style="font-size: 10px">@jobobs.JobObservation.StartDate?.ToString("dd/MM/yyyy")</MudChip>
                                            <MudIcon Icon="@Icons.Material.Filled.PlayCircle" />
                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["planned"]</span>.</span>
                                            </MudTooltip>
                                            }
                                            //In Progress
                                            else if (jobobs.JobObservation?.Status == 2)
                                            {
                                            <MudTooltip Text="@Localizer["inProgress"]" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                            <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@jobobs.JobObservation.StartDate?.ToString("dd/MM/yyyy")</MudChip>
                                            <MudIcon Icon="@Icons.Material.Filled.StopCircle" />
                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["inProgress"]</span>.</span>
                                            </MudTooltip>
                                            }

                                            //Late job observations
                                            else if (jobobs.JobObservation?.Status == 3)
                                            {
                                            <MudTooltip Text="@Localizer["late"]" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                            <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px">@jobobs.JobObservation.StartDate?.ToString("dd/MM/yyyy")</MudChip>
                                            <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" />
                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["late"]</span>.</span>
                                            </MudTooltip>
                                            }

                                            //Under Review job observations
                                            else if (jobobs.JobObservation?.Status == 4)
                                            {
                                            <MudTooltip Text="@Localizer["underReview"]" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                            <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@jobobs.JobObservation.StartDate?.ToString("dd/MM/yyyy")</MudChip>
                                            <MudIcon Icon="@Icons.Material.Filled.IncompleteCircle" />
                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["underReview"]</span>.</span>
                                            </MudTooltip>
                                            }

                                            //Rejected job observations
                                            else if (jobobs.JobObservation?.Status == 5)
                                            {
                                            <MudTooltip Text="@Localizer["rejected"]" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                            <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px">@jobobs.JobObservation.StartDate?.ToString("dd/MM/yyyy")</MudChip>
                                            <MudIcon Icon="@Icons.Material.Filled.Cancel" />
                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["rejected"]</span>.</span>
                                            </MudTooltip>
                                            }
                                            //Finalized
                                            else if (jobobs.JobObservation?.Status == 6)
                                            {
                                            <MudTooltip Text="@Localizer["finished"]" Color="Color.Success" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                            <MudButton Color="Color.Success" Style="padding: 0px;" Variant="Variant.Outlined">

                                            <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="font-size: 10px">@jobobs.JobObservation.StartDate?.ToString("dd/MM/yyyy")</MudChip>
                                            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Success" />
                                            </MudButton>
                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@Localizer["finished"]</span>.</span>
                                            </MudTooltip>
                                            }



                                            }
                                            }
                                            }
                                            </div>
                                            @if (context.Where(j => Convert.ToDateTime(j.JobObservation.StartDate?.ToShortDateString()).Date <= Convert.ToDateTime(compare.ToShortDateString()).Date && Convert.ToDateTime(compare.ToShortDateString()).Date <= Convert.ToDateTime(j.JobObservation.EndDate?.ToShortDateString()).Date && (j.JobObservation.Status == optionStatus || optionStatus == 0)).ToList().Count() > 2)
                                            {
                                            <MudButton @onclick="(() => OpenDialog5(date.ToString()))" FullWidth=true Style="text-align:center; height: 5px;" Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.KeyboardArrowDown"></MudButton>
                                            }


                                            }
                                            </MudTd>
                                            } *@



                                                                    }


                                                                </MudTr>


                                                            }

                                                        }





                                                    }

                                                </tbody>
