@page "/SOSDetails/{sosId:int}"

@using System.Net.Http.Json
@using AutoMapper;
@using MudBlazor
@using System.Globalization;
@using System.Text.RegularExpressions;
@using System.Runtime.CompilerServices;

@inject NavigationManager NavigationManager
@inject IUserService UsersServices
@inject IAreaService AreasServices
@inject IOperationService OperationsServices
@inject IPATService PATsServices
@inject IJSRuntime JSRuntime
@inject IJSRuntime JS
@inject IILUService ILUServices
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject IDistributionService DistributionServices
@inject ISOSReviewService SOSServices
@inject IAssyChartService AssyChartsServices
@inject IBridgeCDMSService CDMSServices


<style>

    .vertical-text {
        vertical-align: middle;
    }

    .vertical-content {
        writing-mode: vertical-lr;
        white-space: nowrap;
        word-wrap: break-word;
        max-width: 100%;
    }


    .scroll1::-webkit-scrollbar {
        width: 4px;
        touch-action: pan-y;
    }

    .mud-tabs-header.mud-tabs-header-after {
        width: 100%;
    }
</style>

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["sosDetails"]</PageTitle>
@*Breadcrumb links*@
<div style="display: flex; align-items: center; justify-content: space-between;">
    <MudItem>
        <MudBreadcrumbs Class="mb-2" Items="_links">
            <ItemTemplate Context="item">
                <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
            </ItemTemplate>
        </MudBreadcrumbs>
    </MudItem>
    <MudItem Style="text-align: end">
        <img src="Images/logo.png" Height="50" />
    </MudItem>
</div>

<MudTabs Border="true" Outlined="true" PanelClass="px-4 py-6" ApplyEffectsToContainer="true" Class="mt-0" HeaderPosition="TabHeaderPosition.After" PrevIcon="@Icons.Material.Filled.SkipPrevious" NextIcon="@Icons.Material.Filled.SkipNext">
    <Header>
        @if (MonthlyView)
        {
            <MudItem Style="display: flex; justify-content: space-evenly;">
                <MudText Typo="Typo.h6">
                    <MudTooltip Text=@Localizer["lastMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info">
                        @if (_yearMonth.Value.Month >= 2)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Color="Color.Info" @onclick="@(()=>LastMonth())" Class="mr-4"></MudIconButton>
                        }

                    </MudTooltip>
                    @showMonth @year
                    <MudTooltip Text=@Localizer["nextMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info">
                        @if (_yearMonth.Value.Month <= 11)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowForwardIos" Color="Color.Info" @onclick="@(()=>NextMonth())" Class="ml-4"></MudIconButton>
                        }
                    </MudTooltip>
                </MudText>
            </MudItem>
        }
    </Header>

    <ChildContent>

        <MudTabPanel Text="Yearly" ID='"pn_one"' OnClick="@( () => MonthlyView = false)">
            <ChildContent>
                @if (ShowTable)
                {
                    <MudSimpleTable Dense>
                     <tbody>
                         <tr>
                             <MudTd colspan="2" rowspan="2">
                                 <MudItem Class="d-flex justify-content-between mb-5" Style="align-items: center;">
                                     <MudText Typo="Typo.h6">@Localizer["sosDetails"] @SOS_Review.AplicationYear </MudText>
                                 </MudItem>
                             </MudTd>
                             <MudTd colspan="2">
                                 <MudItem Class="d-flex">
                                     <MudIcon Icon="@Icons.Material.Filled.BusinessCenter"> </MudIcon>
                                     <MudText Class="ml-2">@Localizer["area"]</MudText>
                                 </MudItem>
                             </MudTd>
                             <MudTd colspan="2">
                                 <MudItem Class="d-flex">
                                     <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
                                     <MudText Class="ml-2">@Localizer["plant"]</MudText>
                                 </MudItem>
                             </MudTd>
                         </tr>
                         <tr>
                             <MudTd rowspan="2" colspan="2">
                                 @SOS_Review.Area?.Description
                             </MudTd>
                             <MudTd rowspan="2" colspan="2">
                                 @SOS_Review.Plant?.Description
                             </MudTd>
                         </tr>
                     </tbody>
                 </MudSimpleTable>
                    <MudSimpleTable Class="mb-5 calendar-table rounded" Style="overflow-x: auto;" Dense Bordered=false>
                         <thead>
                             <tr>
                             </tr>
                             <tr>

                                 <th rowspan="2">
                                     <MudItem Class="d-flex">
                                         <MudIcon Icon="@Icons.Material.Filled.AccountTree"> </MudIcon>
                                         <MudText Class="ml-2">@Localizer["distribution"]</MudText>
                                     </MudItem>
                                 </th>
                                 <th rowspan="2">
                                     No. HOE
                                 </th>
                                 <th rowspan="2">
                                     Nombre. HOE
                                 </th>
                                 <th rowspan="2" Style="min-width: 350px">
                                     Quien Revisa
                                 </th>
                                 <th rowspan="2">
                                     Directorios
                                 </th>
                                 <th rowspan="2" class="vertical-text">

                                     <div class="vertical-content">
                                         Programacion
                                     </div>
                                 </th>
                                 <th colspan="12">
                                     @SOS_Review.AplicationYear
                                 </th>
                                 <th colspan="3" rowspan="2">
                                     Notas
                                 </th>

                             </tr>

                             <tr>
                                 @for (var i = 1; i <= 12; i++)
                                {
                                    <th style="text-align: center">
                                        @textInfo.ToTitleCase(CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i))
                                    </th>
                                }
                            </tr>

                        </thead>



                        <tbody style="width: 100%;">





                            @foreach (Distribution Distribution_Item in _distributions)
                            {
                                var rowTotal = Distribution_Item.Operations.Count() != 0 ? Distribution_Item.Operations.Count() * 2 + 1 : 2;

                                <MudTr>
                                    <MudTd><MudButton Variant="Variant.Outlined" Size="Size.Small" EndIcon="@(Distribution_Item.ShowDetails ? @Icons.Material.Filled.KeyboardArrowUp : @Icons.Material.Filled.KeyboardArrowDown)" OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">@((Distribution_Item.ShowDetails == true) ? "Hide" : "Show") Details of: @Distribution_Item.Description </MudButton></MudTd>
                                    <MudTd colspan="18" DataLabel="Distribution">
                                        <MudButton FullWidth="true" OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))" EndIcon="@(Distribution_Item.ShowDetails ? @Icons.Material.Filled.KeyboardArrowUp : @Icons.Material.Filled.KeyboardArrowDown)" Variant="Variant.Text" Color="Color.Primary" Style="text-transform:none">@Distribution_Item.Description</MudButton>
                                    </MudTd>
                                </MudTr>
                                @if (Distribution_Item.ShowDetails)
                                {
                                    <MudTr>
                                        <MudTd rowspan="@rowTotal"><MudButton Style="height: 100%" Variant="Variant.Outlined" EndIcon="@Icons.Material.Filled.KeyboardArrowUp" FullWidth=true OnClick="@(() => ShowBtnPress(Distribution_Item.DistributionId))">@((Distribution_Item.ShowDetails == true) ? "Hide" : "Show")  @Distribution_Item.Description </MudButton></MudTd>
                                    </MudTr>
                                    foreach (var op in Distribution_Item.Operations)
                                    {
                                        <MudTr>
                                            <MudTd rowspan="2">@op.Code</MudTd>
                                            <MudTd rowspan="2">@op.Description</MudTd>
                                            <MudTd rowspan="2" Style="min-width: 350px">

                                                @if (SOS_Registers_UserOperationRelationship.TryGetValue(op.OperationId, out var context))
                                                {
                                                    if (context.Exist)
                                                    {
                                                        if (context.StateUpdate)
                                                        {
                                                            <MudAutocomplete Clearable T="User" Label="@Localizer1["UsersSupervisor"]" @bind-Value="context.Register.Supervisor"
                                                                              SearchFunc="@SearchSV" ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer1["UsersPHSupervisor"]}" : $"[{e.UserId}] - {e.Name} - {e.Group?.Description}")"
                                                                              Variant="Variant.Outlined" AdornmentIcon="@(context.StateUpdate ? @Icons.Material.Filled.Save : @Icons.Material.Filled.Person)"
                                                                              ShowProgressIndicator="true" MaxItems="null"
                                                                              OnAdornmentClick="@( () =>  BtnSupervisorsEdit(op.OperationId))">
                                                                 <ItemTemplate Context="e">
                                                                     <MudItem Style="text-align: center">
                                                                         @switch (e.UserType)
                                                                        {
                                                                            case 3:
                                                                                <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary" Class="mr-15 mt-5"> @Localizer1["UsersSupervisor"] </MudChip>
                                                                                break;
                                                                        }
                                                                    </MudItem>
                                                                    <div class="font-weight-bold"><b>@Localizer1["UserId"]:</b>  @e.UserId</div>
                                                                    <div class="font-weight-bold"><b>@Localizer1["UsersName"]:</b>  @e.Name</div>
                                                                    <div class="font-weight-bold"><b>@Localizer1["UsersGroup"]:</b>  @e.Group?.Description</div>


                                                                    <div class="font-weight-bold"><b>@Localizer["UsersArea"]:</b>  </div>
                                                                    <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@e.Area?.Code - @e.Area?.Description </MudChip>

                                                                </ItemTemplate>
                                                            </MudAutocomplete>

                                                        }
                                                        else
                                                        {
                                                            <MudTextField ReadOnly="true" Label="Supervisor" Value="context.Register.Supervisor?.Name" Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentIcon="@(context.StateUpdate ? @Icons.Material.Filled.Save : @Icons.Material.Filled.Edit)" OnAdornmentClick="@( () =>  BtnSupervisorsEdit(op.OperationId))" AdornmentAriaLabel="Upate" />
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <MudAutocomplete Clearable T="User" Label="@Localizer1["UsersSupervisor"]" @bind-Value="context.Register.Supervisor"
                                                                          SearchFunc="@SearchSV" ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer1["UsersPHSupervisor"]}" : $"[{e.UserId}] - {e.Name} - {e.Group?.Description}")"
                                                                          Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.SaveAs"
                                                                          ShowProgressIndicator="true" MaxItems="null"
                                                                          OnAdornmentClick="@( () =>  BtnSupervisorsEdit(op.OperationId))">
                                                             <ItemTemplate Context="e">
                                                                 <MudItem Style="text-align: center">
                                                                     @switch (e.UserType)
                                                                    {
                                                                        case 3:
                                                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary" Class="mr-15 mt-5"> @Localizer1["UsersSupervisor"] </MudChip>
                                                                            break;
                                                                    }
                                                                </MudItem>
                                                                <div class="font-weight-bold"><b>@Localizer1["UserId"]:</b>  @e.UserId</div>
                                                                <div class="font-weight-bold"><b>@Localizer1["UsersName"]:</b>  @e.Name</div>
                                                                <div class="font-weight-bold"><b>@Localizer1["UsersGroup"]:</b>  @e.Group?.Description</div>


                                                                <div class="font-weight-bold"><b>@Localizer["UsersArea"]:</b>  </div>
                                                                <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@e.Area?.Code - @e.Area?.Description </MudChip>

                                                            </ItemTemplate>
                                                        </MudAutocomplete>
                                                    }

                                                }


                                            </MudTd>
                                            <MudTd rowspan="2">
                                                @if (_assyCharts.Any(r => r.DistributionId == Distribution_Item.DistributionId))
                                                {
                                                    var _assychart = _assyCharts?.Where(r => r.DistributionId == Distribution_Item.DistributionId).FirstOrDefault();

                                                    <MudItem Style="text-align: start">
                                                        @if (_assychart != null)
                                                        {
                                                            <MudItem Class="d-flex flex-row align-start justify-center">

                                                                @if (_assychart.RoutesProductsAssyChart?.Count > 0 && _assychart.RoutesProductsAssyChart.Any(r => r.Code.ToLower().Contains(op.Code.ToLower(), StringComparison.InvariantCultureIgnoreCase)))
                                                                {
                                                                    var RoutesCode = _assychart.RoutesProductsAssyChart.Where(r => r.Code.ToLower().Contains(op.Code.ToLower(), StringComparison.InvariantCultureIgnoreCase)).ToList();
                                                                    <MudMenu Dense=true AnchorOrigin="Origin.BottomCenter" Style="display: flex" TransformOrigin="Origin.TopCenter">
                                                                        <ActivatorContent>
                                                                            <MudButton FullWidth="true" StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">Directorys</MudButton>
                                                                        </ActivatorContent>
                                                                        <ChildContent>
                                                                            <MudExpansionPanels Elevation="0">
                                                                                @foreach (SOSCodePath item in RoutesCode)
                                                                                {

                                                                                    <MudExpansionPanel Style="width: auto;">
                                                                                        <TitleContent>
                                                                                            <div Style="align-items: center; display: flex;">
                                                                                                <MudText>@item.Code</MudText>
                                                                                                <MudChip Icon="@Icons.Material.Filled.DirectionsCar" IconColor="Color.Info" Variant="Variant.Text" Color="Color.Success">@item.Product?.Code - @item.Product?.Description</MudChip>
                                                                                            </div>
                                                                                        </TitleContent>
                                                                                        <ChildContent>
                                                                                            <MudItem class="d-flex flex-column justify-center ma-1">
                                                                                                <MudItem class="d-flex d-flex-column justify-center">

                                                                                                    <MudItem Style="flex-direction: column;">
                                                                                                        @if (item.HOE != "")
                                                                                                        {
                                                                                                            <MudPaper Elevation="0">
                                                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, HOE))" @ontouchstart="(() => OpenDialogCodePath(item,HOE))" Style="padding: 0px;" Color="Color.Error">
                                                                                                                    <MudTooltip Text=@Localizer["openHOEFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                                                        <MudTooltip Text="@Regex.Replace(item.HOE, @"/(.*?)§", "/").Replace('§', ' ')" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.HOE.Split('§').Last()</MudChip>
                                                                                                                        </MudTooltip>
                                                                                                                    </MudTooltip>
                                                                                                                </MudButton>
                                                                                                            </MudPaper>
                                                                                                        }
                                                                                                        else
                                                                                                        {
                                                                                                            <MudPaper Elevation="0">
                                                                                                                <MudAlert Severity="Severity.Info">@Localizer["noHOEPath"]</MudAlert>
                                                                                                            </MudPaper>
                                                                                                        }

                                                                                                        @if (item.CommonDirectionHOE != "")
                                                                                                        {
                                                                                                            <MudPaper Elevation="0">
                                                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, HOECD))" @ontouchstart="(() => OpenDialogCodePath(item, HOECD))" Style="padding: 0px;" Color="Color.Error">
                                                                                                                    <MudTooltip Text=@Localizer["openHOEFolderCD"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                                                        <MudTooltip Text="@Regex.Replace(item.CommonDirectionHOE, @"/(.*?)§", "/").Replace('§', ' ')" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CommonDirectionHOE.Split('§').Last()</MudChip>
                                                                                                                        </MudTooltip>
                                                                                                                    </MudTooltip>
                                                                                                                </MudButton>
                                                                                                            </MudPaper>
                                                                                                        }

                                                                                                    </MudItem>

                                                                                                    <MudItem Style="flex-direction: column;">
                                                                                                        @if (@item.CCP != "")
                                                                                                        {
                                                                                                            <MudPaper Elevation="0">
                                                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, CCP))" @ontouchstart="(() => OpenDialogCodePath(item, CCP))" Style="padding: 0px;" Color="Color.Error">
                                                                                                                    <MudTooltip Text=@Localizer["openCCPFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                                                        <MudTooltip Text="@item.CCP" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CCP.Split('/').Last()</MudChip>
                                                                                                                        </MudTooltip>
                                                                                                                    </MudTooltip>
                                                                                                                </MudButton>
                                                                                                            </MudPaper>
                                                                                                        }
                                                                                                        else
                                                                                                        {
                                                                                                            <MudPaper Elevation="0">
                                                                                                                <MudAlert Severity="Severity.Info">@Localizer["noCCPPath"]</MudAlert>
                                                                                                            </MudPaper>
                                                                                                        }
                                                                                                        @if (@item.CommonDirectionCCP != "")
                                                                                                        {
                                                                                                            <MudPaper Elevation="0">
                                                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, CCPCD))" @ontouchstart="(() => OpenDialogCodePath(item, CCPCD))" Style="padding: 0px;" Color="Color.Error">
                                                                                                                    <MudTooltip Text=@Localizer["openCCPFolderCD"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                                                        <MudTooltip Text="@item.CommonDirectionCCP" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CommonDirectionCCP.Split('/').Last()</MudChip>
                                                                                                                        </MudTooltip>
                                                                                                                    </MudTooltip>
                                                                                                                </MudButton>
                                                                                                            </MudPaper>
                                                                                                        }
                                                                                                    </MudItem>

                                                                                                    <MudItem Style="flex-direction: column;">
                                                                                                        @if (item.GOS != "")
                                                                                                        {
                                                                                                            <MudPaper Elevation="0">
                                                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, GOS))" @ontouchstart="(() => OpenDialogCodePath(item, GOS))" Style="padding: 0px;" Color="Color.Error">
                                                                                                                    <MudTooltip Text=@Localizer["openGOSFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                                                        <MudTooltip Text="@item.GOS" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.GOS.Split('/').Last()</MudChip>
                                                                                                                        </MudTooltip>
                                                                                                                    </MudTooltip>
                                                                                                                </MudButton>

                                                                                                            </MudPaper>
                                                                                                        }
                                                                                                        else
                                                                                                        {
                                                                                                            <MudPaper Elevation="0">

                                                                                                                <MudAlert Severity="Severity.Info">@Localizer["noGOSPath"]</MudAlert>
                                                                                                            </MudPaper>
                                                                                                        }
                                                                                                        @if (item.CommonDirectionGOS != "")
                                                                                                        {
                                                                                                            <MudPaper Elevation="0">
                                                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, GOSCD))" @ontouchstart="(() => OpenDialogCodePath(item, GOSCD))" Style="padding: 0px;" Color="Color.Error">
                                                                                                                    <MudTooltip Text=@Localizer["openGOSFolderCD"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                                                        <MudTooltip Text="@item.CommonDirectionGOS" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CommonDirectionGOS.Split('/').Last()</MudChip>
                                                                                                                        </MudTooltip>
                                                                                                                    </MudTooltip>
                                                                                                                </MudButton>

                                                                                                            </MudPaper>
                                                                                                        }
                                                                                                    </MudItem>






                                                                                                </MudItem>
                                                                                            </MudItem>

                                                                                        </ChildContent>
                                                                                    </MudExpansionPanel>
                                                                                }
                                                                            </MudExpansionPanels>
                                                                        </ChildContent>
                                                                    </MudMenu>
                                                                }
                                                                else
                                                                {
                                                                    <MudAlert Severity="Severity.Info">
                                                                        @Localizer1["ACNoRouteCode"]
                                                                    </MudAlert>
                                                                }
                                                            </MudItem>
                                                        }
                                                        else
                                                        {
                                                            if (_assychart is null)
                                                            {
                                                                <MudItem class="d-flex flex-column justify-center align-self-start">
                                                                    <MudPaper Elevation="0">
                                                                        <MudAlert Severity="Severity.Info">
                                                                            No AssyCharts Found
                                                                        </MudAlert>
                                                                    </MudPaper>
                                                                </MudItem>
                                                            }
                                                            else
                                                            {
                                                                <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
                                                            }


                                                        }

                                                    </MudItem>
                                                }
                                                else
                                                {
                                                    <MudAlert Severity="Severity.Info">
                                                        @Localizer1["ACNoAssyChart"]
                                                    </MudAlert>
                                                }
                                            </MudTd>


                                            <MudTd>Programada</MudTd>

                                            @for (int i = 1; i < 13; i++)
                                            {
                                                int currentIndex = i;
                                                <MudTd style="text-align: center; width:160px; max-height:160px ">

                                                    @if (SOS_Registers_Matrix.TryGetValue((op.OperationId, currentIndex), out var context))
                                                    {
                                                        @if (context?.Count() > 0 && context.FindIndex(j => j.JobObservation?.Status == 7) != -1)
                                                        {
                                                            <div style="min-height: 8vh;    display: flex;    overflow-y: scroll;    max-height: 8vh;    scroll-behavior: smooth;    align-content: center;    justify-content: center;    align-items: center;" class="scroll scroll1">

                                                                @foreach (SOSRegisterJobObservation jobobs in context)
                                                                {
                                                                    //Finalized
                                                                    if (jobobs.JobObservation?.Status == 1)
                                                                    {
                                                                        <MudTooltip Text="@Localizer["planned"]" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                            <MudIcon Icon="@Icons.Material.Filled.PlayCircle" />
                                                                        </MudTooltip>
                                                                    }
                                                                    //In Progress
                                                                    else if (jobobs.JobObservation?.Status == 2)
                                                                    {
                                                                        <MudTooltip Text="@Localizer["inProgress"]" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                            <MudIcon Icon="@Icons.Material.Filled.StopCircle" />
                                                                        </MudTooltip>
                                                                    }

                                                                    //Late job observations
                                                                    else if (jobobs.JobObservation?.Status == 3)
                                                                    {
                                                                        <MudTooltip Text="@Localizer["late"]" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                            <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" />
                                                                        </MudTooltip>
                                                                    }

                                                                    //Under Review job observations
                                                                    else if (jobobs.JobObservation?.Status == 4)
                                                                    {
                                                                        <MudTooltip Text="@Localizer["underReview"]" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                            <MudIcon Icon="@Icons.Material.Filled.IncompleteCircle" />
                                                                        </MudTooltip>
                                                                    }

                                                                    //Rejected job observations
                                                                    else if (jobobs.JobObservation?.Status == 5)
                                                                    {
                                                                        <MudTooltip Text="@Localizer["rejected"]" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                            <MudIcon Icon="@Icons.Material.Filled.Cancel" />
                                                                        </MudTooltip>
                                                                    }
                                                                    //Finalized
                                                                    else if (jobobs.JobObservation?.Status == 6)
                                                                    {
                                                                        <MudTooltip Text="@Localizer["finished"]" Color="Color.Success" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
