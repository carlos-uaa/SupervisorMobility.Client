@* Grafica de estadisticas *@
<MudDialog DisableSidePadding="false" @bind-IsVisible="ShowGraphicDonnut" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 75vh; overflow-y: scroll">
            @if (opInDistDialog.isActive)
            {
                double[] Sosdata = { opInDistDialog.sosplanned, opInDistDialog.sosinProgress, opInDistDialog.soslate, opInDistDialog.sosunderReview, opInDistDialog.sosrejected, opInDistDialog.sosfinished, opInDistDialog.sosprogramed };
                double[] AnotherData = { opInDistDialog.planned, opInDistDialog.inProgress, opInDistDialog.late, opInDistDialog.underReview, opInDistDialog.rejected, opInDistDialog.finished, opInDistDialog.programed };


                <MudSimpleTable Class="table-striped">
                    <tr>
                        <th colspan="19">
                            <MudText Class="ml-2" Typo="Typo.h5">Operations resume </MudText>
                        </th>
                    </tr>
                    <tr>
                        <td colspan="10" rowspan="1">
                            Total SOS Anual Jobs @opInDistDialog.TotalSosJobs
                        </td>
                        <td colspan="9" rowspan="1">
                            Total Another @opInDistDialog.TotalOutSosJobs
                        </td>
                    </tr>
                    <tr>

                        <td colspan="10" rowspan="4">
                            <MudItem style="display: flex">

                                <MudChart ChartType="ChartType.Donut" LegendPosition="Position.Left" Width="300px" Height="300px"
                                          InputData="@Sosdata" InputLabels="@labels" XAxisLabels="@labels">
                                    <CustomGraphics>
                                        <text class="donut-inner-text" x="47%" y="35%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="2">Total SOS</text>
                                        <text class="donut-inner-text" x="47%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="5">@Sosdata.Sum().ToString()</text>
                                    </CustomGraphics>
                                </MudChart>
                            </MudItem>
                        </td>
                        <td colspan="9" rowspan="4">
                            <MudItem style="display: flex">

                                <MudChart ChartType="ChartType.Donut" LegendPosition="Position.Left" Width="300px" Height="300px"
                                          InputData="@AnotherData" InputLabels="@labels" XAxisLabels="@labels">
                                    <CustomGraphics>
                                        <text class="donut-inner-text" x="47%" y="35%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="2">Total Another</text>
                                        <text class="donut-inner-text" x="47%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="black" font-family="Helvetica" font-size="5">@AnotherData.Sum().ToString()</text>
                                    </CustomGraphics>
                                </MudChart>
                            </MudItem>
                        </td>


                    </tr>
                </MudSimpleTable>

            }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="CloseGraphicDonnut">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>
