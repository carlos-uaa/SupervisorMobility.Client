<style>

    .scroll1::-webkit-scrollbar {
        width: 2px;
    }

    .calendar-item {
        font-size: 10px;
        color: black;
        cursor: pointer;
        width: 14vh;
    }


    .vertical-text {
        vertical-align: middle;
    }

    .vertical-content {
        writing-mode: vertical-lr;
        white-space: nowrap;
        word-wrap: break-word;
        max-width: 100%;
    }

    .right-border {
        border-right: 1px solid var(--mud-palette-table-lines);
    }

    .mud-simple-table.mud-table-sticky-header * table thead * th {
        background-color: var(--mud-palette-surface);
        position: sticky;
        z-index: 2;
        top: 0;
    }

    .scroll1::-webkit-scrollbar {
        width: 4px;
        touch-action: pan-y;
    }

    .mud-tabs-header.mud-tabs-header-after {
        width: 100%;
    }

    .mud-tabs-toolbar-content {
        width: 50%;
        display: flex;
        position: relative;
        justify-content: center;
    }

    .mud-tabs-header.mud-tabs-header-before {
        display: flex;
        width: 50%;
    }

    .table-container {
        box-shadow: var(--mud-elevation-1);
        overflow-x: auto;
        border-radius: var(--mud-default-borderradius);
    }

        .table-container:hover {
            box-shadow: var(--mud-elevation-2);
        }


    .fixed-column {
        position: sticky;
        left: 0;
        z-index: 2;
        background-color: #f0f0f0;
    }

    .dynamic-left {
        left: 0;
    }

    table {
        border-collapse: collapse;
        min-width: 100%;
        border-radius: var(--mud-default-borderradius);
    }

    .scrollable-columns > th,
    .scrollable-columns > td {
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .fixed-row {
        position: sticky;
        top: 0; /* Las filas fijas se ubicarán en la parte superior de la tabla */
        z-index: 2; /* Asegura que las filas fijas estén por encima del contenido desplazable */
    }

</style>


