@page "/calendario-operaciones"
@using System.Globalization
@using MudBlazor


@inject Microsoft.AspNetCore.Components.WebAssembly.Hosting.IWebAssemblyHostEnvironment Environment

<style>
    /* Contenedor principal */
    .calendar-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
    }

    /* Contenedor del mes */
    .month-container {
        min-width: 300px;
    }

    /* Días de la semana */
    .weekdays {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        text-align: center;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .weekday {
        padding: 5px;
    }

    /* Grid de días */
    .days-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
    }

    /* Estilos para las celdas de día */
    .day-cell {
        height: 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border-radius: 4px;
        margin: 1px;
        padding: 2px;
        transition: all 0.2s;
    }

    .empty-day {
        visibility: hidden;
    }

    .weekend-day {
        background-color: #f5f5f5;
        color: #9e9e9e;
    }

    .operation-day {
        font-weight: bold;
        color: #333;
    }

    .day-number {
        font-size: 0.9rem;
    }

    .operation-text {
        font-size: 0.6rem;
        line-height: 1;
    }

    /* Leyenda */
    .legend-container {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .legend-color {
        width: 16px;
        height: 16px;
        border-radius: 3px;
        border: 1px solid #ddd;
    }
</style>
<!-- Leyenda -->
<MudPaper Elevation="0" Class="mt-6 pa-4">
    <MudText Typo="Typo.h6" Class="mb-2">Leyenda de Distribuciones</MudText>
    <div class="legend-container">
        @foreach (var dist in Dist_Manager.Where(d => d.isSelected))
        {
            <div class="legend-item">
                <div class="legend-color" style="background-color: @DistributionColors[dist.distribution.Description];"></div>
                <span>@dist.distribution.Description</span>
            </div>
        }
    </div>
</MudPaper>
<!-- Controles -->
<MudGrid Class="mb-6">

    @if (IsDialog)
    {
        <MudItem xs="12" class="mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" @onclick="(() => StartCreateSuggestion.InvokeAsync())" FullWidth="true">
                Generar Calendario
            </MudButton>
        </MudItem>
    }
</MudGrid>
<!-- Calendario -->

    <div class="calendar-container">
        @foreach (var month in CalendarMonths.Where(y => y.Year == Year))
        {
            <MudPaper Elevation="2" Class="month-container pa-2 mb-4">
                <MudText Typo="Typo.h6" Class="text-center mb-2">@month.MonthName.ToUpper()</MudText>

                <!-- Días de la semana -->
                <div class="weekdays">
                    @foreach (var day in new[] { "S", "M", "T", "W", "T", "F", "S" })
                    {
                        <div class="weekday">@day</div>
                    }
                </div>

                <!-- Días del mes -->
                <div class="days-grid">
                    @foreach (var day in month.Days)
                    {
                        <div class="@GetDayClasses(day)" style="@GetDayStyle(day)">
                            <div class="day-number">@day.DayNumber</div>
                        </div>
                    }
                </div>
            </MudPaper>
        }
    </div>


