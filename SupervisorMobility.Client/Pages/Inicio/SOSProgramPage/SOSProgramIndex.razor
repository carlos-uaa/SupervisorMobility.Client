@page "/sosProgram"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using System.Globalization;
@using System.Net.Http.Json;

@inject IJSRuntime js
@inject IGroupService GroupService
@inject IJobStructureService JobStructureCategoriesService
@inject IDialogService DialogService
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IJobObservationService JobObservationService
@inject ISOSReviewService SOSReviewServices
@inject IUserService UsersService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1
@inject NavigationManager NavigationManager


@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["sosProgram"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@if(ShowLoading){
    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
        <ItemTemplate>
            <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                <MudItem class="d-flex flex-column justify-center align-self-center">
                    <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                </MudItem>
                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
            </div>
        </ItemTemplate>
    </MudCarousel>
}else
@if (_SosReviewList == null)
{
    <text>
        @Localizer["loading"] ...
    </text>
}
else if (_SosReviewList.Count == 0)
{
    <MudContainer>

        <MudText Align="Align.Center">
            <h4>@Localizer["thereAreNoSosCreated"]</h4>
            <MudSpacer></MudSpacer>
            @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
            {
                <MudButton @onclick="(() => CreateSosReview())">
                    <MudText>@Localizer["createSOS"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Pat" Color="Color.Primary"></MudIcon>
                </MudButton>
            }
        </MudText>
    </MudContainer>
}
else
{
    <MudTable Items="@_SosReviewList" T="SOSReviewProgram" SortLabel="SortBy" Class="styled-table table-striped" FixedHeader=true Height="55vh" Hover Striped="true" Filter="new Func<SOSReviewProgram,bool>(FilterFunc1)" RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" OnRowClick="RowClickEvent">
        <PagerContent>
            <MudTablePager />
        </PagerContent>
        <ToolBarContent>
            <MudText Typo="Typo.h6" Align="Align.Center">@Localizer["sosProgram"]</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="@searchString1" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-2"></MudTextField>
            <MudSpacer />
            @if (user.UserType == 1 || user.UserType == 3)
            {
                <MudButton @onclick="(() => CreateSosReview())">
                    <MudText>@Localizer["createSOS"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary"></MudIcon>
                </MudButton>

            }
        </ToolBarContent>
        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<SOSReviewProgram, object>(x=>x.SOSid)" Enabled="true">SOS ID</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<SOSReviewProgram, object>(x=>x.Status)">@Localizer["status"]</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<SOSReviewProgram, object>(x=>x?.Supervisors?.FirstOrDefault()?.Name)">Supervisors</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<SOSReviewProgram, object>(x=>x.Plant?.Description)">@Localizer["plant"]</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<SOSReviewProgram, object>(x=>x.Area?.Description)">@Localizer["area"]</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<SOSReviewProgram, object>(x=>x.AplicationYear)">@Localizer["applicationYear"]</MudTableSortLabel>
            </MudTh>
            <MudTh>
                @Localizer["actions"]
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="SOS ID">
                <MudText Align="Align.Center">@context.SOSid</MudText>
            </MudTd>
            <MudTd DataLabel=@Localizer["status"]>
                <MudText Align="Align.Center">
                    @switch (context.Status)
                    {
                        case 1:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlaylistPlay" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">@Localizer["new"]</MudChip>
                            break;
                        case 2:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlaylistAddCheck" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">@Localizer["approved"]</MudChip>
                            break;
                    }
                </MudText>
            </MudTd>
            <MudTd DataLabel="Supervisor">
                @*<MudText Align="Align.Center">@context.Supervisor?.Name</MudText>*@
                 @if (context.Supervisors?.Count > 0)
                        {
                            <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                <ActivatorContent>
                                    <MudButton FullWidth=true EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small">@Localizer["SOS_ShowSupervisors"]</MudButton>
                                </ActivatorContent>
                                <ChildContent>
                                    @foreach (var usr in context.Supervisors)
                                    {
                                        <MudMenuItem Icon="@Icons.Material.Filled.SupervisorAccount" IconColor="Color.Secondary">@usr.UserId - @usr.Name</MudMenuItem>
                                    }

                                </ChildContent>
                            </MudMenu>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                                @Localizer["SOS_NoSupervisors"]
                            </MudAlert>
                        }

            </MudTd>
            <MudTd DataLabel=@Localizer["plant"]>
                <MudText Align="Align.Center">@context.Plant?.Description</MudText>
            </MudTd>
            <MudTd DataLabel=@Localizer["area"]>
                <MudText Align="Align.Center">@context.Area?.Description</MudText>
            </MudTd>
            <MudTd DataLabel=@Localizer["applicationYear"]>
                <MudText Align="Align.Center">@context.AplicationYear</MudText>
            </MudTd>
            <MudTd DataLabel=@Localizer["actions"]>
                <MudText Align="Align.Center">
                    <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                        <ActivatorContent>
                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => SosReviewDetails(context.SOSid))" @ontouchstart="(() => SosReviewDetails(context.SOSid))">@Localizer["sosDetails"]</MudMenuItem>
                            @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                            {
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => OpenDeleteDialog(context.SOSid))" @ontouchstart="(() => OpenDeleteDialog(context.SOSid))">@Localizer["delete"] SOS</MudMenuItem>
                            }
                        </ChildContent>
                    </MudMenu>
                    @* <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => PatDetails(context.PATid))"></MudIconButton>
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => OpenDeleteDialog(context.PATid))"></MudIconButton>*@
                </MudText>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@*Delete Pat modal*@
<MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
        <MudText Class="mt-4 mb-4">
            @Localizer["areYouSueYourWantToDeleteThisSOS"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
        <MudButton @onclick="(() => DeleteSosReview(deleteSosReviewId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">@Localizer["delete"]</MudButton>
    </DialogActions>
</MudDialog>