{
    [Parameter] public int? hriID { get; set; }
    private Dictionary<string, (string ContentType, string Uri)> UploadedImages { get; set; } = new();
    private int NumeroCiclos { get; set; } = 3;
    private int añoActual;
    private int mesActual;
    private int diasEnMes;
    private string mesTexto;
    private GetHRIDto _currentHRI = new GetHRIDto();

    // Variables para manejo de fechas y generación dinámica de la tabla
    private DateTime fechaHRI = DateTime.Now;

    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var fechaHoy = DateTime.Now;
        await LoadData(fechaHoy);
    }

    private async Task LoadData(DateTime fechaHoy)
    {
        _loading = true;

        if (hriID.HasValue)
        {
            var response = await HRIService.GetHRIById(hriID.Value);
            if (response != null && response.Data != null)
                _currentHRI = response.Data;
            else
                _currentHRI = new GetHRIDto();
        }
        else
            _currentHRI = new GetHRIDto();

        

        añoActual = fechaHoy.Year;
        mesActual = fechaHoy.Month;
        diasEnMes = DateTime.DaysInMonth(añoActual, mesActual);
        mesTexto = fechaHoy.ToString("MMMM", new System.Globalization.CultureInfo("es-ES"));

        _loading = false;
    }

    private string GetImageSrc(string url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return string.Empty;

        var apiBase = "https://localhost:10201/";
        
        if (string.IsNullOrWhiteSpace(url))
            return string.Empty;

        var encoded = Uri.EscapeDataString(url);
        return $"{apiBase}api/HRImages/content?path={encoded}";
    }

    private bool EsFinDeSemana(int dia) {
        DateTime fecha = new DateTime(añoActual, mesActual, dia);
        return fecha.DayOfWeek == DayOfWeek.Saturday || fecha.DayOfWeek == DayOfWeek.Sunday;
    }

    private int GetWeekOfMonth(int day)
    {
        DateTime date = new DateTime(añoActual, mesActual, day);
        // Lógica simple: (Día + (Día del primer día del mes - 1)) / 7 + 1
        return (day + (int)new DateTime(date.Year, date.Month, 1).DayOfWeek - 1) / 7 + 1;
    }

    private void GetBack()
    {
        NavigationManager.NavigateTo("/hri/index");
    }


    private async Task OnDateChanged(DateTime? date)
    {
        if (date == null) return;
        fechaHRI = date.Value;
        // Recargar los datos del nuevo mes
        await LoadDataForMonth(fechaHRI.Month, fechaHRI.Year);
    }

    private async Task PreviousMonth()
    {
        var m = mesActual == 1 ? 12 : mesActual - 1;
        var y = mesActual == 1 ? añoActual - 1 : añoActual;
        fechaHRI = new DateTime(y, m, 1);
        await LoadDataForMonth(m, y);
    }
    private async Task NextMonth()
    {
        var m = mesActual == 12 ? 1 : mesActual + 1;
        var y = mesActual == 12 ? añoActual + 1 : añoActual;
        fechaHRI = new DateTime(y, m, 1);
        await LoadDataForMonth(m, y);
    }

    private async Task LoadDataForMonth(int month, int year)
    {
        _loading = true;

        // Año del HRI
        añoActual = fechaHRI.Year;

        // Mes del HRI
        mesActual = fechaHRI.Month;
        mesTexto = fechaHRI.ToString("MMMM", new System.Globalization.CultureInfo("es-ES"));
        diasEnMes = DateTime.DaysInMonth(añoActual, mesActual);

        var response = await HRIService.GetDailyByMonthAndYear(hriID.Value, month, year);
        if (response != null && response.Data != null)
        {
            _currentHRI.ItemsRevised = response.Data.ItemsRevised;
            _currentHRI.HourmeterRevision = response.Data.HourmeterRevision;
            _currentHRI.HriCycles = response.Data.HriCycles;
            _currentHRI.WeeklyRevisions = response.Data.WeeklyRevisions;
        }

        _loading = false;
    }
}