@page "/hri/index"
@using SupervisorMobility.Client.Data.Entites.Dtos.HRIDtos
@using SupervisorMobility.Client.Data.Entites.Dtos.HRIRevisionItemsDtos
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IHRIService HRIService
@inject IHRIRevisionItemsService HRIRevisionItemsService
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-8">
    
    @* Encabezado Dinámico *@
    <MudGrid Class="mb-6" Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
        <MudItem>
            <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" Size="Size.Large" Class="mr-3"/>
        </MudItem>
        <MudItem>
            <MudText Typo="Typo.h4" Class="mud-text-primary">Gestión de Inspecciones HRI</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Control de Ciclos, Revisiones y Activos</MudText>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="4" Class="pa-6 rounded-lg mb-8">
        
        @* Barra de Herramientas *@
        <MudGrid Class="mb-6" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_searchString" 
                              Placeholder="Buscar por Control #, Departamento o Item..." 
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Search" 
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Clearable="true"
                              FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6" Class="d-flex justify-sm-end gap-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FilterList">Filtros</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.Add" Href="/hri/form" Class="rounded-pill px-6">
                    Nueva Inspección
                </MudButton>
            </MudItem>
        </MudGrid>

        @* DataGrid Principal con Jerarquía *@
        <MudDataGrid Items="@_hriList" 
                     T="HRIToTableDto"
                     Hover="true" 
                     Filterable="true" 
                     QuickFilter="@QuickFilter"
                     Hideable="true"
                     Height="calc(100vh - 400px)"
                     FixedHeader="true"
                     Loading="@_loading"
                     Class="modern-datagrid rounded">
            
            <Columns>
                @* Columna de Expansión para ver detalles rápidos *@
                <HierarchyColumn T="HRIToTableDto"  InitiallyExpandedFunc="@( (HRIToTableDto item) => false )" />

                <PropertyColumn Property="x => x.ControlNumber" Title="Nº Control" />

                <TemplateColumn Title="Línea / Item">
                    <CellTemplate>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2"><b>Línea:</b> @context.Item.Line?.LineName</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Item.NameOfItem?.Name</MudText>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

                <PropertyColumn Property="x => x.Department" Title="Departamento" />
                
                @* Indicadores de Complejidad (Listas) *@
                <TemplateColumn Title="Contenido">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="1">
                            <MudTooltip Text="Imágenes">
                                <MudBadge Content="@context.Item.ImagesCount" Color="Color.Info" Overlap="true" Bordered="true">
                                    <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Size="Size.Small" Color="Color.Default"/>
                                </MudBadge>
                            </MudTooltip>
                            <MudTooltip Text="Items revisados">
                                <MudBadge Content="@context.Item.RevisedItemsCount" Color="Color.Tertiary" Overlap="true" Bordered="true" Class="ml-4">
                                    <MudIcon Icon="@Icons.Material.Filled.FactCheck" Size="Size.Small" Color="Color.Default"/>
                                </MudBadge>
                            </MudTooltip>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Estado" SortBy="x => x.IsActive">
                    <CellTemplate>
                        <MudChip Color="@(context.Item.IsActive ? Color.Success : Color.Warning)" 
                                 Variant="Variant.Text" 
                                 Size="Size.Small" 
                                 Class="@($"font-weight-bold rounded-pill {(context.Item.IsActive ? "mud-bg-success-light" : "mud-bg-warning-light")}")">
                            @(context.Item.IsActive ? "ACTIVO" : "INACTIVO")
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Acciones" HeaderStyle="text-align:right;" CellStyle="text-align:right;">
                    <CellTemplate>
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                            <MudMenuItem Icon="@Icons.Material.Filled.FileOpen" IconColor="Color.Info" OnClick="@(() => DetailsHRI(context.Item))">Detalles</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Primary" OnClick="@(() => EditHRI(context.Item))">Editar</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.DateRange" IconColor="Color.Success" OnClick="@(() => Revisions(context.Item))">Revisiones</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.History" IconColor="Color.Tertiary" OnClick="@(() => History(context.Item))">Historial</MudMenuItem>
                            <MudDivider DividerType="DividerType.Middle" Class="my-2"/>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(() => DeleteHRI(context.Item))">Eliminar</MudMenuItem>
                        </MudMenu>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>

            @* Contenido expandible para mostrar detalles de las listas sin salir de la página *@
            <ChildRowContent>
                <MudCard Elevation="0" Class="ma-4 mud-bg-alternating rounded-lg border-dashed">
                    <MudCardContent>
                        @* Lógica Provisional: Si no hay items y no está cargando, llamamos al endpoint *@
                        @{
                            CheckAndLoadDetails(context.Item);
                        }

                        @if (_loadingItemDetails)
                        {
                            <div class="d-flex align-center pa-4">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                                <MudText Class="ms-3">Cargando ítems desde el servidor...</MudText>
                            </div>
                        }
                        else
                        {
                            <MudTabs Elevation="0" Outlined="false" Color="Color.Primary" Rounded="true">
                                <MudTabPanel Text="Items Revisados" Icon="@Icons.Material.Filled.List">
                                    <MudList T="string" Dense="true">
                                        @if (_hriItemsList != null && _hriItemsList.Any())
                                        {
                                            @foreach (var rev in _hriItemsList)
                                            {
                                                <MudListItem Text="@rev.RevisionPoint" 
                                                             Icon="@Icons.Material.Filled.CheckCircle" 
                                                             IconColor="Color.Success" />
                                            }
                                        }
                                        else
                                        {
                                            <MudListItem Text="No se encontraron registros para esta inspección." 
                                                         Icon="@Icons.Material.Filled.Info" />
                                        }
                                    </MudList>
                                </MudTabPanel>
                            </MudTabs>
                        }
                    </MudCardContent>
                </MudCard>
            </ChildRowContent>

            <PagerContent>
                <MudDataGridPager T="HRIToTableDto" RowsPerPageString="Filas:" />
            </PagerContent>
        </MudDataGrid>
    </MudPaper>
</MudContainer>

<style>
    .modern-grid-header th {
        background-color: var(--mud-palette-background-grey) !important;
        font-weight: 600 !important;
        text-transform: uppercase;
        font-size: 0.75rem;
    }
    .mud-bg-alternating { background-color: #f8f9fa; }
    .mud-bg-success-light { background-color: rgba(76, 175, 80, 0.1); }
    .mud-bg-warning-light { background-color: rgba(255, 152, 0, 0.1); }
    .border-dashed { border: 1px dashed var(--mud-palette-divider); }
</style>

@code {
    private bool _loading = true;
    private bool _loadingItemDetails = true;
    private string _searchString = "";
    private List<HRIToTableDto> _hriList = new();
    private List<GetHRIRevisionItemDto> _hriItemsList = new();

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        var response = await HRIService.GetHRISoftInfoList();
        if (response.Success)
            _hriList = response.Data;
        else
            Snackbar.Add("Error al cargar las inspecciones HRI.", Severity.Error);

        _loading = false;
    }

    private Func<HRIToTableDto, bool> QuickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        return x.ControlNumber.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
               x.Department.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
               (x.NameOfItem?.Name?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
    };

    private void CreateNewHRI() { NavigationManager.NavigateTo("/hri/form"); }
    private void DetailsHRI(HRIToTableDto item) { NavigationManager.NavigateTo($"/hri/details/{item.HriId}"); }
    private void EditHRI(HRIToTableDto item) { NavigationManager.NavigateTo($"/hri/form/{item.HriId}"); }
    private void ViewHistory(HRIToTableDto item) { /* Lógica para ver historial de ciclos */ }
    private void Revisions(HRIToTableDto item) { NavigationManager.NavigateTo($"/hri/revisions/{item.HriId}"); }
    private void History(HRIToTableDto item) { NavigationManager.NavigateTo($"/hri/history/{item.HriId}"); }
    private async Task DeleteHRI(HRIToTableDto item)
    {
        // Dialogo de confirmación antes de eliminar
        var dialogOptions = new DialogOptions() { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, DisableBackdropClick = true, ClassBackground = "dialog" };
        var dialogParameters = new DialogParameters
            {
                { "Title", "Eliminar HRI" },
                { "ContentText", "¿Estás seguro de que deseas eliminar esta HRI?" },
                { "ButtonText", "Eliminar" },
                { "CancelText", "Cancelar" },
                { "Color", Color.Error },
                { "Icon", @Icons.Material.Outlined.Delete },
                { "IconColor", Color.Error }
            };
        var dialog = await DialogService.ShowAsync<Confirmation>("Eliminar HRI", dialogParameters, dialogOptions);
        var dialogResult = await dialog.Result;

        if (dialogResult.Canceled) return;

        // Llamada al servicio para eliminar la HRI
        var response = await HRIService.DeleteHRI(item.HriId);
        if (response.Success)
            Snackbar.Add("HRI eliminada correctamente.", Severity.Success);
        else
            Snackbar.Add("Error al eliminar la HRI.", Severity.Error);

        StateHasChanged();
    }

    private async Task CheckAndLoadDetails(HRIToTableDto item)
    {
        _loadingItemDetails = true;

        // Obtener la lista de items revisados para este HRI
        var response = await HRIRevisionItemsService.GetHRIRevisionItemsByHRIId(item.HriId);
        if (response.Success && response.Data != null)
            _hriItemsList = response.Data;
        else
        {
            Snackbar.Add("Error al cargar los ítems revisados para esta inspección.", Severity.Error);
            _hriItemsList = new List<GetHRIRevisionItemDto>(); // Aseguramos que la lista esté vacía para evitar errores en la UI
        }

        _loadingItemDetails = false;
        StateHasChanged();
    }
}