@page "/hri/revisions"
@page "/hri/revisions/{hriID:int}"
@using SupervisorMobility.Client.Data.Entites.Dtos.HRIDtos
@using SupervisorMobility.Client.Data.Entities.Dtos.HRIDtos
@using SupervisorMobility.Client.Data.Entities.Dtos.HRIRevisionItemsDtos
@inject IHRIService HRIService
@inject IHRIRevisionCyclesService RevisionCyclesService
@inject IHRIHourmeterRevisionService HourmeterRevisionService
@inject IHRICyclesService HRICyclesService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService

@if(!_loading)
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-10">

    <div class="d-flex justify-space-between align-center mb-8 px-2">
        <div>
            <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">
                Detalles de Hoja de Revisión Inicial
            </MudText>
            @* <MudText Typo="Typo.subtitle1" Class="mud-text-secondary mt-1">
                ID Documento: #REV-2026-0041 | Fecha de Creación: 01/04/2026
            </MudText> *@
        </div>
        <MudChip Color="Color.Success" Variant="Variant.Filled" Size="Size.Large">ACTIVO</MudChip>
    </div>

    <MudGrid Spacing="4">
        @* I. INFORMACIÓN GENERAL Y EVIDENCIA *@
        <MudItem xs="12">
            <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4" Style="border-left: 5px solid var(--mud-palette-info)">
                <div class="d-flex align-center mb-4">
                    <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">I. Información General y Evidencia</MudText>
                </div>

                <div class="mb-6">
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Tertiary" Style="font-weight: 600; text-transform: uppercase;">
                        LAY OUT:
                    </MudText>

                    @* GALERÍA SOLO LECTURA *@
                    <div class="d-flex gap-3 overflow-x-auto py-2 px-1 custom-scrollbar" style="width: 100%; min-height: 160px; align-items: center;">
                        @if(_currentHRI.Images != null && _currentHRI.Images.Count > 0)
                        {
                            foreach (var entry in _currentHRI.Images)
                            {
                                <div class="flex-shrink-0 rounded-lg overflow-hidden mud-elevation-2"
                                     style="height: 150px; border: 1px solid var(--mud-palette-lines-default);">
                                    <MudImage Src="@GetImageSrc(entry.ImageUrl)"
                                              Height="150"
                                              ObjectFit="ObjectFit.Cover"
                                              Style="width: auto; display: block;"
                                              Alt="@entry.ImageType" />
                                </div>
                            }
                        }
                        else
                        {
                            <div class="d-flex flex-column align-center justify-center" style="width: 100%; padding: 40px 0; border: 2px dashed #ccc; border-radius: 8px;">
                                <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Size="Size.Large" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">No hay imágenes disponibles</MudText>
                            </div>
                        }
                    </div>
                </div>

                <MudDivider Class="mb-6" />

                <MudGrid Spacing="3">
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Nombre de Item</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">@(_currentHRI.NameOfItem?.Name ?? "")</MudText>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Nombre de Línea</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">@(_currentHRI.Line?.LineName ?? "")</MudText>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Número de Control</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">@(_currentHRI.ControlNumber ?? "")</MudText>
                    </MudItem>

                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Dock Asignado</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">@(_currentHRI.Dock?.DockName ?? "")</MudText>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Departamento</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">@(_currentHRI.Department ?? "")</MudText>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Supervisor Encargado</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">@(_currentHRI.Supervisor?.Name ?? "")</MudText>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Numero de Turnos</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">3 Turnos</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        @* II. PUNTOS DE REVISIÓN - MODO REGISTRO MENSUAL *@
        <MudItem xs="12">
            <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4" Style="border-left: 5px solid var(--mud-palette-warning)">
                <div class="d-flex align-center mb-4">
                    <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                        <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Small" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">II. Registro de Realización de Revisión</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            MES: @mesTexto | AÑO: @añoActual
                        </MudText>
                    </div>
                </div>

                <div class="table-container-scroll rounded-lg border">
                    <MudSimpleTable Dense="true" Hover="false" Striped="false" Elevation="0">
                        <thead>
                            <tr style="background-color: #f5f5f5;">
                                <th rowspan="2" class="border-right">#</th>
                                <th rowspan="2" style="min-width: 220px;" class="border-right">Puntos de Revisión</th>
                                <th rowspan="2" style="min-width: 130px;" class="border-right">Criterio</th>
                                <th rowspan="2" class="text-center border-right">Turno</th>
                                <th colspan="@diasEnMes" class="text-center">
                                    Días del Mes (@mesTexto @añoActual)
                                </th>
                            </tr>
                            <tr style="background-color: #f5f5f5;">
                                @for (int d = 1; d <= diasEnMes; d++)
                                {
                                    <th class="day-cell day-header @(EsFinDeSemana(d) ? "cell-disabled" : "")">@d</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if(_currentHRI.ItemsRevised != null)
                            {
                                foreach (var p in _currentHRI.ItemsRevised)
                                {
                                    foreach (var c in p.RevisionCycles)
                                    {
                                        <tr>
                                            @if (c.Cycle == 1)
                                            {
                                                <td rowspan="@NumeroCiclos" class="text-center border-right">@p.ItemId</td>
                                                <td rowspan="@NumeroCiclos" class="border-right"><b>@p.RevisionPoint</b></td>
                                                <td rowspan="@NumeroCiclos" class="border-right"><MudText Typo="Typo.caption">@p.Veredict.Description</MudText></td>
                                            }
                                            <td class="text-center border-right" style="background-color: #fafafa;"><b>@c.Cycle</b></td>

                                            @for (int d = 1; d <= diasEnMes; d++)
                                            {
                                                bool inhabíl = EsFinDeSemana(d);
                                                <td class="day-cell @(inhabíl ? "cell-disabled" : "")">
                                                    @if (!inhabíl)
                                                    {
                                                        <div style="cursor: pointer; height: 100%; width: 100%; overflow: hidden;">
                                                            @{
                                                                int currentDay = d;
                                                                // Buscamos si existe una revisión para el día "d" en el ciclo actual
                                                                var revisionExistente = c.DailyRevisions?
                                                                                        .FirstOrDefault(r => r.Day == currentDay);
                                                            }

                                                            @if (revisionExistente != null && !string.IsNullOrEmpty(revisionExistente.Status))
                                                            {
                                                                @* Si ya existe la revisión, mostramos el valor como texto o un span con estilo *@
                                                                <div style="display: flex; align-items: center; justify-content: center; height: 100%; font-size: 12px; font-weight: bold;"
                                                                     class="@(c.Cycle != loggedTurn ? "cell-disabled-no-user" : "")">
                                                                    @revisionExistente.Status
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                @* Si no existe, mostramos el select para que el usuario pueda capturar *@
                                                                <select style=" width: 100%; 
                                                                        height: 100%; 
                                                                        cursor: pointer; 
                                                                        appearance: none; 
                                                                        -webkit-appearance: none; 
                                                                        -moz-appearance: none; 
                                                                        border: 1px solid #ccc;
                                                                        border-radius: 4px;
                                                                        background-color: #f9f9f9;
                                                                        text-align: center;
                                                                        padding: 0;
                                                                        font-size: 12px;
                                                                        color: #333;
                                                                        outline: none;
                                                                        transition: border-color 0.2s;"
                                                                        @onchange="@(e => AddItemDailyRevision(currentDay, c.RevisionCycleId, e.Value.ToString()))"
                                                                        disabled="@(c.Cycle != loggedTurn)"
                                                                        class="@(c.Cycle != loggedTurn ? "cell-disabled-no-user" : "")">
                                                                <option value=""></option>
                                                                <option value="Ok" style="background-color: #fff; color: #28a745;">Ok</option>
                                                                <option value="NG" style="background-color: #fff; color: #dc3545;">NG</option>
                                                                <option value="NA" style="background-color: #fff; color: #6c757d;">N/A</option>
                                                            </select>
                                                            }
                                                        </div>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                    <tr style="height: 2px; background-color: var(--mud-palette-divider);">
                                        <td colspan="@(diasEnMes + 4)"></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </MudSimpleTable>
                </div>
            </MudPaper>
        </MudItem>

        @* III. ASIGNACIÓN DE PERSONAL *@
        <MudItem xs="12">
            <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4" Style="border-left: 5px solid var(--mud-palette-success)">
                <div class="d-flex align-center mb-4">
                    <MudAvatar Color="Color.Success" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                        <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">III. Revisiones de Personal</MudText>
                </div>

                <div class="table-container-scroll rounded-lg border">
                    <MudSimpleTable Dense="true" Hover="false" Elevation="0">
                        <thead>
                            <tr style="background-color: #f5f5f5;">
                                <th class="border-right" style="width: 80px;">Turno</th>
                                <th class="border-right" style="min-width: 150px;">Rol</th>
                                <th class="border-right" style="min-width: 200px;">Personal Asignado</th>
                                @for (int d = 1; d <= diasEnMes; d++)
                                {
                                    <th class="day-cell day-header @(EsFinDeSemana(d) ? "cell-disabled" : "")">@d</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="mud-table-row" style="background-color: rgba(var(--mud-palette-info-rgb), 0.05);">
                                <td class="text-center border-right">
                                    <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Small" Color="Color.Info" />
                                </td>
                                <td class="border-right">
                                    <MudText Typo="Typo.caption" Style="font-weight: 700;" Color="Color.Info">HORÓMETRO</MudText>
                                </td>
                                <td class="border-right">
                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">Medición de Horómetro General</MudText>
                                </td>
                                @for (int d = 1; d <= diasEnMes; d++)
                                {
                                    bool inhabíl = EsFinDeSemana(d);

                                    <td class="day-cell @(inhabíl ? "cell-disabled" : "")">
                                        @if (!inhabíl)
                                        {
                                            <div style="cursor: pointer; height: 100%; width: 100%; overflow: hidden;">
                                                @{
                                                    int currentDay = d;
                                                    // Buscamos si existe una revisión para el día "d" en el ciclo actual
                                                    var revisionExistente = _currentHRI.HourmeterRevision?.DailyRevisions?
                                                                            .FirstOrDefault(r => r.Day == currentDay);
                                                }

                                                @if (revisionExistente != null && !string.IsNullOrEmpty(revisionExistente.Status))
                                                {
                                                    @* Si ya existe la revisión, mostramos el valor como texto o un span con estilo *@
                                                    <div style="display: flex; align-items: center; justify-content: center; height: 100%; font-size: 12px; font-weight: bold;">
                                                        @revisionExistente.Status
                                                    </div>
                                                }
                                                else
                                                {
                                                    @* Si no existe, mostramos el select para que el usuario pueda capturar *@
                                                    <select style=" width: 100%; 
                                                                height: 100%; 
                                                                cursor: pointer; 
                                                                appearance: none; 
                                                                -webkit-appearance: none; 
                                                                -moz-appearance: none; 
                                                                border: 1px solid #ccc;
                                                                border-radius: 4px;
                                                                background-color: #f9f9f9;
                                                                text-align: center;
                                                                padding: 0;
                                                                font-size: 12px;
                                                                color: #333;
                                                                outline: none;
                                                                transition: border-color 0.2s;"
                                                                @onchange="@(e => AddHourmeterDailyRevision(currentDay, _currentHRI.HourmeterRevision?.Id ?? 0, e.Value.ToString()))">>
                                                        <option value=""></option>
                                                        <option value="Ok" style="background-color: #fff; color: #28a745;">Ok</option>
                                                        <option value="NG" style="background-color: #fff; color: #dc3545;">NG</option>
                                                        <option value="NA" style="background-color: #fff; color: #6c757d;">N/A</option>
                                                    </select>
                                                }
                                            </div>
                                        }
                                    </td>
                                }
                            </tr>
                            @foreach (var cycle in _currentHRI.HriCycles)
                            {
                                @* Fila para el Operador *@
                                <tr>
                                    <td rowspan="2" class="text-center border-right" style="background-color: #fafafa; font-weight: bold;">
                                        <MudIcon Icon="@Icons.Material.Filled.Loop" Size="Size.Small" Color="Color.Primary" /><br />
                                        @cycle.Cycle
                                    </td>
                                    <td class="border-right"><MudText Typo="Typo.caption" Style="font-weight: 600;">OPERADOR</MudText></td>
                                    <td class="border-right"><MudText Typo="Typo.body2">@cycle.Operator?.Name</MudText></td>
                            
                                    @for (int d = 1; d <= diasEnMes; d++)
                                    {
                                        bool inhabíl = EsFinDeSemana(d);

                                        <td class="day-cell @(inhabíl ? "cell-disabled" : "")">
                                            @if (!inhabíl)
                                            {
                                                <div style="cursor: pointer; height: 100%; width: 100%; overflow: hidden;">
                                                    @{
                                                        int currentDay = d;
                                                        // Buscamos si existe una revisión para el día "d" en el ciclo actual
                                                        var revisionExistente = cycle.DailyRevisions?
                                                                                .FirstOrDefault(r => r.Day == currentDay && r.UserId == cycle.Operator?.UserId);
                                                    }

                                                    @if (revisionExistente != null && !string.IsNullOrEmpty(revisionExistente.Status))
                                                    {
                                                        @* Si ya existe la revisión, mostramos el valor como texto o un span con estilo *@
                                                        <div style="display: flex; align-items: center; justify-content: center; height: 100%; font-size: 12px; font-weight: bold;"
                                                             class="@(cycle.Cycle != loggedTurn ? "cell-disabled-no-user" : "")">
                                                            @revisionExistente.Status
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        @* Si no existe, mostramos el select para que el usuario pueda capturar *@
                                                        <select style=" width: 100%; 
                                                                    height: 100%; 
                                                                    cursor: pointer; 
                                                                    appearance: none; 
                                                                    -webkit-appearance: none; 
                                                                    -moz-appearance: none; 
                                                                    border: 1px solid #ccc;
                                                                    border-radius: 4px;
                                                                    background-color: #f9f9f9;
                                                                    text-align: center;
                                                                    padding: 0;
                                                                    font-size: 12px;
                                                                    color: #333;
                                                                    outline: none;
                                                                    transition: border-color 0.2s;"
                                                                    @onchange="@(e => AddCyclesDailyRevision(currentDay, cycle.CycleId, cycle.Operator?.UserId ?? 0, e.Value.ToString()))"
                                                                    disabled="@(cycle.Cycle != loggedTurn)"
                                                                    class="@(cycle.Cycle != loggedTurn ? "cell-disabled-no-user" : "")">
                                                            <option value=""></option>
                                                            <option value="Ok" style="background-color: #fff; color: #28a745;">Ok</option>
                                                            <option value="NG" style="background-color: #fff; color: #dc3545;">NG</option>
                                                            <option value="NA" style="background-color: #fff; color: #6c757d;">N/A</option>
                                                        </select>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    }
                                </tr>
                                @* Fila para el Supervisor *@
                                <tr class="border-bottom">
                                    <td class="border-right"><MudText Typo="Typo.caption" Style="font-weight: 600;">SUPERVISOR</MudText></td>
                                    <td class="border-right"><MudText Typo="Typo.body2">@cycle.Supervisor?.Name</MudText></td>
                            
                                    @for (int d = 1; d <= diasEnMes; d++)
                                    {
                                        bool inhabíl = EsFinDeSemana(d);

                                        <td class="day-cell @(inhabíl ? "cell-disabled" : "")">
                                            @if (!inhabíl)
                                            {
                                                <div style="cursor: pointer; height: 100%; width: 100%; overflow: hidden;">
                                                    @{
                                                        int currentDay = d;
                                                        // Buscamos si existe una revisión para el día "d" en el ciclo actual
                                                        var revisionExistente = cycle.DailyRevisions?
                                                                                .FirstOrDefault(r => r.Day == currentDay && r.UserId == cycle.Supervisor?.UserId);
                                                    }

                                                    @if (revisionExistente != null && !string.IsNullOrEmpty(revisionExistente.Status))
                                                    {
                                                        @* Si ya existe la revisión, mostramos el valor como texto o un span con estilo *@
                                                        <div style="display: flex; align-items: center; justify-content: center; height: 100%; font-size: 12px; font-weight: bold;"
                                                             class="@(cycle.Cycle != loggedTurn ? "cell-disabled-no-user" : "")">
                                                            @revisionExistente.Status
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        @* Si no existe, mostramos el select para que el usuario pueda capturar *@
                                                        <select style=" width: 100%; 
                                                                    height: 100%; 
                                                                    cursor: pointer; 
                                                                    appearance: none; 
                                                                    -webkit-appearance: none; 
                                                                    -moz-appearance: none; 
                                                                    border: 1px solid #ccc;
                                                                    border-radius: 4px;
                                                                    background-color: #f9f9f9;
                                                                    text-align: center;
                                                                    padding: 0;
                                                                    font-size: 12px;
                                                                    color: #333;
                                                                    outline: none;
                                                                    transition: border-color 0.2s;"
                                                                    @onchange="@(e => AddCyclesDailyRevision(currentDay, cycle.CycleId, cycle.Supervisor?.UserId ?? 0, e.Value.ToString()))"
                                                                    disabled="@(cycle.Cycle != loggedTurn)"
                                                                    class="@(cycle.Cycle != loggedTurn ? "cell-disabled-no-user" : "")">
                                                            <option value=""></option>
                                                            <option value="Ok" style="background-color: #fff; color: #28a745;">Ok</option>
                                                            <option value="NG" style="background-color: #fff; color: #dc3545;">NG</option>
                                                            <option value="NA" style="background-color: #fff; color: #6c757d;">N/A</option>
                                                        </select>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" Class="mt-4">
            <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4" Style="border-left: 5px solid var(--mud-palette-secondary)">
                <div class="d-flex align-center mb-4">
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">IV. Validación Senior Supervisor (SSV)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Revisiones semanales de cumplimiento</MudText>
                    </div>
                </div>

                <div class="table-container-scroll rounded-lg border">
                    <MudSimpleTable Dense="true" Hover="false" Elevation="0">
                        <thead>
                            <tr style="background-color: #f5f5f5;">
                                <th class="border-right" style="min-width: 150px;">Nivel</th>
                                <th class="border-right" style="min-width: 200px;">Senior Supervisor</th>
                                @for (int d = 1; d <= diasEnMes; d++)
                                {
                                    <th class="day-cell day-header @(EsFinDeSemana(d) ? "cell-disabled" : "")">@d</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="border-right" style="background-color: #fafafa;">
                                    <MudChip Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Text"><b>SSV</b></MudChip>
                                </td>
                                <td class="border-right">
                                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@_currentHRI.SSV.Name</MudText>
                                </td>

                                @{
                                    int diaCorriente = 1;
                                    while (diaCorriente <= diasEnMes)
                                    {
                                        if (EsFinDeSemana(diaCorriente))
                                        {
                                            <td class="day-cell cell-disabled"></td>
                                            diaCorriente++;
                                        }
                                        else
                                        {
                                            int inicioBloque = diaCorriente;
                                            int span = 0;
                
                                            // Identificamos el número de semana de este bloque
                                            int numeroSemana = GetWeekOfMonth(inicioBloque);

                                            while (diaCorriente <= diasEnMes && !EsFinDeSemana(diaCorriente))
                                            {
                                                span++;
                                                diaCorriente++;
                                            }

                                            // Buscamos si ya existe una revisión guardada para esta semana
                                            var revisionExistente = _currentHRI.WeeklyRevisions?
                                                .FirstOrDefault(w => w.Week == numeroSemana && w.Month == mesActual);

                                            if(revisionExistente != null && revisionExistente?.RevisionId != 0)
                                            {
                                                <td colspan="@span" class="pa-0" style="text-align: center;">@revisionExistente.Status</td>
                                            }
                                            else
                                            {
                                                <td colspan="@span" class="pa-0">
                                                    <select @onchange="(e) => OnWeeklyStatusChanged(e.Value.ToString(), numeroSemana)"
                                                            style="width: 100%; height: 100%; border: 1px solid #ccc; text-align: center;">
                        
                                                        <option value=""></option>
                                                        <option value="Ok" style="background-color: #fff; color: #28a745;">Ok</option>
                                                        <option value="NG" style="background-color: #fff; color: #dc3545;">NG</option>
                                                        <option value="NA" style="background-color: #fff; color: #6c757d;">N/A</option>
                                                    </select>
                                                </td>                                                    
                                            }
                                        }
                                    }
                                }
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <div class="d-flex justify-end gap-2 mt-2">
                <MudButton Variant="Variant.Filled" Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.Print">Descargar Excel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="SaveChanges">Guardar Cambios</MudButton>
            </div>
        </MudItem>

    </MudGrid>
</MudContainer>
}
else
