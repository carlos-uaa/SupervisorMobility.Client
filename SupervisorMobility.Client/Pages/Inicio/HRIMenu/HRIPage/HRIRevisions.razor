@code{
    [Parameter] public int? hriID { get; set; }
    private Dictionary<string, (string ContentType, string Uri)> UploadedImages { get; set; } = new();
    private int NumeroCiclos { get; set; } = 3;
    private int añoActual;
    private int mesActual;
    private int diasEnMes;
    private string mesTexto;
    private GetHRIDto _currentHRI = new GetHRIDto();

    private User user = new();
    private string json;
    private int loggedTurn = 1;
    private List<CreateDailyRevisionDto> ItemsDailyrevisions = new List<CreateDailyRevisionDto>();
    private List<CreateDailyRevisionDto> HourmeterDailyrevisions = new List<CreateDailyRevisionDto>();
    private List<CreateDailyRevisionDto> CyclesDailyrevisions = new List<CreateDailyRevisionDto>();
    private List<CreateWeeklyRevisionDto> WeeklyRevisions = new List<CreateWeeklyRevisionDto>();

    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;

        if (hriID.HasValue)
        {
            var response = await HRIService.GetHRIById(hriID.Value);
            if (response != null && response.Data != null)
                _currentHRI = response.Data;
            else
                _currentHRI = new GetHRIDto();
        }
        else
            _currentHRI = new GetHRIDto();

        await GetUserAsync();

        var fechaHoy = DateTime.Now;

        añoActual = fechaHoy.Year;
        mesActual = fechaHoy.Month;
        diasEnMes = DateTime.DaysInMonth(añoActual, mesActual);
        mesTexto = fechaHoy.ToString("MMMM", new System.Globalization.CultureInfo("es-ES"));

        _loading = false;
    }

    private async Task GetUserAsync()
    {
        await TryGetAsync();

        if(_currentHRI.HriCycles != null)
            foreach (var turn in _currentHRI.HriCycles)
            {
                if (turn.Operator != null && turn.Operator.UserId == user.UserId)
                {
                    loggedTurn = turn.Cycle;
                    break;
                }
                else if (turn.Supervisor != null && turn.Supervisor.UserId == user.UserId)
                {
                    loggedTurn = turn.Cycle;
                    break;
                }
            }            
    }

    private async Task<bool> TryGetAsync()
    {
        bool hasProperty = await HasPropertyAsync();
        if (hasProperty)
        {
            json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "user");
            user = JsonSerializer.Deserialize<User>(json) ?? new();
        }
        else
        {
            user = new();
        }
        return hasProperty;
    }

    private async Task<bool> HasPropertyAsync()
        => await JSRuntime.InvokeAsync<bool>("localStorage.hasOwnProperty", "user");

    private string GetImageSrc(string url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return string.Empty;

        var apiBase = "https://localhost:10201/";
        
        if (string.IsNullOrWhiteSpace(url))
            return string.Empty;

        var encoded = Uri.EscapeDataString(url);
        return $"{apiBase}api/HRImages/content?path={encoded}";
    }

    private bool EsFinDeSemana(int dia) {
        DateTime fecha = new DateTime(añoActual, mesActual, dia);
        return fecha.DayOfWeek == DayOfWeek.Saturday || fecha.DayOfWeek == DayOfWeek.Sunday;
    }

    private Dictionary<string, string> EstadosRevision = new();

    private void RotarEstado(int ciclo, int dia, string rol)
    {
        string key = $"{ciclo}-{dia}-{rol}";
        if (!EstadosRevision.ContainsKey(key)) EstadosRevision[key] = "";

        EstadosRevision[key] = EstadosRevision[key] switch
        {
            "Ok" => "O",   // Cumple
            "NG" => "X",  // No Cumple
            "No aplica" => "N/A",// No Aplica
            _ => ""      // Default
        };

        StateHasChanged();
    }

    private Color GetColorEstado(string estado) => estado switch
    {
        "O" => Color.Success,
        "X" => Color.Error,
        "N/A" => Color.Default,
        _ => Color.Transparent
    };

    private string GetUserTypeLabel(int userType) => userType switch
    {
        1 => "A",
        2 => "SSV",
        3 => "S",
        4 => "O",
        5 => "M",
        6 => "LS",
        7 => "HC",
        8 => "RTC",
        _ => "Invalid"
    };

    private void AddItemDailyRevision(int dia, int cycle, string value)
    {
        var revision = new CreateDailyRevisionDto();
        revision.EntityRelationId = cycle;
        revision.Day = dia;
        revision.Month = mesActual;
        revision.Status = value;
        revision.UserId = user.UserId;
        revision.UserType = GetUserTypeLabel(user.UserType);

        ItemsDailyrevisions.Add(revision);
    }

    private void AddHourmeterDailyRevision(int dia, int relation, string value)
    {
        var revision = new CreateDailyRevisionDto();
        revision.EntityRelationId = relation;
        revision.Day = dia;
        revision.Month = mesActual;
        revision.Status = value;
        revision.UserId = user.UserId;
        revision.UserType = GetUserTypeLabel(user.UserType);

        HourmeterDailyrevisions.Add(revision);
    }

    private void AddCyclesDailyRevision(int dia, int relation, int userId, string value)
    {
        var revision = new CreateDailyRevisionDto();
        revision.EntityRelationId = relation;
        revision.Day = dia;
        revision.Month = mesActual;
        revision.Status = value;
        revision.UserId = userId;
        revision.UserType = GetUserTypeLabel(user.UserType);

        CyclesDailyrevisions.Add(revision);
    }

    private void OnWeeklyStatusChanged(string value, int weekNumber)
    {
        // Buscamos si ya existe este cambio en nuestra lista temporal de "pendientes por guardar"
        var existingChange = WeeklyRevisions.FirstOrDefault(x => x.Week == weekNumber);

        if (string.IsNullOrEmpty(value))
        {
            if (existingChange != null) WeeklyRevisions.Remove(existingChange);
            return;
        }

        if (existingChange != null)
        {
            // Si el DTO no tiene propiedad Status, asegúrate de agregarla 
            // o mapearla a IsActive según tu lógica de negocio
            // existingChange.Status = newValue; 
        }
        else
        {
            WeeklyRevisions.Add(new CreateWeeklyRevisionDto
            {
                HriId = _currentHRI.HriId,
                UserId = user.UserId,
                Month = mesActual,
                Week = weekNumber,
                IsActive = true,
                Status = value
            });
        }
    }

    private int GetWeekOfMonth(int day)
    {
        DateTime date = new DateTime(añoActual, mesActual, day);
        // Lógica simple: (Día + (Día del primer día del mes - 1)) / 7 + 1
        return (day + (int)new DateTime(date.Year, date.Month, 1).DayOfWeek - 1) / 7 + 1;
    }

    private bool ValidateSave() => ItemsDailyrevisions.Any() || HourmeterDailyrevisions.Any() || CyclesDailyrevisions.Any() || WeeklyRevisions.Any();

    private async Task SaveChanges()
    {
        if (!ValidateSave())
        {
            Snackbar.Add("No hay cambios para guardar.", Severity.Warning);
            return;
        }

        // Llamar dialogo de confirmacion antes de realizar las acciones
        var dialogOptions = new DialogOptions() { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, DisableBackdropClick = true, ClassBackground = "dialog" };
        var dialogParameters = new DialogParameters
            {
                { "Title", "Guardar Cambios" },
                { "ContentText", "¿Estás seguro de que deseas guardar las revisiones realizadas?" },
                { "ButtonText", "Guardar" },
                { "CancelText", "Cancelar" },
                { "Color", Color.Primary },
                { "Icon", @Icons.Material.Outlined.Save },
                { "IconColor", Color.Tertiary }
            };
        var dialog = await DialogService.ShowAsync<Confirmation>("Guardar Cambios", dialogParameters, dialogOptions);
        var dialogResult = await dialog.Result;

        if (dialogResult.Canceled) return;

        // Enviar las revisiones de Items al backend
        if (ItemsDailyrevisions.Any())
        {
            foreach (var revision in ItemsDailyrevisions)
            {
                var response = await RevisionCyclesService.CreateNewDailyRevision(revision);
                if (!response.Success)
                {
                    Snackbar.Add($"Error al guardar revisión del día {revision.Day} para el ciclo: {response.Message}", Severity.Error);
                    return;
                }
            }

            Snackbar.Add("Se guardaron correctamente las revisiones para los items revisados", Severity.Success);
            StateHasChanged();
        }

        // Enviar las revisiones de Horómetro al backend
        if(HourmeterDailyrevisions.Any())
        {
            foreach (var revision in HourmeterDailyrevisions)
            {
                var response = await HourmeterRevisionService.AddDailyRevisionToHourmeterRevision(revision);
                if (!response.Success)
                {
                    Snackbar.Add($"Error al guardar revisión del día {revision.Day} para el horómetro: {response.Message}", Severity.Error);
                    return;
                }
            }

            Snackbar.Add("Se guardaron correctamente las revisiones para el Horómetro", Severity.Success);
            StateHasChanged();
        }

        // Enviar las revisiones de Cycles al backend
        if(CyclesDailyrevisions.Any())
        {
            foreach (var revision in CyclesDailyrevisions)
            {
                var response = await HRICyclesService.CreateNewDailyRevision(revision);
                if (!response.Success)
                {
                    Snackbar.Add($"Error al guardar revisión del día {revision.Day} para el ciclo: {response.Message}", Severity.Error);
                    return;
                }
            }

            Snackbar.Add("Se guardaron correctamente las revisiones para los usuarios en turno", Severity.Success);
            StateHasChanged();
        }

        // Enviar las revisiones semanales al backend
        if(WeeklyRevisions.Any())
        {
            var response = await HRIService.CreateNewWeeklyRevision(WeeklyRevisions);
            if (!response.Success)
            {
                Snackbar.Add($"Error al guardar las revisiones semanales: {response.Message}", Severity.Error);
                return;
            }

            Snackbar.Add("Se guardaron correctamente las revisiones semanales", Severity.Success);
            StateHasChanged();
        }

        await LoadData();
    }
}