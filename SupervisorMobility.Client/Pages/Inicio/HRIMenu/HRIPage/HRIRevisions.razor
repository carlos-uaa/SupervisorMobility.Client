@page "/hri/revisions"

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-10">

    <div class="d-flex justify-space-between align-center mb-8 px-2">
        <div>
            <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">
                Detalles de Hoja de Revisión Inicial
            </MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary mt-1">
                ID Documento: #REV-2026-0041 | Fecha de Creación: 01/04/2026
            </MudText>
        </div>
        <MudChip Color="Color.Success" Variant="Variant.Filled" Size="Size.Large">ACTIVO</MudChip>
    </div>

    <MudGrid Spacing="4">
        @* I. INFORMACIÓN GENERAL Y EVIDENCIA *@
        <MudItem xs="12">
            <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4" Style="border-left: 5px solid var(--mud-palette-info)">
                <div class="d-flex align-center mb-4">
                    <MudAvatar Color="Color.Info" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">I. Información General y Evidencia</MudText>
                </div>

                <div class="mb-6">
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Tertiary" Style="font-weight: 600; text-transform: uppercase;">
                        LAY OUT:
                    </MudText>

                    @* GALERÍA SOLO LECTURA *@
                    <div class="d-flex gap-3 overflow-x-auto py-2 px-1 custom-scrollbar" style="width: 100%; min-height: 160px; align-items: center;">
                        @foreach (var entry in UploadedImages)
                        {
                            <div class="flex-shrink-0 rounded-lg overflow-hidden mud-elevation-2"
                                 style="height: 150px; border: 1px solid var(--mud-palette-lines-default);">
                                <MudImage Src="@entry.Value.Uri"
                                          Height="150"
                                          ObjectFit="ObjectFit.Cover"
                                          Style="width: auto; display: block;"
                                          Alt="@entry.Key" />
                            </div>
                        }
                    </div>
                </div>

                <MudDivider Class="mb-6" />

                <MudGrid Spacing="3">
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Nombre de Item</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">Montacargas Eléctrico - Caterpillar Serie F</MudText>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Nombre de Línea</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">Almacén de Producto Terminado</MudText>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Número de Control</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">MT-28-WMS</MudText>
                    </MudItem>

                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Dock Asignado</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">Dock A - Norte</MudText>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Departamento</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">Logística</MudText>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Supervisor Encargado</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">Juan Pérez Rodríguez</MudText>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Numero de Turnos</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">@NumeroCiclos Turnos</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>

        @* II. PUNTOS DE REVISIÓN - MODO REGISTRO MENSUAL *@
        <MudItem xs="12">
            <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4" Style="border-left: 5px solid var(--mud-palette-warning)">
                <div class="d-flex align-center mb-4">
                    <MudAvatar Color="Color.Warning" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                        <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Small" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">II. Registro de Realización de Revisión</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">MES: ABRIL | AÑO: 2026</MudText>
                    </div>
                </div>


                <div class="table-container-scroll rounded-lg border">
                    <MudSimpleTable Dense="true" Hover="false" Striped="false" Elevation="0">
                        <thead>
                            <tr style="background-color: #f5f5f5;">
                                <th rowspan="2" class="border-right">#</th>
                                <th rowspan="2" style="min-width: 220px;" class="border-right">Puntos de Revisión</th>
                                <th rowspan="2" style="min-width: 130px;" class="border-right">Criterio</th>
                                <th rowspan="2" class="text-center border-right">Turno</th>
                                <th colspan="@diasEnMes" class="text-center">Días del Mes (Abril @añoActual)</th>
                            </tr>
                            <tr style="background-color: #f5f5f5;">
                                @for (int d = 1; d <= diasEnMes; d++)
                                {
                                    <th class="day-cell day-header @(EsFinDeSemana(d) ? "cell-disabled" : "")">@d</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var listaPuntos = new[] {
                                    new { Id = 1, Nombre = "FUGAS DE ACEITE", Criterio = "SIN MANCHAS" },
                                    new { Id = 2, Nombre = "HORQUILLAS Y SEGUROS", Criterio = "SIN DEFORMACIÓN" },
                                    new { Id = 3, Nombre = "CHASIS Y CONTRAPESO", Criterio = "SIN GOLPES" },
                                    new { Id = 4, Nombre = "CRISTALES DE CABINA", Criterio = "LIMPIOS / NO ROTOS" },
                                    new { Id = 5, Nombre = "LLANTAS Y BIRLOS", Criterio = "BUEN ESTADO / AJUSTADOS" },
                                    new { Id = 6, Nombre = "SISTEMA DE DIRECCIÓN", Criterio = "SUAVE / SIN JUEGO" },
                                    new { Id = 7, Nombre = "EXTINTOR", Criterio = "CARGA VIGENTE" }
                                };
                            }

                            @foreach (var p in listaPuntos)
                            {
                                @for (int c = 1; c <= NumeroCiclos; c++)
                                {
                                    <tr>
                                        @if (c == 1)
                                        {
                                            <td rowspan="@NumeroCiclos" class="text-center border-right">@p.Id</td>
                                            <td rowspan="@NumeroCiclos" class="border-right"><b>@p.Nombre</b></td>
                                            <td rowspan="@NumeroCiclos" class="border-right"><MudText Typo="Typo.caption">@p.Criterio</MudText></td>
                                        }
                                        <td class="text-center border-right" style="background-color: #fafafa;"><b>@c</b></td>

                                        @for (int d = 1; d <= diasEnMes; d++)
                                        {
                                            bool inhabíl = EsFinDeSemana(d);
                                            <td class="day-cell @(inhabíl ? "cell-disabled" : "")">
                                                @if (!inhabíl)
                                                {
                                                    @* Aquí iría el componente para marcar X o O *@
                                                    <div style="cursor: pointer; height: 100%; width: 100%; overflow: hidden;">
                                                        <select style=" width: 100%; 
                                                                    height: 100%; 
                                                                    cursor: pointer; 
                                                                    appearance: none; 
                                                                    -webkit-appearance: none; 
                                                                    -moz-appearance: none; 
                                                                    border: 1px solid #ccc;
                                                                    border-radius: 4px;
                                                                    background-color: #f9f9f9;
                                                                    text-align: center;
                                                                    padding: 0;
                                                                    font-size: 12px;
                                                                    color: #333;
                                                                    outline: none;
                                                                    transition: border-color 0.2s;">
                                                            <option value=""></option>
                                                            <option value="Ok" style="background-color: #fff; color: #28a745;">Ok</option>
                                                            <option value="NG" style="background-color: #fff; color: #dc3545;">NG</option>
                                                            <option value="NA" style="background-color: #fff; color: #6c757d;">N/A</option>
                                                        </select>
                                                    </div>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                                @* Separador visual entre grupos de items *@
                                <tr style="height: 2px; background-color: var(--mud-palette-divider);">
                                    <td colspan="@(diasEnMes + 4)"></td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </div>
            </MudPaper>
        </MudItem>

        @* III. ASIGNACIÓN DE PERSONAL *@
        <MudItem xs="12">
            <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4" Style="border-left: 5px solid var(--mud-palette-success)">
                <div class="d-flex align-center mb-4">
                    <MudAvatar Color="Color.Success" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                        <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Small" />
                    </MudAvatar>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">III. Revisiones de Personal</MudText>
                </div>

                <div class="table-container-scroll rounded-lg border">
                    <MudSimpleTable Dense="true" Hover="false" Elevation="0">
                        <thead>
                            <tr style="background-color: #f5f5f5;">
                                <th class="border-right" style="width: 80px;">Turno</th>
                                <th class="border-right" style="min-width: 150px;">Rol</th>
                                <th class="border-right" style="min-width: 200px;">Personal Asignado</th>
                                @for (int d = 1; d <= diasEnMes; d++)
                                {
                                    <th class="day-cell day-header @(EsFinDeSemana(d) ? "cell-disabled" : "")">@d</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="mud-table-row" style="background-color: rgba(var(--mud-palette-info-rgb), 0.05);">
                                <td class="text-center border-right">
                                    <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Small" Color="Color.Info" />
                                </td>
                                <td class="border-right">
                                    <MudText Typo="Typo.caption" Style="font-weight: 700;" Color="Color.Info">HORÓMETRO</MudText>
                                </td>
                                <td class="border-right">
                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">Medición de Horómetro General</MudText>
                                </td>
                                @for (int d = 1; d <= diasEnMes; d++)
                                {
                                    int currentCycle = 0; // Identificador único para el horómetro
                                    int diaActual = d;
                                    string rol = "HOR"; // Rol específico para horómetro
                                    bool inhabíl = EsFinDeSemana(diaActual);
                                    string key = $"{currentCycle}-{diaActual}-{rol}";
                                    string estado = EstadosRevision.ContainsKey(key) ? EstadosRevision[key] : "";

                                    <td class="day-cell @(inhabíl ? "cell-disabled" : "")">
                                        @if (!inhabíl)
                                        {
                                            <button type="button" 
                                                    class="mud-button-root mud-icon-button mud-ripple"
                                                    style="width: 100%; height: 100%; font-weight: bold; font-size: 0.75rem; color: var(--mud-palette-@GetColorEstado(estado).ToDescriptionString());"
                                                    @onclick="() => RotarEstado(currentCycle, diaActual, rol)">
                                                @estado
                                            </button>
                                        }
                                    </td>
                                }
                            </tr>
                            @for (int i = 1; i <= NumeroCiclos; i++)
                            {
                                int currentCycle = i;
                                @* Fila para el Operador *@
                                <tr>
                                    <td rowspan="2" class="text-center border-right" style="background-color: #fafafa; font-weight: bold;">
                                        <MudIcon Icon="@Icons.Material.Filled.Loop" Size="Size.Small" Color="Color.Primary" /><br />
                                        @currentCycle
                                    </td>
                                    <td class="border-right"><MudText Typo="Typo.caption" Style="font-weight: 600;">OPERADOR</MudText></td>
                                    <td class="border-right"><MudText Typo="Typo.body2">Operador Especialista @((char)(64 + i))</MudText></td>
                            
                                    @for (int d = 1; d <= diasEnMes; d++)
                                    {
                                        int diaActual = d;
                                        string rol = "SUP";
                                        bool inhabíl = EsFinDeSemana(diaActual);
                                        string key = $"{currentCycle}-{diaActual}-{rol}";
                                        string estado = EstadosRevision.ContainsKey(key) ? EstadosRevision[key] : "";

                                        <td class="day-cell @(inhabíl ? "cell-disabled" : "")">
                                            @if (!inhabíl)
                                            {
                                                <button type="button" 
                                                        class="mud-button-root mud-icon-button mud-ripple"
                                                        style="width: 100%; height: 100%; font-weight: bold; font-size: 0.75rem; color: var(--mud-palette-@GetColorEstado(estado).ToDescriptionString());"
                                                        @onclick="() => RotarEstado(currentCycle, diaActual, rol)">
                                                    @estado
                                                </button>
                                            }
                                        </td>
                                    }
                                </tr>
                                @* Fila para el Supervisor *@
                                <tr class="border-bottom">
                                    <td class="border-right"><MudText Typo="Typo.caption" Style="font-weight: 600;">SUPERVISOR</MudText></td>
                                    <td class="border-right"><MudText Typo="Typo.body2">Supervisor Logístico @i</MudText></td>
                            
                                    @for (int d = 1; d <= diasEnMes; d++)
                                    {
                                        int diaActual = d;
                                        string rol = "SUP";
                                        bool inhabíl = EsFinDeSemana(diaActual);
                                        string key = $"{currentCycle}-{diaActual}-{rol}";
                                        string estado = EstadosRevision.ContainsKey(key) ? EstadosRevision[key] : "";

                                        <td class="day-cell @(inhabíl ? "cell-disabled" : "")">
                                            @if (!inhabíl)
                                            {
                                                <button type="button" 
                                                        class="mud-button-root mud-icon-button mud-ripple"
                                                        style="width: 100%; height: 100%; font-weight: bold; font-size: 0.75rem; color: var(--mud-palette-@GetColorEstado(estado).ToDescriptionString());"
                                                        @onclick="() => RotarEstado(currentCycle, diaActual, rol)">
                                                    @estado
                                                </button>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" Class="mt-4">
            <MudPaper Elevation="0" Outlined="true" Class="rounded-xl pa-4" Style="border-left: 5px solid var(--mud-palette-secondary)">
                <div class="d-flex align-center mb-4">
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Medium" Rounded="true" Class="mr-3">
                        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" />
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">IV. Validación Senior Supervisor (SSV)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Revisiones semanales de cumplimiento</MudText>
                    </div>
                </div>

                <div class="table-container-scroll rounded-lg border">
                    <MudSimpleTable Dense="true" Hover="false" Elevation="0">
                        <thead>
                            <tr style="background-color: #f5f5f5;">
                                <th class="border-right" style="min-width: 150px;">Nivel</th>
                                <th class="border-right" style="min-width: 200px;">Senior Supervisor</th>
                                @for (int d = 1; d <= diasEnMes; d++)
                                {
                                    <th class="day-cell day-header @(EsFinDeSemana(d) ? "cell-disabled" : "")">@d</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="border-right" style="background-color: #fafafa;">
                                    <MudChip Size="Size.Small" Color="Color.Tertiary" Variant="Variant.Text"><b>SSV</b></MudChip>
                                </td>
                                <td class="border-right">
                                    <MudText Typo="Typo.body2" Style="font-weight: 600;">Roberto G. (Planta 2)</MudText>
                                </td>

                                @{
                                    int diaCorriente = 1;
                                    while (diaCorriente <= diasEnMes)
                                    {
                                        if (EsFinDeSemana(diaCorriente))
                                        {
                                            <td class="day-cell cell-disabled"></td>
                                            diaCorriente++;
                                        }
                                        else
                                        {
                                            // Calculamos cuántos días hábiles seguidos hay hasta el próximo fin de semana o fin de mes
                                            int inicioBloque = diaCorriente;
                                            int span = 0;
                                            while (diaCorriente <= diasEnMes && !EsFinDeSemana(diaCorriente))
                                            {
                                                span++;
                                                diaCorriente++;
                                            }

                                            // Celda combinada para la semana
                                            <td colspan="@span" class="pa-0">
                                                <button type="button" 
                                                        class="mud-button-root mud-ripple d-flex align-center justify-center"
                                                        style="width: 100%; height: 32px; border: 1px solid var(--mud-palette-lines-default);"
                                                        @onclick='() => Console.WriteLine("Validar Semana")'>
                                                </button>
                                            </td>
                                        }
                                    }
                                }
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12">
            <div class="d-flex justify-end gap-2 mt-2">
                <MudButton Variant="Variant.Filled" Color="Color.Tertiary" StartIcon="@Icons.Material.Filled.Print">Descargar Excel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Editar Documento</MudButton>
            </div>
        </MudItem>

    </MudGrid>
</MudContainer>

<style>
    .bg-light-grey {
        background-color: var(--mud-palette-background-grey);
    }
    .mud-table-cell {
        vertical-align: middle !important;
        padding-top: 8px !important;
        padding-bottom: 8px !important;
    }
    
    .custom-scrollbar::-webkit-scrollbar {
        height: 8px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: var(--mud-palette-background-grey); 
        border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: var(--mud-palette-lines-default); 
        border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: var(--mud-palette-text-secondary); 
    }

    .day-cell {
        min-width: 30px !important;
        width: 30px !important;
        height: 30px !important;
        padding: 0 !important;
        text-align: center !important;
        border: 1px solid var(--mud-palette-lines-default) !important;
        font-size: 0.75rem !important;
    }
    
    .day-header {
        background-color: var(--mud-palette-action-default);
        font-weight: bold;
        font-size: 0.7rem;
    }

    .cycle-label {
        font-weight: bold;
        background-color: var(--mud-palette-background-grey);
        width: 40px;
        text-align: center;
    }

    /* Contenedor con scroll para no romper el layout */
    .table-container-scroll {
        overflow-x: auto;
        white-space: nowrap;
    }

    .day-cell {
        min-width: 32px !important;
        width: 32px !important;
        height: 32px !important;
        padding: 0 !important;
        text-align: center !important;
        border: 1px solid var(--mud-palette-lines-default) !important;
    }
    
    /* Clase para días inhábiles (Sábado y Domingo) */
    .cell-disabled {
        background-color: var(--mud-palette-action-default) !important;
        background-image: stripe(45deg, #e0e0e0 25%, transparent 25%, transparent 50%, #e0e0e0 50%, #e0e0e0 75%, transparent 75%, transparent);
        background-size: 4px 4px;
        cursor: not-allowed;
    }

    .day-header {
        background-color: #f0f0f0;
        font-weight: bold;
        font-size: 0.75rem;
    }

    .table-container-scroll {
        overflow-x: auto;
        max-width: 100%;
    }
</style>

@code{
    private Dictionary<string, (string ContentType, string Uri)> UploadedImages { get; set; } = new();
    private int NumeroCiclos { get; set; } = 3;
    private int añoActual = 2026;
    private int mesActual = 4;
    private int diasEnMes = 30;

    protected override void OnInitialized()
    {
        // Llenamos el diccionario con las imágenes de la carpeta TempHRI
        for (int i = 1; i <= 9; i++)
        {
            string imageName = $"{i}.png"; // Ajusta la extensión si son .png
            string imageId = Guid.NewGuid().ToString(); // Generamos un ID único como llave
        
            // La Uri debe apuntar a la ruta relativa desde wwwroot para que el navegador la encuentre
            string relativePath = $"Images/TempHRI/{imageName}";
        
            UploadedImages.Add(imageId, ("image/png", relativePath));
        }
    }

    // Función simple para saber si es fin de semana
    private bool EsFinDeSemana(int dia) {
        DateTime fecha = new DateTime(añoActual, mesActual, dia);
        return fecha.DayOfWeek == DayOfWeek.Saturday || fecha.DayOfWeek == DayOfWeek.Sunday;
    }

    private Dictionary<string, string> EstadosRevision = new();

    private void RotarEstado(int ciclo, int dia, string rol)
    {
        string key = $"{ciclo}-{dia}-{rol}";
        if (!EstadosRevision.ContainsKey(key)) EstadosRevision[key] = "";

        EstadosRevision[key] = EstadosRevision[key] switch
        {
            "Ok" => "O",   // Cumple
            "NG" => "X",  // No Cumple
            "No aplica" => "N/A",// No Aplica
            _ => ""      // Reset
        };

        StateHasChanged();
    }

    private Color GetColorEstado(string estado) => estado switch
    {
        "O" => Color.Success,
        "X" => Color.Error,
        "N/A" => Color.Default,
        _ => Color.Transparent
    };
}