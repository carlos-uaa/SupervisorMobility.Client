@using MudBlazor
@using static SupervisorMobility.Client.Pages.Inicio.HRIMenu.FrequenciesPage.FrequenciesIndex
@using SupervisorMobility.Client.Data.Entities.Hri

<MudDialog DisableSidePadding="true">
    <TitleContent>
        <div class="d-flex align-center px-4 py-2">
            <MudIcon Icon="@GetIcon()" Color="@GetColor()" Size="Size.Large" Class="mr-3" />
            <MudText Typo="Typo.h6" Class="font-weight-bold mud-text-primary">
                @GetTitle()
            </MudText>
        </div>
        <MudDivider />
    </TitleContent>

    <DialogContent>
        <MudContainer Class="pt-6 pb-4 px-6">
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Code"
                                  Label="Código de Frecuencia"
                                  Placeholder="Ej. HR-L-001"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  ReadOnly="@IsViewMode"
                                  Required="true"
                                  RequiredError="El código es obligatorio" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudTextField @bind-Value="Model.Description"
                                  Label="Nombre de la Frecuencia"
                                  Placeholder="Ej. Northern Distribution"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  ReadOnly="@IsViewMode"
                                  Required="true"
                                  RequiredError="El nombre es obligatorio" />
                </MudItem>

                <MudItem xs="12" Class="d-flex align-center mt-2">
                    <MudSwitch @bind-Value="Model.IsActive"
                               Color="Color.Success"
                               Disabled="@IsViewMode"
                               Label="La Frecuencia se encuentra activa" />
                </MudItem>
            </MudGrid>
        </MudContainer>
    </DialogContent>

    <DialogActions>
        <MudContainer Class="d-flex justify-end px-6 pb-4 gap-2">
            <MudButton OnClick="Cancel"
                       Variant="Variant.Text"
                       Class="rounded-pill px-4">
                @(IsViewMode ? "Cerrar" : "Cancelar")
            </MudButton>
            
            @if (!IsViewMode)
            {
                <MudButton OnClick="Submit"
                           Variant="Variant.Filled"
                           Color="@GetColor()"
                           Class="rounded-pill px-8">
                    @(Mode == FormMode.Create ? "Guardar" : "Actualizar")
                </MudButton>
            }
        </MudContainer>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    // El objeto que vamos a editar, crear o ver
    [Parameter] public Frequency Model { get; set; } = new();

    // El modo del formulario
    [Parameter] public FormMode Mode { get; set; }

    private bool IsViewMode => Mode == FormMode.View;

    private void Submit() => MudDialog.Close(DialogResult.Ok(Model));
    private void Cancel() => MudDialog.Cancel();

    // --- Helpers visuales dinámicos ---
    private string GetTitle() => Mode switch
    {
        FormMode.Create => "Nuevo Registro HRI",
        FormMode.Edit => "Editar Registro HRI",
        FormMode.View => "Detalles del Registro",
        _ => ""
    };

    private string GetIcon() => Mode switch
    {
        FormMode.Create => Icons.Material.Filled.AddCircleOutline,
        FormMode.Edit => Icons.Material.Filled.EditNote,
        FormMode.View => Icons.Material.Filled.Info,
        _ => Icons.Material.Filled.Apps
    };

    private Color GetColor() => Mode switch
    {
        FormMode.Create => Color.Secondary, // Teal/Cian que usamos antes
        FormMode.Edit => Color.Warning,
        FormMode.View => Color.Info,
        _ => Color.Default
    };

    // Puedes colocar este Enum aquí o en una clase separada si lo usarás en más pantallas
    public enum FormMode
    {
        Create,
        Edit,
        View
    }
}