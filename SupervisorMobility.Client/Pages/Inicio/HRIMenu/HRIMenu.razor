@page "/hri/menu"
@inject IStringLocalizer<Resource> Localizer

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudGrid Spacing="3">

        <!-- Docks -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="menu-card">
                <MudItem Class="pa-2 header">
                    <MudChip Label Color="Color.Dark" Variant="Variant.Filled" Size="Size.Small">D</MudChip>
                    <MudText>@Localizer["Docks"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Dock" Size="Size.Medium" />
                </MudItem>
                <MudItem Class="content">
                    <MudText Class="pa-4">@Localizer["DocksDescription"]</MudText>
                </MudItem>
                <MudItem Class="pa-3 footer">
                    <MudButton Href="hri/docks" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">View all</MudButton>
                </MudItem>
            </MudPaper>
        </MudItem>

        <!-- Frequencies -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="menu-card">
                <MudItem Class="pa-2 header">
                    <MudChip Label Color="Color.Dark" Variant="Variant.Filled" Size="Size.Small">F</MudChip>
                    <MudText>@Localizer["Frequencies"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Wifi" Size="Size.Medium" />
                </MudItem>
                <MudItem Class="content">
                    <MudText Class="pa-4">@Localizer["FrequenciesDescription"]</MudText>
                </MudItem>
                <MudItem Class="pa-3 footer">
                    <MudButton Href="hri/frequency" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">View all</MudButton>
                </MudItem>
            </MudPaper>
        </MudItem>

        <!-- HRI -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="menu-card">
                <MudItem Class="pa-2 header">
                    <MudChip Label Color="Color.Dark" Variant="Variant.Filled" Size="Size.Small">HRI</MudChip>
                    <MudText>@Localizer["HRI"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Medium" />
                </MudItem>
                <MudItem Class="content">
                    <MudText Class="pa-4">@Localizer["HRIDescription"]</MudText>
                </MudItem>
                <MudItem Class="pa-3 footer">
                    <MudButton Href="hri/index" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">View all</MudButton>
                </MudItem>
            </MudPaper>
        </MudItem>

        <!-- Items -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="menu-card">
                <MudItem Class="pa-2 header">
                    <MudChip Label Color="Color.Dark" Variant="Variant.Filled" Size="Size.Small">I</MudChip>
                    <MudText>@Localizer["Items"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Medium" />
                </MudItem>
                <MudItem Class="content">
                    <MudText Class="pa-4">@Localizer["ItemsDescription"]</MudText>
                </MudItem>
                <MudItem Class="pa-3 footer">
                    <MudButton Href="hri/items" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">View all</MudButton>
                </MudItem>
            </MudPaper>
        </MudItem>

        <!-- Lines -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="menu-card">
                <MudItem Class="pa-2 header">
                    <MudChip Label Color="Color.Dark" Variant="Variant.Filled" Size="Size.Small">L</MudChip>
                    <MudText>@Localizer["Lines"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Medium" />
                </MudItem>
                <MudItem Class="content">
                    <MudText Class="pa-4">@Localizer["LinesDescription"]</MudText>
                </MudItem>
                <MudItem Class="pa-3 footer">
                    <MudButton Href="hri/lines" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">View all</MudButton>
                </MudItem>
            </MudPaper>
        </MudItem>

        <!-- Revision Method -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="menu-card">
                <MudItem Class="pa-2 header">
                    <MudChip Label Color="Color.Dark" Variant="Variant.Filled" Size="Size.Small">RM</MudChip>
                    <MudText>@Localizer["RevisionMethod"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Rule" Size="Size.Medium" />
                </MudItem>
                <MudItem Class="content">
                    <MudText Class="pa-4">@Localizer["RevisionMethodDescription"]</MudText>
                </MudItem>
                <MudItem Class="pa-3 footer">
                    <MudButton Href="hri/revisionmethods" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">View all</MudButton>
                </MudItem>
            </MudPaper>
        </MudItem>

        <!-- Veredict -->
        <MudItem xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="menu-card">
                <MudItem Class="pa-2 header">
                    <MudChip Label Color="Color.Dark" Variant="Variant.Filled" Size="Size.Small">V</MudChip>
                    <MudText>@Localizer["Veredict"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Gavel" Size="Size.Medium" />
                </MudItem>
                <MudItem Class="content">
                    <MudText Class="pa-4">@Localizer["VeredictDescription"]</MudText>
                </MudItem>
                <MudItem Class="pa-3 footer">
                    <MudButton Href="hri/veredicts" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">View all</MudButton>
                </MudItem>
            </MudPaper>
        </MudItem>

    </MudGrid>
</MudContainer>
