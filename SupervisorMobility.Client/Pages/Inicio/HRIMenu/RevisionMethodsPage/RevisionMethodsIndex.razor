@page "/hri/revisionmethods"
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IHRIRevisionItemsService RevisionService

@* Contenedor principal con padding y fondo suave *@
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-8">
    
    @* Encabezado de la página fuera de la tarjeta para un look moderno *@
    <MudGrid Class="mb-6" Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
        <MudItem>
            <MudIcon Icon="@Icons.Material.Filled.AppSettingsAlt" Color="Color.Primary" Size="Size.Large" Class="mr-3"/>
        </MudItem>
        <MudItem>
            <MudText Typo="Typo.h4" Class="mud-text-primary">HRI Revision Methods</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Administración & Gestión</MudText>
        </MudItem>
    </MudGrid>

    @* Tarjeta principal que contiene los controles y la grilla *@
    <MudPaper Elevation="4" Class="pa-6 rounded-lg mb-8">
        
        @* Panel de Control Superior (Búsqueda y Nuevo) *@
        <MudGrid Class="mb-6" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="8" md="6">
                <MudTextField @bind-Value="_searchString" 
                              Placeholder="Buscar por Código o Nombre de Método..." 
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Search" 
                              IconSize="Size.Medium" 
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mt-0"
                              FullWidth="true"
                              Clearable="true">
                </MudTextField>
            </MudItem>
            <MudItem xs="12" sm="4" md="3" Class="d-flex justify-sm-end">
                <MudTooltip Text="Administrar Columnas">
                    <MudIconButton Icon="@Icons.Material.Filled.ViewColumn" 
                                   OnClick="@(() => _dataGrid.ShowColumnsPanel())" />
                </MudTooltip>
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Tertiary" 
                           StartIcon="@Icons.Material.Filled.Add" 
                           OnClick="CreateNew"
                           Class="rounded-pill px-6"
                           Size="Size.Small">
                    Nuevo Registro
                </MudButton>
            </MudItem>
        </MudGrid>

        @* DataGrid Principal con Estilizado Avanzado *@
        <MudDataGrid Items="@_hriMethods" 
                     T="RevisionMethod"
                     Hover="true" 
                     Striped="false"
                     Bordered="false"
                     HeaderClass="modern-grid-header"
                     RowClassFunc="@((item, index) => index % 2 == 0 ? "" : "mud-bg-alternating")"
                     Filterable="true" 
                     QuickFilter="@QuickFilter"
                     Hideable="true"
                     FixedHeader="true"
                     Height="calc(100vh - 350px)"
                     Loading="@_loading"
                     Class="modern-datagrid rounded"
                     @ref="_dataGrid">
            
            <Columns>
                <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" InitialSortDirection="SortDirection.Ascending" />
                <PropertyColumn Property="x => x.Code" Title="Código" Sortable="true" />
                <PropertyColumn Property="x => x.Description" Title="Nombre de Método" Sortable="true" />
                
                @* Columna de Estado Personalizada con Chips Modernos *@
                <TemplateColumn Title="Estado" Sortable="true" SortBy="x => x.IsActive">
                    <CellTemplate>
                        @if (context.Item.IsActive)
                        {
                            <MudChip Color="Color.Success" Variant="Variant.Text" Size="Size.Small" Class="font-weight-bold rounded-pill mud-bg-success-light">ACTIVO</MudChip>
                        }
                        else
                        {
                            <MudChip Color="Color.Warning" Variant="Variant.Text" Size="Size.Small" Class="font-weight-bold rounded-pill mud-bg-warning-light">INACTIVO</MudChip>
                        }
                    </CellTemplate>
                </TemplateColumn>
                
                @* Columna de Acciones con Botones Estilizados *@
                <TemplateColumn Title="Acciones" HeaderStyle="text-align:right;" CellStyle="text-align:right;" Sortable="false">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                            <MudTooltip Text="Ver Detalles">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" OnClick="@(() => ViewDetails(context.Item))" Class="rounded-lg mud-bg-info-light"/>
                            </MudTooltip>
                            <MudTooltip Text="Editar">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Variant="Variant.Filled" Size="Size.Small" OnClick="@(() => EditItem(context.Item))" Class="rounded-lg mud-bg-warning-light"/>
                            </MudTooltip>
                            <MudTooltip Text="Eliminar">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Variant="Variant.Filled" Size="Size.Small" OnClick="@(() => DeleteItem(context.Item))" Class="rounded-lg mud-bg-error-light"/>
                            </MudTooltip>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            
            <PagerContent>
                <MudDataGridPager T="RevisionMethod" InfoFormat="Mostrando {first_item}-{last_item} de {all_items}" RowsPerPageString="Filas:" />
            </PagerContent>
        </MudDataGrid>

    </MudPaper>
</MudContainer>

<style>
    .modern-grid-header th {
        background-color: var(--mud-palette-background-grey) !important;
        color: var(--mud-palette-text-primary) !important;
        font-weight: 600 !important;
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    .mud-bg-alternating {
        background-color: #fcfcfc;
    }

    /* Colores de fondo suaves para botones de acción y chips */
    .mud-bg-success-light { background-color: rgba(76, 175, 80, 0.1); }
    .mud-bg-warning-light { background-color: rgba(255, 152, 0, 0.1); }
    .mud-bg-info-light { background-color: rgba(33, 150, 243, 0.1); }
    .mud-bg-error-light { background-color: rgba(244, 67, 54, 0.1); }
    
    .modern-datagrid .mud-table-container {
        border: 1px solid var(--mud-palette-divider);
    }
</style>

@code {
    private bool _loading = true;
    private string _searchString = "";
    private List<RevisionMethod> _hriMethods = new();
    private MudDataGrid<RevisionMethod> _dataGrid = null!;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        
        var response  = await RevisionService.GetAllRevisionMethods();
        if(response.Success)
            _hriMethods = response.Data;
        else
            Snackbar.Add("Error al cargar los métodos de revisión", Severity.Error);
        
        _loading = false;
    }

    // Lógica de búsqueda rápida del DataGrid
    private Func<RevisionMethod, bool> QuickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (x.Code.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.Description.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    };

    // Métodos para botones de acción (Implementar navegación o diálogos aquí)
    private void DeleteItem(RevisionMethod item) => Console.WriteLine($"Eliminando: {item.Id}");

    private async Task CreateNew()
    {
        var parameters = new DialogParameters
        {
            { "Model", new RevisionMethod() { IsActive = true } }, // Valores por defecto
            { "Mode", RevisionMethodsFormDialog.FormMode.Create }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true, ClassBackground = "modern-dialog-bg" };
        var dialog = await DialogService.ShowAsync<RevisionMethodsFormDialog>("", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is RevisionMethod newRecord)
        {
            var response = await RevisionService.CreateRevisionMethod(newRecord);
            if (response != null && response.Success)
            {
                newRecord = response.Data;
                Snackbar.Add("Registro creado exitosamente", Severity.Success);
            }
            else
                Snackbar.Add("Error al crear el registro: " + response?.Message, Severity.Error);
        }
    }

    private async Task EditItem(RevisionMethod item)
    {
        // Importante: Clonar el objeto para no editar la fila directamente antes de darle "Guardar"
        var itemToEdit = new RevisionMethod { Id = item.Id, Code = item.Code, Description = item.Description, IsActive = item.IsActive };

        var parameters = new DialogParameters<RevisionMethodsFormDialog>
        {
            { "Model", itemToEdit },
            { "Mode", RevisionMethodsFormDialog.FormMode.Edit }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<RevisionMethodsFormDialog>("", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is RevisionMethod updatedRecord)
        {
            var response = await RevisionService.UpdateRevisionMethod(updatedRecord.Id, updatedRecord);
            if (response != null && response.Success)
            {
                updatedRecord = response.Data;
                Snackbar.Add("Registro actualizado exitosamente", Severity.Success);
            }
            else
                Snackbar.Add("Error al actualizar el registro: " + response?.Message, Severity.Error);
        }
    }

    private void ViewDetails(RevisionMethod item)
    {
        var parameters = new DialogParameters<RevisionMethodsFormDialog>
        {
            { "Model", item },
            { "Mode", RevisionMethodsFormDialog.FormMode.View }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        DialogService.Show<RevisionMethodsFormDialog>("", parameters, options);
    }
}