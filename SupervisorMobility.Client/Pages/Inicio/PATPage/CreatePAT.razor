@page "/PAT/createPat"

@inject NavigationManager NavigationManager
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionService
@inject IOperationService OperationService
@inject IPATService PATsServices
@inject IJSRuntime JSRuntime
@inject IUserService UsersService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService

@*Title*@
<PageTitle>Supervisor Mobility |  @Localizer["createPAT"]</PageTitle>

@*Breadcrumb links*@
@*<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>*@

@*Form*@
<EditForm Model="_pat" OnValidSubmit="CreatePatAsync">
    <DataAnnotationsValidator />
    <MudGrid Class="d-flex " Style="flex-direction: column; align-content: center;">
        <MudItem>
            <MudCard Style="min-width: 50vw">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6"> @Localizer["PATDetails"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success"> @Localizer["new"] PAT</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (user.UserType == 1)
                    {
                        @*Mud select for Plants for Admin*@
                        <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text"  Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.PlantId" For="@(() => _pat.PlantId)" SelectedValuesChanged="ShowAreas">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAPlant"]</MudSelectItem>
                            @foreach (var type in _plants)
                            {
                                <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        @*Mud select for Plants *@
                        <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text"  Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.PlantId" For="@(() => _pat.PlantId)" SelectedValuesChanged="ShowAreas">
                            @foreach (var type in _plants)
                            {
                                if (type.PlantId == user.PlantId)
                                {
                                    <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    }


                    @if (_pat.PlantId != 0 && user.UserType == 1)
                    {
                        @*Mud select for Areas for Admin *@
                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.AreaId" For="@(() => _pat.AreaId)" SelectedValuesChanged="ShowDistributions">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnArea"]</MudSelectItem>
                            @foreach (var type in _areas)
                            {
                                <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (_pat.PlantId != 0 && user.UserType == 2)
                    {
                        @*Mud select for Areas for SSV *@
                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.AreaId" For="@(() => _pat.AreaId)" SelectedValuesChanged="ShowDistributions">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnArea"]</MudSelectItem>
                            @foreach (var type in user.Areas)
                            {
                                <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (_pat.PlantId != 0)
                    {
                        @*Mud select for Areas for SV *@
                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.AreaId" For="@(() => _pat.AreaId)" SelectedValuesChanged="ShowDistributions">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnArea"]</MudSelectItem>
                            @foreach (var type in _areas)
                            {
                                if (type.AreaId == user.AreaId)
                                {
                                    <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    }
                    else
                    {
                        @*Mud select for Areas *@
                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.AreaId" For="@(() => _pat.AreaId)" SelectedValuesChanged="ShowDistributions">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAPlant"]</MudSelectItem>
                        </MudSelect>
                    }

                    @*Mud select for Distribution *@
                   @*  @if (_pat.AreaId != 0)
                    {
                        <MudSelect T="int" Label=@Localizer["distribution"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.DistributionId" For="@(() => _pat.DistributionId)">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectADistribution"]</MudSelectItem>
                            @foreach (var type in _distributions)
                            {
                                <MudSelectItem Value="type.DistributionId">
                                    @(
                                $"{type.Code} - {type.Description}"
                                )
                                </MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        <MudSelect T="int" Label=@Localizer["distribution"] Disabled Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.DistributionId" For="@(() => _pat.DistributionId)">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnArea"]</MudSelectItem>
                        </MudSelect>
                    } *@

                    <MudDatePicker @bind-Date="_pat.AplicationDate" Label=@Localizer["applicationDate"] PickerVariant="PickerVariant.Dialog" DateFormat="yyyy" FixMonth="@DateTime.Today.Month" FixDay="@DateTime.Today.Day" AutoClose="true" OpenTo="OpenTo.Year" Color="Color.Info" AdornmentColor="Color.Info" Class="mt-3" />

                    @if(user.UserType == 1){
                        @if(_pat.PlantId != 0 && _pat.AreaId != 0)
                        {
                            @*Mud select for SSV for Admin *@
                            <MudSelect T="int" Label="SSV" Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)" SelectedValuesChanged="ShowSupervisors">
                                <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnSSV"]</MudSelectItem>
                                @foreach (var ssv in _SSVs)
                                {
                                    <MudSelectItem Value="ssv.UserId">@($"{ssv.Name}")</MudSelectItem>
                                }
                            </MudSelect>
                            @if (ssvId != 0)
                            {
                                @if (_supervisors.Count > 0)
                                {
                                    <MudSelect T="int" Label="Supervisor" Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.SupervisorId" For="@(() => _pat.SupervisorId)">
                                        <MudSelectItem Disabled="true" Value="0">@Localizer["selectASupervisor"]</MudSelectItem>
                                        @foreach (var sv in _supervisors)
                                        {
                                            <MudSelectItem Value="sv.UserId">
                                                @($"{sv.Name}")
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Info" Class="mt-5">
                                        @Localizer["thisSSVDoesNotHaveSubordinates"]
                                    </MudAlert>
                                }
                            }
                            else
                            {
                                <MudSelect T="int" Label="Supervisor" Disabled Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.SupervisorId" For="@(() => _pat.SupervisorId)">
                                    <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnSSV"]</MudSelectItem>
                                </MudSelect>
                            }
                        }
                    else
                    {
                        @*Mud select for SSV *@
                        <MudSelect T="int" Label="SSV" Variant="Variant.Text" Disabled Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)">
                                <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnArea"]</MudSelectItem>
                        </MudSelect>
                    }



                    }
                    else if(user.UserType == 3){
                        <MudTextField T="string" @bind-Value="user.Name" Label="Supervisor" Class="mt-3" />
                        <MudTextField T="string" @bind-Value="SupervisorName" Label="SSV" Class="mt-3" />

                    }

                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["create"] PAT</MudButton>
                    <MudButton Href="/PAT" Variant="Variant.Filled" Class="ml-4">@Localizer["cancel"]</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>