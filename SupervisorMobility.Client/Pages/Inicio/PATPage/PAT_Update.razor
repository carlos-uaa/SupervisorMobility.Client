@page "/PAT/Update/{patID:int}"

@using System.Net.Http.Json
@using MudBlazor
@using System.Globalization;

@inject NavigationManager NavigationManager
@inject IUserService UsersServices
@inject IAreaService AreasServices
@inject IOperationService OperationsServices
@inject IDistributionService DistributionsServices
@inject IPATService PATsServices
@inject IJSRuntime JSRuntime
@inject IILUService ILUServices
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1
@inject IBreadcrumbService BreadcrumbService

@inject Microsoft.AspNetCore.Components.WebAssembly.Hosting.IWebAssemblyHostEnvironment Environment


@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["PATDetails"]</PageTitle>
@*Breadcrumb links*@
@*<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>*@

<style>

    .vertical-text {
        vertical-align: middle;
    }

    .vertical-content {
        writing-mode: vertical-lr;
        white-space: nowrap;
        word-wrap: break-word;
        max-width: 100%;
    }


    .mud-simple-table.mud-table-sticky-header * table thead * th {
        background-color: var(--mud-palette-surface);
        position: sticky;
        z-index: 2;
        top: 0;
    }

    .scroll1::-webkit-scrollbar {
        width: 4px;
        touch-action: pan-y;
    }



    .table-container {
        box-shadow: var(--mud-elevation-1);
        overflow-x: auto;
        border-radius: var(--mud-default-borderradius);
    }

        .table-container:hover {
            box-shadow: var(--mud-elevation-2);
        }


    .fixed-column {
        position: sticky;
        left: 0;
        z-index: 2;
        background-color: #f0f0f0;
    }

    .dynamic-left {
        left: 0;
    }
    /*
                                    table {
                                        border-collapse: collapse;
                                        min-width: 100%;
                                        border-radius: var(--mud-default-borderradius);
                                    } */

    th,
    td {
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .fixed-row {
        position: sticky;
        top: 0; /* Las filas fijas se ubicarán en la parte superior de la tabla */
        z-index: 2; /* Asegura que las filas fijas estén por encima del contenido desplazable */
    }

    .gray-color td {
        background-color: #f0f0f0;
        padding: 4px !important;
    }
</style>

@if (ShowTable)
{
    <MudSimpleTable Class="mb-5 calendar-table rounded" Style="overflow-x: auto;" Dense>
        <thead>
            <tr>
                <th>
                    <MudItem Class="d-flex">
                        <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
                        <MudText Class="ml-2">@Localizer["area"]</MudText>
                    </MudItem>
                </th>
                <th>@Localizer["applicationYear"]</th>
                <th>Supervisor</th>
                <th>SSV</th>
                <th>
                </th>
                <th>
                </th>
                <th>
                </th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>
                    @_pat?.Area?.Code - @_pat?.Area?.Description
                </td>
                <td>

                    @if (MonthlyView)
                    {
                        <MudItem Style="display: flex;  align-items: center">
                            <MudTooltip Text=@Localizer["lastMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                @if (_yearMonth.Value.Month >= 2 || (_yearMonth.Value.Year > DateTime.Now.Year && _yearMonth.Value.Month >= 2))
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Color="Color.Info" @onclick="@(()=>LastMonth())" OnTouch="@(()=>LastMonth())" Class="mr-4"></MudIconButton>
                                }
                            </MudTooltip>
                            <MudDatePicker Style="width: 150px; margin-top: -8px" OpenTo="OpenTo.Month" MinDate="@date" MaxDate="@LastdayYear" FixDay="1" DateFormat="MMMM / yyyy" PickerVariant="PickerVariant.Dialog" Color="Color.Info" AdornmentColor="Color.Info" DateChanged=@OnDateChanged Date="_yearMonth" />
                            <MudTooltip Text=@Localizer["nextMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                @if (_yearMonth.Value.Month <= 11)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.ArrowForwardIos" Color="Color.Info" @onclick="@(()=>NextMonth())" OnTouch="@(()=>NextMonth())" Class="ml-4"></MudIconButton>
                                }
                            </MudTooltip>
                        </MudItem>
                    }
                    else
                    {
                        @_pat?.AplicationYear
                    }
                </td>
                <td>
                    <MudText>@string.Join(" / ", _pat.Supervisors.Select(s => s.Name))</MudText>
                </td>
                <td>
                    <MudText>@string.Join(" / ", _pat.Supervisors.Select(s => s.Superior?.Name).Where(name => name != null).Distinct())</MudText>
                </td>
                <td>
                    <MudItem Style="justify-content: end" Class="ml-auto">
                        <MudItem Class="d-flex">
                            @switch (_pat.Status)
                            {
                                case 1:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlaylistPlay" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">@Localizer["new"]</MudChip>
                                    break;
                                case 2:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                    break;
                                case 3:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                    break;
                                case 4:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                    break;
                                case 5:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                    break;
                                case 6:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                    break;
                            }

                        </MudItem>
                    </MudItem>

                </td>
                <td>
                       <MudItem Class="ml-auto">
                        @if ((user.UserType == 1 || user.UserType == 2) && _pat?.Status != 2)
                        {
                            <MudButton @onclick="(() => OpenSignComment())" StartIcon="@Icons.Material.Filled.BorderColor" IconColor="Color.Info">@Localizer["approvePAT"]</MudButton>
                        }
                    </MudItem>
                </td>
                <td>
                    <MudItem Class="ml-auto">

                        @if (Dev_env)
                        {

                            <MudSelect Style="float: left; margin-bottom: 10px;" T="int" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.Status">
                                <MudSelectItem Value="1">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlaylistPlay" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">@Localizer["new"]</MudChip>
                                </MudSelectItem>
                                <MudSelectItem Value="2">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                </MudSelectItem>
                                <MudSelectItem Value="3">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                </MudSelectItem>
                                <MudSelectItem Value="4">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                </MudSelectItem>
                                <MudSelectItem Value="5">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                </MudSelectItem>
                                <MudSelectItem Value="6">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                </MudSelectItem>

                            </MudSelect>

                        }
                    </MudItem>
                    <MudItem Class="ml-auto">
                        @if (_pat.Status != 6)
                        {
                            if (user.UserType == 1 || user.UserType == 3)
                            {
                                <MudButton StartIcon="@Icons.Material.Filled.StopCircle" @onclick="() => SaveProgressPat()" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["saveProgress"]</MudButton>
                            }
                        }
                    </MudItem>

                </td>
            </tr>
        </tbody>
    </MudSimpleTable>


    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
         <Header>
            <MudItem Class="ml-auto" Style="display: flex; ">
                <MudButton Color="Color.Success" StartIcon="@Icons.Custom.FileFormats.FileExcel" Variant="Variant.Filled" Size="Size.Small" OnClick="DownloadExcel" Class="mr-10 my-2">Export</MudButton>
                <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" Class="ml-5">
                    <ActivatorContent>
                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">@Localizer["showAllSymbols"]</MudButton>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem><span style="font-weight: bold; text-align: center" class="mr-12">I</span>@Localizer["canDoItWithHelp"]</MudMenuItem>
                        <MudMenuItem><span style="font-weight: bold; text-align: center" class="mr-11">L</span>@Localizer["canDoItYourself"]</MudMenuItem>
                        <MudMenuItem><span style="font-weight: bold; text-align: center" class="mr-10">U</span> @Localizer["canInstructOthers"]</MudMenuItem>
                        <MudMenuItem><span style="font-weight: bold" class="mr-14"></span> @Localizer["inexperiencedOperator"]</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Outlined.Circle" IconColor="Color.Dark">@Localizer["incumbentOperator"]</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.ChangeHistory" IconColor="Color.Dark">@Localizer["personnelInTrainingPeriod"]</MudMenuItem>
                    </ChildContent>
                </MudMenu>

                <MudToggleIconButton Toggled="IsZoomed" Class="mx-5" Icon="@Icons.Material.Filled.ZoomIn" Color="@Color.Info"
                                    ToggledIcon="@Icons.Material.Filled.ZoomOut" ToggledColor="@Color.Primary" ToggledChanged="@(async (_) => await ToggleZoom())" />
            </MudItem>

                                            </Header>
                                            <ChildContent>


        <MudTabPanel Text="Yearly" OnClick="@(() => MonthlyView = false)">
            <div class="table-container mb-10">
                <div class="scrollable-columns">
                    <MudSimpleTable Class="mb-5 rounded" Dense FixedHeader="true" Style="overflow-x: auto; height: 82vh" Elevation="0">
                        <thead>
                            <tr class="fixed-row">
                                <th colspan="2">@Localizer["operatorsByOperation"]</th>
                                <th colspan="2" rowspan="3" class="fixed-column dynamic-left ">@Localizer["operatorName"]</th>
                                <Virtualize Context="usr" Items="_UserOfArea">
                                    @if (User_Knolowed[usr.UserId])
                                    {
                                        <th rowspan="3" colspan="2">
                                            <div style="text-align: end;">
                                                <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="@usr.Name" AnchorOrigin="Origin.BottomCenter">
                                                    <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" OnClick="(() => OpenHistoryILU(usr.UserId))" OnTouch="(() => OpenHistoryILU(usr.UserId))">
                                                        @Localizer["historyILU"]
                                                    </MudMenuItem>
                                                </MudMenu>
                                            </div>
                                        </th>
                                    }
                                    else
                                    {
                                        <th style="background-color: #f9dad8; color: #f44336;" rowspan="3" colspan="2" class="thead">
                                            @usr.Name
                                        </th>
                                    }
                                </Virtualize>
                                <th rowspan="3">
                                    <b class="mr-4">ROR</b> @_UserOfArea.Count
                                </th>
                                <th rowspan="3">
                                </th>
                            </tr>
                            <tr>
                                <th colspan="2">
                                    <div style="display:flex; align-items: center;">
                                        @{
                                            double? percentage = CalculateDistributionPercentage();
                                        }
                                        @if (percentage.HasValue)
                                        {
                                            <span class="mr-2">@($"{percentage.Value:F2}%")</span>
                                        }
                                        else if (_pat.KnowledgePercentage is not null)
                                        {
                                            <span class="mr-2">@(_pat.KnowledgePercentage ?? 0)%</span>
                                        }
                                        else
                                        {
                                            <MudInput T="double?" ReadOnly />
                                        }
                                        @Localizer["in"] 1 x
                                        <MudInput T="int?" Class="ml-2" @bind-Value="_pat.KnowledgePercentage" />
                                    </div>
                                </th>
                            </tr>
                            <tr>
                                <th colspan="2">@Localizer["operatorsByOperation"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <th colspan="2" style="align-items: center;">
                                    <div style="display:flex; align-items: center;">
                                        @{
                                            double? percentageUsers = CalculateUserPercentage();
                                        }
                                        @if (percentageUsers.HasValue)
                                        {
                                            <span class="mr-2">@($"{percentageUsers.Value:F2}%")</span>
                                        }
                                        else
                                        {
                                            <MudInput T="double?" ReadOnly /> <span>%</span>
                                        }
                                        @Localizer["in"] <MudInput T="int?" @bind-Value="_pat.KnowledgePercentage" Class="ml-2" ReadOnly /> x 1
                                    </div>

                                </th>
                                <th colspan="2" class="fixed-column dynamic-left">

                                    <div style="display:flex; align-items: center;">
                                        <MudSelect @bind-Value="leader"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Dense
                                                   Class="mr-2">
                                            <MudSelectItem Value="@("S")">S</MudSelectItem>
                                            <MudSelectItem Value="@("C")">C</MudSelectItem>
                                        </MudSelect>
                                        @Localizer["payroll"]
                                    </div>

                                </th>
                                <Virtualize Context="usr" Items="_UserOfArea">
                                    @if (User_Knolowed[usr.UserId])
                                    {
                                        <th colspan="2" style="text-align: center;">
                                            @usr.Payroll
                                        </th>
                                    }
                                    else
                                    {
                                        <th style="background-color: #f9dad8; color: #f44336; text-align: center;" colspan="2">
                                            @usr.Payroll
                                        </th>
                                    }
                                </Virtualize>
                                <th><MudInput T="int?" @bind-Value="_pat.KnowledgePercentage" Class="ml-2" ReadOnly Style="max-width: 3vw;" /> x 1</th>
                                <th rowspan="2"><b>NOTAS RELACIONADAS CON LAS <br />OPERACIONES / DISTRIBUCIONES</b></th>
                            </tr>
                            <tr class="fixed-row">
                                <th colspan="2" class="fixed-column dynamic-left" style="max-width:60px;width:50px"> @Localizer1["code"]</th>
                                <th colspan="2" class="fixed-column dynamic-left"> @Localizer["distributionName"]</th>
                                <Virtualize Items="_UserOfArea">
                                    <th>Nivel</th>
                                    <th>Fecha</th>
                                </Virtualize>
                                <th style="min-width: 8vw;">
                                    <MudInput T="int" Class="ml-2" @bind-Value="countUserO" ReadOnly Style="max-width: 3vw;" /> Ops.
                                </th>
                            </tr>
                            @foreach (var op in _distributions)
                            {

                                <tr>
                                    <td style="max-width:120px;width:100px" colspan="2" class="fixed-column dynamic-left">@op.Code</td>
                                    @if (Distributions_Knolowed[op.DistributionId])
                                    {
                                        <th colspan="2" class="fixed-column dynamic-left">
                                            <div style="text-align: end;">
                                                <MudMenu AnchorOrigin="Origin.BottomCenter">
                                                    <ActivatorContent>
                                                        @op.Description &nbsp;
                                                        @switch (op.CriticalType)
                                                        {
                                                            case 1:
                                                                <MudImage Src="Images/HOE Symbols/Air Bag A.png" Alt="ILU Image" Height="30" Class="rounded-lg" />
                                                                break;
                                                            case 2:
                                                                <MudImage Src="Images/HOE Symbols/Air Bag B.png" Alt="ILU Image" Height="30" Class="rounded-lg" />
                                                                break;
                                                            case 3:
                                                                <MudImage Src="Images/HOE Symbols/Air Bag C.png" Alt="ILU Image" Height="30" Class="rounded-lg" />
                                                                break;
                                                        }
                                                        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown"></MudIcon>
                                                    </ActivatorContent>
                                                    <ChildContent>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" OnClick="(() => OpenHistoryILU_Operation(op.DistributionId))" OnTouch="(() => OpenHistoryILU_Operation(op.DistributionId))">
                                                            @Localizer["historyILU"]
                                                        </MudMenuItem>
                                                    </ChildContent>
                                                </MudMenu>
                                            </div>
                                        </th>
                                    }
                                    else
                                    {
                                        <th class="fixed-column dynamic-left" colspan="2" style="background-color:#fbe8ce;color:#ff9800">
                                            @op.Description &nbsp;
                                            @switch (op.CriticalType)
                                            {
                                                case 1:
                                                    <MudImage Src="Images/HOE Symbols/Air Bag A.png" Alt="ILU Image" Height="30" Class="rounded-lg" />
                                                    break;
                                                case 2:
                                                    <MudImage Src="Images/HOE Symbols/Air Bag B.png" Alt="ILU Image" Height="30" Class="rounded-lg" />
                                                    break;
                                                case 3:
                                                    <MudImage Src="Images/HOE Symbols/Air Bag C.png" Alt="ILU Image" Height="30" Class="rounded-lg" />
                                                    break;
                                            }
                                        </th>
                                    }


                                    <Virtualize Context="usr" Items="_UserOfArea">
                                        <td style="text-align: end;" colspan="2">


                                            @if (ILU_Matrix.TryGetValue((op.DistributionId, usr.UserId), out var context))
                                            {
                                                <table style="border: none">
                                                    <tbody>
                                                        @{
                                                            var latestContext = context?.OrderByDescending(c => c.AcquisitionDate).FirstOrDefault();
                                                            string ILULevelNumber = "§";
                                                            @if (latestContext != null)
                                                            {
                                                                ILULevelNumber = _LevelsILU.Find(u => u.ILULevelId == latestContext.ILULevelId).ILULevelCode;
                                                            }
                                                        }

                                                        @if (latestContext != null)
                                                        {
                                                            <tr style="border: none; display: flex; justify-content: space-between;">
                                                                @if (ILULevelNumber != "§")
                                                                {
                                                                    string imageSrc = "";
                                                                    <td style="border: none">
                                                                        @switch (ILULevelNumber)
                                                                        {
                                                                            case "ITrainee":
                                                                                imageSrc = "Images/ITrainee.png";
                                                                                break;
                                                                            case "I":
                                                                                imageSrc = "Images/I.png";
                                                                                break;
                                                                            case "ILeader":
                                                                                imageSrc = "Images/ILeader.png";
                                                                                break;
                                                                            case "LTrainee":
                                                                                imageSrc = "Images/LTrainee.png";
                                                                                break;
                                                                            case "LTraineeLeader":
                                                                                imageSrc = "Images/LTraineeLeader.png";
                                                                                break;
                                                                            case "L":
                                                                                imageSrc = "Images/L.png";
                                                                                break;
                                                                            case "LLeader":
                                                                                imageSrc = "Images/LLeader.png";
                                                                                break;
                                                                            case "UTrainee":
                                                                                imageSrc = "Images/UTrainee.png";
                                                                                break;
                                                                            case "ULeaderTrainee":
                                                                                imageSrc = "Images/ULeaderTrainee.png";
                                                                                break;
                                                                            case "ULeader":
                                                                                imageSrc = "Images/ULeader.png";
                                                                                break;
                                                                            case "U":
                                                                                imageSrc = "Images/U.png";
                                                                                break;
                                                                            default:
                                                                                imageSrc = "Images/default.png";
                                                                                break;
                                                                        }
                                                                        <div class="d-flex align-items-center">
                                                                            <MudImage Src="@imageSrc" Alt="ILU Image" Height="45" Class="rounded-lg" />
                                                                        </div>
                                                                    </td>
                                                                }
                                                                <td style="border: none">
                                                                    @latestContext.AcquisitionDate?.ToString("dd/MM/yyyy")
                                                                    @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                                                    {
                                                                        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="" Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                                                            <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="(() => CreateJobObservation(op.DistributionId, usr.UserId))" OnTouch="(() => CreateJobObservation(op.DistributionId, usr.UserId))">
                                                                                @Localizer["createJobObservation"]
                                                                            </MudMenuItem>
                                                                            <MudMenuItem Class="animationContainer" Style="max-width:300px" Icon="@Icons.Material.Filled.Add" OnClick="@( () => OpenDialogAddILU(op.DistributionId, usr.UserId))" OnTouch="( () => OpenDialogAddILU(op.DistributionId, usr.UserId))">
                                                                                <MudText Class="animationtext">@Localizer["newILUFor"] @usr.Name in Operation @op.Description </MudText>
                                                                            </MudMenuItem>
                                                                        </MudMenu>

                                                                    }

                                                                </td>
                                                            </tr>
                                                        }
                                                        else if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                                        {
                                                            <tr style="border: none; display: flex; justify-content: space-between;">
                                                                <td style="border: none">
                                                                </td>
                                                                <td colspan="2">
                                                                    <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="" Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                                                        <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="(() => CreateJobObservation(op.DistributionId, usr.UserId))" OnTouch="(() => CreateJobObservation(op.DistributionId, usr.UserId))">
                                                                            @Localizer["createJobObservation"]
                                                                        </MudMenuItem>
                                                                        <MudMenuItem Class="animationContainer" Style="max-width:300px" Icon="@Icons.Material.Filled.Add" OnClick="@( () => OpenDialogAddILU(op.DistributionId, usr.UserId))" OnTouch="( () => OpenDialogAddILU(op.DistributionId, usr.UserId))">
                                                                            <MudText Class="animationtext">@Localizer["newILUFor"] @usr.Name in Operation @op.Description </MudText>
                                                                        </MudMenuItem>
                                                                    </MudMenu>
                                                                </td>
                                                            </tr>


                                                        }
                                                    </tbody>
                                                </table>
                                            }

                                        </td>
                                    </Virtualize>
                                    <td>
                                        @{
                                            var hasLowLevel = HasLowLevelForUsers(ILU_Matrix, _UserOfArea, op.DistributionId);
                                            var sum = CountHighLevelForUsers(ILU_Matrix, _UserOfArea, op.DistributionId);
                                            var meetsKnowledge = sum >= (_pat.KnowledgePercentage ?? 0);
                                        }

                                        @if (_pat.KnowledgePercentage != null)
                                        {
                                            @if (hasLowLevel && !meetsKnowledge || !hasLowLevel && !meetsKnowledge && sum > 0)
                                            {
                                                <span style="color:red"><b>X</b></span>
                                            }
                                            else if (meetsKnowledge)
                                            {
                                                <span><b>O</b></span>
                                            }
                                        }
                                    </td>
                                    <td>
                                        @if (_pat.PatDistributionComments.Any(c => c.DistributionId == op.DistributionId))
                                        {
                                            var currentComment = _pat.PatDistributionComments.First(c => c.DistributionId == op.DistributionId);
                                            <MudTextField @bind-Value="currentComment.Comment"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Lines="2"
                                                          Class="mr-2">
                                            </MudTextField>
                                        }
                                    </td>
                                </tr>
