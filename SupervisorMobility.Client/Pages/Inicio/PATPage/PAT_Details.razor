                                                        <td><span class="mr-2">@($"{monthsUsersPercentage[11]:F2}%")</span></td>
                                                    </tr>
                                                </tbody>
                                            </MudSimpleTable>

                                        </td>
                                    }
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </div>
                </div>

            </MudTabPanel>
