                                    <td colspan="4" style="max-width:60px;width:50px;" class="fixed-column">
                                        <div style="display:flex;">
                                            <div style="display:flex; align-items: center" class="mr-2">
                                                <b> RTO </b>  &nbsp;&nbsp; @_distributions.Count
                                            </div>
                                            <div style="display:flex; align-items: center" class="mr-2">
                                                1 x <MudInput T="int?" Class="ml-2" @bind-Value="_pat.KnowledgePercentage" ReadOnly />
                                            </div>
                                            <div style="display:flex; align-items: center">
                                                <MudInput T="int" Class="ml-2" @bind-Value="countDistO" ReadOnly /> Personas
                                            </div>
                                        </div>
                                    </td>

                                    <Virtualize Context="usr" Items="_UserOfArea.Where(u => _visibleSubordinateIds.Contains(u.UserId)).ToList()">
                                        @{
                                            int index = _UserOfArea.IndexOf(usr);
                                        }

                                        <td colspan="2" style="text-align: center;">

                                            @{
                                                var hasLowLevel = HasLowLevel(ILU_Matrix, _distributions, usr.UserId);
                                                var sum = CountHighLevel(ILU_Matrix, _distributions, usr.UserId);
                                                var meetsKnowledge = sum >= (_pat.KnowledgePercentage ?? 0);
                                            }


                                            @if (_pat.KnowledgePercentage != null)
                                            {

                                                var role = _pat.PatUserRoles?.ElementAtOrDefault(index)?.Role;
                                                var isSaveLeaderS = _pat.SaveLeader == "S";
                                                var isSaveLeaderC = _pat.SaveLeader == "C";
                                                var isRoleRelevant = role == null || role == OperatorRole.Lider || role == OperatorRole.CA;

                                                @if ((role == null && isSaveLeaderS) || (isRoleRelevant && isSaveLeaderC))
                                                {
                                                    @if (hasLowLevel && !meetsKnowledge || !hasLowLevel && !meetsKnowledge && sum > 0 || !meetsKnowledge)
                                                    {
                                                        <span style="color:red; text-align: center;"><b>X</b></span>
                                                    }
                                                    else if (meetsKnowledge)
                                                    {
                                                        <span style="text-align: center;"><b>O</b></span>
                                                    }

                                                }
                                            }
                                        </td>
                                    </Virtualize>

                                    <td style="text-align: center;"></td>
                                    <td style="text-align: center;">Nivel de habilidad Tecnica</td>
                                </tr>
                                <tr>
                                    <td colspan="2" style="max-width:60px;width:50px;" class="fixed-column">
                                        <b>
                                            Ops a Nivel L & U por Operador
                                        </b>
                                    </td>
                                    <td colspan="2" class="fixed-column dynamic-left">
                                    </td>
                                    <Virtualize Context="usr" Items="_UserOfArea.Where(u => _visibleSubordinateIds.Contains(u.UserId)).ToList()">
                                        <td style="text-align: center;" colspan="2">
                                            @{
                                                var sum = CountHighLevel(ILU_Matrix, _distributions, usr.UserId);
                                                @sum
                                            }
                                        </td>
                                    </Virtualize>
                                    <td style="text-align: center;"></td>
                                    <td style="text-align: center;">Histórico año actual</td>
                                </tr>
                                <tr>
                                    <td colspan="2" rowspan="4" style="max-width:60px;width:50px;" class="fixed-column">
                                        <p style="text-align: center; font-size: 11px">
                                            <b>NOTAS<br>RELACIONADAS CON LOS<br> OPERADORES</b><br>
                                            (REPROGRAMACIÓN / VACACIONES<br> / BAJAS /PLAN DE SUCESIÓN /<br> LIBERACIONES)
                                        </p>
                                    </td>

                                    <td colspan="2" class="fixed-column dynamic-left">
                                    </td>
                                    @if (_pat?.PatUserRoles != null)
                                    {
                                        <Virtualize Context="patUserRole" Items="_pat.PatUserRoles.Where(u => _visibleSubordinateIds.Contains(u.UserId)).ToList()">
                                            <td style="text-align: center;" colspan="2" rowspan="2">
                                                <MudTextField @bind-Value="patUserRole.Comment" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" Class="mr-2" ReadOnly></MudTextField>
                                                <MudSelect @bind-Value="patUserRole.Role"
                                                           ReadOnly
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Dense
                                                           Class="mr-2"
                                                           Placeholder="Select Role">

                                                    @foreach (var role in new List<OperatorRole?> { null }.Concat(Enum.GetValues<OperatorRole>().Cast<OperatorRole?>()))
                                                    {
                                                        <MudSelectItem Value="role">
                                                            @if (role is not null)
                                                        {
                                                            @role
                                                        }
                                                        else
                                                        {
                                                            <span>Clear</span>
                                                        }
                                                    </MudSelectItem>
                                                    }
                                                </MudSelect>
                                            </td>
                                        </Virtualize>
                                        <td style="text-align: center;" rowspan="2"></td>
                                        <td style="text-align: center;" rowspan="2">
                                            <MudSimpleTable>
                                                <thead>
                                                    <tr>
                                                        <th>MES</th>
                                                        @for (int i = 0; i < 6; i++)
                                                        {
                                                            <th>@monthsNames[i]</th>
                                                        }
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr class="gray-color">
                                                        <td style="background-color: white; text-align: center;">@_pat.KnowledgePercentage X 1</td>
                                                        <td><span class="mr-2">@($"{monthsDistributionPercentage[0]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsDistributionPercentage[1]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsDistributionPercentage[2]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsDistributionPercentage[3]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsDistributionPercentage[4]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsDistributionPercentage[5]:F2}%")</span></td>
                                                    </tr>
                                                    <tr class="gray-color">
                                                        <td style="background-color: white; text-align: center;">1 X @_pat.KnowledgePercentage</td>
                                                        <td><span class="mr-2">@($"{monthsUsersPercentage[0]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsUsersPercentage[1]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsUsersPercentage[2]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsUsersPercentage[3]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsUsersPercentage[4]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsUsersPercentage[5]:F2}%")</span></td>
                                                    </tr>
                                                </tbody>
                                                <thead>
                                                    <tr>
                                                        <th>MES</th>
                                                        @for (int i = 6; i < 12; i++)
                                                        {
                                                            <th>@monthsNames[i]</th>
                                                        }
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr class="gray-color">
                                                        <td style="background-color: white; text-align: center;">@_pat.KnowledgePercentage X 1</td>
                                                        <td><span class="mr-2">@($"{monthsDistributionPercentage[6]:F2}%")</span></td>
