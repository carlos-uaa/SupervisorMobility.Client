                                                        <td><span class="mr-2">@($"{monthsDistributionPercentage[8]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsDistributionPercentage[9]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsDistributionPercentage[10]:F2}%")</span></td>
                                                        <td><span class="mr-2">@($"{monthsDistributionPercentage[11]:F2}%")</span></td>
                                                    </tr>
                                                    <tr class="gray-color">
                                                        <td style="background-color: white; text-align: center;">1 X @_pat.KnowledgePercentage</td>
                                                        <td><span class="mr-2">@($"{monthsUsersPercentage[6]:F2}%")</span></td>
