@page "/kaizen"
@inject IBreadcrumbService BreadcrumbService
@inject IKaizenService KaizensServices
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["Kaizen"]</PageTitle>


    @if (Loading)
{
    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
        <ItemTemplate>
            <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                <MudItem class="d-flex flex-column justify-center align-self-center">
                    <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                </MudItem>
                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
                </div>
            </ItemTemplate>
        </MudCarousel>

    <MudSimpleTable Class="styled-table table-striped" FixedHeader=true>
        <thead>
            <tr>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
            </tr>
        </thead>
        <tbody>

            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /> <MudSpacer />   <MudSkeleton SkeletonType="SkeletonType.Rectangle" /> <MudSpacer />  <MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>

        </tbody>
    </MudSimpleTable>
}
else
{
    @if (_Kaizens.Count > 0)
    {
        <MudTable Items="_Kaizens" Hover="true" T="Kaizen" Class="styled-table table-striped mt-5" FixedHeader=true Height="75vh"
        RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" OnRowClick="RowClickEvent" T="Kaizen"
                  SortLabel="SortBy" Filter="new Func<Kaizen,bool>(FilterFunc1)"
                      RowsPerPage="15" HorizontalScrollbar="true" Virtualize="true">
            <ToolBarContent>
                <MudText Typo="Typo.h6" Align="Align.Center">@Localizer["Kaizen"]</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="@searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-2"></MudTextField>
                <MudSpacer />
                <MudButton @onclick="(() => Createkaizen())">
                    <MudText>@Localizer["create"] @Localizer["kaizen"]</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary"></MudIcon>
                    </MudButton>
                </ToolBarContent>
                <HeaderContent>
                    @if (user.UserType == 1)
                {
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.KaizenId)">
                            @Localizer["kaizen"] Id
                        </MudTableSortLabel>
                    </MudTh>
                }

                <MudTh>
                    <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.KaizenName)">
                        @Localizer["name"]
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.kpiName)">
                        @Localizer["kpi"]
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.Plant?.Code)">
                        @Localizer["plant"]
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.Area?.Description)">
                        @Localizer["area"]
                    </MudTableSortLabel>
                </MudTh>
                 <MudTh>
                    <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.SeniorSupervisor?.Name)">
                        @Localizer["SSV"]
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.Supervisor?.Name)">
                        @Localizer["SV"]
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.Status)">
                        @Localizer["status"]
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudText Align="Align.Center">@Localizer["actions"]</MudText>
                    </MudTh>
                </HeaderContent>
                <RowTemplate>
                    @if (user.UserType == 1)
                {
                    <MudTd DataLabel="Id">
                        <MudText Align="Align.Center">@context.KaizenId</MudText>
                        </MudTd>
                }
                <MudTd DataLabel=@Localizer["name"]>
                    <MudText Align="Align.Center">
                        @(context.KaizenName.Length > 25 ? context.KaizenName.Substring(0,20) + "..." : context.KaizenName)
                    </MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["description"]>
                        <MudText Align="Align.Center">@context.kpiName</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["plant"]>
                        <MudText Align="Align.Center">@context.Plant?.Code</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["area"]>
                        <MudText Align="Align.Center">@context.Area?.Description</MudText>
                    </MudTd>
                     <MudTd DataLabel=@Localizer["SSV"]>
                        <MudText Align="Align.Center">@context.SeniorSupervisor?.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["SV"]>
                        <MudText Align="Align.Center">@context.Supervisor?.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["status"]>
                        <MudText Align="Align.Center">@context.Status</MudText>
                    </MudTd>

                    <MudTd DataLabel=@Localizer["actions"]>
                        <MudText Align="Align.Center">
                            <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                <ActivatorContent>
                                    <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                </ActivatorContent>
                                <ChildContent>
                                    @* <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => KaizenDetails( context.KaizenId))" OnTouch="(() => KaizenDetails(context.KaizenId))">@Localizer["KaizenDetails"]</MudMenuItem> *@
                                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdateKaizen(context.KaizenId))" OnTouch="(() => UpdateKaizen( context.KaizenId))">@Localizer["editKaizen"]</MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => OpenDeleteDialog(context.KaizenId))" OnTouch="(() => OpenDeleteDialog(context.KaizenId))">@Localizer["deleteKaizen"]</MudMenuItem>
                                </ChildContent>
                            </MudMenu>
                        </MudText>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 15, 25, 50, 100, int.MaxValue }" />
                </PagerContent>
            </MudTable>
    }
    else
    {
        <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">@Localizer["thereAreNoKaizensCreatedForThisPlant"]</MudText>
        <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">
            <MudButton Color="Color.Info" @onclick="(() => Createkaizen())">@Localizer["createANewKaizen"]</MudButton>
            </MudText>
    }
}


@code {

    private List<BreadcrumbItem> _links;
    private List<Kaizen> _Kaizens;

    private IList<string> _sourceMsgLoading = new List<string>();
    private IList<Color> _Colors = new List<Color>() { Color.Default, Color.Primary, Color.Secondary, Color.Success, Color.Info, Color.Default, Color.Primary, Color.Secondary, Color.Success, Color.Info };


    private bool visibleDelete = false;
    private bool Loading = true;
    public int deleteKaizenId = 0;

    private DialogOptions dialogDeleteOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, Position = DialogPosition.TopCenter, DisableBackdropClick = true, CloseButton = true };

    //User
    private string json = string.Empty;
    public User user = new();
    public bool logged = false;

    protected async override Task OnInitializedAsync()
    {
        _sourceMsgLoading.Add($"{Localizer1["Loading1"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading2"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading3"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading4"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading5"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading6"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading7"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading8"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading9"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading10"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading11"]}");

        _links = new List<BreadcrumbItem>{
            new BreadcrumbItem(text: Localizer["home"], href: "/", disabled:false),
            new BreadcrumbItem(text: Localizer["Kaizen"], href: "", disabled: true)
            };

        BreadcrumbService.UpdateBreadcrumbs(_links);

        logged = await TryGetAsync();

        if (!logged)
        {
            Snackbar.Clear();
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Add(Localizer["errorYouHaveToLogIn"], Severity.Warning);
            NavigationManager.NavigateTo($"/");
        }
        else
        {

            _Kaizens = new();
            try
            {
                _Kaizens = await KaizensServices.GetAllKaizen(includeNavigation: true, includePeople: true);
            }
            catch (Exception ex)
            {

            }
            finally
            {
                Loading = false;
                StateHasChanged();

            }

        }
    }

    private async Task<bool> TryGetAsync()
    {
        bool hasProperty = await HasPropertyAsync();
        if (hasProperty)
        {
            json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "user");
            user = JsonSerializer.Deserialize<User>(json) ?? new();

        }

        return hasProperty;
    }


    private async Task<bool> HasPropertyAsync()
       => await JSRuntime.InvokeAsync<bool>("localStorage.hasOwnProperty", "user");

    private void Createkaizen()
    {
        NavigationManager.NavigateTo($"/kaizen/createkaizen");

    }

    void KaizenDetails(int KaizenId)
    {
        NavigationManager.NavigateTo($"/kaizen/detailskaizen/{KaizenId}");
    }

 

    // Delete Kaizen
    async Task DeleteKaizen(int KaizenId)
    {
        _Kaizens.RemoveAll(Kaizen => Kaizen.KaizenId == KaizenId);
        await KaizensServices.DeleteKaizen(KaizenId);

        visibleDelete = false;
    }

    void CloseDeleteModal() => visibleDelete = false;


    private void OpenDeleteDialog(int deleteId)
    {
        deleteKaizenId = deleteId;
        visibleDelete = true;
    }

    // Update Kaizen
    void UpdateKaizen(int KaizenId)
    {
        NavigationManager.NavigateTo($"plants");
    }


    private int selectedRowNumber = -1;
    private MudTable<Kaizen> SelectTableEvent;

    private void RowClickEvent(TableRowClickEventArgs<Kaizen> tableRowClickEventArgs)
    {
    }

    private string SelectedRowClassFunc(Kaizen element, int rowNumber)
    {
        if (selectedRowNumber == rowNumber)
        {
            selectedRowNumber = -1;
            if (SelectTableEvent.SelectedItem != null && SelectTableEvent.SelectedItem.Equals(element))
            {
                NavigationManager.NavigateTo($"kaizen/Updatekaizen/{element.KaizenId}");
            }
            return string.Empty;
        }
        else if (SelectTableEvent.SelectedItem != null && SelectTableEvent.SelectedItem.Equals(element))
        {
            selectedRowNumber = rowNumber;
            return "selected";
        }
        else
        {
            return string.Empty;
        }
    }
    private string searchString = "";

    private bool FilterFunc1(Kaizen element) => FilterFunc(element, searchString);
    private bool FilterFunc(Kaizen element, string searchString)
        {
            if (string.IsNullOrWhiteSpace(searchString))
                return true;
            if (element.PlantId.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        if (element.Plant?.Description?.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;   
            if (element.Plant?.Code?.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
        if (element.AreaId.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Area?.Description?.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
            if (element.Area?.Code ?.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase) == true)
            return true;
            if (element.KaizenName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
         
            return false;
        }
}
