@page "/kaizen"
@inject IBreadcrumbService BreadcrumbService
@inject IKaizenService KaizensServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["Kaizen"]</PageTitle>

        @if (_Kaizens.Count > 0)
    {
        <MudTable Items="_Kaizens" Hover="true" T="Kaizen" Class="styled-table table-striped" FixedHeader=true Height="75vh" RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" OnRowClick="RowClickEvent" T="Kaizen">
            <ToolBarContent>
                <MudSpacer />
                <MudButton @onclick="(() => Createkaizen())">
                    <MudText>@Localizer["create"] @Localizer["kaizen"]</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary"></MudIcon>
                    </MudButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.KaizenId)">
                            @Localizer["kaizen"] Id
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.KaizenName)">
                        @Localizer["name"]
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.kpiName)" InitialDirection="SortDirection.Ascending">
                        @Localizer["kpi"]
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<Kaizen, object>(x=>x.Status)" InitialDirection="SortDirection.Ascending">
                        @Localizer["status"]
                    </MudTableSortLabel>
                </MudTh>
                <MudTh>
                    <MudText Align="Align.Center">@Localizer["actions"]</MudText>
                    </MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Id">
                        <MudText Align="Align.Center">@context.KaizenId</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["code"]>
                        <MudText Align="Align.Center">@context.KaizenName</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["description"]>
                        <MudText Align="Align.Center">@context.kpiName</MudText>
                    </MudTd>  
                    <MudTd DataLabel=@Localizer["status"]>
                        <MudText Align="Align.Center">@context.Status</MudText>
                    </MudTd>

                    <MudTd DataLabel=@Localizer["actions"]>
                        <MudText Align="Align.Center">
                            <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                <ActivatorContent>
                                    <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                </ActivatorContent>
                                <ChildContent>
                                    @* <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => KaizenDetails( context.KaizenId))" @ontouchstart="(() => KaizenDetails(context.KaizenId))">@Localizer["KaizenDetails"]</MudMenuItem> *@
                                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdateKaizen(context.KaizenId))" @ontouchstart="(() => UpdateKaizen( context.KaizenId))">@Localizer["editKaizen"]</MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => OpenDeleteDialog(context.KaizenId))" @ontouchstart="(() => OpenDeleteDialog(context.KaizenId))">@Localizer["deleteKaizen"]</MudMenuItem>
                                </ChildContent>
                            </MudMenu>
                             </MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
    }
    else
    {
        <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">@Localizer["thereAreNoKaizensCreatedForThisPlant"]</MudText>
        <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">
            <MudButton Color="Color.Info" @onclick="(() => Createkaizen())">@Localizer["createANewKaizen"]</MudButton>
            </MudText>
    }


@code {

    private List<BreadcrumbItem> _links;
    private List<Kaizen> _Kaizens;

    private bool visibleDelete = false;
    public int deleteKaizenId = 0;

    private DialogOptions dialogDeleteOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, Position = DialogPosition.TopCenter, DisableBackdropClick = true, CloseButton = true };


    protected async override Task OnInitializedAsync()
    {
        _links = new List<BreadcrumbItem>{
            new BreadcrumbItem(text: Localizer["home"], href: "/", disabled:false),
            new BreadcrumbItem(text: Localizer["Kaizen"], href: "", disabled: true)
            };

        BreadcrumbService.UpdateBreadcrumbs(_links);

    }


    private void Createkaizen()
    {
        
    }

    void KaizenDetails(int KaizenId)
    {
        NavigationManager.NavigateTo($"plants");
    }

    // Create Kaizen
    void CreateKaizen()
    {
        NavigationManager.NavigateTo($"plants");
    }

    // Delete Kaizen
    async Task DeleteKaizen(int KaizenId)
    {
        _Kaizens.RemoveAll(Kaizen => Kaizen.KaizenId == KaizenId);
        await KaizensServices.DeleteKaizen(KaizenId);

        visibleDelete = false;
    }

    void CloseDeleteModal() => visibleDelete = false;


    private void OpenDeleteDialog(int deleteId)
    {
        deleteKaizenId = deleteId;
        visibleDelete = true;
    }

    // Update Kaizen
    void UpdateKaizen( int KaizenId)
    {
        NavigationManager.NavigateTo($"plants");
    }


    private int selectedRowNumber = -1;
    private MudTable<Kaizen> SelectTableEvent;

    private void RowClickEvent(TableRowClickEventArgs<Kaizen> tableRowClickEventArgs)
    {
    }

    private string SelectedRowClassFunc(Kaizen element, int rowNumber)
    {
        if (selectedRowNumber == rowNumber)
        {
            selectedRowNumber = -1;
            if (SelectTableEvent.SelectedItem != null && SelectTableEvent.SelectedItem.Equals(element))
            {
                NavigationManager.NavigateTo($"kaizen/Updatekaizen");
            }
            return string.Empty;
        }
        else if (SelectTableEvent.SelectedItem != null && SelectTableEvent.SelectedItem.Equals(element))
        {
            selectedRowNumber = rowNumber;
            return "selected";
        }
        else
        {
            return string.Empty;
        }
    }
}
