<MudGrid Justify="Justify.Center" Class="overflow-x-auto">
    @if (loadingSchedule)
    {
        <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
            <ItemTemplate>
                <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                    <MudItem class="d-flex flex-column justify-center align-self-center">
                        <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                    </MudItem>
                    @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                    <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
                </div>
            </ItemTemplate>
        </MudCarousel>
    }
    else
    {
        <MudItem lg="12" md="12" sm="12" xs="12" Class="text-align: center;">
            <MudItem Style="display: flex; justify-content: space-between; align-items: center; margin-top: -10px">
                <MudText Typo="Typo.h6" Style="display: flex; justify-content: space-evenly;  align-items: center; margin-bottom: -14px" >
                    <MudTooltip Text=@Localizer["lastMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info" class="mb-4">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Color="Color.Info" @onclick="@(()=>LastMonth())" Class="mr-4"></MudIconButton>
                    </MudTooltip>
                    <span style=" max-width: 14vw; min-width: 10vw;" class="mb-4">
                        <MudDatePicker OpenTo="OpenTo.Month" FixDay="1" DateFormat="MMMM / yyyy" PickerVariant="PickerVariant.Dialog" Color="Color.Info" AdornmentColor="Color.Info" DateChanged=@OnDateChangedAsync Date="_yearMonth" />
                    </span>
@*
                    @showMonth @year*@
                    <MudTooltip Text=@Localizer["nextMonth"] Arrow="true" Placement="Placement.Top" Color="Color.Info">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowForwardIos" Color="Color.Info" @onclick="@(()=>NextMonth())" Class="ml-4"></MudIconButton>
                    </MudTooltip>
                </MudText>
                <MudItem Style="display: flex; justify-content: space-evenly;  align-items: center;">
                    <MudSelect T="int" Label="@Localizer["status"]" Variant="Variant.Text" Class="mr-4" Style="width: 13vw" AnchorOrigin="Origin.BottomCenter" @bind-Value="@optionStatus" Dense>
                        <MudSelectItem Value="0">@Localizer["allStatus"]</MudSelectItem>
                        <MudSelectItem Value="7">
                            <span style="display: flex; align-items: center;">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Class="mr-2"></MudIcon>
                                @Localizer["programmed"]
                            </span>
                        </MudSelectItem>
                        <MudSelectItem Value="1">
                            <span style="display: flex; align-items: center;">
                                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Class="mr-2"></MudIcon>
                                @Localizer["planned"]
                            </span>
                        </MudSelectItem>
                        <MudSelectItem Value="2">
                            <span style="display: flex; align-items: center;">
                                <MudIcon Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Class="mr-2"></MudIcon>
                                @Localizer["inProgress"]
                            </span>
                        </MudSelectItem>
                        <MudSelectItem Value="3">
                            <span style="display: flex; align-items: center;">
                                <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Class="mr-2"></MudIcon>
                                @Localizer["late"]
                            </span>
                        </MudSelectItem>
                        <MudSelectItem Value="4">
                            <span style="display: flex; align-items: center;">
                                <MudIcon Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Class="mr-2"></MudIcon>
                                @Localizer["underReview"]
                            </span>
                        </MudSelectItem>
                        <MudSelectItem Value="5">
                            <span style="display: flex; align-items: center;">
                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Class="mr-2"></MudIcon>
                                @Localizer["rejected"]
                            </span>
                        </MudSelectItem>
                        <MudSelectItem Value="6">
                            <span style="display: flex; align-items: center;">
                            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Class="mr-2"></MudIcon>
                                @Localizer["finished"]
                            </span>
                        </MudSelectItem>
                    </MudSelect>
                    <MudButton StartIcon="@Icons.Material.Filled.FilterAlt" Color="Color.Primary" @onclick="(() => OpenDialogScheduleFilter())" Style="margin-bottom: -14px">@Localizer["filters"]</MudButton>
                </MudItem>
            </MudItem>
            @*FixedHeader=true Style="height:70vh" *@
            <MudSimpleTable Striped=true Bordered=true Elevation="6" Class="calendar-table scroll1" Dense FixedHeader=true Style="height: 82vh">
                <thead>
                    <tr style="cursor:default">
                        @for (var dayIndex = 0; dayIndex < days.Count(); dayIndex++)
                        {
                            <th style="text-align: center; width:14.28%">
                                @days[dayIndex].ToString().ToUpper()
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (var weekIndex = 0; weekIndex < weeks.Count(); weekIndex++)
                    {
                        <tr>
                            @for (var dayIndex = 0; dayIndex < weeks[weekIndex].Dates.Count(); dayIndex++)
                            {
                                var day = weeks[weekIndex].Dates[dayIndex].DayName;
                                var wIndex = weekIndex;
                                var dIndex = dayIndex;

