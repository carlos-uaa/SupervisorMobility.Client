                                                                    <MudTooltip Text="Open to Plan" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog3(jobobs.JobObservationId))">
                                                                        <MudChip Variant="Variant.Text" Color="Color.Warning" Label >
                                                                        <MudIconButton @onclick="(() => OpenDialog3(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Warning" Icon="@Icons.Material.Filled.Info"></MudIconButton>
                                                                            <span class="calendar-item">@opDescription</span>
                                                                        </MudChip>
                                                                        </MudTooltip>
                                                                }
                                                                else
                                                                {
                                                                    <MudTooltip Text="Open to Plan" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog3(jobobs.JobObservationId))">
                                                                        <MudChip Variant="Variant.Text" Color="Color.Error" Label >
                                                                            <MudIconButton @onclick="(() => OpenDialog3(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Error" Icon="@Icons.Material.Filled.Info"></MudIconButton>
                                                                            <span class="calendar-item">@opDescription</span>
                                                                        </MudChip>
                                                                    </MudTooltip>
                                                                }
                                                                        
                                                            }
                                                            else if(jobobs.Status == 7 && jobobs.Type != 3)
                                                            {
                                                                <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                    <MudChip Variant="Variant.Text" Color="Color.Warning" Label >
                                                                        <MudIconButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Warning" Icon="@Icons.Material.Filled.Info"></MudIconButton>
                                                                        <span class="calendar-item">@opDescription</span>
                                                                    </MudChip>
                                                                </MudTooltip>
                                                            }

                                                            break;
                                                        }

                                                    }

                                                }

                                        </div>
                                        @if (_jobObservations.Where(j => (Convert.ToDateTime(j.StartDate?.ToShortDateString()).Date <= Convert.ToDateTime(compare.ToShortDateString()).Date
                                                && Convert.ToDateTime(compare.ToShortDateString()).Date <= Convert.ToDateTime(j.EndDate?.ToShortDateString()).Date) ||
                                                (Convert.ToDateTime(j.StartDate?.ToShortDateString()).Date == Convert.ToDateTime(compare.ToShortDateString()).Date && j.Status == 7 && (7 == optionStatus || optionStatus == 0))
                                                && (j.Status == optionStatus || optionStatus == 0)).ToList().Count() > 2)
                                        {
                                            int totalCount = _jobObservations
                                                .Where(j => (Convert.ToDateTime(j.StartDate?.ToShortDateString()).Date <= Convert.ToDateTime(compare.ToShortDateString()).Date &&
                                                            Convert.ToDateTime(compare.ToShortDateString()).Date <= Convert.ToDateTime(j.EndDate?.ToShortDateString()).Date) ||
                                            (Convert.ToDateTime(j.StartDate?.ToShortDateString()).Date == Convert.ToDateTime(compare.ToShortDateString()).Date && j.Status == 7 && (7 == optionStatus || optionStatus == 0))
                                                            && (j.Status == optionStatus || optionStatus == 0))
                                                .ToList()
                                                .Count();
                                            totalCount = totalCount - 2;
                                            <MudItem Class="mx-2">
                                                <MudButton @onclick="(() => OpenDialog5(date))" FullWidth=true Style="text-align:center; height: 6px;" Variant="Variant.Filled" Color="Color.Info" >+ @totalCount</MudButton>
                                            </MudItem>
                                        }
                                    </td>

                                }

                            }
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudItem>
    }
</MudGrid>


