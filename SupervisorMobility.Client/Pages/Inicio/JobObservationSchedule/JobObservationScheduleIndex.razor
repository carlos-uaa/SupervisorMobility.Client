                                                    @if (user.UserType == 1 || user.UserType == 6)
                                                    {
                                                        @if (plantId != 0 && areaId != 0)
                                                        {
                                                            <MudSelect T="int" Label="SSV" Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)" SelectedValuesChanged="ShowSupervisors">
                                                                <MudSelectItem Value="0">@Localizer["allSSV"]</MudSelectItem>
                                                                @foreach (var ssv in _SSVs)
                                                                {
                                                                    <MudSelectItem Value="ssv.UserId">@($"{ssv.Name}")</MudSelectItem>
                                                                }
                                                            </MudSelect>
                                                        }
                                                        else
                                                        {
                                                            <MudSelect T="int" Label="SSV" Variant="Variant.Text" Disabled Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)">
                                                                <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnArea"]</MudSelectItem>
                                                            </MudSelect>
                                                        }

                                                    }
                                                    else if (user.UserType == 2)
                                                    {
                                                        <MudTextField T="string" @bind-Value="ssv" Label="SSV" Required="true" OnlyValidateIfDirty="true" ReadOnly />
                                                    }
                                                    else if (user.UserType == 3)
                                                    {

                                                        <MudTextField T="string" @bind-Value="ssv" Label="SSV" Required="true" OnlyValidateIfDirty="true" ReadOnly />
                                                    }
                                                    else if (user.UserType == 5)
                                                    {
                                                        @if (plantId != 0 && areaId != 0)
                                                        {
                                                            @if (user.Subordinates!.Count > 0)
                                                            {
                                                                <MudSelect T="int" Label="SSV" Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)" SelectedValuesChanged="ShowSupervisors">
                                                                    <MudSelectItem Value="0">@Localizer["allSSV"]</MudSelectItem>
                                                                    @foreach (var ssv in user.Subordinates)
                                                                    {
                                                                        <MudSelectItem Value="ssv.UserId">@($"{ssv.Name}")</MudSelectItem>
                                                                    }
                                                                </MudSelect>
                                                            }
                                                            else
                                                            {
                                                                <MudAlert Severity="Severity.Info" Class="mt-5">
                                                                    @Localizer["ssvHasNoSupervisors"]
                                                                </MudAlert>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <MudSelect T="int" Label="SSV" Variant="Variant.Text" Disabled Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ssvId" For="@(() => ssvId)">
                                                                <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnArea"]</MudSelectItem>
                                                            </MudSelect>
                                                        }

                                                    }

                                                </td>
                                            </tr>
                                            <tr>
                                                <td>
                                                    @if (user.UserType == 1 || user.UserType == 5 || user.UserType == 6)
                                                    {
                                                        @if (ssvId != 0 && plantId != 0)
                                                        {
                                                            @if (_supervisors.Count > 0)
                                                            {
                                                                <MudSelect T="int" Label="Supervisor" Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@supervisorId" For="@(() => supervisorId)" SelectedValuesChanged="JobObservationsBySupervisor">
                                                                    <MudSelectItem Value="0">@Localizer["allSupervisors"]</MudSelectItem>
                                                                    @foreach (var sv in _supervisors)
                                                                    {
                                                                        <MudSelectItem Value="sv.UserId">
                                                                            @($"{sv.Name}")
                                                                        </MudSelectItem>
                                                                    }
                                                                </MudSelect>
                                                            }
                                                            else
                                                            {
                                                                <MudAlert Severity="Severity.Info" Class="mt-5">
                                                                    @Localizer["ssvHasNoSupervisors"]
                                                                </MudAlert>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <MudSelect T="int" Label="Supervisor" Disabled Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="supervisorId" For="@(() => supervisorId)">
                                                                <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnSSV"]</MudSelectItem>
                                                            </MudSelect>
                                                        }
                                                    }
                                                    else if (user.UserType == 2)
                                                    {
                                                        @if (areaId != 0)
                                                        {
                                                            @if (_supervisors.Count > 0)
                                                            {
                                                                <MudSelect T="int" Label="Supervisor" Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@supervisorId" For="@(() => supervisorId)" SelectedValuesChanged="JobObservationsBySupervisor">
                                                                    <MudSelectItem Value="0">@Localizer["allSupervisors"]</MudSelectItem>
                                                                    @foreach (var sv in _supervisors)
                                                                    {
                                                                        <MudSelectItem Value="sv.UserId">
                                                                            @($"{sv.Name}")
                                                                        </MudSelectItem>
                                                                    }
                                                                </MudSelect>
                                                            }
                                                            else
                                                            {
                                                                <MudAlert Severity="Severity.Info" Class="mt-5">
                                                                    @Localizer["ssvAreaHasNoSupervisors"]
                                                                </MudAlert>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <MudSelect T="int" Label="Supervisor" Disabled Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="supervisorId" For="@(() => supervisorId)">
                                                                <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnArea"]</MudSelectItem>
                                                            </MudSelect>
                                                        }
                                                    }
                                                    else if (user.UserType == 3)
                                                    {
                                                        <MudTextField T="string" @bind-Value="supervisor" Label="Supervisor" Required="true" OnlyValidateIfDirty="true" ReadOnly />

                                                    }
                                                </td>
                                                <td>
                                                    <MudSelect T="int" Label="@Localizer["status"]" Variant="Variant.Text" Class="mr-4" Style="width: 13vw" AnchorOrigin="Origin.BottomCenter" @bind-Value="@optionStatus" Dense>
                                                        <MudSelectItem Value="0">@Localizer["allStatus"]</MudSelectItem>
                                                        <MudSelectItem Value="7">
                                                            <span style="display: flex; align-items: center;">
                                                                <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Class="mr-2"></MudIcon>
                                                                @Localizer["programmed"]
                                                            </span>
                                                        </MudSelectItem>
                                                        <MudSelectItem Value="1">
                                                            <span style="display: flex; align-items: center;">
                                                                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Class="mr-2"></MudIcon>
                                                                @Localizer["planned"]
                                                            </span>
                                                        </MudSelectItem>
                                                        <MudSelectItem Value="2">
                                                            <span style="display: flex; align-items: center;">
                                                                <MudIcon Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Class="mr-2"></MudIcon>
                                                                @Localizer["inProgress"]
                                                            </span>
                                                        </MudSelectItem>
                                                        <MudSelectItem Value="3">
                                                            <span style="display: flex; align-items: center;">
                                                                <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Class="mr-2"></MudIcon>
                                                                @Localizer["late"]
                                                            </span>
                                                        </MudSelectItem>
                                                        <MudSelectItem Value="4">
                                                            <span style="display: flex; align-items: center;">
                                                                <MudIcon Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Class="mr-2"></MudIcon>
                                                                @Localizer["underReview"]
                                                            </span>
                                                        </MudSelectItem>
                                                        <MudSelectItem Value="5">
                                                            <span style="display: flex; align-items: center;">
                                                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Class="mr-2"></MudIcon>
                                                                @Localizer["rejected"]
                                                            </span>
                                                        </MudSelectItem>
                                                        <MudSelectItem Value="6">
                                                            <span style="display: flex; align-items: center;">
                                                            <MudIcon Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Class="mr-2"></MudIcon>
                                                                @Localizer["finished"]
                                                            </span>
                                                        </MudSelectItem>
                                                    </MudSelect>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </MudSimpleTable>
                                </MudItem>
                            }
                        </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="CloseScheduleFilter">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>
