<MudDialog DisableSidePadding="false" @bind-IsVisible="visibleScheduleFiltersModal" Options="scheduleFiltersDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="text-align: center;">
            @Localizer["jobObservationSchedule"]
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid Justify="Justify.Center">
            <MudItem Class="d-flex align-center justify-center mud-width-full">
                            @if (!loadingToolbar)
                            {
                                <MudItem xs="12" sm="6" md="4" lg="4" Class="mr-4">
                                    <MudSimpleTable Style="overflow-x: auto;" Dense=true>
                                        <tbody>
                                            <tr>
                                                <th colspan="2" style="text-align: center;">@Localizer["programmedJobObservation"] (@totalProgrammed)</th>
                                            </tr>
                                            <tr>
                                                <td>
                                                    <div style="min-height: 15vh; overflow-y: scroll; max-height: 15vh; scroll-behavior: smooth; text-align:center; display: flex; justify-content: center;" class="scroll scroll1">
                                                        <div style=" display: flex; flex-direction: column;">
                                                            @if (totalProgrammed > 0)
                                                            {
                                                                @foreach (var jobobs in _jobObservations)
                                                                {
                                                                    if (jobobs.Status == 7 && jobobs.StartDate?.Month == _yearMonth?.Month && jobobs.StartDate?.Year == _yearMonth?.Year)
                                                                    {
                                                                        if (jobobs.StartDate >= DateTime.Now)
                                                                        {

                                                                            <MudTooltip Text="Open to Plan" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog3(jobobs.JobObservationId))">
                                                                    <MudButton @onclick="(() => OpenDialog3(jobobs.JobObservationId))" Style="padding: 0px;" Class="ml-5 mr-5" Color="Color.Warning" FullWidth>
                                                                                <MudChip Icon="@Icons.Material.Filled.Today" Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" Style="font-size: 10px">@jobobs.PlannedStartDate?.Day</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.Info" />
                                                                                <span style="font-weight: bold; font-size: 13px; cursor:pointer">@jobobs.Operation?.Code</span>
                                                                            </MudButton>
                                                                        </MudTooltip>
                                                                        }
                                                                        else
                                                                        {
                                                                            <MudTooltip Text="Open to Plan" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog3(jobobs.JobObservationId))">
                                                                                <MudButton @onclick="(() => OpenDialog3(jobobs.JobObservationId))" Style="padding: 0px;" Class="ml-5 mr-5" Color="Color.Error" FullWidth>
                                                                                <MudChip Icon="@Icons.Material.Filled.Today" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px">@jobobs.PlannedStartDate?.Day</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.Info" />
                                                                                <span style="font-weight: bold; font-size: 13px; cursor:pointer">@jobobs.Operation?.Code</span>
                                                                            </MudButton>
                                                                        </MudTooltip>
                                                                        }
                                                                    }
                                                                }

                                                            }
                                                            else
                                                            {
                                                                if (plantId != 0 && areaId != 0 && ssvId != 0 && supervisorId != 0)
                                                                {
                                                                    <MudAlert Severity="Severity.Info" Class="mt-5">
                                                                        @Localizer["ThereAreNoJobObservationsProgrammedInSOSForThisSupervisor"]
                                                                    </MudAlert>
                                                                }
                                                                else if (plantId != 0 && areaId != 0 && ssvId != 0)
                                                                {
                                                                    <MudAlert Severity="Severity.Info" Class="mt-5">
                                                                        @Localizer["ThereAreNoJobObservationsProgrammedInSOSForThisSSV"]
                                                                    </MudAlert>
                                                                }
                                                                else if (plantId != 0 && areaId != 0)
                                                                {
                                                                    <MudAlert Severity="Severity.Info" Class="mt-5">
                                                                        @Localizer["ThereAreNoJobObservationsProgrammedInSOSForThisArea"]
                                                                    </MudAlert>
                                                                }
                                                                else if (plantId != 0)
                                                                {
                                                                    <MudAlert Severity="Severity.Info" Class="mt-5">
                                                                        @Localizer["ThereAreNoJobObservationsProgrammedInSOSForThisPlant"]
                                                                    </MudAlert>
                                                                }
                                                                else
                                                                {

                                                                    <MudAlert Severity="Severity.Info" Class="mt-5">
                                                                        @Localizer["ThereAreNoJobObservationsProgrammedInSOSForThisMonth"]
                                                                    </MudAlert>
                                                                }


                                                            }
                                                        </div>
                                                    </div>
                                                </td>

                                            </tr>
                                            <tr>
                                                <td colspan="2">
                                                    <div class="pt-1 pb-4 pr-2">
