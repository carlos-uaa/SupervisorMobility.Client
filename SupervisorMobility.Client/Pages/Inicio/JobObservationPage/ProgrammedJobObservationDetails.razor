                                            {
                                                Glosary word;
                                                word = _glosaryInfo["Management of the anomaly"];
                                                <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                                    <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                        <MudText>@Localizer["managementOfTheAnomaly"]</MudText>
                                                        </MudBadge>
                                                    </MudTooltip>
                                            }
                                            else
                                            {
                                                <span>@Localizer["managementOfTheAnomaly"]</span>
                                            }
                                        </MudRadio>
                                        @if (_jobObservation.Option == 3)
                                        {
                                            <MudTextField @bind-Value="_jobObservation.Anomaly" T="string" Label=@Localizer["writeTheAnomaly"] Placeholder=@Localizer["anomaly"] Variant="Variant.Outlined" Margin="Margin.Dense" />
                                        }
                                    </MudRadioGroup>

                                </td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </MudItem>
            </MudPaper>

            <MudCardActions>
                @if (LoggedUser.UserType == 1 || LoggedUser.UserType == 2 || LoggedUser.UserType == 3)
                {
                    <MudItem Class="ml-auto">
                        <MudButton StartIcon="@Icons.Material.Filled.DateRange" Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => PlanNewJobObservation())">@Localizer["save"]</MudButton>
                        </MudItem>
                }
            </MudCardActions>
        </MudItem>
    </MudGrid>

}


<MudDialog @bind-IsVisible="CodePathModalDisplay" Options="dialogOptions" Style="    max-height: 95vh;    min-height: 80vh;">
    <DialogContent>
        <SupervisorMobility.Client.Pages.Components.TreeView Path_Id="SOSCodePathId" ></SupervisorMobility.Client.Pages.Components.TreeView>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseModalFiles" Variant="Variant.Filled">@Localizer["Close"]</MudButton>
    </DialogActions>
    </MudDialog>
