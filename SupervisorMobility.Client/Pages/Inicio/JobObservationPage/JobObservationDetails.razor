                            </MudChip>
                        </MudItem>
                    }
                    @if (!searchAssychart && messageErrorFolders != null)
                    {
                        <MudItem class="d-flex flex-column justify-center align-self-start">
                            <MudAlert Severity="Severity.Info">@messageErrorFolders</MudAlert>
                        </MudItem>
                    }
                    @if (searchAssychart && messageErrorFolders == null)
                    {
