                                                    <th>Cycle 2 (cs)</th>
                                                    <th>Cycle 3 (cs)</th>
                                                    <th>Cycle 4 (cs)</th>
                                                    <th>Cycle 5 (cs)</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var op in _filteredOperations)
                                                {
                                                    var standardTime = "0.0";
                                                    <tr>
                                                        <td>@op.Description</td>
                                                        @if ((_jobObservation.ModelsSpecification != null && _jobObservation.ModelsSpecification != "0|0|0|0|0" && _jobObservation.ModelsSpecification != "0") && op.NameTime != null)
                                                        {
                                                            var names = op.NameTime.Split("§");
                                                            var standardTimeIndex = _specifications.FindIndex(s => s == _jobObservation.ModelsSpecification);

                                                            <td>
                                                                @if (op.Time != null)
                                                                {
                                                                    var times = op.Time.Replace(',', '.').Split("§");
                                                                    standardTime = times[standardTimeIndex];
                                                                    <span>@standardTime</span>
                                                                }
                                                                else
                                                                {
                                                                    <span>0.0</span>
                                                                }
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td>0.0</td>
                                                        }

                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            var value = OperationTimes.ContainsKey(op.OperationId) && OperationTimes[op.OperationId].ContainsKey(i)
                                                            ? OperationTimes[op.OperationId][i]
                                                            : 0.0;

                                                            if (double.TryParse(standardTime, out double standardTimeValue))
                                                            {
                                                                var lowerBound = standardTimeValue * 0.95;
                                                                var upperBound = standardTimeValue * 1.05;

                                                                var percentageDifference = Math.Abs((value - standardTimeValue) / standardTimeValue) * 100;

                                                                var cycleColor = "";

                                                                if (value == 0.0 || standardTimeValue == 0.0)
                                                                {
                                                                    cycleColor = "";
                                                                }
                                                                else if (value > upperBound)
                                                                {
                                                                    cycleColor = "red";
                                                                }
                                                                else if (value < lowerBound)
                                                                {
                                                                    cycleColor = "yellow";
                                                                }
                                                                else if (value >= lowerBound && value <= upperBound)
                                                                {
                                                                    cycleColor = "green";
                                                                }


                                                                <td>
                                                                    <MudTextField T="string" ReadOnly Value="@value.ToString().Replace(',','.')" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                                                   Class="@cycleColor" />
                                                                 </td>
