        </MudItem>
        @if (showLoading)
        {
            <MudItem>
                <MudSimpleTable>
                    <thead>
                        <tr>
                            <td colspan="2" class="pt-10">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Style="margin-right: 10vw; margin-left: 10vw;" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Style="margin-right: 10vw; margin-left: 10vw;" />
                            </td>
                        </tr>
                    </thead>
                    <tbody>

                        <tr>
                            <td class="pt-10">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                            </td>
                            <td style="display:flex;" class="pt-10">
                                <div style="width: 50%">
                                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="mr-4" />
                                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="mr-4" />
                                </div>
                                <div style="width: 50%">
                                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="pt-10">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                            </td>
                            <td style="display:flex;" class="pt-10">
                                <div style="width: 50%">
                                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="mr-4" />
                                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Class="mr-4" />
                                </div>
                                <div style="width: 50%">
