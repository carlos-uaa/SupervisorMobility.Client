                                                                                                <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CommonDirectionCCP.Split('/').Last()</MudChip>
                                                                                                </MudTooltip>
                                                                                            </MudTooltip>
                                                                                        </MudButton>
                                                                                    </MudPaper>
                                                                            }
                                                                        </MudItem>

                                                                        <MudItem Style="flex-direction: column;">
                                                                            @if (item.GOS != "")
                                                                            {
                                                                                <MudPaper Elevation="0">
                                                                                    <MudButton OnClick="(() => OpenDialogCodePath(item, 3))" @ontouchstart="(() => OpenDialogCodePath(item, 3))" Style="padding: 0px;" Color="Color.Error">
                                                                                        <MudTooltip Text=@Localizer["openGOSFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
