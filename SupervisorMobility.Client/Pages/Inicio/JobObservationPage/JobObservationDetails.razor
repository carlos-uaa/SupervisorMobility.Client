                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                            </td>
                            <td class="pt-10">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                            </td>
                        </tr>
                        <tr>
                            <td style="width: 50%" class="pt-10">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                            </td>
                            <td class="pt-10">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" class="pt-10">
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" />
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
        }
        else
        {
            <MudExpansionPanels MultiExpansion Elevation="1">
                @foreach (var (category, section) in _checklistCategoriesAndQuestions.Select((category, section) => (category, section)))
                {
                    string title = $"Section {section}";
                    var ids = _jobObservation.SectionIds.Split('|');

                    if (ids.Any(id => id == category.JobCategoryStructureId.ToString()))
                    {
                        @switch (category.Type)
                        {
                            case StructureType.Titular:
                                <MudExpansionPanel IsInitiallyExpanded=true Style="min-width: 100%">
                                    <TitleContent>
                                        <MudText Typo="Typo.h6" Style="text-align: center;">
                                            @Localizer["jobObservacionCiclycalCard"] @_jobObservation.JobObservationId
                                            @if (_jobObservation.Type == 1)
                                            {
                                                <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">@Localizer["planned"]</MudChip>
                                            }
                                            else if (_jobObservation.Type == 2)
                                            {
                                                <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">Eventual</MudChip>
                                            }
                                            else if (_jobObservation.Type == 3)
                                            {
                                                <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">@Localizer["sosReviewProgram"]</MudChip>
                                            }
                                            @switch (_jobObservation.Status)
                                            {
                                                case 1:
                                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Style="cursor:pointer">@Localizer["planned"]</MudChip>
                                                    break;
                                                case 2:
                                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                                    break;
                                                case 3:
                                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                                    break;
                                                case 4:
                                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                                    break;
                                                case 5:
                                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                                    break;
                                                case 6:
                                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                                    break;
                                            }
                                        </MudText>
                                    </TitleContent>
                                    <ChildContent>
                                        <MudSimpleTable Dense="@dense" Hover="@hover" ReadOnly="@ronly" Elevation="0"
