                                    </ActivatorContent>
                                    <ChildContent>
                                        <MudExpansionPanels Elevation="0">
                                            <MudCheckBox T="bool" @bind-Checked="@FilterOperation" Label="Filter By Operation" />

                                            @if (!FilterOperation)
                                            {

                                                @foreach (SOSCodePath item in _assychart.RoutesProductsAssyChart)
