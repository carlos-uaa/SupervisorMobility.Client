                                                    </MudTooltip>
                                                    }
                                                    else
                                                    {
                                                    <span style="font-weight: bold"> SSV</span>
                                                    }
                                            </MudText>
                                        </th>
                                        <tr>
                                            <td>
                                                <MudTextField T="string" @bind-Value="_jobObservation.OperatorCommentary" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="4" ReadOnly />
                                            </td>
                                            <td>
                                                    @if (_jobObservation.SsvSignature == "Signed")
                                                    {
                                                    <MudChip Class="mr-10" Icon="@Icons.Material.Filled.PlaylistAddCheck" Color="Color.Info" Variant="Variant.Text">
                                                            @Localizer["signed"]
                                                    </MudChip>
                                                    }
                                                    else
                                                    {
                                                    <MudChip Class="mr-10" Icon="@Icons.Material.Filled.AssignmentLate" Color="Color.Warning" Variant="Variant.Text">
                                                            @Localizer["unsignedOnlySSVCanSignIt"]
                                                    </MudChip>
                                                    }
                                                <MudText Style="text-align:center; font-weight:bold;">
                                                        @Localizer["operatorPayroll"]
                                                </MudText>
                                                <MudTextField T="string" @bind-Value="_jobObservation.OperatorSignature" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly />
                                            </td>
                                        </tr>
                                            @if (_jobObservation.Status == 6 && _jobObservation.ReleasedFeedback != "" && _jobObservation.ReleasedFeedback != null)
                                            {
                                            <tr>
                                                <th colspan="2">
                                                    <MudText Style="text-align:center; font-weight:bold;">
                                                            @Localizer["addFeedback"]
                                                    </MudText>
                                                </th>
                                            </tr>
                                            <tr>
                                                <td colspan="2">
                                                    <MudTextField T="string" @bind-Value="_jobObservation.ReleasedFeedback" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                                                </td>
                                            </tr>

                                            }
                                        </tbody>
                                    </MudSimpleTable>
                                </MudExpansionPanel>
                                break;
                        }
                    }
                }
            </MudExpansionPanels>
        }
        @if (currentImage != "")
        {

            <MudItem Style="text-align:center; display: flex; justify-content: center;">
                <div class="container drawing-container pa-8">
                    <div class="row justify-content-center">
                        <div class="col-md-12 text-center">
                            <h3>@Localizer["operatorsSignature"]</h3>
                            <img src="@currentImage" style="display:block" class="canvas-container" />
                        </div>
                    </div>
                </div>
            </MudItem>
        }
    </MudItem>
</MudGrid>
<MudDialog @bind-IsVisible="CodePathModalDisplay" Options="dialogOptions" Style="    max-height: 95vh;    min-height: 80vh;">
    <DialogContent>
        <SupervisorMobility.Client.Pages.Components.TreeView Path_Id="SOSCodePathId" panel="panelSelect"></SupervisorMobility.Client.Pages.Components.TreeView>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseModalFiles" Variant="Variant.Filled">@Localizer["Close"]</MudButton>
    </DialogActions>
