                                @for (int i = 1; i <= 5; i++)
                                {
                                    var totalCycleTime = _filteredOperations.Sum(op => OperationTimes.ContainsKey(op.OperationId) && OperationTimes[op.OperationId].ContainsKey(i)
                                        ? OperationTimes[op.OperationId][i]
                                        : 0.0);

                                    <td>
                                        <MudText Typo="Typo.body1">@Math.Round(totalCycleTime, 2)</MudText>
                                    </td>
                                }
