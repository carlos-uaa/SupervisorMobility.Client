@page "/jobobservation"

@using System.Net.Http.Json
@using MudBlazor

@inject NavigationManager NavigationManager
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IJSRuntime JSRuntime
@inject IJobStructureService JobStructureCategoriesService
@inject IAssyChartService AssyChartServices
@inject ISnackbar Snackbar
@inject IJobObservationService JobObservationService
@inject IDistributionService DistributionService
@inject IOperationService OperationService
@inject IDialogService DialogService
@inject IUserService UsersService
@inject IStringLocalizer<Resource> Localizer

@if (logged == true)
{
    @*Title*@
    <PageTitle>Supervisor Mobility | @Localizer["jobObservations"]</PageTitle>
    <MudItem Class="d-flex justify-content-between" Style="align-items: center;">
        <MudText Typo="Typo.h6">@Localizer["jobObservations"]</MudText>
        <MudItem Style="justify-content: end" Class="ml-auto">
            <MudItem Class="d-flex">
                @if (user.UserType == 1 || user.UserType == 6)
                {

                    @*Mud select of Plants for Admin*@
                    <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text" Class="mb-3 mr-8" AnchorOrigin="Origin.BottomCenter" @bind-Value="@plantId" For="@(() => plantId)" SelectedValuesChanged="ShowAreas" Style="width: 15vw;">
                        <MudSelectItem Value="0">@Localizer["allPlants"]</MudSelectItem>
                        @foreach (var type in _plants)
                        {
                            <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>
                    @if (plantId != 0)
                    {
                        @*Mud select of Areas for Admin*@
                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mb-3 mr-8" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowJobObs" Style="width: 15vw;">
                            <MudSelectItem Value="0">@Localizer["allAreas"]</MudSelectItem>
                            @foreach (var type in _areas)
                            {
                                <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        @*Mud select for SSV *@
                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Disabled Class="mb-3 mr-8" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" Style="width: 15vw;">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAPlant"]</MudSelectItem>
                        </MudSelect>
                    }
                }
                else if (user.UserType == 2)
                {
                    @*Mud select of Areas for Admin*@
                    <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mb-3 mr-8" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowJobObs" Style="width: 15vw;">
                        <MudSelectItem Value="0">@Localizer["allAreas"]</MudSelectItem>
                        @foreach (var type in _areas)
                        {
                            <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>
                }
                else if (user.UserType == 5)
                {
                    @*Mud select of Areas for Admin*@
                    <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mb-3 mr-8" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" For="@(() => areaId)" SelectedValuesChanged="ShowJobObs" Style="width: 15vw;">
                        <MudSelectItem Value="0">@Localizer["allAreas"]</MudSelectItem>
                        @foreach (var type in _areas)
                        {
                            <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>
                }
                <MudButton Href="/jobobservationschedule" StartIcon="@Icons.Material.Filled.CalendarMonth" Color="Color.Info" Class="mr-8">@Localizer["calendar"]</MudButton>
                @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                {
                    <MudButton @onclick="(() => PlanJobObservation())" StartIcon="@Icons.Material.Filled.EditCalendar" Class="mr-8">@Localizer["plan"]</MudButton>
                    @*<MudButton @onclick="(() => CreateJobObservation())" StartIcon="@Icons.Material.Filled.Add">@Localizer["create"]</MudButton>*@
                    <MudButton @onclick="(() => CreateNewJobObservation())" StartIcon="@Icons.Material.Filled.Add">@Localizer["create"]</MudButton>
                }
            </MudItem>
        </MudItem>
    </MudItem>
    <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
        <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text=@totalJobObservations>
            <MudTable Items="_jobObservations.Where(j => j.Status != 7 )" T="JobObservation" Dense="@dense" Hover="@hover" ReadOnly="@ronly" Filter="new Func<JobObservation,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true Height="55vh"  OnRowClick="(args) => RowClickEvent(args, 0)"  RowClassFunc="(element, rowNumber) => SelectedRowClassFunc(element, rowNumber, 0)" @ref="SelectTableEvent"
                HorizontalScrollbar="true" >
                <ToolBarContent>
                    @if (plantId == new int())
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="my-2" Style="text-align:center;"> @Localizer["firstSelectAPlant"]</MudAlert>
                        <MudSpacer />
                        <MudTextField @bind-Value="searchString" Clearable Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5"></MudTextField>
                        <MudSpacer />
                    }
                    else if (_jobObservations.Where(j => j.Status != 7).ToList().Count == 0 && !filters)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="my-2" Style="text-align:center;">@Localizer["thisPlantDoesNotHaveJobObservatoins"]</MudAlert>
                    }
                    else
                    {
                        <MudTooltip Text=@Localizer["showHideFilters"] Arrow="true" Placement="Placement.Right" Color="Color.Info">
                            <MudIconButton Icon="@Icons.Material.Filled.FilterAlt" Color="@color" @onclick="(() => ActiveFilters())" Class="mr-0"></MudIconButton>
                        </MudTooltip>
                        @if (filters == false)
                        {
                            <MudSpacer />
                            <MudTextField @bind-Value="searchString" Clearable Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5"></MudTextField>
                        }
                        <MudSpacer />
                        @if (filters == true)
                        {
                            <MudTextField @bind-Value="idFilter" Label="Id" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 5vw" Class="pt-2" TextChanged="Filters"></MudTextField>
                            <MudSelect Clearable T="int" Label=@Localizer["distribution"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@distributionId" SelectedValuesChanged="FilterDistributions">
                                <MudSelectItem Disabled="true" Value="0">@Localizer["notSelected"]</MudSelectItem>
                                @foreach (var type in _distributions)
                                {
                                    var statusCount = _jobObservations.Where(j => j.DistributionId == type.DistributionId && j.Status != 7).ToList().Count;
                                    var isDisabled = statusCount == 0;

                                    <MudSelectItem  Value="type.DistributionId" Disabled="@isDisabled">
                                        <MudChip Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Style="margin: 0px">@statusCount</MudChip>
                                        @($"{type.Description}")
                                    </MudSelectItem>

                                }
                            </MudSelect>
                            <MudSpacer />
                            @if (!operationFlag)
                            {
                                <MudTooltip Text=@Localizer["selectADistributionFirst"] Arrow="true" Placement="Placement.Right" Color="Color.Error">
                                    <MudSelect T="int" Label=@Localizer["operation"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@operationId" Disabled>
                                    <MudSelectItem Disabled="true" Value="0">@Localizer["notSelected"]</MudSelectItem>
                                </MudSelect>
                            </MudTooltip>
                            }
                            else
                            {
                                <MudSelect Clearable T="int" Label=@Localizer["operation"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@operationId" SelectedValuesChanged="Filters">
                                    <MudSelectItem Disabled="true" Value="0" @onclick="(() => ShowError())">@Localizer["notSelected"]</MudSelectItem>
                                    @foreach (var type in _operations)
                                    {

                                        var statusCount = _jobObservations.Where(j => j.OperationId == type.OperationId && j.Status != 7).ToList().Count;
                                        var isDisabled = statusCount == 0;

                                        <MudSelectItem Value="type.OperationId" Disabled="@isDisabled">
                                            <MudChip Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Style="margin: 0px">@statusCount</MudChip>
                                            @($"{type.Description}")
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            <MudSpacer />
                            <MudDatePicker Placeholder=@Localizer["dd/mm/yyyy"] @bind-Date="@filterDate" Label=@Localizer["date"] Color="Color.Info" AdornmentColor="Color.Info" Style="max-width: 12vw" Variant="Variant.Outlined" Margin="Margin.Dense" Class="pt-2" PickerClosed="Filters" />
                            @*Mud select for Operator *@
                            <MudSelect Clearable T="int" Label=@Localizer["operator"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@operatorId" SelectedValuesChanged="Filters">
                                <MudSelectItem Disabled="true" Value="0">@Localizer["notSelected"]</MudSelectItem>
                                @foreach (var type in operatorUsers)
                                {

                                    var statusCount = _jobObservations.Where(j => j.OperatorId == type.UserId && j.Status != 7).ToList().Count;
                                    var isDisabled = statusCount == 0;

                                    <MudSelectItem Value="type.UserId"  Disabled="@isDisabled">
                                        <MudChip Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Style="margin: 0px">@statusCount</MudChip>
                                        @($"{type.Name}")
                                    </MudSelectItem>
                                }
                            </MudSelect>
                            <MudSpacer />
                            @*Mud select of Status *@
                            <MudSelect Clearable T="int" Label=@Localizer["status"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@statusId" SelectedValuesChanged="Filters">
                                <MudSelectItem Value="0" Disabled>@Localizer["notSelected"]</MudSelectItem>

                                @foreach (var status in new[] { 1, 2, 3, 4, 5, 6 })
                                {
                                    var statusCount = _jobObservations.Where(j => j.Status == status).ToList().Count;
                                    var isDisabled = statusCount == 0;

                                    <MudSelectItem Value="@status" Disabled="@isDisabled">
                                        <MudChip Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Style="margin: 0px">@statusCount</MudChip>
                                        @Localizer[GetStatusLabel(status)]
                                    </MudSelectItem>
                                }
                        </MudSelect>
                            <MudSpacer />
                            <MudTooltip Text=@Localizer["clearFilters"] Arrow="true" Placement="Placement.Left" Color="Color.Error">
                                <MudIconButton Icon="@Icons.Material.Filled.Clear" Color="Color.Error" @onclick="(() => ClearFilters())" Class="mr-0"></MudIconButton>
                            </MudTooltip>
                        }
                    }
                </ToolBarContent>
                <ColGroup>
                    <col style="width: 60px;" />
                    <col />
                    <col />
                    <col />
                    <col />
                    <col />
                </ColGroup>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.JobObservationId)">Id</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Distribution?.Description)" InitialDirection="SortDirection.Ascending">@Localizer["distribution"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operation?.Description)">@Localizer["operation"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.StartDate)">@Localizer["startDate"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operator?.Name)">@Localizer["operator"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Status)">@Localizer["status"]</MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: center">@Localizer["actions"]</MudTh>
                </HeaderContent>
              
                <RowTemplate>
                    <MudTd DataLabel="Id"  >
                        <MudText Align="Align.Center">@context.JobObservationId</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["distribution"]  >
                        <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["operation"]  >
                        <MudText Align="Align.Center">@context.Operation?.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["startDate"]  >
                        <MudText Align="Align.Center">@context.StartDate?.ToShortDateString()</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["operator"]  >
                        <MudText Align="Align.Center">@context.Operator?.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["status"]  >
                        <MudText Align="Align.Center">
                            @switch (context.Status)
                            {
                                case 1:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">@Localizer["planned"]</MudChip>
                                    break;
                                case 2:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Size="Size.Small" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                    break;
                                case 3:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                    break;
                                case 4:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Size="Size.Small" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                    break;
                                case 5:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                    break;
                                case 6:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                    break;
                            }
                        </MudText>
                    </MudTd>
                    <MudTd  >
                        <MudText Align="Align.Center">
                            <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                <ActivatorContent>
                                    <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                </ActivatorContent>
                                <ChildContent>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() =>  OpenDialog2(context.JobObservationId))" OnTouch="(() =>  OpenDialog2(context.JobObservationId))">@Localizer["jobObservationDetails"]</MudMenuItem>
                                    @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                    {
                                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(()=>EditJobObservation(context.JobObservationId))" OnTouch="(()=>EditJobObservation(context.JobObservationId))">@Localizer["editJobObservations"]</MudMenuItem>
                                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() =>OpenDeleteDialog(context.JobObservationId))" OnTouch="(() => OpenDeleteDialog(context.JobObservationId))">@Localizer["deleteJobObservation"]</MudMenuItem>
                                    }
                                </ChildContent>
                            </MudMenu>

                            @*
                        <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => OpenDialog2(context.JobObservationId))"></MudIconButton>
                        <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => EditJobObservation(context.JobObservationId))"></MudIconButton>
                        <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => OpenDeleteDialog(context.JobObservationId))"></MudIconButton>
                        *@
                        </MudText>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudTabPanel>
