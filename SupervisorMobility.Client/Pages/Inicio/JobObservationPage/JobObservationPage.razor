                </ColGroup>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.JobObservationId)">Id</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Distribution?.Description)" InitialDirection="SortDirection.Ascending">@Localizer["distribution"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operation?.Description)">@Localizer["operation"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.StartDate)">@Localizer["startDate"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operator?.Name)">@Localizer["operator"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Status)">@Localizer["status"]</MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: center">@Localizer["actions"]</MudTh>
                </HeaderContent>
                <GroupHeaderTemplate>
                </GroupHeaderTemplate>
                <RowTemplate>
                    <MudTd DataLabel="Id">
                        <MudText Align="Align.Center">@context.JobObservationId</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["distribution"]>
                        <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["operation"]>
                        <MudText Align="Align.Center">@context.Operation?.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["startDate"]>
                        <MudText Align="Align.Center">@context.StartDate?.ToShortDateString()</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["operator"]>
                        <MudText Align="Align.Center">@context.Operator?.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel=@Localizer["status"]>
                        <MudText Align="Align.Center">
                            @switch (context.Status)
                            {
                                case 1:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">@Localizer["planned"]</MudChip>
                                    break;
                                case 2:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Size="Size.Small" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                    break;
                                case 3:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                    break;
                                case 4:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Size="Size.Small" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                    break;
                                case 5:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                    break;
                                case 6:
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                    break;
                            }
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Align="Align.Center">
                            <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                <ActivatorContent>
                                    <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                </ActivatorContent>
                                <ChildContent>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() =>  OpenDialog2(context.JobObservationId))" OnTouch="(() =>  OpenDialog2(context.JobObservationId))">@Localizer["jobObservationDetails"]</MudMenuItem>
                                    @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                    {
                                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(()=>EditJobObservation(context.JobObservationId))" OnTouch="(()=>EditJobObservation(context.JobObservationId))">@Localizer["editJobObservations"]</MudMenuItem>
                                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() =>OpenDeleteDialog(context.JobObservationId))" OnTouch="(() => OpenDeleteDialog(context.JobObservationId))">@Localizer["deleteJobObservation"]</MudMenuItem>
                                    }
                                </ChildContent>
                            </MudMenu>

                            @*
                        <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => OpenDialog2(context.JobObservationId))"></MudIconButton>
                        <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => EditJobObservation(context.JobObservationId))"></MudIconButton>
                        <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => OpenDeleteDialog(context.JobObservationId))"></MudIconButton>
                        *@
                        </MudText>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudTabPanel>

    </MudTabs>
    @*Delete observation modal*@
    <MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
        <DialogContent>
            <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
            <MudText Class="mt-4 mb-4">
                <span style="color: #2196f3; text-align:justify">@user.Name</span>,
                @Localizer["areYouSureYouWantToDeleteThisJobObservation"]
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
            <MudButton @onclick="(() => DeleteJobObservation(deleteJobObservationId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">@Localizer["delete"]</MudButton>
        </DialogActions>
    </MudDialog>


    <MudDialog DisableSidePadding="false" @bind-IsVisible="visible" Options="dialogOptions">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">
                <SupervisorMobility.Client.Pages.Inicio.JobObservationPage.JobObservationDetails JobObservationId="jobId"></SupervisorMobility.Client.Pages.Inicio.JobObservationPage.JobObservationDetails>
            </MudContainer>
        </DialogContent>
        <DialogActions>
            @if(_jobObservation != null){

            @if ((_jobObservation.Status == 1 || _jobObservation.Status == 3) && user.UserType != 4)
            {
                <MudButton StartIcon="@Icons.Material.Filled.DateRange" Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => OpenCommentDialog())">@Localizer["changeDate"]</MudButton>
            }
            @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
            {
                <MudButton  @onclick="(() => EditJobObservation(jobId))" Color="Color.Info" EndIcon="@Icons.Material.Filled.Edit">@Localizer["edit"]</MudButton>
            }
            }else{
            <MudProgressLinear Color="Color.Secondary" Indeterminate="true" Class="my-7" />
            }
            <MudButton Color="Color.Info" OnClick="Close">@Localizer["close"]</MudButton>
        </DialogActions>
    </MudDialog>
}