                                                            imageSrc = "Images/LTraineeLeader.png";
                                                            break;
                                                        case "L":
                                                            imageSrc = "Images/L.png";
                                                            break;
                                                        case "LLeader":
                                                            imageSrc = "Images/LLeader.png";
                                                            break;
                                                        case "UTrainee":
                                                            imageSrc = "Images/UTrainee.png";
                                                            break;
                                                        case "ULeaderTrainee":
                                                            imageSrc = "Images/ULeaderTrainee.png";
                                                            break;
                                                        case "ULeader":
                                                            imageSrc = "Images/ULeader.png";
                                                            break;
                                                        case "U":
                                                            imageSrc = "Images/U.png";
                                                            break;
                                                        default:
                                                            imageSrc = "Images/default.png";
                                                            break;
                                                    }

                                                }
                                                <div class="d-flex align-items-center">
                                                    <MudImage Src="@imageSrc" Alt="ILU Image" Height="30" Class="rounded-lg" Style="margin-top: -5px" />
                                                    <span class="ml-3">@type.ILULevelDescription</span>
                                                </div>
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </td>
                                <td>
                                    @*Mud select for Operator *@
                                    <MudSelect T="int" Label=@Localizer["operator"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperatorId" For="@(() => _jobObservation.OperatorId)">
                                        <MudSelectItem Value="_operator.UserId">@($"{_operator.Name}")</MudSelectItem>
                                    </MudSelect>
                                </td>
                            </tr>

                        </tbody>
                    </MudSimpleTable>
                </MudItem>
            </MudPaper>

            <MudCardActions>
                @if (LoggedUser.UserType == 1 || LoggedUser.UserType == 2 || LoggedUser.UserType == 3)
                {
                    <MudItem Class="ml-auto">
                        <MudButton StartIcon="@Icons.Material.Filled.DateRange" Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => PlanNewJobObservation())" Disabled="@(auxILU_Level == 0)">@Localizer["save"]</MudButton>
                    </MudItem>
                }
            </MudCardActions>
        </MudItem>
    </MudGrid>

}


<MudDialog @bind-IsVisible="CodePathModalDisplay" Options="dialogOptions" Style="    max-height: 95vh;    min-height: 80vh;">
    <DialogContent>
        <SupervisorMobility.Client.Pages.Components.TreeView Path_Id="SOSCodePathId" panel="panelSelect"></SupervisorMobility.Client.Pages.Components.TreeView>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseModalFiles" Variant="Variant.Filled">@Localizer["Close"]</MudButton>
    </DialogActions>
</MudDialog>