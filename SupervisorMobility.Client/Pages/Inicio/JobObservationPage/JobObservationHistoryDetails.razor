<MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
    <MudItem lg="10" md="12" sm="12" xs="12">
        <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
            <MudItem Class="d-flex justify-space-between pa-1 ma-1 mt-6">
                <MudItem Style="text-align: start">
                    @if (!searchAssychart && messageErrorFolders == null)
                    {
                        <MudItem Class="d-flex justify-center align-center">
                            <MudChip Color="Color.Info" Variant="Variant.Outlined">
                                <MudProgressCircular Color="Color.Info" Size="Size.Small" Indeterminate="true" Class="mr-3" />
                                Loading Assy Chart
                            </MudChip>
                        </MudItem>
                    }
                    @if (!searchAssychart && messageErrorFolders != null)
                    {
                        <MudItem class="d-flex flex-column justify-center align-self-start">
                            <MudAlert Severity="Severity.Info">@messageErrorFolders</MudAlert>
                        </MudItem>
                    }
                    @if (searchAssychart && messageErrorFolders == null)
                    {
                        <MudItem Class="d-flex flex-row align-start justify-center">

                            @if (_assychart.RoutesProductsAssyChart?.Count > 0)
                            {
                               <MudMenu Dense=true AnchorOrigin="Origin.BottomCenter" Style="display: flex" TransformOrigin="Origin.TopCenter">
                                    <ActivatorContent>
                                        <MudButton FullWidth="true" StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">Directorys</MudButton>
                                    </ActivatorContent>
                                    <ChildContent>
                                        <MudExpansionPanels Elevation="0">
                                        
                                                @foreach (SOSCodePath item in _assychart.RoutesProductsAssyChart)
                                                {

                                                    <MudExpansionPanel Style="width: auto;">
                                                        <TitleContent>
                                                            <div Style="align-items: center; display: flex;">
                                                                <MudText>@item.Code</MudText>
                                                                <MudChip Icon="@Icons.Material.Filled.DirectionsCar" IconColor="Color.Info" Variant="Variant.Text" Color="Color.Success">@item.Product?.Code - @item.Product?.Description</MudChip>
                                                            </div>
                                                        </TitleContent>
                                                        <ChildContent>
                                                            <MudItem class="d-flex flex-column justify-center ma-1">
                                                                <MudItem class="d-flex d-flex-column justify-center">

                                                                    <MudItem Style="flex-direction: column;">
                                                                        @if (item.HOE != "")
                                                                        {
                                                                            <MudPaper Elevation="0">
                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, HOE))" @ontouchstart="(() => OpenDialogCodePath(item,HOE))" Style="padding: 0px;" Color="Color.Error">
                                                                                    <MudTooltip Text=@Localizer["openHOEFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                        <MudTooltip Text="@Regex.Replace(item.HOE, @"/(.*?)§", "/").Replace('§', ' ')" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.HOE.Split('§').Last()</MudChip>
                                                                                        </MudTooltip>
                                                                                    </MudTooltip>
                                                                                </MudButton>
                                                                            </MudPaper>
                                                                        }
                                                                        else
                                                                        {
                                                                            <MudPaper Elevation="0">
                                                                                <MudAlert Severity="Severity.Info">@Localizer["noHOEPath"]</MudAlert>
                                                                            </MudPaper>
                                                                        }

                                                                        @if (item.CommonDirectionHOE != "")
                                                                        {
                                                                            <MudPaper Elevation="0">
                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, HOECD))" @ontouchstart="(() => OpenDialogCodePath(item, HOECD))" Style="padding: 0px;" Color="Color.Error">
                                                                                    <MudTooltip Text=@Localizer["openHOEFolderCD"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                        <MudTooltip Text="@Regex.Replace(item.CommonDirectionHOE, @"/(.*?)§", "/").Replace('§', ' ')" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CommonDirectionHOE.Split('§').Last()</MudChip>
                                                                                        </MudTooltip>
                                                                                    </MudTooltip>
                                                                                </MudButton>
                                                                            </MudPaper>
                                                                        }

                                                                    </MudItem>

                                                                    <MudItem Style="flex-direction: column;">
                                                                        @if (@item.CCP != "")
                                                                        {
                                                                            <MudPaper Elevation="0">
                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, CCP))" @ontouchstart="(() => OpenDialogCodePath(item, CCP))" Style="padding: 0px;" Color="Color.Error">
                                                                                    <MudTooltip Text=@Localizer["openCCPFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                        <MudTooltip Text="@item.CCP" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CCP.Split('/').Last()</MudChip>
                                                                                        </MudTooltip>
                                                                                    </MudTooltip>
                                                                                </MudButton>
                                                                            </MudPaper>
                                                                        }
                                                                        else
                                                                        {
                                                                            <MudPaper Elevation="0">
                                                                                <MudAlert Severity="Severity.Info">@Localizer["noCCPPath"]</MudAlert>
                                                                            </MudPaper>
                                                                        }
                                                                        @if (@item.CommonDirectionCCP != "")
                                                                        {
                                                                            <MudPaper Elevation="0">
                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, CCPCD))" @ontouchstart="(() => OpenDialogCodePath(item, CCPCD))" Style="padding: 0px;" Color="Color.Error">
                                                                                    <MudTooltip Text=@Localizer["openCCPFolderCD"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                        <MudTooltip Text="@item.CommonDirectionCCP" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CommonDirectionCCP.Split('/').Last()</MudChip>
                                                                                        </MudTooltip>
                                                                                    </MudTooltip>
                                                                                </MudButton>
                                                                            </MudPaper>
                                                                        }
                                                                    </MudItem>

                                                                    <MudItem Style="flex-direction: column;">
                                                                        @if (item.GOS != "")
                                                                        {
                                                                            <MudPaper Elevation="0">
                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, GOS))" @ontouchstart="(() => OpenDialogCodePath(item, GOS))" Style="padding: 0px;" Color="Color.Error">
                                                                                    <MudTooltip Text=@Localizer["openGOSFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                        <MudTooltip Text="@item.GOS" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.GOS.Split('/').Last()</MudChip>
                                                                                        </MudTooltip>
                                                                                    </MudTooltip>
                                                                                </MudButton>

                                                                            </MudPaper>
                                                                        }
                                                                        else
                                                                        {
                                                                            <MudPaper Elevation="0">

                                                                                <MudAlert Severity="Severity.Info">@Localizer["noGOSPath"]</MudAlert>
                                                                            </MudPaper>
                                                                        }
                                                                        @if (item.CommonDirectionGOS != "")
                                                                        {
                                                                            <MudPaper Elevation="0">
                                                                                <MudButton OnClick="(() => OpenDialogCodePath(item, GOSCD))" @ontouchstart="(() => OpenDialogCodePath(item, GOSCD))" Style="padding: 0px;" Color="Color.Error">
                                                                                    <MudTooltip Text=@Localizer["openGOSFolderCD"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false">
                                                                                        <MudTooltip Text="@item.CommonDirectionGOS" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CommonDirectionGOS.Split('/').Last()</MudChip>
                                                                                        </MudTooltip>
                                                                                    </MudTooltip>
                                                                                </MudButton>

                                                                            </MudPaper>
                                                                        }
                                                                    </MudItem>






                                                                </MudItem>
                                                            </MudItem>

                                                        </ChildContent>
                                                    </MudExpansionPanel>
                                                }
                                           






                                        </MudExpansionPanels>
                                    </ChildContent>
                                </MudMenu>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info">
                                    @Localizer1["ACNoProducts"]
                                </MudAlert>
                            }
                        </MudItem>
                    }

                </MudItem>
                <MudItem Style="text-align: end">
                    @switch (_jobObservationVersion.Status)
                    {
                        case 1:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Style="cursor:pointer">@Localizer["planned"]</MudChip>
                            break;
                        case 2:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                            break;
                        case 3:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Style="cursor:pointer">@Localizer["late"]</MudChip>
                            break;
                        case 4:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                            break;
                        case 5:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                            break;
                        case 6:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                            break;
                        case 7:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Style="cursor:pointer">@Localizer["programmed"]</MudChip>
                            break;
                    }
                </MudItem>
            </MudItem>
            <MudText Typo="Typo.h6">
                @Localizer["jobObservacionCiclycalCard"] @JobObservationId
                <MudChip Variant="Variant.Text" Color="Color.Info" Icon="@Icons.Material.Filled.History">History Version @JobObservationVersionId</MudChip>
                @if (_jobObservationVersion.Type == 1)
                {
                    <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">@Localizer["planned"]</MudChip>
                }
                else if (_jobObservationVersion.Type == 2)
                {
                    <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">Eventual</MudChip>
                }
            </MudText>
        </MudItem>
        <MudPaper Class="" Elevation="0">
            <MudItem Class="ml-2">
                <MudSimpleTable Dense="@dense" Hover="@hover" ReadOnly="@ronly"
                                HorizontalScrollbar="true">
                    <tbody>
                        <tr>
                            <td style="width:50%">
                                <div class="d-flex">
                                    @*Mud select of Plants*@
                                    <MudSelect T="int?" Label=@Localizer["plant"] Variant="Variant.Text" Class="mt-3  mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservationVersion.PlantId" ReadOnly>
                                        <MudSelectItem Disabled="true" Value="@_jobObservationVersion.PlantId">@_jobObservationVersion.Plant?.Code - @_jobObservationVersion.Plant?.Description</MudSelectItem>
                                    </MudSelect>
                                    @*Mud select of Areas *@
                                    <MudSelect T="int?" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservationVersion.AreaId" ReadOnly>
                                        <MudSelectItem Disabled="true" Value="@_jobObservationVersion.AreaId">@_jobObservationVersion.Area?.Code - @_jobObservationVersion.Area?.Description</MudSelectItem>
                                    </MudSelect>
                                </div>
                            </td>
                            <td class="d-flex mt-3">
                                <MudDatePicker @bind-Date="_jobObservationVersion.StartDate" Label=@Localizer["startDate"] Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4" ReadOnly/>
                                <MudDatePicker @bind-Date="_jobObservationVersion.EndDate" Label=@Localizer["endDate"] Color="Color.Info" AdornmentColor="Color.Info" MinDate="_jobObservationVersion.StartDate" ReadOnly />
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*Mud select of Distribution *@
                                <MudSelect T="int?" Label=@Localizer["distribution"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservationVersion.DistributionId" ReadOnly>
                                    <MudSelectItem Disabled="true" Value="@_jobObservationVersion.DistributionId">@_jobObservationVersion.Distribution?.Code - @_jobObservationVersion.Distribution?.Description</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td  class="d-flex mt-3">
                                <MudTextField T="string" @bind-Value="_jobObservationVersion.Supervisor.Name" Label=@Localizer["observer"] Class="mr-4" ReadOnly />
                                    <MudSelect T="int" Label="KPI" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@kpiID" ReadOnly>
                                        <MudSelectItem Disabled="true" Value="0">@Localizer["notSelected"]</MudSelectItem>
                                        <MudSelectItem Value="1">@($"S & E")</MudSelectItem>
                                        <MudSelectItem Value="2">@($"Q")</MudSelectItem>
                                        <MudSelectItem Value="3">@($"D")</MudSelectItem>
                                        <MudSelectItem Value="4">@($"C")</MudSelectItem>
                                        <MudSelectItem Value="5">@($"Other")</MudSelectItem>
                                </MudSelect>
                            </td>
                        </tr>
                        <tr class="mt-3">
                            <td>
                                @*Mud select of Operations *@
                                <MudSelect T="int?" Label=@Localizer["operation"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservationVersion.OperationId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservationVersion.OperationId">@_jobObservationVersion.Operation?.Code - @_jobObservationVersion.Operation?.Description</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td>
                                @if(_jobObservationVersion.Operator != null){
                                  <MudTextField T="string" @bind-Value="_jobObservationVersion.Operator.Name" Label=@Localizer["operator"] Class="mr-4" ReadOnly/>
                                }
                                else{
                                  <MudTextField T="string" Label=@Localizer["operator"] Class="mr-4" ReadOnly/>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" style="text-align: center;">
                                <MudRadioGroup @bind-SelectedOption="_jobObservationVersion.Option" >
                                    <MudRadio Option="1" Color="Color.Info" Size="Size.Small" Disabled>@Localizer["verifyTraining"]</MudRadio>
                                    <MudRadio Option="2" Color="Color.Info" Size="Size.Small" Disabled>@Localizer["mantainAndOrImproveTheWorkArea"]</MudRadio>
                                    <MudRadio Option="3" Color="Color.Info" Size="Size.Small" Disabled>
                                        @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("Management of the anomaly"))
                                        {
                                            Glosary word;
                                            word = _glosaryInfo["Management of the anomaly"];
                                            <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                                <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                    <MudText>@Localizer["managementOfTheAnomaly"]</MudText>
                                                </MudBadge>
                                            </MudTooltip>
                                        }
                                        else
                                        {
                                            <span>@Localizer["managementOfTheAnomaly"]</span>
                                        }
                                    </MudRadio>
                                    @if (_jobObservationVersion.Option == 3)
                                    {
                                        <MudTextField @bind-Value="_jobObservationVersion.Anomaly" T="string" Label=@Localizer["writeTheAnomaly"] Placeholder=@Localizer["anomaly"] Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    }
                                </MudRadioGroup>

                            </td>
                        </tr>
                        @if (_jobObservationVersion.Justification != "" && _jobObservationVersion.Justification != null)
                        {
                            <tr>
                                <td colspan="2">
                                    <MudText Style="text-align:center; font-weight:bold;">
                                        @Localizer["justificationToUpdate"]
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2">
                                    <MudTextField T="string" @bind-Value="_jobObservationVersion.Justification" ReadOnly Label=@Localizer["justification"] Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem Class="ml-2">
                <MudSimpleTable Dense=true Style="overflow-x: auto;" Bordered=true Class="mt-6 mb-3">
                    <tbody>
                        <tr>
                            <td colspan="1">
                                <MudTextField T="double" @bind-Value="taktTime" Label="Takt Time" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" ReadOnly />
                            </td>
                        </tr>
                        <tr>
                            <td colspan="5" style="text-align:center">
                                @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("HOE Time"))
                                {
                                    Glosary word;
                                    word = _glosaryInfo["HOE Time"];
                                    <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                        <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                            <MudText Style="text-align:center; font-weight:bold;">@Localizer["HOETime"]</MudText>
                                        </MudBadge>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <span style="text-align:center; font-weight:bold;">@Localizer["HOETime"]</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <MudTextField T="string" @bind-Value="HoeTimes[0]" Label=@Localizer["time1"] Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" ReadOnly/>
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="HoeTimes[1]" Label=@Localizer["time2"] Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" ReadOnly/>
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="HoeTimes[2]" Label=@Localizer["time3"] Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" ReadOnly/>
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="HoeTimes[3]" Label=@Localizer["time4"] Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" ReadOnly/>
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="HoeTimes[4]" Label=@Localizer["time5"] Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" ReadOnly/>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="5">
                                <MudText Style="text-align:center; font-weight:bold;">
                                    @Localizer["model"]
                                </MudText>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*Mud select of Products*@
                                <MudSelect T="int" Label=@Localizer["product1"] Variant="Variant.Text" Class="mt-3" AdornmentIcon="@Icons.Material.Filled.DirectionsCar" AdornmentColor="Color.Info" @bind-Value="@models[0]" ReadOnly>
                                    @if (models[0] == 0)
                                    {
                                        <MudSelectItem Disabled=true Value="0">@Localizer["notSelected"]</MudSelectItem>
                                    }
                                    else
                                    {
                                        @foreach (var type in _products)
                                        {
                                            if (models[0] == type.ProductId)
                                            {
                                                <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                            }
                                        }

                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label=@Localizer["product2"] Variant="Variant.Text" Class="mt-3"  AdornmentIcon="@Icons.Material.Filled.DirectionsCar" AdornmentColor="Color.Info"  @bind-Value="@models[1]" ReadOnly>
                                    @if (models[1] == 0)
                                    {
                                        <MudSelectItem Disabled=true Value="0">@Localizer["notSelected"]</MudSelectItem>
                                    }
                                    else
                                    {
                                        @foreach (var type in _products)
                                        {
                                            if (models[1] == type.ProductId)
                                            {
                                                <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                            }
                                        }

                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label=@Localizer["product3"] Variant="Variant.Text" Class="mt-3"  AdornmentIcon="@Icons.Material.Filled.DirectionsCar" AdornmentColor="Color.Info"  @bind-Value="@models[2]" ReadOnly>
                                    @if (models[2] == 0)
                                    {
                                        <MudSelectItem Disabled=true Value="0">@Localizer["notSelected"]</MudSelectItem>
                                    }
                                    else
                                    {
                                        @foreach (var type in _products)
                                        {
                                            if (models[2] == type.ProductId)
                                            {
                                                <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                            }
                                        }

                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label=@Localizer["product4"] Variant="Variant.Text" Class="mt-3"  AdornmentIcon="@Icons.Material.Filled.DirectionsCar" AdornmentColor="Color.Info"  @bind-Value="@models[3]" ReadOnly>
                                    @if (models[3] == 0)
                                    {
                                        <MudSelectItem Disabled=true Value="0">@Localizer["notSelected"]</MudSelectItem>
                                    }
                                    else
                                    {
                                        @foreach (var type in _products)
                                        {
