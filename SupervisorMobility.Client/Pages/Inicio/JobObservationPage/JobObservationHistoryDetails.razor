<style>

    .green {
        background: var(--mud-palette-success-hover);
        border: 1px solid var(--mud-palette-success);
        border-radius: 6px;
    }

    .yellow {
        background: var(--mud-palette-warning-hover);
        border: 1px solid var(--mud-palette-warning);
        border-radius: 6px;
    }

    .red {
        background: var(--mud-palette-error-hover);
        border: 1px solid var(--mud-palette-error);
        border-radius: 6px;
    }

</style>

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["jobObservationHistoryDetails"]</PageTitle>

@* Job Observation Form*@
@*@if (_jobObservation.IsActive == true)
{
    <MudText>
        <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
