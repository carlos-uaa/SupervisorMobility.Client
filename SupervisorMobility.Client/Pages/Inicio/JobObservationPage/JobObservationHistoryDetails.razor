    private async Task<AsyncVoidMethodBuilder> OpenDialogCodePath(SOSCodePath itemselected, int panelSelect)
    {

        showLoading = true;
        SOSCodePathId = itemselected.SOSCodePathId;
        switch (panelSelect)
        {
            case 1:
                SosPanelOpen = "HOE";
                break;

            case 2:
                SosPanelOpen = "CCP";
                break;

            case 3:
                SosPanelOpen = "GOS";
                break;

            case 4:
                SosPanelOpen = "HOE_CD";
                break;

            case 5:
                SosPanelOpen = "CCP_CD";
                break;

            case 6:
                SosPanelOpen = "GOS_CD";
                break;


        }

        CodePathModalDisplay = true;
        StateHasChanged();
        return new AsyncVoidMethodBuilder();
    }


