@code {
    [Parameter]
    public string title { get; set; } = "";
    [Parameter]
    public Dictionary<string, Glosary> _glosaryInfo { get; set; }
    [Parameter]
    public int auxErgonomicsLevel { get; set; }
    [Parameter]
    public List<string> area_ListS { get; set; } = new List<string>();
    [Parameter]
    public List<string> area_ListQ { get; set; } = new List<string>();
    [Parameter]
    public List<string> area_ListD { get; set; } = new List<string>();
    [Parameter]
    public List<string> area_ListC { get; set; } = new List<string>();
    [Parameter]
    public List<string> area_ListOther { get; set; } = new List<string>();
    [Parameter]
    public List<Lup> _tempLup { get; set; } = new();

    [Parameter]
    public EventCallback<(int, int)> RemoveFromList { get; set; }
    [Parameter]
    public EventCallback<int> UpdateAreaLists { get; set; }
    [Parameter]
    public EventCallback<int> AddTempLup { get; set; }
    [Parameter]
    public EventCallback<Lup> DeleteLup { get; set; }

    private async void OpenGuideDialog(int pillarID)
    {
        var parameters = new DialogParameters
            {
                { "selectedPillar", pillarID }
            };
        var dialog = await DialogService.ShowAsync<Guide_Dialog>("", parameters, dialogGuideOptions);
        await dialog.Result;

    }
    private DialogOptions dialogGuideOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true, Position = DialogPosition.TopCenter };

    void Closed(MudChip chip)
    {
        // react to chip closed
    }
}
