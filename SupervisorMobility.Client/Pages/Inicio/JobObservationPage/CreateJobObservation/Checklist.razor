@using System.Text.RegularExpressions
@using SupervisorMobility.Client.Data.Entities.QuestionHelperEntities
@inject IStringLocalizer<Resource> Localizer

<MudExpansionPanel IsInitiallyExpanded=true Style="min-width: 100%">
    <TitleContent>
        @title
        <MudText Typo="Typo.h6" Style="text-align: center;">
            @category.Description
        </MudText>
    </TitleContent>
    <ChildContent>
        <MudSimpleTable Style="overflow-x: auto;" Dense=true Bordered=true Class="mb-3" Elevation="0">
            <thead>
                <tr>
                    <th>
                        <MudText Style="font-weight:bold;">
                            @Localizer["Questions"]
                        </MudText>
                    </th>
                    <th>
                        <MudText Style="text-align:center; font-weight:bold;">
                            @Localizer["Answers"]
                        </MudText>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var question in category.ChecklistQuestions)
                {
                    int secNum = section;
                    string pattern = @"\\n"; string replacement = "<br />";
                    ChecklistAnswer answer = questionAnswers[question.QuestionID];
                    <tr>
                        <td width="70%">
                            <MudText Align="Align.Justify"><b>@(section)-@question.CategorySequence.</b>  @((MarkupString)(currentLanguage == "es-ES" ? Regex.Replace(question.Prompt, pattern, replacement) : Regex.Replace(question.PromptEN, pattern, replacement))) </MudText>
                        </td>
                    @if (question.Type != null)
                    {
                        <td width="25%">
                            @switch (question.Type.Code)
                            {
                                case "TF":
                                    <MudItem style="align-content: end; display: flex; justify-content: center;">
                                        <MudRadioGroup T="string" Value="answer.Answer" ValueChanged="(an)=>{AnswerChangeOption.InvokeAsync((an, question.QuestionID, secNum, category.JobCategoryStructureId)); CheckQuestions();}">
                                            <MudRadio Option="question.Options[0]" Color="Color.Success" UnCheckedColor="Color.Info" Dense="true" @onchange="@(() => {questionAnswers[question.QuestionID].Show = true; RemoveLupOpportunity.InvokeAsync((questionAnswers[question.QuestionID], secNum, question));})">@question.Options[0]</MudRadio>
                                            <MudRadio Option="question.Options[1]" Color="Color.Error" UnCheckedColor="Color.Info" Dense="true" @onchange="(() => AddLupOpportunity.InvokeAsync((questionAnswers[question.QuestionID], secNum, question)))">@question.Options[1]</MudRadio>
                                            <MudRadio Option="question.Options[2]" Color="Color.Info" UnCheckedColor="Color.Info" Dense="true" @onchange="@(() => {questionAnswers[question.QuestionID].Show = true; RemoveLupOpportunity.InvokeAsync((questionAnswers[question.QuestionID], secNum, question));})">@question.Options[2]</MudRadio>
                                        </MudRadioGroup>
                                    </MudItem>
                                break;
                                case "MC":
                                    <MudItem style="align-content: end; display: flex; justify-content: center;">
                                        <MudSelect T="string" Label="" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="answer.Answer" SelectedValuesChanged="(an)=>{AnswerChangeOption.InvokeAsync((an.First(), question.QuestionID, secNum, category.JobCategoryStructureId)); CheckQuestions();}">
                                            <MudSelectItem Disabled="true" Value="string.Empty">Select Answer</MudSelectItem>
                                            @foreach(var opt in question.Options)
                                            {
                                                @if (!question.DisabledOptions.Contains(opt))
                                                {
                                                    <MudSelectItem Value="@opt">@opt</MudSelectItem>
                                                }
                                            }
                                        </MudSelect>
                                    </MudItem>
                                break;
                                default:
                                    <MudItem>
                                        <MudTextField Class="ml-4" T="string" Style="max-width:70px" Value="answer.Answer" ValueChanged="(an)=>{AnswerChangeOption.InvokeAsync((an, question.QuestionID, secNum, category.JobCategoryStructureId)); CheckQuestions();}" />
                                    </MudItem>
                                break;
                            }
                        </td>
                        @if(question.Type.Code == "TF")
                        {
                            <td>
                                <MudButton Style=" display: -webkit-box;" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small" EndIcon="@(question.show ? @Icons.Material.Filled.KeyboardArrowUp : @Icons.Material.Filled.KeyboardArrowDown)" OnClick="@(() => questionAnswers[question.QuestionID].Show = !questionAnswers[question.QuestionID].Show)"></MudButton>
                            </td>
                        }
                    }
                    </tr>
                    @if (answer.Show)
                    {
                        <tr>
                            <td colspan="3">
                                <MudItem Style="display:flex; justify-content: space-around; flex-wrap: nowrap;">
                                    <MudItem Style="width: 60%; display: flex; justify-content: center; flex-direction: column">

                                        @if (_jobObservation.Status != 6)
                                        {

                                            <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;">

                                                @if (answer.capturedImages.Count() + answer.capturedImagesFiles?.Count() + answer.Evidences?.Count() < 5)
                                                {
                                                    <InputFile id="@(question.QuestionID.ToString())" OnChange="@( (e) => UploadFiles.InvokeAsync((e, answer)))" hidden single accept=".jpg, .jpeg, .gif, .svg, .png"></InputFile>
                                                    <MudButton Class="flex-initial d-flex flex-grow-0 px-9 py-2"
                                                               HtmlTag="label"
                                                               Variant="Variant.Filled"
                                                               Color="Color.Primary"
                                                               StartIcon="@Icons.Material.Filled.Image"
                                                               for="@(question.QuestionID.ToString())">
                                                        Load picture
                                                    </MudButton>
                                                }

                                                @if (answer.capturedImages.Count() + answer.capturedImagesFiles?.Count() + answer.Evidences?.Count < 5)
                                                {
                                                    <MudTooltip Text="Take photo" Color="Color.Info" Placement="Placement.Right" Arrow="true">
                                                        <MudIconButton @onclick="(() => OpenCameraAnswerDialog.InvokeAsync(answer))" OnTouch="(() => OpenCameraAnswerDialog.InvokeAsync(answer))" Color="Color.Info" Size="Size.Small" Icon="@Icons.Material.Filled.AddAPhoto"></MudIconButton>
                                                    </MudTooltip>
                                                }

                                            </MudItem>
                                        }
                                        <MudItem Class="d-flex" Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;">

                                            <MudItem Class="d-flex" Style="flex-direction: row; flex-wrap: wrap; justify-content: flex-start;">

                                                @foreach (var (file, index) in answer.MediaUris.Select((file, index) => (file, index)))
                                                {
                                                    <MudItem Class=" mr-8 mb-4">
                                                        <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                                                            <MudTooltip Text="Delete photo" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                                                <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="() => RemoveImageFileAnswer.InvokeAsync((answer, index))" OnTouch="() => RemoveImageFileAnswer.InvokeAsync((answer, index))"></MudIcon>
                                                            </MudTooltip>
                                                        </MudItem>
                                                        <MudListItem Icon="@Icons.Material.Filled.PictureInPicture" @key="@file">
                                                            <MudImage ObjectFit="ObjectFit.Cover" Height="180" Width="320" Src="@file" Elevation="25" Class="rounded-lg" />
                                                        </MudListItem>
                                                    </MudItem>
                                                }
                                            </MudItem>
                                            <MudItem Class="d-flex" Style="flex-direction: row; flex-wrap: wrap; justify-content: flex-start;">

                                                @foreach (var (image, index) in answer.capturedImages.Select((image, index) => (image, index)))
                                                {
                                                    <MudItem Class=" mr-8 mb-4">
                                                        <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                                                            <MudTooltip Text="Delete photo" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                                                <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="() => RemoveImageAnswer.InvokeAsync((answer, index))" OnTouch="() => RemoveImageAnswer.InvokeAsync((answer, index))"></MudIcon>
                                                            </MudTooltip>
                                                        </MudItem>
                                                        <MudListItem Icon="@Icons.Material.Filled.Camera" @key="@image">
                                                            <MudImage ObjectFit="ObjectFit.Cover" Height="180" Width="320" Src=@image Alt="Evidence" Elevation="25" Class="rounded-lg" />
                                                        </MudListItem>
                                                    </MudItem>
                                                }
                                            </MudItem>
                                        </MudItem>
                                    </MudItem>
                                    @{
                                        bool isDisabled = string.IsNullOrEmpty(answer.CommentarySV) || (section == 1 && (question.CategorySequence == 4 || question.CategorySequence == 5)?answer.Answer != "YES" :answer.Answer != "NG");
                                        string answerCommentarySV = answer.CommentarySV ?? "";
                                    }
                                    <MudItem Style="display:flex; flex-direction: column;  width: 30%" Class="ma-5">
                                        <MudTextField Disabled="@(user.UserType > 3)" T="string" Label="Comment" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="@answer.CommentarySV" Lines="3" TextChanged="()=>AnswerComentaryUpdate.InvokeAsync()" />
                                        <MudButton Class="my-2"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   EndIcon="@Icons.Material.Filled.Send"
                                                   Disabled="@isDisabled"
                                                   @onclick="(() => UpdateListEntry.InvokeAsync((question, secNum, answerCommentarySV)))">
                                            Enviar al Lup
                                        </MudButton>
                                        <MudTextField Disabled="@(user.UserType > 2)" T="string" Label="Senior Supervisor Comment" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="@answer.CommentarySSV" Lines="3" TextChanged="()=>AnswerComentaryUpdate.InvokeAsync()"/>
                                    </MudItem>
                                </MudItem>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    </ChildContent>
</MudExpansionPanel>

@code {
    [Parameter]
    public string title { get; set; } = "";

    [Parameter]
    public JobCategoryStructure category { get; set; }

    [Parameter]
    public int section { get; set; }

    [Parameter]
    public Dictionary<int, ChecklistAnswer> questionAnswers { get; set; }
    [Parameter]
    public string currentLanguage { get; set; }
    [Parameter]
    public User user { get; set; } = new();
    [Parameter]
    public JobObservation _jobObservation { get; set; } = new();

    [Parameter]
    public int kpiID { get; set; }
    [Parameter]
    public CategoryData Data { get; set; } = new();

    [Parameter]
    public EventCallback<(string, int, int, int)> AnswerChangeOption { get; set; }
    [Parameter]
    public EventCallback<(ChecklistAnswer, int, ChecklistQuestion)> AddLupOpportunity { get; set; }
    [Parameter]
    public EventCallback<(ChecklistAnswer, int, ChecklistQuestion)> RemoveLupOpportunity { get; set; }
    [Parameter]
    public EventCallback<(int, ChecklistQuestion, string)> AddDisabledOptions { get; set; }
    [Parameter]
    public EventCallback<(int, ChecklistQuestion, string)> RemoveDisabledOptions { get; set; }
    [Parameter]
    public EventCallback<(int, ChecklistQuestion, bool)> DisableEnableQuestion { get; set; }
    [Parameter]
    public EventCallback<(InputFileChangeEventArgs, ChecklistAnswer)> UploadFiles { get; set; }
    [Parameter]
    public EventCallback<ChecklistAnswer> OpenCameraAnswerDialog { get; set; }
    [Parameter]
    public EventCallback<(ChecklistAnswer, int)> RemoveImageFileAnswer { get; set; }
    [Parameter]
    public EventCallback<(ChecklistAnswer, int)> RemoveImageAnswer { get; set; }
    [Parameter]
    public EventCallback AnswerComentaryUpdate { get; set; }
    [Parameter]
    public EventCallback<(int,int)> OnKPIChange { get; set; }
    [Parameter]
    public EventCallback<(ChecklistQuestion, int, string)> UpdateListEntry { get; set; }

    private void CheckQuestions()
    {
        if (Data.QuestionsInCategory.Any())
        {
            foreach (var Qst in category.ChecklistQuestions)
            {
                if (Data.QuestionsInCategory.ContainsKey(Qst.QuestionID))
                {
                    var actions = Data.QuestionsInCategory[Qst.QuestionID];

                    foreach (var action in actions.QuestionContent)
                    {
                        Console.WriteLine("Hello");
                        bool executeFlag = false;
                        foreach (var questions in action.Value.Questions)
                        {
                            switch (questions.Value.Comparator)
                            {
                                case "!":
                                    executeFlag = questionAnswers[questions.Value.QuestionId].Answer != questions.Value.QstOption;
                                    break;

                                case "=":
                                    executeFlag = questionAnswers[questions.Value.QuestionId].Answer == questions.Value.QstOption;
                                    break;
                            }
                            if (executeFlag == false) goto escapeWhenFalse;
                        }
                        foreach (var methods in action.Value.Actions)
                        {

                            switch (methods.Value.Operation)
                            {
                                case "SET":
                                    questionAnswers[Qst.QuestionID].Answer = methods.Value.Value;
                                    AnswerChangeOption.InvokeAsync((methods.Value.Value, Qst.QuestionID, section, category.JobCategoryStructureId));
                                    break;

                                case "DISABLE":
                                    DisableEnableQuestion.InvokeAsync((category.JobCategoryStructureId, Qst, true));
                                    Qst.Disable = true;
                                    break;
                                case "DBLOPT":
                                    int index = Qst.Options.FindIndex(opt => opt == methods.Value.Operation);
                                    if (index >= 0 && !Qst.DisabledOptions.Any(p => p == methods.Value.Value))
                                    {
                                        AddDisabledOptions.InvokeAsync((category.JobCategoryStructureId, Qst, methods.Value.Value));
                                        Qst.DisabledOptions.Add(methods.Value.Value);
                                    }
                                    break;
                            }
                        }
                    escapeWhenFalse:;
                        if(!executeFlag)
                        {
                            foreach(var DisMeth in action.Value.Actions.Values.Where(p=>p.Operation == "DBLOPT"))
                            {
                                RemoveDisabledOptions.InvokeAsync((category.JobCategoryStructureId, Qst, DisMeth.Value));
                                Qst.DisabledOptions.Remove(DisMeth.Value);
                            }
                            foreach (var DisMeth in action.Value.Actions.Values.Where(p => p.Operation == "DISABLE"))
                            {
                                Qst.Disable = false;
                                DisableEnableQuestion.InvokeAsync((category.JobCategoryStructureId, Qst, false));
                            }
                        }
                        StateHasChanged();
                    }
                }
            }
        }
    }

}
