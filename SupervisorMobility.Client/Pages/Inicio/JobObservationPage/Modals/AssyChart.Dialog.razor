@inject IStringLocalizer<Resource> Localizer
<MudDialog Style="    max-height: 95vh;    min-height: 80vh;">
    <DialogContent>
        <SupervisorMobility.Client.Pages.Components.TreeView Path_Id="SOSCodePathId" panel="panelSelect"></SupervisorMobility.Client.Pages.Components.TreeView>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Filled">@Localizer["Close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public int SOSCodePathId { get; set; }

    [Parameter]
    public string panelSelect { get; set; }

    void Close() => MudDialog.Close();
}
