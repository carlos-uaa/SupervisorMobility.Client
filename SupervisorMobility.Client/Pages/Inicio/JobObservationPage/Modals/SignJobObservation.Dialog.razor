@inject IStringLocalizer<Resource> Localizer
<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
        <MudText Class="mt-4 mb-4">
            <span style="color: #2196f3; text-align:justify">@userName</span>,
            @Localizer["areYouSureYouWantToSignTheJobObservationFromThisAccount"]
        </MudText>
        <MudText Class="mt-4 mb-4">
            @Localizer["onceSignedItCannotBeModified"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Cancel" Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => Submit(0))">@Localizer["reject"]</MudButton>
        <MudButton @onclick="(() => Submit(1))" Color="Color.Info" StartIcon="@Icons.Material.Filled.Circle" Variant="Variant.Filled">@Localizer["finish"]</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public string userName { get; set; }

    void Submit(int option)
    {
        MudDialog.Close(DialogResult.Ok(option));
    }
    void Cancel() => MudDialog.Cancel();
}
