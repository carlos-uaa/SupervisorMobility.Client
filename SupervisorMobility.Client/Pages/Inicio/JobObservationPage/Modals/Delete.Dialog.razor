@inject IStringLocalizer<Resource> Localizer
<MudDialog>
<DialogContent>
    <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
        <MudText Class="mt-4 mb-4">
            <span style="color: #2196f3; text-align:justify">@Name</span>,
        @Localizer["areYouSureYouWantToDeleteThisLup"]
    </MudText>
</DialogContent>
<DialogActions>
    <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
        <MudButton @onclick="(() => DeleteLup.InvokeAsync(lupId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">@Localizer["delete"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public string Name { get; set; }
    [Parameter]
    public int lupId { get; set; }
    [Parameter]
    public EventCallback<int> DeleteLup { get; set; }

    void CloseDeleteModal() => MudDialog.Cancel();
}