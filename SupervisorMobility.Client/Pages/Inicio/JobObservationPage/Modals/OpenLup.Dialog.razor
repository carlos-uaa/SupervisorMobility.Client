@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager

<MudDialog DisableSidePadding="false">
    <DialogContent>
        <MudContainer Style="max-height: 75vh; overflow-y: scroll">
            <SupervisorMobility.Client.Pages.Inicio.LupPage.LupDetails LupId="lupId"></SupervisorMobility.Client.Pages.Inicio.LupPage.LupDetails>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudIconButton @onclick="(() => EditLup())" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>
        <MudButton Color="Color.Info" OnClick="Close">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public int lupId { get; set; }

    void Close() => MudDialog.Close();
    void Cancel() => MudDialog.Cancel();

    void EditLup()
    {
        NavigationManager.NavigateTo($"lup/updatelup/{lupId}");
    }
}
