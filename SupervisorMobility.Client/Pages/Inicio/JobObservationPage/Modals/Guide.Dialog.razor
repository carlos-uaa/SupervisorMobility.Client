@inject IStringLocalizer<Resource> Localizer
<MudDialog Style="max-height: 95vh; min-height: 80vh;">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="text-align: center;">Job Observation | LUP Guide</MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs @bind-ActivePanelIndex="selectedPillar" Outlined="true" Rounded="true" Border="true" TabPanelHeaderPosition="TabHeaderPosition.Before"
                 ApplyEffectsToContainer="true" PanelClass="px-6" Style="max-height: 78vh; min-height: 70vh; width: 100%;">
            <MudTabPanel>
                <TabContent>
                    <MudChip Icon="@Icons.Material.Filled.Folder" Style="display: flex;" Color="Color.Info">S & E</MudChip>
                </TabContent>
                <ChildContent>
                    <MudText>Safety & Environment Guide</MudText>
                </ChildContent>
            </MudTabPanel>
            <MudTabPanel>
                <TabContent>
                    <MudChip Icon="@Icons.Material.Filled.Folder" Style="display: flex;" Color="Color.Info">Q</MudChip>
                </TabContent>
                <ChildContent>
                    <MudText>Quality Guide</MudText>
                </ChildContent>
            </MudTabPanel>
            <MudTabPanel>
                <TabContent>
                    <MudChip Icon="@Icons.Material.Filled.Folder" Style="display: flex;" Color="Color.Info">D</MudChip>
                </TabContent>
                <ChildContent>
                    <MudText>Delivery Guide</MudText>
                </ChildContent>
            </MudTabPanel>
            <MudTabPanel>
                <TabContent>
                    <MudChip Icon="@Icons.Material.Filled.Folder" Style="display: flex;" Color="Color.Info">C</MudChip>
                </TabContent>
                <ChildContent>
                    <MudText>Cost Guide</MudText>
                </ChildContent>
            </MudTabPanel>
            <MudTabPanel>
                <TabContent>
                    <MudChip Icon="@Icons.Material.Filled.Folder" Style="display: flex;" Color="Color.Info">Other</MudChip>
                </TabContent>
                <ChildContent>
                    <MudText>Other Guide</MudText>
                </ChildContent>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Filled">@Localizer["Close"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter]
    public int selectedPillar { get; set;  }

    void Close() => MudDialog.Close();
}
