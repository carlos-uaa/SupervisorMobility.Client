                                <MudTimePicker Label="End hour" @bind-Time="endHour" Color="Color.Info" AdornmentColor="Color.Info" Class="pt-2" ReadOnly PickerClosed="ShowHourMessage"/>*@
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    @*Mud select of Operations *@
