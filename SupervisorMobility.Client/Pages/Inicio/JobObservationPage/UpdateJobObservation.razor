                                                                                {
                                                                                    @lup.Oportunity.Substring(0, 70) <span>...</span>
                                                                                }
                                                                            </MudChip>
                                                                            @switch (lup.Status)
                                                                            {
                                                                                case 1:
                                                                                    <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["new"]</MudChip>
                                                                                    break;
                                                                                case 2:
                                                                                    <MudChip Variant="Variant.Text" Color="Color.Info" Size="Size.Small">@Localizer["inProgress"]</MudChip>
                                                                                    break;
                                                                                case 3:
                                                                                    <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small">@Localizer["finished"]</MudChip>
                                                                                    break;
                                                                                case 4:
                                                                                    <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small">@Localizer["canceled"]</MudChip>
                                                                                    break;
                                                                            }
                                                                            <MudTooltip Text=@Localizer["deleteLupItem"] Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" @onclick="(() => OpenDeleteDialog(lup.LupId))"></MudIconButton>
                                                                            </MudTooltip>
                                                                        </MudButton>
                                                                    </MudTooltip>

                                                                }
                                                            }
                                                            @if (capturedImages.Count > 0 && photosPillar == 5)
                                                            {
                                                                <MudExpansionPanels Elevation="1" MultiExpansion="true" Dense>
                                                                 <MudExpansionPanel IsInitiallyExpanded=true Style="min-width: 100%;" Dense>
                                                                     <TitleContent>
                                                                         <MudText Style="text-align: center; padding:0 !important">
                                                                             @Localizer["Add Evidence Photos "]
                                                                                <MudChip Variant="Variant.Text" Color="Color.Info" Icon="@Icons.Material.Filled.ChecklistRtl">
                                                                                    ID @lupPhotosId
                                                                                    @if (oportunity.Length < 50)
                                                                                    {
                                                                                        <span>&nbsp;@oportunity</span>
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        <span>&nbsp;@oportunity.Substring(0, 50) ...</span>
                                                                                    }
                                                                                </MudChip>
                                                                            </MudText>
                                                                        </TitleContent>
                                                                        <ChildContent>
                                                                            <MudItem Class="d-flex" Style="flex-direction: row; flex-wrap: wrap; justify-content: flex-start;">

                                                                                @foreach (var (image, index) in capturedImages.Select((image, index) => (image, index)))
                                                                                {
                                                                                    <MudItem Class=" mr-8 mb-4">
                                                                                        <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                                                                                            <MudTooltip Text="Delete photo" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                                                                                <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="() => RemoveImage(index)"></MudIcon>
                                                                                            </MudTooltip>
                                                                                        </MudItem>
                                                                                        <MudImage ObjectFit="ObjectFit.Cover" Height="160" Width="320" Src=@image Alt="Evidence" Elevation="25" Class="rounded-lg" />
                                                                                    </MudItem>
                                                                                }
                                                                            </MudItem>
                                                                            <div style="display: flex; align-items: center; justify-content: space-between;">
                                                                                <MudItem Class="mb-4">
                                                                                    <MudButton Variant="Variant.Filled" @onclick="(() => OpenCameraDialog(lupPhotosId, oportunity, photosPillar))" StartIcon="@Icons.Material.Filled.AddAPhoto" Color="Color.Info">Add photo</MudButton>
                                                                                    @{
                                                                                        string uploadMessage = "Upload Photo";
                                                                                        if (capturedImages.Count > 1)
                                                                                        {
                                                                                            uploadMessage = "Upload " + capturedImages.Count.ToString() + " Photos";
                                                                                        }
                                                                                    }

                                                                                    <MudButton Class="ml-4" Variant="Variant.Filled" @onclick=UploadEvidence StartIcon="@Icons.Material.Filled.FileUpload" Color="Color.Primary">@uploadMessage</MudButton>
                                                                                    </MudItem>
                                                                                </div>
                                                                            </ChildContent>
                                                                        </MudExpansionPanel>
                                                                    </MudExpansionPanels>
                                                            }
                                                        }
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </MudSimpleTable>
                                    </td>
                                </tr>
                                <tr>
                                    <th colspan="2">
                                        <MudText Style="text-align:center; font-weight:bold;">
                                            @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("SSV"))
                                            {
                                                Glosary word;
                                                word = _glosaryInfo["SSV"];
                                                <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                                    <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                        <MudText Style="font-weight:bold">@word.Name</MudText>
                                                        </MudBadge>
                                                    </MudTooltip>
                                            }
                                            else
                                            {
                                                <span style="font-weight: bold">SSV </span>
                                            }
                                            @Localizer["comentaries"]
                                        </MudText>
                                    </th>
                                </tr>
                                <tr>
                                    <td colspan="2">
                                        @if (user.UserType == 1 || user.UserType == 2)
                                        {
                                            <MudTextField T="string" @bind-Value="_jobObservation.SsvCommentary" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                                        }
                                        else
                                        {

                                            <MudTextField T="string" @bind-Value="_jobObservation.SsvCommentary" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" ReadOnly />
                                        }
                                    </td>
                                </tr>
                            <th>
                                <MudText Style="text-align:center; font-weight:bold;">
                                        @Localizer["improvementIdeasAndOrCommentsFromTheOperator"]
                                </MudText>
                            </th>
                            <th>
                                <MudText Style="text-align:center; font-weight:bold;">
                                        @Localizer["signatureOfThe"]
                                        @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("SSV"))
                                        {
                                            Glosary word;
                                            word = _glosaryInfo["SSV"];
                                        <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                            <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                <MudText Style="font-weight:bold">@word.Name</MudText>
                                                </MudBadge>
                                            </MudTooltip>
                                        }
                                        else
                                        {
                                        <span style="font-weight: bold"> SSV</span>
                                        }
                                </MudText>
                            </th>
                            <tr>
                                <td>
                                    <MudTextField T="string" @bind-Value="_jobObservation.OperatorCommentary" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="4" />
                                </td>
                                <td>
                                        @*<MudTextField T="string" @bind-Value="_jobObservation.SsvSignature" Variant="Variant.Outlined" Margin="Margin.Dense" />*@
                                        @if ((_jobObservation.SsvSignature != "Signed" || _jobObservation.SsvSignature == null) && user.UserType == 1)
                                        {

                                        <MudButton Class="mr-10" StartIcon="@Icons.Material.Filled.BorderColor" Color="Color.Info" @onclick="(() => OpenSignComment())">
                                                @Localizer["signIt"]
                                        </MudButton>
                                        }
                                        else if ((_jobObservation.SsvSignature != "Signed" || _jobObservation.SsvSignature == null) && user.UserType == 2)
                                        {
                                            @if (_jobObservation.Supervisor.SuperiorId == user.UserId)
                                            {
                                            <MudButton Class="mr-10" StartIcon="@Icons.Material.Filled.BorderColor" Color="Color.Info" @onclick="(() => OpenSignComment())">
                                                    @Localizer["signIt"]
                                            </MudButton>
                                            }
                                        }
                                        else if (_jobObservation.SsvSignature == "Signed")
                                        {
                                        <MudChip Class="mr-10" Icon="@Icons.Material.Filled.PlaylistAddCheck" Color="Color.Info" Variant="Variant.Text">
                                                @Localizer["signed"]
                                        </MudChip>
                                        }
                                        else
                                        {
                                        <MudChip Class="mr-10" Icon="@Icons.Material.Filled.AssignmentLate" Color="Color.Warning" Variant="Variant.Text">
                                                @Localizer["unsignedOnlySSVCanSignIt"]
                                        </MudChip>
                                        }
                                    <MudText Style="text-align:center; font-weight:bold;">
                                            @Localizer["operatorsSignature"]
                                    </MudText>
                                    <MudTextField T="string" @bind-Value="_jobObservation.OperatorSignature" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </td>
                            </tr>
                                @if ((user.UserType == 1 || user.UserType == 5) && _jobObservation.Status == 6)
                                {
                                <tr>
                                    <th colspan="2">
                                        <MudText Style="text-align:center; font-weight:bold;">
                                                @Localizer["addFeedback"]
                                        </MudText>
                                    </th>
                                </tr>
                                <tr>
                                    <td colspan="2">
                                        <MudTextField T="string" @bind-Value="_jobObservation.ReleasedFeedback" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                                    </td>
                                </tr>

                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudExpansionPanel>
                            }
                        }
                    </MudExpansionPanels>
                <MudCardActions>
                    <MudItem Class="ml-auto mt-4">

                        @if (_jobObservation.Status != 6)
                        {
                            if (user.UserType == 1 || user.UserType == 3)
                            {
                                <MudButton StartIcon="@Icons.Material.Filled.StopCircle" ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["saveProgress"]</MudButton>
                            }
                            if ((_jobObservation.Status == 1 || _jobObservation.Status == 3) && user.UserType != 4)
                            {
                                <MudButton StartIcon="@Icons.Material.Filled.DateRange" Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => OpenCommentDialog())">@Localizer["changeDate"]</MudButton>
                            }
                            if (user.UserType == 1 || user.UserType == 4 || user.UserType == 3)
                            {
                                <MudButton StartIcon="@Icons.Material.Filled.IncompleteCircle" Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => UnderReviewJobObservation())">@Localizer["underReview"]</MudButton>
                            }
                            <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelUpdateJobObservation())">@Localizer["cancel"]</MudButton>
                        }
                        else
                        {
                            @if (user.UserType == 1 || user.UserType == 5)
                            {
                                <MudButton StartIcon="@Icons.Material.Filled.Feedback" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto mr-4" @onclick="(() => AddReleasedFeedback())">@Localizer["addFeedback"]</MudButton>
                            }
                            <MudButton Variant="Variant.Filled" Class="ml-auto" @onclick="(() => CancelUpdateJobObservation())">@Localizer["goBack"]</MudButton>
                        }
                    </MudItem>
                </MudCardActions>
            </MudItem>
        </MudGrid>
    </EditForm>
    }

    @*Camera Modal for LUP*@
    <MudDialog DisableSidePadding="false" @bind-IsVisible="visibleCamera" Options="dialogCameraOptions">
        <TitleContent>
            <MudItem>
                <MudText Typo="Typo.h6" Style="text-align:center">LUP Evidence</MudText>
            </MudItem>
        </TitleContent>
        <DialogContent>
            <MudContainer Style="max-height: 85vh; overflow-y: scroll text-align:center; justify-content: center; align-items:center;">
                <MudPaper Elevation="0">
                    <CameraStreamer @ref=CameraStreamerReference
                                    Width=1280
                                    Height=720
                                    OnRendered=OnRenderedHandler
                                    OnFrame=OnFrameHandler
                                    Style="max-height: 70vh; width: 100%; border-radius: 10px"
                                    Class="mud-elevation-4 rounded white"
                                    CameraID=@cameraId
                                            Autostart />
                     <MudItem style="text-align: center">
                         @if (frameCount > 0)
                        {
                            <MudButton @onclick=GetCurrentFrame Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.LinkedCamera" Color="Color.Info" Class="mt-2 mb-4">
                                Take photo
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.LinkedCamera" Color="Color.Info" Class="mt-2 mb-4" Disabled>
                             Take photo
                         </MudButton>
                        }
                    </MudItem>
                </MudPaper>
            </MudContainer>
        </DialogContent>
    </MudDialog>

@* camera dialog For Cheklist Answer *@
    <MudDialog DisableSidePadding="false" @bind-IsVisible="visibleDialogAnswerCamera" Options="dialogCameraOptions">
        <TitleContent>
            <MudItem>
                <MudText Typo="Typo.h6" Style="text-align:center">Evidence for @SelectedAnswer.Prompt</MudText>
                </MudItem>
            </TitleContent>
            <DialogContent>
                <MudContainer Style="max-height: 85vh; overflow-y: scroll text-align:center; justify-content: center; align-items:center;">
                    <MudPaper Elevation="0">
                        <CameraStreamer @ref=CameraStreamerReference
                                        Width=1280
                                        Height=720
                                        OnRendered=OnRenderedHandler
                                        OnFrame=OnFrameHandler
                                        Style="max-height: 70vh; width: 100%; border-radius: 10px"
                                        Class="mud-elevation-4 rounded white"
                                        CameraID=@cameraId
                                            Autostart />
                     <MudItem style="text-align: center">
                         @if (frameCount > 0)
                        {
                            <MudButton @onclick=GetCurrentFrameAnswer Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.LinkedCamera" Color="Color.Info" Class="mt-2 mb-4">
                                Take photo
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.LinkedCamera" Color="Color.Info" Class="mt-2 mb-4" Disabled>
                             Take photo
                         </MudButton>
                        }
                    </MudItem>
                </MudPaper>
            </MudContainer>
        </DialogContent>
    </MudDialog>

    @*Delete lup modal*@
    <MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
        <DialogContent>
            <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
                <MudText Class="mt-4 mb-4">
                    <span style="color: #2196f3; text-align:justify">@user.Name</span>,
                @Localizer["areYouSureYouWantToDeleteThisLup"]
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
                <MudButton @onclick="(() => DeleteLup(deleteLupId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">@Localizer["delete"]</MudButton>
            </DialogActions>
        </MudDialog>

    @*Sign observation modal*@
    <MudDialog @bind-IsVisible="visibleSign" Options="dialogSignOptions">
        <DialogContent>
            <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
                <MudText Class="mt-4 mb-4">
                    <span style="color: #2196f3; text-align:justify">@user.Name</span>,
                @Localizer["areYouSureYouWantToSignTheJobObservationFromThisAccount"]
            </MudText>
            <MudText Class="mt-4 mb-4">
                @Localizer["onceSignedItCannotBeModified"]
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseSign" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.Cancel" Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => Reject())">@Localizer["reject"]</MudButton>
                <MudButton @onclick="(() => SignDate())" Color="Color.Info" StartIcon="@Icons.Material.Filled.Circle" Variant="Variant.Filled">@Localizer["finish"]</MudButton>
            </DialogActions>
        </MudDialog>

    @*Change Date modal*@
    <MudDialog DisableSidePadding="false" @bind-IsVisible="visible" Options="dialogCommentOptions">
        <DialogContent>
            <MudContainer Style="min-height:40vh; max-height: 75vh; overflow-y: scroll; text-align: center">
                <MudSimpleTable>
                    <thead>
                        <tr>
                            <th colspan="2" style="text-align:center">
                                <MudText Typo="Typo.h6">@Localizer["selectANewDate"]</MudText>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <MudDatePicker @bind-Date="_jobObservation.StartDate" Label=@Localizer["newStartDate"] Color="Color.Info" AdornmentColor="Color.Info" Class="pt-2" />
                                    @*<MudTimePicker Label="New Start hour" @bind-Time="startHour" Color="Color.Info" AdornmentColor="Color.Info" Class="pt-2" />*@
                                </td>
                                <td>
                                    <MudDatePicker @bind-Date="_jobObservation.EndDate" Label=@Localizer["newEndDate"] Color="Color.Info" AdornmentColor="Color.Info" MinDate="_jobObservation.StartDate" Class="pt-2" />
                                    @*<MudTimePicker Label="New End hour" @bind-Time="endHour" Color="Color.Info" AdornmentColor="Color.Info" Class="pt-2" />*@
                                </td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                    <MudText Typo="Typo.h6" Class="mt-4">@Localizer["WriteDownACommentToChangeTheDate"]</MudText>
                    <MudTextField T="string" @bind-Value="_jobObservation.Justification" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="10" Class="mt-4" />
                </MudContainer>
            </DialogContent>
            <DialogActions>
                <MudButton Color="Color.Info" @onclick="(() => ChangeDate())">@Localizer["save"]</MudButton>
                <MudButton Color="Color.Info" OnClick="Close">@Localizer["close"]</MudButton>
            </DialogActions>
        </MudDialog>

    @*lup modal*@
    <MudDialog DisableSidePadding="false" @bind-IsVisible="visibleLup" Options="dialogLup">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">
                <SupervisorMobility.Client.Pages.Inicio.LupPage.LupDetails LupId="lupId"></SupervisorMobility.Client.Pages.Inicio.LupPage.LupDetails>
            </MudContainer>
        </DialogContent>
        <DialogActions>
            <MudIconButton @onclick="(() => EditLup(lupId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>
            <MudButton Color="Color.Info" OnClick="CloseLup">@Localizer["close"]</MudButton>
            </DialogActions>
        </MudDialog>

    @*Past modal*@
    <MudDialog DisableSidePadding="false" @bind-IsVisible="visiblePast" Options="dialogPastJobObservations">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; min-height:50vh; overflow-y: scroll">
                <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                    <MudText Typo="Typo.h6">
                        @Localizer["pastJobObservationLup"]
                    </MudText>
                    <MudText>
                        <MudChip Color="Color.Info" Variant="Variant.Text">@_jobObservation.Distribution?.Description</MudChip>
                            <MudChip Color="Color.Info" Variant="Variant.Text">@_jobObservation.Operation?.Description</MudChip>

                        </MudText>
                    </MudItem>
                    @if (pastjobObservations.Count > 0)
                {
                    <MudTable Items="pastjobObservations" T="JobObservation" Bordered Class="mt-3 past-jobObservations-table mb-10">
                         <HeaderContent>
                             <MudTh style="text-align: center">
                                 <MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.JobObservationId)">Id</MudTableSortLabel>
                             </MudTh>
                             <MudTh style="text-align: center"><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.StartDate)">@Localizer["startDate"]</MudTableSortLabel></MudTh>
                                <MudTh style="text-align: center; width: 65%">@Localizer["totalLup"]</MudTh>
                                <MudTh style="text-align: center"><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Status)">@Localizer["status"]</MudTableSortLabel></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <MudTooltip Text=@Localizer["goToJobObservation"] Arrow="true" Placement="Placement.Right" Color="Color.Info">
                                        <MudChip Variant="Variant.Text" Color="Color.Info" Size="Size.Small" @onclick="(() => GoToJobObservation(context.JobObservationId))"> @context.JobObservationId</MudChip>
                                    </MudTooltip>
                                </MudTd>
                                <MudTd>
                                    <MudText>@context.StartDate?.ToShortDateString()</MudText>
                                </MudTd>
                                <MudTd>
                                    <MudText>
                                        @if (pastLup.Count > 0)
                                    {
                                        @foreach (var lup in pastLup)
                                        {
                                            if (lup.JobObservationId == context.JobObservationId)
                                            {
                                                <MudTooltip Text="@lup.LupId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true">
                                                    <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined" @onclick="(() => OpenDialogLup(lup.LupId))">
                                                        <MudChip Color="Color.Info" OnClose="Closed" Size="Size.Small" CloseIcon="@Icons.Material.Filled.ChecklistRtl" Variant="Variant.Text" Style="cursor:pointer">
                                                            @switch (lup.Pillar)
                                                            {
                                                                case 1:
                                                                    <span>S | &nbsp;</span>
                                                                    break;
                                                                case 2:
                                                                    <span>Q | &nbsp;</span>
                                                                    break;
                                                                case 3:
                                                                    <span>D | &nbsp;</span>
                                                                    break;
                                                                case 4:
                                                                    <span>C | &nbsp;</span>
                                                                    break;
                                                                case 5:
                                                                    <span>@Localizer["other"] | &nbsp;</span>
                                                                    break;
                                                            }
                                                            @if (lup.Oportunity.Length < 70)
                                                            {
                                                                @lup.Oportunity
                                                            }
                                                            else
                                                            {
                                                                @lup.Oportunity.Substring(0, 70) <span>...</span>
                                                            }
                                                        </MudChip>
                                                        @switch (lup.Status)
                                                        {
                                                            case 1:
                                                                <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small">@Localizer["new"]</MudChip>
                                                                break;
                                                            case 2:
                                                                <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small">@Localizer["inProgress"]</MudChip>
                                                                break;
                                                            case 3:
                                                                <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["finished"]</MudChip>
                                                                break;
                                                            case 4:
                                                                <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small">@Localizer["canceled"]</MudChip>
                                                                break;
                                                        }
                                                    </MudButton>
                                                </MudTooltip>
                                            }
                                        }
                                    }
                                </MudText>
                            </MudTd>
                            <MudTd>
                                <MudText>

                                    @switch (context.Status)
                                    {
                                        case 1:
                                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">@Localizer["planned"]</MudChip>
                                            break;
                                        case 2:
                                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Size="Size.Small" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                            break;
                                        case 3:
                                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                            break;
                                        case 4:
                                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                            break;
                                        case 5:
                                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                            break;
                                        case 6:
                                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                            break;
                                    }
                                </MudText>
                            </MudTd>
