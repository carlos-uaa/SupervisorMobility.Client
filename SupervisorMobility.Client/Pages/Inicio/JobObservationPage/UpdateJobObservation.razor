                                    <MudDatePicker @bind-Date="_jobObservation.EndDate" Label=@Localizer["endDate"] Color="Color.Info" AdornmentColor="Color.Info" MinDate="_jobObservation.StartDate" Class="pt-2" ReadOnly PickerClosed="ShowDateMessage" />
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    @*Mud select of Distribution *@
