@*Title*@
<PageTitle>Supervisor Mobility |  @Localizer["jobObservations"]</PageTitle>
<div style="display: flex; align-items: center; justify-content: space-between;">
    <MudItem>
        <MudBreadcrumbs Items="_links">
            <ItemTemplate Context="item">
                <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
            </ItemTemplate>
        </MudBreadcrumbs>
    </MudItem>
    <MudItem Style="text-align: end">
        <MudButton @onclick="(() => OpenDialogPastJobObservations())" Class="ml-4" Style="float:right" Variant="Variant.Filled" Color="Color.Info" Size="Size.Small" StartIcon="@Icons.Material.Filled.AccessTime"> @Localizer["pastJobObservationLup"]</MudButton>
    </MudItem>
</div>

@* Job Observation Form*@
