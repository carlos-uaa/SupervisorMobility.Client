                                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAPlant"]</MudSelectItem>
                                            @foreach (var type in _plants)
                                            {
                                                <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else{
                                        @*Mud select for Plants *@
                                        <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.PlantId" For="@(() => _jobObservation.PlantId)" SelectedValuesChanged="ShowAreas">
                                            @foreach (var type in _plants)
                                            {
                                                if(type.PlantId == user.PlantId){
                                                    <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                                }
                                            }
                                        </MudSelect>
                                    }

                                    @if (_jobObservation.PlantId != 0 && user.UserType == 1)
                                    {
                                        @*Mud select for Areas for Admin *@
