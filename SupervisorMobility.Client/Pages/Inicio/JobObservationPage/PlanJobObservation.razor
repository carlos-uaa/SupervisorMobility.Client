                                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnArea"]</MudSelectItem>
                                            @foreach (var type in user.Areas)
                                            {
                                                <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else if (_jobObservation.PlantId != 0)
                                    {
                                        @*Mud select for Areas for SV *@
                                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.AreaId" For="@(() => _jobObservation.AreaId)" SelectedValuesChanged="ShowDistributions">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnArea"]</MudSelectItem>
                                            @foreach (var type in _areas)
                                            {
                                                if (type.AreaId == user.AreaId)
                                                {
                                                    <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                                }
                                            }
                                        </MudSelect>
                                    }
                                    else
