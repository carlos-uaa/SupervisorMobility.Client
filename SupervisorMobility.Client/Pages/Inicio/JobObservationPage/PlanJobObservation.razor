                                                <img src="Images/dialogerror.png" Height="140" Width="140" />
                                            </MudItem>

                                            <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                    <MudText Typo="Typo.h6" Align="Align.Center" Label="Name"> @Localizer["ServerNotResponse"]</MudText>
