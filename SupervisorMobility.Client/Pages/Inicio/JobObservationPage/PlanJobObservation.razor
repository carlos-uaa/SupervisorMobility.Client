   @*                                 <MudTextField T="string" @bind-Value="_jobObservation.Operator" Label="Operador" />
                                    <MudText Color="Color.Error" Style="font-size:12px"><ValidationMessage For="@(() => _jobObservation.Operator)" /></MudText>*@
