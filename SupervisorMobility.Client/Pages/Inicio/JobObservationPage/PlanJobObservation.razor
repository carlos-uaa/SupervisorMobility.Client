                                                                break;
                                                            case 10:
                                                                imageSrc = "Images/ULeader.png";
                                                                break;
                                                            case 11:
                                                                imageSrc = "Images/U.png";
                                                                break;
                                                            default:
                                                                imageSrc = "Images/default.png";
                                                                break;
                                                        }
                                                        <MudImage Src="@imageSrc" Alt="ILU Image" Height="45" Class="rounded-lg" Style="margin-top: -5px" />
