<style>

    .green {
        background: var(--mud-palette-success-hover);
        border: 1px solid var(--mud-palette-success);
        border-radius: 6px;
    }

    .yellow {
        background: var(--mud-palette-warning-hover);
        border: 1px solid var(--mud-palette-warning);
        border-radius: 6px;
    }

    .red {
        background: var(--mud-palette-error-hover);
        border: 1px solid var(--mud-palette-error);
        border-radius: 6px;
    }

    .current-time {
        border: 3px solid var(--mud-palette-success);
        border-radius: 6px;
    }

    .canvas-container {
        border: 1px dashed #000;
        box-shadow: 5px 5px 5px rgb(218, 214, 213);
        border-radius: 10px;
        transition: all 0.3s ease-out;
    }

        .canvas-container:hover {
            transform: scale(1.005);
        }

</style>

