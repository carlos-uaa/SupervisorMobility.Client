        <tbody>
            <tr>
                <td>@Localizer["Cycle Time"]</td>

                    @for (int i = 0; i < 5; i++)
                    {

                        double value;
                        if (!double.TryParse(CycleTimes[i], NumberStyles.Float, CultureInfo.InvariantCulture, out value))
                        {
                            value = 0.0;
                        }

                        var standardTime = "0.0";
                        if (jobProductIds[i] != 0)
                        {
                            standardTime = _productAndSpecification
                            .FirstOrDefault(ps => ps.ProductName == _products
                            .First(p => p.ProductId == jobProductIds[i]).Code)?.StandardTime;
                        }

                        if (double.TryParse(standardTime, out double standardTimeValue))
                        {
                            var lowerBound = standardTimeValue * 0.95;
                            var upperBound = standardTimeValue * 1.05;

                            var percentageDifference = Math.Abs((value - standardTimeValue) / standardTimeValue) * 100;

                            var cycleColor = "";

                            if (value == 0.0 || standardTimeValue == 0.0)
                            {
                                cycleColor = "";
                            }
                            else if (value > upperBound)
                            {
                                cycleColor = "red";
                            }
                            else if (value < lowerBound)
                            {
                                cycleColor = "yellow";
                            }
                            else if (value >= lowerBound && value <= upperBound)
                            {
                                cycleColor = "green";
                            }

                            if (i == currentCycle)
                            {
                                cycleColor += " current-time";
                            }

                            <td>
                                <MudTextField T="string" Value="@value.ToString().Replace(',','.')" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Class="@cycleColor" />
                            </td>
                        }
                        else
                        {
                            <td>
                                <MudTextField T="double" ReadOnly Value="@value" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </td>
                        }

                    }

            </tr>
