                        <span>@(IsContinuous ? Localizer["yes"] : Localizer["no"])</span>

                    }
                    else
                    {
                        <MudToggleGroup T="bool" SelectionMode="SelectionMode.SingleSelection" @bind-Value="IsContinuous" Color="Color.Info" CheckMark Dense   >
                            <MudToggleItem Value="@(true)" Text="@Localizer["yes"]" />
