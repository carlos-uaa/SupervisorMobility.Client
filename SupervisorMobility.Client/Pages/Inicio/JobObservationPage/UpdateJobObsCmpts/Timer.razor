    private bool isTimerRunning2 = false;
    bool errorflag = false;
    private DateTime startTime2;
    private System.Timers.Timer timer2;

    private string elapsedTime2 = "00:00:00.000";
    private string cronometerTime = "0.00";
    private int currentOperationIndex = 0;

    private double previousOperationTime = 0.0;
    private bool IsContinuous = true;

    public int[] jobSpecificationIds = new int[5];



    private void StartOrPauseTimer()
    {
        if (isTimerRunning2)
        {
            StopTimer();
        }
        else
        {
            StartTimer();
        }
    }

    private void StartTimer()
    {
        if (!isTimerRunning2)
        {
            startTime2 = DateTime.Now - TimeSpan.Parse(elapsedTime2); // Restaura el tiempo de inicio en función del tiempo transcurrido
        }

        timer2 = new System.Timers.Timer(1);
        errorflag = false;
        isTimerRunning2 = true;
        timer2.Elapsed += OnTimerTick;
        timer2.AutoReset = true;
        timer2.Enabled = true;
    }

    private void PauseTimer()
    {
        cronometerTime = "0.00";
        isTimerRunning2 = false;
        timer2.Enabled = false;
        currentOperationIndex = 0;
        PauseTime.InvokeAsync();

        StateHasChanged();
    }

    private void StopTimer()
    {
        // Solo detiene el temporizador sin reiniciar el tiempo transcurrido
        isTimerRunning2 = false;
        timer2.Enabled = false;
        StateHasChanged();
    }


    private void OnTimerTick(object? sender, ElapsedEventArgs e)
    {
        if (isTimerRunning2)
        {
            TimeSpan hundreths;
            double centiseconds = 0.0;
            if (TimeSpan.TryParseExact(elapsedTime2, "hh\\:mm\\:ss\\.fff", CultureInfo.InvariantCulture, out hundreths))
            {
                centiseconds = hundreths.TotalMilliseconds / 60000.0;
            }
            else
            {
                Console.WriteLine("Wrong timestamp format.");
            }

            cronometerTime = string.Format("{0:0.000}", centiseconds);
        }

        DateTime currentTime = e.SignalTime;
        elapsedTime2 = $"{currentTime.Subtract(startTime2)}".Substring(0, 12);
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        if (isTimerRunning2 && args.Code == "KeyN")
        {
            NextOp();
        }
    }

    public bool checkIfError(int i, int? value)
    {
        if (errorflag)
        {
            bool check = currentCycle - 1 == i;
            bool chekV = value == 0;
            return check && chekV;
        }
        else
        {
            return false;
        }
    }

    public void NextOp()
    {
        NextOperation.InvokeAsync();
        if (currentCycle >= 4 || !IsContinuous)
        {
            PauseTimer();
        }
        else if (IsContinuous)
        {
            startTime2 = DateTime.Now;
            timer2 = new System.Timers.Timer(1);
            errorflag = false;
            isTimerRunning2 = true;
            timer2.Elapsed += OnTimerTick;
            timer2.AutoReset = true;
            timer2.Enabled = true;
        }
        StateHasChanged();
    }

    public void WaitTime()
    {
        WaitingTime.InvokeAsync();
        StateHasChanged();
    }


    public double GetElapsedCentiseconds()
    {
        TimeSpan hundreths;
        double centiseconds = 0.0;
        if (TimeSpan.TryParseExact(elapsedTime2, "hh\\:mm\\:ss\\.fff", CultureInfo.InvariantCulture, out hundreths))
        {
            centiseconds = hundreths.TotalMilliseconds / 60000.0;
        }
        else
        {
            Console.WriteLine("Wrong timestamp format.");
        }

        return Math.Round(centiseconds, 2);
    }

