@page "/hoe/createHoe"
@using System.Text.RegularExpressions

@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbServices
@inject IAreaService AreaServices
@inject IUserService UsersService
@inject IProductService ProductsService
@inject IDataPanelService DataPanelServices
@inject IAppearanceService AppearanceServices
@inject ILogbookAppearanceService LogbookAppearanceServices
@inject SignatureImageService _signatureImageService
@inject IPartServices PartsServices
@inject IFileUploadAndDownloadService FilesServices
@inject ITestService TestService
@inject IProductService ProductsServices
@inject ISOSHubService SOSHubServices
<style>

    .custom-table td:first-child {
        background-color: #f5f5f6;
    }

    .comments-table td:first-child {
        background-color: white;
    }

</style>

<PageTitle>Supervisor Mobility | @Localizer["configuration"]</PageTitle>
<EditForm Model="_sosHub" OnValidSubmit="CreateNewSOSHub">
    <MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
        <MudItem lg="8" md="10" sm="10" xs="12">
            <MudExpansionPanels Elevation="5" MultiExpansion="true">
                <MudExpansionPanel IsInitiallyExpanded=true Style="min-width: 100%;">
                    <TitleContent>
                        <div class="d-flex" style="align-items: center; justify-content:center;">
                            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
                            <MudText Typo="Typo.h6" Style="text-align: center;">
                                @Localizer["HOE / SOS"]
                            </MudText>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudSimpleTable Style="overflow-x: auto;" Dense=true Elevation="0" Class="custom-table">
                            <tbody>
                                <tr>
                                    <td width="25%">
                                        <MudText>Operation Description</MudText>
                                    </td>
                                    <td>
@*                                    <MudTextField Margin="Margin.Dense" Value="@("Pr1960 Install Water Pump Housing And Gasket - Install Gasktet to Water Pump Housing")" Lines="2" />
*@
                                    <MudTextField @bind-Value="_sosHub.OperationDescription" Margin="Margin.Dense" Lines="4" />
                                    <MudButton OnClick="AnalyzeText">Generate Steps</MudButton>
                                    
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Process Sheet</MudText>
                                    </td>
                                    <td>
                                        <MudTextField Margin="Margin.Dense" @bind-Value="_sosHub.ProcessSheet" Class="ml-4" />
                                        <MudText Style="font-weight:bold;" Class="mt-4 ml-4">Revisión - Modificación</MudText>
                                        <MudSimpleTable Style="overflow-x: auto;" Class="comments-table" Dense="true" Elevation="0">
                                            <tbody>
                                                @foreach (var item in items)
                                                {
                                                    <tr>
                                                        <td width="90%">
                                                            <MudTextField @bind-Value="@item.Commentary" Label="Revisión - Modificación" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                                                        </td>
                                                        @if (items.IndexOf(item) > 0)
                                                        {
                                                            <td width="10%">
                                                                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="() => RemoveItem(item)" StartIcon="@Icons.Material.Filled.Delete">Remove</MudButton>
                                                            </td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </MudSimpleTable>
                                        <MudButton OnClick="AddItem" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Style="float: right">Add Commentary</MudButton>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Common Direction</MudText>
                                    </td>
                                    <td>
                                        <MudStack Style="width: 100%">
                                            <MudFileUpload T="IReadOnlyList<IBrowserFile>" OnFilesChanged="OnInputFileChanged" Hidden="false" Class="flex-1" InputClass="absolute mud-width-full mud-height-full overflow-hidden z-20" InputStyle="opacity:0"
                                            @ondragenter="@SetDragClass" @ondragleave="@ClearDragClass" @ondragend="@ClearDragClass">
                                                <ButtonTemplate Context="evidence">
                                                    <MudPaper Height="@($"{height}px")" Outlined="true" Class="@DragClass">
                                                        <MudText Style="font-weight:bold;" Class="ml-4"> @Localizer["dragAndDropEvidenceFilesHereOrClick"]</MudText>
                                                            @foreach (var file in fileNames)
                                                            {
                                                                <MudItem Style="text-align:center;" Class="d-flex justify-center align-content-center align-center">
                                                                    <MudText Typo="Typo.h6">@file.message</MudText>
                                                                @switch (file.ftype)
                                                                {
                                                                    case "application/pdf":
                                                                        <img src="Images/pdf.png" Height="25" Width="25" />
                                                                        break;

                                                                    case "application/msword":
                                                                        // Para documentos Word con extensión .doc
                                                                        <img src="Images/doc.png" Height="25" Width="25" />

                                                                        break;

                                                                    case "application/vnd.openxmlformats-officedocument.wordprocessingml.document":
                                                                        <img src="Images/docx.png" Height="25" Width="25" />

                                                                        // Para documentos Word con extensión .docx
                                                                        break;

                                                                    case "application/vnd.ms-powerpoint":
                                                                        <img src="Images/ppt.png" Height="25" Width="25" />
                                                                        // Para presentaciones PowerPoint con extensión .ppt
                                                                        break;

                                                                    case "application/vnd.openxmlformats-officedocument.presentationml.presentation":
                                                                        <img src="Images/pptx.png" Height="25" Width="25" />

                                                                        // Para presentaciones PowerPoint con extensión .pptx
                                                                        break;

                                                                    case "application/vnd.ms-excel":
                                                                        // Para hojas de cálculo Excel con extensión .xls
                                                                        <img src="Images/xls.png" Height="25" Width="25" />
                                                                        break;

                                                                    case "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet":
                                                                        // Para hojas de cálculo Excel con extensión .xlsx
                                                                        <img src="Images/xlsx.png" Height="25" Width="25" />

                                                                        break;

                                                                    case "image/jpeg":
                                                                        <img src="Images/jpg.png" Height="25" Width="25" />

                                                                        // Para imágenes JPEG con extensión .jpg o .jpeg
                                                                        break;

                                                                    case "image/png":
                                                                        // Para imágenes PNG con extensión .png
                                                                        <img src="Images/png.png" Height="25" Width="25" />

                                                                        break;

                                                                    case "image/gif":
                                                                        // Para imágenes GIF con extensión .gif
                                                                        <img src="Images/gif.png" Height="25" Width="25" />
                                                                        break;

                                                                    default:
                                                                        <img src="Images/error.png" Height="25" Width="25" />
                                                                        break;
                                                                }
                                                                    <MudButton Target="_blank"
                                                                               Variant="Variant.Text"
                                                                               Color="Color.Secondary"
                                                                               Style="text-transform:none; font-size: 12px;">
                                                                            
                                                                        @file.name
                                                                    </MudButton>
                                                                </MudItem>
                                                            }
                                                    </MudPaper>
                                                </ButtonTemplate>
                                            </MudFileUpload>
                                        </MudStack>
                                        <MudButton OnClick="Clear" Disabled="@(!fileNames.Any() )" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Style="float: right" Class="mt-3"> @Localizer["clear"]</MudButton>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Applied Models</MudText>
                                    </td>
                                    <td>
                                        <MudSelect T="int" Label=@Localizer["product"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@productId" OpenIcon="@Icons.Material.Filled.DirectionsCar" AdornmentColor="Color.Info">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAProduct"]</MudSelectItem>
                                            @foreach (var type in _products)
                                            {
                                                <MudSelectItem Value="type.ProductId">
                                                    @type.Code
                                                </MudSelectItem>
                                            }
                                        </MudSelect>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Steps</MudText>
                                    </td>
                                    <td>
                                        <MudButton Variant="Variant.Filled" OnClick="ShowStepsDialog">
                                            Edit Steps
                                            <span>&nbsp;(@segments.Count)</span>
                                        </MudButton>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Images</MudText>
                                    </td>
                                    <td>
                                        <MudButton Variant="Variant.Filled" OnClick="ShowImagesDialog">
                                            Edit Images
                                            <span>&nbsp;(@capturedImages.Count)</span>
                                        </MudButton>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Videos</MudText>
                                    </td>
                                    <td>
                                        <MudButton Variant="Variant.Filled" OnClick="ShowVideosDialog">
                                            Edit Videos
                                            <span>&nbsp;(@MediaUris.Count)</span>
                                        </MudButton>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Revised Items</MudText>
                                    </td>
                                    <td>
                                        <MudTextField Margin="Margin.Dense" @bind-Value="_sosHub.RevisedItems" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Training time</MudText>
                                    </td>
                                    <td>
                                        <MudTimePicker @bind-Time="_sosHub.TrainingTime" TimeEditMode="TimeEditMode.Normal" Label="Select Time" Margin="Margin.Dense" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Safety Equipment</MudText>
                                    </td>
                                    <td>
                                        <MudTextField Margin="Margin.Dense" Value="@("Leather Shoes, Safety Glasses, Gloves")" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Tools Used</MudText>
                                    </td>
                                    <td>
                                        <MudTextField Margin="Margin.Dense" Value="@("N/A")" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Materials Used</MudText>
                                    </td>
                                    <td>
                                        <MudTextField Margin="Margin.Dense" Value="@("Water Pump Housing, Water Pump Housing Gasket")" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Other information</MudText>
                                    </td>
                                    <td>
                                        <MudTextField Margin="Margin.Dense" @bind-Value="_sosHub.OtherInformation" Lines="3" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Area</MudText>
                                    </td>
                                    <td>
                                        <MudTextField Margin="Margin.Dense" Value="@("Decherd: Nissan : Assembly : PR Assembly : Zone 1 : PR Zone 1")" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Owner</MudText>
                                    </td>
                                    <td>
                                        @if (_supervisors.Count > 0)
                                        {
                                            <MudAutocomplete T="int"
                                                Label=@Localizer["Supervisor"]
                                                Variant="Variant.Text"
                                                AnchorOrigin="Origin.BottomCenter"
                                                @bind-Value="supervisorOwnerId"
                                                OpenIcon="@Icons.Material.Filled.SupervisorAccount"
                                                AdornmentColor="Color.Secondary"
                                                Clearable
                                                                                  ResetValueOnEmptyText
                                                ShowProgressIndicator="true" ProgressIndicatorColor="Color.Info"
                                                ToStringFunc="@(s => _supervisors.FirstOrDefault(x => x.UserId == s)?.Name)"
                                                SearchFunc="SearchSupervisors">
                                                
                                            </MudAutocomplete>
                                        }

                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Created</MudText>
                                    </td>
                                    <td>
                                        <MudTextField T="DateTime?" Format="s" Label="DateTimeLocal" InputType="InputType.DateTimeLocal" @bind-Value="createdDateTime" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Editor</MudText>
                                    </td>
                                    <td>
                                        @if (_supervisors.Count > 0)
                                        {
                                            <MudAutocomplete T="int"
                                                Label=@Localizer["Supervisor"]
                                                Variant="Variant.Text"
                                                AnchorOrigin="Origin.BottomCenter"
                                                @bind-Value="supervisorEditorId"
                                                OpenIcon="@Icons.Material.Filled.SupervisorAccount"
                                                AdornmentColor="Color.Secondary"
                                                Clearable
                                                ResetValueOnEmptyText
                                                ShowProgressIndicator="true" ProgressIndicatorColor="Color.Info"
                                                ToStringFunc="@(s => _supervisors.FirstOrDefault(x => x.UserId == s)?.Name)"
                                                SearchFunc="SearchSupervisors">
                                            </MudAutocomplete>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Modified</MudText>
                                    </td>
                                    <td>
                                        <MudTextField T="DateTime?" Format="s" Label="DateTimeLocal" InputType="InputType.DateTimeLocal" @bind-Value="modifiedDateTime" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Plan</MudText>
                                    </td>
                                    <td>
                                        <MudTextField Margin="Margin.Dense" @bind-Value="_sosHub.Plan" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Source Plan</MudText>
                                    </td>
                                    <td>
                                        <MudTextField Margin="Margin.Dense" @bind-Value="_sosHub.SourcePlan" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Status</MudText>
                                    </td>
                                    <td>
                                        <MudSelect Margin="Margin.Dense" T="string" Variant="Variant.Text" @bind-Value="_sosHub.Status">
                                            <MudSelectItem Value="@("Pending")" />
                                            <MudSelectItem Value="@("Approved")" />
                                            <MudSelectItem Value="@("Rejected")" />
                                        </MudSelect>
                                    </td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
            <MudCardActions>
                <MudItem Class="ml-auto mt-4">
                    <MudButton ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.PlayCircle" Variant="Variant.Filled" Color="Color.Info" Class="ml-4">@Localizer["createHOE"]</MudButton>
                </MudItem>
            </MudCardActions>
        </MudItem>
    </MudGrid>
</EditForm>

<MudDialog @bind-IsVisible="visibleStepsDialog" Options="dialogStepsOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Steps"]
            </MudText>
        </div>    
        <div class="d-flex" style="align-items: center; justify-content:center;">
        <MudText Typo="Typo.h6" Style="text-align: center;">
                @((MarkupString)HighlightedText)
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudTable Items="@segments" Class="custom-table">
            <HeaderContent>
                <MudTh Style="font-weight:bold; width: 50%">Analysis</MudTh>
                <MudTh Style="font-weight:bold">Main Point</MudTh>
                <MudTh Style="font-weight:bold">Critical Points</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Analysis</MudTd>
                <MudTd>@context.MainPoint</MudTd>
                <MudTd>
                    <ul>
                        @foreach (var point in context.CriticalPoints)
                        {

                            <li>
                                <MudText @onclick="() => HighlightTerm(point)" @ontouchstart="() => HighlightTerm(point)" Class="cursor-pointer">
                                    @point
                                </MudText>
                               </li>
                        }
                    </ul>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseStepsDialog" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
    </DialogActions>
</MudDialog>
 

<MudDialog @bind-IsVisible="visibleImagesDialog" Options="dialogImagesOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Images"]
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;">

            <InputFile id="previousEvidence" OnChange="@( (e) => UploadFiles(e, 1))" hidden multiple accept=".jpg, .jpeg, .gif, .svg, .png"></InputFile>
            <MudButton Class="flex-initial d-flex flex-grow-0 px-9 py-2"
                       HtmlTag="label"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Image"
                       for="previousEvidence">
                Load picture
            </MudButton>
            @if (capturedImages.Count == 0)
            {
                <MudItem>
                    <MudButton @onclick="() => OpenCameraDialog(1)" Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.AddAPhoto">
                        Open Camera
                    </MudButton>
                </MudItem>
            }
            else if (capturedImages.Count > 0)
            {
                <MudItem>
                    <MudButton Variant="Variant.Filled" @onclick="() => OpenCameraDialog(1)" StartIcon="@Icons.Material.Filled.AddAPhoto" Color="Color.Info">Add photo</MudButton>
                </MudItem>
            }
        </MudItem>
        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;  min-height: 50vh">
            @if (capturedImages.Count > 0)
            {
                <div style="display: flex; align-items: center; justify-content: space-between;" class="mt-4">
                    <MudItem Class="d-flex" Style="flex-direction: row; flex-wrap: wrap; justify-content: flex-start; overflow-y: scroll; max-height:50vh; scroll-behavior: smooth; justify-content: center;">

                        @foreach (var (image, index) in capturedImages.Select((image, index) => (image, index)))
                        {
                            <MudItem Class=" mr-8 mb-4">
                                <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                                    <MudTooltip Text="Delete photo" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                        <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="() => RemoveImage(index, 1)"></MudIcon>
                                    </MudTooltip>
                                </MudItem>
                                <MudImage ObjectFit="ObjectFit.Contain" Height="80" Width="130" Src=@image Alt="Evidence" Elevation="25" Class="rounded-lg" Style="cursor:pointer" @onclick="() => OpenEvidenceDialog(index, 0)" />
                            </MudItem>
                        }
                    </MudItem>

                </div>
            }
        </MudItem>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseImagesDialog" Variant="Variant.Filled">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>


<MudDialog @bind-IsVisible="visibleVideosDialog" Options="dialogVideosOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Videos"]
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;">
            <MudFileUpload T="IReadOnlyList<IBrowserFile>" OnFilesChanged="UploadFiles" Accept=".mp4, .mov, .wmv, .avi, .mkv, .flv, .webm">
                <ButtonTemplate Context="fileContext">
                    <MudButton HtmlTag="label"
                               Variant="Variant.Filled"
                               Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               for="@fileContext">
                        <MudText>Files</MudText>
                    </MudButton>
                </ButtonTemplate>
            </MudFileUpload>
            @if (MediaUris.Count != 0)
            {
                <MudButton OnClick=@(async () => await Submit()) ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Success" Class="mr-2" Disabled=@DisabledFinish>
                    @if (DisabledFinish)
                    {
                        <MudText>Loading</MudText>
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    }
                    else
                    {
                        <MudText>Upload</MudText>
                    }
                </MudButton>
            }
        </MudItem>
        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;  min-height: 50vh">
            @if (MediaUris != null && MediaUris.Count > 0)
            {
                @foreach (var item in MediaUris.ToList())
                {
                    <MudItem Class="mr-4 mb-4">
                        <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                            <MudTooltip Text="Delete photo" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="@(() => DeleteItem(item.Key))"></MudIcon>
                            </MudTooltip>
                        </MudItem>
                        <video width="300" height="150" controls @key="item.Key">
                            <source src="@item.Value.Item2">
                            Your browser does not support the video tag.
                        </video>
                    </MudItem>
                }
            }
            else
            {
                <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">No media available.</MudAlert>
            }
        </MudItem>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseVideosDialog" Variant="Variant.Filled">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>



@*Evidence Modal*@
<MudDialog DisableSidePadding="false" @bind-IsVisible="visibleEvidence" Options="dialogEvidenceOptions">
    <DialogContent>
        <MudPaper Elevation="0">
            @if (capturedImages.Count() > 0)
            {
                <MudCarousel Class="mud-width-full" Style="height: 75vh" ShowArrows=true ShowBullets=true EnableSwipeGesture=true AutoCycle="false" TData="object" @bind-SelectedIndex=@photoIndex>
                    <PreviousButtonTemplate>
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Class="ml-4" Style="cursor:pointer">
                            <MudIcon Icon="@Icons.Material.Filled.NavigateBefore" />
                        </MudAvatar>
                    </PreviousButtonTemplate>
                    <NextButtonTemplate>
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Class="mr-4" Style="cursor:pointer">
                            <MudIcon Icon="@Icons.Material.Filled.NavigateNext" />
                        </MudAvatar>
                    </NextButtonTemplate>
                    <ChildContent>
                        @foreach (var evidence in capturedImages)
                        {
                            <MudCarouselItem Transition="Transition.Fade">
                                <MudImage ObjectFit="ObjectFit.Cover" Height="720" Width="1280" Src=@evidence Alt="Evidence" Elevation="25" Class="rounded-lg" Style="max-height: 66vh; width: 100%; border-radius: 10px; margin-bottom:24px;" />
                            </MudCarouselItem>
                        }
                    </ChildContent>
                </MudCarousel>
            }
            else
            {
                <MudItem Style="height: 75vh">
                    <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                        @Localizer["there is no previous evidence :)"]
                    </MudAlert>
                </MudItem>
            }
        </MudPaper>
    </DialogContent>
</MudDialog>

@*Camera Modal*@
<MudDialog DisableSidePadding="false" @bind-IsVisible="visibleCamera" Options="dialogCameraOptions">
    <TitleContent>
        <MudItem>
            <MudText Typo="Typo.h6" Style="text-align:center">Kaizen Evidence</MudText>
        </MudItem>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 85vh; overflow-y: scroll text-align:center; justify-content: center; align-items:center;">
            <MudPaper Elevation="0">
                <CameraStreamer @ref=CameraStreamerReference
                                Width=1280
                                Height=720
                                OnRendered=OnRenderedHandler
                                OnFrame=OnFrameHandler
                                Style="max-height: 70vh; width: 100%; border-radius: 10px"
                                Class="mud-elevation-4 rounded white"
                                CameraID=@cameraId
                                Autostart />
                <MudItem style="text-align: center">
                    @if (frameCount > 0)
                    {
                        <MudButton @onclick=GetCurrentFrame Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.LinkedCamera" Color="Color.Info" Class="mt-2 mb-4">
                            Take photo
                        </MudButton>
                    }
                    else
                    {
                        <MudButton StartIcon="@Icons.Material.Filled.LinkedCamera" Color="Color.Info" Class="mt-2 mb-4" Disabled>
                            Take photo
                        </MudButton>
                    }
                </MudItem>
            </MudPaper>
        </MudContainer>
    </DialogContent>
</MudDialog>

