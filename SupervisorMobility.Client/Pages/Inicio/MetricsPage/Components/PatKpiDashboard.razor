<MudGrid Spacing="2" Class="mb-4">
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="lup-kpi-card lup-kpi-primary pa-4" Elevation="0">
            <div class="lup-kpi-head">
                <MudIcon Icon="@Icons.Material.Filled.Assessment" />
                <MudText Typo="Typo.caption">Cobertura OR_O</MudText>
            </div>
            <MudText Typo="Typo.h4" Class="font-weight-bold mt-2">@KpiCoverage%</MudText>
            <MudText Typo="Typo.caption" Class="lup-kpi-sub mt-1">Meta: @KpiCoverageTarget%</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="lup-kpi-card lup-kpi-info pa-4" Elevation="0">
            <div class="lup-kpi-head">
                <MudIcon Icon="@Icons.Material.Filled.Pending" />
                <MudText Typo="Typo.caption">Cobertura OR_P</MudText>
            </div>
            <MudText Typo="Typo.h4" Class="font-weight-bold mt-2">@KpiPeopleCoverage%</MudText>
            <MudText Typo="Typo.caption" Class="lup-kpi-sub mt-1">Meta: @KpiPeopleCoverageTarget%</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="lup-kpi-card lup-kpi-success pa-4" Elevation="0">
            <div class="lup-kpi-head">
                <MudIcon Icon="@Icons.Material.Filled.Error" />
                <MudText Typo="Typo.caption">Rotacion Mensual</MudText>
            </div>
            <MudText Typo="Typo.h4" Class="font-weight-bold mt-2">@KpiRotation%</MudText>
            <MudText Typo="Typo.caption" Class="lup-kpi-sub mt-1">Objetivo: @KpiRotationTarget%</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="lup-kpi-card lup-kpi-warn pa-4" Elevation="0">
            <div class="lup-kpi-head">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                <MudText Typo="Typo.caption">Lead Time PAT</MudText>
            </div>
            <MudText Typo="Typo.h4" Class="font-weight-bold mt-2">@KpiLeadTime</MudText>
            <MudText Typo="Typo.caption" Class="lup-kpi-sub mt-1">Creación a aprobación</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudPaper Class="pa-4 mb-4" Elevation="1" Style="border-radius: 12px; overflow-y: scroll; height: 70vh;">
    <MudItem Class="d-flex align-center mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Analytics" Color="Color.Info" Class="mr-2" />
        <MudText Typo="Typo.h6">Dashboard KPI PAT</MudText>
    </MudItem>

    <MudGrid Spacing="2">
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-2" Elevation="0" Style="background:#ffffff; border:1px solid #e2e8f0; border-radius:10px;">
                <MudText Align="Align.Center" Typo="Typo.subtitle2" Class="mb-2">Cumplimiento OR_O</MudText>
                <MudChart ChartType="ChartType.Donut" Width="100%" Height="260px"
                          InputData="@OrOChart" InputLabels="@OrOLabels" XAxisLabels="@OrOLabels" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-2" Elevation="0" Style="background:#ffffff; border:1px solid #e2e8f0; border-radius:10px;">
                <MudText Align="Align.Center" Typo="Typo.subtitle2" Class="mb-2">Cumplimiento OR_P</MudText>
                <MudChart ChartType="ChartType.Donut" Width="100%" Height="260px"
                          InputData="@OrPChart" InputLabels="@OrPLabels" XAxisLabels="@OrPLabels" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-2" Elevation="0" Style="background:#ffffff; border:1px solid #e2e8f0; border-radius:10px;">
                <MudText Align="Align.Center" Typo="Typo.subtitle2" Class="mb-2">Estatus PAT</MudText>
                <MudChart ChartType="ChartType.Pie" Width="100%" Height="260px"
                          InputData="@PatStatusChart" InputLabels="@PatStatusLabels" XAxisLabels="@PatStatusLabels" />
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="2" Class="mt-1">
        <MudItem xs="12">
            <MudPaper Class="pa-2" Elevation="0" Style="background:#ffffff; border:1px solid #e2e8f0; border-radius:10px;">
                <MudText Align="Align.Center" Typo="Typo.subtitle2" Class="mb-2">Historico anual de habilidad</MudText>
                <MudChart ChartType="ChartType.Line" Width="100%" Height="320px"
                          ChartSeries="@HistoricalAbilitySeries" XAxisLabels="@HistoricalMonths" />
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    private int KpiCoverage = 81;
    private int KpiCoverageTarget = 75;
    private int KpiPeopleCoverage = 78;
    private int KpiPeopleCoverageTarget = 70;
    private int KpiRotation = 6;
    private int KpiRotationTarget = 8;
    private int KpiLeadTime = 31;

    private double[] OrOChart => new double[] { KpiCoverage, 100 - KpiCoverage };
    private string[] OrOLabels => new string[] { "Cumple", "Gap" };

    private double[] OrPChart => new double[] { KpiPeopleCoverage, 100 - KpiPeopleCoverage };
    private string[] OrPLabels => new string[] { "Cumple", "Gap" };

    private double[] PatStatusChart => new double[] { 5, 9, 3, 2 };
    private string[] PatStatusLabels => new string[] { "Nuevo", "En progreso", "En revision", "Finalizado" };

    private string[] HistoricalMonths => new[] { "Ene", "Feb", "Mar", "Abr", "May", "Jun", "Jul", "Ago", "Sep", "Oct", "Nov", "Dic" };
    private List<ChartSeries> HistoricalAbilitySeries => new()
    {
        new ChartSeries
        {
            Name = "OR_O",
            Data = new double[] { 62, 66, 70, 74, 77, 81, 82, 84, 85, 86, 88, 89 }
        },
        new ChartSeries
        {
            Name = "OR_P",
            Data = new double[] { 58, 61, 64, 69, 73, 78, 79, 80, 82, 83, 85, 87 }
        }
    };
}



