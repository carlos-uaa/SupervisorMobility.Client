@page "/reports"

@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1

<style>

    .menu-card {
        width: 100%;
        box-shadow: 5px 5px 5px rgb(218, 214, 213 );
        border-radius: 10px;
        transition: all 0.3s ease-out;
        cursor: default;
    }

        .menu-card:hover {
            box-shadow: #9ad8f3 0px 2px 4px;
            transform: scale(1.005);
        }

        .menu-card .header {
            border-radius: 10px 10px 0 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background-color: #f1f5f9;
        }


        .menu-card .content {
            text-align: justify;
            height: 16vh;
            overflow-x: scroll;
        }

            .menu-card .content::-webkit-scrollbar {
                width: 4px;
            }

        .menu-card .footer {
            border-radius: 0 0 10px 10px;
            background-color: #f1f5f9;
        }

</style>

<PageTitle>Supervisor Mobility | Reports</PageTitle>

<MudGrid>
<MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
    <MudPaper Class="menu-card">
        <MudItem Class="pa-2 header">
            <MudChip Label
                    Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">JR</MudChip>
            <MudText>@Localizer["jobObservations"]</MudText>
            <MudImage Src="Images/servicio.png" Height="25" Width="25" />
        </MudItem>
        <MudItem Class="content">
            <MudText Class="pa-4">
                @Localizer["JobReportsDescription"]
            </MudText>
        </MudItem>
        <MudItem Class="pa-3 footer">
            <MudButton Href="reports/jobobservation" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View</MudButton>
        </MudItem>
    </MudPaper>
</MudItem>
<MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
    <MudPaper Class="menu-card">
        <MudItem Class="pa-2 header">
            <MudChip Label
                    Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">LUPR</MudChip>
            <MudText>@Localizer["toDoLup"]</MudText>
            <MudImage Src="Images/mecanografia.png" Height="25" Width="25" />
        </MudItem>
        <MudItem Class="content">
            <MudText Class="pa-4">
                @Localizer["lupReport"]
            </MudText>
        </MudItem>
        <MudItem Class="pa-3 footer">
            <MudButton Href="reports/lup" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View</MudButton>
        </MudItem>
    </MudPaper>
</MudItem>
</MudGrid>

@code {

}
