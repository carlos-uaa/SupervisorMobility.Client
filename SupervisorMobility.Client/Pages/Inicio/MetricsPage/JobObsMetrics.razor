@page "/reports/jobobservation"
@using SupervisorMobility.Client.Data.Entities.ChartData
@using SupervisorMobility.Client.Data.Entities.PaginationEntities

@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1

@inject IMetricsService MetricService
@inject IJobObservationService JobObservationService
@inject IJSRuntime JS


<PageTitle>Supervisor Mobility | Reports</PageTitle>
@if (isLoading)
{
    <div class="d-flex justify-center align-center" style="height: 50vh;">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
    </div>
}
else
{
    <MudGrid Spacing="2" Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="lup-kpi-card lup-kpi-primary pa-4" Elevation="0">
                <div class="lup-kpi-head">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary"></MudIcon>
                    <MudText Typo="Typo.caption">Total Registers</MudText>
                </div>

                <MudText Typo="Typo.h4" Class="font-weight-bold mt-2">@total</MudText>
                <MudText Typo="Typo.caption" Class="lup-kpi-sub mt-1">Total Registers</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="lup-kpi-card lup-kpi-info pa-4" Elevation="0">
                <div class="lup-kpi-head">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success"></MudIcon>
                    <MudText Typo="Typo.caption">Success percentage</MudText>
                </div>
                <MudText Typo="Typo.h4" Class="font-weight-bold mt-2">64%</MudText>
                <MudText Typo="Typo.caption" Class="lup-kpi-sub mt-1">Estados acumulados por progreso</MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="lup-kpi-card lup-kpi-success pa-4" Elevation="0">
                <div class="lup-kpi-head">
                    <MudIcon Icon="@Icons.Material.Filled.Pending" Color="Color.Tertiary"></MudIcon>
                    <MudText Typo="Typo.caption">Open percentage</MudText>
                </div>
                <MudText Typo="Typo.h4" Class="font-weight-bold mt-2">12%</MudText>
                <MudText Typo="Typo.caption" Class="lup-kpi-sub mt-1"></MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="lup-kpi-card lup-kpi-warn pa-4" Elevation="0">
                <div class="lup-kpi-head">
                    <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error"></MudIcon>
                    <MudText Typo="Typo.caption">ILU Late percentage</MudText>
                </div>
                <MudText Typo="Typo.h4" Class="font-weight-bold mt-2">31%</MudText>
                <MudText Typo="Typo.caption" Class="lup-kpi-sub mt-1">Demo: variacion contra semana previa</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <div style="overflow-y: scroll; height: 70vh; overflow-x: clip;">
        <SupervisorMobility.Client.Pages.Inicio.MetricsPage.Components.JobFiltersForm filters="@filters" filtersChanged="applyFilters" />

        <MudGrid Class="mb-4 mt-4">
            
            <MudItem xs="12" sm="12" md="2">
                <MudCard Elevation="2" Class="h-100 d-flex flex-column justify-center align-center rounded-lg" Style="background-color: var(--mud-palette-info); color: white;">
                    <MudCardContent Class="d-flex flex-column align-center text-center">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Style="font-size: 4rem;" Class="mb-2" />
                        <MudText Typo="Typo.h6" Class="font-weight-medium">@Localizer["JobObsStatusReport"]</MudText>
                        <MudText Typo="Typo.h2" Class="font-weight-bold">@total</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="12" md="10">
                <MudGrid>
                    <MudItem xs="12" sm="5">
                        <MudCard Elevation="2" Class="h-100 rounded-lg pa-4 d-flex justify-center align-center">
                            <canvas id="myPieChart" width="400" height="300"></canvas>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="7">
                        <MudCard Elevation="2" Class="h-100 rounded-lg pa-4 d-flex justify-center align-center">
                            <canvas id="myStackedBarChart" width="500" height="300" />
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudItem>
        </MudGrid>


        <MudCard Elevation="0" Class="pa-4" Style="border: 1px solid var(--mud-palette-lines-default);">
            <MudCardHeader Class="px-0 pt-0 pb-4">
                <CardHeaderContent>
                    <MudText Typo="Typo.h5" Class="font-weight-bold" Color="Color.Primary">@Localizer["JobObsLateReprogReport"]</MudText>
                </CardHeaderContent>
            </MudCardHeader>

            <MudCardContent Class="pa-0">
                <MudTabs @bind-ActivePanelIndex="reportType" Elevation="0" Color="Color.Transparent" Rounded="true" ApplyEffectsToContainer="true" TabHeaderClass="font-weight-bold mb-4">
                    
                    <MudTabPanel Icon="@Icons.Material.Filled.WarningAmber" Text=@Localizer["late"]>
                        <MudTable ServerData="@(new Func<TableState, Task<TableData<JobObservation>>>(LoadJobObs))" T="JobObservation" Hover="true" ReadOnly="true" FixedHeader="true" Height="55vh" HorizontalScrollbar="true" @ref="JobsTable" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px;">
                            <HeaderContent>
                                <MudTh Style="text-transform: uppercase; font-size: 12px; font-weight: 600; color: var(--mud-palette-text-secondary);"><MudTableSortLabel SortLabel="dt_field" T="JobObservation" InitialDirection="SortDirection.Ascending">@Localizer["distribution"]</MudTableSortLabel></MudTh>
                                <MudTh Style="text-transform: uppercase; font-size: 12px; font-weight: 600; color: var(--mud-palette-text-secondary);"><MudTableSortLabel SortLabel="op_field" T="JobObservation">@Localizer["operation"]</MudTableSortLabel></MudTh>
                                <MudTh Style="text-transform: uppercase; font-size: 12px; font-weight: 600; color: var(--mud-palette-text-secondary);"><MudTableSortLabel SortLabel="o_field" T="JobObservation">@Localizer["operator"]</MudTableSortLabel></MudTh>
                                <MudTh Style="text-transform: uppercase; font-size: 12px; font-weight: 600; color: var(--mud-palette-text-secondary);"><MudTableSortLabel SortLabel="sd_field" T="JobObservation">@Localizer["startDate"]</MudTableSortLabel></MudTh>
                                <MudTh Style="text-transform: uppercase; font-size: 12px; font-weight: 600; color: var(--mud-palette-text-secondary);"><MudTableSortLabel SortLabel="ed_field" T="JobObservation">@Localizer["endDate"]</MudTableSortLabel></MudTh>
                                <MudTh Style="text-transform: uppercase; font-size: 12px; font-weight: 600; color: var(--mud-palette-text-secondary);"><MudTableSortLabel SortLabel="st_field" T="JobObservation">@Localizer["status"]</MudTableSortLabel></MudTh>
                            </HeaderContent>

                            <RowTemplate>
                                <MudTd DataLabel=@Localizer["distribution"]><MudText Align="Align.Center">@context.Distribution?.Description</MudText></MudTd>
                                <MudTd DataLabel=@Localizer["operation"]><MudText Align="Align.Center">@context.Operations?.FirstOrDefault()?.Description</MudText></MudTd>
                                <MudTd DataLabel=@Localizer["operator"]><MudText Align="Align.Center" Class="font-weight-medium">@context.Operator?.Name</MudText></MudTd>
                                <MudTd DataLabel=@Localizer["startDate"]><MudText Align="Align.Center" Color="Color.Tertiary">@context.StartDate?.ToShortDateString()</MudText></MudTd>
                                <MudTd DataLabel=@Localizer["endDate"]><MudText Align="Align.Center" Color="Color.Tertiary">@context.EndDate?.ToShortDateString()</MudText></MudTd>
                                <MudTd DataLabel=@Localizer["status"]>
                                    <div class="d-flex justify-center">
                                        @switch (context.Status)
                                        {
                                            case 1:
                                                <MudChip Variant="Variant.Outlined" Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Size="Size.Small" Class="rounded-pill font-weight-bold">@Localizer["planned"]</MudChip>
                                                ; break;
                                            case 2:
                                                <MudChip Variant="Variant.Outlined" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Size="Size.Small" Class="rounded-pill font-weight-bold">@Localizer["inProgress"]</MudChip>
                                                ; break;
                                            case 3:
                                                <MudChip Variant="Variant.Outlined" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Size="Size.Small" Class="rounded-pill font-weight-bold">@Localizer["late"]</MudChip>
                                                ; break;
                                            case 4:
                                                <MudChip Variant="Variant.Outlined" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Size="Size.Small" Class="rounded-pill font-weight-bold">@Localizer["underReview"]</MudChip>
                                                ; break;
                                            case 7:
                                                <MudChip Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Size="Size.Small" Class="rounded-pill font-weight-bold">@Localizer["programmed"]</MudChip>
                                                ; break;
                                        }
                                    </div>
                                </MudTd>
                            </RowTemplate>

                            <NoRecordsContent>
                                <div class="py-8 d-flex flex-column justify-center align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size: 3rem;" Color="Color.Secondary" Class="mb-2" />
                                    <MudText Color="Color.Secondary">No matching records found</MudText>
                                </div>
                            </NoRecordsContent>
                            
                            <LoadingContent>
                                <div class="py-8 d-flex flex-column justify-center align-center">
                                    <MudProgressCircular Size="Size.Medium" Color="Color.Primary" Indeterminate="true" Class="mb-3" />
                                    <MudText Color="Color.Primary" Class="font-weight-medium">Loading data...</MudText>
                                </div>
                            </LoadingContent>

                            <PagerContent><MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" Class="border-top-none" /></PagerContent>
                        </MudTable>
                    </MudTabPanel>

                    <MudTabPanel Icon="@Icons.Material.Filled.EventRepeat" Text=@Localizer["reprogrammed"]>
                        <MudTable ServerData="@(new Func<TableState, Task<TableData<JobObservation>>>(LoadJobObs))" T="JobObservation" Hover="true" ReadOnly="true" FixedHeader="true" Height="55vh" HorizontalScrollbar="true" @ref="JobsTable" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px;">
                            <HeaderContent>
                                <MudTh Style="text-transform: uppercase; font-size: 12px; font-weight: 600; color: var(--mud-palette-text-secondary);"><MudTableSortLabel SortLabel="dt_field" T="JobObservation" InitialDirection="SortDirection.Ascending">@Localizer["distribution"]</MudTableSortLabel></MudTh>
                                <MudTh Style="text-transform: uppercase; font-size: 12px; font-weight: 600; color: var(--mud-palette-text-secondary);"><MudTableSortLabel SortLabel="op_field" T="JobObservation">@Localizer["operation"]</MudTableSortLabel></MudTh>
                                <MudTh Style="text-transform: uppercase; font-size: 12px; font-weight: 600; color: var(--mud-palette-text-secondary);">@Localizer["reprogrammed"]</MudTh>
                                <MudTh Style="text-transform: uppercase; font-size: 12px; font-weight: 600; color: var(--mud-palette-text-secondary);"><MudTableSortLabel SortLabel="ed_field" T="JobObservation">@Localizer["originalDate"]</MudTableSortLabel></MudTh>
                                <MudTh Style="text-transform: uppercase; font-size: 12px; font-weight: 600; color: var(--mud-palette-text-secondary);">@Localizer["reasonDateChange"]</MudTh>
                            </HeaderContent>

                            <RowTemplate>
                                <MudTd DataLabel=@Localizer["distribution"]><MudText Align="Align.Center">@context.Distribution?.Description</MudText></MudTd>
                                <MudTd DataLabel=@Localizer["operation"]><MudText Align="Align.Center">@context.Operations?.FirstOrDefault()?.Description</MudText></MudTd>
                                <MudTd DataLabel=@Localizer["reprogrammed"]><MudText Align="Align.Center" Color="Color.Warning" Class="font-weight-medium">@((context.PlannedStartDate ?? context.StartDate)?.ToShortDateString())</MudText></MudTd>
                                <MudTd DataLabel=@Localizer["originalDate"]><MudText Align="Align.Center" Style="text-decoration: line-through; color: var(--mud-palette-text-disabled);">@context.OriginalPlannedDate?.ToShortDateString()</MudText></MudTd>
                                <MudTd DataLabel=@Localizer["reasonDateChange"]><MudText Align="Align.Left" Typo="Typo.body2" Color="Color.Secondary">@context.Justification</MudText></MudTd>
                            </RowTemplate>

                            <NoRecordsContent>
                                <div class="py-8 d-flex flex-column justify-center align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size: 3rem;" Color="Color.Secondary" Class="mb-2" />
                                    <MudText Color="Color.Secondary">No matching records found</MudText>
                                </div>
                            </NoRecordsContent>

                            <LoadingContent>
                                <div class="py-8 d-flex flex-column justify-center align-center">
                                    <MudProgressCircular Size="Size.Medium" Color="Color.Primary" Indeterminate="true" Class="mb-3" />
                                    <MudText Color="Color.Primary" Class="font-weight-medium">Loading data...</MudText>
                                </div>
                            </LoadingContent>

                            <PagerContent><MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" Class="border-top-none" /></PagerContent>
                        </MudTable>
                    </MudTabPanel>

                </MudTabs>
            </MudCardContent>
        </MudCard>
    </div>
}

<style>
    .lup-page {
        padding: 0.5rem 0 1.25rem 0;
    }

    .lup-loading-wrap {
        min-height: 45vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .lup-kpi-card {
        border-radius: 14px;
        border: 1px solid rgba(0, 0, 0, 0.08);
        height: 100%;
        position: relative;
        overflow: hidden;
        background: linear-gradient(130deg, #f8fafc 0%, #ffffff 100%);
    }

    .lup-kpi-primary {
        background: linear-gradient(130deg, #f8fafc 0%, #ffffff 100%);
        border-left: 4px solid #22c55e;
    }

    .lup-kpi-info {
        border-left: 4px solid #3b82f6;
    }

    .lup-kpi-success {
        border-left: 4px solid #f59e0b;
    }

    .lup-kpi-warn {
        border-left: 4px solid #a855f7;
    }

    .lup-kpi-head {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        color: rgba(0, 0, 0, 0.72);
    }

    .lup-kpi-sub {
        color: rgba(0, 0, 0, 0.62);
    }

    .lup-card {
        border-radius: 14px;
        border: 1px solid rgba(0, 0, 0, 0.07);
        height: 100%;
    }

    .lup-card-head {
        display: flex;
        align-items: center;
        gap: 0.65rem;
    }

    .lup-filter-box,
    .lup-chart-box {
        border-radius: 10px;
        border-color: rgba(0, 0, 0, 0.08) !important;
    }

    .lup-chart-kpi {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
    }

    .lup-demo-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

</style>
