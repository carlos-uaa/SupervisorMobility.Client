@page "/lup/details/{lupId:int}"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using System.Globalization;
@using System.Net.Http.Json;

@inject IJSRuntime JSRuntime
@inject IDialogService DialogService
@inject IJobObservationService JobObservationService
@inject ILupService LupServices
@inject IFileUploadAndDownloadService FilesServices
@inject IStringLocalizer<Resource> Localizer

@inject NavigationManager NavigationManager

@*Title*@
<PageTitle>Supervisor Mobility | LUP</PageTitle>

@* Lup *@
<MudGrid Justify="Justify.Center">
    <MudItem lg="10" md="12" sm="12" xs="12">
        <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
            <MudText Typo="Typo.h6">
                Lup @_lup.LupId
            </MudText>
        </MudItem>
        <MudItem Class="ml-2">
            <MudSimpleTable Bordered Class="mt-3">
                <tbody>
                    <tr>
                        <td style="width:50%">
                            <MudDatePicker @bind-Date="_lup.CreatedDate" Label=@Localizer["startDate"] Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4" />
                        </td>
                        <td> 
                        @if(_lup.EndDate == null)
                        {
                                <MudText> @Localizer["endDate"]:  @Localizer["notYetCompleted"]</MudText>
                        }
                        else
                        {
                            <MudDatePicker @bind-Date="_lup.EndDate" Label=@Localizer["endDate"] Color="Color.Info" AdornmentColor="Color.Info" />
                        }
                        </td>
                    </tr>
                </tbody>
            </MudSimpleTable>
            <MudSimpleTable Style="overflow-x: auto;" Bordered=true Class="mt-3 mb-3">
                <thead>
                    <tr>
                        <th>
                            <MudText Style="font-weight:bold;">
                                @Localizer["pillar"]
                            </MudText>
                        </th>
                        <th>
                            <MudText Style="text-align:center; font-weight:bold;">
                                @Localizer["opportunityAreaDetected"]
                            </MudText>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        @if(_lup.Pillar == 1)
                        {
                        <td style="width: 20%">
                            S
                        </td>
                        <td>
                             <MudText >@_lup.Oportunity</MudText>
                        </td>
                        }
                    </tr>
                    <tr>
                        @if (_lup.Pillar == 2)
                        {
                        <td>
                            Q
                        </td>
                        <td>
                                <MudText>@_lup.Oportunity</MudText>
                        </td>
                        }
                    </tr>
                    <tr>
                        @if (_lup.Pillar == 3)
                        {
                        <td>
                            D
                        </td>
                        <td>
                                <MudText>@_lup.Oportunity</MudText>
                        </td>
                        }
                    </tr>
                    <tr>
                        @if (_lup.Pillar == 4)
                        {
                        <td>
                            C
                        </td>
                        <td>
                                <MudText>@_lup.Oportunity</MudText>
                        </td>
                        }
                    </tr>
                    <tr>
                        @if (_lup.Pillar == 5)
                        {
                        <td>
                             @Localizer["other"]
                        </td>
                        <td>
                                <MudText>@_lup.Oportunity</MudText>
                        </td>
                        }                        
                    </tr>
                </tbody>
            </MudSimpleTable>
            <MudSimpleTable Style="overflow-x: auto;" Bordered>
                <tbody>
                    <tr>
                        <td style="font-weight:bold; width: 20%"> @Localizer["jobObservation"] Id</td>
                        <td>
                            <MudTooltip Text=@Localizer["goToJobObservation"] Arrow="true" Placement="Placement.Right" Color="Color.Info">
                                <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                    <MudChip Variant="Variant.Text" Color="Color.Info" @onclick="(() => GoToJobObservation(_lup.JobObservationId))"> @_lup.JobObservationId</MudChip>
                                </MudBadge>
                            </MudTooltip>
                            <MudChip Variant="Variant.Text" Color="Color.Info"> @jobObservation.Distribution?.Description</MudChip>
                            <MudChip Variant="Variant.Text" Color="Color.Info"> @jobObservation.Operation?.Description</MudChip>
                        </td>
                    </tr>
                    <tr>
                        <td style="font-weight:bold"> @Localizer["observer"]</td>
                        <td>@_lup.Observer</td>
                    </tr>
                    <tr>
                        <td style="font-weight:bold">Q3</td>
                        <td>@_lup.Q3</td>
                    </tr>
                    <tr>
                        <td style="font-weight:bold">Q4</td>
                        <td>@_lup.Q4</td>
                    </tr>
                    <tr>
                        @if (!(_lup.Justification == null || _lup.Justification.Length == 0) && _lup.Status == 4)
                        {
                            <td style="font-weight:bold"> @Localizer["justification"]</td>
                            <td>@_lup.Justification</td>
                        }
                    </tr>
                    <tr>
                        <td style="font-weight:bold">@Localizer["status"]</td>
                        <td>
                            @switch (_lup.Status)
                            {
                                case 1:
                                    <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["new"]</MudChip>
                                    break;
                                case 2:
                                    <MudChip Variant="Variant.Text" Color="Color.Info" Size="Size.Small">@Localizer["inProgress"]</MudChip>
                                    break;
                                case 3:
                                    <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small">@Localizer["finished"]</MudChip>
                                    break;
                                case 4:
                                    <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small">@Localizer["canceled"]</MudChip>
                                    break;
                            }
                            
                        </td>
                    </tr>
                </tbody>
            </MudSimpleTable>
                <MudSimpleTable Bordered Class="mt-3 mb-10">
                <thead>
                    <tr>
                        <td>
                            <MudText Typo="Typo.h6">
                                @Localizer["evidence"]
                            </MudText>
                        </td>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="d-flex" style="flex-direction: row; flex-wrap: wrap; justify-content: flex-start;">
                            @if (_lup.Evidences.Count > 0)
                            {
                                @foreach (var evidence in _lup.Evidences)
                                {
                                    <MudPaper Class="mr-5 mt-5">
                                        <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center mt-5">
                                            @switch (evidence?.ContentType)
                                            {
                                                case "application/pdf":
                                                    <img src="Images/pdf.png" Height="70" Width="70" />
                                                    break;

                                                case "application/msword":
                                                    // Para documentos Word con extensión .doc
                                                    <img src="Images/doc.png" Height="70" Width="70" />

                                                    break;

                                                case "application/vnd.openxmlformats-officedocument.wordprocessingml.document":
                                                    <img src="Images/docx.png" Height="70" Width="70" />

                                                    // Para documentos Word con extensión .docx
                                                    break;

                                                case "application/vnd.ms-powerpoint":
                                                    <img src="Images/ppt.png" Height="70" Width="70" />
                                                    // Para presentaciones PowerPoint con extensión .ppt
                                                    break;

                                                case "application/vnd.openxmlformats-officedocument.presentationml.presentation":
                                                    <img src="Images/pptx.png" Height="70" Width="70" />

                                                    // Para presentaciones PowerPoint con extensión .pptx
                                                    break;

                                                case "application/vnd.ms-excel":
                                                    // Para hojas de cálculo Excel con extensión .xls
                                                    <img src="Images/xls.png" Height="70" Width="70" />
                                                    break;

                                                case "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet":
                                                    // Para hojas de cálculo Excel con extensión .xlsx
                                                    <img src="Images/xlsx.png" Height="70" Width="70" />

                                                    break;

                                                case "image/jpeg":
                                                    <img src="Images/jpg.png" Height="70" Width="70" />

                                                    // Para imágenes JPEG con extensión .jpg o .jpeg
                                                    break;

                                                case "image/png":
                                                    // Para imágenes PNG con extensión .png
                                                    <img src="Images/png.png" Height="70" Width="70" />

                                                    break;

                                                case "image/gif":
                                                    // Para imágenes GIF con extensión .gif
                                                    <img src="Images/gif.png" Height="70" Width="70" />
                                                    break;

                                                default:
                                                    <img src="Images/error.png" Height="70" Width="70" />
                                                    break;
                                            }
                                            <MudTooltip Text=@Localizer["download"] Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true">
                                                <MudButton @onclick="@(() => DownloadFile(evidence.FileUploadId, evidence?.FileName) )">
                                                    <MudItem>
                                                        <MudChip Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer" Icon="@Icons.Material.Filled.Download" Text="@evidence?.FileName" Color="Color.Info" />
                                                    </MudItem> 
                                                </MudButton>
                                            </MudTooltip>
                                        </MudItem>

                                    </MudPaper>
                                }
                            }
                            else
                            {
                                <span> @Localizer["noFilesUploadedYet"]</span>
                            }
                        </td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudItem>
    </MudItem>
</MudGrid>
