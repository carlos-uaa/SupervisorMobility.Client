@page "/checklistcategories/sequence"
@inject IChecklistService ChecklistService

<MudIconButton Href="/checklistcategories" Icon="@Icons.Material.Filled.ArrowLeft" aria-label="back"></MudIconButton>

<MudDropContainer T="ChecklistCategory" Items="_checklistCategories" ItemsSelector="@((item,dropzone) => item.Container == dropzone)" ItemDropped="ItemUpdated" Class="d-flex flex-wrap flex-grow-1">
    <ChildContent>
        <MudDropZone T="ChecklistCategory" Identifier="CategoryContainer" Class="rounded mud-background-gray pa-6 ma-8 flex-grow-1" AllowReorder="true">
            <MudText Typo="Typo.h6" Class="mb-4">
                Reorder categories
            </MudText>
        </MudDropZone>
    </ChildContent>
    <ItemRenderer>
            <MudPaper Elevation="25" Class="pa-4 my-4">
                @($"{context.Description}")
            </MudPaper>
    </ItemRenderer>
</MudDropContainer>