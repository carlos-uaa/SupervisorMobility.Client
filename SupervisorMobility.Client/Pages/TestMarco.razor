@page "/TestMarco"
@using MudBlazor
@using System.Globalization
@using System.Text
@using System.Text.RegularExpressions

<MudButton OnClick="AddSection" Variant="Variant.Filled">Añadir Sección</MudButton>

<MudSimpleTable>
    <MudTr>
        <MudTh>Sección</MudTh>
        <MudTh>Análisis</MudTh>
        <MudTh>Pasos</MudTh>
        <MudTh>Punto Crítico</MudTh>
    </MudTr>

    @foreach (var (section, indexSection) in Sections.Select((section, indexSection) => (section, indexSection)))
    {

        <MudTr>
            <MudTd colspan="4">
                @indexSection
                <MudButton OnClick="() => AddAnalisis(indexSection)" Variant="Variant.Filled">Añadir Análisis</MudButton>
            </MudTd>
        </MudTr>
        <MudTr>
            <MudTd>
            </MudTd>
            <MudTd>
                @foreach (var (analisis, indexAnalisis) in section.Analisis.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                {
                    <MudTextField @bind-Value="Sections[indexSection].Analisis[indexAnalisis].Text" Label="Añadir Análisis" Variant="Variant.Filled" Class="mb-2" />

                }

            </MudTd>
            <MudTd>
                @if (section.Analisis.Any())
                {
                    <MudButton OnClick="() => AddPaso(indexSection)" Variant="Variant.Filled">Añadir Paso</MudButton>
                }
                @foreach (var (paso, indexPaso) in section.Pasos.Select((paso, indexPaso) => (paso, indexPaso)))
                {
                    <MudTextField @bind-Value="Sections[indexSection].Pasos[indexPaso]" Label="Paso" Variant="Variant.Filled" Class="mb-2" />
                }

            </MudTd>
            <MudTd>
                @if (section.Pasos.Any())
                {

                    @foreach (var (analisis, indexAnalisis) in section.Analisis.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                    {
                        @if (!string.IsNullOrEmpty(Sections[indexSection].Analisis[indexAnalisis].PuntoCritico))
                        {

                            <MudText Typo="Typo.subtitle1">
                                <MudHighlighter Text="@(GetAnalisisText(indexSection, indexAnalisis))" HighlightedText="@(GetHighlightedText(indexSection, indexAnalisis))" />
                            </MudText>
                        }

                        <MudTextField @bind-Value="Sections[indexSection].Analisis[indexAnalisis].PuntoCritico" Label="Punto Crítico" Variant="Variant.Filled" Class="mb-2" @onchange="(e) => ApplyHighlights(indexSection, indexAnalisis)" />
                        <MudTextField @bind-Value="Sections[indexSection].Analisis[indexAnalisis].Razon" Label="Razón" Variant="Variant.Filled" Class="mb-2" />
                    }
                }
            </MudTd>

        </MudTr>
    }
</MudSimpleTable>

@code {
    public List<Section> Sections { get; set; } = new List<Section>();

    public class Section
    {
        public List<Analisis> Analisis { get; set; } = new List<Analisis>();
        public List<string> Pasos { get; set; } = new List<string>();
    }

    public class Analisis
    {
        public string Text { get; set; }
        public string PuntoCritico { get; set; } = string.Empty;
        public string Razon { get; set; }
    }



    private void AddSection()
    {
        Sections.Add(new Section());
    }

    private void AddAnalisis(int sectionIndex)
    {
        Sections[sectionIndex].Analisis.Add(new Analisis());
    }

    private void AddPaso(int sectionIndex)
    {
        Sections[sectionIndex].Pasos.Add("");
    }

    private void ApplyHighlights(int sectionIndex, int analisisIndex)
    {
        var analisis = Sections[sectionIndex].Analisis[analisisIndex];
        var text = analisis.Text;
        var term = analisis.PuntoCritico;

        if (string.IsNullOrEmpty(term))
        {
            return;
        }

        var highlightedText = ReplaceInsensitive(text, term);
        analisis.Text = highlightedText;
    }

    private static string Normalize(string input)
    {
        if (string.IsNullOrEmpty(input))
        {
            return string.Empty;
        }

        return input.Normalize(NormalizationForm.FormD)
            .Where(c => CharUnicodeInfo.GetUnicodeCategory(c) != UnicodeCategory.NonSpacingMark)
            .Aggregate(new StringBuilder(), (sb, c) => sb.Append(c))
            .ToString()
            .ToLowerInvariant();
    }

    private static string ReplaceInsensitive(string text, string search)
    {
        if (string.IsNullOrEmpty(search))
        {
            return text;
        }

        string normalizedText = Normalize(text);
        string normalizedSearch = Normalize(search);

        var result = Regex.Replace(normalizedText, Regex.Escape(normalizedSearch), m =>
        {
            int startIndex = normalizedText.IndexOf(m.Value, m.Index, StringComparison.OrdinalIgnoreCase);
            string originalMatch = text.Substring(startIndex, search.Length);
            return $"<mark>{originalMatch}</mark>";
        }, RegexOptions.IgnoreCase | RegexOptions.CultureInvariant);

        return result;
    }

    private string GetAnalisisText(int sectionIndex, int analisisIndex)
    {
        return Sections[sectionIndex].Analisis[analisisIndex].Text;
    }

    private string GetHighlightedText(int sectionIndex, int analisisIndex)
    {
        return Sections[sectionIndex].Analisis[analisisIndex].PuntoCritico;
    }
}
