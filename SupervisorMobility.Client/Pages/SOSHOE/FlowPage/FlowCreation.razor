@page "/soshoe/flow/create"
@using Blazor.Diagrams.Components
@inject IJSRuntime JSRuntime

<MudPaper Height="75vh" Style="overflow:hidden; position:relative;">
    <MudDrawerContainer Class="mud-height-full">
        <MudDrawer Open Fixed="false" Elevation="1" Variant="@DrawerVariant.Mini" Style="scrollbar-width: none;">
            <MudNavMenu>
                <MudItem Class="pa-2">
                    <MudText Typo="Typo.subtitle1">Figuras</MudText>
                </MudItem>
                <MudItem Class="pa-2">
                    <a class="data-figure" style="overflow: hidden; width: 100px; height: 98px; padding: 1px; opacity: 1;" draggable="true" data-figure-type="Terminal">
                        <svg style="left: 1px; top: 1px; width: 98px; height: 96px; display: block; position: relative; overflow: hidden; pointer-events: none;">
                            <g transform="translate(0.5,0.5)" style="visibility: visible; pointer-events: none;">
                                <rect x="4.7" y="22.9" width="84.7" height="42.3" rx="28" ry="28" fill="none" stroke="rgb(0, 0, 0)" stroke-width="1.3" style="pointer-events: none;"></rect>
                            </g>
                        </svg>
                    </a>
                </MudItem>
                <MudItem Class="pa-2">
                    <a class="data-figure" style="overflow: hidden; width: 100px; height: 98px; padding: 1px; opacity: 1;" draggable="true" data-figure-type="Proceso">
                        <svg style="left: 1px; top: 1px; width: 98px; height: 96px; display: block; position: relative; overflow: hidden; pointer-events: none;">
                            <g transform="translate(0.5,0.5)" style="visibility: visible; pointer-events: none;">
                                <rect x="10" y="10" width="80" height="50" fill="none" stroke="rgb(0, 0, 0)" stroke-width="1.3"></rect>
                            </g>
                        </svg>
                    </a>
                </MudItem>
                <MudItem Class="pa-2">
                    <a class="data-figure" style="overflow: hidden; width: 115px; height: 80px; padding: 1px; opacity: 1;" draggable="true" data-figure-type="DecisionRombo">
                        <svg width="115" height="80" style="display: block; position: relative; overflow: hidden;">
                            <polygon points="57.5,0 115,40 57.5,80 0,40" fill="none" stroke="rgb(0, 0, 0)" stroke-width="1.3"></polygon>
                        </svg>
                    </a>
                </MudItem>
                <MudItem Class="pa-2">
                    <a class="data-figure" style="overflow: hidden; width: 115px; height: 80px; padding: 1px; opacity: 1;" draggable="true" data-figure-type="Decision">
                        <svg width="115" height="80" style="display: block; position: relative; overflow: hidden;">
                            <polygon points="10,40 40,10 80,10 110,40 80,70 40,70" fill="none" stroke="rgb(0, 0, 0)" stroke-width="1.3"></polygon>
                        </svg>
                    </a>
                </MudItem>
                <MudItem Class="pa-2">
                    <a class="data-figure" style="overflow: hidden; width: 100px; height: 98px; padding: 1px; opacity: 1;" draggable="true" data-figure-type="Conexion">
                        <svg width="100" height="100" style="display: block; position: relative; overflow: hidden;">
                            <circle cx="50" cy="50" r="40" fill="none" stroke="rgb(0, 0, 0)" stroke-width="1.3"></circle>
                        </svg>
                    </a>
                </MudItem>
                <MudItem Class="pa-2">
                    <a class="data-figure" style="overflow: hidden; width: 100px; height: 70px; padding: 1px; opacity: 1;" draggable="true" data-figure-type="Suplemento">
                        <svg width="100" height="70" style="display: block; position: relative; overflow: hidden;">
                            <path d="M85,10 H15 V60 H85" fill="none" stroke="black" stroke-width="1.3"></path>
                        </svg>
                    </a>
                </MudItem>
            </MudNavMenu>
        </MudDrawer>

        <div class="mud-height-full" style="display: flex; align-items: center; flex-direction: column;">
            <div class="diagram-container" @ref="container" @ondrop="OnDrop">
                <CascadingValue Value="Diagram" IsFixed="true">
                    <DiagramCanvas>
                    </DiagramCanvas>
                </CascadingValue>
            </div>
            @*
            <br>
            <MudGrid>
                <MudItem xs="6">
                    <MudButton OnClick="SaveDiagramAsJson">Guardar JSON</MudButton>
                    <MudTextField @bind-Value="diagramJson" ReadOnly="true" />
                </MudItem>
            </MudGrid>
            <br>
            <MudGrid>
                <MudItem xs="6">
                    <MudTextField @bind-Value="inputJson" Placeholder="JSON" />
                    <MudButton OnClick="LoadDiagramFromJson">Cargar JSON</MudButton>
                </MudItem>
            </MudGrid>
        *@
        </div>
    </MudDrawerContainer>
</MudPaper>
