            </tr>
            <tr>

                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>
                <th rowspan="2" colspan="3">Tiempo de aprendizaje</th>
