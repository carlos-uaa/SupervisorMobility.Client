@page "/Analysis/Details/{AnalysisId:int}"

@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1
@inject ISOSAnalysisService SOSAnalysisServices

<style>
    .vertical {
        writing-mode: tb-rl;
        -webkit-transform: rotate(0deg);
        -moz-transform: rotate(0deg);
        -o-transform: rotate(0deg);
        -ms-transform: rotate(0deg);
        transform: rotate(0deg);
        white-space: nowrap;
        display: block;
        bottom: 0;
        width: 20px;
        height: 20px;
        text-align: center !important;
    }
</style>

@if (ShowLoading)
{
    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
        <ItemTemplate>
            <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                <MudItem class="d-flex flex-column justify-center align-self-center">
                    <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                </MudItem>
                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
            </div>
        </ItemTemplate>
    </MudCarousel>
}
else
{
    <MudSimpleTable>
        <thead>
            <tr>
                <th rowspan="2" colspan="3">Nombre de la Operación</th>
                <th rowspan="2" colspan="3">@_sosAnalysis.SOSHub.ProcessSheet</th>
                <th colspan="3">No. De Revision</th>
                <th colspan="3">N</th>
                <th colspan="3">1</th>
                <th colspan="3">2</th>
                <th colspan="3"></th>
            </tr>
            <tr>

                <th colspan="3">Fecha</th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>
                <th rowspan="2" colspan="3">Equipo de Seguridad</th>
                <th rowspan="2" colspan="3">
                    @foreach (var equipment in _sosAnalysis.SOSHub.SafetyEquipment)
                    {
                        <MudText>@equipment.EquipmentName</MudText>
                    }
                </th>

                <th colspan="3">Punto Revisado (Cambio)</th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>
                <th rowspan="7" colspan="1" class="vertical">Confirmado Por</th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>
                <th rowspan="2" colspan="3">Herramientas</th>
                <th rowspan="2" colspan="3">
                    @foreach (var tool in _sosAnalysis.SOSHub.ToolsUsed)
                    {
                        <MudText>@tool.ToolName</MudText>
                    }
                </th>

                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>

                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>
                <th rowspan="2" colspan="3">Modelo</th>
                <th rowspan="2" colspan="3"><MudText>@_sosAnalysis.SOSHub.AppliedModel?.Description</MudText></th>

                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>

                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>
                <th rowspan="2" colspan="3">Tiempo de aprendizaje</th>
                <th rowspan="2" colspan="3">
                    <MudAutocomplete T="int"
                                     Label=@Localizer["Cycles"]
                                     Variant="Variant.Text"
                                     AnchorOrigin="Origin.BottomCenter"
                                     @bind-Value="cycleId"
                                     OpenIcon="@Icons.Material.Filled.AccessTime"
                                     AdornmentColor="Color.Info"
                                     Clearable
                                     ResetValueOnEmptyText
                                     ShowProgressIndicator="true" ProgressIndicatorColor="Color.Info"
                                     MaxItems="10"
                                     ReadOnly>
                    </MudAutocomplete>
                </th>

                <th colspan="3">Supervisor Gral (Aprovo)</th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>

                <th colspan="3">Supervisor (Elaboro)</th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td colspan="1">No.</td>
                <td colspan="3">Análisis</td>
                <td colspan="1">No.</td>
                <td colspan="1">Pasos Principales</td>
                <td colspan="2">Tiempo</td>
                <td colspan="4">Punto Critico (Razon)</td>
                <td colspan="10">Ilustracion, Notas operacion, otros</td>
            </tr>

            @foreach (var (sect, indexSection) in _sosAnalysis.SOSHub.Sections.Select((sect, indexSection) => (sect, indexSection)))
            {
                @foreach (var analysis in sect.Analyses)
                {
                    <tr>
                        @if (analysis == sect.Analyses.First())
                        {
                            <td colspan="1" style="border-left: 2px solid #000; border-top: 2px solid #000;" >@getAnalysisIndex()</td>
                            <td colspan="3" style="border-top: 2px solid #000;">@analysis.Text</td>
                        }
                        else
                        {
                            <td colspan="1" style="border-left: 2px solid #000;">@getAnalysisIndex()</td>
                            <td colspan="3" >@analysis.Text</td>
                        }

                        @if (analysis == sect.Analyses.First())
                        {
                            int TotalRowSpan = sect.Analyses.Count();
                            <td colspan="1" style="border-top: 2px solid #000; border-bottom: 2px solid #000" rowspan="@TotalRowSpan">@(indexSection + 1)</td>
                            <td colspan="1" style="border-top: 2px solid #000; border-bottom: 2px solid #000" rowspan="@TotalRowSpan">@sect.Step</td>
                            <td colspan="2" style="border-top: 2px solid #000; border-bottom: 2px solid #000" rowspan="@TotalRowSpan">Tiempo Seccion @(indexSection + 1)</td>
                        }

                    @if (analysis == sect.Analyses.First())
                    {
                            <td colspan="4" style=" border-top: 2px solid #000; border-right: 2px solid #000;">

                            @foreach (var (cp, cpIndex) in analysis.CriticalPoints.Select((cp, cpIndex) => (cp, cpIndex)))
                            {
                                <MudItem>
                                    <MudText>@cp</MudText>
                                    <MudText>
                                        @ReasonFormat(analysis.Reasons[cpIndex])
                                    </MudText>
                                </MudItem>
                            }
                        </td>
                    }else{
                        <td colspan="4" style="border-right: 2px solid #000;">

                                @foreach (var (cp, cpIndex) in analysis.CriticalPoints.Select((cp, cpIndex) => (cp, cpIndex)))
                                {
                                    <MudItem>
                                        <MudText>@cp</MudText>
                                        <MudText>
                                            @ReasonFormat(analysis.Reasons[cpIndex])
                                        </MudText>
                                    </MudItem>
                                }
                            </td>
                    }
                         

                        @if (sect != _sosAnalysis.SOSHub.Sections.First())
                        {
                            int TotalRowSpanImages = (_sosAnalysis.SOSHub.Sections.Select(a => a.Analyses).Count() );
                            <td colspan="10" style="" rowspan="@TotalRowSpanImages"></td>
                        }
                    </tr>

                   @*  @if (analysis != sect.Analyses.Last())
                    {
                        <tr>
                            <td colspan="1" style="border-left: 2px solid #000;"></td>
                            <td colspan="3"></td>
                            <td colspan="4" style="border-right: 2px solid #000;"></td>
                        </tr>
                    } *@
                }
            }
        </tbody>
    </MudSimpleTable>
}


@code {
    [Parameter]
    public int? AnalysisId { get; set; }

    SOSAnalysis _sosAnalysis { get; set; } = new();
    int cycleId = 0;
    int IndexAnalysis { get; set; } = 0;

    //Loading
    private IList<string> _sourceMsgLoading = new List<string>();
    private IList<Color> _Colors = new List<Color>() { Color.Default, Color.Primary, Color.Secondary, Color.Success, Color.Info, Color.Default, Color.Primary, Color.Secondary, Color.Success, Color.Info };
    public bool ShowLoading = true;

    protected async override Task OnInitializedAsync()
    {

        _sourceMsgLoading.Add($"{Localizer1["Loading1"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading2"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading3"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading4"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading5"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading6"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading7"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading8"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading9"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading10"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading11"]}");

        _sosAnalysis = await SOSAnalysisServices.GetSOSAnalysis((int)AnalysisId, true, true, true, true, true);
        cycleId = _sosAnalysis.SOSHub.TrainingTime != null ? GetCycleId(_sosAnalysis.SOSHub.TrainingTime) : 0;

        ShowLoading = false;
        StateHasChanged();
    }


    public static int GetCycleId(string trainingTime)
    {
        string cycleIdString = trainingTime.Split(' ').First();

        if (int.TryParse(cycleIdString, out int cycleId))
        {
            return cycleId;
        }
        else
        {
            return 0;
        }
    }

    public int getAnalysisIndex()
    {
        IndexAnalysis++;
        int index = IndexAnalysis;
        return index;
    }

    public static string ReasonFormat(string input)
    {
        if (string.IsNullOrEmpty(input))
        {
            return input;
        }

        if (!input.StartsWith("("))
        {
            input = "(" + input;
        }

        if (!input.EndsWith(")"))
        {
            input = input + ")";
        }

        return input;
    }
}
