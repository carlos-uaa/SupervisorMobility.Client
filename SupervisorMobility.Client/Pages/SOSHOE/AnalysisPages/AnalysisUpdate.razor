@page "/Analysis/Update/{AnalysisId:int}"

@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1
@inject ISOSAnalysisService SOSAnalysisServices

<style>
    .vertical {
        writing-mode: tb-rl;
        -webkit-transform: rotate(0deg);
        -moz-transform: rotate(0deg);
        -o-transform: rotate(0deg);
        -ms-transform: rotate(0deg);
        transform: rotate(0deg);
        white-space: nowrap;
        display: block;
        bottom: 0;
        width: 20px;
        height: 20px;
        text-align: center !important;
    }

    .border-left {
        border-left: 2px solid #ababab;
    }

    .table-header td{
        background-color: #f5f5f6;
    }

    .grey-background {
        background-color: #f5f5f6;
    }

</style>

@if (ShowLoading)
{
    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
        <ItemTemplate>
            <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                <MudItem class="d-flex flex-column justify-center align-self-center">
                    <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                </MudItem>
                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
            </div>
        </ItemTemplate>
    </MudCarousel>
}
else
{
    <MudSimpleTable Class="pb-10" Dense>
        <thead>
            <tr class="table-header">
                <th rowspan="2" colspan="3">Nombre de la Operación</th>
                <th rowspan="2" colspan="3">@_sosAnalysis.SOSHub.ProcessSheet</th>
                <th colspan="3">No. De Revision</th>
                <th colspan="3">N</th>
                <th colspan="3">1</th>
                <th colspan="3">2</th>
                <th colspan="3"></th>
            </tr>
            <tr>

                <th colspan="3">Fecha</th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>
                <th rowspan="2" colspan="3">Equipo de Seguridad</th>
                <th rowspan="2" colspan="3">
                    @if (_sosAnalysis.SOSHub.SafetyEquipment.Any())
                    {
                        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: center; align-items: center;">

                            @foreach (var equipment in _sosAnalysis.SOSHub.SafetyEquipment)
                            {
                                <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Warning" Variant="Variant.Outlined">
                                    <MudChip Color="Color.Warning" Icon="@Icons.Material.Filled.Engineering" Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer">
                                        @(equipment.EquipmentName)
                                    </MudChip>
                                </MudButton>
                            }
                        </MudItem>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Currently, there is no equipment.</MudAlert>
                    }

                </th>

                <th colspan="3">Punto Revisado (Cambio)</th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>
                <th rowspan="7"  class="vertical">Confirmado Por</th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>
                <th rowspan="2" colspan="3">Herramientas</th>
                <th rowspan="2" colspan="3">
                    @if (_sosAnalysis.SOSHub.ToolsUsed.Any())
                    {
                        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: center; align-items: center;">

                            @foreach (var tool in _sosAnalysis.SOSHub.ToolsUsed)
                            {
                                <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined">
                                    <MudChip Color="Color.Info" Icon="@Icons.Material.Filled.Build" Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer">
                                        @(tool.ToolName)
                                    </MudChip>
                                </MudButton>
                            }
                        </MudItem>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Currently, there are no tools.</MudAlert>
                    }
                </th>

                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>

                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>
                <th rowspan="2" colspan="3">Modelo</th>
                <th rowspan="2" colspan="3"><MudText>@_sosAnalysis.SOSHub.AppliedModel?.Description</MudText></th>

                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>

                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>
                <th rowspan="2" colspan="3">Tiempo de aprendizaje</th>
                <th rowspan="2" colspan="3">
                    <MudAutocomplete T="int"
                                     Label=@Localizer["Cycles"]
                                     Variant="Variant.Text"
                                     AnchorOrigin="Origin.BottomCenter"
                                     @bind-Value="cycleId"
                                     OpenIcon="@Icons.Material.Filled.AccessTime"
                                     AdornmentColor="Color.Info"
                                     Clearable
                                     ResetValueOnEmptyText
                                     ShowProgressIndicator="true" ProgressIndicatorColor="Color.Info"
                                     MaxItems="10"
                                     ReadOnly>
                    </MudAutocomplete>
                </th>

                <th colspan="3">Supervisor Gral (Aprobó)</th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
            <tr>

                <th colspan="3">Supervisor (Elaboró)</th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
                <th colspan="3"></th>
            </tr>
        </thead>
        <tbody>
            <tr class="table-header">
                <td colspan="1" >No.</td>
                <td colspan="3">Análisis</td>
                <td colspan="1">No.</td>
                <td colspan="1">Pasos Principales</td>
                <td colspan="2">Tiempo</td>
                <td colspan="4">Punto Critico (Razon)</td>
                <td colspan="10">Ilustracion, Notas operacion, otros</td>
            </tr>

            @foreach (var (sect, indexSection) in _sosAnalysis.SOSHub.Sections.Select((sect, indexSection) => (sect, indexSection)))
            {
                @foreach (var analysis in sect.Analyses)
                {
                    <tr >
                        @if (sect == _sosAnalysis.SOSHub.Sections.Last())
                        {
                            <td colspan="1" style="border-left: 2px solid #ababab; border-top: 2px solid #ababab; border-bottom: 2px solid #ababab;">@getAnalysisIndex()</td>
                            <td colspan="3" style="border-top: 2px solid #ababab; border-bottom: 2px solid #ababab;">@analysis.Text</td>
                        }
                        else if (analysis == sect.Analyses.First())
                        {
                            <td colspan="1" style="border-left: 2px solid #ababab; border-top: 2px solid #ababab;">@getAnalysisIndex()</td>
                            <td colspan="3" style="border-top: 2px solid #ababab; ">@analysis.Text</td>
                        }
                        else
                        {
                            <td colspan="1" style="border-left: 2px solid #ababab; border-bottom: 2px solid #ababab;">@getAnalysisIndex()</td>
                            <td colspan="3">@analysis.Text</td>
                        }

                        @if (analysis == sect.Analyses.First())
                        {
                            int TotalRowSpan = sect.Analyses.Count();
                            <td colspan="1" style="border-top: 2px solid #ababab; border-bottom: 2px solid #ababab; " rowspan="@TotalRowSpan">@(indexSection + 1)</td>
                            <td colspan="1" style="border-top: 2px solid #ababab; border-bottom: 2px solid #ababab;" rowspan="@TotalRowSpan">@sect.Step</td>
                            <td colspan="2" style="border-top: 2px solid #ababab; border-bottom: 2px solid #ababab;" rowspan="@TotalRowSpan">
                                <MudInput Value="@($"Time {indexSection + 1}")" Variant="Variant.Outlined" Margin="Margin.Dense" />

                            </td>
                        }

                        @if (sect == _sosAnalysis.SOSHub.Sections.Last())
                        {
                            <td colspan="4" style=" border-top: 2px solid #ababab; border-right: 2px solid #ababab; border-bottom: 2px solid #ababab;">

                                @foreach (var (cp, cpIndex) in analysis.CriticalPoints.Select((cp, cpIndex) => (cp, cpIndex)))
                                {
                                    <MudItem>
                                        <MudText>@cp</MudText>
                                        <MudText>
                                            @ReasonFormat(analysis.Reasons[cpIndex])
                                        </MudText>
                                    </MudItem>
                                }
                            </td>
                        }
                        else if (analysis == sect.Analyses.First())
                        {
                            <td colspan="4" style=" border-top: 2px solid #ababab; border-right: 2px solid #ababab;">

                                @foreach (var (cp, cpIndex) in analysis.CriticalPoints.Select((cp, cpIndex) => (cp, cpIndex)))
                                {
                                    <MudItem>
                                        <MudText>@cp</MudText>
                                        <MudText>
                                            @ReasonFormat(analysis.Reasons[cpIndex])
                                        </MudText>
                                    </MudItem>
                                }
                            </td>
                        }
                        else
                        {
                            <td colspan="4" style="border-right: 2px solid #ababab; border-bottom: 2px solid #ababab;">

                                @foreach (var (cp, cpIndex) in analysis.CriticalPoints.Select((cp, cpIndex) => (cp, cpIndex)))
                                {
                                    <MudItem>
                                        <MudText>@cp</MudText>
                                        <MudText>
                                            @ReasonFormat(analysis.Reasons[cpIndex])
                                        </MudText>
                                    </MudItem>
                                }
                            </td>
                        }


                        @if (sect == _sosAnalysis.SOSHub.Sections.First())
                        {
                            int totalAnalyses = _sosAnalysis.SOSHub.Sections.Sum(section => section.Analyses.Count());
                            int totalCriticalPoints = _sosAnalysis.SOSHub.Sections
                            .SelectMany(section => section.Analyses)
                            .Sum(analysis => analysis.CriticalPoints.Count());
                            int TotalRowSpanImages = totalAnalyses + totalCriticalPoints;
                            <td colspan="10" rowspan="@TotalRowSpanImages">
                                @if (capturedImages.Any())
                                {
                                    @foreach (var (image, index) in capturedImages.Select((image, index) => (image, index)))
                                    {
                                        <MudItem Class="mb-4">
                                            <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                                            </MudItem>
                                            <MudImage ObjectFit="ObjectFit.Contain" Height="160" Width="260" Src=@image Alt="Evidence" Elevation="25" Class="rounded-lg" />
                                        </MudItem>
                                    }
                                }
                            </td>
                        }
                    </tr>

                }
            }
        </tbody>
    </MudSimpleTable>
}



