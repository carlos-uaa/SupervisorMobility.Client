                        <MudText>@Localizer["HOESOSSequence"]</MudText>
                        <MudImage Src="Images/admin.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["SOSSequenceDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="soshoe/Sequence" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        @* <MudButton Href="soshoe/Generate/Sequence" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Generate</MudButton> *@
                    </MudItem>
                </MudPaper>
            </MudItem>
        }

    </MudGrid>
    }
}