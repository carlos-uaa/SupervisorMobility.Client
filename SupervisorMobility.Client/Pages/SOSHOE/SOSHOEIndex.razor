@page "/SOSHOE"

@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService


<style>

    .menu-card {
        width: 100%;
        box-shadow: 5px 5px 5px rgb(218, 214, 213 );
        border-radius: 10px;
        transition: all 0.3s ease-out;
        cursor: default;
    }

        .menu-card .header {
            border-radius: 10px 10px 0 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background-color: #f1f5f9;
        }


        .menu-card .content {
            text-align: justify;
            height: 16vh;
            overflow-x: scroll;
        }

            .menu-card .content::-webkit-scrollbar {
                width: 4px;
            }

        .menu-card .footer {
            border-radius: 0 0 10px 10px;
            background-color: #f1f5f9;
        }

        .menu-card:hover {
            box-shadow: #9ad8f3 0px 2px 4px;
            transform: scale(1.005);
        }

</style>

@if (logged == true)
{
    @*Title*@
    <PageTitle>Supervisor Mobility | @Localizer["SOSHOE"]</PageTitle>
    @*Breadcrumb links*@
    @*   <MudBreadcrumbs Items="_links">
        <ItemTemplate Context="item">
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        </ItemTemplate>
    </MudBreadcrumbs> *@

    @*Dashboard grid*@
    <MudGrid Class="pb-10">

