                    <MudImage Src="Images/admin.png" Height="25" Width="25" />
                </MudItem>
                <MudItem Class="content">
                    <MudText Class="pa-4">
                        @Localizer["SOSDescription"]
                    </MudText>
                </MudItem>
                <MudItem Class="pa-3 footer">
                    <MudButton Href="hoe" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
