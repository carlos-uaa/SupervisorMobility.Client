                        <MudText>@Localizer["HOESOSCombination"]</MudText>
                        <MudImage Src="Images/admin.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["SOSCombinationDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="soshoe/Combination" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        @* <MudButton Href="soshoe/Generate/Combination" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Generate</MudButton> *@
                    </MudItem>
                </MudPaper>
            </MudItem>
            @*HOE/SOS Distribution*@
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                    <MudItem Class="pa-2 header">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">H/S D</MudChip>
                        <MudText>@Localizer["HOESOSDistribution"]</MudText>
                        <MudImage Src="Images/admin.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["SOSDistributionDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="soshoe/Distribution" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        @* <MudButton Href="soshoe/Generate/Distribution" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Generate</MudButton> *@
                    </MudItem>
                </MudPaper>
            </MudItem>
            @*HOE/SOS Flow*@
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                    <MudItem Class="pa-2 header">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">H/S F</MudChip>
