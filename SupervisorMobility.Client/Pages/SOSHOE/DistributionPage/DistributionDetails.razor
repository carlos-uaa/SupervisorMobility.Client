@page "/soshoe/Distribution/Details/{DistributionId:int}"

@inject ISOSDistributionService SOSDistributionServices
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1
@inject IExportationService Exportation

<style>
    .vertical {
        writing-mode: tb-rl;
        -webkit-transform: rotate(180deg);
        -moz-transform: rotate(180deg);
        -o-transform: rotate(180deg);
        -ms-transform: rotate(180deg);
        transform: rotate(180deg);
    }

    .border-left {
        border-left: 2px solid #ababab;
    }

    .table-header td {
        background-color: #f5f5f6;
    }

    .table-header-gray th {
        background-color: #f5f5f6;
    }

    .table-header-gray td {
        padding: 0px 1% !important;
    }

    .divider {
        border-left: 1px solid var(--mud-palette-table-lines);
    }

    .images_cell {
    }

    .table-header-gray .images_cell {
        padding: 1% 2% !important;
    }

    .section_divider {
        border-top: 3px dashed var(--mud-palette-table-lines);
    }

    .mud-input .mud-input-slot {
        font-size: 0.6rem;
        scrollbar-width: none;
        margin: 2px;
    }

    .verticalText {
        writing-mode: vertical-rl;
        transform: rotate(180deg);
    }

</style>

@if (ShowLoading)
{
    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
        <ItemTemplate>
            <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                <MudItem class="d-flex flex-column justify-center align-self-center">
                    <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                </MudItem>
                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
            </div>
        </ItemTemplate>
    </MudCarousel>
}
else
{
    <MudText Typo="Typo.h6"><b>HOJA DE OPERACION ESTANDAR (DISTRIBUCIÓN)</b></MudText>
    <MudPaper Square="true" Elevation="3">
        <MudSimpleTable>
            <thead>
                <MudTr>
                    <MudTh colspan="5" rowspan="2"><b>NOMBRE DEL PROCESO</b><br />@_sosDistribution.ProcessName</MudTh>
                    <MudTh><b>TURNO</b></MudTh>
                    <MudTh><b>OPERADOR</b></MudTh>
                    <MudTh><b>SUPERVISOR</b></MudTh>
                </MudTr>
            </thead>
            <tbody>
                <MudTr>
                    <MudTd rowspan="2">
                        <b>ELABORÓ</b><br />
                        @if (_sosDistribution.SOSHub?.ApproverOwners?.FirstOrDefault()?.Name != null)
                        {
                            @_sosDistribution.SOSHub?.ApproverOwners?.FirstOrDefault()?.Name
                        }
                    </MudTd>
                    <MudTd rowspan="2">
                        <b>REVISÓ</b><br />
                        @if (_sosDistribution.DistributionLogbooks?.FirstOrDefault()?.Reviewer?.Name != null)
                        {
                            @_sosDistribution.DistributionLogbooks?.FirstOrDefault()?.Reviewer?.Name
                        }
                    </MudTd>
                    <MudTd rowspan="2">
                        <b>APROBÓ</b><br />
                        @if (_sosDistribution.DistributionLogbooks?.FirstOrDefault()?.Approver?.Name != null)
                        {
                            @_sosDistribution.DistributionLogbooks?.FirstOrDefault()?.Approver?.Name
                        }
                    </MudTd>
                    <MudTd rowspan="2" colspan="2"></MudTd>
                </MudTr>
                <MudTr>
                    <MudTd>
                        <ul style="list-style-type:none; padding-left:0;">
                            @if(_sosDistribution.Turns?.Any() ?? false){

                                @foreach(Turn turn in _sosDistribution.Turns){

                                    <li>@turn.TurnType</li>
                                }
                            }
                        </ul>
                    </MudTd>
                    <MudTd>
                        <ul style="list-style-type:none; padding-left:0;">
                            @if (_sosDistribution.Turns?.Any() ?? false)
                            {

                                @foreach (Turn turn in _sosDistribution.Turns)
                                {

                                    <li>@turn.Operator?.Name</li>
                                }
                            }
                        </ul>
                    </MudTd>
                    <MudTd>
                        <ul style="list-style-type:none; padding-left:0;">
                            @if (_sosDistribution.Turns?.Any() ?? false)
                            {

                                @foreach (Turn turn in _sosDistribution.Turns)
                                {

                                    <li>@turn.Supervisor?.Name</li>
                                }
                            }
                        </ul>
                    </MudTd>
                </MudTr>
                <MudTr>
                    <MudTd><b>FECHA DE EMISIÓN</b><br />@_sosDistribution.CreatedAt?.ToShortDateString()</MudTd>
                    <MudTd>
                        <b>MES DE APLICACIÓN</b><br />@_sosDistribution.ApplicationMonth?.ToString("MM/yyyy")
                    </MudTd>
                    <MudTd><b>MODELO</b><br />
                        @foreach (Product model in _sosDistribution.SOSHub.AppliedModels)
                        {
                            @($"{model?.Description} -")
                        }
                    </MudTd>
                    <MudTd><b>TIEMPO TACTO</b><br />@_sosDistribution.TackTime</MudTd>
                    <MudTd><b>TIEMPO DE APRENDIZAJE</b><br />@_sosDistribution.SOSHub?.TrainingTime</MudTd>
                    <MudTd><b>PLANTA</b><br />@_sosDistribution.SOSHub?.Plant?.Description</MudTd>
                    <MudTd><b>GERENCIA</b><br />@_sosDistribution.SOSHub?.Department?.Description</MudTd>
                    <MudTd><b>HOJA</b><br />1 de 1</MudTd>
                </MudTr>
            </tbody>
        </MudSimpleTable>
        <MudSimpleTable Dense Style="width:100%; margin:0px; padding:0px;" Square="true">
            <tbody class="table-header-gray">
                <tr>
                    <th rowspan="2">No.</th>
                    <th colspan="3" rowspan="2" style="font-size: 12px">SECUENCIA DE OPERACIÓN</th>
                    <th colspan="2" rowspan="2" style="font-size: 12px">PUNTOS CRITICOS</th>
                    <th colspan="5">Tiempo</th>
                    <th rowspan="2">DIAGRAMA DE DESPLAZAMIENTO</th>
                </tr>
                <tr>
                    <th style="padding: 2px; min-width: 5vw;" class="verticalText">
                        <MudInput @bind-Value="applicationModels[0]" Variant="Variant.Outlined" Margin="Margin.Dense"  Lines="3" Style="font-size: 0.6rem; max-height: 10vh;" ReadOnly />
                    </th>
                    <th style="padding: 2px; min-width: 5vw;" class="verticalText">
                        <MudInput @bind-Value="applicationModels[1]" Variant="Variant.Outlined" Margin="Margin.Dense"  Lines="3" Style="font-size: 0.6rem; max-height: 10vh;" ReadOnly />
                    </th>
                    <th style="padding: 2px; min-width: 5vw;"  class="verticalText">
                        <MudInput @bind-Value="applicationModels[2]" Variant="Variant.Outlined" Margin="Margin.Dense"  Lines="3" Style="font-size: 0.6rem; max-height: 10vh;" ReadOnly />
                    </th>
                    <th style="padding: 2px; min-width: 5vw;"  class="verticalText">
                        <MudInput @bind-Value="applicationModels[3]" Variant="Variant.Outlined" Margin="Margin.Dense"  Lines="3" Style="font-size: 0.6rem; max-height: 10vh;" ReadOnly />
                    </th>
                    <th style="padding: 2px; min-width: 5vw;" class="verticalText">
                        <MudInput @bind-Value="applicationModels[4]" Variant="Variant.Outlined" Margin="Margin.Dense"  Lines="3" Style="font-size: 0.6rem; max-height: 10vh;" ReadOnly />
                    </th>
                </tr>
    
                @{
                    int indexDistribution = 0;
                }
                @if(_sosDistribution.SOSHub != null)
                {
                    @foreach (var (sect, indexSection) in _sosDistribution.SOSHub.Sections.Select((sect, indexSection) => (sect, indexSection)))
                    {
                        @foreach (var (distribution, indexA) in sect.Analyses.Select((distribution, indexA) => (distribution, indexA)))
                        {
                            <tr class="@(indexSection != 0 && indexA==0?"section_divider":"")">
                                @if (indexA == 0)
                                {
                                    int TotalRowSpan = sect.Analyses.Count();
                                    <td rowspan="@TotalRowSpan">@(indexSection + 1)</td>
                                    <td rowspan="@TotalRowSpan" colspan="3" style="font-size: 12px">@sect.Step</td>
                                }
                                <td colspan="2">
                                    @foreach (var (cp, cpIndex) in distribution.CriticalPoints.Select((cp, cpIndex) => (cp, cpIndex)))
                                    {
                                        <MudItem>
                                            <MudText Style="font-size: 12px">@cp</MudText>
                                           @*  <MudText>
                                                @ReasonFormat(distribution.Reasons[cpIndex])
                                            </MudText> *@
                                        </MudItem>
                                    }
                                </td>
                                 @if (indexA == 0)
                                    {
                                        int TotalRowSpan = sect.Analyses.Count();
                                        int indexTime = _sosDistribution.Times.ToList().FindIndex(t => t.SectionId == sect.SectionId);

                                        var timesArray = new string[5];  

                                        for (int i = 0; i < timesArray.Length; i++)
                                        {
                                            timesArray[i] = "";
                                        }

                                        if (indexTime != -1)
                                        {
                                            var timeString = _sosDistribution.Times.ElementAt(indexTime).Time;
                                            var splitTimes = timeString?.Split("§") ?? new string[0];

                                            for (int i = 0; i < splitTimes.Length && i < timesArray.Length; i++)
                                            {
                                                timesArray[i] = splitTimes[i];
                                            }
                                        }

                                    <td rowspan="@TotalRowSpan">
                                        @if (indexTime != -1)
                                        {
                                            <MudInput Value="@timesArray[0]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;" />
                                        }
                                    </td>
                                    <td rowspan="@TotalRowSpan">
                                        @if (indexTime != -1)
                                        {
                                            <MudInput Value="@timesArray[1]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;" />
                                        }
                                    </td>
                                    <td rowspan="@TotalRowSpan">
                                        @if (indexTime != -1)
                                        {
                                            <MudInput Value="@timesArray[2]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;" />
                                        }
                                    </td>
                                    <td rowspan="@TotalRowSpan">
                                        @if (indexTime != -1)
                                        {
                                            <MudInput Value="@timesArray[3]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;" />
                                        }
                                    </td>
                                    <td rowspan="@TotalRowSpan">
                                        @if (indexTime != -1)
                                        {
                                            <MudInput Value="@timesArray[4]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;" />
                                        }
                                    </td>

                                    }                                @if (indexSection == 0 && indexA == 0)
                                {
                                    int totalAnalyses = _sosDistribution.SOSHub.Sections.Sum(section => section.Analyses.Count());
                                    int totalCriticalPoints = _sosDistribution.SOSHub.Sections
                                    .SelectMany(section => section.Analyses)
                                    .Sum(distribution => distribution.CriticalPoints.Count());
                                    int totalSpecialCases = _sosDistribution.SOSHub.MaterialsUsed.Count();

                                    int TotalRowSpanImages = totalAnalyses + totalCriticalPoints + 2 + totalSpecialCases;
                                    <td class="divider images_cell" rowspan="@TotalRowSpanImages" style="vertical-align: top; min-width: 30vw; height: 100%">
                                        <div class="d-flex align-content-space-between flex-wrap flex-grow-1 gap-4">

                                        <MudItem Class="d-flex flex-column align-start">
                                            @if (capturedImages.Any())
                                            {
                                                <div style="display: flex; align-items: center; justify-content: space-between;">
                                                    <MudItem Class="d-flex" Style="flex-direction: row; flex-wrap: wrap; justify-content: flex-start; overflow-y: scroll; max-height:65vh; scroll-behavior: smooth; justify-content: center;">
                                                        @foreach (var (image, index) in capturedImages.Select((image, index) => (image, index)))
                                                        {
                                                            <MudItem Class="mb-2 mr-2">
                                                                <MudImage ObjectFit="ObjectFit.Contain" Height="160" Width="260" Src=@image Alt="Evidence" Elevation="25" Class="rounded-lg" @onclick="() => OpenEvidenceDialog(index)" Style="cursor:pointer" />
                                                            </MudItem>
                                                        }
                                                    </MudItem>
                                                </div>
                                            }
                                            else
                                            {
                                                <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                                                    @Localizer["There are no images"]
                                                </MudAlert>
                                            }
                                        </MudItem>
                                        <MudSimpleTable Style="width:100%">
                                            <tr>
                                                @foreach (var rev in mostRecentLogs)
                                                {
                                                    <td style="width:25%; font-size: 12px;">@(rev.Approver?.Name)</td>
                                                    <td style="width:25%; font-size: 12px;">@(rev.Changes)</td>
                                                    <td style="width:25%; font-size: 12px;">@(rev.Date?.ToString("dd-MMM-yyyy").Replace(".", ""))</td>
                                                    <td style="width:25%; font-size: 12px;">@(rev.Reviewer?.Name)</td>
                                                }
                                            </tr>
                                            <tr>
                                                <th style="font-size: 12px;">APROBO</th>
                                                <th style="font-size: 12px;">CAMBIO</th>
                                                <th style="font-size: 12px;">FECHA</th>
                                                <th style="font-size: 12px;">REV</th>
                                            </tr>
                                        </MudSimpleTable>

                                        </div>

                                    </td>
                                }
                            </tr>
                        }
                    }
                    
                }
                <tr>
                    <MudTd colspan="2" rowspan="2">
                        <b style="font-size: 12px;">No Control</b><br />
                        <MudInput @bind-Value="_sosDistribution.ControlNumber" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.6rem;" />
                    </MudTd>
                    <td colspan="3"></td>
                    <td style="font-size: 12px;">Tiempo Adicional total</td>
                    <td>
                        <MudInput Value="@additionalTimes[0]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;" />
                    </td>
                    <td>
                        <MudInput Value="@additionalTimes[1]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;" />
                    </td>
                    <td>
                        <MudInput Value="@additionalTimes[2]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;"/>
                    </td>
                    <td>
                        <MudInput Value="@additionalTimes[3]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;"/>
                    </td>
                    <td>
                        <MudInput Value="@additionalTimes[4]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;" />
                    </td>
                </tr>
                <tr >
                    <td colspan="3"></td>
                    <td style="font-size: 12px;" class="mb-2">Tiempo Ciclo</td>
                    <td>
                        <MudInput Value="@cycleTimes[0]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;" />
                    </td>
                    <td>
                        <MudInput Value="@cycleTimes[1]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;"/>
                    </td>
                    <td>
                        <MudInput Value="@cycleTimes[2]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;" />
                    </td>
                    <td>
                        <MudInput Value="@cycleTimes[3]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;"/>
                    </td>
                    <td>
                        <MudInput Value="@cycleTimes[4]" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly Style="font-size: 0.8rem;"/>
                    </td>
                </tr>

            </tbody>
        </MudSimpleTable>
    </MudPaper>
    <br />
    <MudSimpleTable Class="table-header-gray mb-2">
        <thead>
            <tr>
                <th style="min-width: 5vw;">TIEMPO</th>
                <th style="min-width: 5vw;">CANTIDAD @applicationModels[0]</th>
                <th style="min-width: 5vw;">CANTIDAD @applicationModels[1]</th>
                <th style="min-width: 5vw;">CANTIDAD @applicationModels[2]</th>
                <th style="min-width: 5vw;">CANTIDAD @applicationModels[3]</th>
                <th style="min-width: 5vw;">CANTIDAD @applicationModels[4]</th>
                <th style="min-width: 5vw;">TIEMPO</th>
                <th style="min-width: 5vw;">@applicationModels[0]</th>
                <th style="min-width: 5vw;">@applicationModels[1]</th>
                <th style="min-width: 5vw;">@applicationModels[2]</th>
                <th style="min-width: 5vw;">@applicationModels[3]</th>
                <th style="min-width: 5vw;">@applicationModels[4]</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Take</td>
                @for (int i = 0; i < 5; i++)
                {
                    <td>@takeQuantity[i]</td>
                }
                @for (int i = 0; i < 6; i++)
                {
                    <td>@takeTime[i]</td>
                }
            </tr>
            <tr>
                <td>Leave</td>
                @for (int i = 0; i < 5; i++)
                {
                    <td>@leaveQuantity[i]</td>
                }
                @for (int i = 0; i < 6; i++)
                {
                    <td>@leaveTime[i]</td>
                }
            </tr>
            <tr>
                <td>Steps</td>
                @for (int i = 0; i < 5; i++)
                {
                    <td>@stepsQuantity[i]</td>
                }
                @for (int i = 0; i < 6; i++)
                {
                    <td>@stepsTime[i]</td>
                }
            </tr>
            <tr>
                <td colspan="7"></td>
                @for (int i = 1; i <= 5; i++)
                {
                    var totalTimeColumn = (Convert.ToDouble(takeTime[i]) + Convert.ToDouble(leaveTime[i]) + Convert.ToDouble(stepsTime[i]));
                    <td>@totalTimeColumn.ToString("F2")</td>
                }
            </tr>

        </tbody>
    </MudSimpleTable>
    <MudSimpleTable Style="width:100%" Class="table-header-gray mb-2">
        <tr>
            <th style="writing-mode: vertical-rl; transform: rotate(180deg); " rowspan="2">SÍMBOLOS</th>
            <th style="">SEGURIDAD</th>
            <th style="">INVENTARIO</th>
            <th style="">CHEQUEO</th>
            <th style="text-align:center;">ÁREA DE OPERACIÓN</th>
            <th style="">RUTA</th>
        </tr>
        <tr>
            <td style="text-align: center; vertical-align: middle;">
                <MudImage Src="/Images/DistributionSymbols/safety.png" Alt="Seguridad" Width="20" />
            </td>
            <td style="text-align: center; vertical-align: middle;">
                <MudImage Src="/Images/DistributionSymbols/inventory.png" Alt="Inventario" Width="20" />
            </td>
            <td style="text-align: center; vertical-align: middle;">
                <MudImage Src="/Images/DistributionSymbols/checking.png" Alt="Chequeo" Width="20" />
            </td>
            <td style="text-align: center; vertical-align: middle;">
                <MudImage Src="/Images/DistributionSymbols/operation_area.png" Alt="Área de Operación" Width="20" />
            </td>
            <td style="text-align: center; vertical-align: middle;">
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
            </td>
        </tr>
    </MudSimpleTable>

    <MudItem Style="float:right;">
        <MudButton Color="Color.Success" StartIcon="@Icons.Custom.FileFormats.FileExcel" Variant="Variant.Filled" OnClick="DownloadExcel" Class="mb-2">Export</MudButton>
    </MudItem>
    
}





@*Evidence Modal*@
<MudDialog DisableSidePadding="false" @bind-IsVisible="visibleEvidence" Options="dialogEvidenceOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Distribution Images"]
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudPaper Elevation="0">
            @if (capturedImages.Count() > 0)
            {
                <MudCarousel Class="mud-width-full" Style="height: 65vh" ShowArrows=true ShowBullets=true EnableSwipeGesture=true AutoCycle="false" TData="object" @bind-SelectedIndex=@photoIndex>
                    <PreviousButtonTemplate>
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Class="ml-4" Style="cursor:pointer">
                            <MudIcon Icon="@Icons.Material.Filled.NavigateBefore" />
                        </MudAvatar>
                    </PreviousButtonTemplate>
                    <NextButtonTemplate>
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Class="mr-4" Style="cursor:pointer">
                            <MudIcon Icon="@Icons.Material.Filled.NavigateNext" />
                        </MudAvatar>
                    </NextButtonTemplate>
                    <ChildContent>
                        @foreach (var evidence in capturedImages)
                        {
                            <MudCarouselItem Transition="Transition.Fade">
                                <MudImage ObjectFit="ObjectFit.Cover" Height="650" Width="1152" Src=@evidence Alt="Evidence" Elevation="25" Class="rounded-lg" Style="max-height: 55vh; width: 100%; border-radius: 10px; margin-bottom:24px;" />
                            </MudCarouselItem>
                        }
                    </ChildContent>
                </MudCarousel>
            }
            else
            {
                <MudItem Style="height: 65vh">
                    <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                        @Localizer["There are no images"]
                    </MudAlert>
                </MudItem>
            }
        </MudPaper>
    </DialogContent>
</MudDialog>

<MudDialog DisableSidePadding="false" @bind-IsVisible="visibleCommentaries" Options="dialogCommentariesOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Commentaries"]
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudItem Style="height: 65vh">
            <MudSimpleTable Style="overflow-x: auto;" Class="comments-table" Dense="true" Elevation="0">
                <tbody>
                    @if (_sosDistribution.Notes != null && _sosDistribution.Notes.Any())
                    {
                        @foreach (Commentary comment in _sosDistribution.Notes)
                        {
                            <tr>
                                <td width="90%">
                                    <MudTextField ReadOnly @bind-Value="@comment.Comment" Label="Revisión - Modificación" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <MudItem Style="height: 65vh">
                            <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                                @Localizer["There are no commentaries"]
                            </MudAlert>
                        </MudItem>
                    }
                </tbody>
            </MudSimpleTable>

        </MudItem>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseCommentariesDialog" Variant="Variant.Filled">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog DisableSidePadding="false" @bind-IsVisible="visibleLogbook" Options="dialogLogbookOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Distribution Logbook"]
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudItem Style="height: 65vh">
            <MudSimpleTable Style="overflow-x: auto;" Class="comments-table" Dense="true" Elevation="0" Hover>
                <thead>
                    <tr class="table-header-gray">
                        <th>No. de revisión</th>
                        <th>SSV</th>
                        <th>SV</th>
                        <th>Date</th>
                        <th>Revised Items</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_sosDistribution.DistributionLogbooks?.Any() ?? false)
                    {
                        int i = 0;
                        @foreach (SOSDistributionLogbook logbook in _sosDistribution.DistributionLogbooks)
                        {
                            <tr>
                                <td>
                                    @if (i == 0)
                                    {
                                        <span>N</span>
                                        i++;
                                    }
                                    else
                                    {
                                        <span>@(i++)</span>
                                    }
                                </td>
                                <td>@logbook.Approver?.Name</td>
                                <td>@logbook.Reviewer?.Name</td>
                                <td>@logbook.Date?.ToShortDateString()</td>
                                <td>@logbook.Changes</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4">
                                <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                                    @Localizer["There is no distribution logbook"]
                                </MudAlert>
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudItem>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseLogbookDialog" Variant="Variant.Filled">@Localizer["close"]</MudButton>
    </DialogActions>

</MudDialog>