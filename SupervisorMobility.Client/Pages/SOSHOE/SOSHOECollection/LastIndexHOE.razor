                                <MudText Typo="Typo.h6" Style="text-align: center;">
                                    @Localizer["HOE"]
                                </MudText>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudGrid Spacing="2" Justify="Justify.SpaceEvenly">
                                <MudItem xs="4">
                                    <MudButton Class="custom-button-card" Style="--clr:#39FF14" OnClick="@( () => GoToPageGenerate(1))">
                                        <MudCard>
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/analisis-de-los-datos.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Analysis</b></MudText>
                                                    <MudText Typo="Typo.body2">DocumentoSosAnalisi</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                        <i></i>
                                    </MudButton>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudButton Class="custom-button-card" Style="--clr:#FF44CC" OnClick="@(() => GoToPageGenerate(2))">
                                        <MudCard>
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/combinacion.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Combination</b></MudText>
                                                    <MudText Typo="Typo.body2">Descripcion Combination</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.CallMerge" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                        <i></i>
                                    </MudButton>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudButton Class="custom-button-card" Style="--clr:#0FF0FC" OnClick="@(() => GoToPageGenerate(3))">
                                        <MudCard>
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/reparto-de-beneficios.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Distribution</b></MudText>
                                                    <MudText Typo="Typo.body2">Documento de Distribucion</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.Hub" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                        <i></i>
                                    </MudButton>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudButton Class="custom-button-card" Style="--clr:#FF3131" OnClick="@(() => GoToPageGenerate(4))">
                                        <MudCard>
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/flujo-de-datos.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Flow</b></MudText>
                                                    <MudText Typo="Typo.body2">Flow Docuemnt Description</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.Air" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                        <i></i>
                                    </MudButton>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudButton Class="custom-button-card" Style="--clr:#8A2BE2" OnClick="@(() => GoToPageGenerate(5))">
                                        <MudCard>
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/flujo-de-trabajo.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Sequence</b></MudText>
                                                    <MudText Typo="Typo.body2">Documento de Sequence</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.Earbuds" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                        <i></i>
                                    </MudButton>
                                </MudItem>
                                <MudItem xs="4">
                                    <MudButton Class="custom-button-card" Style="--clr:#c4c4c4" OnClick="@(() => GoToPageGenerate(0))">
                                        <MudCard>
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/prueba.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>PAT</b></MudText>
                                                    <MudText Typo="Typo.body2">@Localizer["patDescription"]</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.Earbuds" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                        <i></i>
                                    </MudButton>
                                </MudItem>
                            </MudGrid>
                        </ChildContent>
                    </MudExpansionPanel>
                    <MudExpansionPanel IsInitiallyExpanded Style="min-width: 100%">
                        <ChildContent>
                            <MudGrid Spacing="2" Justify="Justify.Center">
                                <MudItem xs="6" Style="display: flex; justify-content: center;">
                                    <MudButton Class="custom-button-card" Style="--clr:#39FF14" OnClick="@(() => GoToPageGenerate(6))">
                                        <MudCard>
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/flujo-de-requisitos.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b> Cuadro Sinoptico de Requisitos de Operación</b></MudText>
                                                    <MudText Typo="Typo.body2"> Cuadro Sinoptico de Requisitos de Operación</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                        <i></i>
                                    </MudButton>
                                </MudItem>
                                <MudItem xs="6" Style="display: flex; justify-content: center;">
                                    <MudButton Class="custom-button-card" Style="--clr:#39FF14" OnClick="@(() => GoToPageGenerate(7))">
                                        <MudCard>
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/procedimiento.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left">
                                                        <b>
                                                            Cuadro Sinoptico de Puntos de Control
                                                        </b>
                                                    </MudText>
                                                    <MudText Typo="Typo.body2">Cuadro Sinoptico de Puntos de Control</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                        <i></i>
                                    </MudButton>
                                </MudItem>

                                <MudItem xs="6" Style="display: flex; justify-content: center;">
                                    <MudButton Class="custom-button-card" Style="--clr:#39FF14" OnClick="@(() => GoToPageGenerate(9))">
                                        <MudCard>
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/HojaControl.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Hoja de Control Individual</b></MudText>
                                                    <MudText Typo="Typo.body2">Hoja de Control Individual</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                        <i></i>
                                    </MudButton>
                                </MudItem>
                            </MudGrid>
                        </ChildContent>
                    </MudExpansionPanel>
                    <MudExpansionPanel IsInitiallyExpanded Style="min-width: 100%" Class="mb-10">
                        <TitleContent>
                            <div class="d-flex" style="align-items: center; justify-content:center;">
                                <MudText Typo="Typo.h6" Style="text-align: center;">
                                    @Localizer["Documents"]
                                </MudText>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudTable T="Object" Items="Documents" RowClassFunc="@SelectedRowDocument" @ref="SelectTableEventDocument" OnRowClick="RowClickEventDocument">
                                <HeaderContent>

                                    <MudTh>
                                        Doc Type
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">
                                            Operation Name
                                        </MudText>
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">
                                            Internal Control Number
                                        </MudText>
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">
                                            Process Name
                                        </MudText>
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">Actions</MudText>
                                    </MudTh>
                                </HeaderContent>
                                <RowTemplate>

                                    @if (@context is SOSAnalysis analysis)
                                    {
                                        <MudTd DataLabel="Id">
                                            <MudCard Elevation="0" Style="width:min-content">
                                                <MudCardHeader>
                                                    <CardHeaderAvatar>
                                                        <MudAvatar>
                                                            <MudImage Src="Images/analisis-de-los-datos.png" />
                                                        </MudAvatar>
                                                    </CardHeaderAvatar>
                                                    <CardHeaderContent>
                                                        <MudText Typo="Typo.h6" Style="text-align:left"><b>Analysis</b></MudText>
                                                    </CardHeaderContent>
                                                    <CardHeaderActions>
                                                        <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Color="MudBlazor.Color.Primary"></MudIcon>
                                                    </CardHeaderActions>
                                                </MudCardHeader>
                                            </MudCard>
                                        </MudTd>
                                        <MudTd DataLabel="OperationName">
                                            <MudText Align="Align.Center">@analysis.OperationName</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="InternalControlNumber">
                                            <MudText Align="Align.Center">@analysis.InternalControlNumber</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="ProcessName">
                                            <MudText Align="Align.Center">@analysis.ProcessName</MudText>
                                        </MudTd>
                                        <MudTd>
                                            <MudText Align="Align.Center">
                                                <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                    <ActivatorContent>
                                                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                    </ActivatorContent>
                                                    <ChildContent>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<SOSAnalysis>(analysis.SOSAnalysisId))" OnTouch="(() => Details<SOSAnalysis>(analysis.SOSAnalysisId))">Details</MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<SOSAnalysis>(analysis.SOSAnalysisId))" OnTouch="(() => Update<SOSAnalysis>(analysis.SOSAnalysisId))">Edit </MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<SOSAnalysis>(analysis.SOSAnalysisId))" OnTouch="(() => Delete<SOSAnalysis>(analysis.SOSAnalysisId))">Delete </MudMenuItem>
                                                    </ChildContent>
                                                </MudMenu>
                                            </MudText>
                                        </MudTd>
                                    }
                                    else if (@context is SOSCombination combination)
                                    {

                                        <MudTd DataLabel="Id">
                                            <MudCard Elevation="0" Style="width:min-content">
                                                <MudCardHeader>
                                                    <CardHeaderAvatar>
                                                        <MudAvatar>
                                                            <MudImage Src="Images/combinacion.png" />
                                                        </MudAvatar>
                                                    </CardHeaderAvatar>
                                                    <CardHeaderContent>
                                                        <MudText Typo="Typo.h6" Style="text-align:left"><b>Combination</b></MudText>
                                                    </CardHeaderContent>
                                                    <CardHeaderActions>
                                                        <MudIcon Icon="@Icons.Material.Filled.CallMerge" Color="MudBlazor.Color.Primary"></MudIcon>
                                                    </CardHeaderActions>
                                                </MudCardHeader>
                                            </MudCard>
                                        </MudTd>
                                        <MudTd DataLabel="OperationName">
                                            <MudText Align="Align.Center">@combination.OperationName</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="InternalControlNumber">
                                            <MudText Align="Align.Center">@combination.InternalControlNumber</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="ProcessName">
                                            <MudText Align="Align.Center">@combination.ProcessName</MudText>
                                        </MudTd>
                                        <MudTd>
                                            <MudText Align="Align.Center">
                                                <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                    <ActivatorContent>
                                                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                    </ActivatorContent>
                                                    <ChildContent>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<SOSCombination>(combination.SOSCombinationId))" OnTouch="(() => Details<SOSCombination>(combination.SOSCombinationId))">Details</MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<SOSCombination>(combination.SOSCombinationId))" OnTouch="(() => Update<SOSCombination>(combination.SOSCombinationId))">Edit </MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<SOSCombination>(combination.SOSCombinationId))" OnTouch="(() => Delete<SOSCombination>(combination.SOSCombinationId))">Delete </MudMenuItem>
                                                    </ChildContent>
                                                </MudMenu>
                                            </MudText>
                                        </MudTd>
                                    }
                                    else if (@context is SOSDistribution distribution)
                                    {

                                        <MudTd DataLabel="Id">
                                            <MudCard Elevation="0" Style="width:min-content">
