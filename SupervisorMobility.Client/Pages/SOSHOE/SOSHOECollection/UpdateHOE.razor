@page "/soshoe/Hub/Update/{sosHubId:int}"
@using System.Text.RegularExpressions

@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1
@inject IBreadcrumbService BreadcrumbServices
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionServices
@inject IDepartmentService DepartmentServices
@inject IUserService UsersService
@inject IProductService ProductsServices
@inject IDataPanelService DataPanelServices
@inject IAppearanceService AppearanceServices
@inject ILogbookAppearanceService LogbookAppearanceServices
@inject SignatureImageService _signatureImageService
@inject IPartServices PartsServices
@inject IFileUploadAndDownloadService FilesServices
@inject ITestService TestService
@inject ISOSHubService SOSHubServices
@inject IToolService ToolsServices
@inject IEquipmentService EquipmentsServices
@inject IMaterialService MaterialsServices
@inject IStationService StationServices
@inject IBridgeCDMSService CDMSServices

<style>

    .custom-table td:first-child {
        background-color: #f5f5f6;
    }

    .comments-table td:first-child {
        background-color: white;
    }

</style>

<PageTitle>Supervisor Mobility | @Localizer["configuration"]</PageTitle>


@if (ShowLoading)
{
    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
        <ItemTemplate>
            <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                <MudItem class="d-flex flex-column justify-center align-self-center">
                    <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                </MudItem>
                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
            </div>
        </ItemTemplate>
    </MudCarousel>
}
else
{
    <EditForm Model="_sosHub" OnValidSubmit="UpdateSOSHub">
        <MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
            <MudItem lg="10" md="10" sm="10" xs="12">
                <MudExpansionPanels Elevation="5" MultiExpansion="true">
                    <MudExpansionPanel IsInitiallyExpanded=true Style="min-width: 100%;">
                        <TitleContent>
                            <div class="d-flex" style="align-items: center; justify-content:center;">
                                <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
                                <MudText Typo="Typo.h6" Style="text-align: center;">
                                    @Localizer["HubCollectionTitle"]
                                </MudText>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudSimpleTable Style="overflow-x: auto;" Dense=true Elevation="0" Class="custom-table">
                                <tbody>
                                    <tr>
                                        <td width="20%">
                                            <MudText>Folio</MudText>
                                        </td>
                                        <td>
                                            <MudTextField Margin="Margin.Dense" @bind-Value="_sosHub.Folio" ReadOnly />
                                         </td>
                                     </tr>
                                     <tr>
                                         <td style="padding: 0px">
                                             <MudTabs Color="Color.Tertiary" Position="Position.Left" Rounded="true" Border="true" SliderColor="Color.Dark" @bind-ActivePanelIndex="analysisTabsIndex"
                                                      ApplyEffectsToContainer="true">
                                                 <MudTabPanel Text="Capture of analysis" Style="color:#424242; width: 15vw;">
                                                 </MudTabPanel>

                                                 @if (!string.IsNullOrEmpty(RawAnalisis?.FirstOrDefault()?.Text) || _sosHub.Sections.Count > 0)
                                                {
                                                    <MudTabPanel Text="Step capture" OnClick="CreateBakup" Style="color:#424242;  width: 15vw;">
                                                    </MudTabPanel>
                                                }

                                                @if (_sosHub.Sections.Count() > 0)
                                                {
                                                    <MudTabPanel Text="Reason Capture" Style="color:#424242;  width: 15vw;">
                                                    </MudTabPanel>
                                                }
                                            </MudTabs>


                                        </td>
                                        <td>
                                            @if (analysisTabsIndex == 0)
                                            {
                                                <MudContainer Style="display: flex; flex-direction: column;">

                                                    @if (RawAnalisis.Count != RawAnalisisBk.Count && _sosHub.Sections.Count > 0 && RawAnalisis.Count == 0)
                                                    {
                                                        <MudItem>
                                                            <MudButton OnClick="RestoreBakup" Color="Color.Primary" Style="float: left">Restore Backup </MudButton>
                                                        </MudItem>
                                                        <MudItem>

                                                            <MudSimpleTable Style="overflow-x: auto;" Class="comments-table" Dense="true" Elevation="0">
                                                                <tbody>
                                                                    @foreach (var (analisis, indexAnalisis) in RawAnalisisBk.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                                    {
                                                                        <tr>
                                                                            <td width="90%">
                                                                                <MudText Typo="Typo.subtitle2" Label="Análisis" Variant="Variant.Filled" Class="mb-2">@RawAnalisisBk[indexAnalisis].Text</MudText>
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                </tbody>
                                                            </MudSimpleTable>
                                                        </MudItem>
                                                    }
                                                    else
                                                    {
                                                        <MudItem>

                                                            <MudSimpleTable Style="overflow-x: auto;" Class="comments-table" Dense="true" Elevation="0">
                                                                <tbody>
                                                                    @{
                                                                        var combinedList = RawAnalisisBk.Union(RawAnalisis).ToList();
                                                                    }

                                                                    @foreach (var (analisis, indexAnalisis) in combinedList.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                                    {
                                                                        <tr>
                                                                            @if (RawAnalisis.Contains(analisis))
                                                                            {
                                                                                <td width="90%">
                                                                                    <MudTextField @bind-Value="@RawAnalisis[RawAnalisis.FindIndex(i => i == analisis)].Text" Label="Analisis" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                                                                                </td>

                                                                                <td width="10%">
                                                                                    <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="() => RemoveRawItem(analisis)" Disabled="DeleteAnalisis" StartIcon="@Icons.Material.Filled.Delete">Remove</MudButton>
                                                                                </td>
                                                                            }
                                                                            else if (_sosHub.AnalysesBkup.Find(a => a == analisis)?.IsActive == true)
                                                                            {
                                                                                <td width="90%">
                                                                                    <MudText Typo="Typo.subtitle2" Label="Análisis" Variant="Variant.Filled" Class="mb-2">@analisis.Text</MudText>
                                                                                </td>
                                                                                <td width="10%">
                                                                                </td>
                                                                            }
                                                                        </tr>
                                                                    }
                                                                </tbody>
                                                            </MudSimpleTable>
                                                            <MudButton OnClick="AddRawItem" Color="Color.Primary" Disabled="AddAnalisis" StartIcon="@Icons.Material.Filled.Add" Style="float: right">Add analisis</MudButton>
                                                        </MudItem>
                                                    }


                                                </MudContainer>

                                            }
                                            else if (analysisTabsIndex == 1)
                                            {
                                                <MudContainer Style="display: flex; flex-direction: column;">
                                                    <MudItem>
                                                        <MudButton OnClick="RestoreBakup" Color="Color.Primary" Style="float: left">Restore Backup </MudButton>
                                                    </MudItem>
                                                    @if (RawAnalisis.Count > 0)
                                                    {
                                                        <MudItem>
                                                            <MudStack>
                                                                <MudText>Selection Values: @string.Join(", ", _selectedValues ?? new List<string>())</MudText>
                                                                <MudStack Class="flex-wrap">
                                                                    <MudToggleGroup T="string" SelectionMode="SelectionMode.MultiSelection" @bind-Values="_selectedValues" Rounded="true" Color="Color.Primary" CheckMark Vertical="true" Style="text-align:start">
                                                                         @foreach (var (analisis, indexAnalisis) in RawAnalisis.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                                        {
                                                                            <MudToggleItem Value="@RawAnalisis[indexAnalisis].Text" UnselectedIcon="@Icons.Material.Filled.CheckBoxOutlineBlank" SelectedIcon="@Icons.Material.Filled.CheckBox" />
                                                                        }
                                                                    </MudToggleGroup>
                                                                </MudStack>
                                                            </MudStack>

                                                            <MudButton OnClick="AddStep" Color="Color.Primary" Disabled="@(_selectedValues.Count() == 0 ? true : false)" StartIcon="@Icons.Material.Filled.Add" Style="float: right">Generar Paso</MudButton>
                                                        </MudItem>
                                                    }

                                                    @if (_sosHub.Sections.Count > 0)
                                                    {
                                                        <MudItem>
                                                            <MudText Typo="Typo.h5">Preview</MudText>
                                                            <MudSimpleTable Elevation="0">
                                                                <MudTr>
                                                                    <MudTh>Análisis</MudTh>
                                                                    <MudTh>Pasos</MudTh>
                                                                    <MudTh>Punto Crítico</MudTh>
                                                                    <MudTh></MudTh>
                                                                </MudTr>

                                                                @foreach (var (section, indexSection) in _sosHub.Sections.Select((section, indexSection) => (section, indexSection)))
                                                                {
                                                                    <MudTr>
                                                                        <MudTd Style="width:50%; background-color: white">
                                                                            @foreach (var (analisis, indexAnalisis) in section.Analyses.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                                            {
                                                                                @if (analisis.CriticalPoints.Any())
                                                                                {
                                                                                    <MudText Typo="Typo.subtitle1" Label="Análisis" Variant="Variant.Filled" Class="mb-2">
                                                                                        @((MarkupString)GenerateHighlightedText(GetFormatedAnalisisText(indexSection, indexAnalisis), analisis.CriticalPoints))
                                                                                    </MudText>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <MudText Typo="Typo.subtitle1" Class="mb-2">
                                                                                        @_sosHub.Sections[indexSection].Analyses[indexAnalisis].Text
                                                                                    </MudText>
                                                                                }
                                                                            }
                                                                        </MudTd>
                                                                        <MudTd Style="width:20%">
                                                                            <MudTextField @bind-Value="_sosHub.Sections[indexSection].Step" Label="Paso" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />
                                                                        </MudTd>
                                                                        <MudTh Style="width:20%">
                                                                            @if (!string.IsNullOrEmpty(section.Step))
                                                                            {
                                                                                @foreach (var (analisis, indexAnalisis) in section.Analyses.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                                                {
                                                                                    <MudItem>
                                                                                        @foreach (var (criticalPoint, indexPoints) in analisis.CriticalPoints.Select((criticalPoint, indexPoints) => (criticalPoint, indexPoints)))
                                                                                        {
                                                                                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                                                                                @_sosHub.Sections[indexSection].Analyses[indexAnalisis].CriticalPoints[indexPoints]
                                                                                            </MudText>
                                                                                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                                                                                @ReasonFormat(_sosHub.Sections[indexSection].Analyses[indexAnalisis].Reasons[indexPoints])
                                                                                            </MudText>
                                                                                        }
                                                                                    </MudItem>
                                                                                }
                                                                            }
                                                                        </MudTh>

                                                                        <MudTd Style="width:10%">
                                                                            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="() => RemoveSectionItem(section)" StartIcon="@Icons.Material.Filled.Delete">Remove</MudButton>
                                                                        </MudTd>
                                                                    </MudTr>
                                                                }
                                                            </MudSimpleTable>
                                                        </MudItem>
                                                    }
                                                </MudContainer>

                                            }
                                            else if (analysisTabsIndex == 2)
                                            {
                                                <MudSimpleTable Style="width:100%; " Elevation="0">
                                                    <MudTr>
                                                        <MudTh>Análisis</MudTh>
                                                        <MudTh>Pasos</MudTh>
                                                        <MudTh>Punto Crítico</MudTh>
                                                    </MudTr>

                                                    @foreach (var (section, indexSection) in _sosHub.Sections.Select((section, indexSection) => (section, indexSection)))
                                                    {
                                                        <MudTr>
                                                            <MudTd Style="width:50%; background-color: white;">
                                                                @foreach (var (analisis, indexAnalisis) in section.Analyses.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                                {
                                                                    @if (analisis.CriticalPoints.Any())
                                                                    {
                                                                        <MudText Typo="Typo.subtitle1" Label="Análisis" Variant="Variant.Filled" Class="mb-2">
                                                                            @((MarkupString)GenerateHighlightedText(GetFormatedAnalisisText(indexSection, indexAnalisis), analisis.CriticalPoints))
                                                                        </MudText>
                                                                    }
                                                                    else
                                                                    {
                                                                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                                                                            @_sosHub.Sections[indexSection].Analyses[indexAnalisis].Text
                                                                        </MudText>
                                                                    }
                                                                    @if (analisis != section.Analyses.Last())
                                                                    {
                                                                        <MudDivider DividerType="DividerType.Middle" Class="my-6" />
                                                                    }
                                                                }
                                                            </MudTd>
                                                            <MudTd Style="width:20%">
                                                                <MudText Typo="Typo.subtitle1" Class="mb-2">
                                                                    @_sosHub.Sections[indexSection].Step
                                                                </MudText>
                                                            </MudTd>
                                                            <MudTd Style="width:30%">
                                                                @if (!string.IsNullOrEmpty(section.Step))
                                                                {
                                                                    @foreach (var (analisis, indexAnalisis) in section.Analyses.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                                    {
                                                                        <MudItem>
                                                                            @foreach (var (criticalPoint, indexPoints) in analisis.CriticalPoints.Select((criticalPoint, indexPoints) => (criticalPoint, indexPoints)))
                                                                            {
                                                                                <MudText Typo="Typo.subtitle1" Class="mb-2">
                                                                                    @_sosHub.Sections[indexSection].Analyses[indexAnalisis].CriticalPoints[indexPoints]
                                                                                </MudText>
                                                                                <MudTextField @bind-Value="_sosHub.Sections[indexSection].Analyses[indexAnalisis].Reasons[indexPoints]" Label="Razón" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" />

                                                                            }
                                                                        </MudItem>
                                                                        @if (analisis != section.Analyses.Last())
                                                                        {
                                                                            <MudDivider DividerType="DividerType.Middle" Class="my-6" />
                                                                        }
                                                                    }
                                                                }
                                                            </MudTd>

                                                        </MudTr>
                                                    }
                                                </MudSimpleTable>

                                            }

                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <MudText>Process Sheet</MudText>
                                        </td>
                                        <td>
                                            <MudTextField Margin="Margin.Dense" @bind-Value="_sosHub.ProcessSheet" Class="ml-4" />
                                            <MudText Style="font-weight:bold;" Class="mt-4 ml-4">Revisión - Modificación</MudText>
                                            <MudSimpleTable Style="overflow-x: auto;" Class="comments-table" Dense="true" Elevation="0">
                                                <tbody>
                                                    @foreach (var item in items.Where(i => i.IsActive))
                                                    {
                                                        <tr>
                                                            <td width="90%">
                                                                <MudTextField @bind-Value="@item.Commentary" Label="Revisión - Modificación" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                                                            </td>
                                                            @if (items.IndexOf(item) > 0)
                                                            {
                                                                <td width="10%">
                                                                    <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="() => RemoveItem(item, false)" StartIcon="@Icons.Material.Filled.Delete">Remove</MudButton>
                                                                </td>
                                                            }
                                                        </tr>
                                                    }
                                                    @foreach (var tempItem in tempItems)
                                                    {
                                                        <tr>
                                                            <td width="90%">
                                                                <MudTextField @bind-Value="@tempItem.Commentary" Label="Revisión - Modificación" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                                                            </td>
                                                            @if (tempItems.IndexOf(tempItem) > 0 || items.Count() > 0)
                                                            {
                                                                <td width="10%">
                                                                    <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="() => RemoveItem(tempItem, true)" StartIcon="@Icons.Material.Filled.Delete">Remove</MudButton>
                                                                </td>
                                                            }
                                                        </tr>
                                                    }
                                                </tbody>
                                            </MudSimpleTable>
                                            <MudButton OnClick="AddItem" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Style="float: right">Add Commentary</MudButton>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <MudText>Common Direction</MudText>
                                        </td>
                                        <td>
                                            <MudButton @onclick="() => ShowFileExplorerDialog(true)" Color="Color.Primary" IconColor="Color.Warning" StartIcon="@Icons.Material.Filled.Folder">GOS File Explorer</MudButton>
                                            <MudButton @onclick="() => ShowFileExplorerDialog(false)" Color="Color.Primary" IconColor="Color.Warning" StartIcon="@Icons.Material.Filled.FolderCopy">CCP File Explorer</MudButton>
                                            @if (finalFilesSelection.Any())
                                            {
                                                <MudCard>
                                                    <MudPaper Elevation="0">
                                                        @foreach (var item in finalFilesSelection)
                                                        {
                                                            var path = @Regex.Replace(item.Item2, @"§", string.Empty);
                                                            <MudTooltip Text="@path" Arrow="true" Placement="Placement.Top">
                                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="delete" Color="Color.Error" OnClick="()=>ManipulateFinalList(item.Item1, false, true)"></MudIconButton>
                                                                <MudButton Variant="Variant.Text"
                                                                           Size="Size.Small"
                                                                           StartIcon="@Icons.Material.Filled.InsertDriveFile"
                                                                           IconColor="@Color.Info"
                                                                           OnClick="()=>DownloadDocument(item.Item1)"
                                                                           EndIcon="@Icons.Material.Filled.FileDownload">
                                                                    @Regex.Replace((string)item.Item1.GetType().GetProperty("Nombre").GetValue(item.Item1), @"§", string.Empty)
                                                                </MudButton>
                                                            </MudTooltip>

                                                            <br />
                                                        }
                                                    </MudPaper>
                                                </MudCard>
                                            }
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <MudText>Applied Models</MudText>
                                        </td>
                                        <td class="d-flex">
                                            <MudSelect T="int" Label=@Localizer["product"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@productId" SelectedValuesChanged="GenerateFolio" OpenIcon="@Icons.Material.Filled.DirectionsCar" AdornmentColor="Color.Info">
                                                <MudSelectItem Disabled="true" Value="0">@Localizer["selectAProduct"]</MudSelectItem>
                                                @foreach (var type in _products)
                                                {
                                                    <MudSelectItem Value="type.ProductId">
                                                        @type.Code
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                            @if (productId != 0)
                                            {
                                                <MudSelect Class="ml-4" T="string" Label="Side" AnchorOrigin="Origin.BottomCenter" @bind-Value="@productSide" SelectedValuesChanged="GenerateFolio" OpenIcon="@Icons.Material.Filled.CarRepair" AdornmentColor="Color.Info">
                                                    <MudSelectItem Value="@("L")" />
                                                    <MudSelectItem Value="@("R")" />
                                                </MudSelect>

                                            }
                                            else
                                            {
                                                <MudSelect Class="ml-4" T="string" Variant="Variant.Text" Disabled AnchorOrigin="Origin.BottomCenter" @bind-Value="@productSide" OpenIcon="@Icons.Material.Filled.CarRepair" AdornmentColor="Color.Info">
                                                     <MudSelectItem Disabled="true" Value="@("")">@Localizer["firstSelectAProduct"]</MudSelectItem>
                                                 </MudSelect>
                                            }
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>
                                            <MudText>Images</MudText>
                                        </td>
                                        <td>
                                            <MudButton Variant="Variant.Filled" OnClick="ShowImagesDialog">
                                                Edit Images
                                                <span>&nbsp;(@capturedImages.Count)</span>
                                            </MudButton>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <MudText>Videos</MudText>
                                        </td>
                                        <td>
                                            <MudButton Variant="Variant.Filled" OnClick="ShowVideosDialog">
                                                Edit Videos
                                                <span>&nbsp;(@MediaUris.Count)</span>
                                            </MudButton>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <MudText>Revised Items</MudText>
                                        </td>
                                        <td>
                                            <MudTextField Margin="Margin.Dense" @bind-Value="_sosHub.RevisedItems" />
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <MudText>Training time</MudText>
                                        </td>
                                        <td style="display:flex;">
                                            <MudAutocomplete T="int"
                                                             Label=@Localizer["Cycles"]
                                                             Variant="Variant.Text"
                                                             AnchorOrigin="Origin.BottomCenter"
                                            @bind-Value="cycleId"
                                                             OpenIcon="@Icons.Material.Filled.AccessTime"
                                                             AdornmentColor="Color.Info"
                                                                                  Clearable
                                                                                  ResetValueOnEmptyText
                                                              ShowProgressIndicator="true" ProgressIndicatorColor="Color.Info"
                                                              ToStringFunc="ReturnCycles"
                                                              SearchFunc="SearchCycles"
                                                              MaxItems="10">

                                             </MudAutocomplete>

                                         </td>
                                     </tr>
                                     <tr>
                                         <td>
                                             <MudText>Safety Equipment</MudText>
                                         </td>
                                         <td>
                                             <MudAutocomplete T="string"
                                             @bind-Value="selectedEquipmentName"
                                                              Label="Buscar equipamiento"
                                                              SearchFunc="SearchEquipment"
                                                              Placeholder="Buscar equipamiento..."
                                                              Variant="Variant.Text"
                                                              AnchorOrigin="Origin.BottomCenter"
                                                              AdornmentColor="Color.Warning"
                                                                                  ResetValueOnEmptyText
                                                              CoerceText="false"
                                                              CoerceValue="true"
                                                                                  Clearable
                                                              ShowProgressIndicator="true"
                                                              ProgressIndicatorColor="Color.Info"
                                                              OpenIcon="@Icons.Material.Filled.Engineering">
                                             </MudAutocomplete>

                                             @if (IsExistingEquipment)
                                            {
                                                <MudButton Color="Color.Primary" @onclick="AddSelectedEquipment" Disabled="@(string.IsNullOrWhiteSpace(selectedEquipmentName))">
                                                    Agregar equipamiento
                                                </MudButton>
                                            }
                                            else if (!string.IsNullOrWhiteSpace(selectedEquipmentName))
                                            {
                                                string title = "Equipment";
                                                <MudButton Color="Color.Secondary" @onclick="(() => OpenResourceModal(title))">
                                                    Crear equipamiento
                                                </MudButton>
                                            }

                                            @if (_equipmentIds.Count > 0)
                                            {
                                                <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: center; align-items: center;">

                                                    @foreach (var equipmentId in _equipmentIds)
                                                    {
                                                        <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Warning" Variant="Variant.Outlined">
                                                            <MudChip Color="Color.Warning" Icon="@Icons.Material.Filled.Engineering" Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer">
                                                                @(_equipment.FirstOrDefault(t => t.EquipmentId == equipmentId)?.EquipmentName)
                                                            </MudChip>

                                                            <MudTooltip Text="Delete Equipment" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" @onclick="(() => RemoveEquipment(equipmentId))"></MudIconButton>
                                                            </MudTooltip>
                                                        </MudButton>
                                                    }
                                                </MudItem>
                                            }
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <MudText>Tools Used</MudText>
                                        </td>
                                        <td>
                                            <MudAutocomplete T="string"
                                            @bind-Value="selectedToolName"
                                                             Label="Buscar herramienta"
                                                             SearchFunc="SearchTools"
                                                             Placeholder="Buscar herramienta..."
