                            </MudCardHeader>
                        </MudCard>
                        break;
                    case 66:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/flujo-de-requisitos.png" />
