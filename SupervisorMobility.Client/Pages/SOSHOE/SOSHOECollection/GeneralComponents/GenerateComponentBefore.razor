<style>
    .cards__card {
        border-left: 4px solid #0a7bcf;
        transition: transform 0.3s ease;
        box-shadow: 0px 4px 8px #0a7bcf3b;
    }

    .cards__card:hover {
        transform: scale(1.01);
    }

    .cards__separator {
        width: 2px;
        height: 0;
        background: #0a7bcf;
        margin-right: 5px;
        margin-left: 5px;
        transition: height 0.3s ease;
    }

    .cards__card:hover .cards__separator {
        height: 40px;
    }
</style>

<MudDialog DisableSidePadding="false" Options="dialogPagesOptions" Style="min-height: 30vh; max-height:75vh">
