@inject Microsoft.AspNetCore.Components.WebAssembly.Hosting.IWebAssemblyHostEnvironment Environment
@inject IStringLocalizer<Resource> Localizer
@inject IUserService UsersService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

@inject ISOSHubService SOSHubServices
@inject ISOSAnalysisService SOSAnalysisServices
@inject ISOSCombinationService SOSCombinationServices
@inject ISOSDistributionService SOSDistributionServices
@inject ISOSFlowService SOSFlowServices
@inject ISOSSequenceService SOSSequenceServices

@inject IPlantService PlantServices
@inject IDepartmentService DepartmentServices
@inject IStationService StationServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionServices

<MudDialog DisableSidePadding="false" Options="dialogPagesOptions" Style="min-height: 30vh; max-height:75vh">
    <TitleContent>
        <MudItem Style="float: left">
            <SupervisorMobility.Client.Pages.Components.ButtonBack OnClick="@(() => ReturnToGenerateindex())"></SupervisorMobility.Client.Pages.Components.ButtonBack>
        </MudItem>
        <MudItem>
            @if (loaded)
            {
                @switch (selectedIndexPageGenerate)
                {
                    case 0:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/prueba.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left">
                                        @if (_sosHub.PATs?.Count == 0 || _sosHub.PATs?.Last().Status == 6 && _pat.PATid != 0)
                                        {
                                            <b> Generate </b>
                                        }
                                        else
                                        {
                                            <b> Revision</b>
                                        }
                                        <b> PAT</b>
                                    </MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_sosHub.PATs?.Count > 0 && _sosHub.PATs?.Last().Status != 6 && _pat.PATid != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<PAT>(_pat.PATid)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>
                        break;
                    case 1:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/analisis-de-los-datos.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left">
                                        @if (_sosHub.SOSAnalysis.Count == 0)
                                        {
                                            <b> Generate </b>
                                        }
                                        else
                                        {
                                            <b> Revision</b>
                                        }
                                        <b> Analysis</b>
                                    </MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_sosHub.SOSAnalysis.Count > 0 && _sosAnalysis.AnalysisLogbooks?.Last().Status != 2 || _sosAnalysis.SOSAnalysisId != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSAnalysis>(_sosAnalysis.SOSAnalysisId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>
                        break;
                    case 2:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/combinacion.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Combination</b></MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_sosHub.SOSCombination.Count > 0 && _sosCombination.CombinationLogbooks?.Last().Status != 2 || _sosCombination.SOSCombinationId != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSCombination>(_sosCombination.SOSCombinationId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>
                        break;
                    case 3:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/reparto-de-beneficios.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Distribution</b></MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_sosHub.SOSDistribution.Count > 0 && _sosDistribution.DistributionLogbooks?.Last().Status != 2 || _sosDistribution.SOSDistributionId != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSDistribution>(_sosDistribution.SOSDistributionId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>
                        break;
                    case 4:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/flujo-de-datos.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Flow</b></MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_sosHub.SOSFlow.Count > 0 && _sosFlow.FlowLogbooks?.Last().Status != 2 || _sosFlow.SOSFlowId != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSFlow>(_sosFlow.SOSFlowId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>
                        break;
                    case 5:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/flujo-de-trabajo.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Sequence</b></MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>

                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_sosHub.SOSSequence.Count > 0 && _sosSequence.SequenceLogbooks?.Last().Status != 2 || _sosSequence.SOSSequenceId != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView OnClick="() => Details<SOSSequence>(_sosSequence.SOSSequenceId)" ButtonText="@Localizer["details"]"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>
                        break;
                    case 6:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/flujo-de-requisitos.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Cuadro Sinoptico de Requisitos de Operación</b></MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>

                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_sosHub.SOSSynopticOperatingRequirements.Count > 0 && _SOSSynopticRequirements.SynopticRequirementsLogbooks?.Last().Status != 2 || _SOSSynopticRequirements.SOSSynopticTableofOperatingRequirementsId != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView OnClick="() => Details<SOSSynopticRequirementsOperationSequence>(_SOSSynopticRequirements.SOSSynopticTableofOperatingRequirementsId)" ButtonText="@Localizer["details"]"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>
                        break;

                }
            }
        </MudItem>
    </TitleContent>
    <DialogContent>
        @if (loaded)
        {
            @switch (selectedIndexPageGenerate)
            {
                case 0:
                    <div class="d-flex" style="max-height: auto">
                        <MudItem Class="ma-5" Style="width: 100%;">
                            @if (_sosHub.PATs?.Count == 0 || _sosHub.PATs?.Last().Status == 6)
                            {
                                <SupervisorMobility.Client.Pages.Inicio.PATPage.CreatePAT is_Hoe="true" _pat="_pat" SOSHubId="_sosHub.SOSHubId" _plants="_plants" _areas="_areas" Plant_Id="(int)_sosHub.PlantId" Area_Id="(int)_sosHub.AreaId" _supervisors="_sosHub.ReviewerEditors"></SupervisorMobility.Client.Pages.Inicio.PATPage.CreatePAT>
                            }
                            else
                            {
                                <MudSimpleTable Class="mb-5 calendar-table rounded" Style="overflow-x: auto;" Dense>
                                    <thead>
                                        <tr>
                                            <th>
                                                <MudItem Class="d-flex">
                                                    <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
                                                    <MudText Class="ml-2">@Localizer["area"]</MudText>
                                                </MudItem>
                                            </th>
                                            <th>@Localizer["applicationYear"]</th>
                                            <th>Supervisor</th>
                                            <th>SSV</th>
                                            <th>@Localizer["status"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>
                                                @_pat?.Area?.Code - @_pat?.Area?.Description
                                            </td>
                                            <td>@_pat?.CreationDate?.Year</td>
                                            <td>
                                                <MudText>@string.Join(" / ", _pat.Supervisors.Select(s => s.Name))</MudText>
                                            </td>
                                            <td>
                                                <MudText>@string.Join(" / ", _pat.Supervisors.Select(s => s.Superior?.Name).Where(name => name != null).Distinct())</MudText>
                                            </td>
                                            <td>
                                                <MudItem Style="justify-content: end" Class="ml-auto">
                                                    <MudItem Class="d-flex">
                                                        @switch (_pat.Status)
                                                        {
                                                            case 1:
                                                                <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlaylistPlay" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">@Localizer["new"]</MudChip>
                                                                break;
                                                            case 2:
                                                                <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                                                break;
                                                            case 3:
                                                                <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                                                break;
                                                            case 4:
                                                                <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                                                break;
                                                            case 5:
                                                                <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                                                break;
                                                            case 6:
                                                                <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                                                break;
                                                        }
                                                    </MudItem>
                                                </MudItem>
                                            </td>
                                        </tr>

                                    </tbody>
                                </MudSimpleTable>

                            }

                        </MudItem>
                    </div>
                    break;
                case 1:
                    <div class="d-flex" style="min-height:40vh; max-height: auto">
                        <MudItem Class="ma-5">
                            <MudSimpleTable Dense Style="width:100%; margin:0px; padding:0px;" Square="true">
                                <tbody class="table-header-gray">
                                    <tr>
                                        <th rowspan="2">Nombre de la Operación</th>
                                        <td rowspan="2" colspan="3">
                                            @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0)
                                            {
                                                <MudTextField Margin="Margin.Dense" @bind-Value="_sosAnalysis.OperationName" />
                                            }
                                            else
                                            {
                                                <MudTextField ReadOnly Margin="Margin.Dense" @bind-Value="_sosAnalysis.OperationName" />
                                            }
                                        </td>
                                        <th class="divider" colspan="2">No. de Revisión</th>
                                        <td style="width:30%;">
                                            @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().NoRevision == 0)
                                            {
                                                <b> New - @_sosAnalysis.AnalysisLogbooks?.Count() </b>
                                            }
                                            else
                                            {
                                                @if (_sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0)
                                                {
                                                    <b> NewTemporal - @_sosAnalysis.AnalysisLogbooks?.Count() </b>
                                                }
                                                else if (_sosAnalysis.AnalysisLogbooks?.Last().Status == 2)
                                                {
                                                    <b> NewRevision - @_sosAnalysis.AnalysisLogbooks?.Count() </b>
                                                }
                                                else
                                                {
                                                    <b> @_sosAnalysis.AnalysisLogbooks?.Last().NoRevision </b>
                                                }
                                            }
                                        </td>
                                    </tr>
                                    <tr>
                                        <th class="divider" colspan="2">Fecha</th>
                                        <td style="width:20%">
                                            @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().NoRevision == 0)
                                            {
                                                <b> New - @(DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")) </b>
                                            }
                                            else
                                            {
                                                @if (_sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0)
                                                {
                                                    <b> NewTemporal - @(DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")) </b>
                                                }
                                                else if (_sosAnalysis.AnalysisLogbooks?.Last().Status == 2)
                                                {
                                                    <b> NewRevision - @(DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")) </b>
                                                }
                                                else
                                                {
                                                    <b>
                                                        @(_sosAnalysis.AnalysisLogbooks?.Last().Date?.ToString("dd-MMM-yyyy").Replace(".", ""))
                                                    </b>
                                                }
                                            }

                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Número de control interno</th>
                                        <td style="width:20%">
                                            @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0)
                                            {
                                                <MudTextField Margin="Margin.Dense" @bind-Value="_sosAnalysis.InternalControlNumber" />
                                            }
                                            else
                                            {
                                                <MudTextField ReadOnly Margin="Margin.Dense" @bind-Value="_sosAnalysis.InternalControlNumber" />
                                            }
                                        </td>
                                        <th>Nombre del proceso</th>
                                        <td style="width:20%">
                                            @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0)
                                            {
                                                <MudTextField Margin="Margin.Dense" @bind-Value="_sosAnalysis.ProcessName" />
                                            }
                                            else
                                            {
                                                <MudTextField ReadOnly Margin="Margin.Dense" @bind-Value="_sosAnalysis.ProcessName" />
                                            }
                                        </td>
                                        <th rowspan="3" colspan="2" class="divider">Status<br />( Estado )</th>

                                        <td rowspan="3" style="width:30%">

                                            @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0 || _sosAnalysis.AnalysisLogbooks?.Last().Status == 2)
                                            {
                                                <b>
                                                    <MudChip Class="mr-10" Icon="@Icons.Material.Filled.PlaylistPlay" Color="Color.Warning" Variant="Variant.Text">
                                                        @Localizer["new"]
                                                    </MudChip>
                                                </b>
                                            }
                                            else
                                            {
                                                <b>
                                                    @switch (_sosAnalysis.AnalysisLogbooks?.Last().Status)
                                                    {
                                                        case 0:
                                                            <MudChip Class="mr-10" Icon="@Icons.Material.Filled.PlaylistAddCheck" Color="Color.Success" Variant="Variant.Text">
                                                                @Localizer["unknow"]!
                                                            </MudChip>
                                                            break;
                                                        case 1:
                                                            <MudChip Class="mr-10" Icon="@Icons.Material.Filled.PlaylistAddCheck" Color="Color.Success" Variant="Variant.Text">
                                                                @Localizer["created"]!
                                                            </MudChip>
                                                            break;
                                                    }
                                                </b>
                                            }


                                        </td>

                                    </tr>
                                    <tr>
                                        <th>Equipo de seguridad</th>
                                        <td colspan="3">
                                            @if (_sosHub.SafetyEquipment != null && _sosHub.SafetyEquipment.Any())
                                            {
                                                @foreach (var element in _sosHub.SafetyEquipment.Take(2).ToList())
                                                {
                                                    <MudChip Color="Color.Warning" Icon="@Icons.Material.Filled.Engineering" Size="Size.Small" Variant="Variant.Outlined">
                                                        @element.EquipmentName
                                                    </MudChip>
                                                }
                                                @if (_sosHub.SafetyEquipment.Count > 2)
                                                {

                                                    <MudMenu Style="float:right" MaxHeight="300" ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                        <ActivatorContent>
                                                            <MudChip Color="Color.Default" Icon="@Icons.Material.Filled.ExpandCircleDown" Size="Size.Small" Variant="Variant.Text">
                                                                Show more
                                                            </MudChip>
                                                        </ActivatorContent>
                                                        <ChildContent>
                                                            @foreach (var element in _sosHub.SafetyEquipment)
                                                            {
                                                                <MudMenuItem>
                                                                    <MudChip Color="Color.Warning" Icon="@Icons.Material.Filled.Engineering" Size="Size.Small" Variant="Variant.Outlined">
                                                                        @element.EquipmentName
                                                                    </MudChip>
                                                                </MudMenuItem>
                                                            }
                                                        </ChildContent>
                                                    </MudMenu>
                                                }
                                            }
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Herramientas</th>
                                        <td colspan="3">
                                            @if (_sosHub.ToolsUsed != null && _sosHub.ToolsUsed.Any())
                                            {

                                                @foreach (var element in _sosHub.ToolsUsed.Take(2).ToList())
                                                {
                                                    <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined">
                                                        <MudChip Color="Color.Info" Icon="@Icons.Material.Filled.Build" Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer">
                                                            @(element.Tool?.ToolName)
                                                        </MudChip>
                                                    </MudButton>
                                                }

                                                @if (_sosHub.ToolsUsed.Count > 2)
                                                {


                                                    <MudMenu Style="float:right" MaxHeight="300" ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                        <ActivatorContent>
                                                            <MudChip Color="Color.Default" Icon="@Icons.Material.Filled.ExpandCircleDown" Size="Size.Small" Variant="Variant.Text">
                                                                Show more
                                                            </MudChip>
                                                        </ActivatorContent>
                                                        <ChildContent>
                                                            @foreach (var element in _sosHub.ToolsUsed)
                                                            {
                                                                <MudMenuItem>
                                                                    <MudChip Color="Color.Info" Icon="@Icons.Material.Filled.Build" Size="Size.Small" Variant="Variant.Outlined">
                                                                        @element.Tool?.ToolName
                                                                    </MudChip>
                                                                </MudMenuItem>
                                                            }
                                                        </ChildContent>
                                                    </MudMenu>
                                                }

                                            }
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Unidades</th>
                                        <td colspan="3">
                                            @if (_sosHub.AppliedModels?.Count > 0)
                                            {
                                                <MudItem Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4 pb-5">
                                                    @foreach (Product item in _sosHub.AppliedModels)
                                                    {
                                                        <MudChip T="string" Icon="@Icons.Material.Filled.DirectionsCar" Color="Color.Secondary">@item.Description</MudChip>
                                                    }
                                                </MudItem>
                                            }

                                        </td>
                                        <th rowspan="2" class="divider"><span class="vertical">Confirmado Por</span></th>
                                        <th>Supervisor Gral.<br />( Aprobó )</th>
                                        <td style="width:30%">
                                            @if (_sosHub.SOSAnalysis.Count == 0)
                                            {
                                                <MudAutocomplete T="int"
                                                                 Label=@Localizer["SeniorSupervisor"]
                                                                 Variant="Variant.Text"
                                                                 AnchorOrigin="Origin.BottomCenter"
                                                                 @bind-Value="ApproverAnalysisId"
                                                                 OpenIcon="@Icons.Material.Filled.SupervisorAccount"
                                                                 AdornmentColor="Color.Secondary"
                                                                 Clearable
                                                                 ResetValueOnEmptyText
                                                                 ShowProgressIndicator="true" ProgressIndicatorColor="Color.Info"
                                                                 ToStringFunc="@(s => _sosHub.ApproverOwners?.FirstOrDefault(x => x.UserId == s)?.Name)"
                                                                 SearchFunc="SearchApproverOwners">
                                                </MudAutocomplete>
                                            }
                                            else
                                            {
                                                <MudAutocomplete T="int"
                                                                 Label=@Localizer["SeniorSupervisor"]
                                                                 Variant="Variant.Text"
                                                                 AnchorOrigin="Origin.BottomCenter"
                                                                 @bind-Value="ApproverAnalysisId"
                                                                 OpenIcon="@Icons.Material.Filled.SupervisorAccount"
                                                                 AdornmentColor="Color.Secondary"
                                                                 Clearable
                                                                 ResetValueOnEmptyText
                                                                 ReadOnly="_sosAnalysis.AnalysisLogbooks?.Last().Status != 2"
                                                                 ShowProgressIndicator="true" ProgressIndicatorColor="Color.Info"
                                                                 ToStringFunc="@(s => _sosHub.ApproverOwners?.FirstOrDefault(x => x.UserId == s)?.Name)"
                                                                 SearchFunc="SearchApproverOwners">
                                                </MudAutocomplete>
                                            }
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Tiempo de aprendizaje</th>
                                        <td colspan="3">
                                            <MudAutocomplete T="int"
                                                             Margin="Margin.Dense"
                                                             Label=@Localizer["Cycles"]
                                                             Variant="Variant.Text"
                                                             AnchorOrigin="Origin.BottomCenter"
                                                             @bind-Value="cycleId"
                                                             OpenIcon="@Icons.Material.Filled.AccessTime"
                                                             AdornmentColor="Color.Info"
                                                             Clearable
                                                             ResetValueOnEmptyText
                                                             ShowProgressIndicator="true" ProgressIndicatorColor="Color.Info"
                                                             MaxItems="10"
                                                             ReadOnly>
                                            </MudAutocomplete>
                                        </td>
                                        <th>Supervisor<br />( Elaboró )</th>
                                        <td style="width:30%">
                                            @if (_sosHub.SOSAnalysis.Count == 0)
                                            {
                                                @if (_sosHub.ReviewerEditors.Count > 0)
                                                {
                                                    <MudAutocomplete T="int"
                                                                     Label=@Localizer["Supervisor"]
                                                                     Variant="Variant.Text"
                                                                     AnchorOrigin="Origin.BottomCenter"
                                                                     @bind-Value="ReviewerAnalysisId"
                                                                     OpenIcon="@Icons.Material.Filled.SupervisorAccount"
                                                                     AdornmentColor="Color.Secondary"
                                                                     Clearable
                                                                     ResetValueOnEmptyText
                                                                     ShowProgressIndicator="true"
                                                                     ProgressIndicatorColor="Color.Info"
                                                                     ToStringFunc="@(s => _sosHub.ReviewerEditors?.FirstOrDefault(x => x.UserId == s)?.Name)"
                                                                     SearchFunc="SearchReviewerEditors">

