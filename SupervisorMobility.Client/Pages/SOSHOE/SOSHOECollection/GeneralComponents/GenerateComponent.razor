@using SupervisorMobility.Client.Pages.SOSHOE.SOSHOECollection.GeneralComponents.Sections
@using SupervisorMobility.Client.Pages.SOSHOE.SOSHOECollection.GeneralComponents.Components
@inject Microsoft.Extensions.Localization.IStringLocalizer<GenerateComponent> Localizer

<style>
    .dialog-scroll-fix {
        overflow-x: hidden !important;
        padding: 8px;
        width: 100%;
        box-sizing: border-box;
    }

    .no-margin-grid {
        margin: 0 !important;
        width: 100% !important;
    }
</style>

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@GetStepIcon()" Class="mr-3 mb-n1" />
            @GetStepTitle()
        </MudText>
    </TitleContent>

    <DialogContent>
        <div class="dialog-scroll-fix">
            <MudGrid Spacing="3" Class="no-margin-grid">
                @if (State.IsLoading)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                }
                else
                {
                    @switch (State.SelectedIndex)
                    {
                        case 0: <PATSection @ref="PatSectionRef" State="State" OnNotify="StateHasChanged" />; break;
                        case 1: <AnalysisSection @ref="AnalysisSectionRef" State="State" OnNotify="StateHasChanged" />; break;
                        case 2: <CombinationSection @ref="CombinationSectionRef" State="State" OnNotify="StateHasChanged" />; break;
                        case 3: 
                        case 7:
                            <SelectAnalisis_Sequences AreaId="36" DistributionId="0" @bind-Selection="_selections" /> break;
                        case 33:
                            <DistributionSection @ref="DistributionSectionRef" State="State" AnalysysSequences="_selections" OnNotify="StateHasChanged" /> break;
                        case 4: <FlowSection @ref="FlowSectionRef" State="State" OnNotify="StateHasChanged" />; break;
                        case 5: <SequenceSection @ref="SequenceSectionRef" State="State" OnNotify="StateHasChanged" />; break;
                        case 6: <CSROSection @ref="CSROSectionRef" State="State" OnNotify="StateHasChanged" />; break;
                        case 77: <CSPCSection @ref="CSPCSectionRef" State="State" AnalysysSequences="_selections" OnNotify="StateHasChanged" />; break;
                        case 9: <HCISection @ref="HCISectionRef" State="State"OnNotify="StateHasChanged" />; break;
                        default:
                            <MudAlert Severity="Severity.Info">Seleccione un paso válido.</MudAlert>
                            break;
                    }
                }
            </MudGrid>
        </div>
    </DialogContent>

    <DialogActions>
        @* Botón de Atrás (No se muestra en el primer paso) *@
        @if (State.SelectedIndex > 0)
        {
            <MudButton Variant="Variant.Text"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="GoBack">
                @Localizer["Back"]
            </MudButton>
        }
        <MudSpacer />

        @* Botón Cancelar/Cerrar *@
        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="Close">
            @Localizer["Cancel"]
        </MudButton>

        @* BOTONES DINÁMICOS SEGÚN EL PASO *@
        @switch (State.SelectedIndex)
        {
            case 0:
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.Add"
                           OnClick="() => PatSectionRef.GeneratePat()">
                    Generate PAT
                </MudButton>
                break;
            case 1:
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.Analytics"
                           OnClick="() => AnalysisSectionRef.GenerateAnalysis()">
                    Generate Analysis
                </MudButton>
                break;
            case 2:
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="() => CombinationSectionRef.GenerateCombination()">
                    Generate Combination
                </MudButton>
                break;
            case 33:
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                            OnClick="() => DistributionSectionRef.GenerateDistribution()">
                    Generate Distribution
                </MudButton>
                break;
            case 4:
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="() => FlowSectionRef.GenerateFlow()">
                    Generate Flow
                </MudButton>
                break;
            case 5:
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="() => SequenceSectionRef.GenerateSequence()">
                    Generate Sequence
                </MudButton>
                break;
            case 6:
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="() => CSROSectionRef.GenerateRequirement()">
                    Generate STRO
                </MudButton>
                break;
            case 77: 
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="() => CSPCSectionRef.GenerateControlPoints()">
                    Generate STCO
                </MudButton>
                break;
            case 8:
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="() => HCISectionRef.GenerateHCI()">
                    Generate HCI
                </MudButton>
                break;
        }

        @if (State.SelectedIndex == 3 || State.SelectedIndex == 7)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Info"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="GoNext"
                       Class="ml-2">
                @Localizer["Next Step"]
            </MudButton>
        }
    </DialogActions>
</MudDialog>