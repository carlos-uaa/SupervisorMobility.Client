    </DialogContent>
    <DialogActions>
        @if (loaded)
        {
            @switch (selectedIndexPageGenerate)
            {
                case 0:
                    @if (_sosHub.PATs?.Count == 0 || _sosHub.PATs?.Last().Status == 6)
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => CreatePatAsync())" Color="Color.Primary">
                            <MudText>@Localizer["create"] PAT</MudText>
                        </MudButton>
                    }
                    else
                    {


                        @if (Dev_env)
                        {

                            <MudSelect Style="float: left; margin-bottom: 10px;" T="int" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_sosHub.PATs.Last().Status">
                                <MudSelectItem Value="1">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlaylistPlay" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">@Localizer["new"]</MudChip>
                                </MudSelectItem>
                                <MudSelectItem Value="2">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                </MudSelectItem>
                                <MudSelectItem Value="3">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                </MudSelectItem>
                                <MudSelectItem Value="4">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                </MudSelectItem>
                                <MudSelectItem Value="5">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                </MudSelectItem>
                                <MudSelectItem Value="6">
                                    <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                </MudSelectItem>

                            </MudSelect>

                        }
                        @if (_sosHub.PATs?.Last().Status != 6)
                        {
                            <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => CreatePatAsync())" Color="Color.Primary">
                                <MudText>Revision</MudText>
                            </MudButton>
                        }
                    }
                    break;
                case 1:
                    @if (_sosHub.SOSAnalysis.Count == 0)
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateAnalysis())" Color="Color.Primary">
                            <MudText>Generate</MudText>
                        </MudButton>
                    }
                    else
                    {
                        @if (_sosAnalysis.AnalysisLogbooks?.Last().Status == 2)
                        {
                            <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateAnalysis())" Color="Color.Primary">
                                <MudText>Revision</MudText>
                            </MudButton>
                        }

                    }
                    break;
                case 2:


                    @if (_sosHub.SOSCombination.Count == 0)
                    {


                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateCombination())" Color="Color.Primary">
                            <MudText>Generate</MudText>
                        </MudButton>
                    }
                    else
                    {
                        @if (_sosCombination.CombinationLogbooks?.Last().Status == 2)
                        {

                            <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateCombination())" Color="Color.Primary">
                                <MudText>Revision</MudText>
                            </MudButton>
                        }

                    }
                    break;
                case 3:

                    @if (_sosHub.SOSDistribution.Count != 0)
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowRight" OnClick="@(() => selectedIndexPageGenerate = 33)" Color="Color.Primary">
                            <MudText>View Card</MudText>
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowRight" OnClick="@(() => selectedIndexPageGenerate = 33)" Color="Color.Primary">
                            <MudText>Next Step</MudText>
                        </MudButton>
                    }

                    break;
                case 33:
                    @if (_sosHub.SOSDistribution.Count == 0)
                    {
                        <MudButton Style="float: left" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowLeft" OnClick="@(() => selectedIndexPageGenerate = 3)" Color="Color.Primary">
                            <MudText>Return Step</MudText>
                        </MudButton>
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateDistribution())" Color="Color.Primary">
                            <MudText>Generate</MudText>
                        </MudButton>
                    }
                    else
                    {
                        @if (_sosDistribution.DistributionLogbooks?.Last().Status == 2)
                        {
                            <MudButton Style="float: left" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowLeft" OnClick="@(() => selectedIndexPageGenerate = 3)" Color="Color.Primary">
                                <MudText>Edit First Step</MudText>
                            </MudButton>
                            <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateDistribution())" Color="Color.Primary">
                                <MudText>Revision</MudText>
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Style="float: left" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowLeft" OnClick="@(() => selectedIndexPageGenerate = 3)" Color="Color.Primary">
                                <MudText>View First Step</MudText>
                            </MudButton>
                        }
                    }
                    break;

                case 4:
                    @if (_sosHub.SOSFlow.Count == 0)
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateFlow())" Color="Color.Primary">
                            <MudText>Generate</MudText>
                        </MudButton>
                    }
                    else
                    {
                        @if (_sosFlow.FlowLogbooks?.Last().Status == 2)
                        {
                            <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateFlow())" Color="Color.Primary">
                                <MudText>Revision</MudText>
                            </MudButton>
                        }

                    }
                    break;
                case 5:
                    @if (_sosHub.SOSSequence.Count == 0)
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateSequence())" Color="Color.Primary">
                            <MudText>Generate</MudText>
                        </MudButton>
                    }
                    else
                    {
                        @if (_sosSequence.SequenceLogbooks?.Last().Status == 2)
                        {
                            <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateSequence())" Color="Color.Primary">
                                <MudText>Revision</MudText>
                            </MudButton>
                        }

                    }
                    break;
                case 6:

                    @if (_sosHub.SOSSynopticOperatingRequirements.Count != 0)
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowRight" OnClick="@(() => selectedIndexPageGenerate = 66)" Color="Color.Primary">
                            <MudText>View Card</MudText>
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowRight" OnClick="@(() => selectedIndexPageGenerate = 66)" Color="Color.Primary">
                            <MudText>Next Step</MudText>
                        </MudButton>
                    }

                    break;
                case 66:
                    @if (_sosHub.SOSSynopticOperatingRequirements.Count == 0)
                    {
                        <MudButton Style="float: left" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowLeft" OnClick="@(() => selectedIndexPageGenerate = 6)" Color="Color.Primary">
                            <MudText>Return Step</MudText>
                        </MudButton>
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateSynopticRequirements())" Color="Color.Primary">
                            <MudText>Generate Synoptic</MudText>
                        </MudButton>
                    }
                    else
                    {
                        @if (_SOSSynopticRequirements.SynopticRequirementsLogbooks?.Last().Status == 2)
                        {
                            <MudButton Style="float: left" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowLeft" OnClick="@(() => selectedIndexPageGenerate = 6)" Color="Color.Primary">
                                <MudText>Edit First Step</MudText>
                            </MudButton>
                            <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() => GenerateSynopticRequirements())" Color="Color.Primary">
                                <MudText>Revision</MudText>
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Style="float: left" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowLeft" OnClick="@(() => selectedIndexPageGenerate = 6)" Color="Color.Primary">
                                <MudText>View First Step</MudText>
                            </MudButton>
                        }
                    }
                    break;

                case 7: break;
                case 8: break;
            }
        }
    </DialogActions>
</MudDialog>


