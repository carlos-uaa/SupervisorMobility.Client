@using SupervisorMobility.Client.Data.Entities.SOS_Process
@inject IStringLocalizer<Resource> Localizer
@inject ISOSDistributionService SOSDistributionService
@inject ISOSHubService SOSHubService
@inject IUserService UsersService
@inject IPlantService PlantService
@inject IDepartmentService DepartmentService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<style>
    .list-container { 
        height: 280px; 
        overflow-y: auto; 
        background-color: #fdfdfd; 
        border: 1px solid #e0e0e0; 
        border-radius: 8px;
    }

    /* Estilo para cuando no hay datos */
    .empty-state-dashed {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: calc(100% - 16px);
        border: 2px dashed #e0e0e0;
        margin: 8px;
        border-radius: 8px;
        background-color: #fafafa;
    }

    /* Cards de los items */
    .item-card { 
        background: white; 
        border: 1px solid #f0f0f0; 
        border-radius: 4px;
        transition: all 0.2s ease;
    }

    .item-card:hover { 
        background-color: #f9f9f9;
        transform: translateX(4px); 
        box-shadow: 2px 2px 5px rgba(0,0,0,0.05);
    }

    /* Bordes laterales de colores */
    .border-l-primary { border-left: 4px solid var(--mud-palette-primary) !important; }
    .border-l-secondary { border-left: 4px solid var(--mud-palette-secondary) !important; }
    .border-l-success { border-left: 4px solid var(--mud-palette-success) !important; }

    .mud-background-gray { background-color: #f8f9fa; }
    .border-radius-lg { border-radius: 12px; }
    
    /* Bordes dinámicos */
    .border-l-primary { border-left: 4px solid var(--mud-palette-primary) !important; }
    .border-l-secondary { border-left: 4px solid var(--mud-palette-secondary) !important; }
    .border-l-success { border-left: 4px solid var(--mud-palette-success) !important; }
    
    .bg-white { background-color: white !important; }
    .mud-input-control>.mud-input-control-input-container { width: 100% !important}
    .dialog { backdrop-filter: blur(10px); }
</style>

<MudGrid Spacing="3" Class="ma-0">
            
    <MudItem xs="12">
        <MudPaper Elevation="0" Class="pa-5 mud-background-gray border-radius-lg">
            <div class="d-flex align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.SettingsSuggest" Color="Color.Primary" Class="mr-2"/>
                <MudText Typo="Typo.h6" Style="font-weight: 800;">Configuración de Nueva Distribución</MudText>
            </div>

            <MudGrid Spacing="2">
                @* Campos Editables de Identificación *@
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_distribution.OperationName"
                                    Label="Nombre de la operación" 
                                    Variant="Variant.Outlined" 
                                    Margin="Margin.Dense" 
                                    Disabled="@(!(State.Hub.SOSAnalysis?.Count == 0 || _distribution.DistributionLogbooks?.Last().SOSDistributionLogbookId == 0))"
                                    Class="bg-white"/>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_distribution.InternalControlNumber"
                                    Label="Número de control interno" 
                                    Variant="Variant.Outlined" 
                                    Margin="Margin.Dense"
                                    Disabled="@(!(State.Hub.SOSAnalysis?.Count == 0 || _distribution.DistributionLogbooks?.Last().SOSDistributionLogbookId == 0))"
                                    Class="bg-white"/>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_distribution.ProcessName"
                                    Label="Nombre del proceso" 
                                    Variant="Variant.Outlined" 
                                    Margin="Margin.Dense" 
                                    Disabled="@(!(State.Hub.SOSAnalysis?.Count == 0 || _distribution.DistributionLogbooks?.Last().SOSDistributionLogbookId == 0))"
                                    Class="bg-white"/>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="State.Hub.TrainingTime"
                                     Label="Tiempo de aprendizaje"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Class="bg-white"
                                     Min="1" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Timer" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="State.Hub.CreatedDate"
                                    Label="Fecha de Emisión"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Class="bg-white" 
                                    Color="Color.Success"
                                    AdornmentColor="Color.Success"
                                    ReadOnly/>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_distribution.ApplicationMonth"
                                    Label="Mes"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Class="bg-white"
                                    Color="Color.Error"
                                    AdornmentColor="Color.Error"
                                    OpenTo="OpenTo.Month"
                                    IsDateDisabledFunc="@((DateTime dt) => (dt < DateTime.Now.AddDays(-1)))" />
                </MudItem>

                <MudItem xs="12" md="4">
                    @if (State.Hub.SOSDistribution == null || State.Hub.SOSDistribution.Count == 0 || State.Hub.SOSDistribution.Last().DistributionLogbooks?.Last().SOSDistributionLogbookId == 0)
                    {
                        <MudTextField @bind-Value="_distribution.TackTime"
                                      Label="Tiempo tacto"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="bg-white"
                                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.Timer" />
                    }
                    else
                    {
                        <MudTextField @bind-Value="_distribution.TackTime" ReadOnly="true"
                                      Label="Tiempo tacto"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="bg-white"
                                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.Timer" />
                    }
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudAutocomplete T="Plant" @bind-Value="selectedPlant"
                                        Label="Planta"
                                        SearchFunc="@SearchPlants"
                                        ToStringFunc="@(p => (p == null || p == new Plant()) ? null : $"{p.Code} - {p.Description}")"
                                        Variant="Variant.Outlined"
                                        Margin="Margin.Dense"
                                        Class="bg-white"
                                        ResetValueOnEmptyText="true"
                                        CoerceText="false"
                                        AdornmentIcon="@Icons.Material.Filled.Factory" 
                                        AdornmentColor="Color.Tertiary"/>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudAutocomplete T="Department" @bind-Value="selectedDepartment"
                                        Label="Gerencia"
                                        SearchFunc="@SearchDepartments"
                                        ToStringFunc="@(d => d == null ? null : $"{d.Code} - {d.Description}")"
                                        Variant="Variant.Outlined"
                                        Margin="Margin.Dense"
                                        Class="bg-white"
                                        ResetValueOnEmptyText="true"
                                        CoerceText="false"
                                        AdornmentIcon="@Icons.Material.Filled.AccountTree" 
                                        AdornmentColor="Color.Primary"/>
                </MudItem>

                @* Fila Informativa (Read Only) *@
                <MudItem xs="12" md="4">
                    <MudTextField Value="GetDate()" Label="Fecha de Registro" Variant="Variant.Filled" ReadOnly="true"
                                    Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Event" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField Value="GetRevNumber()" Label="Revisión Actual" Variant="Variant.Filled" ReadOnly="true"
                                    Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.History" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudField Label="Status" Variant="Variant.Filled" Margin="Margin.Dense" InnerPadding="false" Class="d-flex align-center" Style="width: 100% !important">
                        <MudChip Color="Color.Info" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.FiberNew" Class="ml-2 ma-0">NEW</MudChip>
                    </MudField>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>

    @* --- Columna: Unidades --- *@
    <MudItem xs="12" md="4" Style="margin-top: 10px;">
        <div class="d-flex align-center mb-2 px-1">
            <MudIcon Icon="@Icons.Material.Outlined.DirectionsCar" Color="Color.Success" Size="Size.Small" Class="mr-2" />
            <MudText Typo="Typo.subtitle2" Style="font-weight:700">Unidades</MudText>
            <MudSpacer />
            <MudBadge Content="@(State.Hub.AppliedModels?.Count ?? 0)" Color="Color.Success" Overlap="false" Bordered="true" Class="mr-7" />
        </div>
        <div class="list-container pa-2">
            @if (State.Hub.AppliedModels?.Any() == true)
            {
                @foreach (var item in State.Hub.AppliedModels)
                {
                    <MudPaper Elevation="0" Class="item-card pa-3 mb-2 border-l-success">
                        <MudText Typo="Typo.body2"><strong>@item.Code</strong> | @item.Description</MudText>
                    </MudPaper>
                }
            }
            else
            {
                <div class="empty-state-dashed">
                    <MudIcon Icon="@Icons.Material.Outlined.DirectionsCar" Size="Size.Large" Color="Color.Default" Style="opacity: 0.3;" />
                    <MudText Typo="Typo.caption" Class="mt-2" Style="opacity: 0.6;">Sin unidades registradas</MudText>
                </div>
            }
        </div>
    </MudItem>

    <MudItem xs="12" md="8">
        <div class="d-flex align-center mb-2 px-1">
            <MudIcon Icon="@Icons.Material.Filled.Cyclone" Color="Color.Secondary" Size="Size.Small" Class="mr-2" />
            <MudText Typo="Typo.subtitle2" Style="font-weight:700">Ciclos</MudText>
            <MudSpacer />
            <MudButton OnClick="AddNewTurn" StartIcon="@Icons.Material.Filled.Add" IconColor="Color.Secondary" Size="Size.Small" Class="mr-7">Ciclo</MudButton>
        </div>
        <div class="list-container pa-2">
            @if (_distribution.Turns?.Any() == true)
            {
                <MudTable Items="@_distribution.Turns"
                            Hover="true"
                            Breakpoint="Breakpoint.None"
                            Elevation="0"
                            Class="mt-2"
                            RowClass="pa-4">
                    <HeaderContent>
                        <MudTh Style="font-weight: 700; color: var(--mud-palette-secondary);">CICLO</MudTh>
                        <MudTh Style="font-weight: 700;">OPERADOR</MudTh>
                        <MudTh Style="font-weight: 700;">SUPERVISOR</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Ciclo">
                            <MudChip Color="Color.Secondary" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.Loop">
                                @context.TurnType
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Operador">
                            <MudAutocomplete T="User"
                                                @bind-Value="context.Operator"
                                                SearchFunc="@SearchOperators(context.Supervisor)"
                                                Placeholder="Seleccionar Operador..."
                                                Variant="Variant.Outlined"
                                                Adornment="Adornment.Start"
                                                AdornmentIcon="@Icons.Material.Outlined.Person"
                                                AdornmentColor="Color.Secondary"
                                                Margin="Margin.Dense"
                                                ResetValueOnEmptyText="true"
                                                CoerceText="true"
                                                ToStringFunc="@(u => u == null ? "" : $"{u.Name} ({GetUserType(u.UserType)})")" />
                        </MudTd>

                        <MudTd DataLabel="Supervisor">
                            <MudAutocomplete T="User"
                                                @bind-Value="context.Supervisor"
                                                SearchFunc="@SearchSupervisors"
                                                Placeholder="Seleccionar Supervisor..."
                                                Variant="Variant.Outlined"
                                                Adornment="Adornment.Start"
                                                AdornmentIcon="@Icons.Material.Outlined.SupervisedUserCircle"
                                                AdornmentColor="Color.Secondary"
                                                Margin="Margin.Dense"
                                                ResetValueOnEmptyText="true"
                                                CoerceText="true"
                                                ToStringFunc="@(u => u == null ? "" : $"{u.Name} ({GetUserType(u.UserType)})")" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <div class="empty-state-dashed">
                    <MudIcon Icon="@Icons.Material.Filled.Cyclone" Size="Size.Large" Color="Color.Default" Style="opacity: 0.3;" />
                    <MudText Typo="Typo.caption" Class="mt-2" Style="opacity: 0.6;">Sin ciclos registradas</MudText>
                </div>
            }
        </div>
    </MudItem>

    <MudItem xs="12">
        <MudDivider Class="my-2" />
        <MudGrid Spacing="2">
            <MudItem xs="12" md="6">
                <MudAutocomplete T="User" Label="Revisor Responsable" @bind-Value="_selectedReviewer" SearchFunc="@SearchUsers"
                                    ToStringFunc="@(u => u == null ? "" : $"{u.Name} ({u.UserId})")" ResetValueOnEmptyText="true"
                                    AdornmentIcon="@Icons.Material.Filled.PersonSearch" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudAutocomplete T="User" Label="Aprobador Final" @bind-Value="_selectedApprover" SearchFunc="@SearchUsers"
                                    ToStringFunc="@(u => u == null ? "" : $"{u.Name} ({u.UserId})")" ResetValueOnEmptyText="true"
                                    AdornmentIcon="@Icons.Material.Filled.VerifiedUser" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public SOSState State { get; set; }
    [Parameter] public AnalysisSequencesDto AnalysysSequences { get; set; }
    [Parameter] public EventCallback OnNotify { get; set; }

    private SOSDistribution _distribution = new SOSDistribution();

    private List<User> _allUsers = new();
    private User _selectedReviewer;
    private User _selectedApprover;
    private List<User> _supervisors { get; set; }
    private List<Plant> _plants { get; set; }
    private Plant selectedPlant { get; set; } = new Plant();
    private List<Department> _departments { get; set; }
    private Department selectedDepartment { get; set; } = new Department();

    private User user = new User();
    private string json = string.Empty;

    private List<User> _operators = new();
    private bool _isTableLoading = false;

    protected override async Task OnInitializedAsync()
    {
        // Obtener el usuario logeado del localStorage
        await GetLoggedUserAsync();

        _allUsers = (await UsersService.GetUsers(false, true)).ToList();
        if (State?.Hub?.SOSDistribution == null || State.Hub.SOSDistribution.Count == 0)
            _distribution = new SOSDistribution();
        else
            _distribution = State.Hub.SOSDistribution.First();

        // Cargar supervisores dependiendo del tipo de usuario logueado
        _supervisors = new List<User>();
        switch (user.UserType)
        {
            case 1:
                _supervisors = await UsersService.GetUsersByUserTypeInPlant(State.Hub.PlantId.Value, 3, false, true);
                _supervisors = _supervisors.OrderBy(s => s.Name).ToList();
                break;
            case 2:
                foreach (var sv in user.Subordinates.ToList())
                {
                    _supervisors?.Add(sv);
                }
                break;
            case 3:
                _supervisors?.Add(user);
                break;
        }

        // Cargar plantas
        if (_plants == null || !_plants.Any())
        {
            _plants = await PlantService.GetPlants();
            _plants = _plants.OrderBy(p => p.Description).ToList();
        }

        // Cargar departamentos
        if (_departments == null || !_plants.Any())
        {
            _departments = await DepartmentService.GetDepartments();
            _departments = _departments.OrderBy(d => d.Description).ToList();
        }
    }

    // Usuario en local storage
    private async Task GetLoggedUserAsync()
    {
        if (!await TryGetAsync())
            user = new();
    }

    private async Task<bool> TryGetAsync()
    {
        bool hasProperty = await HasPropertyAsync();
        if (hasProperty)
        {
            json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "user");
            user = JsonSerializer.Deserialize<User>(json) ?? new();
        }
        return hasProperty;
    }

    private async Task<bool> HasPropertyAsync() => await JSRuntime.InvokeAsync<bool>("localStorage.hasOwnProperty", "user");

    private void EditDistribution(SOSDistribution distribution)
    {
        // Navegación a la página de detalle de distribución
        NavigationManager.NavigateTo($"/sosdistribution/edit/{distribution.SOSDistributionId}");
    }

    private bool ValidateForm()
    {
        if (string.IsNullOrEmpty(_distribution.OperationName) || string.IsNullOrEmpty(_distribution.ProcessName) || string.IsNullOrEmpty(_distribution.InternalControlNumber))
        {
            Snackbar.Add("Por favor, complete los campos de identificación (Nombre de Operación, Nombre de Proceso y Número de Control Interno).", Severity.Warning);
            return false;
        }

        if (_selectedReviewer == null || _selectedReviewer.UserId == 0)
        {
            Snackbar.Add("Por favor, seleccione un Revisor Responsable.", Severity.Warning);
            return false;
        }

        if (_selectedApprover == null || _selectedApprover.UserId == 0)
        {
            Snackbar.Add("Por favor, seleccione un Aprobador Final.", Severity.Warning);
            return false;
        }

        return true;
    }

    public async Task GenerateDistribution()
    {
        if (!ValidateForm())
            return;

        _isTableLoading = true;
        try
        {
            // Llamar dialogo de confirmacion antes de realizar las acciones
            var dialogOptions = new DialogOptions() { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, DisableBackdropClick = true, ClassBackground = "dialog" };
            var dialogParameters = new DialogParameters
            {
                { "Title", "Confirm Create" },
                { "ContentText", "Are you sure you want to Create the SOS Distribution?" },
                { "ButtonText", "Create!" },
                { "CancelText", Localizer["Cancel"].Value },
                { "Color", Color.Success },
                { "Icon", @Icons.Material.Outlined.Add },
                { "IconColor", Color.Primary }
            };
            var dialog = await DialogService.ShowAsync<Confirmation>(Localizer["ConfirmationCreation"].Value, dialogParameters, dialogOptions);
            var dialogResult = await dialog.Result;

            if (dialogResult.Canceled)
                return; // Se cancela la creación

            if(State.Hub.SOSDistribution != null && State.Hub.SOSDistribution.Count > 0)
            {
                //REVISION
                if (_selectedReviewer.UserId == 0 || _selectedApprover.UserId == 0)
                {
                    bool? result = await DialogService.ShowMessageBox(
                       "Warning",
                       _selectedApprover == null || _selectedApprover == new User() ? "Es necesario el aprobador" : "Es necesario seleccionar el editor (elaboro)!",
                       yesText: "Ok!");
                    var state = result == null ? "Canceled" : "Deleted!";
                    StateHasChanged();
                    return;
                }

                var copySequences = _distribution.Sequences;
                var copyAnalyses = _distribution.Analyses;

                _distribution = State.Hub.SOSDistribution.First();

                if (_distribution.DistributionLogbooks != null || _distribution.DistributionLogbooks.First().SOSDistributionLogbookId == 0)
                {
                    _distribution.DistributionLogbooks.Clear();
                }

                SOSDistributionLogbook logDistribution = new();

                logDistribution.NoRevision = _distribution.DistributionLogbooks?.Count();
                logDistribution.ApproverId = _selectedApprover.UserId;
                logDistribution.ReviewerId = _selectedReviewer.UserId;
                logDistribution.Date = System.DateTime.Now;
                logDistribution.Status = 1;
                logDistribution.IsActive = true;
                if (_distribution.DistributionLogbooks == null)
                {
                    _distribution.DistributionLogbooks = new List<SOSDistributionLogbook>();
                }

                _distribution.DistributionLogbooks.Add(logDistribution);



                var Gen_sosDistribution = await SOSHubService.GenerateDistribution(State.Hub.SOSHubId, _distribution);

                Snackbar.Clear();
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
                if (Gen_sosDistribution != 0)
                {
                    Snackbar.Add($"{Localizer["_sosDistributionGeneratedSucces"]}", Severity.Info);
                    NavigationManager.NavigateTo($"/soshoe/Distribution/Details/{_distribution.SOSDistributionId}");
                    _distribution = new SOSDistribution();
                    //Pregutar si quiere ver el analisis generado
                }
                else
                {
                    Snackbar.Add($"{Localizer["Fail_sosDistributionGeneratedSucces"]}", Severity.Error);
                }

                StateHasChanged();

            }
            else
            {
                if (_selectedReviewer.UserId == 0 || _selectedApprover.UserId == 0)
                {
                    bool? result = await DialogService.ShowMessageBox(
                       "Warning",
                       string.IsNullOrEmpty(_distribution.OperationName) ? "Es necesario el aproador" : "Es necesario seleccionar el editor (elaboro)!",
                       yesText: "Ok!");
                    var state = result == null ? "Canceled" : "Deleted!";
                    StateHasChanged();
                }
                else if (string.IsNullOrEmpty(_distribution.ProcessName) || string.IsNullOrEmpty(_distribution.InternalControlNumber))
                {
                    bool? result = await DialogService.ShowMessageBox(
                      "Warning",
                      string.IsNullOrEmpty(_distribution.ProcessName) ? "Es necesario el nombre de Proceso" : "Es necesario el nombre del proceso!",
                      yesText: "Ok!");
                    var state = result == null ? "Canceled" : "Deleted!";
                    StateHasChanged();
                }
                else if (string.IsNullOrEmpty(_distribution.OperationName))
                {
                    bool? result = await DialogService.ShowMessageBox(
                      "Warning",
                       "Es necesario el nombre de operacion!",
                      yesText: "Ok!");
                    var state = result == null ? "Canceled" : "Deleted!";
                    StateHasChanged();
                }
                else
                {
                    //reviewer = SV = Editor  //Approver = SSV = owner

                    //_sosDistribution.ReviewerId = ReviewerDistributionId;
                    //_sosDistribution.ApproverId = ApproverDistributionId;
                    SOSDistributionLogbook logDistribution = new();

                    logDistribution.NoRevision = 0;
                    logDistribution.ReviewerId = _selectedReviewer.UserId;
                    logDistribution.ApproverId = _selectedApprover.UserId;
                    logDistribution.Date = System.DateTime.Now;
                    logDistribution.Status = 1;
                    logDistribution.IsActive = true;
                    if (_distribution.DistributionLogbooks == null)
                    {
                        _distribution.DistributionLogbooks = new List<SOSDistributionLogbook>();
                    }

                    _distribution.DistributionLogbooks.Add(logDistribution);

                    if (_distribution.SOSDistributionOperationSequence == null)
                    {
                        _distribution.SOSDistributionOperationSequence = new List<SOSDistributionOperationSequence>();
                    }

                    var Gen_sosDistribution = await SOSHubService.GenerateDistribution(State.Hub.SOSHubId, _distribution);

                    Snackbar.Clear();
                    Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
                    if (Gen_sosDistribution != 0)
                    {
                        Snackbar.Add($"{Localizer["_sosDistributionGeneratedSucces"]}", Severity.Info);
                        NavigationManager.NavigateTo($"/soshoe/Distribution/Details/{Gen_sosDistribution}");
                        _distribution = new SOSDistribution();
                        //Pregutar si quiere ver el analisis generado
                    }
                    else
                    {
                        Snackbar.Add($"{Localizer["Fail_sosDistributionGeneratedSucces"]}", Severity.Error);
                    }

                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isTableLoading = false;
        }
    }

    private string GetRevNumber()
    {
        string number = string.Empty;

        // Validación inicial
        if (State?.Hub?.SOSDistribution == null || State.Hub.SOSDistribution.Count == 0)
            return "No Distribution";

        if (_distribution.DistributionLogbooks == null || !_distribution.DistributionLogbooks.Any())
            return "No Logbooks";

        var lastLogbook = _distribution.DistributionLogbooks.Last();

        if (lastLogbook.NoRevision == 0)
            number = $"New - {_distribution.DistributionLogbooks.Count()}";
        else if (lastLogbook.SOSDistributionLogbookId == 0)
            number = $"NewTemporal - {_distribution.DistributionLogbooks.Count()}";
        else if (lastLogbook.Status == 2)
            number = $"NewRevision - {_distribution.DistributionLogbooks.Count()}";
        else
            number = $"{lastLogbook.NoRevision}";

        return number;
    }

    private string GetDate()
    {
        string date = string.Empty;

        // Validación inicial
        if (State?.Hub?.SOSDistribution == null || State.Hub.SOSDistribution.Count == 0)
            return DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "");

        if (_distribution.DistributionLogbooks == null || !_distribution.DistributionLogbooks.Any())
            return DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "");

        var lastLogbook = _distribution.DistributionLogbooks.Last();

        if (lastLogbook.NoRevision == 0)
            date = DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "");
        else if (lastLogbook.SOSDistributionLogbookId == 0)
            date = $"NewTemporal - {DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")}";
        else if (lastLogbook.Status == 2)
            date = $"NewRevision - {DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")}";
        else
            date = lastLogbook.Date?.ToString("dd-MMM-yyyy").Replace(".", "");

        return date;
    }

    // Función de búsqueda para MudAutocomplete
    private async Task<IEnumerable<User>> SearchUsers(string value)
    {
        if (string.IsNullOrEmpty(value))
            return _allUsers;

        return _allUsers.Where(x =>
            x.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            x.UserType.ToString().Contains(value)
        );
    }

    private string GetUserType(int userType) => userType switch
    {
        1 => "Administrador",
        2 => "SSV",
        3 => "SV",
        4 => "Operador",
        5 => "Manager",
        6 => "Line Support",
        7 => "Head Count",
        8 => "Users RTC",
        _ => "Desconocido"
    };

    private void AddNewTurn()
    {
        // Inicializar la lista si por alguna razón es nula
        _distribution.Turns ??= new List<Turn>();

        // Validar el límite de 3
        if (_distribution.Turns.Count >= 3)
        {
            Snackbar.Add("Solo se permiten hasta 3 ciclos por distribución.", Severity.Info);
            return;
        }

        // Determinar el TurnType según la posición
        string nextTurnType = _distribution.Turns.Count switch
        {
            0 => "1ero",
            1 => "2ndo",
            2 => "3ero",
            _ => "Extra"
        };

        // 4. Crear y agregar el nuevo modelo
        var newTurn = new Turn
        {
            TurnType = nextTurnType
        };

        _distribution.Turns.Add(newTurn);

        StateHasChanged();
    }

    private Task<IEnumerable<int>> SearchHySReviewer(string searchString)
    {
        IEnumerable<int> result;

        if (string.IsNullOrEmpty(searchString))
        {
            result = _supervisors.Select(x => x.UserId);
        }
        else
        {
            result = _supervisors
                .Where(x => x.Name.Contains(searchString, StringComparison.InvariantCultureIgnoreCase))
                .Select(x => x.UserId);
        }

        return Task.FromResult(result);
    }

    private async Task<IEnumerable<Plant>> SearchPlants(string value)
    {
        if (_plants == null) return new List<Plant>();

        if (string.IsNullOrEmpty(value) || value.Trim() == "-")
            return _plants.Take(20);

        return _plants.Where(x =>
            x.Code.Contains(value, StringComparison.InvariantCultureIgnoreCase) ||
            x.Description.Contains(value, StringComparison.InvariantCultureIgnoreCase)
        ).Take(20);
    }

    private async Task<IEnumerable<Department>> SearchDepartments(string value)
    {
        if (_departments == null) return new List<Department>();

        if (string.IsNullOrEmpty(value) || value.Trim() == "-")
            return _departments.Take(20);

        return _departments.Where(x =>
            (x.Code?.Contains(value, StringComparison.InvariantCultureIgnoreCase) ?? false) ||
            (x.Description?.Contains(value, StringComparison.InvariantCultureIgnoreCase) ?? false)
        ).Take(20);
    }

    private async Task<IEnumerable<User>> SearchSupervisors(string value)
    {
        if (_supervisors == null) return new List<User>();

        if (string.IsNullOrEmpty(value) || value.Trim() == "-")
            return _supervisors.Take(20);

        return _supervisors.Where(x =>
            (x.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            x.UserType.ToString().Contains(value))
        ).Take(20);
    }

    private Func<string, Task<IEnumerable<User>>> SearchOperators(User supervisor)
    {
        return async (string value) =>
        {
            if (supervisor?.Subordinates == null)
                return Enumerable.Empty<User>();

            if (string.IsNullOrWhiteSpace(value))
                return supervisor.Subordinates;

            return supervisor.Subordinates.Where(u =>
                u.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase));
        };
    }
