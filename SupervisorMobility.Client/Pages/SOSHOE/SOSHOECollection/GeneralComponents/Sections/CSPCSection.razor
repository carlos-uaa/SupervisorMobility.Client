@using SupervisorMobility.Client.Data.Entities.SOS_Process
@inject ISynopticControlPointsService ControlPointsService
@inject ISOSHubService SOSHubService
@inject IUserService UsersServices
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource> Localizer

<style>
    .mud-background-gray { background-color: #f8f9fa; }
    .border-radius-lg { border-radius: 12px; }
    .bg-white { background-color: white !important; }
    .dialog { backdrop-filter: blur(10px); }
</style>

<MudGrid Spacing="3" Class="ma-0">
    
    @* HEADER CON INFORMACIÓN GENERAL *@
    <MudItem xs="12">
        <MudPaper Elevation="0" Class="pa-5 mud-background-gray border-radius-lg">
            <div class="d-flex align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.ChecklistRtl" Color="Color.Primary" Class="mr-2"/>
                <MudText Typo="Typo.h6" Style="font-weight: 800;">Configuración de Nuevo Cuadro Sinóptico de Puntos de Control</MudText>
            </div>

            <MudGrid Spacing="2">
                @* Primera fila: PROCESO, MODELOS *@
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_sosControlPoints.ProcessName"
                                  Label="Proceso"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  ReadOnly="@(State.SynopticTableOfControlPoints?.Count > 0)" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <div style="padding-top: 8px;">
                        <MudText Typo="Typo.caption" Style="display: block; margin-bottom: 4px;">Modelos</MudText>
                        <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                            @if (State.Hub?.AppliedModels?.Count > 0)
                            {
                                @foreach (var model in State.Hub.AppliedModels)
                                {
                                    <MudChip Color="Color.Secondary" Icon="@Icons.Material.Filled.DirectionsCar" Size="Size.Small">
                                        @model.Description
                                    </MudChip>
                                }
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Style="opacity: 0.6;">Sin modelos asignados</MudText>
                            }
                        </div>
                    </div>
                </MudItem>

                @* Segunda fila: MES, PLANTA *@
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="_sosControlPoints.CreatedAt"
                                   Label="Mes"
                                   Variant="Variant.Filled"
                                   Margin="Margin.Dense"
                                   ReadOnly="true"
                                   Editable="false"
                                   Style="background-color: #e9ecef;" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField Value="@State.Hub?.Plant?.Description"
                                  Label="Planta"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  ReadOnly="true" />
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>

    @* SELECCIÓN DE USUARIOS *@
    <MudItem xs="12">
        <MudDivider Class="my-2" />
        <MudGrid Spacing="2">
            <MudItem xs="12" md="4">
                <MudAutocomplete T="int"
                                 Label="Elaboró"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 @bind-Value="OwnerControlPointsId"
                                 AdornmentIcon="@Icons.Material.Filled.PersonSearch"
                                 AdornmentColor="Color.Default"
                                 Clearable
                                 ResetValueOnEmptyText
                                 ReadOnly="@(State.SynopticTableOfControlPoints?.Count > 0)"
                                 ShowProgressIndicator="true"
                                 ProgressIndicatorColor="Color.Info"
                                 ToStringFunc="@(s => State.Hub.ApproverOwners?.FirstOrDefault(x => x.UserId == s)?.Name)"
                                 SearchFunc="SearchApproverOwners" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudAutocomplete T="int"
                                 Label="Revisó"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 @bind-Value="ReviewerControlPointsId"
                                 AdornmentIcon="@Icons.Material.Filled.PersonSearch"
                                 AdornmentColor="Color.Default"
                                 Clearable
                                 ResetValueOnEmptyText
                                 ReadOnly="@(State.SynopticTableOfControlPoints?.Count > 0)"
                                 ShowProgressIndicator="true"
                                 ProgressIndicatorColor="Color.Info"
                                 ToStringFunc="@(s => _supervisors.FirstOrDefault(x => x.UserId == s)?.Name)"
                                 SearchFunc="SearchSupervisors" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudAutocomplete T="int"
                                 Label="Aprobó"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 @bind-Value="ApproverControlPointsId"
                                 AdornmentIcon="@Icons.Material.Filled.VerifiedUser"
                                 AdornmentColor="Color.Default"
                                 Clearable
                                 ResetValueOnEmptyText
                                 ReadOnly="@(State.SynopticTableOfControlPoints?.Count > 0)"
                                 ShowProgressIndicator="true"
                                 ProgressIndicatorColor="Color.Info"
                                 ToStringFunc="@(s => State.Hub.ApproverOwners?.FirstOrDefault(x => x.UserId == s)?.Name)"
                                 SearchFunc="SearchApproverOwners" />
            </MudItem>
        </MudGrid>
    </MudItem>

</MudGrid>

@code {
    [Parameter] public SOSState State { get; set; }
    [Parameter] public AnalysisSequencesDto AnalysysSequences { get; set; }
    [Parameter] public EventCallback OnNotify { get; set; }

    private SOSSynopticTableofControlPoints _sosControlPoints = new();
    private List<User> _supervisors = new();

    private int OwnerControlPointsId = 0;
    private int ReviewerControlPointsId = 0;
    private int ApproverControlPointsId = 0;

    protected override async Task OnInitializedAsync()
    {
        // Cargar supervisores para el autocomplete de REVISO
        var allUsers = (await UsersServices.GetUsers(false, true)).ToList();
        _supervisors = allUsers.Where(x => x.UserType == 3).ToList();

        // Si ya existe un registro, cargarlo
        if (State?.SynopticTableOfControlPoints?.Any() == true)
        {
            _sosControlPoints = State.SynopticTableOfControlPoints.First();
        }
        else
        {
            _sosControlPoints = new SOSSynopticTableofControlPoints
            {
                CreatedAt = DateTime.Now
            };
        }
    }

    private Task<IEnumerable<int>> SearchApproverOwners(string searchString)
    {
        IEnumerable<int> result;

        if (string.IsNullOrEmpty(searchString))
            result = State.Hub.ApproverOwners?.Select(x => x.UserId) ?? Enumerable.Empty<int>();
        else
            result = State.Hub.ApproverOwners?
                .Where(x => x.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                .Select(x => x.UserId) ?? Enumerable.Empty<int>();

        return Task.FromResult(result);
    }

    private Task<IEnumerable<int>> SearchSupervisors(string searchString)
    {
        IEnumerable<int> result;

        if (string.IsNullOrEmpty(searchString))
            result = _supervisors.Select(x => x.UserId);
        else
            result = _supervisors
                .Where(x => x.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                .Select(x => x.UserId);

        return Task.FromResult(result);
    }

    public async Task GenerateControlPoints()
    {
        if (string.IsNullOrEmpty(_sosControlPoints.ProcessName))
        {
            Snackbar.Add("Es necesario agregar el Nombre del proceso", Severity.Warning);
            return;
        }

        // Llamar dialogo de confirmacion antes de realizar las acciones
        var dialogOptions = new DialogOptions() { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, DisableBackdropClick = true, ClassBackground = "dialog" };
        var dialogParameters = new DialogParameters
        {
            { "Title", "Confirm Create" },
            { "ContentText", "Are you sure you want to Create this Synoptic Table of Control Points?" },
            { "ButtonText", "Create!" },
            { "CancelText", Localizer["Cancel"].Value },
            { "Color", Color.Success },
            { "Icon", @Icons.Material.Outlined.Add },
            { "IconColor", Color.Primary }
        };
        var dialog = await DialogService.ShowAsync<Confirmation>("Confirm creation", dialogParameters, dialogOptions);
        var dialogResult = await dialog.Result;

        if (dialogResult.Canceled)
            return;

        if (State.Hub.SOSSynopticControlPoints != null && State.Hub.SOSSynopticControlPoints.Count > 0)
        {
            if (ApproverControlPointsId == 0)
            {
                bool? result = await DialogService.ShowMessageBox(
                   "Warning",
                   ApproverControlPointsId == 0 ? "Es necesario el aprobador" : "Es necesario seleccionar el editor (elaboro)!",
                   yesText: "Ok!");
                var state = result == null ? "Canceled" : "Deleted!";
                StateHasChanged();
                return;
            }

            var copySequences = _sosControlPoints.Sequences;
            var copyAnalyses = _sosControlPoints.Analyses;

            _sosControlPoints = State.Hub.SOSSynopticControlPoints.First();

            if (_sosControlPoints.SynopticPointsLogbooks != null && _sosControlPoints.SynopticPointsLogbooks.First().SOSSynopticPointsLogbookId == 0)
                _sosControlPoints.SynopticPointsLogbooks.Clear();

            SOSSynopticPointsLogbook logGenerateSynopticControlPoints = new SOSSynopticPointsLogbook();

            logGenerateSynopticControlPoints.NoRevision = _sosControlPoints.SynopticPointsLogbooks?.Count();
            logGenerateSynopticControlPoints.ApproverId = ApproverControlPointsId;
            logGenerateSynopticControlPoints.Date = System.DateTime.Now;
            logGenerateSynopticControlPoints.Status = 1;
            logGenerateSynopticControlPoints.IsActive = true;
            if (_sosControlPoints.SynopticPointsLogbooks == null)
                _sosControlPoints.SynopticPointsLogbooks = new List<SOSSynopticPointsLogbook>();

            _sosControlPoints.SynopticPointsLogbooks.Add(logGenerateSynopticControlPoints);



            var Gen_SOSSynopticRequirements = await SOSHubService.GenerateSynopticControlPoints(State.Hub.SOSHubId, _sosControlPoints);

            Snackbar.Clear();
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            if (Gen_SOSSynopticRequirements != 0)
            {
                Snackbar.Add($"{Localizer["_SOSSynopticControlPointsGeneratedSuccess"]}", Severity.Info);
                NavigationManager.NavigateTo($"/soshoe/SynopticControlPoints/Details/{_sosControlPoints.SOSSynopticTableofControlPointsId}");
                _sosControlPoints = new SOSSynopticTableofControlPoints();
                //Pregutar si quiere ver el analisis generado
            }
            else
                Snackbar.Add($"{Localizer["Fail_SOSSynopticControlPointsGeneratedSuccess"]}", Severity.Error);

            StateHasChanged();

        }
        else
        {
            if (string.IsNullOrEmpty(_sosControlPoints.ProcessName) || OwnerControlPointsId == 0)
            {
                bool? result = await DialogService.ShowMessageBox(
                  "Warning",
                   OwnerControlPointsId == 0 ? "Es necesario el elaborador" : "Es necesario el nombre de processo!",
                  yesText: "Ok!");
                var state = result == null ? "Canceled" : "Deleted!";
                StateHasChanged();
            }
            else if (ApproverControlPointsId == 0 || ReviewerControlPointsId == 0)
            {
                bool? result = await DialogService.ShowMessageBox(
                  "Warning",
                  ApproverControlPointsId == 0 ? "Es necesario el aprovador" : "Es necesario seleccionar el editor!",
                  yesText: "Ok!");
                var state = result == null ? "Canceled" : "Deleted!";
                StateHasChanged();
            }
            else
            {
                _sosControlPoints.SOSHubId = State.Hub.SOSHubId;
                _sosControlPoints.ReviewerId = ReviewerControlPointsId;
                _sosControlPoints.ApproverId = ApproverControlPointsId;
                _sosControlPoints.CreatorId = OwnerControlPointsId;

                SOSSynopticPointsLogbook logGenerateSynopticControlPoints = new SOSSynopticPointsLogbook();

                logGenerateSynopticControlPoints.NoRevision = 0;
                logGenerateSynopticControlPoints.ApproverId = ApproverControlPointsId;
                logGenerateSynopticControlPoints.Date = System.DateTime.Now;
                logGenerateSynopticControlPoints.Status = 1;
                logGenerateSynopticControlPoints.IsActive = true;
                if (_sosControlPoints.SynopticPointsLogbooks == null)
                    _sosControlPoints.SynopticPointsLogbooks = new List<SOSSynopticPointsLogbook>();

                _sosControlPoints.SynopticPointsLogbooks.Add(logGenerateSynopticControlPoints);


                if (_sosControlPoints.SOSSynopticRequirementsOperationSequence == null)
                    _sosControlPoints.SOSSynopticRequirementsOperationSequence = new List<SOSSynopticRequirementsOperationSequence>();


                var Gen_sosControlPoints = await SOSHubService.GenerateSynopticControlPoints(State.Hub.SOSHubId, _sosControlPoints);

                Snackbar.Clear();
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
                if (Gen_sosControlPoints != 0)
                {
                    Snackbar.Add($"{Localizer["_SOSSynopticControlPointsGeneratedSuccess"]}", Severity.Info);
                    NavigationManager.NavigateTo($"/soshoe/SynopticControlPoints/Details/{Gen_sosControlPoints}");
                    _sosControlPoints = new SOSSynopticTableofControlPoints();
                }
                else
                    Snackbar.Add($"{Localizer["Fail_SOSSynopticControlPointsGeneratedSuccess"]}", Severity.Error);

                StateHasChanged();
            }
        }
    }
}