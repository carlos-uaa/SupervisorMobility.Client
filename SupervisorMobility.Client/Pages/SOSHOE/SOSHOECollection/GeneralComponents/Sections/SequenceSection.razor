@using SupervisorMobility.Client.Data.Entities.SOS_Process
@inject ISOSHubService SOSHubService
@inject ISnackbar Snackbar
@inject IUserService UsersService
@inject NavigationManager NavigationManager

<style>
    .list-container {
        height: 280px;
        overflow-y: auto;
        background-color: #fdfdfd;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
    }

    /* Estilo para cuando no hay datos */
    .empty-state-dashed {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: calc(100% - 16px);
        border: 2px dashed #e0e0e0;
        margin: 8px;
        border-radius: 8px;
        background-color: #fafafa;
    }

    /* Cards de los items */
    .item-card {
        background: white;
        border: 1px solid #f0f0f0;
        border-radius: 4px;
        transition: all 0.2s ease;
    }

    .item-card:hover { background-color: #f9f9f9; transform: translateX(4px); box-shadow: 2px 2px 5px rgba(0,0,0,0.05); }

    /* Bordes laterales de colores */
    .border-l-primary { border-left: 4px solid var(--mud-palette-primary) !important; }
    .border-l-secondary { border-left: 4px solid var(--mud-palette-secondary) !important; }
    .border-l-success { border-left: 4px solid var(--mud-palette-success) !important; }
    .mud-background-gray { background-color: #f8f9fa; }
    .border-radius-lg { border-radius: 12px; }

    /* Bordes dinámicos */
    .border-l-primary { border-left: 4px solid var(--mud-palette-primary) !important; }
    .border-l-secondary { border-left: 4px solid var(--mud-palette-secondary) !important; }
    .border-l-success { border-left: 4px solid var(--mud-palette-success) !important; }
    .bg-white { background-color: white !important; }
    .mud-input-control > .mud-input-control-input-container { width: 100% !important }
</style>

<MudGrid Spacing="3" Class="ma-0">

    <MudItem xs="12">
        <MudPaper Elevation="0" Class="pa-5 mud-background-gray border-radius-lg">
            <div class="d-flex align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.SettingsSuggest" Color="Color.Primary" Class="mr-2" />
                <MudText Typo="Typo.h6" Style="font-weight: 800;">Configuración de la Nueva Sequencia</MudText>
            </div>

            <MudGrid Spacing="2">
                @* Campos Editables de Identificación *@
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_sequence.OperationName"
                                    Label="Nombre de la operación"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Disabled="@IsSequenceEditDisabled()"
                                    Class="bg-white" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_sequence.InternalControlNumber"
                                    Label="Número de control interno"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Disabled="@IsSequenceEditDisabled()"
                                    Class="bg-white" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_sequence.ProcessName"
                                    Label="Nombre del proceso"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Disabled="@IsSequenceEditDisabled()"
                                    Class="bg-white" />
                </MudItem>

                @* Fila Informativa (Read Only) *@
                <MudItem xs="12" md="4">
                    <MudTextField Value="GetDate()" Label="Fecha de Registro" Variant="Variant.Filled" ReadOnly="true"
                                    Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Event" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField Value="GetRevNumber()" Label="Revisión Actual" Variant="Variant.Filled" ReadOnly="true"
                                    Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.History" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudField Label="Status" Variant="Variant.Filled" Margin="Margin.Dense" InnerPadding="false" Class="d-flex align-center" Style="width: 100% !important">
                        <MudChip Color="Color.Info" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.FiberNew" Class="ml-2 ma-0">NEW</MudChip>
                    </MudField>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>

    @* --- Columna: Equipo de Seguridad --- *@
    <MudItem xs="12" md="4">
        <div class="d-flex align-center mb-2 px-1">
            <MudIcon Icon="@Icons.Material.Outlined.Shield" Color="Color.Primary" Size="Size.Small" Class="mr-2" />
            <MudText Typo="Typo.subtitle2" Style="font-weight:700">Equipo de Seguridad</MudText>
            <MudSpacer />
            <MudBadge Content="@(State.Hub.SafetyEquipment?.Count ?? 0)" Color="Color.Primary" Overlap="false" Bordered="true" Class="mr-4" />
        </div>
        <div class="list-container pa-2">
            @if (State.Hub.SafetyEquipment?.Any() == true)
            {
                @foreach (var item in State.Hub.SafetyEquipment)
                {
                    <MudPaper Elevation="0" Class="item-card pa-3 mb-2 border-l-primary">
                        <MudText Typo="Typo.body2">@item.EquipmentName</MudText>
                    </MudPaper>
                }
            }
            else
            {
                <div class="empty-state-dashed">
                    <MudIcon Icon="@Icons.Material.Outlined.Shield" Size="Size.Large" Color="Color.Default" Style="opacity: 0.3;" />
                    <MudText Typo="Typo.caption" Class="mt-2" Style="opacity: 0.6;">Sin equipo de seguridad registrado</MudText>
                </div>
            }
        </div>
    </MudItem>

    @* --- Columna: Herramientas --- *@
    <MudItem xs="12" md="4">
        <div class="d-flex align-center mb-2 px-1">
            <MudIcon Icon="@Icons.Material.Outlined.Build" Color="Color.Secondary" Size="Size.Small" Class="mr-2" />
            <MudText Typo="Typo.subtitle2" Style="font-weight:700">Herramientas</MudText>
            <MudSpacer />
            <MudBadge Content="@(State.Hub.ToolsUsed?.Count ?? 0)" Color="Color.Secondary" Overlap="false" Bordered="true" Class="mr-4" />
        </div>
        <div class="list-container pa-2">
            @if (State.Hub.ToolsUsed?.Any() == true)
            {
                @foreach (var item in State.Hub.ToolsUsed)
                {
                    <MudPaper Elevation="0" Class="item-card pa-3 mb-2 border-l-secondary">
                        <MudText Typo="Typo.body2" Class="font-bold">@item.Tool.ToolCode</MudText>
                    </MudPaper>
                }
            }
            else
            {
                <div class="empty-state-dashed">
                    <MudIcon Icon="@Icons.Material.Outlined.Build" Size="Size.Large" Color="Color.Default" Style="opacity: 0.3;" />
                    <MudText Typo="Typo.caption" Class="mt-2" Style="opacity: 0.6;">Sin herramientas registradas</MudText>
                </div>
            }
        </div>
    </MudItem>

    @* --- Columna: Unidades --- *@
    <MudItem xs="12" md="4">
        <div class="d-flex align-center mb-2 px-1">
            <MudIcon Icon="@Icons.Material.Outlined.DirectionsCar" Color="Color.Success" Size="Size.Small" Class="mr-2" />
            <MudText Typo="Typo.subtitle2" Style="font-weight:700">Unidades</MudText>
            <MudSpacer />
            <MudBadge Content="@(State.Hub.AppliedModels?.Count ?? 0)" Color="Color.Success" Overlap="false" Bordered="true" Class="mr-7" />
        </div>
        <div class="list-container pa-2">
            @if (State.Hub.AppliedModels?.Any() == true)
            {
                @foreach (var item in State.Hub.AppliedModels)
                {
                    <MudPaper Elevation="0" Class="item-card pa-3 mb-2 border-l-success">
                        <MudText Typo="Typo.body2"><strong>@item.Code</strong> | @item.Description</MudText>
                    </MudPaper>
                }
            }
            else
            {
                <div class="empty-state-dashed">
                    <MudIcon Icon="@Icons.Material.Outlined.DirectionsCar" Size="Size.Large" Color="Color.Default" Style="opacity: 0.3;" />
                    <MudText Typo="Typo.caption" Class="mt-2" Style="opacity: 0.6;">Sin unidades registradas</MudText>
                </div>
            }
        </div>
    </MudItem>

    <MudItem xs="12">
        <MudDivider Class="my-2" />
        <MudGrid Spacing="2">
            <MudItem xs="12" md="4">
                <MudNumericField @bind-Value="State.Hub.TrainingTime" Label="Tiempo de aprendizaje (min)"
                                    Variant="Variant.Outlined" Min="0" Margin="Margin.Dense" Disabled="@IsSequenceEditDisabled()"
                                    Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Timer" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudAutocomplete T="User" Label="Revisor Responsable" @bind-Value="_selectedReviewer" SearchFunc="@SearchReviewers"
                                    ToStringFunc="@(u => u == null ? "" : $"{u.Name} ({u.UserId})")" ResetValueOnEmptyText="true"
                                    AdornmentIcon="@Icons.Material.Filled.PersonSearch" Variant="Variant.Outlined" Margin="Margin.Dense"
                                    Disabled="@IsSequenceEditDisabled()" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudAutocomplete T="User" Label="Aprobador Final" @bind-Value="_selectedApprover" SearchFunc="@SearchApprovers"
                                    ToStringFunc="@(u => u == null ? "" : $"{u.Name} ({u.UserId})")" ResetValueOnEmptyText="true"
                                    AdornmentIcon="@Icons.Material.Filled.VerifiedUser" Variant="Variant.Outlined" Margin="Margin.Dense"
                                    Disabled="@IsSequenceEditDisabled()" />
            </MudItem>
        </MudGrid>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public SOSState State { get; set; }
    [Parameter] public EventCallback OnNotify { get; set; }

    private SOSSequence _sequence = new SOSSequence();
    private User _selectedReviewer;
    private User _selectedApprover;
    private List<User> _allUsers = new List<User>();
    private List<User> _reviewUsers = new List<User>();
    private List<User> _approveUsers = new List<User>();
    private bool _isTableLoading = false;

    protected override async Task OnInitializedAsync()
    {
        _allUsers = (await UsersService.GetUsers(false, false)).ToList();

        // Load SVs (type 3) and SSVs (type 2) by plant
        if (State?.Hub?.PlantId.HasValue == true)
        {
            _reviewUsers = await UsersService.GetUsersByUserTypeInPlant(State.Hub.PlantId.Value, 3, false, false);
            _reviewUsers = _reviewUsers.OrderBy(s => s.Name).ToList();
            
            _approveUsers = await UsersService.GetUsersByUserTypeInPlant(State.Hub.PlantId.Value, 2, false, false);
            _approveUsers = _approveUsers.OrderBy(s => s.Name).ToList();
        }

        if (State?.Hub?.SOSSequence != null && State.Hub.SOSSequence.Count > 0)
        {
            // Ya existe una secuencia, cargar la primera
            _sequence = State.Hub.SOSSequence.First();

            // Si tiene logbooks, cargar el último revisor y aprobador para mostrarlos
            if (_sequence.SequenceLogbooks != null && _sequence.SequenceLogbooks.Any())
            {
                var lastLogbook = _sequence.SequenceLogbooks.LastOrDefault();
                _selectedReviewer = _allUsers.FirstOrDefault(u => u.UserId == lastLogbook.ReviewerId);
                _selectedApprover = _allUsers.FirstOrDefault(u => u.UserId == lastLogbook.ApproverId);
            }
        }
        else
        {
            // Nueva secuencia - inicializar vacío
            _sequence = new SOSSequence();
        }
    }

    private async Task<IEnumerable<User>> SearchReviewers(string value)
    {
        if (_reviewUsers == null || _reviewUsers.Count == 0)
            return new List<User>();

        if (string.IsNullOrEmpty(value))
        {
            return _reviewUsers.Take(20);
        }

        return _reviewUsers.Where(x =>
            x.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            (x.Payroll.HasValue && x.Payroll.Value.ToString().Contains(value)) ||
            x.UserId.ToString().Contains(value)
        ).Take(20);
    }

    private async Task<IEnumerable<User>> SearchApprovers(string value)
    {
        if (_approveUsers == null || _approveUsers.Count == 0)
            return new List<User>();

        if (string.IsNullOrEmpty(value))
        {
            return _approveUsers.Take(20);
        }

        return _approveUsers.Where(x =>
            x.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            (x.Payroll.HasValue && x.Payroll.Value.ToString().Contains(value)) ||
            x.UserId.ToString().Contains(value)
        ).Take(20);
    }

    private async Task<IEnumerable<User>> SearchUsers(string value)
    {
        if (string.IsNullOrEmpty(value))
            return _allUsers;

        return _allUsers.Where(x =>
            x.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            x.UserId.ToString().Contains(value)
        );
    }

    public async Task GenerateSequence()
    {
        // Validar campos obligatorios
        if (_selectedReviewer == null || _selectedApprover == null)
        {
            Snackbar.Add("Debe seleccionar Revisor y Aprobador antes de generar.", Severity.Warning);
            return;
        }

        if (string.IsNullOrEmpty(_sequence.ProcessName) || string.IsNullOrEmpty(_sequence.InternalControlNumber))
        {
            Snackbar.Add("Nombre de Proceso y Número de Control Interno son requeridos.", Severity.Warning);
            return;
        }

        if (string.IsNullOrEmpty(_sequence.OperationName))
        {
            Snackbar.Add("Nombre de la Operación es requerido.", Severity.Warning);
            return;
        }

        _isTableLoading = true;
        try
        {
            // Verificar si es creación o revisión
            if (State?.Hub?.SOSSequence != null && State.Hub.SOSSequence.Count > 0)
            {
                // CASO: REVISIÓN - Ya existe una secuencia
                _sequence = State.Hub.SOSSequence.First();

                // Limpiar logbooks temporales si existen
                if (_sequence.SequenceLogbooks?.First().SOSSequenceLogbookId == 0)
                {
                    _sequence.SequenceLogbooks.Clear();
                }

                // Crear nuevo logbook de revisión
                var revisionLogbook = new SOSSequenceLogbook
                {
                    NoRevision = _sequence.SequenceLogbooks?.Count() ?? 0,
                    ApproverId = _selectedApprover.UserId,
                    ReviewerId = _selectedReviewer.UserId,
                    Date = DateTime.Now,
                    Status = 1,
                    IsActive = true
                };

                if (_sequence.SequenceLogbooks == null)
                    _sequence.SequenceLogbooks = new List<SOSSequenceLogbook>();

                _sequence.SequenceLogbooks.Add(revisionLogbook);

                var result = await SOSHubService.GenerateSequence(State.Hub.SOSHubId, _sequence);

                if (result != 0)
                {
                    Snackbar.Add("Revisión de la Secuencia generada exitosamente.", Severity.Success);
                    NavigationManager.NavigateTo($"/soshoe/Sequence/Details/{_sequence.SOSSequenceId}");
                }
                else
                {
                    Snackbar.Add("Error al generar la revisión de la Secuencia.", Severity.Error);
                }
            }
            else
            {
                // CASO: NUEVA SECUENCIA
                // Usar el objeto _sequence que ya tiene los valores del formulario bindeados
                _sequence.SOSHubId = State.Hub.SOSHubId;
                _sequence.CreatedDate = DateTime.Now;
                _sequence.IsActive = true;

                // Crear logbook inicial
                var initialLogbook = new SOSSequenceLogbook
                {
                    NoRevision = 0,
                    ReviewerId = _selectedReviewer.UserId,
                    ApproverId = _selectedApprover.UserId,
                    Date = DateTime.Now,
                    Status = 1,
                    IsActive = true
                };

                if (_sequence.SequenceLogbooks == null)
                    _sequence.SequenceLogbooks = new List<SOSSequenceLogbook>();

                _sequence.SequenceLogbooks.Add(initialLogbook);

                // Inicializar listas si son null
                if (_sequence.Times == null)
                    _sequence.Times = new List<SOSTime>();

                if (_sequence.Illustrations == null)
                    _sequence.Illustrations = new List<FileUpload>();

                if (_sequence.Notes == null)
                    _sequence.Notes = new List<Commentary>();

                // IMPORTANTE: Crear Times para cada Section + Analysis del Hub
                if (State.Hub.Sections != null && State.Hub.Sections.Any())
                {
                    foreach (Section section in State.Hub.Sections)
                    {
                        if (section.Analyses != null && section.Analyses.Any())
                        {
                            foreach (Analysis analysis in section.Analyses)
                            {
                                var newTime = new SOSTime
                                {
                                    SectionId = section.SectionId,
                                    AnalysisId = analysis.AnalysisId,
                                    IsActive = true,
                                    Time = ""
                                };
                                _sequence.Times.Add(newTime);
                            }
                        }
                    }
                }

                var result = await SOSHubService.GenerateSequence(State.Hub.SOSHubId, _sequence);

                if (result > 0)
                {
                    Snackbar.Add("Secuencia generada exitosamente.", Severity.Success);
                    NavigationManager.NavigateTo($"/soshoe/Sequence/Details/{result}");

                    // Limpiar formulario
                    _sequence = new SOSSequence();
                    _selectedReviewer = null;
                    _selectedApprover = null;

                    await OnNotify.InvokeAsync();
                }
                else
                {
                    Snackbar.Add("Error al generar la Secuencia.", Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isTableLoading = false;
        }
    }

    private string GetRevNumber()
    {
        string number = string.Empty;

        // Validación inicial
        if (State?.Hub?.SOSSequence == null || State.Hub.SOSSequence.Count == 0)
            return "No Sequence";

        if (_sequence.SequenceLogbooks == null || !_sequence.SequenceLogbooks.Any())
            return "No Logbooks";

        var lastLogbook = _sequence.SequenceLogbooks.LastOrDefault();

        if (lastLogbook.NoRevision == 0)
            number = $"New - {_sequence.SequenceLogbooks.Count()}";
        else if (lastLogbook.SOSSequenceLogbookId == 0)
            number = $"NewTemporal - {_sequence.SequenceLogbooks.Count()}";
        else if (lastLogbook.Status == 2)
            number = $"NewRevision - {_sequence.SequenceLogbooks.Count()}";
        else
            number = $"{lastLogbook.NoRevision}";

        return number;
    }

    private bool IsSequenceEditDisabled()
    {
        // Si no hay secuencia, es editable (nuevo)
        if (State?.Hub?.SOSSequence?.Count == 0)
            return false;

        // Si hay secuencia pero no tiene logbooks, es editable
        if (_sequence?.SequenceLogbooks?.Count == 0)
            return false;

        // Si hay un logbook guardado (no temporal), es readonly
        var lastLogbook = _sequence?.SequenceLogbooks?.LastOrDefault();
        return lastLogbook?.SOSSequenceLogbookId != 0;
    }

    private string GetDate()
    {
        string date = string.Empty;

        // Validación inicial
        if (State?.Hub?.SOSSequence == null || State.Hub.SOSSequence.Count == 0)
            return DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "");

        if (_sequence.SequenceLogbooks == null || !_sequence.SequenceLogbooks.Any())
            return DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "");

        var lastLogbook = _sequence.SequenceLogbooks.LastOrDefault();

        if (lastLogbook.NoRevision == 0)
            date = DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "");
        else if (lastLogbook.SOSSequenceLogbookId == 0)
            date = $"NewTemporal - {DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")}";
        else if (lastLogbook.Status == 2)
            date = $"NewRevision - {DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")}";
        else
            date = lastLogbook.Date?.ToString("dd-MMM-yyyy").Replace(".", "");

        return date;
    }
}