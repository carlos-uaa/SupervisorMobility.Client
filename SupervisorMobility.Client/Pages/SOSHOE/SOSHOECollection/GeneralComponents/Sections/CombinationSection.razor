@using SupervisorMobility.Client.Data.Entities.SOS_Process
@inject ISOSCombinationService SOSCombinationServices
@inject ISOSHubService SOSHubService
@inject IUserService UsersService
@inject IPlantService PlantService
@inject IDepartmentService DepartmentService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<style>
    .list-container { 
        height: 280px; 
        overflow-y: auto; 
        background-color: #fdfdfd; 
        border: 1px solid #e0e0e0; 
        border-radius: 8px;
    }

    /* Estilo para cuando no hay datos */
    .empty-state-dashed {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: calc(100% - 16px);
        border: 2px dashed #e0e0e0;
        margin: 8px;
        border-radius: 8px;
        background-color: #fafafa;
    }

    /* Cards de los items */
    .item-card { 
        background: white; 
        border: 1px solid #f0f0f0; 
        border-radius: 4px;
        transition: all 0.2s ease;
    }

    .item-card:hover { 
        background-color: #f9f9f9;
        transform: translateX(4px); 
        box-shadow: 2px 2px 5px rgba(0,0,0,0.05);
    }

    /* Bordes laterales de colores */
    .border-l-primary { border-left: 4px solid var(--mud-palette-primary) !important; }
    .border-l-secondary { border-left: 4px solid var(--mud-palette-secondary) !important; }
    .border-l-success { border-left: 4px solid var(--mud-palette-success) !important; }

    .mud-background-gray { background-color: #f8f9fa; }
    .border-radius-lg { border-radius: 12px; }
    
    /* Bordes dinámicos */
    .border-l-primary { border-left: 4px solid var(--mud-palette-primary) !important; }
    .border-l-secondary { border-left: 4px solid var(--mud-palette-secondary) !important; }
    .border-l-success { border-left: 4px solid var(--mud-palette-success) !important; }
    
    .bg-white { background-color: white !important; }
    .mud-input-control>.mud-input-control-input-container { width: 100% !important}
</style>

<MudGrid Spacing="3" Class="ma-0">
            
    <MudItem xs="12">
        <MudPaper Elevation="0" Class="pa-5 mud-background-gray border-radius-lg">
            <div class="d-flex align-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.SettingsSuggest" Color="Color.Primary" Class="mr-2"/>
                <MudText Typo="Typo.h6" Style="font-weight: 800;">Configuración de Nueva Combinación</MudText>
            </div>

            <MudGrid Spacing="2">
                @* Campos Editables de Identificación *@
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_combination.OperationName"
                                    Label="Nombre de la operación" 
                                    Variant="Variant.Outlined" 
                                    Margin="Margin.Dense" 
                                    Disabled="@IsCombinationEditDisabled()"
                                    Class="bg-white"/>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_combination.InternalControlNumber"
                                    Label="Número de control interno" 
                                    Variant="Variant.Outlined" 
                                    Margin="Margin.Dense" 
                                    Disabled="@IsCombinationEditDisabled()"
                                    Class="bg-white"/>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_combination.ProcessName"
                                    Label="Nombre del proceso" 
                                    Variant="Variant.Outlined" 
                                    Margin="Margin.Dense" 
                                    Disabled="@IsCombinationEditDisabled()"
                                    Class="bg-white"/>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="State.Hub.CreatedDate"
                                    Label="Fecha de Emisión"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Class="bg-white" 
                                    Color="Color.Success"
                                    AdornmentColor="Color.Success"
                                    ReadOnly/>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="_combination.ApplicationMonth"
                                    Label="Mes"
                                    Variant="Variant.Outlined"
                                    Margin="Margin.Dense"
                                    Class="bg-white"
                                    Color="Color.Error"
                                    AdornmentColor="Color.Error"
                                    OpenTo="OpenTo.Month"
                                    IsDateDisabledFunc="@((DateTime dt) => (dt < DateTime.Now.AddDays(-1)))" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="State.Hub.TrainingTime"
                                    Label="Tiempo de aprendizaje" 
                                    Variant="Variant.Outlined" 
                                    Margin="Margin.Dense" 
                                    Class="bg-white"
                                    Min="1" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Timer"
                                    Disabled="@IsCombinationEditDisabled()"/>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="int?" Label="Planta" ReadOnly="true" Variant="Variant.Text" @bind-Value="State.Hub.PlantId" FullWidth
                                Margin="Margin.Dense" AdornmentIcon="@Icons.Material.Filled.Factory" AdornmentColor="Color.Tertiary"
                                ToStringFunc="@(p => GetPlantName(p))">
                        @if (_plants != null)
                        {
                            @foreach (var plant in _plants)
                            {
                                <MudSelectItem T="int?" Value="@plant.PlantId">@($"{plant.Code} - {plant.Description}")</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="int?" Label="Gerencia" ReadOnly="true" Variant="Variant.Text" @bind-Value="State.Hub.DepartmentId" FullWidth
                                Margin="Margin.Dense" AdornmentIcon="@Icons.Material.Filled.AccountTree" AdornmentColor="Color.Primary"
                                ToStringFunc="@(d => GetDepartmentName(d))">
                        @if (_departments != null)
                        {
                            @foreach (var dept in _departments)
                            {
                                <MudSelectItem T="int?" Value="@dept.DepartmentId">@($"{dept.Code} - {dept.Description}")</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>

                @* Fila Informativa (Read Only) *@
                <MudItem xs="12" md="4">
                    <MudTextField Value="GetDate()" Label="Fecha de Registro" Variant="Variant.Filled" ReadOnly="true"
                                    Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Event" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField Value="GetRevNumber()" Label="Revisión Actual" Variant="Variant.Filled" ReadOnly="true"
                                    Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.History" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudField Label="Status" Variant="Variant.Filled" Margin="Margin.Dense" InnerPadding="false" Class="d-flex align-center" Style="width: 100% !important">
                        <MudChip Color="Color.Info" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.FiberNew" Class="ml-2 ma-0">NEW</MudChip>
                    </MudField>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>

    @* --- Columna: Unidades --- *@
    <MudItem xs="12" md="4" Style="margin-top: 10px;">
        <div class="d-flex align-center mb-2 px-1">
            <MudIcon Icon="@Icons.Material.Outlined.DirectionsCar" Color="Color.Success" Size="Size.Small" Class="mr-2" />
            <MudText Typo="Typo.subtitle2" Style="font-weight:700">Unidades</MudText>
            <MudSpacer />
            <MudBadge Content="@(State.Hub.AppliedModels?.Count ?? 0)" Color="Color.Success" Overlap="false" Bordered="true" Class="mr-7" />
        </div>
        <div class="list-container pa-2">
            @if (State.Hub.AppliedModels?.Any() == true)
            {
                @foreach (var item in State.Hub.AppliedModels)
                {
                    <MudPaper Elevation="0" Class="item-card pa-3 mb-2 border-l-success">
                        <MudText Typo="Typo.body2"><strong>@item.Code</strong> | @item.Description</MudText>
                    </MudPaper>
                }
            }
            else
            {
                <div class="empty-state-dashed">
                    <MudIcon Icon="@Icons.Material.Outlined.DirectionsCar" Size="Size.Large" Color="Color.Default" Style="opacity: 0.3;" />
                    <MudText Typo="Typo.caption" Class="mt-2" Style="opacity: 0.6;">Sin unidades registradas</MudText>
                </div>
            }
        </div>
    </MudItem>

    <MudItem xs="12" md="8">
        <div class="d-flex align-center mb-2 px-1">
            <MudIcon Icon="@Icons.Material.Filled.Cyclone" Color="Color.Secondary" Size="Size.Small" Class="mr-2" />
            <MudText Typo="Typo.subtitle2" Style="font-weight:700">Ciclos</MudText>
            <MudSpacer />
            <MudButton OnClick="AddNewTurn" StartIcon="@Icons.Material.Filled.Add" IconColor="Color.Secondary" Size="Size.Small" Class="mr-7">Ciclo</MudButton>
        </div>
        <div class="list-container pa-2">
            @if (_combination.Turns?.Any() == true)
            {
                <MudTable Items="@_combination.Turns"
                            Hover="true"
                            Breakpoint="Breakpoint.None"
                            Elevation="0"
                            Class="mt-2"
                            RowClass="pa-4">
                    <HeaderContent>
                        <MudTh Style="font-weight: 700; color: var(--mud-palette-secondary);">CICLO</MudTh>
                        <MudTh Style="font-weight: 700;">OPERADOR</MudTh>
                        <MudTh Style="font-weight: 700;">SUPERVISOR</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Ciclo">
                            <MudChip Color="Color.Secondary" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.Loop">
                                @context.TurnType
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Operador">
                            <MudAutocomplete T="User" Disabled="@IsCombinationEditDisabled()"
                                                @bind-Value="context.Operator"
                                                SearchFunc="@SearchOperators(context.Supervisor)"
                                                Placeholder="Seleccionar Operador..."
                                                Variant="Variant.Outlined"
                                                Adornment="Adornment.Start"
                                                AdornmentIcon="@Icons.Material.Outlined.Person"
                                                AdornmentColor="Color.Secondary"
                                                Margin="Margin.Dense"
                                                ResetValueOnEmptyText="true"
                                                CoerceText="true"
                                                ToStringFunc="@(u => u == null ? "" : $"{u.Name} ({GetUserType(u.UserType)})")" />
                        </MudTd>

                        <MudTd DataLabel="Supervisor">
                            <MudAutocomplete T="User" Disabled="@IsCombinationEditDisabled()"
                                                @bind-Value="context.Supervisor"
                                                SearchFunc="@SearchSupervisors"
                                                Placeholder="Seleccionar Supervisor..."
                                                Variant="Variant.Outlined"
                                                Adornment="Adornment.Start"
                                                AdornmentIcon="@Icons.Material.Outlined.SupervisedUserCircle"
                                                AdornmentColor="Color.Secondary"
                                                Margin="Margin.Dense"
                                                ResetValueOnEmptyText="true"
                                                CoerceText="true"
                                                ToStringFunc="@(u => u == null ? "" : $"{u.Name} ({GetUserType(u.UserType)})")" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <div class="empty-state-dashed">
                    <MudIcon Icon="@Icons.Material.Filled.Cyclone" Size="Size.Large" Color="Color.Default" Style="opacity: 0.3;" />
                    <MudText Typo="Typo.caption" Class="mt-2" Style="opacity: 0.6;">Sin ciclos registradas</MudText>
                </div>
            }
        </div>
    </MudItem>

    <MudItem xs="12">
        <MudDivider Class="my-2" />
        <MudGrid Spacing="2">
            <MudItem xs="12" md="4">
                <MudAutocomplete T="User" Label="Revisor Responsable" @bind-Value="_selectedReviewer" SearchFunc="@SearchReviewers"
                                    ToStringFunc="@(u => u == null ? "" : $"{u.Name} ({u.UserId})")" ResetValueOnEmptyText="true"
                                    AdornmentIcon="@Icons.Material.Filled.PersonSearch" Variant="Variant.Outlined" Margin="Margin.Dense"
                                    Disabled="@IsCombinationEditDisabled()" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudAutocomplete T="User" Label="Aprobador Final" @bind-Value="_selectedApprover" SearchFunc="@SearchApprovers"
                                    ToStringFunc="@(u => u == null ? "" : $"{u.Name} ({u.UserId})")" ResetValueOnEmptyText="true"
                                    AdornmentIcon="@Icons.Material.Filled.VerifiedUser" Variant="Variant.Outlined" Margin="Margin.Dense"
                                    Disabled="@IsCombinationEditDisabled()" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudAutocomplete T="User" Label="Revisor H&S" @bind-Value="_selectedReviewerHS" SearchFunc="@SearchReviewers"
                                    ToStringFunc="@(u => u == null ? "" : $"{u.Name} ({u.UserId})")" ResetValueOnEmptyText="true"
                                    AdornmentIcon="@Icons.Material.Filled.HealthAndSafety" Variant="Variant.Outlined" Margin="Margin.Dense"
                                    Disabled="@IsCombinationEditDisabled()" />
            </MudItem>
        </MudGrid>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public SOSState State { get; set; }
    [Parameter] public EventCallback OnNotify { get; set; }

    private SOSCombination _combination = new SOSCombination();
    private List<User> _allUsers = new();
    private User _selectedReviewer;
    private User _selectedApprover;
    private User _selectedReviewerHS;
    private List<User> _supervisors { get; set; }
    private List<User> _reviewUsers = new();  // SVs filtered by plant
    private List<User> _approveUsers = new(); // SSVs filtered by plant
    private List<Plant> _plants { get; set; }
    private List<Department> _departments { get; set; }
    private int ReviewerHYSDocCombinationId = 0;

    private User user = new User();
    private string json = string.Empty;

    private List<User> _operators = new();
    private bool _isTableLoading = false;

    protected override async Task OnInitializedAsync()
    {
        // Obtener el usuario logeado del localStorage
        await GetLoggedUserAsync();

        _allUsers = (await UsersService.GetUsers(false, false)).ToList();

        // Cargar usuarios de revisor y aprobador basado en PlantId del Hub (lógica del Before)
        if (State?.Hub?.PlantId.HasValue == true)
        {
            // ReviewUsers = SVs (tipo 3) de la planta
            _reviewUsers = await UsersService.GetUsersByUserTypeInPlant(State.Hub.PlantId.Value, 3, false, false);
            _reviewUsers = _reviewUsers.OrderBy(s => s.Name).ToList();

            // ApproveUsers = SSVs (tipo 2) de la planta  
            _approveUsers = await UsersService.GetUsersByUserTypeInPlant(State.Hub.PlantId.Value, 2, false, false);
            _approveUsers = _approveUsers.OrderBy(s => s.Name).ToList();
        }

        if (State?.Hub?.SOSCombination != null && State.Hub.SOSCombination.Count > 0)
        {
            // Ya existe una combinación, cargar la primera
            _combination = State.Hub.SOSCombination.First();

            // Si tiene logbooks, cargar el último revisor y aprobador para mostrarlos
            if (_combination.CombinationLogbooks != null && _combination.CombinationLogbooks.Any())
            {
                var lastLogbook = _combination.CombinationLogbooks.Last();
                _selectedReviewer = _allUsers.FirstOrDefault(u => u.UserId == lastLogbook.ReviewerId);
                _selectedApprover = _allUsers.FirstOrDefault(u => u.UserId == lastLogbook.ApproverId);
            }

            // Cargar ReviewerHS si existe
            if (_combination.ReviewerHSId.HasValue && _combination.ReviewerHSId > 0)
            {
                _selectedReviewerHS = _allUsers.FirstOrDefault(u => u.UserId == _combination.ReviewerHSId.Value);
            }
        }
        else
        {
            // Nueva combinación - inicializar vacío
            _combination = new SOSCombination();
        }

        // Cargar supervisores dependiendo del tipo de usuario logueado
        _supervisors = new List<User>();
        switch (user.UserType)
        {
            case 1:
                _supervisors = await UsersService.GetUsersByUserTypeInPlant(State.Hub.PlantId.Value, 3, false, true);
                _supervisors = _supervisors.OrderBy(s => s.Name).ToList();
                break;
            case 2:
                foreach (var sv in user.Subordinates.ToList())
                {
                    _supervisors?.Add(sv);
                }
                break;
            case 3:
                _supervisors?.Add(user);
                break;
        }

        // Cargar plantas para el display read-only
        if (_plants == null || !_plants.Any())
        {
            _plants = await PlantService.GetPlants();
            _plants = _plants.OrderBy(p => p.Description).ToList();
        }

        // Cargar departamentos para el display read-only
        if (_departments == null || !_departments.Any())
        {
            _departments = await DepartmentService.GetDepartments();
            _departments = _departments.OrderBy(d => d.Description).ToList();
        }
    }

    // Usuario en local storage
    private async Task GetLoggedUserAsync()
    {
        if (!await TryGetAsync())
            user = new();
    }

    private async Task<bool> TryGetAsync()
    {
        bool hasProperty = await HasPropertyAsync();
        if (hasProperty)
        {
            json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "user");
            user = JsonSerializer.Deserialize<User>(json) ?? new();
        }
        return hasProperty;
    }

    private async Task<bool> HasPropertyAsync() => await JSRuntime.InvokeAsync<bool>("localStorage.hasOwnProperty", "user");

    private void EditCombination(SOSCombination combination)
    {
        // Navegación a la página de detalle de combinación
        NavigationManager.NavigateTo($"/soscombination/edit/{combination.SOSCombinationId}");
    }

    public async Task GenerateCombination()
    {
        // Validar campos obligatorios
        if (_selectedReviewer == null || _selectedApprover == null)
        {
            Snackbar.Add("Debe seleccionar Revisor y Aprobador antes de generar.", Severity.Warning);
            return;
        }

        if (string.IsNullOrEmpty(_combination.ProcessName) || string.IsNullOrEmpty(_combination.InternalControlNumber))
        {
            Snackbar.Add("Nombre de Proceso y Número de Control Interno son requeridos.", Severity.Warning);
            return;
        }

        if (string.IsNullOrEmpty(_combination.OperationName))
        {
            Snackbar.Add("Nombre de la Operación es requerido.", Severity.Warning);
            return;
        }

        _isTableLoading = true;
        try
        {
            // Verificar si es creación o revisión
            if (State?.Hub?.SOSCombination != null && State.Hub.SOSCombination.Count > 0)
            {
                // CASO: REVISIÓN - Ya existe una combinación
                _combination = State.Hub.SOSCombination.First();

                // Limpiar logbooks temporales si existen
                if (_combination.CombinationLogbooks?.First().SOSCombinationLogbookId == 0)
                {
                    _combination.CombinationLogbooks.Clear();
                }

                // Crear nuevo logbook de revisión
                var revisionLogbook = new SOSCombinationLogbook
                {
                    NoRevision = _combination.CombinationLogbooks?.Count() ?? 0,
                    ApproverId = _selectedApprover.UserId,
                    ReviewerId = _selectedReviewer.UserId,
                    Date = DateTime.Now,
                    Status = 1,
                    IsActive = true
                };

                if(_combination.Turns != null)
                    foreach(var turn in _combination.Turns)
                    {
                        turn.OperatorId = turn.Operator?.UserId;
                        turn.SupervisorId = turn.Supervisor?.UserId;
                    }

                if(_combination.Turns.Any())
                    foreach (var turn in _combination.Turns)
                    {
                        if(turn.OperatorId == 0 || turn.SupervisorId == 0)
                        {
                            Snackbar.Add("Seleccione un Supervisor y operador para cada ciclo, por favor", Severity.Warning);
                        }
                    }

                if (_combination.CombinationLogbooks == null)
                    _combination.CombinationLogbooks = new List<SOSCombinationLogbook>();

                _combination.CombinationLogbooks.Add(revisionLogbook);

                var result = await SOSHubService.GenerateCombination(State.Hub.SOSHubId, _combination);
                
                if (result != 0)
                {
                    Snackbar.Add("Revisión de la Combinación generada exitosamente.", Severity.Success);
                    NavigationManager.NavigateTo($"/soshoe/Combination/Details/{_combination.SOSCombinationId}");
                }
                else
                {
                    Snackbar.Add("Error al generar la revisión de la Combinación.", Severity.Error);
                }
            }
            else
            {
                // CASO: NUEVA COMBINACIÓN
                // Usar el objeto _combination que ya tiene los valores del formulario bindeados
                _combination.SOSHubId = State.Hub.SOSHubId;
                _combination.CreatedAt = DateTime.Now;
                _combination.IsActive = true;

                // Crear logbook inicial
                var initialLogbook = new SOSCombinationLogbook
                {
                    NoRevision = 0,
                    ReviewerId = _selectedReviewer.UserId,
                    ApproverId = _selectedApprover.UserId,
                    Date = DateTime.Now,
                    Status = 1,
                    IsActive = true
                };

                if (_combination.CombinationLogbooks == null)
                    _combination.CombinationLogbooks = new List<SOSCombinationLogbook>();
                
                _combination.CombinationLogbooks.Add(initialLogbook);

                // Asignar ReviewerHS (Health & Safety)
                if (_selectedReviewerHS != null)
                    _combination.ReviewerHSId = _selectedReviewerHS.UserId;

                // Inicializar listas si son null
                if (_combination.Illustrations == null)
                    _combination.Illustrations = new List<FileUpload>();
                
                if (_combination.SOSCombinationOperationSequence == null)
                    _combination.SOSCombinationOperationSequence = new List<SOSCombinationOperationSequence>();

                if (_combination.Turns != null)
                    foreach (var turn in _combination.Turns)
                    {
                        turn.OperatorId = turn.Operator?.UserId;
                        turn.SupervisorId = turn.Supervisor?.UserId;
                    }

                if (_combination.Turns.Any())
                    foreach (var turn in _combination.Turns)
                    {
                        if (turn.OperatorId == 0 || turn.SupervisorId == 0)
                        {
                            Snackbar.Add("Seleccione un Supervisor y operador para cada ciclo, por favor", Severity.Warning);
                        }
                    }

                var result = await SOSHubService.GenerateCombination(State.Hub.SOSHubId, _combination);
                
                if (result > 0)
                {
                    Snackbar.Add("Combinación generada exitosamente.", Severity.Success);
                    NavigationManager.NavigateTo($"/soshoe/Combination/Details/{result}");
                    
                    // Limpiar formulario
                    _combination = new SOSCombination();
                    _selectedReviewer = null;
                    _selectedApprover = null;
                    _selectedReviewerHS = null;

                    await OnNotify.InvokeAsync();
                }
                else
                {
                    Snackbar.Add("Error al generar la Combinación.", Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isTableLoading = false;
        }
    }

    private string GetRevNumber()
    {
        string number = string.Empty;

        // Validación inicial
        if (State?.Hub?.SOSCombination == null || State.Hub.SOSCombination.Count == 0)
            return "No Combination";

        if (_combination.CombinationLogbooks == null || !_combination.CombinationLogbooks.Any())
            return "No Logbooks";

        var lastLogbook = _combination.CombinationLogbooks.LastOrDefault();

        if (lastLogbook.NoRevision == 0)
            number = $"New - {_combination.CombinationLogbooks.Count()}";
        else if (lastLogbook.SOSCombinationLogbookId == 0)
            number = $"NewTemporal - {_combination.CombinationLogbooks.Count()}";
        else if (lastLogbook.Status == 2)
            number = $"NewRevision - {_combination.CombinationLogbooks.Count()}";
        else
            number = $"{lastLogbook.NoRevision}";

        return number;
    }

    private string GetPlantName(int? plantId)
    {
        if (!plantId.HasValue || _plants == null)
            return "";
        
        var plant = _plants.FirstOrDefault(p => p.PlantId == plantId.Value);
        return plant != null ? $"{plant.Code} - {plant.Description}" : "";
    }

    private string GetDepartmentName(int? deptId)
    {
        if (!deptId.HasValue || _departments == null)
            return "";
        
        var dept = _departments.FirstOrDefault(d => d.DepartmentId == deptId.Value);
        return dept != null ? $"{dept.Code} - {dept.Description}" : "";
    }

    private string GetDate()
    {
        string date = string.Empty;

        // Validación inicial
        if (State?.Hub?.SOSCombination == null || State.Hub.SOSCombination.Count == 0)
            return DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "");

        if (_combination.CombinationLogbooks == null || !_combination.CombinationLogbooks.Any())
            return DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "");

        var lastLogbook = _combination.CombinationLogbooks.LastOrDefault();

        if (lastLogbook.NoRevision == 0)
            date = DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "");
        else if (lastLogbook.SOSCombinationLogbookId == 0)
            date = $"NewTemporal - {DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")}";
        else if (lastLogbook.Status == 2)
            date = $"NewRevision - {DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")}";
        else
            date = lastLogbook.Date?.ToString("dd-MMM-yyyy").Replace(".", "");

        return date;
    }

    private bool IsCombinationEditDisabled()
    {
        // Si no hay combinación, es editable (nuevo)
        if (State?.Hub?.SOSCombination?.Count == 0)
            return false;

        // Si hay combinación pero no tiene logbooks, es editable
        if (_combination?.CombinationLogbooks?.Count == 0)
            return false;

        // Si hay un logbook guardado (no temporal), es readonly
        var lastLogbook = _combination?.CombinationLogbooks?.LastOrDefault();
        return lastLogbook?.SOSCombinationLogbookId != 0;
    }

