<MudMessageBox @ref="MessageBoxRef"
               Title="@Title"
               CancelText="@CancelText">
    <MessageContent>
        @((MarkupString)$"Are you sure you want to <b>delete</b> this {ItemName}?")
    </MessageContent>
    <YesButton>
        <MudButton Variant="@Variant"
                   Color="@Color"
                   Class="@ButtonClass"
                   StartIcon="@StartIcon">
            @YesText
        </MudButton>
    </YesButton>
</MudMessageBox>

@code {
    [Parameter] public MudMessageBox MessageBoxRef { get; set; }
    [Parameter] public string ItemName { get; set; }
    [Parameter] public string Title { get; set; } = "Warning";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public string YesText { get; set; } = "Delete!";
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;
    [Parameter] public Color Color { get; set; } = Color.Error;
    [Parameter] public string ButtonClass { get; set; } = "ml-4";
    [Parameter] public string StartIcon { get; set; } = Icons.Material.Filled.DeleteForever;
}