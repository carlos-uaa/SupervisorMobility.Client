<MudItem xs="@Xs" Style="@ItemStyle">
    <MudButton Class="custom-button-card" Style="@($"--clr:{Color}")" OnClick="OnClick">
        <MudCard>
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar>
                        <MudImage Src="@ImageSrc" />
                    </MudAvatar>
                </CardHeaderAvatar>

                <CardHeaderContent>
                    <MudText Typo="Typo.h6" Style="text-align:left">
                        <b>@Title</b>
                    </MudText>
                    <MudText Typo="Typo.body2">@Description</MudText>
                </CardHeaderContent>

                <CardHeaderActions>
                    <MudIcon Icon="@Icon" Color="MudBlazor.Color.Primary"></MudIcon>
                </CardHeaderActions>
            </MudCardHeader>
        </MudCard>
        <i></i>
    </MudButton>
</MudItem>

@code {
    [Parameter] public string Title { get; set; }
    [Parameter] public string Description { get; set; }
    [Parameter] public string ImageSrc { get; set; }
    [Parameter] public string Icon { get; set; }
    [Parameter] public string Color { get; set; } = "#39FF14";
    [Parameter] public EventCallback OnClick { get; set; }

    // Opcionales
    [Parameter] public int Xs { get; set; } = 4;
    [Parameter] public string ItemStyle { get; set; } = "";
}