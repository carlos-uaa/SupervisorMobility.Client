<MudDialog DisableSidePadding="false" @bind-IsVisible="ShowPagesGenerate" Options="dialogPagesOptions" Style="min-height: 30vh; overflow:hidden">
    <DialogContent>
        <MudGrid>
            @switch (selectedIndexPageGenerate)
            {
                case 1:
                    <div class="d-flex" style="min-height:40vh; max-height: auto">
                        <MudItem>
                            <MudButton Style="float: left" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() =>  ReturnToGenerateindex())" Color="Color.Primary">Back</MudButton>
                        </MudItem>
                        <MudItem Class="ma-5">

                            <MudSimpleTable>
                                <thead>
                                    <tr>
                                        <th colspan="3">Nombre de la Operación</th>
                                        <th colspan="3">@_SelectedHoe.ProcessSheet</th>
                                    </tr>
                                    <tr>
                                        <th colspan="3">Equipo de Seguridad</th>
                                        <th colspan="3">
                                            @foreach (var equipment in _SelectedHoe.SafetyEquipment)
                                            {
                                                <MudText>@equipment.EquipmentName</MudText>
                                            }
                                        </th>
                                    </tr>
                                    <tr>
                                        <th colspan="3">Herramientas</th>
                                        <th colspan="3">
                                            @foreach (var tool in _SelectedHoe.ToolsUsed)
                                            {
                                                <MudText>@tool.Tool?.ToolName</MudText>
                                            }
                                        </th>
                                    </tr>
                                    <tr>
                                        <th colspan="3">Modelo</th>
                                        <th colspan="3"><MudText>@_SelectedHoe.AppliedModel?.Description</MudText></th>
                                    </tr>
                                    <tr>
                                        <th colspan="3">Tiempo de aprendizaje</th>
                                        <th colspan="3">
                                            <MudAutocomplete T="int"
                                                             Label=@Localizer["Cycles"]
                                                             Variant="Variant.Text"
                                                             AnchorOrigin="Origin.BottomCenter"
                                                             @bind-Value="cycleId"
                                                             OpenIcon="@Icons.Material.Filled.AccessTime"
                                                             AdornmentColor="Color.Info"
                                                             Clearable
                                                             ResetValueOnEmptyText
                                                             ShowProgressIndicator="true" ProgressIndicatorColor="Color.Info"
                                                             MaxItems="10"
                                                             ReadOnly>
                                            </MudAutocomplete>
                                        </th>
                                    </tr>
                                </thead>

                            </MudSimpleTable>
                            <MudItem Class="ma-3">
                                <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() =>  GenerateAnalisys())" Color="Color.Primary">Generate</MudButton>
                            </MudItem>

                        </MudItem>

                    </div>
                    break;
                case 2:
                    <div class="d-flex" style="height:100%; max-height: auto">
                        <MudItem>
                            <MudButton Style="float: left" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() =>  ReturnToGenerateindex())" Color="Color.Primary">Back</MudButton>
                        </MudItem>
                        <MudItem>

                        </MudItem>
                    </div>
                    break;
                case 3:
                    <div class="d-flex" style="height:100%; max-height: auto">
                        <MudItem>
                            <MudButton Style="float: left" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() =>  ReturnToGenerateindex())" Color="Color.Primary">Back</MudButton>
                        </MudItem>
                        <MudItem>

                        </MudItem>
                    </div>
                    break;
                case 4:
                    <div class="d-flex" style="height:100%; max-height: auto">
                        <MudItem>
                            <MudButton Style="float: left" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() =>  ReturnToGenerateindex())" Color="Color.Primary">Back</MudButton>
                        </MudItem>
                        <MudItem>

                        </MudItem>
                    </div>
                    break;
                case 5:
                    <div class="d-flex" style="height:100%; max-height: auto">
                        <MudItem>
                            <MudButton Style="float: left" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() =>  ReturnToGenerateindex())" Color="Color.Primary">Back</MudButton>
                        </MudItem>
                        <MudItem>

                        </MudItem>
                    </div>
                    break;
                case 6:
                    break;
                case 7:
                    break;
                case 8:
                    break;
                case 9:
                    break;
            }
        </MudGrid>
    </DialogContent>
    @* <DialogActions>
    <MudButton OnClick="confirmSide" Variant="Variant.Filled">@Localizer["confirm"]</MudButton>
    </DialogActions> *@
</MudDialog>

<MudMessageBox @ref="_DeleteMessage" Title="Warning" CancelText="Cancel">
    <MessageContent>
        Are you sure you want to <b>delete</b> this Hoe?
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" Class="ml-4" StartIcon="@Icons.Material.Filled.DeleteForever">Delete!</MudButton>
    </YesButton>
</MudMessageBox>

@code {
    // Breadcrumb links
    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>();

    // Objects
    public List<SOSHub> _Hoes { get; set; } = new();
    public SOSHub _SelectedHoe { get; set; } = new();

    //User
    private string json = string.Empty;
    public User user = new();
    public bool logged = false;

    //Side Dialog
    private string SideName = string.Empty;
    private int SosHubId = 0;
    public bool ShowSideDialog = false;
    //Loading
    private IList<string> _sourceMsgLoading = new List<string>();
    private IList<Color> _Colors = new List<Color>() { Color.Default, Color.Primary, Color.Secondary, Color.Success, Color.Info, Color.Default, Color.Primary, Color.Secondary, Color.Success, Color.Info };
    public bool ShowLoading = true;

    //Generation
    private DialogOptions dialogResourcesOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true };
    private DialogOptions dialogPagesOptions = new() { CloseOnEscapeKey = true, FullWidth = true, CloseButton = true };
    public bool ShowGenerateDialog = false;
    public bool ShowPagesGenerate = false;
    private int selectedIndexPageGenerate = 0;

    private MudMessageBox _DeleteMessage;

   
    int cycleId = 0;
    //Analisis
    SOSAnalysis analisys { get; set; } = new SOSAnalysis();

    // Initialization
    protected async override Task OnInitializedAsync()
    {


        _Hoes = await SOSHubServices.GetAllSOSHub();

        await GetUserAsync();
        logged = await HasPropertyAsync();
        if (!logged)
        {
            Snackbar.Clear();
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Add($"Error You have to log in", Severity.Error);
            NavigationManager.NavigateTo($"/");
        }

        _links = new List<BreadcrumbItem>
             {
