                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                        <i></i>
                                    </MudButton>
                                </MudItem>
                                <MudItem xs="6" Style="display: flex; justify-content: center;">
                                    <MudButton Class="custom-button-card" Style="--clr:#39FF14" OnClick="@(() => GoToPageGenerate(7))">
                                        <MudCard>
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/procedimiento.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left">
                                                        <b>
                                                            Cuadro Sinoptico de Puntos de Control
                                                        </b>
                                                    </MudText>
                                                    <MudText Typo="Typo.body2">Cuadro Sinoptico de Puntos de Control</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                        <i></i>
                                    </MudButton>
                                </MudItem>
                                <MudItem xs="6" Style="display: flex; justify-content: center;">
                                    <MudButton Class="custom-button-card" Style="--clr:#39FF14" OnClick="@(() => GoToPageGenerate(8))">
                                        <MudCard>
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/planificacion.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Plan Anual de Adiestramiento Técnico</b></MudText>
                                                    <MudText Typo="Typo.body2">Plan Anual de Adiestramiento Técnico</MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
