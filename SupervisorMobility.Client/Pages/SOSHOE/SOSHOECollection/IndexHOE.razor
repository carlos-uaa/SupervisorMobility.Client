    private void RowClickEvent(TableRowClickEventArgs<SOSHub> args)
    {
        if (selectedRowNumber == SelectTableEvent.Items.ToList().IndexOf(args.Item))
        {
            HoeDetails(args.Item.SOSHubId);
        }
        else
        {
            SelectTableEvent.SelectedItem = args.Item;
            selectedRowNumber = SelectTableEvent.Items.ToList().IndexOf(args.Item);
        }
    }

    private string SelectedRowClassFunc(SOSHub element, int rowNumber)
    {
        if (selectedRowNumber == rowNumber)
        {
            SosHubId = element.SOSHubId;
            return "selected"; // Mantener la fila seleccionada
        }
        else if (SelectTableEvent.SelectedItem != null && SelectTableEvent.SelectedItem.Equals(element))
        {
            SosHubId = element.SOSHubId;
            selectedRowNumber = rowNumber;
            return "selected";
        }
        else
        {
            return string.Empty;
        }
    }

    private async Task<AsyncVoidMethodBuilder> FindSelectedHoe(int sosHuBiD)
    {
        Documents.Clear();
        _SelectedHoe = await SOSHubServices.GetSOSHub(sosHuBiD, includeModel: true, includeEquipments: true, includeTools: true, includeMaterials: true, includeCollections: true, includePeopleCollections: true, includeDocuments: true, includePats: true);

        if (_SelectedHoe.SOSAnalysis?.Count() > 0)
            foreach (var analysis in _SelectedHoe.SOSAnalysis.Where(a => a.IsActive == true))
            {
                Documents.Add(analysis);
            }

        if (_SelectedHoe.SOSCombination?.Count() > 0)
            foreach (var combination in _SelectedHoe.SOSCombination.Where(c => c.IsActive == true))
            {
                Documents.Add(combination);
            }

        if (_SelectedHoe.SOSDistribution?.Count() > 0)
            foreach (var distribution in _SelectedHoe.SOSDistribution.Where(d => d.IsActive == true))
            {
                Documents.Add(distribution);
            }

        if (_SelectedHoe.SOSFlow?.Count() > 0)
            foreach (var flow in _SelectedHoe.SOSFlow.Where(f => f.IsActive == true))
            {
                Documents.Add(flow);
            }

        if (_SelectedHoe.SOSSequence?.Count() > 0)
            foreach (var sequence in _SelectedHoe.SOSSequence.Where(s => s.IsActive == true))
            {
                Documents.Add(sequence);
            }

        if (_SelectedHoe.SOSSynopticOperatingRequirements?.Count() > 0)
            foreach (var csro in _SelectedHoe.SOSSynopticOperatingRequirements.Where(c => c.IsActive == true))
            {
                Documents.Add(csro);
            }

        if (_SelectedHoe.SOSSynopticControlPoints?.Count() > 0)
            foreach (var cspc in _SelectedHoe.SOSSynopticControlPoints.Where(c => c.IsActive == true))
            {
                Documents.Add(cspc);
            }

        if (_SelectedHoe.PATs?.Count() > 0)
            foreach (var pat in _SelectedHoe.PATs.Where(p => p.IsActive == true))
            {
                Documents.Add(pat);
            }

        return new AsyncVoidMethodBuilder();
    }

