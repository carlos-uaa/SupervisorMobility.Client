    private string GetStatusIcon(string status) => status switch
    {
        "Pending" => Icons.Material.Filled.Pending,
        "Approved" => Icons.Material.Filled.FactCheck,
        "Rejected" => Icons.Material.Filled.ContentPasteOff,
        "In Progress" => Icons.Material.Filled.RunningWithErrors,
        _ => Icons.Material.Filled.Block
    };

    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Primary,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        "In Progress" => Color.Warning,
        _ => Color.Default
    };
