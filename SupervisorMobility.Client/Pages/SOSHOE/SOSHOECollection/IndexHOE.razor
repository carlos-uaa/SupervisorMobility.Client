<MudDialog DisableSidePadding="false" @bind-IsVisible="ShowPagesGenerate" Options="dialogPagesOptions" Style="min-height: 30vh; overflow:hidden">
    <TitleContent>
        <MudItem Style="float: left">
            <SupervisorMobility.Client.Pages.Components.ButtonBack OnClick="@(() =>  ReturnToGenerateindex())"></SupervisorMobility.Client.Pages.Components.ButtonBack>
        </MudItem>
        <MudItem>
            @if (!ShowDialogLoading)
            {

                @switch (selectedIndexPageGenerate)
                {
                    case 1:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/analisis-de-los-datos.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left">
                                        @if (_SelectedHoe.SOSAnalysis.Count == 0)
                                        {
                                            <b> Generate </b>
                                        }
                                        else
                                        {
                                            <b> Revision</b>
                                        }
                                        <b> Analysis</b>
                                    </MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_SelectedHoe.SOSAnalysis.Count > 0 && _sosAnalysis.AnalysisLogbooks?.Last().Status != 2 || _sosAnalysis.SOSAnalysisId != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSAnalysis>(_sosAnalysis.SOSAnalysisId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>
                        break;
                    case 2:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/combinacion.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Combination</b></MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_SelectedHoe.SOSCombination.Count > 0 && _sosCombination.CombinationLogbooks?.Last().Status != 2 || _sosCombination.SOSCombinationId != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSCombination>(_sosCombination.SOSCombinationId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>

                        break;
                    case 3:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/reparto-de-beneficios.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Distribution</b></MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_SelectedHoe.SOSDistribution.Count > 0 && _sosDistribution.DistributionLogbooks?.Last().Status != 2 || _sosDistribution.SOSDistributionId != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSDistribution>(_sosDistribution.SOSDistributionId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>

                        break;
                    case 4:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/flujo-de-datos.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Flow</b></MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_SelectedHoe.SOSFlow.Count > 0 && _sosFlow.FlowLogbooks?.Last().Status != 2 || _sosFlow.SOSFlowId != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSFlow>(_sosFlow.SOSFlowId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>

                        break;
                    case 5:
                        <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                            <MudCardHeader>
                                <CardHeaderAvatar>
                                    <MudAvatar>
                                        <MudImage Src="Images/flujo-de-trabajo.png" />
                                    </MudAvatar>
                                </CardHeaderAvatar>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Sequence</b></MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>

                                    <MudItem style="padding-top: 5px; padding-left:10px;">
                                        @if (_SelectedHoe.SOSSequence.Count > 0 && _sosSequence.SequenceLogbooks?.Last().Status != 2 || _sosSequence.SOSSequenceId != 0)
                                        {
                                            <SupervisorMobility.Client.Pages.Components.ButtonQuickView OnClick="() => Details<SOSSequence>(_sosSequence.SOSSequenceId)" ButtonText="@Localizer["details"]"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                        }
                                    </MudItem>
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>

                        break;
                }
            }
        </MudItem>
    </TitleContent>
    <DialogContent>
        @if (!ShowDialogLoading)
        {
            @switch (selectedIndexPageGenerate)
            {
                case 1:
                    <div class="d-flex" style="min-height:40vh; max-height: auto">
                        <MudItem Class="ma-5">
