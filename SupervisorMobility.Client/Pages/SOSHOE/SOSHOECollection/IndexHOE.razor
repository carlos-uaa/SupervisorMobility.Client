    private async Task<AsyncVoidMethodBuilder> FindSelectedHoe(int sosHuBiD)
    {
        Documents.Clear();
        _SelectedHoe = await SOSHubServices.GetSOSHub(sosHuBiD, includeModel: true, includeEquipments: true, includeTools: true, includeMaterials: true, includeCollections: true, includePeopleCollections: true, includeDocuments: true);

        if(_SelectedHoe.SOSAnalysis?.Count() > 0) 
        foreach (var analysis in _SelectedHoe.SOSAnalysis)
        {
            Documents.Add(analysis);
        }

        if(_SelectedHoe.SOSCombination?.Count() > 0)
        foreach (var combination in _SelectedHoe.SOSCombination)
        {
            Documents.Add(combination);
        }

        if (_SelectedHoe.SOSDistribution?.Count() > 0)
            foreach (var distribution in _SelectedHoe.SOSDistribution)
        {
            Documents.Add(distribution);
        }

        if (_SelectedHoe.SOSFlow?.Count() > 0)
            foreach (var flow in _SelectedHoe.SOSFlow)
        {
            Documents.Add(flow);
        }

        if (_SelectedHoe.SOSSequence?.Count() > 0)
        foreach (var sequence in _SelectedHoe.SOSSequence)
        {
            Documents.Add(sequence);
        }

        return new AsyncVoidMethodBuilder();
    }

    void HoeDetails(int HoeId)
