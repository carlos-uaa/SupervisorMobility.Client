    }

    // Delete Hoe
    async Task DeleteHoe(int HoeId)
    {
         bool? result = await _DeleteMessage.Show();
        var confirm = result is null ? "Canceled" : "Deleted!";
        StateHasChanged();

        if (confirm == "Deleted!")
        {
            _Hoes.RemoveAll(Hoe => Hoe.SOSHubId == HoeId);
            await SOSHubServices.DeleteSOSHub(HoeId);
        }
    }

