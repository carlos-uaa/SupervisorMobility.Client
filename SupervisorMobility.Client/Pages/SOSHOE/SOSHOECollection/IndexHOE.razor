@page "/soshoe/Hub"
@using System.Runtime.CompilerServices
@using SupervisorMobility.Client.Pages.SOSHOE.SOSHOECollection.HOE_Components

@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService
@inject IUserService UsersService
@inject ISOSHubService SOSHubServices
@inject IDialogService DialogService



@inject ISOSAnalysisService SOSAnalysisServices
@inject ISOSCombinationService SOSCombinationServices
@inject ISOSDistributionService SOSDistributionServices
@inject ISOSFlowService SOSFlowServices
@inject ISOSSequenceService SOSSequenceServices
@inject IPATService PATServices
@inject ISynopticRequirementsService SOSSynopticRequirementsServices
@inject ISynopticControlPointsService SOSSynopticControlPointsServices

<style type="text/css">

    .bounceIn {
    opacity: 0;
    animation-delay: 0.5s;
    animation-duration: 0.5s;
    animation-name: bounceIn;
    animation-fill-mode: forwards;
    }

    .bounceOut {
    animation-duration: 0.5s;
    animation-name: bounceOut;
    animation-fill-mode: forwards;
    }

    .backInDown {
    opacity: 0;
    animation-delay: 0.5s;
    animation-duration: 0.5s;
    animation-name: backInDown;
    animation-fill-mode: forwards;
    }

    .backOutDown {
    animation-duration: 0.5s;
    animation-name: backOutDown;
    animation-fill-mode: forwards;
    }

    .rotateIn {
    opacity: 0;
    animation-delay: 0.5s;
    animation-duration: 0.5s;
    animation-name: rotateIn;
    animation-fill-mode: forwards;
    }

    .rotateOut {
    animation-duration: 0.5s;
    animation-name: rotateOut;
    animation-fill-mode: forwards;
    }

    .dialog { backdrop-filter: blur(10px); }
</style>

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["HOESOSHubTitle"]</PageTitle>

@if (ShowLoading)
{
    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
        <ItemTemplate>
            <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                <MudItem class="d-flex flex-column justify-center align-self-center">
                    <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                </MudItem>
                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
            </div>
        </ItemTemplate>
    </MudCarousel>
}
else if (_Hoes.Count == 0)
{
    <MudContainer>

        <MudText Align="Align.Center">
            <h4>@Localizer["thereAreNoHoeCreated"]</h4>
            <MudSpacer></MudSpacer>
            <MudButton Href="/soshoe/Hub/Create">
                <MudText>@Localizer["newHoe"]</MudText>
                <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary"></MudIcon>
            </MudButton>
        </MudText>
    </MudContainer>
}
else
{

    <MudTable Items="_Hoes" Hover="true" T="SOSHub" SortLabel="Sort By" Height="80vh"
    RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" OnRowClick="RowClickEvent"
    Filter="new Func<SOSHub,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true>
        <ToolBarContent>
            <MudGrid class="d-flex flex-column justify-center align-self-center mb-10">
                <MudItem class="d-flex justify-center align-self-center ">
                    <MudText Typo="Typo.h6" Class="align-item-center center">@Localizer["jobstructure"]</MudText>
                </MudItem>
                <MudItem Class="d-flex">
                    <MudSpacer />
                    <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>

                    <MudSpacer />
                    <MudButton Href="/soshoe/Hub/Create">
                        <MudText>@Localizer["newHoe"]</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary"></MudIcon>
                    </MudButton>
                    <MudButton OnClick="() => Generate(SosHubId)">
                        <MudText>@Localizer["Generate"]</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.GeneratingTokens" Color="Color.Primary"></MudIcon>
                    </MudButton>
                    <MudSpacer />
                </MudItem>
            </MudGrid>
        </ToolBarContent>
        <HeaderContent>
            @if (user.UserType == 1)
            {
                <MudTh>
                    <MudTableSortLabel SortBy="new Func<SOSHub, object>(x=>x?.SOSHubId)">Hoe Id</MudTableSortLabel>
                </MudTh>
            }
            <MudTh>
                <MudTableSortLabel SortBy="new Func<SOSHub, object>(x=>x?.Folio)">Folio</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<SOSHub, object>(x=>x?.ProcessSheet)">ProcessSheet</MudTableSortLabel>
            </MudTh>
            @*  <MudTh>
                <MudTableSortLabel SortBy="new Func<SOSHub, object>(x=>x?.AppliedModelId)">AppliedModelId</MudTableSortLabel>
            </MudTh> *@
            <MudTh>
                <MudTableSortLabel SortBy="new Func<SOSHub, object>(x=>x?.Status)">Status</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudText Align="Align.Center">Actions</MudText>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            @if (user.UserType == 1)
            {
                <MudTd DataLabel="HoeId">
                    <MudText Align="Align.Center">@context.SOSHubId</MudText>
                </MudTd>
            }
            <MudTd DataLabel="Folio">
                <MudText Align="Align.Center">@(string.IsNullOrEmpty(context.Folio) ? NotApplied : context.Folio)</MudText>
            </MudTd>
            <MudTd DataLabel="ProcessSheet">
                <MudText Align="Align.Center">@(string.IsNullOrEmpty(context.ProcessSheet) ? NotApplied : context.ProcessSheet)</MudText>
            </MudTd>
            <MudTd Style="text-align: center;">
                <MudChip Icon="@GetStatusIcon(context.Status)" Color="GetStatusColor(context.Status)">@context.Status</MudChip>
            </MudTd>
            <MudTd>
                <MudText Align="Align.Center">
                    <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                        <ActivatorContent>
                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => HoeDetails(context.SOSHubId))" OnTouch="(() => HoeDetails(context.SOSHubId))">Details</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdateHoe(context.SOSHubId))" OnTouch="(() => UpdateHoe(context.SOSHubId))">Edit </MudMenuItem>
                            @if(context.Status != "In Progress")
                            {
                                <MudMenuItem Icon="@Icons.Material.Filled.GeneratingTokens" IconColor="Color.Info" @onclick="(() => Generate(context.SOSHubId))" OnTouch="(() => Generate(context.SOSHubId))">Generate</MudMenuItem>
                            }
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => DeleteHoe(context.SOSHubId))" OnTouch="(() => DeleteHoe(context.SOSHubId))">Delete </MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                </MudText>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudDialog DisableSidePadding="false" @bind-IsVisible="ShowGenerateDialog" Options="dialogResourcesOptions" Style="overflow:hidden">
    <DialogContent>
        <MudGrid Style="min-height: 45vh; max-height: 75vh; overflow:auto">
            <MudItem lg="12" md="12" sm="12" xs="12">
                <MudExpansionPanels MultiExpansion="true" Style="height:100%">
                    <MudExpansionPanel Text="" Style="min-width: 100%" IsInitiallyExpanded>
                        <TitleContent>
                            <div class="d-flex" style="align-items: center; justify-content:center;">
                                <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
                                <MudText Typo="Typo.h6" Style="text-align: center;">
                                    @Localizer["HOE"]
                                </MudText>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudGrid Spacing="2" Justify="Justify.SpaceEvenly">
                            <DocumentCard 
                                Xs="4"
                                Color="#39FF14"
                                ImageSrc="Images/analisis-de-los-datos.png"
                                Title="Analysis"
                                Description="DocumentoSosAnalisi"
                                Icon="@Icons.Material.Filled.ManageSearch"
                                OnClick="@(() => GoToPageGenerate(1))" />

                            <DocumentCard Xs="4"
                                Color="#FF44CC"
                                ImageSrc="Images/combinacion.png"
                                Title="Combination"
                                Description="Descripcion Combination"
                                Icon="@Icons.Material.Filled.CallMerge"
                                OnClick="@(() => GoToPageGenerate(2))" />

                            <DocumentCard Xs="4"
                                Color="#0FF0FC"
                                ImageSrc="Images/reparto-de-beneficios.png"
                                Title="Distribution"
                                Description="Documento de Distribucion"
                                Icon="@Icons.Material.Filled.Hub"
                                OnClick="@(() => GoToPageGenerate(3))" />

                            <DocumentCard Xs="4"
                                Color="#FF3131"
                                ImageSrc="Images/flujo-de-datos.png"
                                Title="Flow"
                                Description="Flow Document Description"
                                Icon="@Icons.Material.Filled.Air"
                                OnClick="@(() => GoToPageGenerate(4))" />

                            <DocumentCard Xs="4"
                                Color="#8A2BE2"
                                ImageSrc="Images/flujo-de-trabajo.png"
                                Title="Sequence"
                                Description="Documento de Sequence"
                                Icon="@Icons.Material.Filled.Earbuds"
                                OnClick="@(() => GoToPageGenerate(5))" />

                            <DocumentCard Xs="4"
                                Color="#c4c4c4"
                                ImageSrc="Images/prueba.png"
                                Title="PAT"
                                Description="@Localizer["patDescription"]"
                                Icon="@Icons.Material.Filled.Earbuds"
                                OnClick="@(() => GoToPageGenerate(0))" />

                            </MudGrid>
                        </ChildContent>
                    </MudExpansionPanel>
                    <MudExpansionPanel IsInitiallyExpanded Style="min-width: 100%">
                        <ChildContent>
                            <MudGrid Justify="Justify.Center">
                                <DocumentCard Xs="6"
                                              ItemStyle="display:flex; justify-content:center;"
                                              Color="#39FF14"
                                              ImageSrc="Images/flujo-de-requisitos.png"
                                              Title="Cuadro Sinoptico de Requisitos de Operación"
                                              Description="Cuadro Sinoptico de Requisitos de Operación"
                                              Icon="@Icons.Material.Filled.ManageSearch"
                                              OnClick="@(() => GoToPageGenerate(6))" />

                                <DocumentCard Xs="6"
                                              ItemStyle="display:flex; justify-content:center;"
                                              Color="#39FF14"
                                              ImageSrc="Images/procedimiento.png"
                                              Title="Cuadro Sinoptico de Puntos de Control"
                                              Description="Cuadro Sinoptico de Puntos de Control"
                                              Icon="@Icons.Material.Filled.ManageSearch"
                                              OnClick="@(() => GoToPageGenerate(7))" />



                                <DocumentCard Xs="6"
                                              ItemStyle="display:flex; justify-content:center;"
                                              Color="#39FF14"
                                              ImageSrc="Images/HojaControl.png"
                                              Title="Hoja de Control Individual"
                                              Description="Hoja de Control Individual"
                                              Icon="@Icons.Material.Filled.ManageSearch"
                                              OnClick="@(() => GoToPageGenerate(9))" />
                            </MudGrid>

                        </ChildContent>
                    </MudExpansionPanel>
                    <MudExpansionPanel IsInitiallyExpanded Style="min-width: 100%" Class="mb-10">
                        <TitleContent>
                            <div class="d-flex" style="align-items: center; justify-content:center;">
                                <MudText Typo="Typo.h6" Style="text-align: center;">
                                    @Localizer["Documents"]
                                </MudText>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudTable T="Object" Items="Documents" RowClassFunc="@SelectedRowDocument" @ref="SelectTableEventDocument" OnRowClick="RowClickEventDocument">
                                <HeaderContent>

                                    <MudTh>
                                        Doc Type
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">
                                            Operation Name
                                        </MudText>
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">
                                            Internal Control Number
                                        </MudText>
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">
                                            Process Name
                                        </MudText>
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">Actions</MudText>
                                    </MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    @if (@context is SOSAnalysis analysis)
                                    {
                                        <MudTd DataLabel="Id">
                                            <MudCard Elevation="0" Style="width:min-content">
                                                <MudCardHeader>
                                                    <CardHeaderAvatar>
                                                        <MudAvatar>
                                                            <MudImage Src="Images/analisis-de-los-datos.png" />
                                                        </MudAvatar>
                                                    </CardHeaderAvatar>
                                                    <CardHeaderContent>
                                                        <MudText Typo="Typo.h6" Style="text-align:left"><b>Analysis</b></MudText>
                                                    </CardHeaderContent>
                                                    <CardHeaderActions>
                                                        <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Color="MudBlazor.Color.Primary"></MudIcon>
                                                    </CardHeaderActions>
                                                </MudCardHeader>
                                            </MudCard>
                                        </MudTd>
                                        <MudTd DataLabel="OperationName">
                                            <MudText Align="Align.Center">@analysis.OperationName</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="InternalControlNumber">
                                            <MudText Align="Align.Center">@analysis.InternalControlNumber</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="ProcessName">
                                            <MudText Align="Align.Center">@analysis.ProcessName</MudText>
                                        </MudTd>
                                        <MudTd>
                                            <MudText Align="Align.Center">
                                                <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                    <ActivatorContent>
                                                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                    </ActivatorContent>
                                                    <ChildContent>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<SOSAnalysis>(analysis.SOSAnalysisId))" OnTouch="(() => Details<SOSAnalysis>(analysis.SOSAnalysisId))">Details</MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<SOSAnalysis>(analysis.SOSAnalysisId))" OnTouch="(() => Update<SOSAnalysis>(analysis.SOSAnalysisId))">Edit </MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<SOSAnalysis>(analysis.SOSAnalysisId))" OnTouch="(() => Delete<SOSAnalysis>(analysis.SOSAnalysisId))">Delete </MudMenuItem>
                                                    </ChildContent>
                                                </MudMenu>
                                            </MudText>
                                        </MudTd>
                                    }
                                    else if (@context is SOSCombination combination)
                                    {

                                        <MudTd DataLabel="Id">
                                            <MudCard Elevation="0" Style="width:min-content">
                                                <MudCardHeader>
                                                    <CardHeaderAvatar>
                                                        <MudAvatar>
                                                            <MudImage Src="Images/combinacion.png" />
                                                        </MudAvatar>
                                                    </CardHeaderAvatar>
                                                    <CardHeaderContent>
                                                        <MudText Typo="Typo.h6" Style="text-align:left"><b>Combination</b></MudText>
                                                    </CardHeaderContent>
                                                    <CardHeaderActions>
                                                        <MudIcon Icon="@Icons.Material.Filled.CallMerge" Color="MudBlazor.Color.Primary"></MudIcon>
                                                    </CardHeaderActions>
                                                </MudCardHeader>
                                            </MudCard>
                                        </MudTd>
                                        <MudTd DataLabel="OperationName">
                                            <MudText Align="Align.Center">@combination.OperationName</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="InternalControlNumber">
                                            <MudText Align="Align.Center">@combination.InternalControlNumber</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="ProcessName">
                                            <MudText Align="Align.Center">@combination.ProcessName</MudText>
                                        </MudTd>
                                        <MudTd>
                                            <MudText Align="Align.Center">
                                                <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                    <ActivatorContent>
                                                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                    </ActivatorContent>
                                                    <ChildContent>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<SOSCombination>(combination.SOSCombinationId))" OnTouch="(() => Details<SOSCombination>(combination.SOSCombinationId))">Details</MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<SOSCombination>(combination.SOSCombinationId))" OnTouch="(() => Update<SOSCombination>(combination.SOSCombinationId))">Edit </MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<SOSCombination>(combination.SOSCombinationId))" OnTouch="(() => Delete<SOSCombination>(combination.SOSCombinationId))">Delete </MudMenuItem>
                                                    </ChildContent>
                                                </MudMenu>
                                            </MudText>
                                        </MudTd>
                                    }
                                    else if (@context is SOSDistribution distribution)
                                    {

                                        <MudTd DataLabel="Id">
                                            <MudCard Elevation="0" Style="width:min-content">
                                                <MudCardHeader>
                                                    <CardHeaderAvatar>
                                                        <MudAvatar>
                                                            <MudImage Src="Images/reparto-de-beneficios.png" />
                                                        </MudAvatar>
                                                    </CardHeaderAvatar>
                                                    <CardHeaderContent>
                                                        <MudText Typo="Typo.h6" Style="text-align:left"><b>Distribution</b></MudText>
                                                    </CardHeaderContent>
                                                    <CardHeaderActions>
                                                        <MudIcon Icon="@Icons.Material.Filled.Hub" Color="MudBlazor.Color.Primary"></MudIcon>
                                                    </CardHeaderActions>
                                                </MudCardHeader>
                                            </MudCard>
                                        </MudTd>
                                        <MudTd DataLabel="OperationName">
                                            <MudText Align="Align.Center">@distribution.OperationName</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="InternalControlNumber">
                                            <MudText Align="Align.Center">@distribution.InternalControlNumber</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="ProcessName">
                                            <MudText Align="Align.Center">@distribution.ProcessName</MudText>
                                        </MudTd>
                                        <MudTd>
                                            <MudText Align="Align.Center">
                                                <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                    <ActivatorContent>
                                                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                    </ActivatorContent>
                                                    <ChildContent>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<SOSDistribution>(distribution.SOSDistributionId))" OnTouch="(() => Details<SOSDistribution>(distribution.SOSDistributionId))">Details</MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<SOSDistribution>(distribution.SOSDistributionId))" OnTouch="(() => Update<SOSDistribution>(distribution.SOSDistributionId))">Edit </MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<SOSDistribution>(distribution.SOSDistributionId))" OnTouch="(() => Delete<SOSDistribution>(distribution.SOSDistributionId))">Delete </MudMenuItem>
                                                    </ChildContent>
                                                </MudMenu>
                                            </MudText>
                                        </MudTd>
                                    }
                                    else if (@context is SOSFlow flow)
                                    {

                                        <MudTd DataLabel="Id">
                                            <MudCard Elevation="0" Style="width:min-content">
                                                <MudCardHeader>
                                                    <CardHeaderAvatar>
                                                        <MudAvatar>
                                                            <MudImage Src="Images/flujo-de-datos.png" />
                                                        </MudAvatar>
                                                    </CardHeaderAvatar>
                                                    <CardHeaderContent>
                                                        <MudText Typo="Typo.h6" Style="text-align:left"><b>Flow</b></MudText>
                                                    </CardHeaderContent>
                                                    <CardHeaderActions>
                                                        <MudIcon Icon="@Icons.Material.Filled.Air" Color="MudBlazor.Color.Primary"></MudIcon>
                                                    </CardHeaderActions>
                                                </MudCardHeader>
                                            </MudCard>
                                        </MudTd>
                                        <MudTd DataLabel="OperationName">
                                            <MudText Align="Align.Center">@flow.OperationName</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="InternalControlNumber">
                                            <MudText Align="Align.Center">@flow.InternalControlNumber</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="ProcessName">
                                            <MudText Align="Align.Center">@flow.ProcessName</MudText>
                                        </MudTd>
                                        <MudTd>
                                            <MudText Align="Align.Center">
                                                <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                    <ActivatorContent>
                                                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                    </ActivatorContent>
                                                    <ChildContent>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<SOSFlow>(flow.SOSFlowId))" OnTouch="(() => Details<SOSFlow>(flow.SOSFlowId))">Details</MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<SOSFlow>(flow.SOSFlowId))" OnTouch="(() => Update<SOSFlow>(flow.SOSFlowId))">Edit </MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<SOSFlow>(flow.SOSFlowId))" OnTouch="(() => Delete<SOSFlow>(flow.SOSFlowId))">Delete </MudMenuItem>
                                                    </ChildContent>
                                                </MudMenu>
                                            </MudText>
                                        </MudTd>
                                    }
                                    else if (@context is SOSSequence sequence)
                                    {

                                        <MudTd DataLabel="Id">
                                            <MudCard Elevation="0" Style="width:min-content">
                                                <MudCardHeader>
                                                    <CardHeaderAvatar>
                                                        <MudAvatar>
                                                            <MudImage Src="Images/flujo-de-trabajo.png" />
                                                        </MudAvatar>
                                                    </CardHeaderAvatar>
                                                    <CardHeaderContent>
                                                        <MudText Typo="Typo.h6" Style="text-align:left"><b>Sequence</b></MudText>
                                                    </CardHeaderContent>
                                                    <CardHeaderActions>
                                                        <MudIcon Icon="@Icons.Material.Filled.Earbuds" Color="MudBlazor.Color.Primary"></MudIcon>
                                                    </CardHeaderActions>
                                                </MudCardHeader>
                                            </MudCard>
                                        </MudTd>
                                        <MudTd DataLabel="OperationName">
                                            <MudText Align="Align.Center">@sequence.OperationName</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="InternalControlNumber">
