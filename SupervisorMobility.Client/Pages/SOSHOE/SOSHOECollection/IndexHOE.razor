    private async Task<AsyncVoidMethodBuilder> Generate(int hoeId = 0)
    {
        if (hoeId == 0 && SosHubId == 0)
        {
            bool? result = await DialogService.ShowMessageBox("Warning", "Selecciona un elemento de la tabla!", yesText: "Ok!");
            var state = result == null ? "Canceled" : "Deleted!";
        }
        else
        {
            SosHubId = hoeId != 0 ? hoeId : SosHubId;
            await FindSelectedHoe(SosHubId);
            selectedIndexPageGenerate = 0;
            ShowGenerateDialog = true;
        }

        return new AsyncVoidMethodBuilder();
    }

