                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/flujo-de-datos.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Flow</b></MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
