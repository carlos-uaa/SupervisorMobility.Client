                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                    </MudTd>
                                    <MudTd DataLabel="OperationName">
                                        <MudText Align="Align.Center">@flow.OperationName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="InternalControlNumber">
                                        <MudText Align="Align.Center">@flow.InternalControlNumber</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="ProcessName">
                                        <MudText Align="Align.Center">@flow.ProcessName</MudText>
                                    </MudTd>
                                    <MudTd>
                                        <MudText Align="Align.Center">
                                            <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                <ActivatorContent>
                                                    <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                </ActivatorContent>
                                                <ChildContent>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<SOSFlow>(flow.SOSFlowId))" OnTouch="(() => Details<SOSFlow>(flow.SOSFlowId))">Details</MudMenuItem>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<SOSFlow>(flow.SOSFlowId))" OnTouch="(() => Update<SOSFlow>(flow.SOSFlowId))">Edit </MudMenuItem>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<SOSFlow>(flow.SOSFlowId))" OnTouch="(() => Delete<SOSFlow>(flow.SOSFlowId))">Delete </MudMenuItem>
                                                </ChildContent>
                                            </MudMenu>
                                        </MudText>
                                    </MudTd>
                                }
                                else if (@context is SOSSequence sequence)
                                {

                                    <MudTd DataLabel="Id">
                                        <MudCard Elevation="0" Style="width:min-content">
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/flujo-de-trabajo.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Sequence</b></MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.Earbuds" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                    </MudTd>
                                    <MudTd DataLabel="OperationName">
                                        <MudText Align="Align.Center">@sequence.OperationName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="InternalControlNumber">
                                        <MudText Align="Align.Center">@sequence.InternalControlNumber</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="ProcessName">
                                        <MudText Align="Align.Center">@sequence.ProcessName</MudText>
                                    </MudTd>
                                    <MudTd>
                                        <MudText Align="Align.Center">
                                            <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                <ActivatorContent>
                                                    <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                </ActivatorContent>
                                                <ChildContent>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<SOSSequence>(sequence.SOSSequenceId))" OnTouch="(() => Details<SOSSequence>(sequence.SOSSequenceId))">Details</MudMenuItem>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<SOSSequence>(sequence.SOSSequenceId))" OnTouch="(() => Update<SOSSequence>(sequence.SOSSequenceId))">Edit </MudMenuItem>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<SOSSequence>(sequence.SOSSequenceId))" OnTouch="(() => Delete<SOSSequence>(sequence.SOSSequenceId))">Delete </MudMenuItem>
                                                </ChildContent>
                                            </MudMenu>
                                        </MudText>
                                    </MudTd>
                                }
                            </RowTemplate>
                        </MudTable>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudItem>
    </MudGrid>
}

<MudDialog @bind-IsVisible="visibleImagesDialog" Options="dialogImagesOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Images"]
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;  min-height: 50vh">
            @if (capturedImages.Count > 0)
            {
                <div style="display: flex; align-items: center; justify-content: space-between;" class="mt-4">
                    <MudItem Class="d-flex" Style="flex-direction: row; flex-wrap: wrap; justify-content: flex-start; overflow-y: scroll; max-height:50vh; scroll-behavior: smooth; justify-content: center;">

                        @foreach (var (image, index) in capturedImages.Select((image, index) => (image, index)))
                        {
                            <MudItem Class=" mr-8 mb-4">
                                <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                                </MudItem>
                                <MudImage ObjectFit="ObjectFit.Contain" Height="80" Width="130" Src=@image Alt="Evidence" Elevation="25" Class="rounded-lg" Style="cursor:pointer" @onclick="() => OpenEvidenceDialog(index)" />
                            </MudItem>
                        }
                    </MudItem>

                </div>
            }
        </MudItem>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseImagesDialog" Variant="Variant.Filled">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-IsVisible="visibleVideosDialog" Options="dialogVideosOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Videos"]
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;  min-height: 50vh">
            @if (MediaUris != null && MediaUris.Count > 0)
            {
                @foreach (var item in MediaUris.ToList())
                {
                    <MudItem Class="mr-4 mb-4">
                        <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                        </MudItem>
                        <video width="300" height="150" controls @key="item.Key">
                            <source src="@item.Value.Item2">
                            Your browser does not support the video tag.
                        </video>
                    </MudItem>
                }
            }
            else
            {
                <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">No media available.</MudAlert>
            }
        </MudItem>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseVideosDialog" Variant="Variant.Filled">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>

@*Evidence Modal*@
<MudDialog DisableSidePadding="false" @bind-IsVisible="visibleEvidence" Options="dialogEvidenceOptions">
    <DialogContent>
        <MudPaper Elevation="0">
            @if (capturedImages.Count() > 0)
            {
                <MudCarousel Class="mud-width-full" Style="height: 75vh" ShowArrows=true ShowBullets=true EnableSwipeGesture=true AutoCycle="false" TData="object" @bind-SelectedIndex=@photoIndex>
                    <PreviousButtonTemplate>
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Class="ml-4" Style="cursor:pointer">
                            <MudIcon Icon="@Icons.Material.Filled.NavigateBefore" />
                        </MudAvatar>
                    </PreviousButtonTemplate>
                    <NextButtonTemplate>
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Class="mr-4" Style="cursor:pointer">
                            <MudIcon Icon="@Icons.Material.Filled.NavigateNext" />
                        </MudAvatar>
                    </NextButtonTemplate>
                    <ChildContent>
                        @foreach (var evidence in capturedImages)
                        {
                            <MudCarouselItem Transition="Transition.Fade">
                                <MudImage ObjectFit="ObjectFit.Cover" Height="720" Width="1280" Src=@evidence Alt="Evidence" Elevation="25" Class="rounded-lg" Style="max-height: 66vh; width: 100%; border-radius: 10px; margin-bottom:24px;" />
                            </MudCarouselItem>
                        }
                    </ChildContent>
                </MudCarousel>
            }
            else
            {
                <MudItem Style="height: 75vh">
                    <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                        @Localizer["there is no previous evidence :)"]
                    </MudAlert>
                </MudItem>
            }
        </MudPaper>
    </DialogContent>
</MudDialog>


<MudDialog DisableSidePadding="false" @bind-IsVisible="ShowPagesGenerate" Options="dialogPagesOptions" Style="min-height: 30vh; max-height:75vh">
    <TitleContent>
        <MudItem Style="float: left">
            <SupervisorMobility.Client.Pages.Components.ButtonBack OnClick="@(() =>  ReturnToGenerateindex())"></SupervisorMobility.Client.Pages.Components.ButtonBack>
        </MudItem>
        <MudItem>
            @switch (selectedIndexPageGenerate)
            {
                case 1:
                    <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar>
                                    <MudImage Src="Images/analisis-de-los-datos.png" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Style="text-align:left">
                                    @if (_sosHub.SOSAnalysis.Count == 0)
                                    {
                                        <b> Generate </b>
                                    }
                                    else
                                    {
                                        <b> Revision</b>
                                    }
                                    <b> Analysis</b>
                                </MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudItem style="padding-top: 5px; padding-left:10px;">
                                    @if (_sosHub.SOSAnalysis.Count > 0 && _sosAnalysis.AnalysisLogbooks?.Last().Status != 2 || _sosAnalysis.SOSAnalysisId != 0)
                                    {
                                        <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSAnalysis>(_sosAnalysis.SOSAnalysisId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                    }
                                </MudItem>
                            </CardHeaderActions>
                        </MudCardHeader>
                    </MudCard>
                    break;
                case 2:
                    <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar>
                                    <MudImage Src="Images/combinacion.png" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Style="text-align:left"><b>Combination</b></MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudItem style="padding-top: 5px; padding-left:10px;">
                                    @if (_sosHub.SOSCombination.Count > 0 && _sosCombination.CombinationLogbooks?.Last().Status != 2 || _sosCombination.SOSCombinationId != 0)
                                    {
                                        <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSCombination>(_sosCombination.SOSCombinationId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                    }
                                </MudItem>
                            </CardHeaderActions>
                        </MudCardHeader>
                    </MudCard>

                    break;
                case 3:
                    <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar>
                                    <MudImage Src="Images/reparto-de-beneficios.png" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Style="text-align:left"><b>Distribution</b></MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudItem style="padding-top: 5px; padding-left:10px;">
                                    @if (_sosHub.SOSDistribution.Count > 0 && _sosDistribution.DistributionLogbooks?.Last().Status != 2 || _sosDistribution.SOSDistributionId != 0)
                                    {
                                        <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSDistribution>(_sosDistribution.SOSDistributionId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                    }
                                </MudItem>
                            </CardHeaderActions>
                        </MudCardHeader>
                    </MudCard>

                    break;
                case 4:
                    <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar>
                                    <MudImage Src="Images/flujo-de-datos.png" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Style="text-align:left"><b>Flow</b></MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudItem style="padding-top: 5px; padding-left:10px;">
                                    @if (_sosHub.SOSFlow.Count > 0 && _sosFlow.FlowLogbooks?.Last().Status != 2 || _sosFlow.SOSFlowId != 0)
                                    {
                                        <SupervisorMobility.Client.Pages.Components.ButtonQuickView ButtonText="@Localizer["details"]" OnClick="() => Details<SOSFlow>(_sosFlow.SOSFlowId)"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                    }
                                </MudItem>
                            </CardHeaderActions>
                        </MudCardHeader>
                    </MudCard>

                    break;
                case 5:
                    <MudCard Elevation="0" Class="mr-5" Style="margin-top: -10px;">
                        <MudCardHeader>
                            <CardHeaderAvatar>
                                <MudAvatar>
                                    <MudImage Src="Images/flujo-de-trabajo.png" />
                                </MudAvatar>
                            </CardHeaderAvatar>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Style="text-align:left"><b>Sequence</b></MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>

                                <MudItem style="padding-top: 5px; padding-left:10px;">
                                    @if (_sosHub.SOSSequence.Count > 0 && _sosSequence.SequenceLogbooks?.Last().Status != 2 || _sosSequence.SOSSequenceId != 0)
                                    {
                                        <SupervisorMobility.Client.Pages.Components.ButtonQuickView OnClick="() => Details<SOSSequence>(_sosSequence.SOSSequenceId)" ButtonText="@Localizer["details"]"></SupervisorMobility.Client.Pages.Components.ButtonQuickView>
                                    }
                                </MudItem>
                            </CardHeaderActions>
                        </MudCardHeader>
                    </MudCard>

                    break;
            }
        </MudItem>
    </TitleContent>
    <DialogContent>
        @switch (selectedIndexPageGenerate)
        {
            case 1:
                <div class="d-flex" style="min-height:40vh; max-height: auto">
                    <MudItem Class="ma-5">
                        <MudSimpleTable Dense Style="width:100%; margin:0px; padding:0px;" Square="true">
                            <tbody class="table-header-gray">
                                <tr>
                                    <th rowspan="2">Nombre de la Operación</th>
                                    <td rowspan="2" colspan="3">
                                        @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0)
                                        {
                                            <MudTextField Margin="Margin.Dense" @bind-Value="_sosAnalysis.OperationName" />
                                        }
                                        else
                                        {
                                            <MudTextField ReadOnly Margin="Margin.Dense" @bind-Value="_sosAnalysis.OperationName" />
                                        }
                                    </td>
                                    <th class="divider" colspan="2">No. de Revisión</th>
                                    <td style="width:30%;">
                                        @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().NoRevision == 0)
                                        {
                                            <b> New - @_sosAnalysis.AnalysisLogbooks?.Count() </b>
                                        }
                                        else
                                        {
                                            @if (_sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0)
                                            {
                                                <b> NewTemporal - @_sosAnalysis.AnalysisLogbooks?.Count() </b>
                                            }
                                            else if (_sosAnalysis.AnalysisLogbooks?.Last().Status == 2)
                                            {
                                                <b> NewRevision - @_sosAnalysis.AnalysisLogbooks?.Count() </b>
                                            }
                                            else
                                            {
                                                <b> @_sosAnalysis.AnalysisLogbooks?.Last().NoRevision </b>
                                            }
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th class="divider" colspan="2">Fecha</th>
                                    <td style="width:20%">
                                        @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().NoRevision == 0)
                                        {
                                            <b> New - @(DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")) </b>
                                        }
                                        else
                                        {
                                            @if (_sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0)
                                            {
                                                <b> NewTemporal - @(DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")) </b>
                                            }
                                            else if (_sosAnalysis.AnalysisLogbooks?.Last().Status == 2)
                                            {
                                                <b> NewRevision - @(DateTime.Now.ToString("dd-MMM-yyyy").Replace(".", "")) </b>
                                            }
                                            else
                                            {
                                                <b>
                                                    @(_sosAnalysis.AnalysisLogbooks?.Last().Date?.ToString("dd-MMM-yyyy").Replace(".", ""))
                                                </b>
                                            }
                                        }

                                    </td>
                                </tr>
                                <tr>
                                    <th>Número de control interno</th>
                                    <td style="width:20%">
                                        @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0)
                                        {
                                            <MudTextField Margin="Margin.Dense" @bind-Value="_sosAnalysis.InternalControlNumber" />
                                        }
                                        else
                                        {
                                            <MudTextField ReadOnly Margin="Margin.Dense" @bind-Value="_sosAnalysis.InternalControlNumber" />
                                        }
                                    </td>
                                    <th>Nombre del proceso</th>
                                    <td style="width:20%">
                                        @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0)
                                        {
                                            <MudTextField Margin="Margin.Dense" @bind-Value="_sosAnalysis.ProcessName" />
                                        }
                                        else
                                        {
                                            <MudTextField ReadOnly Margin="Margin.Dense" @bind-Value="_sosAnalysis.ProcessName" />
                                        }
                                    </td>
                                    <th rowspan="3" colspan="2" class="divider">Status<br />( Estado )</th>

                                    <td rowspan="3" style="width:30%">

                                        @if (_sosHub.SOSAnalysis.Count == 0 || _sosAnalysis.AnalysisLogbooks?.Last().SOSAnalysisLogbookId == 0 || _sosAnalysis.AnalysisLogbooks?.Last().Status == 2)
                                        {
                                            <b>
                                                <MudChip Class="mr-10" Icon="@Icons.Material.Filled.PlaylistPlay" Color="Color.Warning" Variant="Variant.Text">
                                                    @Localizer["new"]
                                                </MudChip>
                                            </b>
                                        }
                                        else
                                        {
                                            <b>
                                                @switch (_sosAnalysis.AnalysisLogbooks?.Last().Status)
                                                {
                                                    case 0:
                                                        <MudChip Class="mr-10" Icon="@Icons.Material.Filled.PlaylistAddCheck" Color="Color.Success" Variant="Variant.Text">
                                                            @Localizer["unknow"]!
                                                        </MudChip>
                                                        break;
                                                    case 1:
                                                        <MudChip Class="mr-10" Icon="@Icons.Material.Filled.PlaylistAddCheck" Color="Color.Success" Variant="Variant.Text">
                                                            @Localizer["created"]!
                                                        </MudChip>
                                                        break;
                                                }
                                            </b>
                                        }


                                    </td>

                                </tr>
                                <tr>
                                    <th>Equipo de seguridad</th>
                                    <td colspan="3">
                                        @if (_sosHub.SafetyEquipment != null && _sosHub.SafetyEquipment.Any())
                                        {
                                            @foreach (var element in _sosHub.SafetyEquipment.Take(2).ToList())
                                            {
                                                <MudChip Color="Color.Warning" Icon="@Icons.Material.Filled.Engineering" Size="Size.Small" Variant="Variant.Outlined">
                                                    @element.EquipmentName
                                                </MudChip>
                                            }
                                            @if (_sosHub.SafetyEquipment.Count > 2)
                                            {

                                                <MudMenu Style="float:right" MaxHeight="300" ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                    <ActivatorContent>
                                                        <MudChip Color="Color.Default" Icon="@Icons.Material.Filled.ExpandCircleDown" Size="Size.Small" Variant="Variant.Text">
                                                            Show more
                                                        </MudChip>
                                                    </ActivatorContent>
                                                    <ChildContent>
                                                        @foreach (var element in _sosHub.SafetyEquipment)
                                                        {
                                                            <MudMenuItem>
                                                                <MudChip Color="Color.Warning" Icon="@Icons.Material.Filled.Engineering" Size="Size.Small" Variant="Variant.Outlined">
                                                                    @element.EquipmentName
                                                                </MudChip>
                                                            </MudMenuItem>
                                                        }
                                                    </ChildContent>
                                                </MudMenu>
                                            }
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th>Herramientas</th>
                                    <td colspan="3">
