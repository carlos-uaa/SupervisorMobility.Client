                else
                {
                    @if (_sosFlow.FlowLogbooks?.Last().Status == 2)
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() =>  GenerateFlow())" Color="Color.Primary">
                            <MudText>Revision</MudText>
                        </MudButton>
                    }

                }
                break;
            case 5:
                @if (_sosHub.SOSSequence.Count == 0)
                {
                    <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() =>  GenerateSequence())" Color="Color.Primary">
