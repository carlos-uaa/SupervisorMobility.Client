        @switch (selectedIndexPageGenerate)
        {
            case 1:
                @if (_sosHub.SOSAnalysis.Count == 0)
                {
                    <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() =>  GenerateAnalysis())" Color="Color.Primary">
                        <MudText>Generate</MudText>
                    </MudButton>
                }
                else
                {
                    @if (_sosAnalysis.AnalysisLogbooks?.Last().Status == 2)
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() =>  GenerateAnalysis())" Color="Color.Primary">
                            <MudText>Revision</MudText>
                        </MudButton>
                    }

                }
                break;
            case 2:
                @if (_sosHub.SOSCombination.Count == 0)
                {
                    <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() =>  GenerateCombination())" Color="Color.Primary">
                        <MudText>Generate</MudText>
                    </MudButton>
                }
                else
                {
                    @if (_sosCombination.CombinationLogbooks?.Last().Status == 2)
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() =>  GenerateCombination())" Color="Color.Primary">
                            <MudText>Revision</MudText>
                        </MudButton>
                    }

                }
                break;

            case 3:
