                                    </MudTd>
                                    <MudTd DataLabel="InternalControlNumber">
                                        <MudText Align="Align.Center">@sequence.InternalControlNumber</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="ProcessName">
                                        <MudText Align="Align.Center">@sequence.ProcessName</MudText>
                                    </MudTd>
                                    <MudTd>
                                        <MudText Align="Align.Center">
                                            <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                <ActivatorContent>
                                                    <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                </ActivatorContent>
                                                <ChildContent>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<SOSSequence>(sequence.SOSSequenceId))" OnTouch="(() => Details<SOSSequence>(sequence.SOSSequenceId))">Details</MudMenuItem>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<SOSSequence>(sequence.SOSSequenceId))" OnTouch="(() => Update<SOSSequence>(sequence.SOSSequenceId))">Edit </MudMenuItem>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<SOSSequence>(sequence.SOSSequenceId))" OnTouch="(() => Delete<SOSSequence>(sequence.SOSSequenceId))">Delete </MudMenuItem>
                                                </ChildContent>
                                            </MudMenu>
                                        </MudText>
                                    </MudTd>
                                }
                                
                            </RowTemplate>
                        </MudTable>
                        @if(Documents.Any(d => d is PAT)){
                            <MudTable T="Object" Items="Documents.Where(d => d is PAT).ToList()" RowClassFunc="@SelectedRowDocumentPat" @ref="SelectTableEventDocumentPat" OnRowClick="RowClickEventDocumentPat">
                                <HeaderContent>
                                    
                                    <MudTh>
                                        Doc Type
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">
                                            Aplication Year
                                        </MudText>
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">
                                            Supervisors
                                        </MudText>
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">
                                            Status
                                        </MudText>
                                    </MudTh>
                                    <MudTh>
                                        <MudText Align="Align.Center">Actions</MudText>
                                    </MudTh>
                                </HeaderContent>
                                <RowTemplate>

                                  @if (context is PAT pat)
                                    {

                                        <MudTd DataLabel="Id">
                                            <MudCard Elevation="0" Style="width:min-content">
                                                <MudCardHeader>
                                                    <CardHeaderAvatar>
                                                        <MudAvatar>
                                                            <MudImage Src="Images/flujo-de-trabajo.png" />
                                                        </MudAvatar>
                                                    </CardHeaderAvatar>
                                                    <CardHeaderContent>
                                                        <MudText Typo="Typo.h6" Style="text-align:left"><b>PAT</b></MudText>
                                                    </CardHeaderContent>
                                                    <CardHeaderActions>
                                                        <MudIcon Icon="@Icons.Material.Filled.Earbuds" Color="MudBlazor.Color.Primary"></MudIcon>
                                                    </CardHeaderActions>
                                                </MudCardHeader>
                                            </MudCard>
                                        </MudTd>
                                        <MudTd DataLabel="Year">
                                            <MudText Align="Align.Center">@pat.AplicationYear</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="Supervisors">
                                            <MudText Align="Align.Center">
                                                <MudText>@string.Join(" / ", pat.Supervisors?.Select(s => s.Name))</MudText>
                                            </MudText>
                                        </MudTd>
                                        <MudTd DataLabel="PatStatus">
                                            <MudText Align="Align.Center">
                                                @switch (pat.Status)
                                                {
                                                    case 1:
                                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlaylistPlay" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">@Localizer["new"]</MudChip>
                                                        break;
                                                    case 2:
                                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                                        break;
                                                    case 3:
                                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                                        break;
                                                    case 4:
                                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                                        break;
                                                    case 5:
                                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                                        break;
                                                    case 6:
                                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                                        break;
                                                }
                                            </MudText>
                                        </MudTd>
                                        <MudTd>
                                            <MudText Align="Align.Center">
                                                <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                    <ActivatorContent>
                                                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                    </ActivatorContent>
                                                    <ChildContent>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<PAT>(pat.PATid))" OnTouch="(() => Details<PAT>(pat.PATid))">Details</MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<PAT>(pat.PATid))" OnTouch="(() => Update<PAT>(pat.PATid))">Edit </MudMenuItem>
                                                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<PAT>(pat.PATid))" OnTouch="(() => Delete<PAT>(pat.PATid))">Delete </MudMenuItem>
                                                    </ChildContent>
                                                </MudMenu>
                                            </MudText>
                                        </MudTd>
                                    }
                                </RowTemplate>
                            </MudTable>
                        }
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudItem>
    </MudGrid>
}

<MudDialog @bind-IsVisible="visibleImagesDialog" Options="dialogImagesOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Images"]
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;  min-height: 50vh">
            @if (capturedImages.Count > 0)
            {
                <div style="display: flex; align-items: center; justify-content: space-between;" class="mt-4">
                    <MudItem Class="d-flex" Style="flex-direction: row; flex-wrap: wrap; justify-content: flex-start; overflow-y: scroll; max-height:50vh; scroll-behavior: smooth; justify-content: center;">

                        @foreach (var (image, index) in capturedImages.Select((image, index) => (image, index)))
                        {
                            <MudItem Class=" mr-8 mb-4">
                                <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                                </MudItem>
                                <MudImage ObjectFit="ObjectFit.Contain" Height="80" Width="130" Src=@image Alt="Evidence" Elevation="25" Class="rounded-lg" Style="cursor:pointer" @onclick="() => OpenEvidenceDialog(index)" />
                            </MudItem>
                        }
                    </MudItem>

                </div>
            }
        </MudItem>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseImagesDialog" Variant="Variant.Filled">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-IsVisible="visibleVideosDialog" Options="dialogVideosOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Videos"]
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;  min-height: 50vh">
            @if (MediaUris != null && MediaUris.Count > 0)
            {
                @foreach (var item in MediaUris.ToList())
                {
                    <MudItem Class="mr-4 mb-4">
                        <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                        </MudItem>
                        <video width="300" height="150" controls @key="item.Key">
                            <source src="@item.Value.Item2">
                            Your browser does not support the video tag.
                        </video>
                    </MudItem>
                }
            }
            else
            {
                <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">No media available.</MudAlert>
            }
        </MudItem>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseVideosDialog" Variant="Variant.Filled">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>

@*Evidence Modal*@
<MudDialog DisableSidePadding="false" @bind-IsVisible="visibleEvidence" Options="dialogEvidenceOptions">
    <DialogContent>
        <MudPaper Elevation="0">
            @if (capturedImages.Count() > 0)
            {
                <MudCarousel Class="mud-width-full" Style="height: 75vh" ShowArrows=true ShowBullets=true EnableSwipeGesture=true AutoCycle="false" TData="object" @bind-SelectedIndex=@photoIndex>
                    <PreviousButtonTemplate>
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Class="ml-4" Style="cursor:pointer">
                            <MudIcon Icon="@Icons.Material.Filled.NavigateBefore" />
                        </MudAvatar>
                    </PreviousButtonTemplate>
                    <NextButtonTemplate>
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Class="mr-4" Style="cursor:pointer">
                            <MudIcon Icon="@Icons.Material.Filled.NavigateNext" />
                        </MudAvatar>
                    </NextButtonTemplate>
                    <ChildContent>
                        @foreach (var evidence in capturedImages)
                        {
                            <MudCarouselItem Transition="Transition.Fade">
                                <MudImage ObjectFit="ObjectFit.Cover" Height="720" Width="1280" Src=@evidence Alt="Evidence" Elevation="25" Class="rounded-lg" Style="max-height: 66vh; width: 100%; border-radius: 10px; margin-bottom:24px;" />
                            </MudCarouselItem>
                        }
                    </ChildContent>
                </MudCarousel>
            }
            else
            {
                <MudItem Style="height: 75vh">
                    <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                        @Localizer["there is no previous evidence :)"]
                    </MudAlert>
                </MudItem>
            }
        </MudPaper>
    </DialogContent>
</MudDialog>

