@page "/hoe/details/{SOSHubId:int}"
@using System.Text.RegularExpressions

@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1
@inject IBreadcrumbService BreadcrumbServices
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDepartmentService DepartmentServices
@inject IUserService UsersService
@inject IProductService ProductsService
@inject IDataPanelService DataPanelServices
@inject IAppearanceService AppearanceServices
@inject ILogbookAppearanceService LogbookAppearanceServices
@inject SignatureImageService _signatureImageService
@inject IPartServices PartsServices
@inject IFileUploadAndDownloadService FilesServices
@inject ITestService TestService
@inject IProductService ProductsServices
@inject ISOSHubService SOSHubServices
@inject IToolService ToolsServices
@inject IEquipmentService EquipmentsServices
@inject IMaterialService MaterialsServices


<style>

    .custom-table td:first-child {
        background-color: #f5f5f6;
    }

    .comments-table td:first-child {
        background-color: white;
    }

</style>

<PageTitle>Supervisor Mobility | @Localizer["configuration"]</PageTitle>
<MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
        <MudItem lg="10" md="10" sm="10" xs="12">
            <MudExpansionPanels Elevation="5" MultiExpansion="true">
                <MudExpansionPanel IsInitiallyExpanded=true Style="min-width: 100%;">
                    <TitleContent>
                        <div class="d-flex" style="align-items: center; justify-content:center;">
                            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
                            <MudText Typo="Typo.h6" Style="text-align: center;">
                                @Localizer["HOE / SOS"]
                            </MudText>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudSimpleTable Style="overflow-x: auto;" Dense=true Elevation="0" Class="custom-table">
                            <tbody>
                                <tr>
                                    <td width="20%">
                                        <MudText>Operation Name</MudText>
                                    </td>
                                    <td>
                                        <MudTextField Margin="Margin.Dense" @bind-Value="_sosHub.OperationName" ReadOnly/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Process Name</MudText>
                                    </td>
                                    <td>
                                    <MudTextField Margin="Margin.Dense" @bind-Value="_sosHub.ProcessName" ReadOnly />
                                    </td>
                                </tr>
                                <tr>
                                <td style="padding: 0px">
                                    <MudTabs Color="Color.Tertiary" Position="Position.Left" Rounded="true" Border="true" SliderColor="Color.Dark" @bind-ActivePanelIndex="analysisTabsIndex"
                                             ApplyEffectsToContainer="true">
                                        <MudTabPanel Text="Capture of analysis" Style="color:#424242; width: 15vw;">
                                        </MudTabPanel>

                                        @if (!string.IsNullOrEmpty(RawAnalisis.FirstOrDefault()) || _sosHub.Sections.Count > 0)
                                        {
                                            <MudTabPanel Text="Step capture" OnClick="CreateBakup" Style="color:#424242;  width: 15vw;">
                                            </MudTabPanel>
                                        }

                                        @if (_sosHub.Sections.Count() > 0)
                                        {
                                            <MudTabPanel Text="Critical Point Capture" Style="color:#424242;  width: 15vw;">
                                            </MudTabPanel>
                                        }
                                    </MudTabs>


                                </td>
                                <td>
                                    @if (analysisTabsIndex == 0)
                                    {
                                        <MudContainer Style="display: flex; flex-direction: column; width: 80%">

                                            @if (RawAnalisis.Count == 0)
                                            {
                                                <MudItem>

                                                    <MudSimpleTable Style="overflow-x: auto;" Class="comments-table" Dense="true" Elevation="0">
                                                        <tbody>
                                                            @foreach (var (analisis, indexAnalisis) in RawAnalisisBk.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                            {
                                                                <tr>
                                                                    <td width="90%">
                                                                        <MudText Typo="Typo.subtitle2" Label="Análisis" Variant="Variant.Filled" Class="mb-2">@RawAnalisisBk[indexAnalisis]</MudText>
                                                                    </td>

                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </MudSimpleTable>
                                                </MudItem>
                                            }
                                            else
                                            {
                                                <MudItem>

                                                    <MudSimpleTable Style="overflow-x: auto;" Class="comments-table" Dense="true" Elevation="0">
                                                        <tbody>
                                                            @foreach (var (analisis, indexAnalisis) in RawAnalisis.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                            {
                                                                <tr>
                                                                    <td width="90%">
                                                                        <MudTextField @bind-Value="@RawAnalisis[indexAnalisis]" Label="Analis is" Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly></MudTextField>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </MudSimpleTable>
                                                </MudItem>
                                            }


                                        </MudContainer>

                                    }
                                    else if (analysisTabsIndex == 1)
                                    {
                                        <MudContainer Style="display: flex; flex-direction: column;">
                                            @if (_sosHub.Sections.Count > 0)
                                            {
                                                <MudItem>
                                                    <MudText Typo="Typo.h5">Preview</MudText>
                                                    <MudSimpleTable Elevation="0">
                                                        <MudTr>
                                                            <MudTh>Análisis</MudTh>
                                                            <MudTh>Pasos</MudTh>
                                                            <MudTh>Punto Crítico</MudTh>
                                                            <MudTh></MudTh>
                                                        </MudTr>

                                                        @foreach (var (section, indexSection) in _sosHub.Sections.Select((section, indexSection) => (section, indexSection)))
                                                        {
                                                            <MudTr>
                                                                <MudTd Style="width:60%; background-color: white">
                                                                    @foreach (var (analisis, indexAnalisis) in section.Analyses.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                                    {
                                                                        <MudText Typo="Typo.subtitle2" Label="Análisis" Variant="Variant.Filled" Class="mb-2">@_sosHub.Sections[indexSection].Analyses[indexAnalisis].Text</MudText>
                                                                    }
                                                                </MudTd>
                                                                <MudTd Style="width:30%">
                                                                    <MudTextField @bind-Value="_sosHub.Sections[indexSection].Step" Label="Paso" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" ReadOnly/>
                                                                </MudTd>
                                                                <MudTh></MudTh>
                                                            </MudTr>
                                                        }
                                                    </MudSimpleTable>
                                                </MudItem>
                                            }
                                        </MudContainer>

                                    }
                                    else if (analysisTabsIndex == 2)
                                    {
                                        <MudSimpleTable Style="width:100%; " Elevation="0">
                                            <MudTr>
                                                <MudTh>Análisis</MudTh>
                                                <MudTh>Pasos</MudTh>
                                                <MudTh>Punto Crítico</MudTh>
                                            </MudTr>

                                            @foreach (var (section, indexSection) in _sosHub.Sections.Select((section, indexSection) => (section, indexSection)))
                                            {
                                                <MudTr>
                                                    <MudTd Style="width:50%; background-color: white;">
                                                        @foreach (var (analisis, indexAnalisis) in section.Analyses.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                        {
                                                            @if (!string.IsNullOrEmpty(_sosHub.Sections[indexSection].Analyses[indexAnalisis].CriticalPoint))
                                                            {
                                                                <MudText Typo="Typo.subtitle1">
                                                                    <MudHighlighter Text="@(GetAnalisisText(indexSection, indexAnalisis))" HighlightedText="@(GetHighlightedText(indexSection, indexAnalisis))" />
                                                                </MudText>
                                                            }
                                                            else
                                                            {
                                                                <MudText Typo="Typo.subtitle1" Class="mb-2">
                                                                    @_sosHub.Sections[indexSection].Analyses[indexAnalisis].Text
                                                                </MudText>
                                                            }
                                                        }
                                                    </MudTd>
                                                    <MudTd Style="width:20%">
                                                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                                                            @_sosHub.Sections[indexSection].Step
                                                        </MudText>
                                                    </MudTd>
                                                    <MudTd Style="width:30%">
                                                        @if (!string.IsNullOrEmpty(section.Step))
                                                        {
                                                            @foreach (var (analisis, indexAnalisis) in section.Analyses.Select((analisis, indexAnalisis) => (analisis, indexAnalisis)))
                                                            {
                                                                <MudTextField @bind-Value="_sosHub.Sections[indexSection].Analyses[indexAnalisis].CriticalPoint" Label="Punto Crítico" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" ReadOnly/>
                                                                <MudTextField @bind-Value="_sosHub.Sections[indexSection].Analyses[indexAnalisis].Reason" Label="Razón" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2" ReadOnly />
                                                            }
                                                        }
                                                    </MudTd>

                                                </MudTr>
                                            }
                                        </MudSimpleTable>

                                    }

                                </td>
                            </tr>
                                <tr>
                                    <td>
                                        <MudText>Process Sheet</MudText>
                                    </td>
                                    <td>
                                        <MudTextField ReadOnly Margin="Margin.Dense" @bind-Value="_sosHub.ProcessSheet" Class="ml-4" />
                                        <MudText Style="font-weight:bold;" Class="mt-4 ml-4">Revisión - Modificación</MudText>
                                        <MudSimpleTable Style="overflow-x: auto;" Class="comments-table" Dense="true" Elevation="0">
                                            <tbody>
                                                @if(_sosHub.ProcessSheetCommentary != null && _sosHub.ProcessSheetCommentary.Count > 0)
                                                {
                                                    @foreach (var comment in _sosHub.ProcessSheetCommentary)
                                                    {
                                                        <tr>
                                                            <td width="90%">
                                                                <MudTextField ReadOnly @bind-Value="@comment.Comment" Label="Revisión - Modificación" Variant="Variant.Outlined" Margin="Margin.Dense"></MudTextField>
                                                            </td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        </MudSimpleTable>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Common Direction</MudText>
                                    </td>
                                    <td>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Applied Models</MudText>
                                    </td>
                                    <td>
                                        <MudSelect ReadOnly T="int" Label=@Localizer["product"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@productId" OpenIcon="@Icons.Material.Filled.DirectionsCar" AdornmentColor="Color.Info">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAProduct"]</MudSelectItem>
                                            @foreach (var type in _products)
                                            {
                                                <MudSelectItem Value="type.ProductId">
                                                    @type.Code
                                                </MudSelectItem>
                                            }
                                        </MudSelect>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Steps</MudText>
                                    </td>
                                    <td>
                                        <MudButton Variant="Variant.Filled" OnClick="ShowStepsDialog">
                                            Show Steps
                                            <span>&nbsp;(@segments.Count)</span>
                                        </MudButton>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Images</MudText>
                                    </td>
                                    <td>
                                        <MudButton Variant="Variant.Filled" OnClick="ShowImagesDialog">
                                            Show Images
                                            <span>&nbsp;(@capturedImages.Count)</span>
                                        </MudButton>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Videos</MudText>
                                    </td>
                                    <td>
                                        <MudButton Variant="Variant.Filled" OnClick="ShowVideosDialog">
                                            Show Videos
                                            <span>&nbsp;(@MediaUris.Count)</span>
                                        </MudButton>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Revised Items</MudText>
                                    </td>
                                    <td>
                                        <MudTextField ReadOnly Margin="Margin.Dense" @bind-Value="_sosHub.RevisedItems" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Training time</MudText>
                                    </td>
                                    <td style="display:flex;">
                                        <MudAutocomplete T="int"
                                            Label=@Localizer["Cycles"]
                                            Variant="Variant.Text"
                                            AnchorOrigin="Origin.BottomCenter"
                                            @bind-Value="cycleId"
                                            OpenIcon="@Icons.Material.Filled.AccessTime"
                                            AdornmentColor="Color.Info"
                                            Clearable
                                            ResetValueOnEmptyText
                                            ShowProgressIndicator="true" ProgressIndicatorColor="Color.Info"
                                            MaxItems="10"
                                            ReadOnly
                                            >

                                        </MudAutocomplete>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Safety Equipment</MudText>
                                    </td>
                                    <td>
                                        @if (_equipmentIds.Count > 0)
                                        {
                                            <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: center; align-items: center;">

                                                @foreach (var equipmentId in _equipmentIds)
                                                {
                                                    <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Warning" Variant="Variant.Outlined">
                                                        <MudChip Color="Color.Warning" Icon="@Icons.Material.Filled.Engineering" Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer">
                                                            @(_equipment.FirstOrDefault(t => t.EquipmentId == equipmentId)?.EquipmentName)
                                                        </MudChip>

                                                    </MudButton>
                                                }
                                        </MudItem>
                                    }
                                    else
                                    {
                                        <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Currently, there is no equipment.</MudAlert>
                                    }

                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Tools Used</MudText>
                                    </td>
                                    <td>
                                        @if (_toolsIds.Count > 0)
                                        {
                                            <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: center; align-items: center;">

                                                @foreach (var toolId in _toolsIds)
                                                {
                                                    <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined">
                                                    <MudChip Color="Color.Info" Icon="@Icons.Material.Filled.Build" Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer">
                                                            @(_tools.FirstOrDefault(t => t.ToolId == toolId)?.ToolName)
                                                        </MudChip>

                                                    </MudButton>
                                                }
                                            </MudItem>
                                        }
                                        else{
                                            <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Currently, there are no tools.</MudAlert>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Materials Used</MudText>
                                    </td>
                                    <td>
                                        @if (_materialsIds.Count > 0)
                                        {
                                            <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: center; align-items: center;">

                                                @foreach (var materialId in _materialsIds)
                                                {
                                                    <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Primary" Variant="Variant.Outlined">
                                                        <MudChip Color="Color.Primary" Icon="@Icons.Material.Filled.Work" Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer">
                                                            @(_materials.FirstOrDefault(t => t.MaterialId == materialId)?.MaterialName)
                                                        </MudChip>

                                                    </MudButton>
                                                }
                                            </MudItem>
                                        }
                                        else{
                                             <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">Currently, there are no materials.</MudAlert>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Other information</MudText>
                                    </td>
                                    <td>
                                        <MudTextField ReadOnly Margin="Margin.Dense" @bind-Value="_sosHub.OtherInformation" Lines="3" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Area</MudText>
                                    </td>
                                    <td class="d-flex">
                                        <MudItem Class="mr-4">
                                            <MudSelect ReadOnly T="int" Label=@Localizer["department"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@departmentId">
                                                <MudSelectItem Disabled="true" Value="0">@Localizer["selectADepartment"]</MudSelectItem>
                                                @foreach (var type in _departments)
                                                {
                                                    <MudSelectItem Value="type.DepartmentId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem Class="mr-4">

                                            @if (user.UserType == 1)
                                            {

                                                <MudSelect ReadOnly T="int" Label=@Localizer["plant"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@plantId">
                                                    <MudSelectItem Disabled="true" Value="0">@Localizer["selectAPlant"]</MudSelectItem>
                                                    @foreach (var type in _plants)
                                                    {
                                                        <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            }
                                            else
                                            {
                                            <MudSelect ReadOnly T="int" Label=@Localizer["plant"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@plantId">
                                                    @foreach (var type in _plants)
                                                    {
                                                        if (type.PlantId == user.PlantId)
                                                        {
                                                            <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                                        }
                                                    }
                                                </MudSelect>
                                            }
                                        </MudItem>
                                        <MudItem>
                                            @if (plantId != 0 && user.UserType == 1)
                                            {
                                                @*Mud select for Areas for Admin *@
                                                <MudSelect ReadOnly T="int" Label=@Localizer["area"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="areaId" >
                                                    <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnArea"]</MudSelectItem>
                                                    @foreach (var type in _areas)
                                                    {
                                                        <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            }
                                            else if (plantId != 0 && user.UserType == 2)
                                            {
                                                @*Mud select for Areas for SSV *@
                                                <MudSelect ReadOnly T="int" Label=@Localizer["area"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId" >
                                                    <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnArea"]</MudSelectItem>
                                                    @foreach (var type in user.Areas)
                                                    {
                                                        <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            }
                                            else if (plantId != 0)
                                            {
                                                @*Mud select for Areas for SV *@
                                                <MudSelect ReadOnly T="int" Label=@Localizer["area"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId">
                                                    <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnArea"]</MudSelectItem>
                                                    @foreach (var type in _areas)
                                                    {
                                                        if (type.AreaId == user.AreaId)
                                                        {
                                                            <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                                        }
                                                    }
                                                </MudSelect>
                                            }
                                            else
                                            {
                                                @*Mud select for Areas *@
                                            <MudSelect ReadOnly T="int" Label=@Localizer["area"] Variant="Variant.Text" Disabled AnchorOrigin="Origin.BottomCenter" @bind-Value="@areaId">
                                                    <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAPlant"]</MudSelectItem>
                                                </MudSelect>
                                            }
                                        </MudItem>

                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Owner</MudText>
                                    </td>
                                    <td>
                                        @if (_supervisors.Count > 0)
                                        {
                                            <MudAutocomplete T="int"
                                                Label=@Localizer["Supervisor"]
                                                Variant="Variant.Text"
                                                AnchorOrigin="Origin.BottomCenter"
                                                @bind-Value="supervisorOwnerId"
                                                OpenIcon="@Icons.Material.Filled.SupervisorAccount"
                                                AdornmentColor="Color.Secondary"
                                                Clearable
                                                ResetValueOnEmptyText
                                                ShowProgressIndicator="true" 
                                                ProgressIndicatorColor="Color.Info"
                                                ToStringFunc="@(s => _supervisors.FirstOrDefault(x => x.UserId == s)?.Name)"
                                                SearchFunc="SearchSupervisors"
                                                ReadOnly>
                                                
                                            </MudAutocomplete>
                                        }

                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Created</MudText>
                                    </td>
                                    <td>
                                        <MudTextField ReadOnly T="DateTime?" Format="s" Label="DateTimeLocal" InputType="InputType.DateTimeLocal" @bind-Value="createdDateTime" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Editor</MudText>
                                    </td>
                                    <td>
                                        @if (_supervisors.Count > 0)
                                        {
                                            <MudAutocomplete T="int"
                                                Label=@Localizer["Supervisor"]
                                                Variant="Variant.Text"
                                                AnchorOrigin="Origin.BottomCenter"
                                                @bind-Value="supervisorEditorId"
                                                OpenIcon="@Icons.Material.Filled.SupervisorAccount"
                                                AdornmentColor="Color.Secondary"
                                                Clearable
                                                ResetValueOnEmptyText
                                                ShowProgressIndicator="true" ProgressIndicatorColor="Color.Info"
                                                ToStringFunc="@(s => _supervisors.FirstOrDefault(x => x.UserId == s)?.Name)"
                                                SearchFunc="SearchSupervisors"
                                                ReadOnly>
                                            </MudAutocomplete>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Modified</MudText>
                                    </td>
                                    <td>
                                        <MudTextField ReadOnly T="DateTime?" Format="s" Label="DateTimeLocal" InputType="InputType.DateTimeLocal" @bind-Value="modifiedDateTime" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Plan</MudText>
                                    </td>
                                    <td>
                                        <MudTextField ReadOnly Margin="Margin.Dense" @bind-Value="_sosHub.Plan" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Source Plan</MudText>
                                    </td>
                                    <td>
                                        <MudTextField ReadOnly Margin="Margin.Dense" @bind-Value="_sosHub.SourcePlan" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <MudText>Status</MudText>
                                    </td>
                                    <td>
                                        <MudSelect ReadOnly Margin="Margin.Dense" T="string" Variant="Variant.Text" @bind-Value="_sosHub.Status">
                                            <MudSelectItem Value="@("Pending")" />
                                            <MudSelectItem Value="@("Approved")" />
                                            <MudSelectItem Value="@("Rejected")" />
                                        </MudSelect>
                                    </td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
            <MudCardActions>
                <MudItem Class="ml-auto mt-4">
                    <MudButton ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.PlayCircle" Variant="Variant.Filled" Color="Color.Info" Class="ml-4">@Localizer["createHOE"]</MudButton>
                </MudItem>
            </MudCardActions>
        </MudItem>
    </MudGrid>

<MudDialog @bind-IsVisible="visibleStepsDialog" Options="dialogStepsOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Steps"]
            </MudText>
        </div>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @((MarkupString)HighlightedText)
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudTable Items="@segments" Class="custom-table">
            <HeaderContent>
                <MudTh Style="font-weight:bold; width: 50%">Analysis</MudTh>
                <MudTh Style="font-weight:bold">Main Point</MudTh>
                <MudTh Style="font-weight:bold">Critical Points</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Analysis</MudTd>
                <MudTd>@context.MainPoint</MudTd>
                <MudTd>
                    <ul>
                        @foreach (var point in context.CriticalPoints)
                        {

                            <li>

                                @point
                            </li>
                        }
                    </ul>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseStepsDialog" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-IsVisible="visibleImagesDialog" Options="dialogImagesOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Images"]
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;  min-height: 50vh">
            @if (capturedImages.Count > 0)
            {
                <div style="display: flex; align-items: center; justify-content: space-between;" class="mt-4">
                    <MudItem Class="d-flex" Style="flex-direction: row; flex-wrap: wrap; justify-content: flex-start; overflow-y: scroll; max-height:50vh; scroll-behavior: smooth; justify-content: center;">

                        @foreach (var (image, index) in capturedImages.Select((image, index) => (image, index)))
                        {
                            <MudItem Class=" mr-8 mb-4">
                                <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                                </MudItem>
                                <MudImage ObjectFit="ObjectFit.Contain" Height="80" Width="130" Src=@image Alt="Evidence" Elevation="25" Class="rounded-lg" Style="cursor:pointer" @onclick="() => OpenEvidenceDialog(index)" />
                            </MudItem>
                        }
                    </MudItem>

                </div>
            }
        </MudItem>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseImagesDialog" Variant="Variant.Filled">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>


<MudDialog @bind-IsVisible="visibleVideosDialog" Options="dialogVideosOptions">
    <TitleContent>
        <div class="d-flex" style="align-items: center; justify-content:center;">
            <MudImage ObjectFit="ObjectFit.Cover" Height="25" Src="Images/logo.png" Alt="Evidence" Elevation="25" Class="rounded-lg mr-4" />
            <MudText Typo="Typo.h6" Style="text-align: center;">
                @Localizer["Videos"]
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudItem Style="display: flex; align-content: space-between; flex-wrap: wrap; justify-content: space-evenly; align-items: center;  min-height: 50vh">
            @if (MediaUris != null && MediaUris.Count > 0)
            {
                @foreach (var item in MediaUris.ToList())
                {
                    <MudItem Class="mr-4 mb-4">
                        <MudItem Style="text-align:end !important; margin-right: -15px; margin-bottom: -7px; cursor:pointer">
                        </MudItem>
                        <video width="300" height="150" controls @key="item.Key">
                            <source src="@item.Value.Item2">
                            Your browser does not support the video tag.
                        </video>
                    </MudItem>
                }
            }
            else
            {
                <MudAlert Severity="Severity.Info" ContentAlignment="HorizontalAlignment.Center">No media available.</MudAlert>
            }
        </MudItem>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseVideosDialog" Variant="Variant.Filled">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>



@*Evidence Modal*@
<MudDialog DisableSidePadding="false" @bind-IsVisible="visibleEvidence" Options="dialogEvidenceOptions">
    <DialogContent>
        <MudPaper Elevation="0">
            @if (capturedImages.Count() > 0)
            {
                <MudCarousel Class="mud-width-full" Style="height: 75vh" ShowArrows=true ShowBullets=true EnableSwipeGesture=true AutoCycle="false" TData="object" @bind-SelectedIndex=@photoIndex>
                    <PreviousButtonTemplate>
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Class="ml-4" Style="cursor:pointer">
                            <MudIcon Icon="@Icons.Material.Filled.NavigateBefore" />
                        </MudAvatar>
                    </PreviousButtonTemplate>
                    <NextButtonTemplate>
                        <MudAvatar Color="Color.Dark" Variant="Variant.Filled" Class="mr-4" Style="cursor:pointer">
                            <MudIcon Icon="@Icons.Material.Filled.NavigateNext" />
                        </MudAvatar>
                    </NextButtonTemplate>
                    <ChildContent>
                        @foreach (var evidence in capturedImages)
                        {
                            <MudCarouselItem Transition="Transition.Fade">
                                <MudImage ObjectFit="ObjectFit.Cover" Height="720" Width="1280" Src=@evidence Alt="Evidence" Elevation="25" Class="rounded-lg" Style="max-height: 66vh; width: 100%; border-radius: 10px; margin-bottom:24px;" />
                            </MudCarouselItem>
                        }
                    </ChildContent>
                </MudCarousel>
            }
            else
            {
                <MudItem Style="height: 75vh">
                    <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                        @Localizer["there is no previous evidence :)"]
                    </MudAlert>
                </MudItem>
            }
        </MudPaper>
    </DialogContent>
</MudDialog>

