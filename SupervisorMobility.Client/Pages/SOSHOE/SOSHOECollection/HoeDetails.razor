                {
                    <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() =>  GenerateDistribution())" Color="Color.Primary">
                        <MudText>Generate</MudText>
                    </MudButton>
                }
                else
                {
                    @if (_sosDistribution.DistributionLogbooks?.Last().Status == 2)
                    {
                        <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() =>  GenerateDistribution())" Color="Color.Primary">
                            <MudText>Revision</MudText>
                        </MudButton>
                    }

                }
                break;
            case 4:
                @if (_sosHub.SOSFlow.Count == 0)
                {
                    <MudButton Style="float: right" Class="mb-5" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.GeneratingTokens" OnClick="@(() =>  GenerateFlow())" Color="Color.Primary">
                        <MudText>Generate</MudText>
                    </MudButton>
