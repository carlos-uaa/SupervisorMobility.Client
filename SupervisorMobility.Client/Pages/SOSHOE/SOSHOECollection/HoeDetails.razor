                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.Hub" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                    </MudTd>
                                    <MudTd DataLabel="OperationName">
                                        <MudText Align="Align.Center">@distribution.OperationName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="InternalControlNumber">
                                        <MudText Align="Align.Center">@distribution.InternalControlNumber</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="ProcessName">
                                        <MudText Align="Align.Center">@distribution.ProcessName</MudText>
                                    </MudTd>
                                    <MudTd>
                                        <MudText Align="Align.Center">
                                            <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                <ActivatorContent>
                                                    <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                </ActivatorContent>
                                                <ChildContent>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<SOSDistribution>(distribution.SOSDistributionId))" OnTouch="(() => Details<SOSDistribution>(distribution.SOSDistributionId))">Details</MudMenuItem>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<SOSDistribution>(distribution.SOSDistributionId))" OnTouch="(() => Update<SOSDistribution>(distribution.SOSDistributionId))">Edit </MudMenuItem>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<SOSDistribution>(distribution.SOSDistributionId))" OnTouch="(() => Delete<SOSDistribution>(distribution.SOSDistributionId))">Delete </MudMenuItem>
                                                </ChildContent>
                                            </MudMenu>
                                        </MudText>
                                    </MudTd>
                                }
                                else if (@context is SOSFlow flow)
                                {

                                    <MudTd DataLabel="Id">
                                        <MudCard Elevation="0" Style="width:min-content">
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/flujo-de-datos.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Flow</b></MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.Air" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                    </MudTd>
                                    <MudTd DataLabel="OperationName">
                                        <MudText Align="Align.Center">@flow.OperationName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="InternalControlNumber">
                                        <MudText Align="Align.Center">@flow.InternalControlNumber</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="ProcessName">
                                        <MudText Align="Align.Center">@flow.ProcessName</MudText>
                                    </MudTd>
                                    <MudTd>
                                        <MudText Align="Align.Center">
                                            <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                <ActivatorContent>
                                                    <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                                </ActivatorContent>
                                                <ChildContent>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => Details<SOSFlow>(flow.SOSFlowId))" OnTouch="(() => Details<SOSFlow>(flow.SOSFlowId))">Details</MudMenuItem>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => Update<SOSFlow>(flow.SOSFlowId))" OnTouch="(() => Update<SOSFlow>(flow.SOSFlowId))">Edit </MudMenuItem>
                                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => Delete<SOSFlow>(flow.SOSFlowId))" OnTouch="(() => Delete<SOSFlow>(flow.SOSFlowId))">Delete </MudMenuItem>
                                                </ChildContent>
                                            </MudMenu>
                                        </MudText>
                                    </MudTd>
                                }
                                else if (@context is SOSSequence sequence)
                                {
                                    
                                    <MudTd DataLabel="Id">
                                        <MudCard Elevation="0" Style="width:min-content">
                                            <MudCardHeader>
                                                <CardHeaderAvatar>
                                                    <MudAvatar>
                                                        <MudImage Src="Images/flujo-de-trabajo.png" />
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.h6" Style="text-align:left"><b>Sequence</b></MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudIcon Icon="@Icons.Material.Filled.Earbuds" Color="MudBlazor.Color.Primary"></MudIcon>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                        </MudCard>
                                    </MudTd>
                                    <MudTd DataLabel="OperationName">
