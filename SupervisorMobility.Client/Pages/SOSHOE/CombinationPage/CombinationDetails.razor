<style>
    .vertical {
    writing-mode: tb-rl;
    -webkit-transform: rotate(180deg);
    -moz-transform: rotate(180deg);
    -o-transform: rotate(180deg);
    -ms-transform: rotate(180deg);
    transform: rotate(180deg);
    }

    .border-left {
    border-left: 2px solid #ababab;
    }

    .table-header td {
    background-color: #f5f5f6;
    }

    .table-header-gray th {
    background-color: #f5f5f6;
    }

    .table-header-gray td {
    padding: 0px 1% !important;
    }

    .divider {
    border-left: 1px solid var(--mud-palette-table-lines);
    }

    .images_cell {
    }

    .table-header-gray .images_cell {
    padding: 1% 2% !important;
    }

    .section_divider {
    border-top: 3px dashed var(--mud-palette-table-lines);
    }

    .mud-input .mud-input-slot {
    font-size: 0.6rem;
    scrollbar-width: none;
    margin: 2px;
    }

    .verticalText {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    }

    .small-font {
    font-size: 0.8rem;
    margin-top: 5px;
    margin-bottom: 5px;
    }

    .small-font2 {
    font-size: 0.7rem;
    font-weight: bold;
    }

    .zig-zag-line {
    --a: 60deg; /* control the angle */
    --s: 20px; /* size of the zig-zag */
    --b: 5px; /* control the thickness */

    background: black;
    height: calc(var(--b) + var(--s)/(2*tan(var(--a)/2)) + 5px);
    width: 120%;
    --_g: var(--s) repeat-x conic-gradient(from calc(var(--a)/-2) at bottom, #0000,#000 1deg calc(var(--a) - 1deg),#0000 var(--a));
    mask: 50% calc(-1*var(--b))/var(--_g) exclude,50%/var(--_g);
    }

    .last-zig-zag-line {
    --a: 90deg; /* control the angle */
    --s: 20px; /* size of the zig-zag */
    --b: 5px; /* control the thickness */

    background: black;
    width: calc(var(--b) + var(--s)/(2*tan(var(--a)/2)));
    --_g: 100% var(--s) repeat-y conic-gradient(from calc(90deg - var(--a)/2) at left, #0000,#000 1deg calc(var(--a) - 1deg),#0000 var(--a));
    mask: var(--b) 50%/var(--_g) exclude,0 50%/var(--_g);
    }

    .tacktime-cell {
    position: relative;
    }

    .tacktime-line {
    position: absolute;
    border-left: 6px solid red; /* Línea vertical para denotar el TackTime */
    height: 100%;
    top: 0;
    }
</style>

