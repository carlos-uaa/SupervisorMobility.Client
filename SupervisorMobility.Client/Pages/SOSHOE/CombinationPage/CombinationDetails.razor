                                        <div style="  --a: 60deg; --s: 20px; --b: 5px; background: black; height: calc(var(--b) + var(--s)/(2*tan(var(--a)/2))); width: 100%; --_g: var(--s) repeat-x conic-gradient(from calc(var(--a)/-2) at bottom, #0000,#000 1deg calc(var(--a) - 1deg),#0000 var(--a)); mask: 50% calc(-1*var(--b))/var(--_g) exclude,50%/var(--_g);"></div>
