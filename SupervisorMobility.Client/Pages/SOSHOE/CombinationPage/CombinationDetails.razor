            <tr>
                @{
                    double number = 0;
                }
                @for (int i = 0; i < _Celdas; i++)
                {
                    if ((i + 1) % 5 == 0 && (i + 1) % 10 != 0)
                    {
                        //cada 5
                        number = Math.Round(number + (_CellSize * 5), 2);
                        <td colspan="2" style="height:20px; text-align:center;">@number.ToString("F2")</td>
                        i++;
                    }
                    else if ((i + 1) % 10 == 0)
                    {
                        //cada 10
                        number = Math.Round(number + (_CellSize * 5), 2);
                        <td colspan="2" style="height:20px; text-align:center;">@number.ToString("F2")</td>
                        i++;
                    }
                    else
                    {
                        <td style="height:20px"></td>
                    }
                }
            </tr>
            @if (_sosCombination.SOSCombinationOperationSequence?.Any() ?? false)
            {

                @code {
        double cumulativeManualTime = 0.0;
        string[] decimalSeparators = { ".", "," };
        double RoundToThreeDecimals(double value) => Math.Round(value, 3);
        int top = 0;
        }
                GetLastValidOperationIndex();

                @foreach (var (operationSequence, indexOperationSequence) in _sosCombination.SOSCombinationOperationSequence.Select((operationSequence, indexSection) => (operationSequence, indexSection)))
                {
                    bool isLastValidOperation = operationSequence == _sosCombination.SOSCombinationOperationSequence.Last();
                    bool renderStep = true;

                    if (_sosCombination.SOSCombinationOperationSequence.ToList().IndexOf(operationSequence) == 0 && cumulativeManualTime != 0.0)
                    {
                        cumulativeManualTime = 0.0;
                    }
                    // Parse the times, handling nulls and different decimal separators
                    double manualOperationTime = 0.0;
                    manualOperationTime = operationSequence.ManualOperationTime == null ? 0.0 : (double)operationSequence.ManualOperationTime;
                    manualOperationTime = RoundToThreeDecimals(manualOperationTime);

                    double manualWithMachineTime = 0.0;
                    manualWithMachineTime = operationSequence.ManualOperationTimeWithMachineInAutomatic == null ? 0.0 : (double)operationSequence.ManualOperationTimeWithMachineInAutomatic;
                    manualWithMachineTime = RoundToThreeDecimals(manualWithMachineTime);

                    double automaticMachineTime = 0.0;
                    automaticMachineTime = operationSequence.AutomaticMachineOperationTime == null ? 0.0 : (double)operationSequence.AutomaticMachineOperationTime;
                    automaticMachineTime = RoundToThreeDecimals(automaticMachineTime);

                    double steps = 0.0;
                    steps = operationSequence.StepsToNextProcess == null ? 0.0 : (double)operationSequence.StepsToNextProcess;
                    steps = RoundToThreeDecimals(steps);

                    double StepCurrentFragment = Math.Floor((steps / 2) * 100) / 100;
                    double StepPrevious = 0.0;


                    if (StepPrevious == 0 && StepCurrentFragment == 0)
                    {
                        StepCurrentFragment = steps;
                    }
                    else if (indexOperationSequence > 0)
                    {
                        double previousSteps = 0.0;
                        previousSteps = _sosCombination.SOSCombinationOperationSequence.ToList()[indexOperationSequence - 1].StepsToNextProcess == null ? 0.0 : (double)_sosCombination.SOSCombinationOperationSequence.ToList()[indexOperationSequence - 1].StepsToNextProcess;
                        previousSteps = RoundToThreeDecimals(previousSteps);

                        double previousFragment = Math.Floor((previousSteps / 2) * 100) / 100;
                        StepPrevious = RoundToThreeDecimals(previousSteps - previousFragment);


                        if (StepPrevious == previousSteps)
                        {
                            StepPrevious = 0;
                        }
                    }



                    if (isLastValidOperation)
                    {
                        StepCurrentFragment = steps;
                    }
                    // Start the row
                    <tr style="height: 65px;">
                        <td>@operationSequence.SequenceId</td>
                        <td>@operationSequence.ProcessName</td>
                        <td>@operationSequence.PartsPerCycle</td>
                        <td>@operationSequence.ManualOperationTime</td>
                        <td>@operationSequence.ManualOperationTimeWithMachineInAutomatic</td>
                        <td>@operationSequence.AutomaticMachineOperationTime</td>
                        <td>@operationSequence.StepsToNextProcess</td>

                        @{
                            double ExcessMachineTime = 0;

                            if (_tackTimePosition != 0 && (RoundToThreeDecimals(cumulativeManualTime + StepPrevious + manualOperationTime + automaticMachineTime) > _tackTimePosition))
                            {
                                ExcessMachineTime = RoundToThreeDecimals(cumulativeManualTime + StepPrevious + manualOperationTime + automaticMachineTime) - _tackTimePosition;
                                automaticMachineTime = automaticMachineTime - ExcessMachineTime;
                            }


                            double cumulativeTime = cumulativeManualTime;
                            bool isHalfStartCell = (int)(cumulativeManualTime * 100) % 2 != 0;

                            if (manualOperationTime > 0 && manualWithMachineTime <= 0)
                            {
                                top = 20;
                            }
                            else if (manualOperationTime > 0 && manualWithMachineTime > 0)
                            {
                                top = 40;
                            }


                            for (int i = 0; i < _Celdas + 1; i++)
                            {
                                double cellStart = RoundToThreeDecimals(i * _CellSize);
                                double cellEnd = RoundToThreeDecimals(cellStart + _CellSize);


                                if (indexOperationSequence < 2 && i > 9 && i < 25)
                                {
                                    Console.WriteLine($"Index {indexOperationSequence} i: {i} Acumu:{cumulativeTime}, Celda {_CellSize} y {_HalfCellSize} isHafl: {isHalfStartCell}, ManualOperation  {manualOperationTime}, OpMaq {manualWithMachineTime}, maquina {automaticMachineTime}, PrevStep {StepPrevious}, step {StepCurrentFragment}");
                                }


                                if (isHalfStartCell)
                                {
                                    //Case 0: ExcessMachineTime
                                    if (ExcessMachineTime > 0)
                                    {
                                        if (ExcessMachineTime >= _CellSize)
                                        {
                                            ExcessMachineTime = RoundToThreeDecimals(ExcessMachineTime - _CellSize);

                                            <td class="tacktime-cell" style="position: relative; overflow: visible;">
                                                <div style="position: absolute; top: 15px; left: 0; width: 100%; height: 2px; border-top: 2px dashed black;"></div>
                                            </td>
                                        }
                                        else if (ExcessMachineTime > _HalfCellSize && ExcessMachineTime <= _CellSize)
                                        {
                                            ExcessMachineTime = 0;

                                            <td class="tacktime-cell" style="position: relative; overflow: visible;">
                                                <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                            </td>
                                        }
                                        else if (ExcessMachineTime <= _HalfCellSize)
                                        {
                                            ExcessMachineTime = RoundToThreeDecimals(ExcessMachineTime - _HalfCellSize);

                                            <td class="tacktime-cell" style="position: relative; overflow: visible;">
                                                <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                            </td>
                                        }
                                    }
                                    // Case 1: Step Previous
                                    else if (StepPrevious > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                    {
                                        StepPrevious = RoundToThreeDecimals(StepPrevious - _HalfCellSize);
                                        cumulativeTime = RoundToThreeDecimals(cumulativeTime + _HalfCellSize);
                                        isHalfStartCell = false;

                                        <td class="tacktime-cell" style="position: relative; overflow: visible;">
                                            @if (_tackTimePosition != 0 && _tackTimePosition >= cellStart && _tackTimePosition < cellEnd && _sosCombination.TackTime != "")
                                            {
                                                double relativePosition = ((_tackTimePosition - cellStart) / (cellEnd - cellStart)) * 100; // Posición relativa en porcentaje
                                                <div class="tacktime-line" style="left:@relativePosition%;"></div>
                                            }
                                        </td>



                                    }
                                    // Case 2: ManualOperationTime
                                    else if (manualOperationTime > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                    {
                                        manualOperationTime = RoundToThreeDecimals(manualOperationTime - _HalfCellSize);
                                        cumulativeTime = RoundToThreeDecimals(cumulativeTime + _HalfCellSize);
                                        isHalfStartCell = false;


                                        <td class="tacktime-cell" style="position: relative; overflow: visible;">
                                            <div style="position: absolute; top: 15px; width: 50%; height: 2px; background: black;"></div>
                                            @if (_tackTimePosition != 0 && _tackTimePosition >= cellStart && _tackTimePosition < cellEnd && _sosCombination.TackTime != "")
                                            {
                                                double relativePosition = ((_tackTimePosition - cellStart) / (cellEnd - cellStart)) * 100; // Posición relativa en porcentaje
                                                <div class="tacktime-line" style="left:@relativePosition%;"></div>
                                            }
                                        </td>
                                    }
                                    // Case 3: ManualOperationTimeWithMachineInAutomatic and AutomaticMachineOperationTime
                                    else if (manualWithMachineTime > 0 && automaticMachineTime > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                    {

                                        manualWithMachineTime = RoundToThreeDecimals(manualWithMachineTime - _HalfCellSize);
                                        automaticMachineTime = RoundToThreeDecimals(automaticMachineTime - _HalfCellSize);
                                        cumulativeTime = RoundToThreeDecimals(cumulativeTime + _HalfCellSize);
                                        isHalfStartCell = false;


                                        <td class="tacktime-cell" style="position: relative; overflow: visible;">
                                            <div style="position: absolute; top: 15px; left: 50; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                            <div style="position: absolute; top: 35px; left: 50; width: 50%; height: 2px; background: black;"></div>
                                            @if (_tackTimePosition != 0 && _tackTimePosition >= cellStart && _tackTimePosition < cellEnd && _sosCombination.TackTime != "")
                                            {
                                                double relativePosition = ((_tackTimePosition - cellStart) / (cellEnd - cellStart)) * 100; // Posición relativa en porcentaje
                                                <div class="tacktime-line" style="left:@relativePosition%;"></div>
                                            }
                                        </td>
                                    }
                                    // Case 4: Remaining AutomaticMachineOperationTime
                                    else if (automaticMachineTime > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                    {
                                        automaticMachineTime = RoundToThreeDecimals(automaticMachineTime - _HalfCellSize);
                                        isHalfStartCell = false;

                                        <td class="tacktime-cell" style="position: relative; overflow: visible;">
                                            <div style="position: absolute; top: 15px; left: 50; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                            @if (_tackTimePosition != 0 && _tackTimePosition >= cellStart && _tackTimePosition < cellEnd && _sosCombination.TackTime != "")
                                            {
                                                double relativePosition = ((_tackTimePosition - cellStart) / (cellEnd - cellStart)) * 100; // Posición relativa en porcentaje
                                                <div class="tacktime-line" style="left:@relativePosition%;"></div>
                                            }
                                        </td>
                                    }
                                    //case 5: Remaining manualWithMachineTime
                                    else if (manualWithMachineTime > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                    {
                                        manualWithMachineTime = RoundToThreeDecimals(manualWithMachineTime - _HalfCellSize);
                                        cumulativeTime = RoundToThreeDecimals(cumulativeTime + _HalfCellSize);
                                        isHalfStartCell = false;

                                        <td class="tacktime-cell" style="position: relative; overflow: visible;">
                                            <div style="position: absolute; top: 35px; left: 50; width: 50%; height: 2px; background: black;"></div>
                                            @if (_tackTimePosition != 0 && _tackTimePosition >= cellStart && _tackTimePosition < cellEnd && _sosCombination.TackTime != "")
                                            {
                                                double relativePosition = ((_tackTimePosition - cellStart) / (cellEnd - cellStart)) * 100; // Posición relativa en porcentaje
                                                <div class="tacktime-line" style="left:@relativePosition%;"></div>
                                            }
                                        </td>

                                    }
                                    //case 6: Blanck Cell
                                    else
                                    {
                                        <td class="tacktime-cell" style="">
