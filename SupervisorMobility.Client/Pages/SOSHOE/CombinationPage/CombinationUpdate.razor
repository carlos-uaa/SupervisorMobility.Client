            </MudTr>
            <MudTr>
                <MudTd><b>FECHA DE EMISIÓN</b><br />@_sosCombination.CreatedAt?.ToShortDateString()</MudTd>
                <MudTd>
                    <b>MES DE APLICACIÓN</b><br />@_sosCombination.ApplicationMonth?.ToString("MM/yyyy")
                </MudTd>
                <MudTd>
                    <b>MODELO</b><br />
                    @foreach (Product model in _sosCombination.SOSHub.AppliedModels)
                    {
                        <MudChip Color="Color.Info" Icon="@Icons.Material.Filled.DirectionsCar" Size="Size.Small" Variant="Variant.Outlined">
                            @model.Description
                        </MudChip>
                    }
                </MudTd>
                <MudTd><b>TIEMPO DE APRENDIZAJE</b><br />@_sosCombination.SOSHub?.TrainingTime</MudTd>
                <MudTd colspan="2"><b>PLANTA</b><br />@_sosCombination.SOSHub?.Plant?.Description</MudTd>
                <MudTd><b>GERENCIA</b><br />@_sosCombination.SOSHub?.Department?.Description</MudTd>
            </MudTr>
            <td class="divider images_cell" colspan="7" style="min-width: 30vw; height: 100%;">
                <MudItem Class="d-flex" Style="justify-content: center; margin-top: 2px; margin-bottom: -8px;">
                    @if (capturedImages.Any())
                    {
                        <div style="display: flex; align-items: center; justify-content: space-between;">
                            <MudItem Class="d-flex" Style="flex-direction: row; flex-wrap: wrap; justify-content: flex-start; overflow-y: scroll; max-height:65vh; scroll-behavior: smooth; justify-content: center;">
                                @foreach (var (image, index) in capturedImages.Select((image, index) => (image, index)))
                                {
                                    <MudItem Class="mb-2 mr-2">
                                        <MudImage ObjectFit="ObjectFit.Contain" Height="160" Width="260" Src=@image Alt="Evidence" Elevation="25" Class="rounded-lg" @onclick="() => OpenEvidenceDialog(index)" Style="cursor:pointer" />
                                    </MudItem>
                                }
                            </MudItem>
                        </div>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                            @Localizer["There are no images"]
                        </MudAlert>
                    }
                </MudItem>
            </td>
            <MudTr>
                <MudTd>
                    @* <b>VOLUMEN DE PRODUCCIÓN POR TURNO</b><br />@_sosCombination.ProductionVolumePerShift *@
                    <MudTextField @bind-Value="@_sosCombination.ProductionVolumePerShift" Label="VOLUMEN DE PRODUCCIÓN POR TURNO" Variant="Variant.Text" />
                </MudTd>
                <MudTd>
                    @* <b>TIEMPO TACTO</b><br />@_sosCombination.TackTime *@
                    <MudTextField @bind-Value="@_sosCombination.TackTime" Label="TIEMPO TACTO" Variant="Variant.Text" />
                </MudTd>
                <MudTd>
                    @* <b>NO. DE CONTROL</b><br />@_sosCombination.ControlNumber *@
                    <MudTextField @bind-Value="@_sosCombination.ControlNumber" Label="NO. DE CONTROL" Variant="Variant.Text" />
                </MudTd>
                <MudTd colspan="4">
                    <MudSimpleTable Style="width:100%" Class="table-header-gray" Elevation="1">
                        <tbody>

                            <tr>
                                <th style="writing-mode: vertical-rl; transform: rotate(180deg); " rowspan="2">SÍMBOLOS</th>
                                <th style="">SEGURIDAD</th>
                                <th style="">INVENTARIO</th>
                                <th style="">CHEQUEO</th>
                                <th style="text-align:center;">ÁREA DE OPERACIÓN</th>
                                <th style="">RUTA</th>
                            </tr>
                            <tr>
                                <td style="text-align: center; vertical-align: middle;">
                                    <MudImage Src="/Images/DistributionSymbols/safety.png" Alt="Seguridad" Width="20" />
                                </td>
                                <td style="text-align: center; vertical-align: middle;">
                                    <MudImage Src="/Images/DistributionSymbols/inventory.png" Alt="Inventario" Width="20" />
                                </td>
                                <td style="text-align: center; vertical-align: middle;">
                                    <MudImage Src="/Images/DistributionSymbols/checking.png" Alt="Chequeo" Width="20" />
                                </td>
                                <td style="text-align: center; vertical-align: middle;">
                                    <MudImage Src="/Images/DistributionSymbols/operation_area.png" Alt="Área de Operación" Width="20" />
                                </td>
                                <td style="text-align: center; vertical-align: middle;">
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" />
                                </td>
                            </tr>
                        </tbody>
                    </MudSimpleTable>
                </MudTd>
            </MudTr>

        </tbody>
    </MudSimpleTable>
    <br />
    <MudSimpleTable Dense Style="width:100%; margin:0px; padding:0px;" Bordered Elevation="3">
        <tbody>
            <tr>
                <td rowspan="2" class="verticalText"><span class="small-font2">SECUENCIA DE <br />OPERACIÓN</span></td>
                <td rowspan="2">No. DE PROCESO</td>
                <td rowspan="2" class="verticalText"><span class="small-font2">PARTES POR CICLO</span></td>
                <td rowspan="2" class="verticalText"><span class="small-font2">TIEMPO DE OPERACIÓN <br />MANUAL</span></td>
                <td rowspan="2" class="verticalText"><span class="small-font2">TIEMPO DE OP. MANUAL <br />CON MAQ. EN <br />AUTOMATICO</span></td>
                <td rowspan="2" class="verticalText"><span class="small-font2">TIEMPO DE OP.<br /> AUTO. DE MAQ.</span></td>
                <td rowspan="2" class="verticalText"><span class="small-font2"> <br />  </span></td>
                <td colspan="91"></td>
            </tr>
            <tr>
                @{
                    double number = 0.1;
                }
                @for (int i = 0; i < 91; i++)
                {
                    if ((i + 1) % 5 == 0 && (i + 1) % 10 != 0)
                    {
                        <td colspan="2" style="height:20px; text-align:center;">@number.ToString("F1")</td>
                        number = Math.Round(number + 0.1, 1);
                        i++;
                    }
                    else if ((i + 1) % 10 == 0)
                    {
                        <td colspan="2" style="height:20px; text-align:center;">@number.ToString("F1")</td>
                        number = Math.Round(number + 0.1, 1);
                        i++;
                    }
                    else
                    {
                        <td style="height:20px"></td>
                    }
                }
            </tr>


            @if (_sosCombination.SOSCombinationOperationSequence?.Any() ?? false)
            {

                @code {
        double cumulativeManualTime = 0.0;
        string[] decimalSeparators = { ".", "," };
        double RoundToTwoDecimals(double value) => Math.Round(value, 2);
        int top = 0;
        }

                @foreach (var (operationSequence, indexOperationSequence) in _sosCombination.SOSCombinationOperationSequence.Select((operationSequence, indexSection) => (operationSequence, indexSection)))
                {

                    if (_sosCombination.SOSCombinationOperationSequence.ToList().IndexOf(operationSequence) == 0 && cumulativeManualTime != 0.0)
                    {
                        cumulativeManualTime = 0.0;
                    }
                    // Parse the times, handling nulls and different decimal separators
                    double manualOperationTime = 0.0;
                    double.TryParse(operationSequence.ManualOperationTime?.Replace(",", ".") ?? "0", System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out manualOperationTime);
                    manualOperationTime = RoundToTwoDecimals(manualOperationTime);

                    double manualWithMachineTime = 0.0;
                    double.TryParse(operationSequence.ManualOperationTimeWithMachineInAutomatic?.Replace(",", ".") ?? "0", System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out manualWithMachineTime);
                    manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime);

                    double automaticMachineTime = 0.0;
                    double.TryParse(operationSequence.AutomaticMachineOperationTime?.Replace(",", ".") ?? "0", System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out automaticMachineTime);
                    automaticMachineTime = RoundToTwoDecimals(automaticMachineTime);

                    double steps = 0.0;
                    double.TryParse(operationSequence.StepsToNextProcess?.Replace(",", ".") ?? "0", System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out steps);
                    steps = RoundToTwoDecimals(steps);

                    double StepCurrentFragment = Math.Floor((steps / 2) * 100) / 100;
                    double StepPrevious = 0.0;
                    if (indexOperationSequence > 0)
                    {
                        double previousSteps = 0.0;
                        double.TryParse(
                        _sosCombination.SOSCombinationOperationSequence.ElementAt(indexOperationSequence - 1).StepsToNextProcess?.Replace(",", ".") ?? "0",
                        System.Globalization.NumberStyles.Any,
                        System.Globalization.CultureInfo.InvariantCulture,
                        out previousSteps);

                        previousSteps = RoundToTwoDecimals(previousSteps);
                        double previousFragment = Math.Floor((previousSteps / 2) * 100) / 100;
                        StepPrevious = RoundToTwoDecimals(previousSteps - previousFragment);
                    }
                    // Start the row
                    <tr style="height: 65px;">
                        <td>
                            <div class="d-flex flex-column" style="align-items: center;">
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Disabled="@(indexOperationSequence == 0)"
                                OnClick="() => MoveStepsProcess(indexOperationSequence, -1)" />
                                <span>@(indexOperationSequence + 1)</span>
                                <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Disabled="@(indexOperationSequence == _sosCombination.SOSCombinationOperationSequence.Count - 1)"
                                OnClick="() => MoveStepsProcess(indexOperationSequence, 1)" />
                            </div>
                        </td>
                        <td>@operationSequence.ProcessName</td>
                        <td style="min-width: 95px;">
                            <MudTextField @bind-Value="@_sosCombination.SOSCombinationOperationSequence.ElementAt(indexOperationSequence).PartsPerCycle" Variant="Variant.Outlined" Margin="Margin.Dense" Class="small-font" />
                        </td>
                        <td style="min-width: 95px;">
                            <MudTextField @bind-Value="@_sosCombination.SOSCombinationOperationSequence.ElementAt(indexOperationSequence).ManualOperationTime" Variant="Variant.Outlined" Margin="Margin.Dense" Class="small-font" />
                        </td>
                        <td style="min-width: 95px;">
                            <MudTextField @bind-Value="@_sosCombination.SOSCombinationOperationSequence.ElementAt(indexOperationSequence).ManualOperationTimeWithMachineInAutomatic" Variant="Variant.Outlined" Margin="Margin.Dense" Class="small-font" />
                        </td>
                        <td style="min-width: 95px;">
                            <MudTextField @bind-Value="@_sosCombination.SOSCombinationOperationSequence.ElementAt(indexOperationSequence).AutomaticMachineOperationTime" Variant="Variant.Outlined" Margin="Margin.Dense" Class="small-font" />
                        </td>
                        <td style="min-width: 95px;">
                            <MudTextField @bind-Value="@_sosCombination.SOSCombinationOperationSequence.ElementAt(indexOperationSequence).StepsToNextProcess" Variant="Variant.Outlined" Margin="Margin.Dense" Class="small-font" />
                        </td>

                        @{
                            double cumulativeTime = cumulativeManualTime;
                            bool isHalfStartCell = (int)(cumulativeManualTime * 100) % 2 != 0;

                            if (indexOperationSequence > 0 && manualOperationTime > 0)
                            {
                                top = 5;
                            }
                            else if (manualOperationTime > 0 && manualWithMachineTime > 0)
                            {
                                top = 25;
                            }


                            for (int i = 0; i < 91; i++)
                            {
                                double cellStart = RoundToTwoDecimals(i * 0.02);
                                double cellEnd = RoundToTwoDecimals(cellStart + 0.02);

                                if (isHalfStartCell)
                                {
                                    //Step Previous
                                    if (StepPrevious > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                    {
                                        StepPrevious = RoundToTwoDecimals(StepPrevious - 0.01);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);
                                        isHalfStartCell = false;

                                        <td style="position: relative; overflow:hidden">
                                            <div style="position: absolute; top: @($"{top}px"); left: 50%; width: 50%; overflow: hidden;">
                                                <div class="zig-zag-line"></div>
                                            </div>
                                        </td>
                                        top += 10;

                                        if (StepPrevious == 0)
                                        {
                                            if (manualOperationTime > 0 && manualWithMachineTime == 0)
                                            {
                                                top = 5;
                                            }
                                            else if (manualOperationTime > 0 && manualWithMachineTime > 0)
                                            {
                                                top = 25;
                                            }
                                        }
                                    }
                                    // Case 1: ManualOperationTime
                                    else if (cumulativeTime >= cellStart && cumulativeTime < cellEnd && manualOperationTime > 0)
                                    {
                                        manualOperationTime = RoundToTwoDecimals(manualOperationTime - 0.01);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);
                                        isHalfStartCell = false;


                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 50px; width: 50%; height: 2px; background: black;"></div>
                                        </td>
                                    }
                                    // Case 2: ManualOperationTimeWithMachineInAutomatic and AutomaticMachineOperationTime
                                    else if (manualWithMachineTime > 0 && automaticMachineTime > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                    {

                                        manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.01);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);
                                        isHalfStartCell = false;


                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 50; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                            <div style="position: absolute; top: 35px; left: 50; width: 50%; height: 2px; background: black;"></div>
                                        </td>
                                    }
                                    // Case 3: Remaining AutomaticMachineOperationTime
                                    else if (automaticMachineTime > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                    {
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.01);
                                        isHalfStartCell = false;

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 50; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                        </td>
                                    }
                                    //case 4: Remaining manualWithMachineTime
                                    else if (manualWithMachineTime > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                    {
                                        manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);
                                        isHalfStartCell = false;

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 35px; left: 50; width: 50%; height: 2px; background: black;"></div>
                                        </td>

                                    }
                                    else
                                    {
                                        <td style=""></td>
                                    }

                                    continue; // Ir a la siguiente iteración
                                }
                                else if (i == 0 && indexOperationSequence > 0)
                                {
                                    top = -10;
                                }

                                if (StepPrevious > 0 && cellStart >= cumulativeTime && cumulativeTime < cellEnd)
                                {
                                    if (StepPrevious <= 0.01) // Media línea
                                    {
                                        //StepPrevious media linea sola
                                        if (StepPrevious > 0 && manualOperationTime == 0 && manualWithMachineTime == 0 && automaticMachineTime > 0)
                                        {
                                            StepPrevious = RoundToTwoDecimals(StepPrevious - 0.01);

                                            //Solo se traza media linea
                                            cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);

                                            <td style="position: relative;">
                                                <div style="position: absolute; top: @($"{top}px"); left: 0; width: 50%; overflow: hidden;">
                                                    <div class="zig-zag-line"></div>
                                                </div>
                                            </td>
                                        }
                                        //StepPrevious seguido de manualOperationTime
                                        else if (StepPrevious > 0 && manualOperationTime > 0)
                                        {
                                            StepPrevious = RoundToTwoDecimals(StepPrevious - 0.01);
                                            manualOperationTime = RoundToTwoDecimals(manualOperationTime - 0.01);

                                            //Se completo la celda por lo que se resta el valor de 2
                                            cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                            <td style="position: relative;">
                                                <div style="position: absolute; top: @($"{top}px"); left: 0; width: 50%; overflow: hidden;">
                                                    <div class="zig-zag-line"></div>
                                                </div>
                                                <div style="position: absolute; top: 15px; left: 50%; width: 50%; height: 2px; background: black;"></div>
                                            </td>
                                        }
                                        //StepPrevious seguido de ManualWithMachine + Automatic
                                        else if (StepPrevious > 0 && manualOperationTime == 0 && manualWithMachineTime > 0 && automaticMachineTime > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                        {
                                            StepPrevious = RoundToTwoDecimals(StepPrevious - 0.01);

                                            manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);
                                            automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.01);

                                            //Se completo la celda por lo que se resta el valor de 2
                                            cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                            <td style="position: relative;">
                                                <div style="position: absolute; top: @($"{top}px"); left: 0; width: 50%; overflow: hidden;">
                                                    <div class="zig-zag-line"></div>
                                                </div>
                                                <div style="position: absolute; top: 15px; left: 50%; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                                <div style="position: absolute; top: 35px; left: 50%; width: 50%; height: 2px; background: black;"></div>
                                            </td>
                                        }
                                        // StepPrevious seguido de ManualWithMachine
                                        else if (StepPrevious > 0 && manualOperationTime == 0 && manualWithMachineTime > 0 && automaticMachineTime == 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                        {

                                            StepPrevious = RoundToTwoDecimals(StepPrevious - 0.01);

                                            manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);

                                            //Se completo la celda por lo que se resta el valor de 2
                                            cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                            <td style="position: relative;">
                                                <div style="position: absolute; top: @($"{top}px"); left: 0; width: 50%; overflow: hidden;">
                                                    <div class="zig-zag-line"></div>
                                                </div>
                                                <div style="position: absolute; top: 35px; left: 50%; width: 50%; height: 2px; background: black;"></div>
                                            </td>
                                        }
                                        // StepPrevious seguido de AutomaticMachineOperationTime
                                        else if (StepPrevious > 0 && manualOperationTime == 0 && manualWithMachineTime == 0 && automaticMachineTime > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                        {
                                            StepPrevious = RoundToTwoDecimals(StepPrevious - 0.01);

                                            automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.01);

                                            //Se completo la celda por lo que se resta el valor de 2
                                            cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                            <td style="position: relative;">
                                                <div style="position: absolute; top: @($"{top}px") ; left: 0; width: 50%; overflow: hidden;">
                                                    <div class="zig-zag-line"></div>
                                                </div>
                                                <div style="position: absolute; top: 15px; left: 50%; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                            </td>
                                        }
                                        top += 10;
                                    }
                                    else // Línea completa
                                    {
                                        StepPrevious = RoundToTwoDecimals(StepPrevious - 0.02);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                        if (top >= 0)
                                        {
                                            <td style="position: relative; overflow: hidden;">
                                                <div style="position: absolute; top: @($"{top}px"); left: -17px; width: 110%;">
                                                    <div class="zig-zag-line"></div>
                                                </div>
                                            </td>
                                        }
                                        else
                                        {
                                            <td style="position: relative; overflow: visible; clip-path: inset(-50px 0px 0px -50px)">
                                                <div style="position: absolute; top: @($"{top}px"); left: -17px; width: 110%;">
                                                    <div class="zig-zag-line"></div>
                                                </div>
                                            </td>
                                        }
                                        top += 10;
                                    }

                                    if (StepPrevious == 0)
                                    {
                                        if (manualOperationTime > 0 && manualWithMachineTime == 0)
                                        {
                                            top = 5;
                                        }
                                        else if (manualOperationTime > 0 && manualWithMachineTime > 0)
                                        {
                                            top = 25;
                                        }
                                    }


                                }
                                // Case 1.1: manualOperationTime
                                else if (cumulativeTime >= cellStart && cumulativeTime < cellEnd && manualOperationTime > 0)
                                {
                                    if (manualOperationTime <= 0.01) // Media línea
                                    {
                                        // manualOperationTime
                                        if (manualOperationTime > 0 && manualWithMachineTime == 0 && automaticMachineTime == 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                        {
                                            manualOperationTime = RoundToTwoDecimals(manualOperationTime - 0.01);

                                            //Solo se traza media linea
                                            cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);

                                            <td style="position: relative;">
                                                <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; background: black;"></div>
                                            </td>
                                        }
                                        // Case 1.2: manualOperationTime seguido de ManualWithMachine + Automatic
                                        else if (manualOperationTime > 0 && manualWithMachineTime > 0 && automaticMachineTime > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                        {
                                            manualOperationTime = RoundToTwoDecimals(manualOperationTime - 0.01);
                                            manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);
                                            automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.01);

                                            //Se completo la celda por lo que se resta el valor de 2
                                            cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                            <td style="position: relative;">
                                                <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; background: black;"></div>
                                                <div style="position: absolute; top: 15px; left: 50%; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                                <div style="position: absolute; top: 35px; left: 50%; width: 50%; height: 2px; background: black;"></div>
                                            </td>
                                        }
                                        // manualOperationTime seguido de ManualWithMachine
                                        else if (manualOperationTime > 0 && manualWithMachineTime > 0 && automaticMachineTime == 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                        {

                                            manualOperationTime = RoundToTwoDecimals(manualOperationTime - 0.01);
                                            manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);

                                            //Se completo la celda por lo que se resta el valor de 2
                                            cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                            <td style="position: relative;">
                                                <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; background: black;"></div>
                                                <div style="position: absolute; top: 35px; left: 50%; width: 50%; height: 2px; background: black;"></div>
                                            </td>
                                        }
                                        // manualOperationTime seguido de AutomaticMachineOperationTime
                                        else if (manualOperationTime > 0 && manualWithMachineTime == 0 && automaticMachineTime > 0 && StepCurrentFragment > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                        {
                                            manualOperationTime = RoundToTwoDecimals(manualOperationTime - 0.01);
                                            automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.01);
                                            StepCurrentFragment = RoundToTwoDecimals(StepCurrentFragment - 0.01);

                                            //Se completo la celda por lo que se resta el valor de 2
                                            cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                            <td style="position: relative;">
                                                <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; background: black;"></div>
                                                <div style="position: absolute; top: 15px; left: 50%; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                                <div style="position: absolute; top: @($"{top}px"); left: 50%; width: 50%; overflow:hidden">
                                                    <div class="zig-zag-line"></div>
                                                </div>
                                            </td>
                                            top += 10;
                                        }
                                        else if (manualOperationTime > 0 && manualWithMachineTime == 0 && automaticMachineTime > 0 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                        {
                                            manualOperationTime = RoundToTwoDecimals(manualOperationTime - 0.01);
                                            automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.01);

                                            cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);

                                            <td style="position: relative;">
                                                <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; background: black;"></div>
                                                <div style="position: absolute; top: 15px; left: 50%; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                            </td>
                                        }

                                    }
                                    else // Línea completa
                                    {
                                        manualOperationTime = RoundToTwoDecimals(manualOperationTime - 0.02);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                        <td style="position: relative;">
                                            <div style="position: absolute; top: 15px; left: 0; width: 100%; height: 2px; background: black;"></div>
                                        </td>
                                    }
                                }
                                // Case 2: ManualOperationTimeWithMachineInAutomatic and AutomaticMachineOperationTime
                                else if (manualWithMachineTime >= 0.01 && automaticMachineTime >= 0.01 && cumulativeTime >= cellStart && cumulativeTime < cellEnd)
                                {
                                    if (manualWithMachineTime == 0.01 && automaticMachineTime == 0.01 && StepCurrentFragment > 0)
                                    {
                                        manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.01);
                                        StepCurrentFragment = RoundToTwoDecimals(StepCurrentFragment - 0.01);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                            <div style="position: absolute; top: 35px; left: 0; width: 50%; height: 2px; background: black;"></div>
                                            <div style="position: absolute; top: @($"{top}px"); width: 50%; overflow:hidden">
                                                <div class="zig-zag-line"></div>
                                            </div>
                                        </td>
                                        top += 10;
                                    }
                                    else if (manualWithMachineTime == 0.01 && automaticMachineTime == 0.01)
                                    {
                                        manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.01);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                            <div style="position: absolute; top: 35px; left: 0; width: 50%; height: 2px; background: black;"></div>
                                        </td>
                                    }
                                    else if (manualWithMachineTime > 0.01 && automaticMachineTime == 0.01)
                                    {
                                        manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.02);
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.01);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                            <div style="position: absolute; top: 35px; left: 0; width: 100%; height: 2px; background: black;"></div>
                                        </td>
                                    }
                                    else if (manualWithMachineTime == 0.01 && automaticMachineTime > 0.01 && StepCurrentFragment > 0)
                                    {
                                        manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);
                                        StepCurrentFragment = RoundToTwoDecimals(StepCurrentFragment - 0.01);
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.02);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 0; width: 100%; height: 2px; border-top: 2px dashed black;"></div>
                                            <div style="position: absolute; top: 35px; left: 0; width: 50%; height: 2px; background: black;"></div>
                                            <div style="position: absolute; top: @($"{top}px"); width: 50%; overflow:hidden">
                                                <div class="zig-zag-line"></div>
                                            </div>
                                        </td>
                                        top += 10;

                                    }
                                    else if (manualWithMachineTime == 0.01 && automaticMachineTime > 0.01)
                                    {
                                        manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.02);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 0; width: 100%; height: 2px; border-top: 2px dashed black;"></div>
                                            <div style="position: absolute; top: 35px; left: 0; width: 50%; height: 2px; background: black;"></div>
                                        </td>
                                    }
                                    else if (manualWithMachineTime > 0.01 && automaticMachineTime > 0.01)
                                    {
                                        manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.02);
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.02);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);


                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 0; width: 100%; height: 2px; border-top: 2px dashed black;"></div>
                                            <div style="position: absolute; top: 35px; left: 0; width: 100%; height: 2px; background: black;"></div>
                                        </td>
                                    }
                                }
                                // Case 3: Remaining AutomaticMachineOperationTime
                                else if (automaticMachineTime > 0 && cellStart >= cumulativeTime && cumulativeTime < cellEnd)
                                {
                                    if (automaticMachineTime >= 0.02 && StepCurrentFragment > 0.01)
                                    {
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.02);
                                        StepCurrentFragment = RoundToTwoDecimals(StepCurrentFragment - 0.02);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                        <td style=" position: relative; overflow: hidden">
                                            <div style="position: absolute; top: 15px; left: 0; width: 100%; height: 2px; border-top: 2px dashed black;"></div>
                                            <div style="position: absolute; top: @($"{top}px") ; left: -17px; width: 110%;">
                                                <div class="zig-zag-line"></div>
                                            </div>
                                        </td>
                                        top += 10;
                                    }
                                    else if (automaticMachineTime >= 0.02 && StepCurrentFragment == 0.01)
                                    {
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.02);
                                        StepCurrentFragment = RoundToTwoDecimals(StepCurrentFragment - 0.01);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);

                                        <td style=" position: relative; overflow: hidden">
                                            <div style="position: absolute; top: 15px; left: 0; width: 100%; height: 2px; border-top: 2px dashed black;"></div>
                                            <div style="position: absolute; top: @($"{top}px"); left: 0; width: 50%; overflow: hidden;">
                                                <div class="zig-zag-line"></div>
                                            </div>
                                        </td>
                                        top += 10;
                                    }
                                    else if (automaticMachineTime >= 0.02 && StepCurrentFragment == 0)
                                    {
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.02);

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 0; width: 100%; height: 2px; border-top: 2px dashed black;"></div>
                                        </td>
                                    }
                                    else if (automaticMachineTime == 0.01 && StepCurrentFragment == 0)
                                    {
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.02);

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                        </td>
                                    }
                                    else if (automaticMachineTime == 0.01 && StepCurrentFragment == 0.01)
                                    {
                                        automaticMachineTime = RoundToTwoDecimals(automaticMachineTime - 0.01);
                                        StepCurrentFragment = RoundToTwoDecimals(StepCurrentFragment - 0.01);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 15px; left: 0; width: 50%; height: 2px; border-top: 2px dashed black;"></div>
                                            <div style="position: absolute; top: @($"{top}px"); left: 0; width: 50%; overflow:hidden">
                                                <div class="zig-zag-line"></div>
                                            </div>
                                        </td>
                                        top += 10;
                                    }
                                }
                                //case 4: Remaining manualWithMachineTime
                                else if (manualWithMachineTime > 0 && cellStart >= cumulativeTime && cumulativeTime < cellEnd)
                                {
                                    if (manualWithMachineTime >= 0.02)
                                    {
                                        manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.02);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 35px; left: 0; width: 100%; height: 2px; background: black;"></div>
                                        </td>
                                    }
                                    else if (StepCurrentFragment > 0)
                                    {
                                        manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);
                                        StepCurrentFragment = RoundToTwoDecimals(StepCurrentFragment - 0.01);

                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 35px; left: 0; width: 50%; height: 2px; background: black;"></div>
                                            <div style="position: absolute; top: @($"{top}px"); width: 50%; overflow:hidden">
                                                <div class="zig-zag-line"></div>
                                            </div>
                                        </td>
                                        top += 10;
                                    }
                                    else
                                    {
                                        manualWithMachineTime = RoundToTwoDecimals(manualWithMachineTime - 0.01);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);

                                        <td style=" position: relative; ">
                                            <div style="position: absolute; top: 35px; left: 0; width: 50%; height: 2px; background: black;"></div>
                                        </td>
                                    }
                                }
                                //Case 5: Zig Zag Steps
                                else if (manualOperationTime == 0 && manualWithMachineTime == 0 && automaticMachineTime == 0 && StepCurrentFragment > 0 && cellStart >= cumulativeTime && cumulativeTime < cellEnd)
                                {

                                    if (StepCurrentFragment >= 0.02)
                                    {
                                        StepCurrentFragment = RoundToTwoDecimals(StepCurrentFragment - 0.02);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.02);

                                        <td style="position: relative; overflow:hidden">
                                            <div style="position: absolute; top: @($"{top}px") ; left: -17px; width: 110%;">
                                                <div class="zig-zag-line"></div>
                                            </div>
                                        </td>
                                        top += 10;
                                    }
                                    else
                                    {
                                        StepCurrentFragment = RoundToTwoDecimals(StepCurrentFragment - 0.01);
                                        cumulativeTime = RoundToTwoDecimals(cumulativeTime + 0.01);

                                        <td style="position: relative; overflow:hidden">
                                            <div style="position: absolute; top: @($"{top}px") ; left: 0; width: 50%; overflow: hidden;">
                                                <div class="zig-zag-line"></div>
                                            </div>
                                        </td>
                                        top += 10;
                                    }

                                }
                                // Case 6: Empty cell
                                else
                                {
                                    <td style=""></td>
                                }
                            }

                            cumulativeManualTime = RoundToTwoDecimals(cumulativeTime);
                        }

                    </tr>
                }


            }

            @if (_sosCombination.SOSCombinationOperationSequence.Count() < 11)
            {
                @for (int c = 0; c < 11 - _sosCombination.SOSCombinationOperationSequence.Count(); c++)
                {
                    <tr style="height: 65px;">
                        <td>
                        </td>
                        <td>
                        </td>
                        <td>
                        </td>
                        <td>
                        </td>
                        <td>
                        </td>
                        <td>
                        </td>
                        <td>
                        </td>
                        @for (int i = 0; i < 91; i++)
                        {
                            <td></td>
                        }
                    </tr>
                }
            }

        </tbody>
    </MudSimpleTable>
    <br />
