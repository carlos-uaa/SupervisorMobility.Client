                </MudTd>
                <MudTd>
                    <ul style="list-style-type:none; padding-left:0;">
                        @if (_sosCombination.Turns?.Any() ?? false)
                        {

                            @foreach (Turn turn in _sosCombination.Turns)
                            {

                                <li>@turn.Operator?.Name</li>
                            }
                        }
                    </ul>
                </MudTd>
                <MudTd>
                    <ul style="list-style-type:none; padding-left:0;">
                        @if (_sosCombination.Turns?.Any() ?? false)
                        {

