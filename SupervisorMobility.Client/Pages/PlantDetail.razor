@page "/plants/plant/{id:int}"
@inject IPlantService PlantService

@*Title*@
<PageTitle>Supervisor Mobility | @_plant.Description</PageTitle>

@*Dashboard grid*@
<MudGrid>
    @*Plant info*@
    <MudItem xs="12" sm="6" md="3">
        <CascadingValue Value="Id">
            <PlantInfo />
        </CascadingValue>
    </MudItem>
    @*Edit form*@
    <MudItem xs="12" sm="6" md="9">
        
    </MudItem>
</MudGrid>
