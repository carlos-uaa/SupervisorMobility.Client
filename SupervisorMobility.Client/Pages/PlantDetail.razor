@page "/plants/plant/{plantId:int}"
@inject IPlantService PlantService

@*Title*@
<PageTitle>Supervisor Mobility | @_plant.Description</PageTitle>

@*Dashboard grid*@
<MudGrid>
    @*Plant info*@
    <MudItem xs="12" sm="6" md="3">
        <CascadingValue Value="PlantId">
            <PlantInfo />
        </CascadingValue>
    </MudItem>
    @*Related areas*@
    <MudItem xs="12" sm="6" md="9">
        <CascadingValue Value="PlantId">
            <PlantAreas />
        </CascadingValue>
    </MudItem>
</MudGrid>
