@page "/documenttypes/createdoctype"
@inject NavigationManager NavigationManager

@*Title*@
<PageTitle>Supervisor Mobility | Create Document Type</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_documentType" OnValidSubmit="CreateDocTypeAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Doc type details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">New doc type</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="Doc type description"
                                  @bind-Value="_documentType.Description" For="@(() => _documentType.Description)" />
                    <MudTextField Label="Code" Class="mt-3"
                                  @bind-Value="_documentType.Code" For="@(() => _documentType.Code)" />
                    <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_documentType.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Href="/documenttypes" Variant="Variant.Filled" Class="ml-4">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>
