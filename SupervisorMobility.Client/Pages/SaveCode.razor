<h3>saveCode</h3>
@*
<MudTabPanel Text="Monthly" ID='"pn_2"' OnClick="@( () => MonthlyView = true)">
            <ChildContent>

                <MudSimpleTable Dense>
                    <tbody>
                        <tr>
                            <td>
                                <MudItem Class="d-flex justify-content-between mb-5" Style="align-items: center;">
                                    <MudText Typo="Typo.h6">@Localizer["sosDetails"] @SOS_Review.AplicationYear</MudText>
                                </MudItem>
                            </td>
                            <td colspan="2">
                                <MudItem Class="d-flex">
                                    <MudIcon Icon="@Icons.Material.Filled.BusinessCenter"> </MudIcon>
                                    <MudText Class="ml-2">@Localizer["area"]</MudText>
                                </MudItem>
                            </td>
                            <td colspan="2">
                                <MudItem Class="d-flex">
                                    <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
                                    <MudText Class="ml-2">@Localizer["plant"]</MudText>
                                </MudItem>
                            </td>
                        </tr>
                        <tr>
                            <td rowspan="2">
                                <MudDatePicker Label=@Localizer["monthYear"] MinDate="@(new DateTime((int)SOS_Review.AplicationYear, 1, 1))" MaxDate="@(new DateTime((int)SOS_Review.AplicationYear, 12, 31))" OpenTo="OpenTo.Month" FixDay="1" DateFormat="MMMM / yyyy" PickerVariant="PickerVariant.Dialog" Color="Color.Info" AdornmentColor="Color.Info" DateChanged=@OnDateChanged Date="_yearMonth" />
                            </td>
                            <td rowspan="2" colspan="2">
                                @SOS_Review.Area?.Description
                            </td>
                            <td rowspan="2" colspan="2">
                                @SOS_Review.Plant?.Description
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>


                <MudSimpleTable Striped=true Bordered=true Elevation="6" Class="calendar-table rounded">
                    <thead>
                        <tr style="cursor:default">
                            @for (var dayIndex = 0; dayIndex < days.Count(); dayIndex++)
                            {
                                <th style="text-align: center; width:14.28%">
                                    @days[dayIndex].ToString().ToUpper()
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (var weekIndex = 0; weekIndex < weeks.Count(); weekIndex++)
                        {
                            <tr>
                                @for (var dayIndex = 0; dayIndex < weeks[weekIndex].Dates.Count(); dayIndex++)
                                {
                                    var day = weeks[weekIndex].Dates[dayIndex].DayName;
                                    var wIndex = weekIndex;
                                    var dIndex = dayIndex;

                                    @if (weekIndex == 0 && (day == "31" || day == "30" || day == "29" || day == "28" || day == "27" || day == "26" || day == "25"))
                                    {
                                        <td style="text-align: end; width:14.28%;">
                                            <span style="color: #DDDDDD">@weeks[weekIndex].Dates[dayIndex].DayName</span>
                                            <div style="min-height: 16vh"></div>
                                        </td>
                                    }
                                    else
                                    {
                                        var date = @weeks[weekIndex].Dates[dayIndex].DateValue;

                                        var dayName = @weeks[weekIndex].Dates[dayIndex].DayName;

                                        var compare = DateTime.ParseExact(date, "d/M/yyyy", null);
                                        <td style="text-align: end; width:14.28%;">
                                            @if (CultureInfo.CurrentCulture.Name == "en-US" || CultureInfo.CurrentCulture.Name == "en")
                                            {
                                                var todayFormatedDay = DateTime.ParseExact(date, "d/M/yyyy", CultureInfo.InvariantCulture);
                                                var todayEnglish = todayFormatedDay.Month.ToString() + "/" + todayFormatedDay.Day.ToString() + "/" + todayFormatedDay.Year.ToString();

                                                @if (DateTime.Now.ToShortDateString() == todayEnglish)
                                                {
                                                    if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                                    {
                                                        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                                            <MudMenuItem Icon="@Icons.Material.Filled.PlaylistAdd">
                                                                @Localizer["programmedJobObservation"]
                                                            </MudMenuItem>
                                                            <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar">
                                                                @Localizer["planJobObservation"]
                                                            </MudMenuItem>
                                                            <MudMenuItem Icon="@Icons.Material.Filled.Add">
                                                                @Localizer["createJobObservation"]
                                                            </MudMenuItem>
                                                        </MudMenu>
                                                    }
                                                    else
                                                    {
                                                        <MudButton Color="Color.Info">@dayName</MudButton>
                                                    }
                                                }
                                                else
                                                {
                                                    if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                                    {
                                                        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName AnchorOrigin="Origin.BottomCenter">
                                                            <MudMenuItem Icon="@Icons.Material.Filled.PlaylistAdd">
                                                                @Localizer["programmedJobObservation"]
                                                            </MudMenuItem>
                                                            <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar">
                                                                @Localizer["planJobObservation"]
                                                            </MudMenuItem>
                                                            <MudMenuItem Icon="@Icons.Material.Filled.Add">
                                                                @Localizer["createJobObservation"]
                                                            </MudMenuItem>
                                                        </MudMenu>
                                                    }
                                                    else
                                                    {
                                                        <MudButton>@dayName</MudButton>
                                                    }
                                                }
                                            }
                                            else
                                            {
                                                @if (DateTime.Now.ToShortDateString() == date)
                                                {
                                                    if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                                    {

                                                        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                                            <MudMenuItem Icon="@Icons.Material.Filled.PlaylistAdd">
                                                                @Localizer["programmedJobObservation"]
                                                            </MudMenuItem>
                                                            <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar">
                                                                @Localizer["planJobObservation"]
                                                            </MudMenuItem>
                                                            <MudMenuItem Icon="@Icons.Material.Filled.Add">
                                                                @Localizer["createJobObservation"]
                                                            </MudMenuItem>
                                                        </MudMenu>
                                                    }
                                                    else
                                                    {
                                                        <MudButton Color="Color.Info">@dayName</MudButton>
                                                    }
                                                }
                                                else
                                                {
                                                    if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                                    {
                                                        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label=@dayName AnchorOrigin="Origin.BottomCenter">
                                                            <MudMenuItem Icon="@Icons.Material.Filled.PlaylistAdd">
                                                                @Localizer["programmedJobObservation"]
                                                            </MudMenuItem>
                                                            <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar">
                                                                @Localizer["planJobObservation"]
                                                            </MudMenuItem>
                                                            <MudMenuItem Icon="@Icons.Material.Filled.Add">
                                                                @Localizer["createJobObservation"]
                                                            </MudMenuItem>
                                                        </MudMenu>
                                                    }
                                                    else
                                                    {
                                                        <MudButton>@dayName</MudButton>
                                                    }
                                                }
                                            }
                                            <div style="min-height: 16vh; overflow-y: scroll; max-height: 16vh; scroll-behavior: smooth;" class="scroll scroll1">
                                                @foreach (var jobobs in _All_SOSJobobservation)
                                                {
                                                    var time1 = jobobs.StartDate?.ToString("HH:mm");
                                                    var time2 = jobobs.EndDate?.ToString("HH:mm");

                                                    if (Convert.ToDateTime(jobobs.StartDate?.ToShortDateString()).Date <= Convert.ToDateTime(compare.ToShortDateString()).Date && Convert.ToDateTime(compare.ToShortDateString()).Date <= Convert.ToDateTime(jobobs.EndDate?.ToShortDateString()).Date)
                                                    {
                                                        //Ends the same day
                                                        if (Convert.ToDateTime(compare.ToShortDateString()).Date == Convert.ToDateTime(jobobs.StartDate?.ToShortDateString()).Date && Convert.ToDateTime(compare.ToShortDateString()).Date == Convert.ToDateTime(jobobs.EndDate?.ToShortDateString()).Date)
                                                        {
                                                            //Status filter
                                                            switch (optionStatus)
                                                            {
                                                                case 0:

                                                                    //Planned
                                                                    if (jobobs.Status == 1)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Warning">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }
                                                                    //In Progress
                                                                    else if (jobobs.Status == 2)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Info">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.StopCircle" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }

                                                                    //Late job observations
                                                                    else if (jobobs.Status == 3)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Error">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }

                                                                    //Under Review job observations
                                                                    else if (jobobs.Status == 4)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Info">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.IncompleteCircle" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }

                                                                    //Rejected job observations
                                                                    else if (jobobs.Status == 5)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Error">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.Cancel" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }
                                                                    //Finalized
                                                                    else if (jobobs.Status == 6)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Success" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Success">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.Circle" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }

                                                                    break;
                                                                case 1:
                                                                    //Programmed
                                                                    if (jobobs.Status == 1)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Warning">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.PlayCircle" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }

                                                                    break;
                                                                case 2:
                                                                    //In Progress
                                                                    if (jobobs.Status == 2)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Info">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.StopCircle" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }
                                                                    break;
                                                                case 3:
                                                                    //Late job observations
                                                                    if (jobobs.Status == 3)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Error">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }
                                                                    break;
                                                                case 4:
                                                                    if (jobobs.Status == 4)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Info">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.IncompleteCircle" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }
                                                                    break;
                                                                case 5:
                                                                    if (jobobs.Status == 5)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Error">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.Cancel" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }
                                                                    break;
                                                                case 6:
                                                                    if (jobobs.Status == 6)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Success" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
                                                                            <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservationId))" Style="padding: 0px;" Color="Color.Success">
                                                                                <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="font-size: 10px">@time1 - @time2</MudChip>
                                                                                <MudIcon Icon="@Icons.Material.Filled.Circle" />
                                                                            </MudButton>
                                                                            <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservationId</span>.  @jobobs.Distribution?.Description</span>
                                                                        </MudTooltip>
                                                                    }
                                                                    break;

                                                            }

                                                        }
                                                        //lasts more than one day
                                                        else
                                                        {
                                                            switch (optionStatus)
                                                            {
                                                                case 0:
                                                                    //Programmed
                                                                    if (jobobs.Status == 1)
                                                                    {
                                                                        <MudTooltip Text="@jobobs.JobObservationId.ToString()" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservationId))">
