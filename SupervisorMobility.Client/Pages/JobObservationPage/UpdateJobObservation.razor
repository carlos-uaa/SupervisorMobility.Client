@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>
@* Job Observation Form*@
<EditForm Model="_jobObservation" OnValidSubmit="SaveProgressJobObservation">
    <DataAnnotationsValidator />
    <MudItem Style="text-align: end">

       

    </MudItem>
    <MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
        <MudItem lg="10" md="12" sm="12" xs="12">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">

                 <MudItem Class="d-flex justify-space-between pa-1 ma-1">
