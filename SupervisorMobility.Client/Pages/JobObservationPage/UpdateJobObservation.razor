@page "/jobobservation/updatejobobservation/{jobobservationId:int}"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using System.Globalization;
@using System.Net.Http.Json;

@inject IJSRuntime JSRuntime
@inject IGroupService GroupService
@inject IChecklistService ChecklistService
@inject IDialogService DialogService
@inject IPlantService PlantServices
@inject IProductService ProductService
@inject IAreaService AreaServices
@inject IDistributionService DistributionService
@inject IOperationService OperationService
@inject IJobObservationService JobObservationService
@inject IGlosaryService GlosaryService
@inject ILupService LupService
@inject ISnackbar Snackbar

@inject NavigationManager NavigationManager
@inject HttpClient httpClient

@*Title*@
<PageTitle>Supervisor Mobility | Job Observation</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>
@* Job Observation Form*@
<EditForm Model="_jobObservation" OnValidSubmit="EditJobObservation">
    <DataAnnotationsValidator />
    <MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
        <MudItem lg="10" md="12" sm="12" xs="12">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    Tarjeta de Observación de Operación Cíclica @_jobObservation.JobObservationId
                    <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">Eventual</MudChip>
                </MudText>
            </MudItem>
            <MudItem Class="ml-2">
                <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="@_jobObservation.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />
                <MudSimpleTable Dense="@dense" Hover="@hover" ReadOnly="@ronly"
                            HorizontalScrollbar="true">
                    <tbody>
                        <tr>
                            <td>
                                @*Mud select of Plants *@
                                <MudSelect T="int" Label="Plant" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.PlantId" For="@(() => _jobObservation.PlantId)" SelectedValuesChanged="ShowAreas">
                                    <MudSelectItem Disabled="true" Value="0">Select a Plant</MudSelectItem>
                                    @foreach (var type in _plants)
                                    {
                                        <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                    }
                                </MudSelect>
                            </td>
                            <td class="d-flex">
                                <MudDatePicker @bind-Date="_jobObservation.DateStart" Label="Fecha Inicio" Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4" />
                                <MudDatePicker @bind-Date="_jobObservation.DateEnd" Label="Fecha Termino" Color="Color.Info" AdornmentColor="Color.Info" MinDate="_jobObservation.DateStart"/>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*Mud select of Areas *@
                                <MudSelect T="int" Label="Area" Variant="Variant.Text" Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.AreaId" For="@(() => _jobObservation.AreaId)" SelectedValuesChanged="ShowDistributions">
                                    <MudSelectItem Disabled="true" Value="0">Select an Area</MudSelectItem>
                                    @foreach (var type in _areas)
                                    {
                                        <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                    }
                                </MudSelect>
                            </td>
                            <td class="d-flex">
                                <MudTimePicker Label="End hour" @bind-Time="startHour" Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4" />
                                <MudTimePicker Label="End hour" @bind-Time="endHour" Color="Color.Info" AdornmentColor="Color.Info" />
                            </td>
                        </tr>
                        <tr>
                            <td class="d-flex">
                                @*Mud select of Distribution *@
                                <MudSelect T="int" Label="Distribution" Variant="Variant.Text" Placeholder="Select a Distribution" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.DistributionId" For="@(() => _jobObservation.DistributionId)" SelectedValuesChanged="ShowOperations">
                                    <MudSelectItem Disabled="true" Value="0">Select a Distribution</MudSelectItem>
                                    @foreach (var type in _distributions)
                                    {
                                        <MudSelectItem Value="type.DistributionId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                    }
                                </MudSelect>
                                @*Mud select of Operations *@
                                <MudSelect T="int" Label="Operation" Variant="Variant.Text" Placeholder="Select an Operation" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperationId" For="@(() => _jobObservation.OperationId)">
                                    <MudSelectItem Disabled="true" Value="0">Select an Operation</MudSelectItem>
                                    @foreach (var type in _operations)
                                    {
                                        <MudSelectItem Value="type.OperationId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <div class="d-flex">
                                    <MudTextField T="string" @bind-Value="_jobObservation.Observer" Label="Observador" Class="mr-4" />
                                    <MudTextField T="string" @bind-Value="_jobObservation.Operator" Label="Operador" />
                                </div>
                            </td>
                        </tr>
                @*        <tr>
                            <td colspan="2">
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Planned Date
                                </MudText>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex">
                                    <MudDatePicker @bind-Date="_jobObservation.DateStart" Label="Fecha Inicio" Color="Color.Warning" AdornmentColor="Color.Warning" Class="mr-4" />
                                    <MudDatePicker @bind-Date="_jobObservation.DateEnd" Label="Fecha Termino" Color="Color.Warning" AdornmentColor="Color.Warning" MinDate="_jobObservation.DateStart" />
                                </div>
                            </td>
                            <td>
                                <div class="d-flex">
                                    <MudTimePicker Label="End hour" @bind-Time="startHour" Color="Color.Warning" AdornmentColor="Color.Warning" Class="mr-4" />
                                    <MudTimePicker Label="End hour" @bind-Time="endHour" Color="Color.Warning" AdornmentColor="Color.Warning" />
                                </div>
                            </td>
                        </tr>*@
                        <tr>
                            <td colspan="2" style="text-align: center;">
                                <MudRadioGroup @bind-SelectedOption="_jobObservation.Option" style="width:100%;">
                                <MudRadio Option="1" Color="Color.Info" Size="Size.Small">Verificar la Capacitación</MudRadio>
                                <MudRadio Option="2" Color="Color.Info" Size="Size.Small">Mantener y/o Mejorar el área de trabajo</MudRadio>
                                <MudRadio Option="3" Color="Color.Info" Size="Size.Small">Manejo de anomalía</MudRadio>
                                @if(_jobObservation.Option == 3)
                                {
                                        <MudTextField @bind-Value="_jobObservation.Anomaly" T="string" Label="Write the anomaly" Placeholder="Anomaly" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                }
                            </MudRadioGroup>

                            </td>
                        </tr>
                        <tr>
                            <td colspan="2">
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Justification to update
                                </MudText>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2">
                                <MudTextField T="string" @bind-Value="_jobObservation.Justification" Label="Justification" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" >
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Tiempo de la HOE
                                </MudText>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*<MudTimePicker Label="Minutes" Text="13:37" OpenTo="OpenTo.Minutes" />*@
                                <MudTextField T="string" @bind-Value="_jobObservation.Time1HOE" Label="Tiempo 1" Required="true" Variant="Variant.Outlined" RequiredError="Time is required!" Margin="Margin.Dense" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="_jobObservation.Time2HOE" Label="Tiempo 2" Required="true" Variant="Variant.Outlined" RequiredError="Time is required!" Margin="Margin.Dense" />
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem Class="ml-2">
                <MudSimpleTable Dense=true Style="overflow-x: auto;" Bordered=true Class="mt-6 mb-3">
                    <tbody>
                        <tr>
                            <td colspan="5">
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Modelo
                                </MudText>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*Mud select of Products *@
                                <MudSelect T="int" Label="Product 1" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[0]">
                                    <MudSelectItem Disabled="true" Value="0">Select a Product</MudSelectItem>
                                    @foreach (var type in _products)
                                    {
                                        <MudSelectItem Value="type.ProductId">@($"{type.Code}")</MudSelectItem>
                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 2" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[1]">
                                    <MudSelectItem Disabled="true" Value="0">Select a Product</MudSelectItem>
                                    @foreach (var type in _products)
                                    {
                                        <MudSelectItem Value="type.ProductId">@($"{type.Code}")</MudSelectItem>
                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 3" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[2]">
                                    <MudSelectItem Disabled="true" Value="0">Select a Product</MudSelectItem>
                                    @foreach (var type in _products)
                                    {
                                        <MudSelectItem Value="type.ProductId">@($"{type.Code}")</MudSelectItem>
                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 4" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[3]">
                                    <MudSelectItem Disabled="true" Value="0">Select a Product</MudSelectItem>
                                    @foreach (var type in _products)
                                    {
                                        <MudSelectItem Value="type.ProductId">@($"{type.Code}")</MudSelectItem>
                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 5" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[4]">
                                    <MudSelectItem Disabled="true" Value="0">Select a Product</MudSelectItem>
                                    @foreach (var type in _products)
                                    {
                                        <MudSelectItem Value="type.ProductId">@($"{type.Code}")</MudSelectItem>
                                    }
                                </MudSelect>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="5">
                                <MudText Style="text-align:center; font-weight:bold;" Class="mt-5">
                                    Tiempo ciclo
                                </MudText>
                                <MudItem Class="d-flex align-center">
                                    <MudToggleIconButton Toggled="@isRunning" ToggledChanged="OnTimerChanged" Color="Color.Info"
                                                         Icon="@Icons.Material.Filled.PlayArrow" ToggledIcon="@Icons.Material.Filled.Stop" ToggledColor="Color.Error" />

                                    <MudText>@elapsedTime</MudText>&nbsp; s
                                </MudItem>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="5">
                                <MudRadioGroup @bind-SelectedOption="opt">
                                    <MudRadio Option="1" Color="Color.Info" Size="Size.Small">Cicle 1</MudRadio>
                                    <MudRadio Option="2" Color="Color.Info" Size="Size.Small">Cicle 2</MudRadio>
                                    <MudRadio Option="3" Color="Color.Info" Size="Size.Small">Cicle 3</MudRadio>
                                    <MudRadio Option="4" Color="Color.Info" Size="Size.Small">Cicle 4</MudRadio>
                                    <MudRadio Option="5" Color="Color.Info" Size="Size.Small">Cicle 5</MudRadio>
                                </MudRadioGroup>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[0]" Label="Cicle 1" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="s" Adornment="Adornment.End" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[1]" Label="Cicle 2" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="s" Adornment="Adornment.End" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[2]" Label="Cicle 3" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="s" Adornment="Adornment.End" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[3]" Label="Cicle 4" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="s" Adornment="Adornment.End" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[4]" Label="Cicle 5" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="s" Adornment="Adornment.End" />
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem Class="ml-2">
                <MudSimpleTable Style="overflow-x: auto;" Dense=true Bordered=true Class="mt-6 mb-3">
                    <thead>
                        <tr>
                            <th>
                                <MudText Style="font-weight:bold;">
                                    Pilar
                                </MudText>
                            </th>
                            <th>
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Área de oportunidad detectada
                                </MudText>
                            </th>
                            <th style="width: 5%">
                                Add
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td width="10%">
                                @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("S"))
                                {
                                    Glosary word;
                                    word = _glosaryInfo["S"];
                                    <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                        <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                            <MudText>@word.Name</MudText>
                                        </MudBadge>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <span>S</span>
                                }
                            </td>
                            <td style="align-content: end">
                                <MudTextField T="string" @bind-Value="areaS" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2"/>
                            </td>
                            <td>
                                <MudTooltip Text="Add to Pillar S in LUP" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                    <MudIconButton @onclick="(() => AddLup(1))" Variant="Variant.Filled" Color="Color.Info" Icon="@Icons.Material.Filled.Add" Size="Size.Small"></MudIconButton>
                                </MudTooltip>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("Q"))
                                {
                                    Glosary word;
                                    word = _glosaryInfo["Q"];
                                    <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                        <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                            <MudText>@word.Name</MudText>
                                        </MudBadge>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <span>Q</span>
                                }
                            </td>
                            <td style="align-content: end">
                                <MudTextField T="string" @bind-Value="areaQ" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                            </td>
                            <td>
                                <MudTooltip Text="Add to Pillar Q in LUP" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                    <MudIconButton @onclick="(() => AddLup(2))" Variant="Variant.Filled" Color="Color.Info" Icon="@Icons.Material.Filled.Add" Size="Size.Small"></MudIconButton>
                                </MudTooltip>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                D
                            </td>
                            <td style="align-content: end">
                                <MudTextField T="string" @bind-Value="areaD" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                            </td>
                            <td>
                                <MudTooltip Text="Add to Pillar D in LUP" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                    <MudIconButton @onclick="(() => AddLup(3))" Variant="Variant.Filled" Color="Color.Info" Icon="@Icons.Material.Filled.Add" Size="Size.Small"></MudIconButton>
                                </MudTooltip>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                C
                            </td>
                            <td style="align-content: end">
                                <MudTextField T="string" @bind-Value="areaC" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                            </td>
                            <td>
                                <MudTooltip Text="Add to Pillar C in LUP" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                    <MudIconButton @onclick="(() => AddLup(4))" Variant="Variant.Filled" Color="Color.Info" Icon="@Icons.Material.Filled.Add" Size="Size.Small"></MudIconButton>
                                </MudTooltip>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                Otros
                            </td>
                            <td style="align-content: end">
                                <MudTextField T="string" @bind-Value="areaOther" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                            </td>
                            <td>
                                <MudTooltip Text="Add to Pillar Other in LUP" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                    <MudIconButton @onclick="(() => AddLup(5))" Variant="Variant.Filled" Color="Color.Info" Icon="@Icons.Material.Filled.Add" Size="Size.Small"></MudIconButton>
                                </MudTooltip>
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem Class="ml-2">
                <MudSimpleTable Style="overflow-x: auto;" Dense=true Bordered=true Class="mt-6 mb-6">
                    <tbody>
                        <tr>
                            <td colspan="2">
                                <MudSimpleTable Style="overflow-x: auto;" Dense=true Bordered=true Elevation="0">
                                    <thead>
                                        <tr>
                                            <th>
                                                <MudText Style="font-weight:bold;">
                                                    Pillar
                                                </MudText>
                                            </th>
                                            <th>
                                                <MudText Style="text-align:center; font-weight:bold;">
                                                    Improve / Activity Detected
                                                </MudText>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td width="10%">
                                                @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("S"))
                                                {
                                                    Glosary word;
                                                    word = _glosaryInfo["S"];
                                                    <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                                        <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                            <MudText>@word.Name</MudText>
                                                        </MudBadge>
                                                    </MudTooltip>
                                                }
                                                else
                                                {
                                                    <span>S</span>
                                                }
                                            </td>
                                            <td>
                                            @if(_lupJobObservations.Lup.Count > 0)
                                            {
                                                foreach (var lup in _lupJobObservations.Lup)
                                                {
                                                    if(lup.Pillar == 1){
                                                    <MudTooltip Text="@lup.LupId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true">
                                                        <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined" @onclick="(() => OpenDialog2(lup.LupId))">
                                                            <MudChip Color="Color.Info" OnClose="Closed" Size="Size.Small" CloseIcon="@Icons.Material.Filled.ChecklistRtl" Variant="Variant.Text" Style="cursor:pointer">
                                                                @if(lup.Oportunity.Length < 50)
                                                                {
                                                                    @lup.Oportunity
                                                                }
                                                                else{
                                                                    @lup.Oportunity.Substring(0,50) <span>...</span> 
                                                                }
                                                            </MudChip>
                                                                @if (lup.IsActive == true)
                                                                {
                                                                    <MudText>
                                                                        <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">Active</MudChip>
                                                                    </MudText>
                                                                }
                                                                else
                                                                {
                                                                    <MudText>
                                                                            <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small">Inactive Style="cursor:pointer"</MudChip>
                                                                    </MudText>
                                                                }
                                                            <MudTooltip Text="Delete Lup item" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" @onclick="(() => DeleteLup(lup.LupId))"></MudIconButton>
                                                            </MudTooltip>
                                                        </MudButton>
                                                    </MudTooltip>
                                                    
                                                    }
                                                }
                                            }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("Q"))
                                                {
                                                    Glosary word;
                                                    word = _glosaryInfo["Q"];
                                                    <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                                        <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                            <MudText>@word.Name</MudText>
                                                        </MudBadge>
                                                    </MudTooltip>
                                                }
                                                else
                                                {
                                                    <span>Q</span>
                                                }
                                            </td>
                                            <td>
                                            @if(_lupJobObservations.Lup.Count > 0)
                                            {
                                                foreach (var lup in _lupJobObservations.Lup)
                                                {
                                                    if(lup.Pillar == 2){
                                                    <MudTooltip Text="@lup.LupId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true">
                                                        <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined" @onclick="(() => OpenDialog2(lup.LupId))">
                                                            <MudChip Color="Color.Info" OnClose="Closed" Size="Size.Small" CloseIcon="@Icons.Material.Filled.ChecklistRtl" Variant="Variant.Text" Style="cursor:pointer">
                                                                @if(lup.Oportunity.Length < 50)
                                                                {
                                                                    @lup.Oportunity
                                                                }
                                                                else{
                                                                    @lup.Oportunity.Substring(0,50) <span>...</span> 
                                                                }
                                                            </MudChip>
                                                                @if (lup.IsActive == true)
                                                                {
                                                                    <MudText>
                                                                        <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">Active</MudChip>
                                                                    </MudText>
                                                                }
                                                                else
                                                                {
                                                                    <MudText>
                                                                            <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">Inactive</MudChip>
                                                                    </MudText>
                                                                }
                                                            <MudTooltip Text="Delete Lup item" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                                                <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" @onclick="(() => DeleteLup(lup.LupId))"></MudIconButton>
                                                            </MudTooltip>
                                                        </MudButton>
                                                    </MudTooltip>
                                                    
                                                    }
                                                }
                                            }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                D
                                            </td>
                                            <td>
                                            @if(_lupJobObservations.Lup.Count > 0)
                                            {
                                                foreach (var lup in _lupJobObservations.Lup)
                                                {
                                                    if(lup.Pillar == 3){
                                                    <MudTooltip Text="@lup.LupId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true">
                                                                <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined" @onclick="(() => OpenDialog2(lup.LupId))">
                                                                    <MudChip Color="Color.Info" OnClose="Closed" Size="Size.Small" CloseIcon="@Icons.Material.Filled.ChecklistRtl" Variant="Variant.Text" Style="cursor:pointer">
                                                                @if(lup.Oportunity.Length < 50)
                                                                {
                                                                    @lup.Oportunity
                                                                }
                                                                else{
                                                                    @lup.Oportunity.Substring(0,50) <span>...</span> 
                                                                }
                                                            </MudChip>
                                                                @if (lup.IsActive == true)
                                                                {
                                                                    <MudText>
                                                                            <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">Active</MudChip>
                                                                    </MudText>
                                                                }
                                                                else
                                                                {
                                                                    <MudText>
                                                                            <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">Inactive</MudChip>
                                                                    </MudText>
                                                                }
                                                            <MudTooltip Text="Delete Lup item" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" @onclick="(() => DeleteLup(lup.LupId))"></MudIconButton>
                                                            </MudTooltip>
                                                        </MudButton>
                                                    </MudTooltip>
                                                    
                                                    }
                                                }
                                            }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                C
                                            </td>
                                            <td >
                                            @if (_lupJobObservations.Lup.Count > 0)
                                            {
                                                foreach (var lup in _lupJobObservations.Lup)
                                                {
                                                    if (lup.Pillar == 4)
                                                    {
                                                        <MudTooltip Text="@lup.LupId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true">
                                                            <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined" @onclick="(() => OpenDialog2(lup.LupId))">
                                                                    <MudChip Color="Color.Info" OnClose="Closed" Size="Size.Small" CloseIcon="@Icons.Material.Filled.ChecklistRtl" Variant="Variant.Text" Style="cursor:pointer">
                                                                    @if (lup.Oportunity.Length < 50)
                                                                    {
                                                                        @lup.Oportunity
                                                                    }
                                                                    else
                                                                    {
                                                                        @lup.Oportunity.Substring(0,50) <span>...</span>
                                                                    }
                                                                </MudChip>
                                                                @if (lup.IsActive == true)
                                                                {
                                                                    <MudText>
                                                                            <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">Active</MudChip>
                                                                    </MudText>
                                                                }
                                                                else
                                                                {
                                                                    <MudText>
                                                                            <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">Inactive</MudChip>
                                                                    </MudText>
                                                                }
                                                                <MudTooltip Text="Delete Lup item" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                                                        <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" @onclick="(() => DeleteLup(lup.LupId))"></MudIconButton>
                                                                </MudTooltip>
                                                            </MudButton>
                                                        </MudTooltip>

                                                    }
                                                }
                                            }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                Otros
                                            </td>
                                            <td >
                                            @if(_lupJobObservations.Lup.Count > 0)
                                            {
                                                foreach (var lup in _lupJobObservations.Lup)
                                                {
                                                    if(lup.Pillar == 5){
                                                    <MudTooltip Text="@lup.LupId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true">
                                                        <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined" @onclick="(() => OpenDialog2(lup.LupId))">
                                                            <MudChip Color="Color.Info" OnClose="Closed" Size="Size.Small" CloseIcon="@Icons.Material.Filled.ChecklistRtl" Variant="Variant.Text" Style="cursor:pointer">
                                                                @if(lup.Oportunity.Length < 70)
                                                                {
                                                                    @lup.Oportunity
                                                                }
                                                                else{
                                                                    @lup.Oportunity.Substring(0,70) <span>...</span> 
                                                                }
                                                            </MudChip>
                                                                @if (lup.IsActive == true)
                                                                {
                                                                    <MudText>
                                                                        <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">Active</MudChip>
                                                                    </MudText>
                                                                }
                                                                else
                                                                {
                                                                    <MudText>
                                                                            <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">Inactive</MudChip>
                                                                    </MudText>
                                                                }
                                                            <MudTooltip Text="Delete Lup item" Color="Color.Error" Placement="Placement.Right" Arrow="true">
                                                                        <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" @onclick="(() => DeleteLup(lup.LupId))"></MudIconButton>
                                                            </MudTooltip>
                                                        </MudButton>
                                                    </MudTooltip>
                                                    
                                                    }
                                                }
                                            }
                                            </td>
                                        </tr>
                                    </tbody>
                                </MudSimpleTable>
                            </td>
                        </tr>
                        <tr>
                            <th colspan="2">
                                <MudText Style="text-align:center; font-weight:bold;">
                                    SSV Comentaries
                                </MudText>
                            </th>
                        </tr>
                        <tr>
                            <td colspan="2">
                                <MudTextField T="string" @bind-Value="_jobObservation.SsvCommentary" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                            </td>
                        </tr>
                        <th>
                            <MudText Style="text-align:center; font-weight:bold;">
                            Ideas de mejora y/o comentarios del Operador
                            </MudText>
                        </th>
                        <th>
                            <MudText Style="text-align:center; font-weight:bold;">
                            Firma del SSV
                            </MudText>
                        </th>
                        <tr>
                            <td>
                            <MudTextField T="string" @bind-Value="_jobObservation.OperatorCommentary" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="4" />
                            </td>
                            <td>
                            <MudTextField T="string" @bind-Value="_jobObservation.SsvSignature" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Firma del Operador
                                </MudText>
                            <MudTextField T="string" @bind-Value="_jobObservation.OperatorSignature" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>

            <MudCardActions>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">On Hold</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => FinalizeJobObservation())">Finalize</MudButton>
                <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelUpdateJobObservation())">Cancel</MudButton>
            </MudCardActions>
        </MudItem>
    </MudGrid>
</EditForm>


@*lup modal*@
<MudDialog DisableSidePadding="false" @bind-IsVisible="visible" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll">
            <SupervisorMobility.Client.Pages.LupPage.LupDetails LupId="lupId"></SupervisorMobility.Client.Pages.LupPage.LupDetails>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudIconButton @onclick="(() => EditLup(lupId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>
        <MudButton Color="Color.Info" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>