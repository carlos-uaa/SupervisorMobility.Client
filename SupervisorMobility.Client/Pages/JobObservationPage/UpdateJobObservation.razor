                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cycles[1]" Label=@Localizer["cycle2"] Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cycles[2]" Label=@Localizer["cycle3"] Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" />
                            </td>
