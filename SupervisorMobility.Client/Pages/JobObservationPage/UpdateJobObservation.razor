                        <tr>
                            <td >
                                @*Mud select of Operations *@
                                    <MudSelect T="int" Label=@Localizer["operation"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperationId" For="@(() => _jobObservation.OperationId)">
                                    <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnOperation"]</MudSelectItem>
                                    @foreach (var type in _operations)
                                    {
                                        <MudSelectItem Value="type.OperationId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                    }
                                </MudSelect>
                            </td>
                            <td>
@*                                <div class="d-flex">*@                                    
                                    

                                    @*Mud select for Operator *@
                                    <MudSelect T="int" Label=@Localizer["operator"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperatorId" For="@(() => _jobObservation.OperatorId)">
                                        <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnOperator"]</MudSelectItem>
                                        @foreach (var type in operatorUsers)
                                        {
                                            <MudSelectItem Value="type.UserId">@($"{type.Name}")</MudSelectItem>
                                        }
                                    </MudSelect>
@*                                </div>*@
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" style="text-align: center;">
                                <MudRadioGroup @bind-SelectedOption="_jobObservation.Option" style="width:100%;">
                                    <MudRadio Option="1" Color="Color.Info" Size="Size.Small">Verify training</MudRadio>
                                    <MudRadio Option="2" Color="Color.Info" Size="Size.Small">Maintain and/or improve the work area</MudRadio>
                                    <MudRadio Option="3" Color="Color.Info" Size="Size.Small">
                                        @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("Management of the anomaly"))
                                        {
                                            Glosary word;
                                                word = _glosaryInfo["Management of the anomaly"];
                                            <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                                <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                    <MudText>@Localizer["managementOfTheAnomaly"]</MudText>
                                                </MudBadge>
                                            </MudTooltip>
                                        }
                                        else
                                        {
                                            <span>@Localizer["managementOfTheAnomaly"]</span>
                                        }
                                    </MudRadio>
                                    @if (_jobObservation.Option == 3)
                                    {
                                            <MudTextField @bind-Value="_jobObservation.Anomaly" T="string" Label=@Localizer["writeTheAnomaly"] Placeholder=@Localizer["anomaly"] Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    }
                                </MudRadioGroup>

                            </td>
                        </tr>
                            @* @if(_jobObservation.Justification != "" && _jobObservation.Justification != null){
                            <tr>
                                <td colspan="2">
                                    <MudText Style="text-align:center; font-weight:bold;">
                                        New Date
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                      <MudDatePicker @bind-Date="plannedStartDate" Label="New Start Date" Color="Color.Primary" AdornmentColor="Color.Primary" Class="pt-2" ReadOnly />
                                    <MudTimePicker Label="New Start hour" @bind-Time="plannedStartHour" Color="Color.Primary" AdornmentColor="Color.Primary" Class="pt-2" ReadOnly/>
                                </td>                          
                                <td>
                                    <MudDatePicker @bind-Date="plannedEndDate" Label="New End Date" Color="Color.Primary" AdornmentColor="Color.Primary" MinDate="plannedStartDate" Class="pt-2" ReadOnly/>
                                    <MudTimePicker Label="New End hour" @bind-Time="plannedEndHour" Color="Color.Primary" AdornmentColor="Color.Primary" Class="pt-2" ReadOnly/>
                                </td>
                            </tr>*@
@*                            <tr>
                                <td colspan="2">
                                    <MudText Style="text-align:center; font-weight:bold;">
                                        Justification to update
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2">
                                        <MudTextField T="string" @bind-Value="_jobObservation.Justification" ReadOnly Label="Justification" Placeholder="Write down the justification if the date is changed."  Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </td>
                            </tr>
                        }*@
                        <tr>
                            <td colspan="2" style="text-align:center">
                                @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("HOE Time"))
                                {
                                    Glosary word;
                                        word = _glosaryInfo["HOE Time"];
                                    <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                        <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                            <MudText Style="text-align:center; font-weight:bold;">@Localizer["HOETime"]</MudText>
                                        </MudBadge>
                                    </MudTooltip>
                                }
                                else
                                {
                                        <span style="text-align:center; font-weight:bold;">@Localizer["HOETime"]</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*<MudTimePicker Label="Minutes" Text="13:37" OpenTo="OpenTo.Minutes" />*@
                                <MudTextField T="string" @bind-Value="_jobObservation.Time1HOE" Label=@Localizer["time1"] Required="true" Variant="Variant.Outlined" RequiredError="Time is required!" Margin="Margin.Dense" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="_jobObservation.Time2HOE" Label=@Localizer["time2"] Required="true" Variant="Variant.Outlined" RequiredError="Time is required!" Margin="Margin.Dense" />
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem Class="ml-2">
                <MudSimpleTable Dense=true Style="overflow-x: auto;" Bordered=true Class="mt-6 mb-3">
