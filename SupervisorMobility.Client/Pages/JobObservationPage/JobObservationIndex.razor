@page "/jobobservation"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using System.Globalization;
@using System.Net.Http.Json
@inject IJSRuntime JSRuntime
@inject IChecklistService ChecklistService
@inject NavigationManager NavigationManager

@inject HttpClient httpClient
@*Title*@
<PageTitle>Supervisor Mobility | Job Observation Index</PageTitle>

@*Form*@
<MudGrid Justify="Justify.Center">
    <MudItem lg="10" md="12" sm="12" xs="12">
        <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
            <MudText Typo="Typo.h6">Formato de Observación de Operación Cíclica</MudText>
        </MudItem>
        <MudPaper Class="d-flex align-center justify-center mud-width-full pa-4">
            <MudItem xs="12" sm="12" md="5" lg="5">
                <MudDatePicker For="@(() => model.Date)" Label="Fecha" Color="Color.Info" />
                <MudSelect Class="mt-4" @bind-Value="stringValue" Label="Área / Grupo" Placeholder="Please Select">
                    <MudSelectItem Value="@("T&C")">T&C</MudSelectItem>
                    <MudSelectItem Value="@("Paint")">Paint</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="12" md="2" lg="2">
                <MudStack Row=true Class="pa-4">
                    <MudRadioGroup T="int" Class="fs-1">
                        <MudRadio Option="1" Color="Color.Info" UnCheckedColor="Color.Default" Size="Size.Small">Plan</MudRadio>
                        <MudRadio Option="2" Color="Color.Info" UnCheckedColor="Color.Default" Size="Size.Small">Eventual</MudRadio>
                    </MudRadioGroup>
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="12" md="5" lg="5">
                <MudTextField T="string" Label="Observador" Required="true" RequiredError="User name is required!" OnlyValidateIfDirty="true" />
                <div class="d-flex">
                    <MudItem xs="12" sm="6" Class="mr-4 mt-4">
                        <MudSelect @bind-Value="stringValue" Label="Estación" Placeholder="Please Select">
                            <MudSelectItem Value="@("T&C")">T&C</MudSelectItem>
                            <MudSelectItem Value="@("Paint")">Paint</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" Class="mt-4">
                        <MudSelect @bind-Value="stringValue" Label="Operador" Placeholder="Please Select">
                            <MudSelectItem Value="@("T&C")" Disabled="true">T&C</MudSelectItem>
                            <MudSelectItem Value="@("Paint")">Paint</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </div>
            </MudItem>
        </MudPaper>
    </MudItem>
</MudGrid>



@*Breadcrumb links*@
<MudBreadcrumbs Items="_items" Separator=">">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled" @onclick="(() => ShowCategory(item.Text))">
            @item.Text
        </MudButton>
    </ItemTemplate>
</MudBreadcrumbs>
@*Checklist categories table*@
@*
<MudTable Items="_checklistCategories" Hover="true" T="ChecklistCategory">
        <HeaderContent>
        <MudTh>
            <MudText Align="Align.Center">Category Id</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Description</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Status</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="CategoryId">
            <MudText Align="Align.Center">@context.ChecklistCategoryId</MudText>
        </MudTd>
        <MudTd DataLabel="Description">
            <MudText Align="Align.Center">@context.Description</MudText>
        </MudTd>
        <MudTd DataLabel="Status">
            @if (context.IsActive == true)
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                </MudText>
            }
            else
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                </MudText>
            }
        </MudTd>
    </RowTemplate>
</MudTable>
*@
