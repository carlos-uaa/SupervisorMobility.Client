@page "/jobobservation/planjobobservation/{date}"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using System.Globalization;
@using System.Net.Http.Json;

@inject IJSRuntime JSRuntime
@inject IJSRuntime JS
@inject IGroupService GroupService
@inject IChecklistService ChecklistService
@inject IDialogService DialogService
@inject IProductService ProductService
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionService
@inject IOperationService OperationService
@inject IJobObservationService JobObservationService
@inject IGlosaryService GlosaryService
@inject ILupService LupService
@inject ISnackbar Snackbar
@inject IUserService UsersService
@inject IAssyChartService AssychartsServices
@inject IBridgeCDMSService CDMSServices
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager

@*Title*@
<PageTitle>Supervisor Mobility |  @Localizer["jobObservations"]</PageTitle>
<div style="display: flex; align-items: center; justify-content: space-between;">
    <MudItem>
        <MudBreadcrumbs Items="_links">
            <ItemTemplate Context="item">
                <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
            </ItemTemplate>
        </MudBreadcrumbs>
    </MudItem>
    <MudItem Style="text-align: end">
        <MudButton @onclick="(() => OpenDialogPastJobObservations())" Class="ml-4" Style="float:right" Variant="Variant.Filled" Color="Color.Info" Size="Size.Small" StartIcon="@Icons.Material.Filled.AccessTime"> @Localizer["pastJobObservationLup"]</MudButton>
    </MudItem>
</div>

@* Job Observation Form*@
<EditForm Model="_jobObservation" OnValidSubmit="PlanNewJobObservation">
    <DataAnnotationsValidator />

    <MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
    <MudItem lg="10" md="12" sm="12" xs="12">

            <MudItem Class="d-flex justify-space-between pa-1 ma-1 mt-6">
                <MudItem Style="text-align: start">
                    @if (_assycharts?.Count() > 0)
                    {
                        <MudItem Class="d-flex flex-row align-start justify-center">

                            <MudMenu Dense=true MaxHeight="300" ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter" DisableElevation>
                                <ActivatorContent>
                                    <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">Show AssyCharts</MudButton>
                                </ActivatorContent>
                                <ChildContent>
                                    <MudExpansionPanels Elevation="0">
                                        @foreach (AssyChart _assychart in _assycharts)
                                        {

                                            <MudExpansionPanel Text="@_assychart.Operation?.Description" >
                                                <MudItem class="d-flex flex-column justify-center ma-1">
                                                    <MudItem class="d-flex d-flex-column justify-center">

                                                        @if (@_assychart.GOS != "")
                                                        {
                                                            <MudPaper Elevation="0">
                                                                <MudButton @onclick="(() => OpenDialogGOS(_assychart.GOS))" @ontouchstart="(() => OpenDialogGOS(_assychart.GOS))" Style="padding: 0px;" Color="Color.Error">
                                                                    <MudTooltip Text=@Localizer["openGOSFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogGOS(_assychart.GOS))" @ontouchstart="(() => OpenDialogGOS(_assychart.GOS))">
                                                                        <MudTooltip Text="@_assychart.GOS" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true">
                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@_assychart.GOS.Split('/').Last()</MudChip>
                                                                        </MudTooltip>
                                                                    </MudTooltip>
                                                                </MudButton>

                                                            </MudPaper>
                                                        }
                                                        else
                                                        {
                                                            <MudPaper Elevation="0">

                                                                <MudAlert Severity="Severity.Info">@Localizer["noGOSPath"]</MudAlert>
                                                            </MudPaper>
                                                        }

                                                        @if (@_assychart.CCP != "")
                                                        {
                                                            <MudPaper Elevation="0">
                                                                <MudButton @onclick="(() => OpenDialogCcp(_assychart.CCP))" @ontouchstart="(() => OpenDialogCcp(_assychart.CCP))" Style="padding: 0px;" Color="Color.Error">
                                                                    <MudTooltip Text=@Localizer["openCCPFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogCcp(_assychart.CCP))" @ontouchstart="(() => OpenDialogCcp(_assychart.CCP))">
                                                                        <MudTooltip Text="@_assychart.CCP" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true">
                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@_assychart.CCP.Split('/').Last()</MudChip>
                                                                        </MudTooltip>
                                                                    </MudTooltip>
                                                                </MudButton>
                                                            </MudPaper>
                                                        }
                                                        else
                                                        {
                                                            <MudPaper Elevation="0">
                                                                <MudAlert Severity="Severity.Info">@Localizer["noCCPPath"]</MudAlert>
                                                            </MudPaper>
                                                        }

                                                        @if (_assychart.HOE != "")
                                                        {
                                                            <MudPaper Elevation="0">
                                                                <MudButton @onclick="(() => OpenDialogHoe(_assychart.HOE))" @ontouchstart="(() => OpenDialogHoe(_assychart.HOE))" Style="padding: 0px;" Color="Color.Error">
                                                                    <MudTooltip Text=@Localizer["openHOEFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogHoe(_assychart.HOE))" @ontouchstart="(() => OpenDialogHoe(_assychart.HOE))">
                                                                        <MudTooltip Text="@_assychart.HOE.Replace('§',' ')" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true">
                                                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@_assychart.HOE.Split('§').Last()</MudChip>
                                                                        </MudTooltip>
                                                                    </MudTooltip>
                                                                </MudButton>
                                                            </MudPaper>
                                                        }
                                                        else
                                                        {
                                                            <MudPaper Elevation="0">
                                                                <MudAlert Severity="Severity.Info">@Localizer["noHOEPath"]</MudAlert>
                                                            </MudPaper>
                                                        }

                                                    </MudItem>
                                                </MudItem>
                                            </MudExpansionPanel>
                                        }


                                    </MudExpansionPanels>
                                </ChildContent>
                            </MudMenu>


                        </MudItem>
                    }
                    else
                    {
                        @if (_jobObservation.PlantId == 0 && _assycharts is null)
                        {
                            <MudPaper Elevation="0">
                                @Localizer["firstSelectAPlant"]
                            </MudPaper>
                        }
                        @if (_jobObservation.AreaId == 0 && _assycharts is null)
                        {
                                <MudPaper Elevation="0">
                                @Localizer["firstSelectAnArea"]
                            </MudPaper>
                        }
                        @if (_jobObservation.DistributionId == 0 && _assycharts is null)
                        {
                                <MudPaper Elevation="0">
                                @Localizer["selectADistributionFirst"]
                            </MudPaper>
                        }


                        @if (_assycharts != null && _assycharts?.Count() == 0)
                        {
                            <MudItem class="d-flex flex-column justify-center align-self-start">
                                <MudPaper Elevation="0">
                                    <MudText Typo="Typo.h6" Class="align-item-center center">No AssyCharts Found</MudText>
                                </MudPaper>
                            </MudItem>
                        }
                        else
                        {
                            @if (_jobObservation.PlantId != 0 && _jobObservation.AreaId != 0 && _jobObservation.DistributionId != 0)
                            {
                                <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
                            }
                        }


                    }

                </MudItem>

            </MudItem>

        <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                        <MudText Typo="Typo.h6">
                    @Localizer["jobObservacionCiclycalCard"]
                <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">@Localizer["planned"]</MudChip>
            </MudText>
        </MudItem>
            <MudItem Class="ml-2">
            @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="@_jobObservation.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                <MudSimpleTable Style="overflow-x: auto;" Dense=true Class="pt-3 pb-3">
                    <tbody>
                        <tr>
                            <td style="width:50%">
                                <div class="d-flex">
                                    @if(user.UserType == 1){
                                        @*Mud select for Plants for Admin*@
                                        <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.PlantId" For="@(() => _jobObservation.PlantId)" SelectedValuesChanged="ShowAreas">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAPlant"]</MudSelectItem>
                                            @foreach (var type in _plants)
                                            {
                                                <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else{
                                        @*Mud select for Plants *@
                                        <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.PlantId" For="@(() => _jobObservation.PlantId)" SelectedValuesChanged="ShowAreas">
                                            @foreach (var type in _plants)
                                            {
                                                if(type.PlantId == user.PlantId){
                                                    <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                                }
                                            }
                                        </MudSelect>
                                    }

                                    @if (_jobObservation.PlantId != 0 && user.UserType == 1)
                                    {
                                        @*Mud select for Areas for Admin *@
                                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.AreaId" For="@(() => _jobObservation.AreaId)" SelectedValuesChanged="ShowDistributions">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnArea"]</MudSelectItem>
                                            @foreach (var type in _areas)
                                            {
                                                <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else if (_jobObservation.PlantId != 0 && user.UserType == 2)
                                    {
                                        @*Mud select for Areas for SSV *@
                                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.AreaId" For="@(() => _jobObservation.AreaId)" SelectedValuesChanged="ShowDistributions">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnArea"]</MudSelectItem>
                                            @foreach (var type in user.Areas)
                                            {
                                                <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else if (_jobObservation.PlantId != 0)
                                    {
                                        @*Mud select for Areas for SV *@
                                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.AreaId" For="@(() => _jobObservation.AreaId)" SelectedValuesChanged="ShowDistributions">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnArea"]</MudSelectItem>
                                            @foreach (var type in _areas)
                                            {
                                                if (type.AreaId == user.AreaId)
                                                {
                                                    <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                                }
                                            }
                                        </MudSelect>
                                    }
                                    else
                                    {
                                        @*Mud select for Areas *@
                                        <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Disabled Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.AreaId" For="@(() => _jobObservation.AreaId)" SelectedValuesChanged="ShowDistributions">
                                            <MudSelectItem Disabled="true" Value="0"> @Localizer["firstSelectAPlant"]</MudSelectItem>
                                        </MudSelect>
                                    }
                                </div>
                            </td>
                            <td class="d-flex">
                                <MudDatePicker @bind-Date="_jobObservation.StartDate" PickerVariant="PickerVariant.Dialog" Label=@Localizer["startDate"] Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4 pt-2" />
                                <MudDatePicker @bind-Date="_jobObservation.EndDate" PickerVariant="PickerVariant.Dialog" Label=@Localizer["endDate"] Color="Color.Info" AdornmentColor="Color.Info" MinDate="_jobObservation.StartDate" Class="pt-2" />
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*Mud select for Distribution *@
                                @if (_jobObservation.AreaId != 0)
                                {
                                    <MudSelect T="int" Label=@Localizer["distribution"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.DistributionId" For="@(() => _jobObservation.DistributionId)" SelectedValuesChanged="ShowOperations">
                                        <MudSelectItem Disabled="true" Value="0"> @Localizer["selectADistribution"]</MudSelectItem>
                                        @foreach (var type in _distributions)
                                        {
                                            <MudSelectItem Value="type.DistributionId">@(
                                         $"{type.Code} - {type.Description}"
                                         )</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    <MudSelect T="int" Label=@Localizer["distribution"] Disabled Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.DistributionId" For="@(() => _jobObservation.DistributionId)" SelectedValuesChanged="ShowOperations">
                                        <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnArea"]</MudSelectItem>
                                    </MudSelect>                                   
                                }
                            </td>
                            <td>
                                @if(user.UserType == 1)
                                {
                                    @if (_jobObservation.AreaId != 0)
                                    {
                                        @if(_supervisors.Count > 0){
                                            <MudSelect T="int" Label="Supervisor" Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.SupervisorId" For="@(() => _jobObservation.SupervisorId)" SelectedValuesChanged="ShowOperators">
                                                <MudSelectItem Disabled="true" Value="0"> @Localizer["selectASupervisor"]</MudSelectItem>
                                                @foreach (var type in _supervisors)
                                                {
                                                    <MudSelectItem Value="type.UserId">
                                                        @type.Name
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        }
                                        else
                                        {
                                            <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                                                @Localizer["thisAreaDoesNotHaveSupervisors"]
                                            </MudAlert>
                                        }
                                    }
                                    else
                                    {
                                        <MudSelect T="int" Label="Supervisor" Disabled Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.SupervisorId" For="@(() => _jobObservation.SupervisorId)" SelectedValuesChanged="ShowOperators">
                                            <MudSelectItem Disabled="true" Value="0"> @Localizer["firstSelectAnArea"]</MudSelectItem>
                                        </MudSelect>
                                    }

                                }
                                else if(user.UserType == 2){
                                    @if (_jobObservation.AreaId != 0)
                                    {
                                        @if (_supervisors.Count > 0)
                                        {
                                            <MudSelect T="int" Label="Supervisor" Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.SupervisorId" For="@(() => _jobObservation.SupervisorId)" SelectedValuesChanged="ShowOperators">
                                                <MudSelectItem Disabled="true" Value="0">@Localizer["selectASupervisor"]</MudSelectItem>
                                                @foreach (var type in _supervisors)
                                                {
                                                    <MudSelectItem Value="type.UserId">
                                                        @type.Name
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        }
                                        else
                                        {
                                            <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                                                @Localizer["thisAreaDoesNotHaveSupervisors"]
                                            </MudAlert>
                                        }
                                    }
                                    else
                                    {
                                        <MudSelect T="int" Label="Supervisor" Disabled Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.SupervisorId" For="@(() => _jobObservation.SupervisorId)" SelectedValuesChanged="ShowOperators">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["firstSelectAnArea"]</MudSelectItem>
                                        </MudSelect>
                                    }
                                }
                                else if(user.UserType == 3){
                                    <MudTextField T="string" @bind-Value="_jobObservation.Supervisor.Name" Label="Supervisor" Class="mr-4" ReadOnly />

                                }
@*                                <MudTimePicker Label="Start hour" @bind-Time="startHour" Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4 pt-2" />
                                <MudTimePicker Label="End hour" @bind-Time="endHour" Color="Color.Info" AdornmentColor="Color.Info" Class="pt-2" />*@
                            </td>
                        </tr>
                        <tr>
                            <td>

                                @if(_jobObservation.DistributionId != 0){
                                    @*Mud select for Operation *@
                                    <MudSelect T="int" Label=@Localizer["operation"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperationId" For="@(() => _jobObservation.OperationId)" SelectedValuesChanged="ShowPastJobObservations">
                                        <MudSelectItem Disabled="true" Value="0"> @Localizer["selectAnOperation"]</MudSelectItem>
                                        @foreach (var type in _operations)
                                        {
                                            <MudSelectItem Value="type.OperationId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    @*Mud select for Operation *@
                                    <MudSelect T="int" Label=@Localizer["operation"] Disabled Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperationId" For="@(() => _jobObservation.OperationId)" SelectedValuesChanged="ShowPastJobObservations">
                                        <MudSelectItem Disabled="true" Value="0">@Localizer["selectADistributionFirst"]</MudSelectItem>
                                    </MudSelect>
                                }
                            </td>
                            <td>
            @*                    <div class="d-flex">
                                    <MudTextField T="string" @bind-Value="_jobObservation.Supervisor.Name" Label="Observador" Class="mr-4"/>
*@  
                                @if (_jobObservation.SupervisorId != 0)
                                {
                                    @if (operatorUsers.Count > 0)
                                    {
                                        @*Mud select for Operator *@
                                        <MudSelect T="int" Label=@Localizer["operator"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperatorId" For="@(() => _jobObservation.OperatorId)">
                                            <MudSelectItem Disabled="true" Value="0"> @Localizer["selectAnOperator"]</MudSelectItem>
                                                @foreach (var type in operatorUsers)
                                                {
                                                    <MudSelectItem Value="type.UserId">@($"{type.Name}")</MudSelectItem>
                                                }
                                        </MudSelect>

                                    }
                                    else{
                                        <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                                            @Localizer["thisSupervisorDoesNotHaveOperators"]
                                        </MudAlert>
                                    }

                                }
                                else
                                {
                                    @*Mud select for Operator *@
                                    <MudSelect T="int" Label=@Localizer["operator"] Variant="Variant.Text" Disabled AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperatorId" For="@(() => _jobObservation.OperatorId)">
                                        <MudSelectItem Disabled="true" Value="0"> @Localizer["firstSelectASupervisor"]</MudSelectItem>
                                    </MudSelect>
                                }
   @*                                 <MudTextField T="string" @bind-Value="_jobObservation.Operator" Label="Operador" />
                                    <MudText Color="Color.Error" Style="font-size:12px"><ValidationMessage For="@(() => _jobObservation.Operator)" /></MudText>*@
                                @*</div>*@
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" style="text-align: center;">
                                <MudRadioGroup @bind-SelectedOption="_jobObservation.Option" Style="width:100%;">
                                            <MudRadio Option="1" Color="Color.Info" Size="Size.Small" >@Localizer["verifyTraining"]</MudRadio>
                                            <MudRadio Option="2" Color="Color.Info" Size="Size.Small" >@Localizer["mantainAndOrImproveTheWorkArea"]</MudRadio>
                                            <MudRadio Option="3" Color="Color.Info" Size="Size.Small">
                                                @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("Management of the anomaly"))
                                                {
                                                    Glosary word;
                                                    word = _glosaryInfo["Management of the anomaly"];
                                                    <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                                        <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                            <MudText>@Localizer["managementOfTheAnomaly"]</MudText>
                                                        </MudBadge>
                                                    </MudTooltip>
                                                }
                                                else
                                                {
                                                    <span>@Localizer["managementOfTheAnomaly"]</span>
                                                }
                                            </MudRadio>
                                        @if(_jobObservation.Option == 3)
                                        {
                                                <MudTextField T="string" @bind-Value="_jobObservation.Anomaly" Label=@Localizer["writeTheAnomaly"] Placeholder=@Localizer["anomaly"] Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                        }
                                </MudRadioGroup>
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudCardActions Class="mt-7">
                <MudButton ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.PlayCircle" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["planJobObservation"]</MudButton>
                <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateJobObservation())">@Localizer["cancel"]</MudButton>
            </MudCardActions>
    </MudItem>
</MudGrid>
</EditForm>

@*Past modal*@
<MudDialog DisableSidePadding="false" @bind-IsVisible="visiblePast" Options="dialogPastJobObservations">
    <DialogContent>
        <MudContainer Style="max-height: 75vh; min-height:50vh; overflow-y: scroll">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    @Localizer["pastJobObservationLup"]
                </MudText>
                <MudText>
                    <MudChip Color="Color.Info" Variant="Variant.Text">@distribution.Description</MudChip>
                    <MudChip Color="Color.Info" Variant="Variant.Text">@operation.Description</MudChip>

                </MudText>
            </MudItem>
            @if (pastjobObservations.Count > 0)
            {
                <MudTable Items="pastjobObservations" T="JobObservation" Bordered Class="mt-3 past-jobObservations-table mb-10">
                    <HeaderContent>
                        <MudTh style="text-align: center">
                            <MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.JobObservationId)">Id</MudTableSortLabel>
                        </MudTh>
                        <MudTh style="text-align: center"><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.StartDate)">@Localizer["startDate"]</MudTableSortLabel></MudTh>
                        <MudTh style="text-align: center; width: 65%">@Localizer["totalLup"]</MudTh>
                        <MudTh style="text-align: center"><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Status)">@Localizer["status"]</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudTooltip Text=@Localizer["goToJobObservation"] Arrow="true" Placement="Placement.Right" Color="Color.Info">
                                <MudChip Variant="Variant.Text" Color="Color.Info" Size="Size.Small" @onclick="(() => GoToJobObservation(context.JobObservationId))"> @context.JobObservationId</MudChip>
                            </MudTooltip>
                        </MudTd>
                        <MudTd>
                            <MudText>@context.StartDate?.ToShortDateString()</MudText>
                        </MudTd>
                        <MudTd>
                            <MudText>
                                @if (pastLup.Count > 0)
                                {
                                    @foreach (var lup in pastLup)
                                    {
                                        if (lup.JobObservationId == context.JobObservationId)
                                        {
                                            <MudTooltip Text="@lup.LupId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true">
                                                <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined" @onclick="(() => OpenDialogLup(lup.LupId))">
                                                    <MudChip Color="Color.Info" OnClose="Closed" Size="Size.Small" CloseIcon="@Icons.Material.Filled.ChecklistRtl" Variant="Variant.Text" Style="cursor:pointer">
                                                        @switch (lup.Pillar)
                                                        {
                                                            case 1:
                                                                <span>S | &nbsp;</span>
                                                                break;
                                                            case 2:
                                                                <span>Q | &nbsp;</span>
                                                                break;
                                                            case 3:
                                                                <span>D | &nbsp;</span>
                                                                break;
                                                            case 4:
                                                                <span>C | &nbsp;</span>
                                                                break;
                                                            case 5:
                                                                <span>@Localizer["other"] | &nbsp;</span>
                                                                break;
                                                        }
                                                        @if (lup.Oportunity.Length < 70)
                                                        {
                                                            @lup.Oportunity
                                                        }
                                                        else
                                                        {
                                                            @lup.Oportunity.Substring(0,70) <span>...</span>
                                                        }
                                                    </MudChip>
                                                    @switch (lup.Status)
                                                    {
                                                        case 1:
                                                            <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small">@Localizer["new"]</MudChip>
                                                            break;
                                                        case 2:
                                                            <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small">@Localizer["inProgress"]</MudChip>
                                                            break;
                                                        case 3:
                                                            <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["finished"]</MudChip>
                                                            break;
                                                        case 4:
                                                            <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small">@Localizer["canceled"]</MudChip>
                                                            break;
                                                    }
                                                </MudButton>
                                            </MudTooltip>
                                        }
                                    }
                                }
                            </MudText>
                        </MudTd>
                        <MudTd>
                            <MudText>

                                @switch (context.Status)
                                {
                                    case 1:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">@Localizer["planned"]</MudChip>
                                        break;
                                    case 2:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Size="Size.Small" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                        break;
                                    case 3:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                        break;
                                    case 4:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                        break;
                                    case 5:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                        break;
                                    case 6:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                        break;
                                }
                            </MudText>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudItem Style="text-align: center; margin-top: 100px">
                    <MudText Typo="Typo.h6">
                        @Localizer["thereAreNoPastJobObservations"]
                    </MudText>
                </MudItem>
            }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="CloseOverdue">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>



