@page "/jobobservation/history/{jobobservationId:int}"
@inject IJobObservationService JobObservationServices


@*Title*@
<PageTitle>Supervisor Mobility | Job Observation History</PageTitle>

<MudBreadcrumbs Class="mb-5" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@if (_jobChangesList.Count > 0)
{
    <MudTable Items="_jobChangesList" T="JobObservationVersion" Filter="new Func<JobObservationVersion,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true Height="400px"
          HorizontalScrollbar="true">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Job Observation History</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            <MudSpacer />

        </ToolBarContent>
      
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<JobObservationVersion, object>(x=>x.JobObservationVersionId)">Id</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<JobObservationVersion, object>(x=>x?.MadeBy)">ChangedBy</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<JobObservationVersion, object>(x=>x?.resumeVersion)">The following properties were changed</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<JobObservationVersion, object>(x=>x?.Distribution?.Description)">Distribution</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<JobObservationVersion, object>(x=>x?.Operation?.Description)">Operation</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<JobObservationVersion, object>(x=>x?.Operator?.Name)">Operator</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<JobObservationVersion, object>(x=>x?.Status)">Status</MudTableSortLabel></MudTh>
            <MudTh Style="text-align: center">Actions</MudTh>
        </HeaderContent>
        <GroupHeaderTemplate>

        </GroupHeaderTemplate>
        <RowTemplate>
            <MudTd DataLabel="Version Id">
                <MudText Align="Align.Center">@context.JobObservationVersionId</MudText>
            </MudTd>
            <MudTd DataLabel="Resume">
                <MudText Align="Align.Center">@context.MadeBy</MudText>
            </MudTd> <MudTd DataLabel="Resume">
                <MudText Align="Align.Center">@context.resumeVersion</MudText>
            </MudTd>
            <MudTd DataLabel="Distribution">
                <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Operation">
                <MudText Align="Align.Center">@context.Operation?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Operator">
                <MudText Align="Align.Center">@context.Operator?.Name</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudText Align="Align.Center">
                    @switch (context.Status)
                    {
                        case 1:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">Planned</MudChip>
                            break;
                        case 2:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Size="Size.Small" Style="cursor:pointer">In Progress</MudChip>
                            break;
                        case 3:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">Late</MudChip>
                            break;
                        case 4:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">Finished</MudChip>
                            break;
                    }
                </MudText>
            </MudTd>
            <MudTd>
                <MudText Align="Align.Center">
                  @*  <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => OpenDialog2(context.JobObservationId))"></MudIconButton>
                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => EditJobObservation(context.JobObservationId))"></MudIconButton>
                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => DeleteJobObservation(context.JobObservationId))"></MudIconButton>
                *@
                </MudText>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}
else
{
    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">There are still no planned job observations History now.</MudText>
}



@code {
    [Parameter]
    public int jobobservationId { get; set; }

    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "#"),
            new BreadcrumbItem("Job Observation", href: "/jobobservation"),
            new BreadcrumbItem("History of Changes", href: "", disabled: true),
        };

    private List<JobObservationVersion> _jobChangesList = new();
    private bool showui = false;
    private string searchString = "";


    protected override async Task OnParametersSetAsync()
    {
        _jobChangesList = await JobObservationServices.GetHistoryJobObservations(jobobservationId);
        showui = true;
    }

    private bool FilterFunc(JobObservationVersion element)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.JobObservationVersionId.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.DateModification.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
       
 
        if ($"{element.JobObservationId} ".Contains(searchString))
            return true;
        return false;
    }


}
