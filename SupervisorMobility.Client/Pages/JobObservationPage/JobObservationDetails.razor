                                        break;
                                    case "doc":
                                        // Para documentos Word con extensión .doc
                                        <img src="Images/doc.png" Height="70" Width="70" />
                                        break;

                                    case "docx":
                                        <img src="Images/docx.png" Height="70" Width="70" />
                                        // Para documentos Word con extensión .docx
                                        break;

                                    case "ppt":
                                        <img src="Images/ppt.png" Height="70" Width="70" />

                                        // Para presentaciones PowerPoint con extensión .ppt
                                        break;

                                    case "pptx":
                                        <img src="Images/pptx.png" Height="70" Width="70" />
                                        // Para presentaciones PowerPoint con extensión .pptx
                                        break;

                                    case "xls":
                                        // Para hojas de cálculo Excel con extensión .xls
                                        <img src="Images/xls.png" Height="70" Width="70" />
                                        break;

                                    case "xlsx":
                                        // Para hojas de cálculo Excel con extensión .xlsx
                                        <img src="Images/xlsx.png" Height="70" Width="70" />
                                        break;

                                    case "jpg":
                                        <img src="Images/jpg.png" Height="70" Width="70" />
                                        break;

                                    case "jpeg":
                                        // Para imágenes JPEG con extensión .jpg o .jpeg
                                        <img src="Images/jpg.png" Height="70" Width="70" />
                                        break;

                                    case "png":
                                        // Para imágenes PNG con extensión .png
                                        <img src="Images/png.png" Height="70" Width="70" />
                                        break;

                                    case "gif":
                                        // Para imágenes GIF con extensión .gif
                                        <img src="Images/gif.png" Height="70" Width="70" />
                                        break;
                                    default:
                                        <img src="Images/error.png" Height="70" Width="70" />
                                        break;
                                }
                                <MudTooltip Text=@Localizer["download"] Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true">
                                    <MudButton @onclick="() => DownloadFileFromURL_HOE(DocFile.URL, DocFile.Nombre)">
                                        <MudItem>
                                            <MudChip Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer;max-width: 315px" Icon="@Icons.Material.Filled.Download" Color="Color.Info">
                                                @if (DocFile.Nombre.Length > 10)
                                                {
                                                    <span class="marquee">@DocFile.Nombre</span>
                                                }
                                                else
                                                {
                                                    @DocFile.Nombre
                                                }
                                            </MudChip>

                                        </MudItem>
                                    </MudButton>
                                </MudTooltip>
                            </MudItem>

                        </MudPaper>

                    }
                }
                else
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                }
            }
            else
            {
                if (folderError)
                {
                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                            <img src="Images/dialogerror.png" Height="140" Width="140" />
                        </MudItem>

                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["alert"] </MudText>

                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["serverNotResponse"]</MudText>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                }
                else
                {
                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                            <img src="Images/dialogerror.png" Height="140" Width="140" />
                        </MudItem>

                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["alert"] </MudText>

                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["dataNotFound"]</MudText>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                }
            }

        </MudContainer>
    </DialogContent>
    <DialogActions>
        @*<MudIconButton @onclick="(() => JobObservationUpdate(jobId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>*@
        <MudButton Color="Color.Info" OnClick="CloseHoe">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>
