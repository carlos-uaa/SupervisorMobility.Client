<MudText>
    @switch(_jobObservation.Status)
    {
        case 1:
            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">Planned</MudChip>
            break;
        case 2:
            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Size="Size.Small" Style="cursor:pointer">In Progress</MudChip>
            break;
        case 3:
            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">Late</MudChip>
            break;
        case 4:
                <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Size="Size.Small" Style="cursor:pointer">Under Review</MudChip>
            break;
        case 5:
                <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">Rejected</MudChip>
            break;
        case 6:
            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">Finished</MudChip>
            break;
    }
</MudText>
<MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
    <MudItem lg="10" md="12" sm="12" xs="12">
        <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
            <MudText Typo="Typo.h6">
                Tarjeta de Observación de Operación Cíclica @_jobObservation.JobObservationId
               
                <MudItem Class="d-flex justify-space-between pa-1 ma-1">
                    <MudItem Style="text-align: start">
                        @if (searchAssychart)
                        {
                            <MudItem Class="d-flex flex-column align-start justify-center pa-1 ma-1">
                                <MudItem class="">
                                    <MudText Typo="Typo.h6" Class="align-item-center center">Related Documents</MudText>
                                </MudItem>

                                <MudItem Class="d-flex flex-row align-start justify-center pa-2 ma-2">

                                    @if (_assychart.GOS != "")
                                    {
                                        <MudButton @onclick="(() => OpenDialogGOS(_assychart.GOS))" Style="padding: 0px;" Color="Color.Error">
                                            <MudTooltip Text="Open GOS Folder" Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogGOS(_assychart.GOS))">
                                                <MudTooltip Text="@_assychart.GOS" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true">
                                                    <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Style="font-size: 10px">@_assychart.GOS.Split('/').Last()</MudChip>
                                                </MudTooltip>
                                            </MudTooltip>
                                        </MudButton>
                                    }
                                    else
                                    {
                                        <MudAlert Severity="Severity.Info">No GOS Path</MudAlert>
                                    }

                                    @if (_assychart.CCP != "")
                                    {
                                        <MudButton @onclick="(() => OpenDialogCcp(_assychart.CCP))" Style="padding: 0px;" Color="Color.Error">
                                            <MudTooltip Text="Open CCP Folder" Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogCcp(_assychart.CCP))">
                                                <MudTooltip Text="@_assychart.CCP" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true">
                                                    <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Style="font-size: 10px">@_assychart.CCP.Split('/').Last()</MudChip>
                                                </MudTooltip>
                                            </MudTooltip>
                                        </MudButton>
                                    }
                                    else
                                    {
                                        <MudAlert Severity="Severity.Info">No CCP Path</MudAlert>
                                    }

                                    @if (_assychart.HOE != "")
                                    {
                                        <MudButton @onclick="(() => OpenDialogHoe(_assychart.HOE))" Style="padding: 0px;" Color="Color.Error">
                                            <MudTooltip Text="Open HOE Folder" Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogHoe(_assychart.HOE))">
                                                <MudTooltip Text="@_assychart.HOE.Replace('§',' ')" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true">
                                                    <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Style="font-size: 10px">@_assychart.HOE.Split('§').Last()</MudChip>
                                                </MudTooltip>
                                            </MudTooltip>
                                        </MudButton>
                                    }
                                    else
                                    {
                                        <MudAlert Severity="Severity.Info">No HOE Path</MudAlert>
                                    }

                                </MudItem>
                            </MudItem>
                        }
                        else
                        {
                            if (messageErrorFolders != "")
                            {
                                <MudItem class="d-flex flex-column justify-center align-self-start">
                                    <MudText Typo="Typo.h6" Class="align-item-center center">@messageErrorFolders</MudText>
                                </MudItem>
                            }
                            else
                            {
                                <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
                            }

                        }
                    </MudItem>
                    <MudItem Style="text-align: end">
                        @if (_jobObservation.Type == 1)
                        {
                            <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">Planned</MudChip>
                        }
                        else if (_jobObservation.Type == 2)
                        {
                            <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">Eventual</MudChip>
                        }

                        <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3" OnClick="@history">History Versions</MudChip>
                    </MudItem>
                </MudItem>

            </MudText>
        </MudItem>
        <MudPaper Class="" Elevation="0">
            <MudItem Class="ml-2">
                <MudSimpleTable Dense="@dense" Hover="@hover" ReadOnly="@ronly"
                                HorizontalScrollbar="true">
                    <tbody>
                        <tr>
                            <td style="width:50%">
                                @*Mud select of Plants*@
                                <MudSelect T="int" Label="Plant" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.PlantId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservation.PlantId">@_jobObservation.Plant?.Code - @_jobObservation.Plant?.Description</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td class="d-flex">
                                <MudDatePicker @bind-Date="_jobObservation.StartDate" Label="Fecha Inicio" Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4 pt-2" ReadOnly />
                                <MudDatePicker @bind-Date="_jobObservation.EndDate" Label="Fecha Termino" Color="Color.Info" AdornmentColor="Color.Info" MinDate="_jobObservation.StartDate" Class="pt-2" ReadOnly/>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*Mud select of Areas *@
                                <MudSelect T="int" Label="Area" Variant="Variant.Text" Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.AreaId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservation.AreaId">@_jobObservation.Area?.Code - @_jobObservation.Area?.Description</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td >
                                <MudTextField T="string" @bind-Value="_jobObservation.Supervisor.Name" Label="Observer" Class="mr-4" />
@*                              <MudTimePicker Label="Start hour" @bind-Time="startHour" Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4 pt-2" ReadOnly/>
                                <MudTimePicker Label="End hour" @bind-Time="endHour" Color="Color.Info" AdornmentColor="Color.Info" Class="pt-2" ReadOnly />*@
                            </td>
                        </tr>
                        <tr>
                            <td class="d-flex">
                                @*Mud select of Distribution *@
                                <MudSelect T="int" Label="Distribution" Variant="Variant.Text" Placeholder="Select a Distribution" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.DistributionId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservation.DistributionId">@_jobObservation.Distribution?.Code - @_jobObservation.Distribution?.Description</MudSelectItem>
                                </MudSelect>
                                @*Mud select of Operations *@
                                <MudSelect T="int" Label="Operation" Variant="Variant.Text" Placeholder="Select an Operation" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperationId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservation.OperationId">@_jobObservation.Operation?.Code - @_jobObservation.Operation?.Description</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="_jobObservation.Operator.Name" Label="Operator" Class="mr-4" />
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" style="text-align: center;">
                                <MudRadioGroup @bind-SelectedOption="_jobObservation.Option">
                                    <MudRadio Option="1" Color="Color.Info" Size="Size.Small" Disabled=true>Verificar la Capacitación</MudRadio>
                                    <MudRadio Option="2" Color="Color.Info" Size="Size.Small" Disabled=true>Mantener y/o Mejorar el área de trabajo</MudRadio>
                                    <MudRadio Option="3" Color="Color.Info" Size="Size.Small" Disabled>
                                        @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("Manejo de la anomalía"))
                                        {
                                            Glosary word;
                                            word = _glosaryInfo["Manejo de la anomalía"];
                                            <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                                <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                    <MudText>@word.Name</MudText>
                                                </MudBadge>
                                            </MudTooltip>
                                        }
                                        else
                                        {
                                            <span>Manejo de anomalía</span>
                                        }
                                    </MudRadio>
                                    @if (_jobObservation.Option == 3)
                                    {
                                        <MudTextField @bind-Value="_jobObservation.Anomaly" T="string" Label="Write the anomaly" Placeholder="Anomaly" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    }
                                </MudRadioGroup>

                            </td>
                        </tr>
                        @*                        @if (_jobObservation.Justification != null)
                        {
                            <tr>
                                <td colspan="2">
                                    <MudText Style="text-align:center; font-weight:bold;">
                                        New Date
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <MudDatePicker @bind-Date="_jobObservation.EditStartDate" Label="New Start Date" Color="Color.Primary" AdornmentColor="Color.Primary" Class="pt-2" ReadOnly />
                                    <MudTimePicker Label="New Start hour" @bind-Time="changeStartHour" Color="Color.Primary" AdornmentColor="Color.Primary" Class="pt-2" ReadOnly />
                                </td>
                                <td>
                                    <MudDatePicker @bind-Date="_jobObservation.EditEndDate" Label="New End Date" Color="Color.Primary" AdornmentColor="Color.Primary" MinDate="_jobObservation.EditStartDate" Class="pt-2" ReadOnly />
                                    <MudTimePicker Label="New End hour" @bind-Time="changeEndHour" Color="Color.Primary" AdornmentColor="Color.Primary" Class="pt-2" ReadOnly />
                                </td>
                            </tr>*@
           @*                 <tr>
                                <td colspan="2">
                                    <MudText Style="text-align:center; font-weight:bold;">
                                        Justification to update
                                    </MudText>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2">
                                    <MudTextField T="string" @bind-Value="_jobObservation.Justification" ReadOnly Label="Justification" Placeholder="Write down the justification if the date is changed." Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </td>
                            </tr>
                        }*@
                        <tr>
                            <td colspan="2" style="text-align:center">
                                @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("Tiempo de la HOE"))
                                {
                                    Glosary word;
                                    word = _glosaryInfo["Tiempo de la HOE"];
                                    <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                        <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                            <MudText Style="text-align:center; font-weight:bold;">@word.Name</MudText>
                                        </MudBadge>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <span style="text-align:center; font-weight:bold;">Tiempo de la HOE</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*<MudTimePicker Label="Minutes" Text="13:37" OpenTo="OpenTo.Minutes" />*@
                                <MudTextField T="string" @bind-Value="_jobObservation.Time1HOE" Label="Tiempo 1" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="_jobObservation.Time2HOE" Label="Tiempo 2" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem Class="ml-2">
                <MudSimpleTable Dense=true Style="overflow-x: auto;" Bordered=true Class="mt-6 mb-3">
                    <tbody>
                        <tr>
                            <td colspan="5">
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Modelo
                                </MudText>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*Mud select of Products*@
                                <MudSelect T="int" Label="Product 1" Variant="Variant.Text" Placeholder="Select a Product" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[0]">
                                    @if(models[0] == 0){
                                        <MudSelectItem Disabled=true Value="0">Not selected</MudSelectItem>
                                    }
                                    else{
                                        @foreach (var type in _products)
                                        {
                                            if (models[0] == type.ProductId)
                                            {
                                                <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                            }
                                        }

                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 2" Variant="Variant.Text" Placeholder="Select a Product" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[1]">
                                    @if(models[0] == 0){
                                        <MudSelectItem Disabled=true Value="0">Not selected</MudSelectItem>
                                    }
                                    else{
                                        @foreach (var type in _products)
                                        {
                                            if (models[1] == type.ProductId)
                                            {
                                                <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                            }
                                        }

                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 3" Variant="Variant.Text" Placeholder="Select a Product" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[2]">
                                    @if(models[0] == 0){
                                        <MudSelectItem Disabled=true Value="0">Not selected</MudSelectItem>
                                    }
                                    else{
                                        @foreach (var type in _products)
                                        {
                                            if (models[2] == type.ProductId)
                                            {
                                                <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                            }
                                        }

                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 4" Variant="Variant.Text" Placeholder="Select a Product" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[3]">
                                    @if(models[0] == 0){
                                        <MudSelectItem Disabled=true Value="0">Not selected</MudSelectItem>
                                    }
                                    else{
                                        @foreach (var type in _products)
                                        {
                                            if (models[3] == type.ProductId)
                                            {
                                                <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                            }
                                        }

                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 5" Variant="Variant.Text" Placeholder="Select a Product" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[4]">
                                        @if(models[0] == 0){
                                        <MudSelectItem Disabled=true Value="0">Not selected</MudSelectItem>
                                    }
                                    else{
                                        @foreach (var type in _products)
                                        {
                                            if (models[4] == type.ProductId)
                                            {
                                                <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                            }
                                        }

                                    }
                                </MudSelect>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="5" style="text-align:center; padding-top: 10px">
                                @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("Tiempo ciclo"))
                                {
                                    Glosary word;
                                    word = _glosaryInfo["Tiempo ciclo"];
                                    <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                        <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                            <MudText Style="text-align:center; font-weight:bold;">@word.Name</MudText>
                                        </MudBadge>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <span style="text-align:center; font-weight:bold;">Tiempo ciclo</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[0]" Label="Cicle 1" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[1]" Label="Cicle 2" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[2]" Label="Cicle 1" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[3]" Label="Cicle 2" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[4]" Label="Cicle 1" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="cs" Adornment="Adornment.End" />
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem Class="ml-2">
            </MudItem>
            <MudItem Class="ml-2">
                <MudSimpleTable Style="overflow-x: auto;" Dense=true Bordered=true Class="mt-6 mb-6">
                    <tbody>
                        <tr>
                            <td colspan="2">
                                <MudSimpleTable Style="overflow-x: auto;" Dense=true Bordered=true Elevation="0">
                                    <thead>
                                        <tr>
                                            <th>
                                                <MudText Style="font-weight:bold;">
                                                    Pillar
                                                </MudText>
                                            </th>
                                            <th>
                                                <MudText Style="text-align:center; font-weight:bold;">
                                                    Improve / Activity Detected
                                                </MudText>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td width="10%">
                                                @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("S"))
                                                {
                                                    Glosary word;
                                                    word = _glosaryInfo["S"];
                                                    <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                                        <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                            <MudText>@word.Name</MudText>
                                                        </MudBadge>
                                                    </MudTooltip>
                                                }
                                                else
                                                {
                                                    <span>S</span>
                                                }
                                            </td>
                                            <td>
                                                @if (_lupJobObservations.Lup.Count > 0)
                                                {
                                                    foreach (var lup in _lupJobObservations.Lup)
                                                    {
                                                        if (lup.Pillar == 1)
                                                        {
                                                            <MudTooltip Text="@lup.LupId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true">
                                                                <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined">
                                                                    <MudChip Color="Color.Info" OnClose="Closed" Size="Size.Small" CloseIcon="@Icons.Material.Filled.ChecklistRtl" Variant="Variant.Text">
                                                                        @if (lup.Oportunity.Length < 50)
                                                                        {
                                                                            @lup.Oportunity
                                                                        }
                                                                        else
                                                                        {
                                                                            @lup.Oportunity.Substring(0,50) <span>...</span>
                                                                        }
                                                                    </MudChip>
                                                                    @switch (lup.Status)
                                                                    {
                                                                        case 1:
                                                                            <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">New</MudChip>
                                                                            break;
                                                                        case 2:
                                                                            <MudChip Variant="Variant.Text" Color="Color.Info" Size="Size.Small">In Progress</MudChip>
                                                                            break;
                                                                        case 3:
                                                                            <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small">Finished</MudChip>
                                                                            break;
                                                                        case 4:
                                                                            <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small">Canceled</MudChip>
                                                                            break;
                                                                    }
                                                                </MudButton>
                                                            </MudTooltip>

                                                        }
                                                    }
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("Q"))
                                                {
                                                    Glosary word;
                                                    word = _glosaryInfo["Q"];
                                                    <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                                        <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                            <MudText>@word.Name</MudText>
                                                        </MudBadge>
                                                    </MudTooltip>
                                                }
                                                else
                                                {
                                                    <span>Q</span>
                                                }
                                            </td>
                                            <td>
                                                @if (_lupJobObservations.Lup.Count > 0)
                                                {
                                                    foreach (var lup in _lupJobObservations.Lup)
                                                    {
                                                        if (lup.Pillar == 2)
