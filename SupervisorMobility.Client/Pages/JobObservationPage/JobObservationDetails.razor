@page "/jobobservation/details/{jobobservationId:int}"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using System.Globalization;
@using System.Net.Http.Json;

@inject IJSRuntime JSRuntime
@inject IGroupService GroupService
@inject IChecklistService ChecklistService
@inject IDialogService DialogService
@inject IPlantService PlantServices
@inject IProductService ProductService
@inject IAreaService AreaServices
@inject IDistributionService DistributionService
@inject IOperationService OperationService
@inject IJobObservationService JobObservationService

@inject NavigationManager NavigationManager
@inject HttpClient httpClient

@*Title*@
<PageTitle>Supervisor Mobility | Job Observation</PageTitle>

@* Job Observation Form*@
@if (_jobObservation.IsActive == true)
{
    <MudText>
        <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
    </MudText>
}
else
{
    <MudText>
        <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
    </MudText>
}
<MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
    <MudItem lg="10" md="12" sm="12" xs="12">
        <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
            <MudText Typo="Typo.h6">
                Tarjeta de Observación de Operación Cíclica @_jobObservation.JobObservationId
                <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">Eventual</MudChip>
            </MudText>
        </MudItem>
        <MudPaper Class="" Elevation="0">
            <MudItem Class="ml-2">
                <MudSimpleTable Dense="@dense" Hover="@hover" ReadOnly="@ronly" Bordered=true
                          HorizontalScrollbar="true">
                    <tbody>
                        <tr>
                            <td>
                                @*Mud select of Plants*@
                                <MudSelect T="int" Label="Plant" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.PlantId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservation.PlantId">@_jobObservation.Plant?.Code - @_jobObservation.Plant?.Description</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td class="d-flex">
                                <MudDatePicker @bind-Date="_jobObservation.DateStart" Label="Fecha Inicio" Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4" />
                                <MudDatePicker @bind-Date="_jobObservation.DateEnd" Label="Fecha Termino" Color="Color.Info" AdornmentColor="Color.Info" MinDate="_jobObservation.DateStart" />
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*Mud select of Areas *@
                                <MudSelect T="int" Label="Area" Variant="Variant.Text" Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.AreaId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservation.AreaId">@_jobObservation.Area?.Code - @_jobObservation.Area?.Description</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td class="d-flex">
                                <MudTimePicker Label="Start hour" @bind-Time="startHour" Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4" />
                                <MudTimePicker Label="End hour" @bind-Time="endHour" Color="Color.Info" AdornmentColor="Color.Info" />
                            </td>
                        </tr>
                        <tr>
                            <td class="d-flex">
                                @*Mud select of Distribution *@
                                <MudSelect T="int" Label="Distribution" Variant="Variant.Text" Placeholder="Select a Distribution" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.DistributionId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservation.DistributionId">@_jobObservation.Distribution?.Code - @_jobObservation.Distribution?.Description</MudSelectItem>
                                </MudSelect>
                                @*Mud select of Operations *@
                                <MudSelect T="int" Label="Operation" Variant="Variant.Text" Placeholder="Select an Operation" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperationId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservation.OperationId">@_jobObservation.Operation?.Code - @_jobObservation.Operation?.Description</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td>
                                <div class="d-flex">
                                    <MudTextField T="string" @bind-Value="_jobObservation.Observer" Label="Observador" Class="mr-4" />
                                    <MudTextField T="string" @bind-Value="_jobObservation.Operator" Label="Operador" />
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" style="text-align: center;">
                                <MudRadioGroup @bind-SelectedOption="_jobObservation.Option">
                                <MudRadio Option="1" Color="Color.Info" Size="Size.Small" Disabled=true>Verificar la Capacitación</MudRadio>
                                <MudRadio Option="2" Color="Color.Info" Size="Size.Small" Disabled=true>Mantener y/o Mejorar el área de trabajo</MudRadio>
                                <MudRadio Option="3" Color="Color.Info" Size="Size.Small" Disabled=true>Manejo de anomalía</MudRadio>
                                @if(_jobObservation.Option == 3)
                                {
                                        <MudTextField @bind-Value="_jobObservation.Anomaly" T="string" Label="Write the anomaly" Placeholder="Anomaly" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                }
                            </MudRadioGroup>

                            </td>
                        </tr>
                    @if(_jobObservation.Justification != null)
                    {
                        <tr>
                            <td colspan="2">
                                <MudText Style="text-align:center; font-weight:bold;">
                                     Justification to update
                                </MudText>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2">
                                <MudTextField T="string" @bind-Value="_jobObservation.Justification" Label="Justification" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </td>
                        </tr>
                    }
                        <tr>
                            <td colspan="2" >
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Tiempo de la HOE
                                </MudText>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*<MudTimePicker Label="Minutes" Text="13:37" OpenTo="OpenTo.Minutes" />*@
                                <MudTextField T="string" @bind-Value="_jobObservation.Time1HOE" Label="Tiempo 1" Required="true" Variant="Variant.Outlined" RequiredError="Time is required!" Margin="Margin.Dense" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="_jobObservation.Time2HOE" Label="Tiempo 2" Required="true" Variant="Variant.Outlined" RequiredError="Time is required!" Margin="Margin.Dense" />
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem Class="ml-2">
                <MudSimpleTable Dense=true Style="overflow-x: auto;" Bordered=true Class="mt-6 mb-3">
                    <tbody>
                        <tr>
                            <td colspan="5">
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Modelo
                                </MudText>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*Mud select of Products*@
                                <MudSelect T="int" Label="Product 1" Variant="Variant.Text" Placeholder="Select a Product" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[0]">
                                    @foreach (var type in _products)
                                    {
                                        if(models[0] == type.ProductId){
                                            <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 2" Variant="Variant.Text" Placeholder="Select a Product" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[1]">
                                    @foreach (var type in _products)
                                    {
                                        if (models[1] == type.ProductId)
                                        {
                                            <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 3" Variant="Variant.Text" Placeholder="Select a Product" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[2]">
                                    @foreach (var type in _products)
                                    {
                                        if(models[2] == type.ProductId){
                                            <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                        }
                                    }                                
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 4" Variant="Variant.Text" Placeholder="Select a Product" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[3]">
                                    @foreach (var type in _products)
                                    {
                                        if (models[3] == type.ProductId)
                                        {
                                            <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </td>
                            <td>
                                <MudSelect T="int" Label="Product 5" Variant="Variant.Text" Placeholder="Select a Product" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@models[4]">
                                    @foreach (var type in _products)
                                    {
                                        if (models[4] == type.ProductId)
                                        {
                                            <MudSelectItem Value="type.ProductId" Disabled=true>@($"{type.Code}")</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="5">
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Tiempo ciclo
                                </MudText>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[0]" Label="Cicle 1" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="s" Adornment="Adornment.End" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[1]" Label="Cicle 2" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="s" Adornment="Adornment.End" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[2]" Label="Cicle 1" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="s" Adornment="Adornment.End"/>
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[3]" Label="Cicle 2" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="s" Adornment="Adornment.End"/>
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="cicles[4]" Label="Cicle 1" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" AdornmentText="s" Adornment="Adornment.End" />
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem Class="ml-2">
                <MudSimpleTable Style="overflow-x: auto;" Dense=true Bordered=true Class="mt-6 mb-3">
                    <thead>
                        <tr>
                            <th>
                                <MudText Style="font-weight:bold;">
                                    Pilar
                                </MudText>
                            </th>
                            <th>
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Área de oportunidad detectada
                                </MudText>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                               S
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="_jobObservation.SArea" Placeholder="@placeholder" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                            </td>
                        </tr>
                        <tr>
                            <td>
                                Q
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="_jobObservation.QArea" Placeholder="@placeholder" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                            </td>
                        </tr>
                        <tr>
                            <td>
                                D
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="_jobObservation.DArea" Placeholder="@placeholder" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                            </td>
                        </tr>
                        <tr>
                            <td>
                                C
                            </td>
                            <td colspan="9">
                                <MudTextField T="string" @bind-Value="_jobObservation.CArea" Placeholder="@placeholder" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                            </td>
                        </tr>
                        <tr>
                            <td>
                                Otros
                            </td>
                            <td colspan="9">
                                <MudTextField T="string" @bind-Value="_jobObservation.OthersArea" Placeholder="@placeholder" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            <MudItem Class="ml-2">
                <MudSimpleTable Style="overflow-x: auto;" Dense=true Bordered=true Class="mt-6 mb-3">
                    <thead>
                        <tr>
                            <th>
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Mejora / Actividad Identificada
                                </MudText>
                            </th>
                            <th>
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Comentario de SSV
                                </MudText>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <MudTextField T="string" @bind-Value="_jobObservation.IdentifiedActivity" Placeholder="@placeholder" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                            </td>
                            <td>
                                <MudTextField T="string" @bind-Value="_jobObservation.SsvCommentary" Placeholder="@placeholder" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" />
                            </td>
                        </tr>
                        <th>
                            <MudText Style="text-align:center; font-weight:bold;">
                            Ideas de mejora y/o comentarios del Operador
                            </MudText>
                        </th>
                        <th>
                            <MudText Style="text-align:center; font-weight:bold;">
                            Firma del SSV
                            </MudText>
                        </th>
                        <tr>
                            <td>
                            <MudTextField T="string" @bind-Value="_jobObservation.OperatorCommentary" Placeholder="@placeholder" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="4" />
                            </td>
                            <td>
                            <MudTextField T="string" @bind-Value="_jobObservation.SsvSignature" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                <MudText Style="text-align:center; font-weight:bold;">
                                    Firma del Operador
                                </MudText>
                            <MudTextField T="string" @bind-Value="_jobObservation.OperatorSignature" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </td>
                        </tr>
                       
                    </tbody>
                </MudSimpleTable>
            </MudItem>
        </MudPaper>
    </MudItem>
</MudGrid>
