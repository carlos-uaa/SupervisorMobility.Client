                <MudSelect T="int" Label="Operator"  Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Select an Operator" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@OperatorId">
                        <MudSelectItem Disabled="true" Value="0">Not selected</MudSelectItem>
                    @foreach (var type in operatorUsers)
                    {
                        <MudSelectItem Value="type.UserId">@($"{type.Name}")</MudSelectItem>
                    }
                </MudSelect>
                <MudSpacer />
                    @*Mud select of Status *@
                    <MudSelect T="int" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Select a Group" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@StatusId">
                        <MudSelectItem Value="0">All Status</MudSelectItem>
                        <MudSelectItem Value="1">Planned</MudSelectItem>
                        <MudSelectItem Value="2">In Progress</MudSelectItem>
                        <MudSelectItem Value="3">Late</MudSelectItem>
                        <MudSelectItem Value="4">Finalized</MudSelectItem>
                    </MudSelect>
               <MudSpacer />
               <MudSpacer />
               }
