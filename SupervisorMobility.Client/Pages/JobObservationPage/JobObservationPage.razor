@page "/jobobservation"

@using System.Net.Http.Json
@using MudBlazor

@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IChecklistService ChecklistService
@inject IAssyChartService AssyChartServices
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IJobObservationService JobObservationService
@inject IDistributionService DistributionService
@inject IOperationService OperationService
@inject IUserService UsersService

@if(logged == true){
@*Title*@
<PageTitle>Supervisor Mobility | Job Observation</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-5" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>    

<MudItem Class="d-flex justify-content-between" Style="align-items: center;">
    <MudText Typo="Typo.h6">Job Observations</MudText>
        <MudItem Style="justify-content: end" Class="ml-auto">
            <MudButton Href="/jobobservationschedule" StartIcon="@Icons.Material.Filled.CalendarMonth" Color="Color.Info" Class="mr-8">Calendar</MudButton>
            <MudButton @onclick="(() => PlanJobObservation())" StartIcon="@Icons.Material.Filled.EditCalendar" Class="mr-8">Plan</MudButton>
            <MudButton @onclick="(() => CreateJobObservation())" StartIcon="@Icons.Material.Filled.Add">Create</MudButton>
    </MudItem>
</MudItem>
<MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
    <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="All Job Observations">
        <MudTable Items="_jobObservation" T="JobObservation" Dense="@dense" Hover="@hover" ReadOnly="@ronly" Filter="new Func<JobObservation,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true Height="400px"
                HorizontalScrollbar="true">
            <ToolBarContent>
                <MudIconButton Icon="@Icons.Material.Filled.FilterAlt" Color="@color" @onclick="(() => ActiveFilters())" Class="mr-0"></MudIconButton>
                    @if(filters == false)
                    {
                        <MudSpacer />
                        <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-5 ml-5 mr-5"></MudTextField>
                    }
                    <MudSpacer />
                @if(filters == true)
                {
                    <MudTextField @bind-Value="searchString" Placeholder="Id" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 5vw" Class="pt-2"></MudTextField>
                    <MudSelect T="int" Label="Distribution" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Distribution" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@distributionId" SelectedValuesChanged="FilterDistributions">
                    <MudSelectItem Disabled="true" Value="0">Not selected</MudSelectItem>
                    @foreach (var type in _distributions)
                    {
                        <MudSelectItem Value="type.DistributionId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                    }
                </MudSelect>
                <MudSpacer />
                <MudSelect T="int" Label="Operation" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Operation" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@operationId" SelectedValuesChanged="FilterOperations">
                        <MudSelectItem Disabled="true" Value="0">Not selected</MudSelectItem>
                    @foreach (var type in _operations)
                    {
                        <MudSelectItem Value="type.OperationId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                    }
                </MudSelect>
                <MudSpacer />
                    <MudDatePicker @bind-Date="@filterDate" Label="Date" Color="Color.Info" AdornmentColor="Color.Info" Style="max-width: 9vw" Variant="Variant.Outlined" Margin="Margin.Dense" Class="pt-2"/>
