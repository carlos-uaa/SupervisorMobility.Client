@page "/jobobservation"

@using System.Net.Http.Json
@using MudBlazor

@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IChecklistService ChecklistService
@inject IAssyChartService AssyChartServices
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IJobObservationService JobObservationService

@*Title*@
<PageTitle>Supervisor Mobility | Job Observation</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

<MudTable Items="_jobObservation" T="JobObservation" Dense="@dense" Hover="@hover" ReadOnly="@ronly" Filter="new Func<JobObservation,bool>(FilterFunc)" Class="styled-table table-striped"
        HorizontalScrollbar="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Job Observations</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        <MudSpacer />
        <MudSpacer />
        <MudIconButton Href="/jobobservationschedule" Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Info"></MudIconButton>
        <MudIconButton @onclick="(() => CreateJobObservation())" Icon="@Icons.Material.Filled.Add" aria-label="add">New</MudIconButton>

    </ToolBarContent>
    <ColGroup>
        <col style="width: 60px;" />
        <col />
        <col />
        <col />
        <col />
        <col />
    </ColGroup>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.JobObservationId)">Id</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Plant?.Description)">Plant</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Area?.Description)">Area</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Distribution?.Description)">Distribution</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operation?.Description)">Operation</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.DateStart)">Start date</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Observer)">Observer</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operator)">Operator</MudTableSortLabel></MudTh>
        <MudTh Style="text-align: center">Actions</MudTh>
    </HeaderContent>
    <GroupHeaderTemplate>

        </GroupHeaderTemplate>
        <RowTemplate>
            <MudTd DataLabel="JobObservationId">
                <MudText Align="Align.Center">@context.JobObservationId</MudText>
            </MudTd>
            <MudTd DataLabel="Plant">
                <MudText Align="Align.Center">@context.Plant?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Area">
                <MudText Align="Align.Center">@context.Area?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Distribution">
                <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Operation">
                <MudText Align="Align.Center">@context.Operation?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Start Date">
                <MudText Align="Align.Center">@context.DateStart?.ToShortDateString()</MudText>
            </MudTd>
            <MudTd DataLabel="Observer">
                <MudText Align="Align.Center">@context.Observer</MudText>
            </MudTd>
            <MudTd DataLabel="Operator">
                <MudText Align="Align.Center">@context.Operator</MudText>
            </MudTd>
            <MudTd>
                <MudText Align="Align.Center">
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Color="Color.Success" @onclick="(() => OpenDialog2(context.JobObservationId))" Size="Size.Small"></MudIconButton>
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Color="Color.Info" @onclick="(() => EditJobObservation(context.JobObservationId))" Size="Size.Small"></MudIconButton>
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="(() => DeleteJobObservation(context.JobObservationId))" Size="Size.Small"></MudIconButton>
                </MudText>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>


<MudDialog DisableSidePadding="false" @bind-IsVisible="visible" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 75vh; overflow-y: scroll">
            <SupervisorMobility.Client.Pages.JobObservationPage.JobObservationDetails JobObservationId="jobId"></SupervisorMobility.Client.Pages.JobObservationPage.JobObservationDetails>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudIconButton @onclick="(() => EditJobObservation(jobId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>
        <MudButton Color="Color.Info" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>