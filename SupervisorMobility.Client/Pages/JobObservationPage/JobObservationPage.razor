                            <MudSelect T="int" Label="Operation" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Operation" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@operationId" SelectedValuesChanged="Filters">
                                <MudSelectItem Disabled="true" Value="0" @onclick="(() => ShowError())">Not selected</MudSelectItem>
                                @foreach (var type in _operations)
                                {
                                    <MudSelectItem Value="type.OperationId">@($"{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        <MudSpacer />
                        <MudDatePicker Placeholder="dd/mm/yyyy" @bind-Date="@filterDate" Label="Date" Color="Color.Info" AdornmentColor="Color.Info" Style="max-width: 12vw" Variant="Variant.Outlined" Margin="Margin.Dense" Class="pt-2" PickerClosed="Filters" />
                        @*Mud select for Operator *@
                        <MudSelect T="int" Label="Operator" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Select an Operator" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@operatorId" SelectedValuesChanged="Filters">
                            <MudSelectItem Disabled="true" Value="0">Not selected</MudSelectItem>
                            @foreach (var type in operatorUsers)
                            {
                                <MudSelectItem Value="type.UserId">@($"{type.Name}")</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSpacer />
                        <MudTooltip Text="Clear filters" Arrow="true" Placement="Placement.Left" Color="Color.Error">
                            <MudIconButton Icon="@Icons.Material.Filled.Clear" Color="Color.Error" @onclick="(() => ClearFilters())" Class="mr-0"></MudIconButton>
                        </MudTooltip>
                    }
                </ToolBarContent>
                <ColGroup>
                    <col style="width: 60px;" />
                    <col />
                    <col />
                    <col />
                    <col />
                    <col />
                </ColGroup>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.JobObservationId)">Id</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Distribution?.Description)">Distribution</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operation?.Description)">Operation</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.StartDate)">Start date</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operator?.Name)">Operator</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Status)">Status</MudTableSortLabel></MudTh>
                    <MudTh Style="text-align: center">Actions</MudTh>
                </HeaderContent>
                <GroupHeaderTemplate>

                </GroupHeaderTemplate>
                <RowTemplate>
                    <MudTd DataLabel="JobObservationId">
                        <MudText Align="Align.Center">@context.JobObservationId</MudText>
                    </MudTd>
                    <MudTd DataLabel="Distribution">
                        <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel="Operation">
                        <MudText Align="Align.Center">@context.Operation?.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel="Start Date">
                        <MudText Align="Align.Center">@context.StartDate?.ToShortDateString()</MudText>
                    </MudTd>
                    <MudTd DataLabel="Operator">
                        <MudText Align="Align.Center">@context.Operator?.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudText Align="Align.Center">
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">Finished</MudChip>
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudText Align="Align.Center">
                            <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => OpenDialog2(context.JobObservationId))"></MudIconButton>
                            <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => EditJobObservation(context.JobObservationId))"></MudIconButton>
                            <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => OpenDeleteDialog(context.JobObservationId))"></MudIconButton>
                        </MudText>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudTabPanel>
    </MudTabs>
    @*Delete observation modal*@
    <MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
        <DialogContent>
            <MudText Typo="Typo.h6">Confirm</MudText>
            <MudText Class="mt-4 mb-4">
                <span style="color: #2196f3; text-align:justify">@user.Name</span>,
                are you sure you want to delete this job observation?
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">Cancel</MudButton>
            <MudButton @onclick="(() => DeleteJobObservation(deleteJobObservationId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">Delete</MudButton>
        </DialogActions>
    </MudDialog>


    <MudDialog DisableSidePadding="false" @bind-IsVisible="visible" Options="dialogOptions">
        <DialogContent>
            <MudContainer Style="max-height: 75vh; overflow-y: scroll">
                <SupervisorMobility.Client.Pages.JobObservationPage.JobObservationDetails JobObservationId="jobId"></SupervisorMobility.Client.Pages.JobObservationPage.JobObservationDetails>
            </MudContainer>
        </DialogContent>
        <DialogActions>
            <MudIconButton @onclick="(() => EditJobObservation(jobId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>
            <MudButton Color="Color.Info" OnClick="Close">Close</MudButton>
        </DialogActions>
    </MudDialog>
}