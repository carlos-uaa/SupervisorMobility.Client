@page "/jobobservation"

@using System.Net.Http.Json
@using MudBlazor

@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IChecklistService ChecklistService
@inject IAssyChartService AssyChartServices
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IJobObservationService JobObservationService

@*Title*@
<PageTitle>Supervisor Mobility | Job Observation</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

<MudTable Items="_jobObservation" T="JobObservation" Dense="@dense" Hover="@hover" ReadOnly="@ronly"
        HorizontalScrollbar="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Job Observations</MudText>

        <MudSpacer />
        <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        <MudSpacer />
        <MudSpacer />
        <MudIconButton Href="/jobobservation/createjobobservation" Icon="@Icons.Material.Filled.Add" aria-label="add">New</MudIconButton>

    </ToolBarContent>
    <ColGroup>
        <col style="width: 60px;" />
        <col />
        <col />
        <col />
        <col />
        <col />
    </ColGroup>
    <HeaderContent>
        <MudTh Style="text-align: center">Id</MudTh>
        <MudTh Style="text-align: center">Plant</MudTh>
        <MudTh Style="text-align: center">Area</MudTh>
        <MudTh Style="text-align: center">Distribution</MudTh>
        <MudTh Style="text-align: center">Operation</MudTh>
        <MudTh Style="text-align: center">Start date</MudTh>
        <MudTh Style="text-align: center">Observer</MudTh>
        <MudTh Style="text-align: center">Operator</MudTh>
        <MudTh Style="text-align: center">Actions</MudTh>
    </HeaderContent>
    <GroupHeaderTemplate>

        </GroupHeaderTemplate>
        <RowTemplate>
            <MudTd DataLabel="JobObservationId">
                <MudText Align="Align.Center">@context.JobObservationId</MudText>
            </MudTd>
            <MudTd DataLabel="Plant">
                <MudText Align="Align.Center">@context.Plant?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Area">
                <MudText Align="Align.Center">@context.Area?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Distribution">
                <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Operation">
                <MudText Align="Align.Center">@context.Operation?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Start Date">
                <MudText Align="Align.Center">@context.DateStart?.ToShortDateString()</MudText>
            </MudTd>
            <MudTd DataLabel="Observer">
                <MudText Align="Align.Center">@context.Observer</MudText>
            </MudTd>
            <MudTd DataLabel="Operator">
                <MudText Align="Align.Center">@context.Operator</MudText>
            </MudTd>
            <MudTd>
                <MudText Align="Align.Center">
                <MudIconButton @onclick="(() => JobObservationDetails(context.JobObservationId))" Icon="@Icons.Material.Filled.Info" aria-label="info"></MudIconButton>
                <MudIconButton @onclick="(() => EditJobObservation(context.JobObservationId))" Icon="@Icons.Material.Filled.Edit" aria-label="edit"></MudIconButton>
                <MudIconButton @onclick="(() => DeleteJobObservation(context.JobObservationId))" Icon="@Icons.Material.Filled.Delete" aria-label="Delete"></MudIconButton>
                </MudText>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>

