                <col style="width: 60px;" />
                <col />
                <col />
                <col />
                <col />
                <col />
            </ColGroup>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.JobObservationId)">Id</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Distribution?.Description)">Distribution</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operation?.Description)">Operation</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x.DateStart)">Start date</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Operator?.Name)">Operator</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Status)">Status</MudTableSortLabel></MudTh>
                <MudTh Style="text-align: center">Actions</MudTh>
            </HeaderContent>
            <GroupHeaderTemplate>

                </GroupHeaderTemplate>
                <RowTemplate>
                    <MudTd DataLabel="JobObservationId">
                        <MudText Align="Align.Center">@context.JobObservationId</MudText>
                    </MudTd>
                    <MudTd DataLabel="Distribution">
                        <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel="Operation">
                        <MudText Align="Align.Center">@context.Operation?.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel="Start Date">
                        <MudText Align="Align.Center">@context.DateStart?.ToShortDateString()</MudText>
                    </MudTd>
                    <MudTd DataLabel="Operator">
                        <MudText Align="Align.Center">@context.Operator?.Name</MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudText Align="Align.Center">
                        @switch(context.Status)
