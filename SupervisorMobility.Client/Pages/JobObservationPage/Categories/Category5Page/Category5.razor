<MudText Color="Color.Info">Category 5.</MudText>
@*Category 5 Questions*@
<MudGrid Justify="Justify.Center">
    <MudItem lg="10">
        <MudSimpleTable Style="overflow-x: auto;">
            <thead>
                <MudTr>
                    <MudTh>Observación para mejora del estándar de acuerdo al filtro elegido</MudTh>
                    <MudTh></MudTh>
                </MudTr>
            </thead>
            <tbody>
                <MudTr>
                    <MudTd>Mejora identificada</MudTd>
                    <MudTd><MudTextField T="string" Placeholder="Explicar el punto crítico y confirmar que lo haga de acuerdo a la HOE" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" /></MudTd>
                </MudTr>
                <MudTr>
                    <MudTd>
                        Comentario / Firma del operador
                    </MudTd>
                    <MudTd><MudTextField T="string" Placeholder="Requiero de mejor iluminación en mi distribución" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" /></MudTd>
                </MudTr>
                <MudTr>
                    <MudTd>Comentarios y firma del SSV </MudTd>
                    <MudTd><MudTextField T="string" Placeholder="El área se ve muy bien, hay respeto al método y al estado de referencia" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" /></MudTd>
                </MudTr>
            </tbody>
        </MudSimpleTable>
        <MudSimpleTable Style="overflow-x: auto;" Class="mt-4">
            <thead>
                <MudTr>
                    <MudTh>Acción inmediata tomada</MudTh>
                    <MudTh></MudTh>
                </MudTr>
            </thead>
            <tbody>
                <MudTr>
                    <MudTd Class="justify-center">
                        Mejora identificada
                        <MudTextField T="string" Placeholder="Explicar el punto crítico y confirmar que lo haga de acuerdo a la HOE" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                    </MudTd>
                    <MudTd>
                        Comentario / Firma del operador
                        <MudTextField T="string" Placeholder="Requiero de mejor iluminación en mi distribución" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                    </MudTd>
                </MudTr>
            </tbody>
        </MudSimpleTable>
    </MudItem>
</MudGrid>

