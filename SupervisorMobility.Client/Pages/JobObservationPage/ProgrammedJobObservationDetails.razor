<MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
    <MudItem lg="10" md="12" sm="12" xs="12">
        <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
            <MudItem Class="d-flex justify-space-between pa-1 ma-1 mt-6">
                <MudItem Style="text-align: start">
                    @if (searchAssychart)
                    {
                    <MudItem Class="d-flex flex-row align-start justify-center">

                        @if (_assychart.GOS != "")
                        {
                            <MudButton @onclick="(() => OpenDialogGOS(_assychart.GOS))" Style="padding: 0px;" Color="Color.Error">
                                    <MudTooltip Text=@Localizer["openGOSFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogGOS(_assychart.GOS))">
                                    <MudTooltip Text="@_assychart.GOS" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true">
                                        <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@_assychart.GOS.Split('/').Last()</MudChip>
                                    </MudTooltip>
                                </MudTooltip>
                            </MudButton>
                        }
                        else
                        {
                                <MudAlert Severity="Severity.Info">@Localizer["noGOSPath"]</MudAlert>
                        }

                        @if (_assychart.CCP != "")
                        {
                            <MudButton @onclick="(() => OpenDialogCcp(_assychart.CCP))" Style="padding: 0px;" Color="Color.Error">
                                    <MudTooltip Text=@Localizer["openCCPFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogCcp(_assychart.CCP))">
                                    <MudTooltip Text="@_assychart.CCP" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true">
                                        <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@_assychart.CCP.Split('/').Last()</MudChip>
                                    </MudTooltip>
                                </MudTooltip>
                            </MudButton>
                        }
                        else
                        {
                                <MudAlert Severity="Severity.Info">@Localizer["noCCPPath"]</MudAlert>
                        }

                        @if (_assychart.HOE != "")
                        {
                            <MudButton @onclick="(() => OpenDialogHoe(_assychart.HOE))" Style="padding: 0px;" Color="Color.Error">
                                    <MudTooltip Text=@Localizer["openHOEFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogHoe(_assychart.HOE))">
                                    <MudTooltip Text="@_assychart.HOE.Replace('§',' ')" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true">
                                        <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@_assychart.HOE.Split('§').Last()</MudChip>
                                    </MudTooltip>
                                </MudTooltip>
                            </MudButton>
                        }
                        else
                        {
                                <MudAlert Severity="Severity.Info">@Localizer["noHOEPath"]</MudAlert>
                        }

                    </MudItem>
                    }
                    else
                    {
                        if (messageErrorFolders != "")
                        {
                            <MudItem class="d-flex flex-column justify-center align-self-start">
                                <MudText Typo="Typo.h6" Class="align-item-center center">@messageErrorFolders</MudText>
                            </MudItem>
                        }
                        else
                        {
                            <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
                        }

                    }
                </MudItem>
                <MudItem Style="text-align: end">
                    <MudChip Variant="Variant.Text" Color="Color.Info" Class="pl-3" OnClick="@history" Icon="@Icons.Material.Filled.History">@Localizer["historyVersions"]</MudChip>

                </MudItem>
            </MudItem>
            <MudText Typo="Typo.h6" Class="mt-5">
                @Localizer["jobObservacionCiclycalCard"] @_jobObservation.JobObservationId
                <MudChip Variant="Variant.Text" Color="Color.Surface" Class="pl-3">@Localizer["sosReviewProgram"]</MudChip>
                <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Style="cursor:pointer">@Localizer["programmed"]</MudChip>
            </MudText>
        </MudItem>
        <MudPaper Class="" Elevation="0">
            <MudItem Class="ml-2">
                <MudSimpleTable Dense="@dense" Hover="@hover" ReadOnly="@ronly"
                                HorizontalScrollbar="true">
                    <tbody>
                        <tr>
                            <td style="width:50%">
                                @*Mud select of Plants*@
                                <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.PlantId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservation.PlantId">@_jobObservation.Plant?.Code - @_jobObservation.Plant?.Description</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td class="d-flex">
                                <MudDatePicker @bind-Date="_jobObservation.StartDate" Label=@Localizer["startDate"] Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4 pt-2"  />
                                <MudDatePicker @bind-Date="_jobObservation.EndDate" Label=@Localizer["endDate"] Color="Color.Info" AdornmentColor="Color.Info" MinDate="_jobObservation.StartDate" Class="pt-2" />
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @*Mud select of Areas *@
                                <MudSelect T="int" Label=@Localizer["area"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.AreaId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservation.AreaId">@_jobObservation.Area?.Code - @_jobObservation.Area?.Description</MudSelectItem>
                                </MudSelect>
                            </td>
                            <td >
                                <MudTextField T="string" @bind-Value="_jobObservation.Supervisor.Name" Label=@Localizer["observer"] Class="mr-4" />
@*                              <MudTimePicker Label="Start hour" @bind-Time="startHour" Color="Color.Info" AdornmentColor="Color.Info" Class="mr-4 pt-2" ReadOnly/>
                                <MudTimePicker Label="End hour" @bind-Time="endHour" Color="Color.Info" AdornmentColor="Color.Info" Class="pt-2" ReadOnly />*@
                            </td>
                        </tr>
                        <tr>
                            <td class="d-flex">
                                @*Mud select of Distribution *@
                                <MudSelect T="int" Label=@Localizer["distribution"] Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.DistributionId">
                                    <MudSelectItem Disabled="true" Value="@_jobObservation.DistributionId">@_jobObservation.Distribution?.Code - @_jobObservation.Distribution?.Description</MudSelectItem>
                                </MudSelect>
                                @*Mud select of Operations *@
                                <MudSelect T="int" Label=@Localizer["operation"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperationId" For="@(() => _jobObservation.OperationId)">
                                    <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnOperation"]</MudSelectItem>
                                    @foreach (var type in _operations)
                                    {
                                        <MudSelectItem Value="type.OperationId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                    }
                                </MudSelect>
                            </td>
                            <td>
                                @*Mud select for Operator *@
                                <MudSelect T="int" Label=@Localizer["operator"] Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_jobObservation.OperatorId" For="@(() => _jobObservation.OperatorId)">
                                    <MudSelectItem Disabled="true" Value="0">@Localizer["selectAnOperator"]</MudSelectItem>
                                    @foreach (var type in operatorUsers)
                                    {
                                        <MudSelectItem Value="type.UserId">@($"{type.Name}")</MudSelectItem>
                                    }
                                </MudSelect>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" style="text-align: center;">
                                <MudRadioGroup @bind-SelectedOption="_jobObservation.Option">
                                    <MudRadio Option="1" Color="Color.Info" Size="Size.Small" >@Localizer["verifyTraining"]</MudRadio>
                                    <MudRadio Option="2" Color="Color.Info" Size="Size.Small" >@Localizer["mantainAndOrImproveTheWorkArea"]</MudRadio>
                                    <MudRadio Option="3" Color="Color.Info" Size="Size.Small" >
                                        @if (_glosaryInfo != null && _glosaryInfo.ContainsKey("Management of the anomaly"))
                                        {
                                            Glosary word;
                                            word = _glosaryInfo["Management of the anomaly"];
                                            <MudTooltip Text="@word.Description" Arrow="true" Placement="Placement.Top" Color="Color.Info">
                                                <MudBadge Dot=true Color="Color.Info" Style="cursor: pointer">
                                                    <MudText>@Localizer["managementOfTheAnomaly"]</MudText>
                                                </MudBadge>
                                            </MudTooltip>
                                        }
                                        else
                                        {
                                            <span>@Localizer["managementOfTheAnomaly"]</span>
                                        }
                                    </MudRadio>
                                    @if (_jobObservation.Option == 3)
                                    {
                                        <MudTextField @bind-Value="_jobObservation.Anomaly" T="string" Label=@Localizer["writeTheAnomaly"] Placeholder=@Localizer["anomaly"] Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    }
                                </MudRadioGroup>

                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
        </MudPaper>

        <MudCardActions>
            <MudItem Class="ml-auto">
                <MudButton StartIcon="@Icons.Material.Filled.DateRange" Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => PlanNewJobObservation())">@Localizer["planJobObservation"]</MudButton>
            </MudItem>
        </MudCardActions>
    </MudItem>
</MudGrid>

<MudDialog DisableSidePadding="false" @bind-IsVisible="GosDialog" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    GOS @Localizer["rute"]:  @GOSrute
                </MudText>
            </MudItem>
            @if (GosFilesInFolder != null)
            {

                @if (GosFilesInFolder.operation.Count() > 0)
                {
                    @foreach (GOSDocument DocFile in GosFilesInFolder.operation)
                    {

                        <MudPaper Class="mr-5 mt-5" style="flex: 0 0 calc(28% - 1rem);">
                            <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center mt-5">
                                @switch (DocFile.Extension)
                                {
                                    case "pdf":
                                        <img src="Images/pdf.png" Height="70" Width="70" />

                                        break;
                                    case "doc":
                                        // Para documentos Word con extensión .doc
                                        <img src="Images/doc.png" Height="70" Width="70" />
                                        break;

                                    case "docx":
                                        <img src="Images/docx.png" Height="70" Width="70" />
                                        // Para documentos Word con extensión .docx
                                        break;

                                    case "ppt":
                                        <img src="Images/ppt.png" Height="70" Width="70" />

                                        // Para presentaciones PowerPoint con extensión .ppt
                                        break;

                                    case "pptx":
                                        <img src="Images/pptx.png" Height="70" Width="70" />
                                        // Para presentaciones PowerPoint con extensión .pptx
                                        break;

                                    case "xls":
                                        // Para hojas de cálculo Excel con extensión .xls
                                        <img src="Images/xls.png" Height="70" Width="70" />
                                        break;

                                    case "xlsx":
                                        // Para hojas de cálculo Excel con extensión .xlsx
                                        <img src="Images/xlsx.png" Height="70" Width="70" />
                                        break;

                                    case "jpg":
                                        <img src="Images/jpg.png" Height="70" Width="70" />
                                        break;

                                    case "jpeg":
                                        // Para imágenes JPEG con extensión .jpg o .jpeg
                                        <img src="Images/jpg.png" Height="70" Width="70" />
                                        break;

                                    case "png":
                                        // Para imágenes PNG con extensión .png
                                        <img src="Images/png.png" Height="70" Width="70" />
                                        break;

                                    case "gif":
                                        // Para imágenes GIF con extensión .gif
                                        <img src="Images/gif.png" Height="70" Width="70" />
                                        break;
                                    default:
                                        <img src="Images/error.png" Height="70" Width="70" />
                                        break;
                                }
                                <MudTooltip Text=@Localizer["download"] Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true">
                                    <MudButton @onclick="() => DownloadFileFromURL_GOS(DocFile.URL, DocFile.Nombre)">
                                        <MudItem>
                                            <MudChip Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer;max-width: 315px" Icon="@Icons.Material.Filled.Download" Text="@DocFile.Nombre" Color="Color.Info" />
                                        </MudItem>
                                    </MudButton>
                                </MudTooltip>
                            </MudItem>

                        </MudPaper>
                    }
                }
                else
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                }

            }
            else
            {
                if (folderError)
                {
                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                            <img src="Images/dialogerror.png" Height="140" Width="140" />
                        </MudItem>

                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["alert"] </MudText>

                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["serverNotResponse"]</MudText>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                }
                else
                {
                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                            <img src="Images/dialogerror.png" Height="140" Width="140" />
                        </MudItem>

                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["alert"] </MudText>

                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["dataNotFound"]</MudText>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                }
            }



        </MudContainer>
    </DialogContent>
    <DialogActions>
        @*<MudIconButton @onclick="(() => JobObservationUpdate(jobId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>*@
        <MudButton Color="Color.Info" OnClick="CloseGos">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>

