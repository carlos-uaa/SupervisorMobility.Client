                                        @Localizer["signed"]
                                </MudChip>
                                }
                                else
                                {
                                <MudChip Class="mr-10" Icon="@Icons.Material.Filled.AssignmentLate" Color="Color.Warning" Variant="Variant.Text">
                                        @Localizer["unsignedOnlySSVCanSignIt"]
                                </MudChip>
                                }
                            <MudText Style="text-align:center; font-weight:bold;">
                                    @Localizer["operatorsSignature"]
                            </MudText>
                            <MudTextField T="string" @bind-Value="_jobObservation.OperatorSignature" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </td>
                    </tr>
                    </tbody>
                </MudSimpleTable>
            </MudItem>
            @*            <MudCardActions>
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Create Job Observation</MudButton>
            <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateJobObservation())">Cancel</MudButton>
            </MudCardActions>
            *@

            <MudCardActions>
                <MudItem Class="ml-auto">

                    <MudButton ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.PlayCircle" Variant="Variant.Filled" Color="Color.Info" Class="ml-4">@Localizer["createJobObservation"]</MudButton>
                    <MudButton StartIcon="@Icons.Material.Filled.StopCircle" Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => SaveProgressJobObservation())">@Localizer["saveProgress"]</MudButton>
                    <MudButton StartIcon="@Icons.Material.Filled.IncompleteCircle" Variant="Variant.Filled" Color="Color.Info" Class="ml-4" @onclick="(() => UnderReviewJobObservation())">@Localizer["underReview"]</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateJobObservation())">@Localizer["cancel"]</MudButton>
