@*Past modal*@
<MudDialog DisableSidePadding="false" @bind-IsVisible="visiblePast" Options="dialogPastJobObservations">
    <DialogContent>
        <MudContainer Style="max-height: 75vh; min-height:50vh; overflow-y: scroll">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    @Localizer["pastJobObservationLup"]
                </MudText>
                <MudText>
                    <MudChip Color="Color.Info" Variant="Variant.Text">@distribution.Description</MudChip>
                    <MudChip Color="Color.Info" Variant="Variant.Text">@operation.Description</MudChip>

                </MudText>
            </MudItem>
            @if (pastjobObservations.Count > 0)
            {
                <MudTable Items="pastjobObservations" T="JobObservation" Bordered Class="mt-3 past-jobObservations-table mb-10">
                    <HeaderContent>
                        <MudTh style="text-align: center">
                            <MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.JobObservationId)">Id</MudTableSortLabel>
                        </MudTh>
                        <MudTh style="text-align: center"><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.StartDate)">@Localizer["startDate"]</MudTableSortLabel></MudTh>
                        <MudTh style="text-align: center; width: 65%">@Localizer["totalLup"]</MudTh>
                        <MudTh style="text-align: center"><MudTableSortLabel SortBy="new Func<JobObservation, object>(x=>x?.Status)">@Localizer["status"]</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudTooltip Text=@Localizer["goToJobObservation"] Arrow="true" Placement="Placement.Right" Color="Color.Info">
                                <MudChip Variant="Variant.Text" Color="Color.Info" Size="Size.Small" @onclick="(() => GoToJobObservation(context.JobObservationId))"> @context.JobObservationId</MudChip>
                            </MudTooltip>
                        </MudTd>
                        <MudTd>
                            <MudText>@context.StartDate?.ToShortDateString()</MudText>
                        </MudTd>
                        <MudTd>
                            <MudText>
                                @if (pastLup.Count > 0)
                                {
                                    @foreach (var lup in pastLup)
                                    {
                                        if (lup.JobObservationId == context.JobObservationId)
                                        {
                                            <MudTooltip Text="@lup.LupId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true">
                                                <MudButton Style="padding: 0px; margin-right: 10px; margin-top: 10px" Color="Color.Info" Variant="Variant.Outlined" @onclick="(() => OpenDialogLup(lup.LupId))">
                                                    <MudChip Color="Color.Info" OnClose="Closed" Size="Size.Small" CloseIcon="@Icons.Material.Filled.ChecklistRtl" Variant="Variant.Text" Style="cursor:pointer">
                                                        @switch (lup.Pillar)
                                                        {
                                                            case 1:
                                                                <span>S | &nbsp;</span>
                                                                break;
                                                            case 2:
                                                                <span>Q | &nbsp;</span>
                                                                break;
                                                            case 3:
                                                                <span>D | &nbsp;</span>
                                                                break;
                                                            case 4:
                                                                <span>C | &nbsp;</span>
                                                                break;
                                                            case 5:
                                                                <span>@Localizer["other"] | &nbsp;</span>
                                                                break;
                                                        }
                                                        @if (lup.Oportunity.Length < 70)
                                                        {
                                                            @lup.Oportunity
                                                        }
                                                        else
                                                        {
                                                            @lup.Oportunity.Substring(0,70) <span>...</span>
                                                        }
                                                    </MudChip>
                                                    @switch (lup.Status)
                                                    {
                                                        case 1:
                                                            <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small">@Localizer["new"]</MudChip>
                                                            break;
                                                        case 2:
                                                            <MudChip Variant="Variant.Text" Color="Color.Success" Size="Size.Small">@Localizer["inProgress"]</MudChip>
                                                            break;
                                                        case 3:
                                                            <MudChip Variant="Variant.Text" Color="Color.Warning" Size="Size.Small">@Localizer["finished"]</MudChip>
                                                            break;
                                                        case 4:
                                                            <MudChip Variant="Variant.Text" Color="Color.Error" Size="Size.Small">@Localizer["canceled"]</MudChip>
                                                            break;
                                                    }
                                                </MudButton>
                                            </MudTooltip>
                                        }
                                    }
                                }
                            </MudText>
                        </MudTd>
                        <MudTd>
                            <MudText>

                                @switch (context.Status)
                                {
                                    case 1:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlayCircle" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">@Localizer["planned"]</MudChip>
                                        break;
                                    case 2:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info" Size="Size.Small" Style="cursor:pointer">@Localizer["inProgress"]</MudChip>
                                        break;
                                    case 3:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" Size="Size.Small" Style="cursor:pointer">@Localizer["late"]</MudChip>
                                        break;
                                    case 4:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.IncompleteCircle" Color="Color.Info" Style="cursor:pointer">@Localizer["underReview"]</MudChip>
                                        break;
                                    case 5:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Style="cursor:pointer">@Localizer["rejected"]</MudChip>
                                        break;
                                    case 6:
                                        <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.Circle" Color="Color.Success" Style="cursor:pointer">@Localizer["finished"]</MudChip>
                                        break;
                                }
                            </MudText>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudItem Style="text-align: center; margin-top: 100px">
                    <MudText Typo="Typo.h6">
                        @Localizer["thereAreNoPastJobObservations"]
                    </MudText>
                </MudItem>
            }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="CloseOverdue">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>


<MudDialog DisableSidePadding="false" @bind-IsVisible="GosDialog" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    GOS @Localizer["rute"]:  @GOSrute
                </MudText>
            </MudItem>
            @if (GosFilesInFolder != null)
            {

                @if (GosFilesInFolder.operation.Count() > 0)
                {
                    @foreach (GOSDocument DocFile in GosFilesInFolder.operation)
                    {

                        <MudPaper Class="mr-5 mt-5" style="flex: 0 0 calc(28% - 1rem);">
                            <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center mt-5">
                                @switch (DocFile.Extension)
                                {
                                    case "pdf":
                                        <img src="Images/pdf.png" Height="70" Width="70" />

                                        break;
                                    case "doc":
                                        // Para documentos Word con extensión .doc
                                        <img src="Images/doc.png" Height="70" Width="70" />
                                        break;

                                    case "docx":
                                        <img src="Images/docx.png" Height="70" Width="70" />
                                        // Para documentos Word con extensión .docx
                                        break;

                                    case "ppt":
                                        <img src="Images/ppt.png" Height="70" Width="70" />

                                        // Para presentaciones PowerPoint con extensión .ppt
                                        break;

                                    case "pptx":
                                        <img src="Images/pptx.png" Height="70" Width="70" />
                                        // Para presentaciones PowerPoint con extensión .pptx
                                        break;

                                    case "xls":
                                        // Para hojas de cálculo Excel con extensión .xls
                                        <img src="Images/xls.png" Height="70" Width="70" />
                                        break;

                                    case "xlsx":
                                        // Para hojas de cálculo Excel con extensión .xlsx
                                        <img src="Images/xlsx.png" Height="70" Width="70" />
                                        break;

                                    case "jpg":
                                        <img src="Images/jpg.png" Height="70" Width="70" />
                                        break;

                                    case "jpeg":
                                        // Para imágenes JPEG con extensión .jpg o .jpeg
                                        <img src="Images/jpg.png" Height="70" Width="70" />
                                        break;

                                    case "png":
                                        // Para imágenes PNG con extensión .png
                                        <img src="Images/png.png" Height="70" Width="70" />
                                        break;

                                    case "gif":
                                        // Para imágenes GIF con extensión .gif
                                        <img src="Images/gif.png" Height="70" Width="70" />
                                        break;
                                    default:
                                        <img src="Images/error.png" Height="70" Width="70" />
                                        break;
                                }
                                <MudTooltip Text=@Localizer["download"] Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true">
                                    <MudButton @onclick="() => DownloadFileFromURL_GOS(DocFile.URL, DocFile.Nombre)">
                                        <MudItem>
                                            <MudChip Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer;max-width: 315px" Icon="@Icons.Material.Filled.Download" Text="@DocFile.Nombre" Color="Color.Info" />
                                        </MudItem>
                                    </MudButton>
                                </MudTooltip>
                            </MudItem>

                        </MudPaper>
                    }
                }
                else
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                }

            }
            else
            {
                if (folderError)
                {
                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                            <img src="Images/dialogerror.png" Height="140" Width="140" />
                        </MudItem>

                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["alert"] </MudText>

                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["serverNotResponse"]</MudText>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                }
                else
                {
                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                            <img src="Images/dialogerror.png" Height="140" Width="140" />
                        </MudItem>

                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["alert"] </MudText>

                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["dataNotFound"]</MudText>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                }
            }



        </MudContainer>
    </DialogContent>
    <DialogActions>
        @*<MudIconButton @onclick="(() => JobObservationUpdate(jobId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>*@
        <MudButton Color="Color.Info" OnClick="CloseGos">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>

