                                                                                        <MudChip Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer;max-width: 280px; white-space: normal; overflow-wrap: break-word;" Icon="@Icons.Material.Filled.Download" Text="@DocFile.Nombre" Color="Color.Info" />
                                                                                    </MudItem>
                                                                                </MudButton>
                                                                            </MudTooltip>
                                                                        </MudItem>

                                                                    </MudPaper>
                                                                }
                                                            }
                                                        }
                                                        else
                                                        {
                                                            if (item.Has_Files)
                                                            {
                                                                <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                                                                        <img src="Images/dialogerror.png" Height="140" Width="140" />
                                                                    </MudItem>

                                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                                        <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name"> @Localizer["ServerNotResponse"]</MudText>
                                                                            </MudItem>
                                                                        </MudItem>
                                                                    </MudItem>
                                                            }
                                                            else
                                                            {
                                                                <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                                                                        <img src="Images/dialogerror.png" Height="140" Width="140" />
                                                                    </MudItem>

                                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                                        <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["DataNotFound"]</MudText>
                                                                            </MudItem>
                                                                        </MudItem>
                                                                    </MudItem>
                                                            }
                                                        }
                                                    }
                                                </ChildContent>
                                            </MudTabPanel>
                                        }
                                    </ChildContent>

                                </MudTabs>

                            }
                            else
                            {
                                @if (Node_CCP_CD.showLoadingFiles)
                                {
                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                }
                                else
                                {
                                    @if (Node_CCP_CD.Has_Files)
                                    {
                                        @if (Node_CCP_CD.Files_In_Node_CCP.operation.Count() > 0)
                                        {
                                            @foreach (CCPDocument DocFile in Node_CCP_CD.Files_In_Node_CCP.operation)
                                            {
                                                <MudPaper Class="mr-5 mt-5" style="flex: 0 0 calc(28% - 1rem);">
                                                    <MudItem style="text-align:center; display: flex; justify-content: center;" Class="mt-5">
                                                        @switch (DocFile.Extension)
                                                        {
                                                            case "pdf":
                                                                <img src="Images/pdf.png" Height="35" Width="35" />
                                                                break;
                                                            case "doc":
                                                                <img src="Images/doc.png" Height="35" Width="35" />
                                                                break;
                                                            case "docx":
                                                                <img src="Images/docx.png" Height="35" Width="35" />
                                                                break;
                                                            case "ppt":
                                                                <img src="Images/ppt.png" Height="35" Width="35" />
                                                                break;
                                                            case "pptx":
                                                                <img src="Images/pptx.png" Height="35" Width="35" />
                                                                break;
                                                            case "xls":
                                                                <img src="Images/xls.png" Height="35" Width="35" />
                                                                break;
                                                            case "xlsx":
                                                                <img src="Images/xlsx.png" Height="35" Width="35" />
                                                                break;
                                                            case "jpg":
                                                                <img src="Images/jpg.png" Height="35" Width="35" />
                                                                break;
                                                            case "jpeg":
                                                                <img src="Images/jpg.png" Height="35" Width="35" />
                                                                break;
                                                            case "png":
                                                                <img src="Images/png.png" Height="35" Width="35" />
                                                                break;
                                                            case "gif":
                                                                <img src="Images/gif.png" Height="35" Width="35" />
                                                                break;
                                                            default:
                                                                <img src="Images/error.png" Height="35" Width="35" />
                                                                break;
                                                        }
                                                        <MudTooltip Text="Download" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true">
                                                            <MudButton OnClick="() => DownloadFileFromURL_CCP(DocFile.URL, DocFile.Nombre)">
                                                                <MudItem>
                                                                    <MudChip Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer;max-width: 280px; white-space: normal; overflow-wrap: break-word;" Icon="@Icons.Material.Filled.Download" Text="@DocFile.Nombre" Color="Color.Info" />
                                                                </MudItem>
                                                            </MudButton>
                                                        </MudTooltip>
                                                    </MudItem>

                                                </MudPaper>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        if (Node_CCP_CD.Has_Files)
                                        {
                                            <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                                                <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                                                    <img src="Images/dialogerror.png" Height="140" Width="140" />
                                                </MudItem>

                                                <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                    <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                        <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                            <MudText Typo="Typo.h6" Align="Align.Center" Label="Name"> @Localizer["ServerNotResponse"]</MudText>
                                                        </MudItem>
                                                    </MudItem>
                                                </MudItem>
                                        }
                                        else
                                        {
                                            <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                                                <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                                                    <img src="Images/dialogerror.png" Height="140" Width="140" />
                                                </MudItem>

                                                <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                    <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                        <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                            <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["DataNotFound"]</MudText>
                                                        </MudItem>
                                                    </MudItem>
                                                </MudItem>
                                        }
                                    }
                                }

                            }
                        </MudCardContent>
                    </MudCard>
                </ChildContent>
            </MudTabPanel>
        }
        

    </MudTabs>
}
