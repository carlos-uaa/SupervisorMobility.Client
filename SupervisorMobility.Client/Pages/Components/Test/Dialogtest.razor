@page "/TestDialog"
@inject IDialogService DialogService
<MudButton OnClick="OpenDialog" StartIcon="@Icons.Material.Filled.PlayCircle" Variant="Variant.Filled" Color="Color.Info" Class="ml-4">OpenDialog</MudButton>
@code {
    private DialogOptions options = new DialogOptions() { CloseOnEscapeKey = false, DisableBackdropClick = true, CloseButton = false };

    private async void OpenDialog()
    {
        var dialog = await DialogService.ShowAsync<Signature_dialog>("Sign", options);
        var result = await dialog.Result;
    }
}
