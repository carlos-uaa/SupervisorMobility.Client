@page "/draw"
@using System.Drawing
@implements IDisposable
@inject IJSRuntime JS

<canvas id="SignatureRef" height="200" width="500" @ref="canvasRef" />

@code {
    private ElementReference canvasRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Console.WriteLine(canvasRef.Id);
            await JS.InvokeVoidAsync("SignatureCanvasOperations.initializeCanvas", "SignatureRef");
        }
    }

    public void Dispose()
    {
        // Cleanup if needed
    }
}
