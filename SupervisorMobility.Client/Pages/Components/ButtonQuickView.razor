@inject IStringLocalizer<Resource1> Localizer

<style>
    .buttonQuickView {
        text-decoration: none;
        line-height: 1;
        border-radius: 1.5rem;
        overflow: hidden;
        position: relative;
        box-shadow: 10px 10px 20px rgba(0,0,0,.05);
        background-color: #fff;
        color: #121212;
        border: none;
        cursor: pointer;
    }

    .buttonQuickView-decor {
        position: absolute;
        inset: 0;
        background-color: var(--clr);
        transform: translateX(-100%);
        transition: transform .3s;
        z-index: 0;
    }

    .buttonQuickView-content {
        display: flex;
        align-items: center;
        font-weight: 600;
        position: relative;
        overflow: hidden;
    }

    .buttonQuickView__icon {
        width: 48px;
        height: 40px;
        background-color: var(--mud-palette-primary);
        display: grid;
        place-items: center;
    }

    .buttonQuickView__text {
        display: inline-block;
        transition: color .2s;
        padding: 2px 1.5rem 2px;
        padding-left: .75rem;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
        max-width: 150px;
    }

    .buttonQuickView:hover .buttonQuickView__text {
        color: #fff;
    }

    .buttonQuickView:hover .buttonQuickView-decor {
        transform: translate(0);
    }

</style>

@code {

    [Parameter]
    public EventCallback OnClick { get; set; } // Evento OnClick

    [Parameter]
    public string ButtonText { get; set; }
}

<button class="buttonQuickView" style="--clr: var(--mud-palette-primary);" @onclick="OnClick" @ontouchstart="OnClick">
    <span class="buttonQuickView-decor"></span>
    <div class="buttonQuickView-content">
        <div class="buttonQuickView__icon">
            <MudIcon Icon="@Icons.Material.Filled.Info" Title="Info" Color="Color.Default" />
        </div>
        <span class="buttonQuickView__text">@ButtonText</span>
    </div>
</button>


