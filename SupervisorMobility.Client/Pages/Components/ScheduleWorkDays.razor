@page "/workdays"
@using System.Runtime.CompilerServices
@using System.Globalization
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1

@inject ICalendarProductiveService CalendarProductiveServices

<style>
    /* Contenedor principal */
    .calendar-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
    }

    .mud-tooltip-root {
        width: auto !important;
    }

    /* Contenedor del mes */
    .month-container {
        min-width: 300px;
    }

    /* Días de la semana */
    .weekdays {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        text-align: center;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .weekday {
        padding: 5px;
    }

    /* Grid de días */
    .days-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
    }

    /* Estilos para las celdas de día */
    .day-cell {
        height: 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border-radius: 4px;
        margin: 1px;
        padding: 2px;
        transition: all 0.2s;
    }

    .empty-day {
        visibility: hidden;
    }

    .weekend-day {
        background-color: #f5f5f5;
        color: #9e9e9e;
    }

    .operation-day {
        font-weight: bold;
        color: #333;
    }

    .holiday-day {
        background-color: #fdd;
        border: 1px solid #f99;
    }

    .day-number {
        font-size: 0.9rem;
    }

    .operation-text {
        font-size: 0.6rem;
        line-height: 1;
    }

    /* Leyenda */
    .legend-container {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .legend-color {
        width: 16px;
        height: 16px;
        border-radius: 3px;
        border: 1px solid #ddd;
    }

</style>


<MudDivider Class="my-3" />



@if (ShowLoading)
{
    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
        <ItemTemplate>
            <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                <MudItem class="d-flex flex-column justify-center align-self-center">
                    <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                </MudItem>
                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
            </div>
        </ItemTemplate>
    </MudCarousel>
}
else
{
    <div class="calendar-container">
        @foreach (var month in CalendarMonths)
        {
            <MudPaper Elevation="2" Class="month-container pa-2 mb-4">
                <MudText Typo="Typo.h6" Class="text-center mb-2">@month.MonthName.ToUpper()</MudText>

                <!-- Días de la semana -->
                <div class="weekdays">
                    @foreach (var day in new[] { "S", "M", "T", "W", "T", "F", "S" })
                    {
                        <div class="weekday">@day</div>
                    }
                </div>

                <!-- Días del mes -->
                <div class="days-grid">
                    @foreach (var day in month.Days)
                    {
                        @if (day.IsHoliday)
                        {
                            <MudTooltip Text="@day.Description" style="width:auto !important">
                                <div class="@GetDayClasses(day)">
                                    <div class="day-number">@day.DayNumber</div>
                                </div>
                            </MudTooltip>
                        }
                        else
                        {
                            <div class="@GetDayClasses(day)">
                                <div class="day-number">@day.DayNumber</div>
                            </div>
                        }
                    }
                </div>
            </MudPaper>
        }
    </div>

    @if((bool)IsMonth){
        <MudTable Items="ImportedHolidays.Where(d => d.Date.Month == DateTime.Now.Month)" Dense="true" FixedHeader Style="max-height: 20dvh" Height="15dvh">
            <HeaderContent>
                <MudTh>Dia</MudTh>
                <MudTh>Descripción</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    @context.Date.ToString("dd")
                </MudTd>
                <MudTd>
                    @context.Description
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}
@code {
    [Parameter]
    public int? ScheduleYear { get; set; }

    [Parameter]
    public bool? IsMonth { get; set; } = false;
    // Modelo para el calendario
    private List<MonthModel> CalendarMonths = new List<MonthModel>();


    private List<Holiday> ImportedHolidays = new List<Holiday>();

    private IList<string> _sourceMsgLoading = new List<string>();
    private IList<MudBlazor.Color> _Colors = new List<MudBlazor.Color>() { MudBlazor.Color.Default, MudBlazor.Color.Primary, MudBlazor.Color.Secondary, MudBlazor.Color.Success, MudBlazor.Color.Info, MudBlazor.Color.Default, MudBlazor.Color.Primary, MudBlazor.Color.Secondary, MudBlazor.Color.Success, MudBlazor.Color.Info };
    public bool ShowLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _sourceMsgLoading.Add($"{Localizer1["Loading1"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading2"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading3"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading4"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading5"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading6"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading7"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading8"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading9"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading10"]}");
        _sourceMsgLoading.Add($"{Localizer1["Loading11"]}");


        if (ScheduleYear == null)
        {
            ScheduleYear = DateTime.Now.Year;
        }
        ImportedHolidays = await CalendarProductiveServices.GetHolidaysInService((int)ScheduleYear);

        await GenerateCalendar();

        ApplyHolidaysToCalendar();

        ShowLoading = false;
    }


    private async Task<AsyncVoidMethodBuilder> GenerateCalendar()
    {
        CalendarMonths.Clear();
        var calendarMonths = new List<MonthModel>();

        if (IsMonth == true)
        {
            // Solo generar el mes actual si IsMonth es true
            var currentMonth = DateTime.Now.Month;
            DateTime monthStart = new DateTime(ScheduleYear.Value, currentMonth, 1);
            calendarMonths.Add(CreateMonthModel(monthStart));
        }
        else
        {
            // Generar todos los meses
            for (int i = 0; i < 12; i++)
            {
                DateTime monthStart = new DateTime((int)ScheduleYear, 1, 1).AddMonths(i);
                calendarMonths.Add(CreateMonthModel(monthStart));
            }
        }
        CalendarMonths = calendarMonths;
        return new AsyncVoidMethodBuilder();
    }

    // Modelos para el calendario
    private class MonthModel
    {
        public string MonthName { get; set; }
        public int Year { get; set; }
        public List<DayModel> Days { get; set; }
    }

    private class DayModel
    {
        public int DayNumber { get; set; }
        public DateTime Date { get; set; }
        public bool IsWeekend { get; set; }
        public bool IsEmpty { get; set; }
        public bool IsHoliday { get; set; }
        public string Description { get; set; }
    }

    private MonthModel CreateMonthModel(DateTime monthStart)
    {
        var monthModel = new MonthModel
            {
                MonthName = monthStart.ToString("MMMM"),
                Year = monthStart.Year,
                Days = new List<DayModel>()
            };

        int daysInMonth = DateTime.DaysInMonth(monthStart.Year, monthStart.Month);

        var firstDay = new DateTime(monthStart.Year, monthStart.Month, 1);
        var lastDay = firstDay.AddMonths(1).AddDays(-1);

        // Días vacíos al inicio
        int firstDayOfWeek = (int)firstDay.DayOfWeek;
        for (int i = 0; i < firstDayOfWeek; i++)
        {
            monthModel.Days.Add(new DayModel { IsEmpty = true });
        }

        for (int day = 1; day <= lastDay.Day; day++)
        {
            var date = new DateTime(monthStart.Year, monthStart.Month, day);
            bool isWeekend = date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;

            monthModel.Days.Add(new DayModel
                {
                    DayNumber = day,
                    Date = date,
                    IsWeekend = isWeekend
                });
        }

        return monthModel;
    }


    private string GetDayClasses(DayModel day)
    {
        var classes = new List<string> { "day-cell" };

        if (day.IsEmpty)
        {
            classes.Add("empty-day");
        }
        else if (day.IsWeekend)
        {
            classes.Add("weekend-day");
        }

        if (day.IsHoliday)
        {
            classes.Add("holiday-day");
        }

        return string.Join(" ", classes);
    }





    private void ApplyHolidaysToCalendar()
    {
        var holidayDates = ImportedHolidays.Select(h => h.Date.Date).ToHashSet();

        foreach (var month in CalendarMonths)
        {
            foreach (var day in month.Days)
            {
                if (!day.IsEmpty && holidayDates.Contains(day.Date.Date))
                {
                    day.IsHoliday = true;
                    day.Description = ImportedHolidays.FirstOrDefault(h => h.Date.Date == day.Date.Date)?.Description;
                }
            }
        }
    }



