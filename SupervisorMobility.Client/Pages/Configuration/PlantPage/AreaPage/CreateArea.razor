@page "/plants/{plantId:int}/createarea"
@inject IAreaService AreaService
@inject IPlantService PlantService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService
@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["create"] @Localizer["area"]</PageTitle>

@*Breadcrumb links*@
@* <MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == "PlantDetail")
        {
            <MudButton @onclick="(() => CancelCreateOrUpdate())" Variant="Variant.Text" Color="Color.Info">@_plant.Description</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
