@*Form*@
<EditForm Model="_area" class="mt-10" OnValidSubmit="CreateAreaAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localizer["create"] @Localizer["area"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["newArea"]</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label=@Localizer["description"]
                                  @bind-Value="_area.Description" For="@(() => _area.Description)" />
                    <MudTextField Label=@Localizer["code"] Class="mt-3"
                                  @bind-Value="_area.Code" For="@(() => _area.Code)" />
                    @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_area.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["save"]</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">@Localizer["cancel"]</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>
