@page "/plants/{plantId:int}/areas/{areaId:int}"
@inject IAreaService AreaService
@inject IPlantService PlantService
@inject IOperationService OperationService
@inject IDistributionService DistributionService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService

@*Title*@
<PageTitle>Supervisor Mobility | @_area.Description</PageTitle>

    @*Breadcrumb links*@
    @* <MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == Localizer["plantDetails"])
        {
            <MudButton @onclick="(() => GoToPlant())" Variant="Variant.Text" Color="Color.Info">@_plant.Description</MudButton>
        }
        else if (item.Text == Localizer["areaDetails"])
        {
            <MudButton Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@_area.Description</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs> *@

    @*Dashboard grid*@
    <MudGrid>
        @*Area info*@
     
    <MudItem xs="3" lg="3" md="3" sm="3" Class="mt-10">
        <MudCard>
            <MudCardContent Style="justify-content:center">
                <MudText Align="Align.Center"><MudIcon Icon="@Icons.Filled.Business"></MudIcon></MudText>
                <MudText Align="Align.Center">@_plant.Code</MudText>
                    <MudText Typo="Typo.h5" Align="Align.Center">@_plant.Description</MudText>
                    @if (_plant.IsActive == true)
                {
                    <MudText Align="Align.Center" Class="pt-2">
                        <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                        </MudText>
                }
                else
                {
                    <MudText Align="Align.Center" Class="pa-4">
                        <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                        </MudText>
                }
            </MudCardContent>
        </MudCard>
        <MudText Typo="Typo.h4" Style="text-align:center">
            <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowDown"></MudIcon>
        </MudText>
        <MudButton @onclick="(() => FunUpdateArea(PlantId, AreaId))" @ontouchstart="(() => FunUpdateArea(PlantId,AreaId))" FullWidth="true">
            <MudCard Style="display: block; height:100%; width: 100%">
                <MudCardHeader>
                    <CardHeaderActions>
                    </CardHeaderActions>
                    <CardHeaderContent>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"></MudIcon>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Style="justify-content:center">
                    <MudText Align="Align.Center"><MudIcon Icon="@Icons.Filled.Business"></MudIcon></MudText>
                    <MudText Align="Align.Center">@_area.Code</MudText>
                        <MudText Typo="Typo.h5" Align="Align.Center">@_area.Description</MudText>
                        @if (_area.IsActive == true)
                    {
                        <MudText Align="Align.Center" Class="pt-2">
                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                            </MudText>
                    }
                    else
                    {
                        <MudText Align="Align.Center" Class="pa-4">
                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                            </MudText>
                    }
                </MudCardContent>

            </MudCard>
        </MudButton>


    </MudItem>


    @*Related distributions*@
    <MudItem xs="12" sm="6" md="9">
        <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
            <MudTabPanel Icon="@Icons.Material.Filled.ContentPaste" Text=@Localizer["distributions"]>
                @if (_distributions.Count > 0)
                {
                    <MudTable Height="75vh" Items="_distributions" Hover="true" T="Distribution" Class="styled-table table-striped" FixedHeader=true RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" OnRowClick="RowClickEvent">
                        <ToolBarContent>
                            <MudSpacer />

                            <MudButton @onclick="(() => CreateDistribution())">
                                <MudText>@Localizer["create"] @Localizer["distribution"]</MudText>
                                    <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary"></MudIcon>
                                </MudButton>

                            </ToolBarContent>
                            <HeaderContent>
                                <MudTh>
                                    <MudTableSortLabel SortBy="new Func<Distribution, object>(x=>x.DistributionId)">
                                        @Localizer["distribution"] Id
                                </MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<Distribution, object>(x=>x.Code)">
                                    @Localizer["code"]
                                </MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<Distribution, object>(x=>x.Description)" InitialDirection="SortDirection.Ascending">
                                    @Localizer["description"]
                                </MudTableSortLabel>
                            </MudTh>

                            <MudTh>
                                <MudText Align="Align.Center">
                                    @Localizer["actions"]
                                </MudText>
                            </MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Id">
                                <MudText Align="Align.Center">@context.DistributionId</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["code"]>
                                    <MudText Align="Align.Center">@context.Code</MudText>
                                </MudTd>
                                <MudTd DataLabel=@Localizer["description"]>
                                    <MudText Align="Align.Center">@context.Description</MudText>
                                </MudTd>

                                <MudTd>
                                    <MudText Align="Align.Center">
                                        <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                            <ActivatorContent>
                                                <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                            </ActivatorContent>
                                            <ChildContent>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => DistributionDetails(context.DistributionId))" @ontouchstart="(() => DistributionDetails(context.DistributionId))">@Localizer["distributionDetails"]</MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdateDistribution(context.DistributionId))" @ontouchstart="(() => UpdateDistribution(context.DistributionId))">@Localizer["editDistribution"] </MudMenuItem>
                                                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => OpenDeleteDialog(context.DistributionId))" @ontouchstart="(() => OpenDeleteDialog(context.DistributionId))">@Localizer["deleteDistribution"]</MudMenuItem>
                                            </ChildContent>
                                        </MudMenu>
                                        @*                                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => DistributionDetails(context.DistributionId))"></MudIconButton>
                                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => UpdateDistribution(context.DistributionId))"></MudIconButton>
                                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => OpenDeleteDialog(context.DistributionId))"></MudIconButton>*@
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                }
                else
                {
                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">@Localizer["thereAreNoDistributionsCreatedForThisArea"]</MudText>
                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">
                        <MudButton Color="Color.Info" @onclick="(() => CreateDistribution())">@Localizer["createNewDistribution"]</MudButton>
                        </MudText>
                }
            </MudTabPanel>
        </MudTabs>
    </MudItem>
</MudGrid>


@*Delete Distribution modal*@
<MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
            <MudText Class="mt-4 mb-4">
                @Localizer["areYouSureYouWantToDeleteThisDistribution"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
            <MudButton @onclick="(() => DeleteDistribution(deleteDistributionId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">@Localizer["delete"]</MudButton>
        </DialogActions>
    </MudDialog>