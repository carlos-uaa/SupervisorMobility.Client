@page "/plants/{PlantId:int}/areas/{AreaId:int}/distributions/{DistributionId:int}/AddProductInDistribution"
@inject IProductService ProductServices
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["addExistingProduct"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@if(_products.Count > 0){

<EditForm Model="_distribution" OnValidSubmit="AddingProductAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localizer["addExistingProduct"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["addProduct"]</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Class="d-flex flex-row mb-5">
                        <MudSelect T="int" Label="@Localizer["product"]" Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@ProductId" For="@(() => ProductId)" SelectedValuesChanged="UpdateProductDisplay">
                        <MudSelectItem Disabled="true" Value="0">@Localizer["selectAProduct"]</MudSelectItem>
                            @foreach (var product in _products)
                            {
                                <MudSelectItem Value="product.ProductId">@($"{product.Code} - {product.Description}")</MudSelectItem>
                            }
                        </MudSelect>


                    </MudGrid>

                    @if (ProductId != 0)
                    {
                        <MudGrid Class="d-flex flex-column justify-center align-self-center">
                            <MudItem>
                                    <MudText Typo="Typo.h6">@Localizer["productDetails"]</MudText>

                            </MudItem>
                            <MudItem>
                                @if (useButton)
                                {
                                        <MudText Typo="Typo.h6">@Localizer["cannotAddThisProductBecauseIsAlreadyAdded"]</MudText>
                                }
                            </MudItem>
                            <MudItem>
                                    <MudTextField Label="@Localizer["description"]" Disabled
                                          @bind-Value="_product.Description" For="@(() => _product.Description)" />
                                    <MudTextField Label="@Localizer["code"]" Class="mt-3" Disabled
                                          @bind-Value="_product.Code" For="@(() => _product.Code)" />
                                @*<MudSwitch Class="mt-3" Label="Is active?" Disabled @bind-Checked="_product.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@

                            </MudItem>

                        </MudGrid>

                    }

                </MudCardContent>
                <MudCardActions>

                        <MudButton ButtonType="ButtonType.Submit" Disabled="useButton" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["addProduct"]</MudButton>
                        <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">@Localizer["cancel"]</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
    </EditForm>
}
else
{
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}

@code {
    [Parameter]
    public int PlantId { get; set; }
    [Parameter]
    public int AreaId { get; set; }
    [Parameter]
    public int DistributionId { get; set; }

    public int ProductId { get; set; } = 0;


    public bool useButton = true;

    public Plant _plant { get; set; }
    public Area _area { get; set; }
    public Distribution _distribution { get; set; }
    public Product _product = new();


    public List<Product> _products { get; set; } = new List<Product>();

    // Breadcrumb links
    private List<BreadcrumbItem> _links;


    protected override async Task OnParametersSetAsync()
    {
        _products = await ProductServices.GetProducts();
        _plant = await PlantServices.GetPlantById(PlantId);
        _area = await AreaServices.GetAreaById(PlantId, AreaId);
        _distribution = await DistributionServices.GetDistributionWithCollections(PlantId, AreaId, DistributionId);

        _links= new List<BreadcrumbItem>
        {
            new BreadcrumbItem(text: Localizer["home"], href: "/"),
            new BreadcrumbItem(text: Localizer["configuration"], href: "/configuration"),
        };


        _links.Add(new BreadcrumbItem($"{_plant.Description}", href: $"plants/{PlantId}"));
        _links.Add(new BreadcrumbItem($"{_area.Description}", href: $"plants/{PlantId}/areas/{AreaId}"));
        _links.Add(new BreadcrumbItem($"{_distribution.Description}", href: $"plants/{PlantId}/areas/{AreaId}/distributions/{DistributionId}"));
        _links.Add(new BreadcrumbItem(text: Localizer["addProduct"], href: "", disabled: true));

    }

    // Cancel submit form
    void CancelCreateOrUpdate()
    {
        NavigationManager.NavigateTo($"plants/{PlantId}/areas/{AreaId}/distributions/{DistributionId}");
    }


    private void UpdateProductDisplay()
    {
        _product.IsActive = true;
        if (_distribution.Products.Exists(p => p.ProductId == ProductId))
        {
            useButton = true;
        }
        else
        {
            _product = _products[_products.FindIndex(d => d.ProductId == ProductId)];

            if (ProductId != 0 && _product != null)
                useButton = false;
        }

        StateHasChanged();
    }


    // Create distribution
    async void AddingProductAsync()
    {
        Console.WriteLine($"plant{PlantId}  area{AreaId} dist {DistributionId} prod {ProductId} product {_product.ProductId}");

        var result = await DistributionServices.AddProduct(PlantId, AreaId, DistributionId, _product);

        if (result != null)
        {
            NavigationManager.NavigateTo($"plants/{PlantId}/areas/{AreaId}/distributions/{DistributionId}");
        }

    }

}
