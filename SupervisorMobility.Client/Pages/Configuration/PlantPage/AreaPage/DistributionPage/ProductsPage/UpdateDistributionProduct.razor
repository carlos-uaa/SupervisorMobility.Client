@page "/plants/{plantId:int}/areas/{areaId:int}/distributions/{distributionId:int}/product/{productId:int}/update"
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage
@inject IProductService ProductServices
@inject NavigationManager NavigationManager
@inject IDistributionService DistributionService
@inject IAreaService AreaService
@inject IPlantService PlantService
@inject IOperationService OperationService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["updateProducts"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


@if (showui)
{
    <MudGrid>
        @*Distribution info*@
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardContent Style="justify-content:center">
                    <MudText Align="Align.Center" Typo="Typo.h3"><MudIcon Icon="@Icons.Material.Filled.AccountTree"></MudIcon></MudText>

                    <MudText Typo="Typo.h6" Align="Align.Center" Class="pa-2">@_distribution.Description</MudText>
                    <MudText Typo="Typo.h5" Align="Align.Center" Class="pa-2">@_distribution.Code</MudText>

                    @if (_distribution.IsActive == true)
                    {
                        <MudText Align="Align.Center" Class="pt-2">
                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                        </MudText>
                    }
                    else
                    {
                        <MudText Align="Align.Center" Class="pa-4">
                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
        @*Product Info*@
        <MudItem xs="12" sm="6" md="9">
            <MudGrid>
                <MudItem xs="12">
                    <EditForm Model="_product" OnValidSubmit="UpdateProductAsync">
                        <DataAnnotationsValidator />
                        <MudCard>
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">@Localizer["product"]</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudChip Variant="Variant.Text" Color="Color.Info"> @Localizer["updateProduct"]</MudChip>
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudTextField Label="@Localizer["description"]"
                                          @bind-Value="_product.Description" For="@(() => _product.Description)" />
                                <MudTextField Label="@Localizer["code"]" Class="mt-3"
                                          @bind-Value="_product.Code" For="@(() => _product.Code)" />
                                @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_product.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["save"]</MudButton>
                                <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => Close())">@Localizer["close"]</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </EditForm>

                </MudItem>
            </MudGrid>
        </MudItem>
    </MudGrid>


}
else
{


    <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
        <MudItem class="d-flex justify-center align-self-center pa-3 ma-2 ">
            <MudText Typo="Typo.h6" Class="align-item-center center">@Localizer["loadingData"]</MudText>
        </MudItem>
        <MudPaper Class="flex d-flex-row pa-3 ma-2" Elevation="0">
            <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
        </MudPaper>
    </MudItem>
}




@code {
    [Parameter]
    public int PlantId { get; set; }
    [Parameter]
    public int AreaId { get; set; }
    [Parameter]
    public int DistributionId { get; set; }
    [Parameter]
    public int ProductId { get; set; }


    private bool showui = false;
    private Plant _plant = new();
    private Area _area = new();
    private Distribution _distribution = new();
    private Product _product { get; set; }

    // Breadcrumb links
    private List<BreadcrumbItem> _links;

    protected override async Task OnParametersSetAsync()
    {
        _plant = await PlantService.GetPlantById(PlantId);
        _area = await AreaService.GetAreaById(PlantId, AreaId);

        //_plant = await PlantService.GetPlantIncludingAreas(PlantId);
        //_area = _plant.Areas.ToList().Find(a => a.AreaId == AreaId);

        _distribution = await DistributionService.GetDistributionWithCollections(PlantId, AreaId, DistributionId);
        _product = _distribution.Products.Find(p => p.ProductId == ProductId);

        _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem(text: Localizer["home"], href: "#"),
            new BreadcrumbItem(text: Localizer["configuration"], href: "/configuration"),
            new BreadcrumbItem(text: Localizer["plants"], href: "/plants"),
        };


        _links.Add(new BreadcrumbItem($"{_plant.Description}", href: $"/plants/{PlantId}"));
        _links.Add(new BreadcrumbItem($"{_area.Description}", href: $"/plants/{PlantId}/areas/{AreaId}"));
        _links.Add(new BreadcrumbItem($"{_distribution.Description}", href: $"/plants/{PlantId}/areas/{AreaId}/distributions/{DistributionId}"));
        _links.Add(new BreadcrumbItem(text: Localizer["updateProduct"], href: $"/", disabled: true));
        showui = true;
    }


    void Close()
    {
        NavigationManager.NavigateTo($"/plants/{PlantId}/areas/{AreaId}/distributions/{DistributionId}");
    }

    async Task UpdateProductAsync()
    {
        _product.IsActive = true;
        var result = await ProductServices.UpdateProduct(_product);

        if (result)
        {
            NavigationManager.NavigateTo($"/plants/{PlantId}/areas/{AreaId}/distributions/{DistributionId}");
        }

    }

}
