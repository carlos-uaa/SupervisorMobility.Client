@page "/plants/{plantId:int}/areas/{areaId:int}/distributions/{distributionId:int}/operations/updateoperation/{operationId:int}"
@inject IDistributionService DistributionService
@inject IAreaService AreaService
@inject IPlantService PlantService
@inject IOperationService OperationService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1
@inject IBreadcrumbService BreadcrumbService

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["updateOperation"]</PageTitle>

    @*Breadcrumb links*@
    @* <MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == Localizer["plantDetails"])
        {
            <MudButton @onclick="(() => GoToPlant())" Variant="Variant.Text" Color="Color.Info">@_plant.Description</MudButton>
        }
        else if (item.Text == Localizer["areaDetails"])
        {
            <MudButton @onclick="(() => GoToArea())" Variant="Variant.Text" Color="Color.Info">@_area.Description</MudButton>
        }
        else if (item.Text == Localizer["distributionDetails"])
        {
            <MudButton @onclick="(() => GoToDistribution())" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@_distribution.Description</MudButton>
        }
        else if (item.Text == Localizer["updateOperation"])
        {
            <MudButton Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@Localizer["update"] @_operation.Description</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs> *@
    @*Form*@


    @if (showui)
{

    <MudGrid Class="mt-10">

        <MudItem xs="3" lg="3" md="3" sm="3">
            <MudCard>
                <MudCardContent Style="justify-content:center">
                    <MudText Align="Align.Center"><MudIcon Icon="@Icons.Filled.Business"></MudIcon></MudText>
                    <MudText Align="Align.Center">@_plant.Code</MudText>
                        <MudText Typo="Typo.h5" Align="Align.Center">@_plant.Description</MudText>
                        @if (_plant.IsActive == true)
                    {
                        <MudText Align="Align.Center" Class="pt-2">
                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                            </MudText>
                    }
                    else
                    {
                        <MudText Align="Align.Center" Class="pa-4">
                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                            </MudText>
                    }
                </MudCardContent>
            </MudCard>
            <MudText Typo="Typo.h4" Style="text-align:center">
                <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowDown"></MudIcon>
            </MudText>
            <MudCard>
                <MudCardContent Style="justify-content:center">
                    <MudText Align="Align.Center"><MudIcon Icon="@Icons.Material.Filled.HomeWork"></MudIcon></MudText>
                    <MudText Align="Align.Center">@_area.Code</MudText>
                        <MudText Typo="Typo.h5" Align="Align.Center">@_area.Description</MudText>
                        @if (_area.IsActive == true)
                    {
                        <MudText Align="Align.Center" Class="pt-2">
                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                            </MudText>
                    }
                    else
                    {
                        <MudText Align="Align.Center" Class="pa-4">
                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                            </MudText>
                    }
                </MudCardContent>
            </MudCard>
            <MudText Typo="Typo.h4" Style="text-align:center">
                <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowDown"></MudIcon>
            </MudText>
            <MudCard>
                <MudCardContent Style="justify-content:center">
                    <MudText Align="Align.Center"><MudIcon Icon="@Icons.Material.Filled.Workspaces"></MudIcon></MudText>
                    <MudText Align="Align.Center">@_distribution.Code</MudText>
                        <MudText Typo="Typo.h5" Align="Align.Center">@_distribution.Description</MudText>
                        @if (_distribution.IsActive == true)
                    {
                        <MudText Align="Align.Center" Class="pt-2">
                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                            </MudText>
                    }
                    else
                    {
                        <MudText Align="Align.Center" Class="pa-4">
                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                            </MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="9" lg="9" md="9" sm="9">
            <EditForm Model="_operation" OnValidSubmit="UpdateOperationAsync">
                <DataAnnotationsValidator />
                <MudGrid>
                    <MudItem xs="12">
                        <MudCard>
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">@Localizer["update"] @Localizer["operation"]</MudText>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        <MudChip Variant="Variant.Text" Color="Color.Info">@Localizer["updateOperation"]</MudChip>
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent>
                                    <MudTextField Label="@Localizer["description"]"
                                                  @bind-Value="_operation.Description" For="@(() => _operation.Description)" />
                                    <MudTextField Label="@Localizer["code"]" Class="mt-3"
                                                  @bind-Value="_operation.Code" For="@(() => _operation.Code)" />

                                    <MudSelect T="int" Label="@Localizer1["ACCriticalLabel"]" Placeholder="@Localizer1["ACPHCritical"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_operation.CriticalType" For="@(() => _operation.CriticalType)">
                                        <MudSelectItem Disabled="true" Value="0">@Localizer1["ACPHCritical"]</MudSelectItem>

                                        <MudSelectItem Value="1">@($"A")</MudSelectItem>
                                        <MudSelectItem Value="2">@($"B")</MudSelectItem>
                                        <MudSelectItem Value="3">@($"C")</MudSelectItem>
                                        <MudSelectItem Value="5">@($"{Localizer["OPCritical"]}")</MudSelectItem>

                                    </MudSelect>
                                    @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_operation.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["save"]</MudButton>
                                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">@Localizer["cancel"]</MudButton>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
                    </MudGrid>
                </EditForm>
            </MudItem>
        </MudGrid>
}
else
{
    <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
        <MudItem class="d-flex justify-center align-self-center pa-3 ma-2 ">
            <MudText Typo="Typo.h6" Class="align-item-center center">@Localizer["loadingData"]</MudText>
            </MudItem>
            <MudPaper Class="flex d-flex-row pa-3 ma-2" Elevation="0">
                <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
            </MudPaper>
        </MudItem>
}


