@page "/plants/{plantId:int}/areas/{areaId:int}/distributions/{distributionId:int}/operations/detailsoperation/{operationId:int}"
@inject IDistributionService DistributionService
@inject IAreaService AreaService
@inject IPlantService PlantService
@inject IOperationService OperationService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1
@inject IBreadcrumbService BreadcrumbService
@inject IProductService ProductsServices

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["updateOperation"]</PageTitle>

@*Breadcrumb links*@
