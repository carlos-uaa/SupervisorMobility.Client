@if (showui)
{
    <MudGrid Class="mt-10">

        <MudItem xs="3" lg="3" md="3" sm="3">
            <MudCard>
                <MudCardContent Style="justify-content:center">
                    <MudText Align="Align.Center"><MudIcon Icon="@Icons.Filled.Business"></MudIcon></MudText>
                    <MudText Align="Align.Center">@_plant.Code</MudText>
                    <MudText Typo="Typo.h5" Align="Align.Center">@_plant.Description</MudText>
                    @if (_plant.IsActive == true)
                    {
                        <MudText Align="Align.Center" Class="pt-2">
                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                        </MudText>
                    }
                    else
                    {
                        <MudText Align="Align.Center" Class="pa-4">
                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
            <MudText Typo="Typo.h4" Style="text-align:center">
                <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowDown"></MudIcon>
            </MudText>
            <MudCard>
                <MudCardContent Style="justify-content:center">
                    <MudText Align="Align.Center"><MudIcon Icon="@Icons.Material.Filled.HomeWork"></MudIcon></MudText>
                    <MudText Align="Align.Center">@_area.Code</MudText>
                    <MudText Typo="Typo.h5" Align="Align.Center">@_area.Description</MudText>
                    @if (_area.IsActive == true)
                    {
                        <MudText Align="Align.Center" Class="pt-2">
                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                        </MudText>
                    }
                    else
                    {
                        <MudText Align="Align.Center" Class="pa-4">
                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
            <MudText Typo="Typo.h4" Style="text-align:center">
                <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowDown"></MudIcon>
            </MudText>
            <MudCard>
                <MudCardContent Style="justify-content:center">
                    <MudText Align="Align.Center"><MudIcon Icon="@Icons.Material.Filled.Workspaces"></MudIcon></MudText>
                    <MudItem Style=" display: flex;align-content: center;justify-content: center;align-items: center;">
                        <div>
                            <MudText Align="Align.Center">@_distribution.Code</MudText>
                            <MudText Typo="Typo.h5" Align="Align.Center">@_distribution.Description</MudText>
                        </div>
                        @switch (_distribution.CriticalType)
                        {
                            case 1:
                                <MudImage Src="Images/HOE Symbols/Air Bag A.png" Alt="ILU Image" Height="30" Class="rounded-lg" />
                                break;
                            case 2:
                                <MudImage Src="Images/HOE Symbols/Air Bag B.png" Alt="ILU Image" Height="30" Class="rounded-lg" />
                                break;
                            case 3:
                                <MudImage Src="Images/HOE Symbols/Air Bag C.png" Alt="ILU Image" Height="30" Class="rounded-lg" />
                                break;
                        }
                    </MudItem>
                    @if (_distribution.IsActive == true)
                    {
                        <MudText Align="Align.Center" Class="pt-2">
                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                        </MudText>
                    }
                    else
                    {
                        <MudText Align="Align.Center" Class="pa-4">
                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
            <MudText Typo="Typo.h4" Style="text-align:center">
                <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowDown"></MudIcon>
            </MudText>
            <MudCard>
                <MudCardContent Style="justify-content:center">
                    <MudText Align="Align.Center"><MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Color="Color.Primary"></MudIcon></MudText>
                    <MudText Align="Align.Center">@_product?.Code</MudText>
                    <MudText Typo="Typo.h5" Align="Align.Center">@_product?.Description</MudText>
                    @if (_product?.IsActive == true)
                    {
                        <MudText Align="Align.Center" Class="pt-2">
                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>

                        </MudText>
                    }
                    else if (_product?.IsActive == false)
                    {
                        <MudText Align="Align.Center" Class="pa-4">
                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="9" lg="9" md="9" sm="9">
            @*Form*@
            <EditForm Model="_operation" class="mt-10" OnValidSubmit="UpdateOperationAsync">
                <DataAnnotationsValidator />
                <MudGrid>
                    <MudItem xs="12">
                        <MudCard>
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">@Localizer["operationDetails"]</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudButton EndIcon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdateOperationRedirect(OperationId))" OnTouch="(() => UpdateOperationRedirect(OperationId))">@Localizer["editOperation"] </MudButton>
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudTextField ReadOnly Label="@Localizer["description"]"
                                              @bind-Value="_operation.Description" For="@(() => _operation.Description)" />
                                <MudTextField ReadOnly Label="@Localizer["code"]" Class="mt-3"
                                              @bind-Value="_operation.Code" For="@(() => _operation.Code)" />

                                <MudSelect ReadOnly T="int" Label="@Localizer1["ACCriticalLabel"]" Placeholder="@Localizer1["ACPHCritical"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_operation.CriticalType" For="@(() => _operation.CriticalType)">
                                    <MudSelectItem Disabled="true" Value="0">@Localizer1["ACPHCritical"]</MudSelectItem>

                                    <MudSelectItem Value="1">@($"A")</MudSelectItem>
                                    <MudSelectItem Value="2">@($"B")</MudSelectItem>
                                    <MudSelectItem Value="3">@($"C")</MudSelectItem>
                                    <MudSelectItem Value="5">@($"{Localizer["OPCritical"]}")</MudSelectItem>

                                </MudSelect>

     

                                <MudTabs @bind-ActivePanelIndex="@activeTabIndex" Class="mb-10">
                                    @foreach (var tab in openTabs)
                                    {
                                        <MudTabPanel @onclick="() => UpdateProduct()" Icon="@(openTabs.IndexOf(tab) == 0 ? Icons.Material.Filled.FolderOpen : null)">
                                            <TabContent>
                                                @tab
                                            </TabContent>
                                            <ChildContent>
                                                <MudSimpleTable>

                                                    <MudTr>

                                                        @foreach (var (value, index) in NameTimeList[tab].Select((value, index) => (value, index)))
                                                        {
                                                            <MudTd>
                                                                <MudTextField Label="@($"{Localizer["nameTime"]} {index + 1}")" Class="mt-3" ReadOnly
                                                                              @bind-Value="NameTimeList[tab][index]" />
                                                            </MudTd>
                                                        }
                                                    </MudTr>

                                                    <MudTr>
                                                        @foreach (var (value, index) in TimeList[tab].Select((value, index) => (value, index)))
                                                        {
                                                            <MudTd>
                                                                <MudTextField Label="@($"{Localizer["Time"]} {index + 1}")" Class="mt-3" ReadOnly
                                                                              @bind-Value="TimeList[tab][index]" />
                                                            </MudTd>
                                                        }

                                                    </MudTr>

                                                    <MudTr>
                                                        @foreach (var (value, index) in AdditionalTimeList[tab].Select((value, index) => (value, index)))
                                                        {
                                                            <MudTd>
                                                                <MudTextField Label="@($"{Localizer["additionalTime"]} {index + 1}")" Class="mt-3" ReadOnly
                                                                              @bind-Value="AdditionalTimeList[tab][index]" />
                                                            </MudTd>
                                                        }

                                                    </MudTr>

                                                    <MudTr>
                                                        @foreach (var (value, index) in StandardTimeList[tab].Select((value, index) => (value, index)))
                                                        {
                                                            <MudTd>

                                                                <MudTextField Label="@($"{Localizer["standardTime"]} {index + 1}")" Class="mt-3" ReadOnly
                                                                              @bind-Value="StandardTimeList[tab][index]" />
                                                            </MudTd>
                                                        }
                                                    </MudTr>

                                                </MudSimpleTable>

                                            </ChildContent>
                                        </MudTabPanel>
                                    }
                                </MudTabs>

                                @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_operation.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">@Localizer["close"]</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudItem>
    </MudGrid>
}
else
{


    <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
        <MudItem class="d-flex justify-center align-self-center pa-3 ma-2 ">
            <MudText Typo="Typo.h6" Class="align-item-center center">@Localizer["loadingData"]</MudText>
        </MudItem>
        <MudPaper Class="flex d-flex-row pa-3 ma-2" Elevation="0">
            <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
        </MudPaper>
    </MudItem>
}


