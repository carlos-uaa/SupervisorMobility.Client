@page "/plants/{PlantId:int}/areas/{AreaId:int}/distributions/{DistributionId:int}/CreateProductInDistribution"
@inject IProductService ProductServices
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@*Title*@
<PageTitle>Supervisor Mobility | Create Distribution To Product</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == "ProductsDetail")
        {
            <MudButton @onclick="(() => GoToProduct())" Variant="Variant.Text" Color="Color.Info">@_product.Description</MudButton>
        }
        else if (item.Text == "CreateDistribution")
        {
            <MudButton Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_distribution" OnValidSubmit="CreateDistributionAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Distribution details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">New distribution In Product</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Class="d-flex flex-row mb-5">
                        <MudSelect T="int" Label="Plant" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@PlantId" For="@(() => PlantId)" SelectedValuesChanged="UpdateAreas">
                            <MudSelectItem Disabled="true" Value="0">Select a Plant</MudSelectItem>
                            @foreach (var plant in _plants)
                            {
                                <MudSelectItem Value="plant.PlantId">@($"{plant.Code} - {plant.Description}")</MudSelectItem>
                            }
                        </MudSelect>

                        @*Mud select of Areas *@

                        <MudSelect T="int" Label="Area" Variant="Variant.Text" Placeholder="Select a Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@AreaId" For="@(() => AreaId)" >
                            <MudSelectItem Disabled="true" Value="0">Select a Area</MudSelectItem>
                            @foreach (var area in _areas)
                            {
                                <MudSelectItem Value="area.AreaId">@($"{area.Code} - {area.Description}")</MudSelectItem>
                            }
                        </MudSelect>
                    </MudGrid>

                    <MudTextField Label="Distribution description"
                                  @bind-Value="_distribution.Description" For="@(() => _distribution.Description)" />
                    <MudTextField Label="Code" Class="mt-3"
                                  @bind-Value="_distribution.Code" For="@(() => _distribution.Code)" />
                    <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_distribution.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>