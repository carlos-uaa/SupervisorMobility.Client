@page "/plants/{plantId:int}/areas/{areaId:int}/updatedistribution/{distributionId:int}"
@inject IDistributionService DistributionService
@inject IPlantService PlantService
@inject IAreaService AreaService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService
@inject IStringLocalizer<Resource1> Localizer1

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["updateDistribution"]</PageTitle>

@*Form*@
<EditForm Model="_distribution" class="mt-10" OnValidSubmit="UpdateDistributionAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                          @if (!(bool)CriticalTypeUpdatePat){
                            <MudText Typo="Typo.h6">@Localizer["update"] @Localizer["distribution"]</MudText>
                          }else{
                            <MudText Typo="Typo.h6">@Localizer["update"] @Localizer["CriticalType"]</MudText>
                          }
                    </CardHeaderContent>
                    <CardHeaderActions>
                      
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField ReadOnly="(bool)CriticalTypeUpdatePat" Label="@Localizer["description"]"
                                  @bind-Value="_distribution.Description" For="@(() => _distribution.Description)" />
                    <MudTextField ReadOnly="(bool)CriticalTypeUpdatePat" Label="@Localizer["code"]" Class="mt-3"
                                  @bind-Value="_distribution.Code" For="@(() => _distribution.Code)" />

                    <MudSelect T="int" Label="@Localizer1["ACCriticalLabel"]" Placeholder="@Localizer1["ACPHCritical"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_distribution.CriticalType" For="@(() => _distribution.CriticalType)">
                        <MudSelectItem Disabled="true" Value="0">@Localizer1["ACPHCritical"]</MudSelectItem>

                        <MudSelectItem Value="1">@($"A")</MudSelectItem>
                        <MudSelectItem Value="2">@($"B")</MudSelectItem>
                        <MudSelectItem Value="3">@($"C")</MudSelectItem>
                        <MudSelectItem Value="5">@($"{Localizer["OPCritical"]}")</MudSelectItem>

                    </MudSelect>
                    @if (!(bool)CriticalTypeUpdatePat)
                    {
                        <MudSwitch ReadOnly="(bool)CriticalTypeUpdatePat" Class="mt-3" Label="Is active?" @bind-Checked="_distribution.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />
                    }
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["save"]</MudButton>
                    @if (!(bool)CriticalTypeUpdatePat){
                        <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">@Localizer["cancel"]</MudButton>
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>