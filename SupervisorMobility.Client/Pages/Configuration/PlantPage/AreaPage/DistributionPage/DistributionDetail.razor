@page "/plants/{plantId:int}/areas/{areaId:int}/distributions/{distributionId:int}"
@inject IDistributionService DistributionService
@inject IAreaService AreaService
@inject IPlantService PlantService
@inject IOperationService OperationService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@*Title*@
<PageTitle>Supervisor Mobility | @_distribution.Description</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == "PlantDetail")
        {
            <MudButton @onclick="(() => GoToPlant())" Variant="Variant.Text" Color="Color.Info">@_plant.Description</MudButton>
        }
        else if (item.Text == "AreaDetail")
        {
            <MudButton @onclick="(() => GoToArea())" Variant="Variant.Text" Color="Color.Info">@_area.Description</MudButton>
        }
        else if (item.Text == "DistributionDetail")
        {
            <MudButton Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@_distribution.Description</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs>

@*Dashboard grid*@
<MudGrid>
    @*Area info*@
    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent Style="justify-content:center">
                <MudText Align="Align.Center"><MudIcon Icon="@Icons.Filled.Business"></MudIcon></MudText>
                <MudText Align="Align.Center">@_distribution.Code</MudText>
                <MudText Typo="Typo.h5" Align="Align.Center">@_distribution.Description</MudText>
                @if (_distribution.IsActive == true)
                {
                    <MudText Align="Align.Center" Class="pt-2">
                        <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                    </MudText>
                }
                else
                {
                    <MudText Align="Align.Center" Class="pa-4">
                        <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                    </MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
    @*Related operations*@
    <MudItem xs="12" sm="6" md="9">
        <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
            <MudTabPanel Icon="@Icons.Material.Filled.ContentPaste" Text="Operations">
                @if (_distribution.Operations.Count > 0)
                {
                    <MudTable Height="45vh" Items="_distribution.Operations" Hover="true" T="Operation" Filter="new Func<Operation,bool>(FilterOperation)" Class="styled-table table-striped" FixedHeader=true>
                        
                        <ToolBarContent>
                            <MudGrid class="d-flex flex-column justify-center align-self-center">

                                <MudItem Class="d-flex">
                                    <MudSpacer />
                                    <MudTextField @bind-Value="searchString" Placeholder="Search In Operations" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                                    <MudSpacer />
                                    <MudButton @onclick="(() => CreateOperation())">
                                        <MudText>Create Operation</MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Operation" Color="Color.Primary"></MudIcon>
                                    </MudButton>
                                    <MudSpacer />
                                    <MudSpacer />
                                </MudItem>
                            </MudGrid>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>
                                <MudText Align="Align.Center">Operation Id</MudText>
                            </MudTh>
                            <MudTh>
                                <MudText Align="Align.Center">Code</MudText>
                            </MudTh>
                            <MudTh>
                                <MudText Align="Align.Center">Description</MudText>
                            </MudTh>
                            
                            <MudTh>
                                <MudText Align="Align.Center">Actions</MudText>
                            </MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="OperationId">
                                <MudText Align="Align.Center">@context.OperationId</MudText>
                            </MudTd>
                            <MudTd DataLabel="Code">
                                <MudText Align="Align.Center">@context.Code</MudText>
                            </MudTd>
                            <MudTd DataLabel="Description">
                                <MudText Align="Align.Center">@context.Description</MudText>
                            </MudTd>
                            
                            <MudTd>
                                <MudText Align="Align.Center">
                                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => UpdateOperation(context.OperationId))"></MudIconButton>
                                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => DeleteOperation(context.OperationId))"></MudIconButton>
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">There are no operations created for this distribution.</MudText>
                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">
                        <MudButton Color="Color.Info" @onclick="(() => CreateOperation())">Create a new operation</MudButton>

                    </MudText>
                }
            </MudTabPanel>
            <MudTabPanel Icon="@Icons.Material.Filled.ContentPaste" Text="Products">
                @if (_distribution.Products.Count > 0)
                {

                    <MudTable Height="45vh" Items="_distribution.Products" Hover="true" T="Product" Filter="new Func<Product,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true>
                        <ToolBarContent>
                            <MudGrid class="d-flex flex-column justify-center align-self-center">
                                
                                <MudItem Class="d-flex">
                                    <MudSpacer />
                                    <MudTextField @bind-Value="searchString" Placeholder="Search In Products" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                                    <MudSpacer />
                                    <MudButton @onclick="(() => CreateProduct())">
                                        <MudText>Create Product</MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Prodict" Color="Color.Primary"></MudIcon>
                                    </MudButton>
                                    <MudSpacer />

                                    <MudButton @onclick="(() => AddExistProduct())">
                                        <MudText>Add Exist Product</MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Add Exist Product" Color="Color.Primary"></MudIcon>
                                    </MudButton>
                                    <MudSpacer />
                                </MudItem>
                            </MudGrid>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<Product, object>(x=>x?.ProductId)">Product Id</MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<Product, object>(x=>x?.Code)">Code</MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<Product, object>(x=>x?.Description)">Description</MudTableSortLabel>
                            </MudTh>
                            
                            <MudTh>
                                <MudText Align="Align.Center">Actions</MudText>
                            </MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="ProductId">
                                <MudText Align="Align.Center">@context.ProductId</MudText>
                            </MudTd>
                            <MudTd DataLabel="Code">
                                <MudText Align="Align.Center">@context.Code</MudText>
                            </MudTd>
                            <MudTd DataLabel="Description">
                                <MudText Align="Align.Center">@context.Description</MudText>
                            </MudTd>
                            
                            <MudTd>
                                <MudText Align="Align.Center">
                                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => ProductDetails(context.ProductId))"></MudIconButton>
                                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => EditProduct(context.ProductId))"></MudIconButton>
                                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => DeleteProduct(context.ProductId))"></MudIconButton>
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {

                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">There are no products created for this distribution</MudText>
                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">
                        <MudButton Color="Color.Info" @onclick="(() => CreateProduct())">Create a new product</MudButton>
                        <MudSpacer />
                        <MudButton Color="Color.Info" @onclick="(() => AddExistProduct())">Adding a exist product</MudButton>

                    </MudText>
                }
            </MudTabPanel>
        </MudTabs>
    </MudItem>
</MudGrid>