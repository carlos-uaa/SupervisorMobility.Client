@page "/plants"
@inject IPlantService PlantService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@*Title*@
<PageTitle>Supervisor Mobility | Plants</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="ma-2" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@if (_plants == null)
{
    <text>
        Loading . . .
    </text>
}
else if (_plants.Count == 0)
{
    <MudContainer>

        <MudText Align="Align.Center">
            <h4>There are no Plants created.</h4>
            <MudSpacer></MudSpacer>
            <MudButton @onclick="(() => CreatePlant())">
                <MudText>Create Plant</MudText>
                <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Plant" Color="Color.Primary"></MudIcon>
            </MudButton>
        </MudText>
    </MudContainer>
}
else
{
    <MudTable SortLabel="SortBy" Class="styled-table table-striped" FixedHeader=true Height="55vh"
          Items="@_plants" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="true" Filter="new Func<Plant,bool>(FilterFunc1)" >
        <PagerContent>
            <MudTablePager />
        </PagerContent>
        <ToolBarContent>
            <MudText Typo="Typo.h6" Align="Align.Center">Plants</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="@searchString1" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-2"></MudTextField>
            <MudSpacer />
            <MudButton @onclick="(() => CreatePlant())">
                <MudText>Create Plant</MudText>
                <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Plant" Color="Color.Primary"></MudIcon>
            </MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Plant, object>(x=>x.PlantId)" Enabled="true">PlantId</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Plant, object>(x=>x.Code)" >Code</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Plant, object>(x=>x.Description)"><MudText>Description</MudText></MudTableSortLabel>
            </MudTh>
            
            <MudTh>
                <MudText Align="Align.Center">Actions</MudText>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="PlantId">
                <MudText Align="Align.Center">@context.PlantId</MudText>
            </MudTd>
            <MudTd DataLabel="Code">
                <MudText Align="Align.Center">@context.Code</MudText>
            </MudTd>
            <MudTd DataLabel="Description">
                <MudText Align="Align.Center">@context.Description</MudText>
            </MudTd>
            
            <MudTd DataLabel="Actions">
                <MudText Align="Align.Center">
                    <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                        <ActivatorContent>
                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => PlantDetails(context.PlantId))" @ontouchstart="(() => PlantDetails(context.PlantId))">Plant Details</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdatePlant(context.PlantId))" @ontouchstart="(() => UpdatePlant(context.PlantId))">Edit Plant </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => OpenDeleteDialog(context.PlantId))" @ontouchstart="(() => OpenDeleteDialog(context.PlantId))">Delete Plant</MudMenuItem>
                        </ChildContent>
                    </MudMenu>
@*                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => PlantDetails(context.PlantId))"></MudIconButton>
                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => UpdatePlant(context.PlantId))"></MudIconButton>
                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => OpenDeleteDialog(context.PlantId))"></MudIconButton>*@
                </MudText>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@*Delete Plant modal*@
<MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">Confirm</MudText>
        <MudText Class="mt-4 mb-4">
            Are you sure you want to delete this Plant?
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">Cancel</MudButton>
        <MudButton @onclick="(() => DeletePlant(deletePlantId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">Delete</MudButton>
    </DialogActions>
</MudDialog>