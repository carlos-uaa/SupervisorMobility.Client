@page "/plants"
@inject IPlantService PlantService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["plants"]</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="ma-2" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@if (_plants == null)
{
    <text>
        @Localizer["loading"] ...
    </text>
}
else if (_plants.Count == 0)
{
    <MudContainer>

        <MudText Align="Align.Center">
            <h4>@Localizer["thereAreNoPlantsCreated"]</h4>
            <MudSpacer></MudSpacer>
            <MudButton @onclick="(() => CreatePlant())">
                <MudText>@Localizer["createPlant"]</MudText>
                <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Plant" Color="Color.Primary"></MudIcon>
            </MudButton>
        </MudText>
    </MudContainer>
}
else
{
    <MudTable SortLabel="SortBy" Class="styled-table table-striped" FixedHeader=true Height="55vh"
          Items="@_plants" Dense="@dense" Hover="@hover" Bordered="@bordered" Striped="true" Filter="new Func<Plant,bool>(FilterFunc1)" >
        <PagerContent>
            <MudTablePager />
        </PagerContent>
        <ToolBarContent>
            <MudText Typo="Typo.h6" Align="Align.Center">@Localizer["plants"]</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="@searchString1" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-2"></MudTextField>
            <MudSpacer />
            <MudButton @onclick="(() => CreatePlant())">
                <MudText>@Localizer["createPlant"]</MudText>
                <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary"></MudIcon>
            </MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Plant, object>(x=>x.PlantId)" Enabled="true">Id</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Plant, object>(x=>x.Code)">@Localizer["code"]</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Plant, object>(x=>x.Description)"><MudText>@Localizer["description"]</MudText></MudTableSortLabel>
            </MudTh>
            
            <MudTh>
                <MudText Align="Align.Center">@Localizer["actions"]</MudText>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Id">
                <MudText Align="Align.Center">@context.PlantId</MudText>
            </MudTd>
            <MudTd DataLabel=@Localizer["code"]>
                <MudText Align="Align.Center">@context.Code</MudText>
            </MudTd>
            <MudTd DataLabel=@Localizer["description"]>
                <MudText Align="Align.Center">@context.Description</MudText>
            </MudTd>

            <MudTd DataLabel=@Localizer["actions"]>
                <MudText Align="Align.Center">
                    <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                        <ActivatorContent>
                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => PlantDetails(context.PlantId))" @ontouchstart="(() => PlantDetails(context.PlantId))">@Localizer["plantDetails"]</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdatePlant(context.PlantId))" @ontouchstart="(() => UpdatePlant(context.PlantId))">@Localizer["editPlant"] </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => OpenDeleteDialog(context.PlantId))" @ontouchstart="(() => OpenDeleteDialog(context.PlantId))">@Localizer["deletePlant"]</MudMenuItem>
                        </ChildContent>
                    </MudMenu>
@*                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => PlantDetails(context.PlantId))"></MudIconButton>
                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => UpdatePlant(context.PlantId))"></MudIconButton>
                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => OpenDeleteDialog(context.PlantId))"></MudIconButton>*@
                </MudText>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@*Delete Plant modal*@
<MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
        <MudText Class="mt-4 mb-4">
            @Localizer["areYouSureYouWantToDeleteThisPlant"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
        <MudButton @onclick="(() => DeletePlant(deletePlantId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">@Localizer["delete"]</MudButton>
    </DialogActions>
</MudDialog>