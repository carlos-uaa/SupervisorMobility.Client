@page "/plants/createplant"
@inject IPlantService PlantService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["create"] @Localizer["plant"]</PageTitle>

@*Breadcrumb links*@
@* <MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs> *@

@*Form*@
<EditForm Model="_plant" OnValidSubmit="CreatePlantAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localizer["plantDetails"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["newPlant"]</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label=@Localizer["plantDescription"]
                                  @bind-Value="_plant.Description" For="@(() => _plant.Description)" />
                    <MudTextField Label=@Localizer["code"] Class="mt-3"
                                  @bind-Value="_plant.Code" For="@(() => _plant.Code)" />
                  @*  <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_plant.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["save"]</MudButton>
                    <MudButton Href="/plants" Variant="Variant.Filled" Class="ml-4">@Localizer["cancel"]</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>