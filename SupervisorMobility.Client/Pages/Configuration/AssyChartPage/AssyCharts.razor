                            <MudText Align="Align.Center">@context.Operation?.Description</MudText>
                        </MudTd>
                        <MudTd DataLabel="Product">
                            <MudText Align="Align.Center">@context.Product?.Description</MudText>
                        </MudTd>
                        <MudTd DataLabel="Creation Date">
                            <MudText Align="Align.Center">@context.CreationDate</MudText>
                        </MudTd>
                        <MudTd DataLabel="Modification Date">
                            <MudText Align="Align.Center">@context.ModificationDate</MudText>
                        </MudTd>
