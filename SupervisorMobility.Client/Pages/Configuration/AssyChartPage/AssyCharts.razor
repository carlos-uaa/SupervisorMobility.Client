                                <MudSelect T="int" Label=@Localizer["product"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@productId" Disabled>
                                <MudSelectItem Disabled="true" Value="0">@Localizer["notSelected"]</MudSelectItem>
                            </MudSelect>
                        </MudTooltip>
                        }
                        else
