        <MudTabPanel Icon="@Icons.Material.Filled.UploadFile" Text="@Localizer1["ACCreate"]" BadgeData='"✚"' BadgeColor="Color.Primary" OnClick="@(() => @NavigationManager.NavigateTo("/assychart/createassychart"))" />

    </MudTabs>




}
else
