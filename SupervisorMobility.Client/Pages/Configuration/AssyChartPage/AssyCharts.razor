@page "/assychart"
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IChecklistService ChecklistService
@inject IAssyChartService AssyChartServices
@using System.Net.Http.Json
@using MudBlazor
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime


@*Title*@
<PageTitle>Supervisor Mobility | Assy Chart</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

<MudTable Items="_assychart" T="AssyChart" Dense="@dense" Hover="@hover" ReadOnly="@ronly"
          SortLabel="Sort By" Filter="new Func<AssyChart,bool>(FilterFunc)"
          HorizontalScrollbar="true">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Assy Chart</MudText>

        <MudSpacer />
        <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        <MudSpacer />
        <MudButton Href="/assychart/UploadAssyCharts#Upload">
            <MudText>Upload Data</MudText>
            <MudIcon Icon="@Icons.Material.Filled.UploadFile" aria-label="Upload" Color="Color.Primary"></MudIcon>
        </MudButton>
        <MudSpacer />
        <MudButton Href="/assychart/BulkAssyCharts#Bulk">
            <MudText>Bulk Data</MudText>
            <MudIcon Icon="@Icons.Material.Filled.Downloading" aria-label="Cancel" Color="Color.Warning"></MudIcon>
        </MudButton>
        <MudSpacer />
        <MudButton Href="/assychart/createassychart">
            <MudText>Create AssyChart</MudText>
            <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Cancel" Color="Color.Warning"></MudIcon>
        </MudButton>

    </ToolBarContent>
    <ColGroup>
        <col style="width: 60px;" />
        <col />
        <col />
        <col />
        <col />
        <col />
    </ColGroup>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Plant?.Description)">Planta</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Area?.Description)">Area</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Distribution?.Description)">Distribucion</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.GOS)">GOS</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.CCP)">CCP</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.HOE)">HOE</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Operation?.Description)">Nombre de la Operacion</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Product?.Description)">Modelo</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.CreationDate)">Fecha de Creacion</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.ModificationDate)">Fecha de Modificacion</MudTableSortLabel></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <GroupHeaderTemplate>
        <MudTh Class="mud-table-cell-custom-group" colspan="5">@($"{context.GroupName}: {context.Key}")</MudTh>
        </GroupHeaderTemplate>
        <RowTemplate>
            <MudTd DataLabel="CategoryId">
                <MudText Align="Align.Center">@context.Plant?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Code">
                <MudText Align="Align.Center">@context.Area?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Description">
                <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Sequence">
                <MudText Align="Align.Center">@context.GOS</MudText>
            </MudTd> <MudTd DataLabel="Sequence">
                <MudText Align="Align.Center">@context.CCP</MudText>
            </MudTd> <MudTd DataLabel="Sequence">
                <MudText Align="Align.Center">@context.HOE</MudText>
            </MudTd>
            <MudTd DataLabel="Sequence">
                <MudText Align="Align.Center">@context.Operation?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Sequence">
                <MudText Align="Align.Center">@context.Product?.Description</MudText>
            </MudTd>
            <MudTd DataLabel="Sequence">
                <MudText Align="Align.Center">@context.CreationDate</MudText>
            </MudTd>
            <MudTd DataLabel="Sequence">
                <MudText Align="Align.Center">@context.ModificationDate</MudText>
            </MudTd>
            <MudTd>
                <MudText Align="Align.Center">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit" @onclick="(() => GoToUpdateAssyChart(context.AssyChardId))"></MudIconButton>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" @onclick="(() => DeleteAssyChart(context.AssyChardId))"></MudIconButton>
                </MudText>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>


