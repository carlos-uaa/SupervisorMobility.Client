@page "/assychart"
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@*Title*@
<PageTitle>Supervisor Mobility | Assy Chart</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Checklist categories table*@
<MudTable Items="_assychart" Hover="true" T="AssyChart">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Assy Chart</MudText>
        <MudSpacer />
        <MudIconButton Href="/assychart/createassychart" Icon="@Icons.Material.Filled.Add" aria-label="add"></MudIconButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudText Align="Align.Center">Etapa</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Distribución</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">GOS</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Nombre de la operación</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Modelo</MudText>
        </MudTh> 
        <MudTh>
            <MudText Align="Align.Center">Etapa</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Actions</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="CategoryId">
            <MudText Align="Align.Center">@context.Stage</MudText>
        </MudTd>
        <MudTd DataLabel="Code">
            <MudText Align="Align.Center">@context.Distribution</MudText>
        </MudTd>
        <MudTd DataLabel="Description">
            <MudText Align="Align.Center">@context.GOS</MudText>
        </MudTd>
        <MudTd DataLabel="Sequence">
            <MudText Align="Align.Center">@context.OperationName</MudText>
        </MudTd> 
        <MudTd DataLabel="Sequence">
            <MudText Align="Align.Center">@context.Model</MudText>
        </MudTd>  
        <MudTd DataLabel="Sequence">
            <MudText Align="Align.Center">@context.Stage</MudText>
        </MudTd>
        <MudTd>
            <MudText Align="Align.Center">
                <MudIconButton Icon="@Icons.Material.Filled.Info" aria-label="info"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete"></MudIconButton>
            </MudText>
        </MudTd>
    </RowTemplate>
</MudTable>