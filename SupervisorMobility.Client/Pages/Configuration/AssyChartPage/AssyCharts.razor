                        </MudTd>
                        <MudTd DataLabel="@Localizer1["ACArea"]">
                            <MudText Align="Align.Center">@context.Area?.Description</MudText>
                        </MudTd>
                        <MudTd DataLabel="@Localizer1["ACDistribution"]">
