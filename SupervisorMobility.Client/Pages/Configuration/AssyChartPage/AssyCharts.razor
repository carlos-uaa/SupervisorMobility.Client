@*Title*@
<PageTitle>Supervisor Mobility | @Localizer1["ACTitle"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@if (_assychart == null)
