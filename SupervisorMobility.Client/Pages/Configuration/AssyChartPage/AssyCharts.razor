        <MudTabPanel Icon="@Icons.Material.Filled.UploadFile" Text="@Localizer1["ACUpload"]" BadgeData='"🡩"' BadgeColor="Color.Success" OnClick="@(() => @NavigationManager.NavigateTo("/assychart/UploadAssyCharts#Upload"))" />
