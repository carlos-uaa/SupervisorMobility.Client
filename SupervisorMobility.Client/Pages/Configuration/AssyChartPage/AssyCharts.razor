                                        <MudButton @onclick="(() => OpenDialogGOS(context.GOS))" Style="padding: 0px;" Color="Color.Error">
                                            <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Style="font-size: 10px">@context.GOS.Split('/').Last()</MudChip>
                                        </MudButton>
                                    </MudTooltip>
                                </MudTooltip>
                            </MudText>
                        </MudTd> <MudTd DataLabel="CCP">
