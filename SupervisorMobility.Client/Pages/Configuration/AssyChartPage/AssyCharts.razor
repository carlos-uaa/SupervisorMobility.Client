                        <MudAutocomplete ResetValueOnEmptyText MaxItems="null" Clearable="true" OnClearButtonClick="(() => ClearFilters())" T="Distribution" Label="@Localizer["distribution"]" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" ToStringFunc="@(e => distributionId == 0 ? $"{Localizer["notSelected"]}" : $"{e.Code} {e.Description}")" SearchFunc="@SearchDistribution" ShowProgressIndicator="true" ValueChanged="@((item) => SetDistribution(item))">
                            <ItemTemplate Context="e">
                                <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@e.Code - @e.Description </MudChip>
                            </ItemTemplate>
                        </MudAutocomplete>
                        <MudSpacer />

                        @if (!if_pick_Distribution)
                        {
                            <MudTooltip Text=@Localizer["selectADistributionFirst"] Arrow="true" Placement="Placement.Right" Color="Color.Error">
                                <MudSelect T="int" Label=@Localizer["product"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@productId" Disabled>
                                <MudSelectItem Disabled="true" Value="0">@Localizer["notSelected"]</MudSelectItem>
                            </MudSelect>
                        </MudTooltip>
                        }
                        else
                        {
                            <MudSelect T="int" Label=@Localizer["product"] Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@productId" SelectedValuesChanged="Filters">
                                <MudSelectItem Disabled="true" Value="0" OnClick='@(() => ShowError(@Localizer["notSelected"]))'>@Localizer["notSelected"]</MudSelectItem>
                                @foreach (var type in _distributions.Find(d => d.DistributionId == distributionId).Products)
                                {
                                    <MudSelectItem Value="type.ProductId">@($"{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }

                        <MudSpacer />
                        <MudTooltip Text=@Localizer1["clearFilters"] Arrow="true" Placement="Placement.Left" Color="Color.Error">
                            <MudIconButton Icon="@Icons.Material.Filled.Clear" Color="Color.Error" OnClick="(() => ClearFilters())" Class="mr-0"></MudIconButton>
                        </MudTooltip>
                    }
                </ToolBarContent>


                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.AssyChardId)">@Localizer1["ACId"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Plant?.Description)">@Localizer1["ACPlant"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Area?.Description)">@Localizer1["ACArea"]</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Distribution?.Description)" InitialDirection="SortDirection.Ascending">@Localizer1["ACDistribution"]</MudTableSortLabel></MudTh>
                    <MudTh>@Localizer1["Files"]</MudTh>

                    @*  <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Product?.Description)">@Localizer1["ACModel"]</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.GOS)">@Localizer1["ACGOS"]</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.CCP)">@Localizer1["ACCCP"]</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.HOE)">@Localizer1["ACHOE"]</MudTableSortLabel></MudTh>*@
                    <MudTh>@Localizer1["Actions"]</MudTh>
                </HeaderContent>
                <GroupHeaderTemplate>
                    <MudTh Class="mud-table-cell-custom-group" colspan="5">@($"{context.GroupName}: {context.Key}")</MudTh>
                    </GroupHeaderTemplate>
