                                                <MudExpansionPanel Style="width: auto;">
                                                    <TitleContent>
                                                        <div Style="align-items: center; display: flex;">
                                                            <MudText>@item.Code</MudText>
                                                            <MudChip Icon="@Icons.Material.Filled.DirectionsCar" IconColor="Color.Info" Variant="Variant.Text" Color="Color.Success">@item.Product?.Code - @item.Product?.Description</MudChip>
                                                        </div>
                                                    </TitleContent>
                                                    <ChildContent>
                                                        <MudItem class="d-flex flex-column justify-center ma-1">
                                                            <MudItem class="d-flex d-flex-column justify-center">

                                                                <MudItem Style="flex-direction: column;">
                                                                    @if (item.HOE != "")
