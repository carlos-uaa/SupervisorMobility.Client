                                <MudSelectItem Disabled="true" Value="0" OnClick='@(() => ShowError(@Localizer["notSelected"]))'>@Localizer["notSelected"]</MudSelectItem>
                                @foreach (var type in _distributions.Find(d => d.DistributionId == distributionId).Products)
                                {
                                    <MudSelectItem Value="type.ProductId">@($"{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }

