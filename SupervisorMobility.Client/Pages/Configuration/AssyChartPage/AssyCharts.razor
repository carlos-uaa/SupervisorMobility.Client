@page "/assychart"
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IChecklistService ChecklistService
@inject IAssyChartService AssyChartServices
@inject ISnackbar Snackbar
@inject IBridgeCDMSService CDMSServices

@*Title*@
<PageTitle>Supervisor Mobility | Assy Chart</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@if (_assychart == null)
{
    <MudProgressCircular Indeterminate="true"></MudProgressCircular>
}
else if (_assychart.Count == 0)
{
    <text>Defects List not found</text>
    <MudButton Href="/assychart/UploadAssyCharts#Upload">
        <MudText>Upload Data</MudText>
        <MudIcon Icon="@Icons.Material.Filled.UploadFile" aria-label="Upload" Color="Color.Primary"></MudIcon>
    </MudButton>
}
else
{
    <MudTable Items="_assychart" T="AssyChart" Hover="@hover" ReadOnly="@ronly"
          SortLabel="Sort By" Filter="new Func<AssyChart,bool>(FilterFunc)" Class="styled-table table-striped"
          HorizontalScrollbar="true">
        <ToolBarContent>
            <MudGrid class="d-flex flex-column justify-center align-self-center">
                <MudItem class="d-flex justify-center align-self-center ">
                    <MudText Typo="Typo.h6" Class="align-item-center center">Assy Chart</MudText>
                </MudItem>
                <MudItem Class="d-flex">
                    <MudSpacer />
                    <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                    <MudSpacer />
                    <MudButton Href="/assychart/UploadAssyCharts#Upload">
                        <MudText>Upload Data</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.UploadFile" aria-label="Upload" Color="Color.Primary"></MudIcon>
                    </MudButton>
                    <MudSpacer />
                    <MudButton Href="/assychart/BulkAssyCharts#Bulk">
                        <MudText>Bulk Data</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.Downloading" aria-label="Cancel" Color="Color.Warning"></MudIcon>
                    </MudButton>
                    <MudSpacer />
                    <MudButton Href="/assychart/createassychart">
                        <MudText>Create AssyChart</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Cancel" Color="Color.Warning"></MudIcon>
                    </MudButton>
                    <MudSpacer />

                </MudItem>
            </MudGrid>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.AssyChardId)">Id AssyChart</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Plant?.Description)">Plant</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Area?.Description)">Area</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Distribution?.Description)">Distribution</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.GOS)">GOS</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.CCP)">CCP</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.HOE)">HOE</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Operation?.Description)">Operation</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x?.Product?.Description)">Model</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.CreationDate)">Creation Date</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<AssyChart, object>(x=>x.ModificationDate)">Modification Date</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <GroupHeaderTemplate>
            <MudTh Class="mud-table-cell-custom-group" colspan="5">@($"{context.GroupName}: {context.Key}")</MudTh>
            </GroupHeaderTemplate>
            <RowTemplate>
                <MudTd DataLabel="Id AssyChart">
                    <MudText Align="Align.Center">@context.AssyChardId</MudText>
                </MudTd><MudTd DataLabel="Plant">
                    <MudText Align="Align.Center">@context.Plant?.Description</MudText>
                </MudTd>
                <MudTd DataLabel="Area">
                    <MudText Align="Align.Center">@context.Area?.Description</MudText>
                </MudTd>
                <MudTd DataLabel="Distribution">
                    <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
                </MudTd>
                <MudTd DataLabel="GOS">
                    <MudText Align="Align.Center">
                        <MudTooltip Text="Open Folder" Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogGOS(context.GOS))">
                        <MudTooltip Text="@context.GOS" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true" >
                            <MudButton @onclick="(() => OpenDialogGOS(context.GOS))" Style="padding: 0px;" Color="Color.Error">
                                    <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Style="font-size: 10px">@context.GOS.Split('/').Last()</MudChip>
                            </MudButton>
                        </MudTooltip>
                        </MudTooltip>
                    </MudText>
                </MudTd> <MudTd DataLabel="CCP">
                    <MudText Align="Align.Center">
                        <MudTooltip Text="Open Folder" Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogCcp(context.CCP))">
                        <MudTooltip Text="@context.CCP" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true">
                            <MudButton @onclick="(() => OpenDialogCcp(context.CCP))" Style="padding: 0px;" Color="Color.Error">
                                    <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Style="font-size: 10px">@context.CCP.Split('/').Last()</MudChip>
                            </MudButton>
                        </MudTooltip>
                        </MudTooltip>
                    </MudText>
                </MudTd> <MudTd DataLabel="HOE">
                    <MudText Align="Align.Center">
                        <MudTooltip Text="Open Folder" Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true" @onclick="(() => OpenDialogHoe(context.HOE))">
                        <MudTooltip Text="@context.HOE.Replace('§',' ')" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="true">
                            <MudButton @onclick="(() => OpenDialogHoe(context.HOE))" Style="padding: 0px;" Color="Color.Error">
                                <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Style="font-size: 10px">@context.HOE.Split('§').Last()</MudChip>
                            </MudButton>
                        </MudTooltip>
                        </MudTooltip>
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Description">
                    <MudText Align="Align.Center">@context.Operation?.Description</MudText>
                </MudTd>
                <MudTd DataLabel="Product">
                    <MudText Align="Align.Center">@context.Product?.Description</MudText>
                </MudTd>
                <MudTd DataLabel="Creation Date">
                    <MudText Align="Align.Center">@context.CreationDate</MudText>
                </MudTd>
                <MudTd DataLabel="Modification Date">
                    <MudText Align="Align.Center">@context.ModificationDate</MudText>
                </MudTd>
                <MudTd>
                    <MudText Align="Align.Center">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit" @onclick="(() => GoToUpdateAssyChart(context.AssyChardId))"></MudIconButton>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" @onclick="(() => DeleteAssyChart(context.AssyChardId))"></MudIconButton>
                    </MudText>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>

}
<MudDialog DisableSidePadding="false" @bind-IsVisible="GosDialog" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll" Class="d-flex flex-wrap gap-4 ">

            @foreach (GOSDocument DocFile in GosFilesInFolder.operation)
            {
                <MudItem Class="d-flex justify-center flex-wrap flex-column align-content-center align-center">

                    @switch (DocFile.Extension)
                    {
                        case "pdf":
                            <img src="Images/pdf.png" Height="70" Width="70" />

                            break;
                        case "doc":
                            // Para documentos Word con extensión .doc
                            <img src="Images/doc.png" Height="70" Width="70" />
                            break;

                        case "docx":
                            <img src="Images/docx.png" Height="70" Width="70" />
                            // Para documentos Word con extensión .docx
                            break;

                        case "ppt":
                            <img src="Images/ppt.png" Height="70" Width="70" />

                            // Para presentaciones PowerPoint con extensión .ppt
                            break;

                        case "pptx":
                            <img src="Images/pptx.png" Height="70" Width="70" />
                            // Para presentaciones PowerPoint con extensión .pptx
                            break;

                        case "xls":
                            // Para hojas de cálculo Excel con extensión .xls
                            <img src="Images/xls.png" Height="70" Width="70" />
                            break;

                        case "xlsx":
                            // Para hojas de cálculo Excel con extensión .xlsx
                            <img src="Images/xlsx.png" Height="70" Width="70" />
                            break;

                        case "jpg":
                            <img src="Images/jpg.png" Height="70" Width="70" />
                            break;

                        case "jpeg":
                            // Para imágenes JPEG con extensión .jpg o .jpeg
                            <img src="Images/jpg.png" Height="70" Width="70" />
                            break;

                        case "png":
                            // Para imágenes PNG con extensión .png
                            <img src="Images/png.png" Height="70" Width="70" />
                            break;

                        case "gif":
                            // Para imágenes GIF con extensión .gif
                            <img src="Images/gif.png" Height="70" Width="70" />
                            break;
                        default:
                            <img src="Images/error.png" Height="70" Width="70" />
                            break;
                    }

                    <MudItem>
                        <MudButton Href="@DocFile.URL">Download </MudButton>
                        <MudText Class="d-flex flex-wrap">@DocFile.Nombre</MudText>

                    </MudItem>
                </MudItem>
            }


        </MudContainer>
    </DialogContent>
    <DialogActions>
        @*<MudIconButton @onclick="(() => JobObservationUpdate(jobId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>*@
        <MudButton Color="Color.Info" OnClick="CloseGos">Close</MudButton>
    </DialogActions>
</MudDialog>

