@page "/assychart"
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IChecklistService ChecklistService
@inject IAssyChartService AssyChartServices
@inject ISnackbar Snackbar
@inject IBridgeCDMSService CDMSServices
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionServices

@*Title*@
<PageTitle>Supervisor Mobility | Assy Chart</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@if (_assychart == null)
{
    <MudProgressCircular Indeterminate="true"></MudProgressCircular>
}
else if (_assychart.Count == 0)
{
    <text>Defects List not found</text>
    <MudButton Href="/assychart/UploadAssyCharts#Upload">
        <MudText>Upload Data</MudText>
        <MudIcon Icon="@Icons.Material.Filled.UploadFile" aria-label="Upload" Color="Color.Primary"></MudIcon>
    </MudButton>
}
else
{
    <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
        <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="All AssyCharts">
