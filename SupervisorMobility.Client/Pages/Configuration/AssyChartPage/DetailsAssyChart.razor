                </MudItem>

                </MudItem>

                }
                *@



                <MudItem Class="d-flex flex-column justify-center">

                    @if (_assychart.RoutesProductsAssyChart?.Count == 0 )
                    {
                        <MudAlert Severity="Severity.Info">
                            This AssyChart No Have Produts Added
                        </MudAlert>
                    }
                    else
                    {
                        @switch (_assychart.RoutesProductsAssyChart?.Count)
                        {
                            case null:

                                <MudItem class="d-flex d-flex-column justify-center">
                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                </MudItem>

                                break;
                            case 0:

                                if (_assychart.PlantId == 0)
                                {
                                    <MudItem class="d-flex d-flex-column justify-center">
                                        <MudText Typo="Typo.h6"> @Localizer1["routes"] </MudText>
                                    </MudItem>

                                    <MudItem class="d-flex flex-column justify-center justify-align-center">
                                        <MudAlert Severity="Severity.Info">
                                            First Select Plant
                                        </MudAlert>
                                    </MudItem>
                                }
                                else if (_assychart.AreaId == 0)
                                {
                                    <MudItem class="d-flex d-flex-column justify-center">
                                        <MudText Typo="Typo.h6"> @Localizer1["routes"] </MudText>
                                    </MudItem>

                                    <MudItem class="d-flex flex-column justify-center justify-align-center">
                                        <MudAlert Severity="Severity.Info">
                                            First Select Area
                                        </MudAlert>
                                    </MudItem>
                                }
                                else if (_assychart.DistributionId == 0)
                                {
                                    <MudItem class="d-flex d-flex-column justify-center">
                                        <MudText Typo="Typo.h6"> @Localizer1["routes"] </MudText>
                                    </MudItem>

                                    <MudItem class="d-flex flex-column justify-center justify-align-center">
                                        <MudAlert Severity="Severity.Info">
                                            First Select Distribution
                                        </MudAlert>
                                    </MudItem>
                                }
                                else
                                {
                                    <MudItem class="d-flex d-flex-column justify-center">
                                        <MudText Typo="Typo.h6"> @Localizer["Routes"] </MudText>
                                    </MudItem>

                                    <MudItem class="d-flex flex-column justify-center justify-align-center">
                                        <MudAlert Severity="Severity.Info">
                                            First add Some product Route
                                        </MudAlert>
                                    </MudItem>
                                }
                                break;
                            default:
                                <MudItem class="d-flex d-flex-column justify-center">
                                    <MudText Typo="Typo.h6"> @Localizer["Routes"] </MudText>
                                </MudItem>


                                @if (_assychart.RoutesProductsAssyChart is not null && _assychart.RoutesProductsAssyChart?.ToList().Count > 0)
                                {

                                    <MudItem Style="max-height: 70vh; max-width: 90vw; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">
                                        @foreach (var item in _assychart.RoutesProductsAssyChart)
                                        {
                                            <MudButton OnClick="@(e => OpenDialogProduct(item))" FullWidth="false" Class="d-flex justify-center" Style="height:100%;">
                                                <MudCard Elevation="3" Outlined="true" Style="min-width:450px">

                                                    <MudCardHeader>
                                                        <CardHeaderAvatar>
                                                            <MudChip Icon="@Icons.Material.Filled.DirectionsCar" Color="Color.Info">@item.Product?.Code</MudChip>
                                                        </CardHeaderAvatar>
                                                        <CardHeaderContent>
                                                            <MudText Typo="Typo.body1">@item.Product?.Description</MudText>
                                                        </CardHeaderContent>

                                                    </MudCardHeader>

                                                    <MudCardContent Style="max-width: 90vw; overflow-y: scroll; display: flex; flex-wrap: wrap; flex-direction: column;" Class="gap-4">
                                                        <MudTextField Label="@Localizer1["ACLabelGOSSelect"]" ReadOnly="true" @bind-Value="@item.GOS" />
                                                        <MudTextField Label="@Localizer1["ACLabelCCPSelect"]" ReadOnly="true" @bind-Value="@item.CCP" />
                                                        <MudTextField Label="@Localizer1["ACLabelHOESelect"]" ReadOnly="true" Value="@item.HOE.Replace('§', ' ')" />
                                                    </MudCardContent>
                                                </MudCard>
                                            </MudButton>

                                        }
                                    </MudItem>

                                }




                                break;
                        }
                    }


                </MudItem>




                @*Operation *@

                @* <MudItem xs="12" sm="12" lg="12" md="12" Style="display: flex; flex-wrap: wrap; flex-direction:row">
                <MudItem xs="9" sm="9" lg="9" md="9">
                <MudSelect T="int" Label="@Localizer["ACLabelOperation"]" Placeholder="@Localizer["ACPHOperation"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_assychart.OperationId" For="@(() => _assychart.OperationId)">
                <MudSelectItem Disabled="true" Value="0">@Localizer["ACPHOperation"]</MudSelectItem>
                @foreach (var type in _distributionValues.Operations)
                {
                <MudSelectItem Value="type.OperationId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                }
                </MudSelect>
                </MudItem>
                <MudItem xs="3" sm="3" lg="3" md="3">
                @if (_assychart.OperationId != 0)
                {

                @switch (_distributionValues.Operations.Find(op => op.OperationId == _assychart.OperationId).CriticalType)
                {
                case 1:
                <MudTextField  Class="mt-3" AnchorOrigin="Origin.BottomCenter" ReadOnly Value="'A'" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                break;
                case 2:
                <MudTextField  Class="mt-3" AnchorOrigin="Origin.BottomCenter" ReadOnly Value="'B'" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                break;
                case 3:
                <MudTextField  Class="mt-3" AnchorOrigin="Origin.BottomCenter" ReadOnly Value="'C'" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                break;
                default:
                <MudTextField Class="mt-3" AnchorOrigin="Origin.BottomCenter" ReadOnly Value="@Localizer0["OPCritical"]" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                break;
                }

                }
                </MudItem>
                </MudItem>*@





            </MudCardContent>
            }else{
                <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
                    <ItemTemplate>
                        <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                            <MudItem class="d-flex flex-column justify-center align-self-center">
                                <MudProgressCircular Color="@_Colors[context.IndexOf(context)]" Style="height:70px;width:70px;" Indeterminate="true" />
                            </MudItem>
                            @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                            <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@context</MudText>
                        </div>
                    </ItemTemplate>
                </MudCarousel>
            }


            <MudCardActions>
                <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CloseDetalils())">@Localizer["Close"]</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>



<MudDialog @bind-IsVisible="ProductModalDisplay" Options="dialogOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["routes"]</MudText>
        <MudText Class="mt-4 mb-4">

        </MudText>

        <MudItem Style="max-height: 70vh; min-width: 90vw; overflow-y: scroll;" Class="gap-4">


            <MudCard Elevation="3" Outlined="true">

                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudChip Color="Color.Info">@RouteProductDialogDisplay.Product?.Code</MudChip>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.body1">@RouteProductDialogDisplay.Product?.Description</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Style="max-width: 90vw; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">

                    <MudTabs Outlined="true" Position="Position.Left" Rounded="true" Border="true"
                             ApplyEffectsToContainer="true" Class="mt-8" PanelClass="pa-6">

                        @if (RouteProductDialogDisplay.GOS != "")
                        {
                            <MudTabPanel>
                                <TabContent>
                                            <MudChip Icon="@Icons.Material.Filled.Folder" Style="display: flex;" Color="Color.Warning"> GOS</MudChip>

                                </TabContent>
                                <ChildContent>

                                <MudCard Elevation="1" Class="mr-5">
                                    <MudCardHeader Style=" display: flex;  flex-wrap: wrap;  align-content: center;   flex-direction: column;">
                                        <CardHeaderActions>
                                            <MudText Typo="Typo.h6">
                                                @Localizer1["ACGOSRute"]:  @GOSrute
                                            </MudText>
                                        </CardHeaderActions>
                                    </MudCardHeader>
                                    <MudCardContent Style="max-width: 85vw; min-width: 75vw;    display: flex;    flex-wrap: wrap;    justify-content: center; ">
                                        @if (GosFilesInFolder != null)
                                        {

                                            @if (GosFilesInFolder.operation.Count() > 0)
                                            {
                                                @foreach (GOSDocument DocFile in GosFilesInFolder.operation)
                                                {

                                                    <MudPaper Class="mr-5 mt-5" style="flex: 0 0 calc(28% - 1rem);">
                                                        <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center mt-5">
                                                            @switch (DocFile.Extension)
                                                            {
                                                                case "pdf":
                                                                    <img src="Images/pdf.png" Height="70" Width="70" />

                                                                    break;
                                                                case "doc":
                                                                    // Para documentos Word con extensión .doc
                                                                    <img src="Images/doc.png" Height="70" Width="70" />
                                                                    break;

                                                                case "docx":
                                                                    <img src="Images/docx.png" Height="70" Width="70" />
                                                                    // Para documentos Word con extensión .docx
                                                                    break;

                                                                case "ppt":
                                                                    <img src="Images/ppt.png" Height="70" Width="70" />

                                                                    // Para presentaciones PowerPoint con extensión .ppt
                                                                    break;

                                                                case "pptx":
                                                                    <img src="Images/pptx.png" Height="70" Width="70" />
                                                                    // Para presentaciones PowerPoint con extensión .pptx
                                                                    break;

                                                                case "xls":
                                                                    // Para hojas de cálculo Excel con extensión .xls
                                                                    <img src="Images/xls.png" Height="70" Width="70" />
                                                                    break;

                                                                case "xlsx":
                                                                    // Para hojas de cálculo Excel con extensión .xlsx
                                                                    <img src="Images/xlsx.png" Height="70" Width="70" />
                                                                    break;

                                                                case "jpg":
                                                                    <img src="Images/jpg.png" Height="70" Width="70" />
                                                                    break;

                                                                case "jpeg":
                                                                    // Para imágenes JPEG con extensión .jpg o .jpeg
                                                                    <img src="Images/jpg.png" Height="70" Width="70" />
                                                                    break;

                                                                case "png":
                                                                    // Para imágenes PNG con extensión .png
                                                                    <img src="Images/png.png" Height="70" Width="70" />
                                                                    break;

                                                                case "gif":
                                                                    // Para imágenes GIF con extensión .gif
                                                                    <img src="Images/gif.png" Height="70" Width="70" />
                                                                    break;
                                                                default:
                                                                    <img src="Images/error.png" Height="70" Width="70" />
                                                                    break;
                                                            }
                                                            <MudTooltip Text="@Localizer["Download"]" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true">
                                                                <MudButton @onclick="() => DownloadFileFromURL_GOS(DocFile.URL, DocFile.Nombre)">
                                                                    <MudItem>
                                                                        <MudChip Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer;max-width: 315px" Icon="@Icons.Material.Filled.Download" Text="@DocFile.Nombre" Color="Color.Info" />
                                                                    </MudItem>
                                                                </MudButton>
                                                            </MudTooltip>
                                                        </MudItem>

                                                    </MudPaper>
                                                }
                                            }
                                            else if (GosFilesInFolder.operation.Count == 0 && !folderErrorGOS)
                                            {

                                                <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                                                        <img src="Images/navegador.png" Height="140" Width="140" />
                                                    </MudItem>

                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                        <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                        <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                            <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["NoFilesDirectory"]</MudText>
                                                        </MudItem>
                                                    </MudItem>
                                                </MudItem>
                                            }
                                            else
                                            {
                                                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                            }

                                        }
                                        else
                                        {
                                            if (folderErrorGOS)
                                            {
                                                <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                                                        <img src="Images/dialogerror.png" Height="140" Width="140" />
                                                    </MudItem>

                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                        <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                        <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                            <MudText Typo="Typo.h6" Align="Align.Center" Label="Name"> @Localizer["ServerNotResponse"]</MudText>
                                                        </MudItem>
                                                    </MudItem>
                                                </MudItem>
                                            }
                                            else
                                            {
                                                <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                                                        <img src="Images/dialogerror.png" Height="140" Width="140" />
                                                    </MudItem>

                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                        <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                        <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                            <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["DataNotFound"]</MudText>
                                                        </MudItem>
                                                    </MudItem>
                                                </MudItem>
                                            }
                                        }


                                    </MudCardContent>
                                </MudCard>
                                </ChildContent>
                            </MudTabPanel>

                        }

                        @if (RouteProductDialogDisplay.CCP != "")
                        {

                            <MudTabPanel>
                                <TabContent>
                                     <MudChip Icon="@Icons.Material.Filled.Folder" Style="display: flex;" Color="Color.Warning"> CCP</MudChip>
                                </TabContent>
                                <ChildContent>
                                <MudCard Elevation="1" Class="mr-5" Style="min-width: 400px; ">

                                    <MudCardHeader Style=" display: flex;  flex-wrap: wrap;  align-content: center;   flex-direction: column;">
                                        <CardHeaderActions>
                                            <MudText Typo="Typo.h6">
                                                CCP Rute: @CCPrute
                                            </MudText>
                                        </CardHeaderActions>
                                    </MudCardHeader>
                                    <MudCardContent Style="max-width: 85vw; min-width: 75vw;    display: flex;    flex-wrap: wrap;    justify-content: center; ">
                                        @if (CcpFilesInFolder != null)
                                        {
                                            @if (CcpFilesInFolder.operation.Count() > 0)
                                            {
                                                @foreach (CCPDocument DocFile in CcpFilesInFolder.operation)
                                                {
                                                    <MudPaper Class="mr-5 mt-5" style="flex: 0 0 calc(28% - 1rem);">
                                                        <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center mt-5">
                                                            @switch (DocFile.Extension)
                                                            {
                                                                case "pdf":
                                                                    <img src="Images/pdf.png" Height="70" Width="70" />

                                                                    break;
                                                                case "doc":
                                                                    // Para documentos Word con extensión .doc
                                                                    <img src="Images/doc.png" Height="70" Width="70" />
                                                                    break;

                                                                case "docx":
                                                                    <img src="Images/docx.png" Height="70" Width="70" />
                                                                    // Para documentos Word con extensión .docx
                                                                    break;

                                                                case "ppt":
                                                                    <img src="Images/ppt.png" Height="70" Width="70" />

                                                                    // Para presentaciones PowerPoint con extensión .ppt
                                                                    break;

                                                                case "pptx":
                                                                    <img src="Images/pptx.png" Height="70" Width="70" />
                                                                    // Para presentaciones PowerPoint con extensión .pptx
                                                                    break;

                                                                case "xls":
                                                                    // Para hojas de cálculo Excel con extensión .xls
                                                                    <img src="Images/xls.png" Height="70" Width="70" />
                                                                    break;

                                                                case "xlsx":
                                                                    // Para hojas de cálculo Excel con extensión .xlsx
                                                                    <img src="Images/xlsx.png" Height="70" Width="70" />
                                                                    break;

                                                                case "jpg":
                                                                    <img src="Images/jpg.png" Height="70" Width="70" />
                                                                    break;

                                                                case "jpeg":
                                                                    // Para imágenes JPEG con extensión .jpg o .jpeg
                                                                    <img src="Images/jpg.png" Height="70" Width="70" />
                                                                    break;

                                                                case "png":
                                                                    // Para imágenes PNG con extensión .png
                                                                    <img src="Images/png.png" Height="70" Width="70" />
                                                                    break;

                                                                case "gif":
                                                                    // Para imágenes GIF con extensión .gif
                                                                    <img src="Images/gif.png" Height="70" Width="70" />
                                                                    break;
                                                                default:
                                                                    <img src="Images/error.png" Height="70" Width="70" />
                                                                    break;
                                                            }
                                                            <MudTooltip Text="Download" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true">
                                                                <MudButton @onclick="() => DownloadFileFromURL_CCP(DocFile.URL, DocFile.Nombre)">
                                                                    <MudItem>
                                                                        <MudChip Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer;max-width: 315px" Icon="@Icons.Material.Filled.Download" Text="@DocFile.Nombre" Color="Color.Info" />
                                                                    </MudItem>
                                                                </MudButton>
                                                            </MudTooltip>
                                                        </MudItem>

                                                    </MudPaper>
                                                }
                                            }
                                            else if (CcpFilesInFolder.operation.Count == 0 && !folderErrorCCP)
                                            {

                                                <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                                                        <img src="Images/navegador.png" Height="140" Width="140" />
                                                    </MudItem>

                                                    <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                        <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                        <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                            <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["NoFilesDirectory"]</MudText>
                                                        </MudItem>
                                                    </MudItem>
                                                </MudItem>
                                            }
                                            else
                                            {
                                                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                            }
                                        }
                                        else
