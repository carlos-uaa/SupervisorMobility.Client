@page "/assychart/details/{assychartId:int}"

@*Title*@
<PageTitle>Supervisor Mobility |@Localizer1["ACDetails"]</PageTitle>

@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionServices
@inject IAssyChartService AssyChartServices
@inject IBridgeCDMSService CDMSServices
@inject IProductService ProductServices
@inject IJSRuntime JS
@inject IJSRuntime JsRuntime
@inject IBridgeCDMSService CDMSServices
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager


@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>



<MudGrid>
    <MudItem xs="12">
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@Localizer1["ACDetails"]</MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudChip @onclick="()=>EditAssyChart(_assychart.AssyChardId)" @ontouchstart="()=>EditAssyChart(_assychart.AssyChardId)" Variant="Variant.Filled" Class="ml-auto mr-13 mb-10" Icon="@Icons.Material.Filled.Edit" Color="Color.Info">@Localizer1["ACEdit"]</MudChip>

                </CardHeaderActions>
            </MudCardHeader>
            @*Mud select of plants *@

            @if(!ShowLoading){
            
            <MudCardContent>

                <MudSelect T="int" Label="@Localizer1["ACLabelPlant"]" Variant="Variant.Text" Placeholder="@Localizer1["ACPHPlant"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxplant" For="@(() => auxplant)" ReadOnly="true">
                    <MudSelectItem Disabled="true" Value="0">@Localizer1["ACPHPlant"]</MudSelectItem>
                    @foreach (var type in _plants)
                    {
                        <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                    }
                </MudSelect>

                @*Mud select of Areas *@

                <MudSelect T="int" Label="@Localizer1["ACLabelArea"]" Variant="Variant.Text" Placeholder="@Localizer1["ACPHArea"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxarea" For="@(() => auxarea)" ReadOnly="true">
                    <MudSelectItem Disabled="true" Value="0">@Localizer1["ACPHArea"]</MudSelectItem>
                    @foreach (var type in _areas)
                    {
                        <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                    }
                </MudSelect>

                @*Mud select of Distributions *@

                <MudSelect T="int" Label="@Localizer1["ACLabelDistribution"]" Placeholder="@Localizer1["ACPHDistribution"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxdistribution" For="@(() => auxdistribution)" ReadOnly="true">
                    <MudSelectItem Disabled="true" Value="0">@Localizer1["ACPHDistribution"]</MudSelectItem>
                    @foreach (var type in _distributions)
                    {
                        <MudSelectItem Value="type.DistributionId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                    }
                </MudSelect>

                @*   @if (_distributionValues.Products.Count > 0)
                {

                <MudItem class="d-flex d-flex-column justify-center ma-1">

                <MudItem Class="d-flex d-flex-row">

                <MudItem xs="12" sm="12" md="12">
