<MudDialog @bind-IsVisible="CodePathModalDisplay" Options="dialogOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@RouteCodePathDialogDisplay.Code</MudText>
        <MudText Class="mt-4 mb-4">

        </MudText>

        <MudItem Style="min-height: 75vh;" Class="gap-4">
           

