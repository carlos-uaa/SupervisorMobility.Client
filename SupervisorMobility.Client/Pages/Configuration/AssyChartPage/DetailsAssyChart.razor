                                                                    break;

                                                                case "pptx":
                                                                    <img src="Images/pptx.png" Height="70" Width="70" />
                                                                    // Para presentaciones PowerPoint con extensión .pptx
                                                                    break;

                                                                case "xls":
                                                                    // Para hojas de cálculo Excel con extensión .xls
                                                                    <img src="Images/xls.png" Height="70" Width="70" />
                                                                    break;

                                                                case "xlsx":
                                                                    // Para hojas de cálculo Excel con extensión .xlsx
                                                                    <img src="Images/xlsx.png" Height="70" Width="70" />
                                                                    break;

                                                                case "jpg":
                                                                    <img src="Images/jpg.png" Height="70" Width="70" />
                                                                    break;

                                                                case "jpeg":
