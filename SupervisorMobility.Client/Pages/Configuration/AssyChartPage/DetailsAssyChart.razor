<MudDialog @bind-IsVisible="CodePathModalDisplay" Options="dialogOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@RouteCodePathDialogDisplay.Code</MudText>
        <MudText Class="mt-4 mb-4">

        </MudText>

        <MudItem Style="min-height: 75vh;" Class="gap-4">
           

            <MudCard Elevation="3" Outlined="true">

                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudChip Color="Color.Info">@RouteCodePathDialogDisplay.Product?.Code</MudChip>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.body1">@RouteCodePathDialogDisplay.Product?.Description</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Style="max-height: 67vh; min-height: 65vh; width: 100%; display: flex; flex-wrap: wrap;" Class="gap-4">


                        <SupervisorMobility.Client.Pages.Components.TreeView Path_Id="RouteCodePathDialogDisplay.SOSCodePathId" panel="panelSelect"></SupervisorMobility.Client.Pages.Components.TreeView>



                </MudCardContent>
            </MudCard>




        </MudItem>

    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseModalFiles" Variant="Variant.Filled">@Localizer["Close"]</MudButton>
    </DialogActions>
</MudDialog>



