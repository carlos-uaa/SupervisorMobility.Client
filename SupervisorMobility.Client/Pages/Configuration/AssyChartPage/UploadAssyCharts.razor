@page "/assychart/UploadAssyCharts"
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage
@inject IFileUploadAndDownloadService FileUpDoServices
@inject IPlantService PlantsServices
@inject IAreaService AreasServices
@inject IDistributionService DistributionsServices
@inject IAssyChartService AssyChartServices
@inject IProductService ProductsServices
@inject IJSRuntime _js
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1



@*Title*@
<PageTitle>Supervisor Mobility | @Localizer1["ACUploadAC"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


<SupervisorMobility.Client.Pages.Configuration.PlantPage.Plants></SupervisorMobility.Client.Pages.Configuration.PlantPage.Plants>

   
@*<MudItem style="text-align:center">
    <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Site Under Construction</MudText>
    <img src="Images/underConstruction.jpg"  />
</MudItem>*@


<MudContainer Fixed="true" Class="py-10">
    <MudGrid>
        <MudItem>
            @if (showTable)
            {
                <MudTable Items="@_assycharts" T="AssyChart" HorizontalScrollbar="true" ReadOnly="true">
                    <ToolBarContent>
                        <MudSpacer />
                        <MudText Typo="Typo.h6">@Localizer1["ACACResume"]</MudText>
                        <MudSpacer />
                        <MudButton @onclick="(() => UploadFunction())" Disabled="@activeUpload">
                            <MudText>@Localizer1["ACUpload"]</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.UploadFile" aria-label="Upload" Color="Color.Primary"></MudIcon>
                        </MudButton>
                        <MudSpacer />
                        <MudButton @onclick="(() => CancelFunction())">
                            <MudText>@Localizer1["ACCancelUpload"]</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.Cancel" aria-label="Cancel" Color="Color.Warning"></MudIcon>
                        </MudButton>
                        <MudSpacer />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>@Localizer1["ACPlant"]</MudTh>
                        <MudTh>@Localizer1["ACArea"]</MudTh>
                        <MudTh>@Localizer1["ACDistribution"]</MudTh>
                          <MudTh>@Localizer1["Paths"]</MudTh>
                    @* <MudTh>@Localizer1["ACCCP"]</MudTh>*@
                        @*<MudTh>@Localizer1["ACHOE"]</MudTh>*@
                        @*<MudTh>@Localizer1["ACOperation"]</MudTh>*@
                        @*<MudTh>@Localizer1["ACModel"]</MudTh>*@
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Plant">
                            <MudText Align="Align.Center">@context.Plant?.Description</MudText>
                        </MudTd>
                        <MudTd DataLabel="Area">
                            <MudText Align="Align.Center">@context.Area?.Description</MudText>
                        </MudTd>
                        <MudTd DataLabel="Distribution ">
                            <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
                        </MudTd>
                        <MudTd DataLabel="Rutas">
                            <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
                        </MudTd>
                        
                        <MudTd DataLabel="Paths">
                            <MudText Align="Align.Center">Paths</MudText>
                        </MudTd> 
                       @* <MudTd DataLabel="CCP">
                            <MudText Align="Align.Center">@context.CCP</MudText>
                        </MudTd> <MudTd DataLabel="HOE">
                            <MudText Align="Align.Center">@context.HOE</MudText>
                        </MudTd>
                        <MudTd DataLabel="Operation">
                            <MudText Align="Align.Center">@context.Operation?.Description</MudText>
                        </MudTd>
                        <MudTd DataLabel="Product">
                            <MudText Align="Align.Center">@context.Product?.Description</MudText>
                        </MudTd>*@
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            }

          
          
            

        </MudItem>
    </MudGrid>
</MudContainer>
<MudSpacer></MudSpacer>




<MudExpansionPanels>
    <MudExpansionPanel Text="Show event log">
        @foreach (var message in List_Events)
        {
            <MudText>@message.Mensaje</MudText>
        }

    </MudExpansionPanel>
</MudExpansionPanels>
