@page "/assychart"
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IChecklistService ChecklistService

@*Title*@
<PageTitle>Supervisor Mobility | Assy Chart</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Checklist categories table*@
<MudTable Items="_checklistCategories" Hover="true" T="ChecklistCategory">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Checklist categories</MudText>
        <MudSpacer />
        <MudIconButton Href="/checklistcategory/createcategory" Icon="@Icons.Material.Filled.Add" aria-label="add"></MudIconButton>
        <MudIconButton Href="/checklistcategories/sequence" Icon="@Icons.Material.Filled.Reorder" aria-label="reorder"></MudIconButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudText Align="Align.Center">Category Id</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Code</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Description</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Sequence</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Status</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Actions</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="CategoryId">
            <MudText Align="Align.Center">@context.ChecklistCategoryId</MudText>
        </MudTd>
        <MudTd DataLabel="Code">
            <MudText Align="Align.Center">@context.Code</MudText>
        </MudTd>
        <MudTd DataLabel="Description">
            <MudText Align="Align.Center">@context.Description</MudText>
        </MudTd>
        <MudTd DataLabel="Sequence">
            <MudText Align="Align.Center">@context.Sequence</MudText>
        </MudTd>
        <MudTd DataLabel="Status">
            @if (context.IsActive == true)
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                </MudText>
            }
            else
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                </MudText>
            }
        </MudTd>
        <MudTd>
            <MudText Align="Align.Center">
                <MudIconButton Icon="@Icons.Material.Filled.Info" aria-label="info" @onclick="(() => CategoryDetails(context.ChecklistCategoryId))"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit" @onclick="(() => UpdateCategory(context.ChecklistCategoryId))"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="Delete" @onclick="(() => DeleteCategory(context.ChecklistCategoryId))"></MudIconButton>
            </MudText>
        </MudTd>
    </RowTemplate>
</MudTable>