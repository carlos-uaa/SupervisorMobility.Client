                </MudCardContent>

                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Disabled="enablecreate" Variant="Variant.Filled" Color="Color.Info" @onclick="@(() => CreateNewAssyChartAsync())" Class="ml-auto">@Localizer1["ACCreate"]</MudButton>
