                    }
                    }
                    else
                    {
                    if (folderCCPError)
                    {
                    <MudAlert Severity="Severity.Warning" Style="text-align: center"> @Localizer1["ServerNotResponse"] </MudAlert>
                    }
                    }*@





                    @*    <MudSelect Label="CCP" Variant="Variant.Text" Placeholder="Select a CCP" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_newassychart.CCP" For="@(() => _newassychart.CCP)">
                    <MudSelectItem Disabled="true" Value="@_newassychart.GOS">Select a CCP</MudSelectItem>
                    @foreach (var type in _ccp)
