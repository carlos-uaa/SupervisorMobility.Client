<MudDialog @bind-IsVisible="ProductModalDisplay" Options="dialogOptions" @onclose="@(() => StateHasChanged())">
    <DialogContent>
      
        <MudItem Style="max-height: 75vh; min-height: 70vh; min-width: 90vw; overflow-y: scroll;" Class="gap-4">


            <MudCard Elevation="3" Outlined="true">

                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudChip Color="Color.Info">@CodePathDialog.Product?.Code</MudChip>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudTextField Typo="Typo.body1" Label="Code" @bind-Value="@CodePathDialog.Code" ></MudTextField>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudMenu EndIcon="@Icons.Material.Filled.Settings" Label="Options" Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                            @if (!if_add_CD_HOE)
                            {
                                <MudMenuItem Icon="@Icons.Material.Filled.CreateNewFolder" @onclick="(() => AddRemove_CD_HOE())" @ontouchstart="(() => AddRemove_CD_HOE())">
                                    Add Common Direction HOE
                                </MudMenuItem>
                            }
                            @if (!if_add_CD_CCP)
                            {
                                <MudMenuItem Icon="@Icons.Material.Filled.CreateNewFolder" @onclick="(() => AddRemove_CD_CCP())" @ontouchstart="(() => AddRemove_CD_CCP())">
                                    Add Common Direction CCP
                                </MudMenuItem>
                            }
                            @if (!if_add_CD_GOS)
                            {
                                <MudMenuItem Icon="@Icons.Material.Filled.CreateNewFolder" @onclick="(() => AddRemove_CD_GOS())" @ontouchstart="(() => AddRemove_CD_GOS())">
                                    Add Common Direction GOS
                                </MudMenuItem>
                            }
                        </MudMenu>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Style="min-width: 70vw;    max-height: 65vh;    min-height: 60vh; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">

                    <MudCard Elevation="1" Class="mr-5"  Style="min-width: 350px; flex: 0 0 calc(28% - 1rem);">
                        <MudCardHeader>
                            <CardHeaderActions>
                                <MudChip Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Info" Variant="Variant.Outlined">HOE</MudChip>
                                <MudIconButton Icon="@Icons.Material.Filled.FormatClear" Color="Color.Error" OnClick="@(() => DeleteHOERoute())" />
                            </CardHeaderActions>

                        </MudCardHeader>
                        <MudCardContent>

                            @if (HOEFolders != null)
                            {
                                @if (rootNodeHOE.TreeItems.Count > 0)
                                {
                                    <MudPaper Elevation="0">

                                        <MudTextField Label="@Localizer1["ACLabelHOESelect"]" ReadOnly="true" Value="@Regex.Replace(CodePathDialog.HOE, @"/(.*?)§", "/").Replace('§', ' ')" />

                                        <MudTreeView ServerData="LoadServerData" Color="Color.Primary" @bind-SelectedValue="@SelectedNodeHOE" @bind-Value="@CodePathDialog.CommonDirectionHOE" Context="OtherContext" Items="rootNodeHOE.TreeItems">
                                            <ItemTemplate>
                                                <MudTreeViewItem Value="@OtherContext" @onclick="@(() => { @CodePathDialog.HOE = OtherContext.Ruta; })" LoadingIconColor="Color.Info" CanExpand="@OtherContext.EsDirectorio" Text="@OtherContext.Nombre.Split('§').Last()" EndTextTypo="@Typo.caption" />
                                            </ItemTemplate>
                                        </MudTreeView>
                                    </MudPaper>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Info" Style="text-align: center">@Localizer1["ACHOEDirectory"]</MudAlert>
                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                }

                            }
                            else
                            {
                                if (folderHOEError)
                                {
                                    <MudAlert Severity="Severity.Warning" Style="text-align: center"> @Localizer1["ServerNotResponse"] </MudAlert>
                                }
                            }

                             @if (if_add_CD_HOE)
                            {
                                <MudPaper Elevation="0">
                                    @if (if_add_CD_HOE)
                                    {
                                   
                                               <MudIconButton Icon="@Icons.Material.Filled.FolderDelete" Color="Color.Error" OnClick="@(() => AddRemove_CD_HOE())" @ontouchstart="@(() => AddRemove_CD_HOE())" />
                                    <MudChip Icon="@Icons.Material.Filled.Folder" Color="Color.Warning">CommonDirection HOE</MudChip>
                                    <MudIconButton Icon="@Icons.Material.Filled.FormatClear" Color="Color.Warning" OnClick="@(() => DeleteHOERouteCD())" @ontouchstart="@(() => DeleteHOERouteCD())" />
                               
                                        }

                                </MudPaper>
                                @if (HOEFolders != null)
                                {
                                    @if (rootNodeHOE.TreeItems.Count > 0)
                                    {
                                        <MudPaper Elevation="0">

                                            <MudTextField Label="@Localizer1["ACLabelHOESelectCD"]" ReadOnly="true" Value="@Regex.Replace(CodePathDialog.CommonDirectionHOE, @"/(.*?)§", "/").Replace('§', ' ')" />

                                            <MudTreeView ServerData="LoadServerData" Color="Color.Primary" @bind-SelectedValue="@SelectedNodeHOE" @bind-Value="@CodePathDialog.CommonDirectionHOE" For="@(() => @CodePathDialog.CommonDirectionHOE)" Context="OtherContext" Items="rootNodeHOE.TreeItems">
                                                <ItemTemplate>
                                                    <MudTreeViewItem Value="@OtherContext" @onclick="@(() => { @CodePathDialog.CommonDirectionHOE = OtherContext.Ruta; })" LoadingIconColor="Color.Info" CanExpand="@OtherContext.EsDirectorio" Text="@OtherContext.Nombre.Split('§').Last()" EndTextTypo="@Typo.caption" />
                                                </ItemTemplate>
                                            </MudTreeView>
                                        </MudPaper>
                                    }
                                    else
                                    {
                                        <MudAlert Severity="Severity.Info" Style="text-align: center">@Localizer1["ACHOEDirectory"]</MudAlert>
                                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                    }

                                }
                                else
                                {
                                    if (folderHOEError)
                                    {
                                        <MudAlert Severity="Severity.Warning" Style="text-align: center"> @Localizer1["ServerNotResponse"] </MudAlert>
                                    }
                                }


                            }
                        </MudCardContent>
                    </MudCard>

           

                    <MudCard Elevation="1" Class="mr-5" Style="min-width: 350px; flex: 0 0 calc(28% - 1rem);">
                        <MudCardHeader>
                            <CardHeaderActions>
                                <MudChip Icon="@Icons.Material.Filled.Folder" Color="Color.Warning">CCP</MudChip>
                                <MudIconButton Icon="@Icons.Material.Filled.FormatClear" Color="Color.Error" OnClick="@(() => DeleteCCPRoute())" />

                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>

                            @if (CCPFolders != null)
                            {
                                @if (rootNodeCCP.TreeItems.Count > 0)
                                {
                                    <MudPaper Elevation="0">
                                        <MudTextField Label="@Localizer1["ACLabelCCPSelect"]" ReadOnly="true"
                                        @bind-Value="@CodePathDialog.CCP" For="@(() => @CodePathDialog.CCP)" />
                                        <MudTreeView ServerData="LoadServerData" Color="Color.Primary" @bind-SelectedValue="@SelectedNodeCCP" Context="CCPContext" Items="rootNodeCCP.TreeItems">
                                            <ItemTemplate>
                                                <MudTreeViewItem Value="@CCPContext" @onclick="@(() => { @CodePathDialog.CCP = CCPContext.Ruta; })" LoadingIconColor="Color.Info" CanExpand="@CCPContext.EsDirectorio" Text="@CCPContext.Nombre" EndTextTypo="@Typo.caption" />
                                            </ItemTemplate>
                                        </MudTreeView>
                                    </MudPaper>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Info" Style="text-align: center">@Localizer1["ACCCPDirectory"]</MudAlert>
                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                }
                            }
                            else
