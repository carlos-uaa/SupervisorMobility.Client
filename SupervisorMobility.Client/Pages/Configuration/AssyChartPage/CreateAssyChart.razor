@page "/assychart/createassychart"

@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionServices
@inject IAssyChartService AssyChartServices
@inject IProductService ProductServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime
@inject IBridgeCDMSService CDMSServices


@*Title*@
<PageTitle>Supervisor Mobility | Create Assy Chart</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


@*Form New Assy Chard*@
<EditForm Model="_newassychart" OnValidSubmit="CreateNewAssyChartAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">New Assy Chart</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">New Assy Chart</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                @*Mud select of plants *@
                <MudCardContent>
                    <MudSelect T="int" Label="Plant" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_newassychart.PlantId" For="@(() => _newassychart.PlantId)" SelectedValuesChanged="UpdateAreas">
                        <MudSelectItem Disabled="true" Value="0">Select a Plant</MudSelectItem>
                        @foreach (var type in _plants)
                        {
                            <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Mud select of Areas *@

                    <MudSelect T="int" Label="Area" Variant="Variant.Text" Placeholder="Select a Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_newassychart.AreaId" For="@(() => _newassychart.AreaId)" SelectedValuesChanged="UpdateDistributions">
                        <MudSelectItem Disabled="true" Value="0">Select a Area</MudSelectItem>
                        @foreach (var type in _areas)
                        {
                            <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Mud select of Distributions *@

                    <MudSelect T="int" Label="Distribution" Placeholder="Select a Distribution" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_newassychart.DistributionId" For="@(() => _newassychart.DistributionId)" SelectedValuesChanged="UpdateOperationProducts">
                        <MudSelectItem Disabled="true" Value="0">Select a Distribution</MudSelectItem>
                        @foreach (var type in _distributions)
                        {
                            <MudSelectItem Value="type.DistributionId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>


                    @*GOS*@

                    @if (GOSFolders != null)
                    {
                        @if (rootNodeGOS.TreeItems.Count > 0)
                        {
                            <MudPaper Width="600px" Elevation="0">
                                <MudTextField Label="Selected GOS Folder" ReadOnly="true"
                                      @bind-Value="@_newassychart.GOS" For="@(() => @_newassychart.GOS)" />
                                <MudTreeView ServerData="LoadServerData" Color="Color.Primary" @bind-SelectedValue="@SelectedNodeGOS" Context="GosContext" Items="rootNodeGOS.TreeItems">
                                    <ItemTemplate>
                                        <MudTreeViewItem Value="@GosContext" @onclick="@(() => { @_newassychart.GOS = GosContext.Ruta; })" LoadingIconColor="Color.Info" CanExpand="@GosContext.EsDirectorio" Text="@GosContext.Nombre" EndTextTypo="@Typo.caption" />
                                    </ItemTemplate>
                                </MudTreeView>
                            </MudPaper>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Style="text-align: center">Loading GOS Directory...</MudAlert>
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                        }
                    }
                    else
                    {
                        if (folderGOSError)
                        {
                            <MudAlert Severity="Severity.Warning" Style="text-align: center"> Server does not respond </MudAlert>
                        }
                    }


                    @*CCP*@

                    @if (CCPFolders != null)
                    {
                        @if (rootNodeCCP.TreeItems.Count > 0)
                        {

                            <MudPaper Width="600px" Elevation="0">
                                <MudTextField Label="Selected CCP Folder" ReadOnly="true"
                                      @bind-Value="@_newassychart.CCP" For="@(() => @_newassychart.CCP)" />
                                <MudTreeView ServerData="LoadServerData" Color="Color.Primary" @bind-SelectedValue="@SelectedNodeCCP" Context="CCPContext" Items="rootNodeCCP.TreeItems">
                                    <ItemTemplate>
                                        <MudTreeViewItem Value="@CCPContext" @onclick="@(() => { @_newassychart.CCP = CCPContext.Ruta; })" LoadingIconColor="Color.Info" CanExpand="@CCPContext.EsDirectorio" Text="@CCPContext.Nombre" EndTextTypo="@Typo.caption" />
                                    </ItemTemplate>
                                </MudTreeView>
                            </MudPaper>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Style="text-align: center">Loading CCP Directory...</MudAlert>
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                        }
                    }
                    else
                    {
                        if (folderCCPError)
                        {
                            <MudAlert Severity="Severity.Warning" Style="text-align: center"> Server does not respond </MudAlert>
                        }
                    }





                    @*    <MudSelect Label="CCP" Variant="Variant.Text" Placeholder="Select a CCP" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_newassychart.CCP" For="@(() => _newassychart.CCP)">
                    <MudSelectItem Disabled="true" Value="@_newassychart.GOS">Select a CCP</MudSelectItem>
                    @foreach (var type in _ccp)
                    {
                    <MudSelectItem Value="type">@($"{type}")</MudSelectItem>
                    }
                    </MudSelect>*@

                    @*HOE*@

                    @if (HOEFolders != null)
                    {
                        @if (rootNodeHOE.TreeItems.Count > 0)
                        {
                            <MudPaper Width="600px" Elevation="0">
                                @if (SelectedNodeHOE is not null)
                                {
                                    <MudTextField Label="Selected HOE Folder" ReadOnly="true" Value="@_newassychart.HOE.Replace('§', ' ')" />
                                }
                                else
                                {
                                    <MudText>Selected HOE Folder</MudText>
                                }

                                <MudTreeView ServerData="LoadServerData" Color="Color.Primary" @bind-SelectedValue="@SelectedNodeHOE" Context="OtherContext" Items="rootNodeHOE.TreeItems">
                                    <ItemTemplate>
                                        <MudTreeViewItem Value="@OtherContext" @onclick="@(() => { @_newassychart.HOE = OtherContext.Ruta; })" LoadingIconColor="Color.Info" CanExpand="@OtherContext.EsDirectorio" Text="@OtherContext.Nombre.Split('§').Last()" EndTextTypo="@Typo.caption" />
                                    </ItemTemplate>
                                </MudTreeView>
                            </MudPaper>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Style="text-align: center">Loading HOE Directory..</MudAlert>
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                        }

                    }
                    else
                    {
                        if (folderHOEError)
                        {
                            <MudAlert Severity="Severity.Warning" Style="text-align: center"> Server does not respond </MudAlert>
                        }
                    }



                    @*Operation *@
                    <MudSelect T="int" Label="Operation" Placeholder="Select a Operation" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_newassychart.OperationId" For="@(() => _newassychart.OperationId)">
                        <MudSelectItem Disabled="true" Value="0">Select a Operation</MudSelectItem>
                        @foreach (var type in _distributionValues.Operations)
                        {
                            <MudSelectItem Value="type.OperationId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Mud select of Model/Product *@
                    <MudSelect T="int" Label="Product" Placeholder="Select a Product" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_newassychart.ProductId" For="@(() => @_newassychart.ProductId)">
                        <MudSelectItem Disabled="true" Value="@_newassychart.ProductId">Select a Product</MudSelectItem>
                        @foreach (var type in _distributionValues.Products)
                        {
                            <MudSelectItem Value="type.ProductId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>


                    @* Is Active *@
                    <MudSwitch Class="mt-3" Label="Assy Chart Is active?" @bind-Checked="@_newassychart.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />
                </MudCardContent>

                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Create AssyChart</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateAssyChart())">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>
