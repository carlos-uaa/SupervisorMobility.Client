@page "/assychart/createassychart"

@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionServices
@inject IAssyChartService AssyChartServices
@inject IProductService ProductServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime
@inject IBridgeCDMSService CDMSServices
@inject ITreeService TreeServices
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@using ObjectCloner;
@using System.Text.RegularExpressions;

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer1["ACCreate"]</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


@*Form New Assy Chard*@
<EditForm Model="_newassychart" OnValidSubmit="CreateNewAssyChartAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localizer1["ACNewAC"]t</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer1["ACNewAC"]</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                @*Mud select of plants *@
                <MudCardContent>
                    <MudSelect T="int" Label="@Localizer1["ACLabelPlant"]" Variant="Variant.Text" Placeholder="@Localizer1["ACPHPlant"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="auxplant" For="@(() => auxplant)" SelectedValuesChanged="UpdateAreas">
                        <MudSelectItem Disabled="true" Value="0">@Localizer1["ACPHPlant"]</MudSelectItem>
                        @foreach (var type in _plants)
                        {
                            <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Mud select of Areas *@

                    <MudSelect T="int" Label="@Localizer1["ACLabelArea"]" Variant="Variant.Text" Placeholder="@Localizer1["ACPHArea"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxarea" For="@(() => auxarea)" SelectedValuesChanged="UpdateDistributions">
                        <MudSelectItem Disabled="true" Value="0">@Localizer1["ACPHArea"]</MudSelectItem>
                        @foreach (var type in _areas)
                        {
                            <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Mud select of Distributions *@

                    <MudSelect T="int" Label="@Localizer1["ACLabelDistribution"]" Placeholder="@Localizer1["ACPHDistribution"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxdistribution" For="@(() => auxdistribution)" SelectedValuesChanged="UpdateOperationProducts">
                        <MudSelectItem Disabled="true" Value="0">@Localizer1["ACPHDistribution"]</MudSelectItem>
                        @foreach (var type in _distributions)
                        {
                            <MudSelectItem Value="type.DistributionId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>


                @*Mud select for Ergonomics Level *@

                <MudSelect T="int" Label="@Localizer1["Ergonomics Level"]" Placeholder="@Localizer1["Ergonomics Level"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxErgonomicsLevel">
                    <MudSelectItem Disabled="true" Value="0">@Localizer1["Select Ergonomics Level"]</MudSelectItem>
                    <MudSelectItem Value="1">@($"A")</MudSelectItem>
                        <MudSelectItem Value="2">@($"B")</MudSelectItem>
                        <MudSelectItem Value="3">@($"C")</MudSelectItem>
                    </MudSelect>


                    @*Operation *@

                    @*   <MudItem xs="12" sm="12" lg="12" md="12" Style="display: flex; flex-wrap: wrap; flex-direction:row">
                    <MudItem xs="9" sm="9" lg="9" md="9">

                    <MudSelect T="int" Label="@Localizer1["ACLabelOperation"]" Placeholder="@Localizer1["ACPHOperation"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_newassychart.OperationId" For="@(() => _newassychart.OperationId)">
                    <MudSelectItem Disabled="true" Value="0">@Localizer1["ACPHOperation"]</MudSelectItem>
                    @foreach (var type in _distributionValues.Operations)
                    {
                    <MudSelectItem Value="type.OperationId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                    }
                    </MudSelect>
                    </MudItem>
                    <MudItem xs="3" sm="3" lg="3" md="3">
                    @if (_newassychart.OperationId != 0)
                    {

                    @switch (_distributionValues.Operations.Find(op => op.OperationId == _newassychart.OperationId).CriticalType)
                    {
                    case 1:
                    <MudTextField ReadOnly Value="'A'"  Class="mt-3" AnchorOrigin="Origin.BottomCenter" Label="@Localizer1["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                    break;
                    case 2:
                    <MudTextField ReadOnly Value="'B'"  Class="mt-3" AnchorOrigin="Origin.BottomCenter" Label="@Localizer1["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                    break;
                    case 3:
                    <MudTextField ReadOnly Value="'C'"  Class="mt-3" AnchorOrigin="Origin.BottomCenter" Label="@Localizer1["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                    break;
                    default:
                    <MudTextField ReadOnly Value="@Localizer["OPCritical"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" Label="@Localizer1["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                    break;
                    }

                    }
                    </MudItem>
                    </MudItem>*@

                 




                    <MudItem Class="d-flex flex-column justify-center">

                      
                      

                            @switch (_newassychart.RoutesProductsAssyChart?.Count)
                            {
                                case null:

                                    <MudItem class="d-flex d-flex-column justify-center">
                                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                    </MudItem>

                                    break;
                                case 0:

                                    if (auxplant == 0)
                                    {
                                        <MudItem class="d-flex d-flex-column justify-center">
                                            <MudText Typo="Typo.h6"> @Localizer1["Routes"] </MudText>
                                        </MudItem>

                                        <MudItem class="d-flex flex-column justify-center justify-align-center">
                                            <MudAlert Severity="Severity.Info">
                                                First Select Plant
                                            </MudAlert>
                                        </MudItem>
                                    }
                                    else if (auxarea == 0)
                                    {
                                        <MudItem class="d-flex d-flex-column justify-center">
                                            <MudText Typo="Typo.h6"> @Localizer1["Routes"] </MudText>
                                        </MudItem>

                                        <MudItem class="d-flex flex-column justify-center justify-align-center">
                                            <MudAlert Severity="Severity.Info">
                                                First Select Area
                                            </MudAlert>
                                        </MudItem>
                                    }
                                    else if (auxdistribution == 0)
                                    {
                                        <MudItem class="d-flex d-flex-column justify-center">
                                            <MudText Typo="Typo.h6"> @Localizer1["Routes"] </MudText>
                                        </MudItem>

                                        <MudItem class="d-flex flex-column justify-center justify-align-center">
                                            <MudAlert Severity="Severity.Info">
                                                First Select Distribution
                                            </MudAlert>
                                        </MudItem>
                                    }
                                    else
                                    {
                                        <MudItem class="d-flex d-flex-column justify-center">
                                            <MudText Typo="Typo.h6"> @Localizer1["Routes"] </MudText>
                                        </MudItem>
                                        <MudAlert Severity="Severity.Info">
                                            This AssyChart No Have Paths Added
                                        </MudAlert>

                                        <MudItem class="d-flex flex-column justify-center justify-align-center">
                                            
                                              
                                            <MudPaper Style="width: 100%">
                                                <MudButton OnClick="@(e => CreateCodePath())" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                                                        <MudItem style="text-align:center">
                                                            <img src="Images/agregar.png" Height="100" Width="100" />
                                                            <MudText  Variant="Variant.Text" Color="Color.Info">Add New Path Code</MudText>
                                                        </MudItem>
                                                    </MudButton>
                                                </MudPaper>
                                        </MudItem>
                                    }
                                    break;
                                default:
                                    <MudItem class="d-flex d-flex-column justify-center">
                                        <MudText Typo="Typo.h6"> @Localizer1["Routes"] </MudText>
                                    </MudItem>
                                @if (_assychart.RoutesProductsAssyChart is not null && _assychart.RoutesProductsAssyChart?.ToList().Count > 0)
                                {

                                    <MudItem Style="max-height: 70vh; max-width: 90vw; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">
                                        @foreach (var item in _assychart.RoutesProductsAssyChart)
                                        {
                                            <MudButton OnClick="@(e => OpenDialogEditCodePath(item))" FullWidth="false" Class="d-flex justify-center" Style="height:100%;">
                                                <MudCard Elevation="3" Outlined="true" Style="min-width:450px">
                                                    <MudCardHeader>
                                                        <CardHeaderAvatar>
                                                            <MudChip Icon="@Icons.Material.Filled.DirectionsCar" Color="Color.Info">@item.Product?.Code</MudChip>
                                                        </CardHeaderAvatar>
                                                        <CardHeaderContent>
                                                            <MudText Typo="Typo.body1">@item.Code</MudText>
                                                        </CardHeaderContent>

                                                    </MudCardHeader>

                                                    <MudCardContent Style="max-height: 250px; overflow-x:scroll; flex-wrap: wrap; flex-direction: column;" Class="gap-4">
                                                        <MudTextField Label="@Localizer1["ACLabelHOESelect"]" ReadOnly="true" Value="@Regex.Replace(item.HOE, @"/(.*?)§", "/").Replace('§', ' ')" />
                                                        @if (item.CommonDirectionHOE != "")
                                                        {
                                                            <MudTextField Label="@Localizer1["ACLabelHOESelectCD"]" ReadOnly="true" Value="@Regex.Replace(item.CommonDirectionHOE, @"/(.*?)§", "/").Replace('§', ' ')" />
                                                        }
                                                        <MudTextField Label="@Localizer1["ACLabelCCPSelect"]" ReadOnly="true" @bind-Value="@item.CCP" />
                                                        @if (item.CommonDirectionCCP != "")
                                                        {
                                                            <MudTextField Label="@Localizer1["ACLabelCCPSelectCD"]" ReadOnly="true" @bind-Value="@item.CommonDirectionCCP" />
                                                        }
                                                        <MudTextField Label="@Localizer1["ACLabelGOSSelect"]" ReadOnly="true" @bind-Value="@item.GOS" />
                                                        @if (item.CommonDirectionGOS != "")
                                                        {
                                                            <MudTextField Label="@Localizer1["ACLabelGOSSelectCD"]" ReadOnly="true" @bind-Value="@item.CommonDirectionGOS" />
                                                        }
                                                    </MudCardContent>
                                                </MudCard>
                                            </MudButton>

                                        }
                                        <MudPaper>
                                            <MudButton OnClick="@(e => CreateCodePath())" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                                                <MudItem style="text-align:center">
                                                    <img src="Images/agregar.png" Height="100" Width="100" />
                                                    <MudText Variant="Variant.Text" Color="Color.Info">Add New Path Code</MudText>
                                                </MudItem>
                                            </MudButton>
                                        </MudPaper>
                                    </MudItem>

                                }


                                    break;
                            }
                        

                       
                    </MudItem>





                    @*  <MudSelect T="int" Label="@Localizer1["ACLabelProduct"]" Placeholder="@Localizer1["ACPHProduct"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_newassychart.ProductId" For="@(() => @_newassychart.ProductId)">
                    <MudSelectItem Disabled="true" Value="@_newassychart.ProductId">@Localizer1["ACPHProduct"]</MudSelectItem>
                    @foreach (var type in _distributionValues.Products)
                    {
                    <MudSelectItem Value="type.ProductId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                    }
                    </MudSelect>*@


