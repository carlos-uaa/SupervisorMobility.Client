@page "/assychart/updateassychart/{assychartId:int}"

@*Title*@
<PageTitle>Supervisor Mobility |@Localizer["ACUpdateAC"]</PageTitle>

@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionServices
@inject IAssyChartService AssyChartServices
@inject IProductService ProductServices
@inject IJSRuntime JsRuntime
@inject IBridgeCDMSService CDMSServices
@inject IStringLocalizer<Resource1> Localizer
@inject IStringLocalizer<Resource> Localizer0
@inject NavigationManager NavigationManager


@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


@*Form New Assy Chard*@
<EditForm Model="_assychart" OnValidSubmit="UpdateAssyChartAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localizer["ACUpdate"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["ACUpdate"]</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                @*Mud select of plants *@
                <MudCardContent>
                    
                    <MudSelect T="int" Label="@Localizer["ACLabelPlant"]" Variant="Variant.Text" Placeholder="@Localizer["ACPHPlant"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxplant" For="@(() => auxplant)" SelectedValuesChanged="UpdateAreas">
                        <MudSelectItem Disabled="true" Value="0">@Localizer["ACPHPlant"]</MudSelectItem>
                        @foreach (var type in _plants)
                        {
                            <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Mud select of Areas *@

                    <MudSelect T="int" Label="@Localizer["ACLabelArea"]" Variant="Variant.Text" Placeholder="@Localizer["ACPHArea"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxarea" For="@(() => auxarea)" SelectedValuesChanged="UpdateDistributions">
                        <MudSelectItem Disabled="true" Value="0">@Localizer["ACPHArea"]</MudSelectItem>
                        @foreach (var type in _areas)
                        {
                            <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Mud select of Distributions *@

                    <MudSelect T="int" Label="@Localizer["ACLabelDistribution"]" Placeholder="@Localizer["ACPHDistribution"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxdistribution" For="@(() => auxdistribution)" SelectedValuesChanged="UpdateOperationProducts">
                        <MudSelectItem Disabled="true" Value="0">@Localizer["ACPHDistribution"]</MudSelectItem>
                        @foreach (var type in _distributions)
                        {
                            <MudSelectItem Value="type.DistributionId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Operation *@

                   @* <MudItem xs="12" sm="12" lg="12" md="12" Style="display: flex; flex-wrap: wrap; flex-direction:row">
                        <MudItem xs="9" sm="9" lg="9" md="9">
                            <MudSelect T="int" Label="@Localizer["ACLabelOperation"]" Placeholder="@Localizer["ACPHOperation"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_assychart.OperationId" For="@(() => _assychart.OperationId)">
                                <MudSelectItem Disabled="true" Value="0">@Localizer["ACPHOperation"]</MudSelectItem>
                                @foreach (var type in _distributionValues.Operations)
                                {
                                    <MudSelectItem Value="type.OperationId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem> 
                        <MudItem xs="3" sm="3" lg="3" md="3">
                            @if (_assychart.OperationId != 0)
                            {
                                
                                    @switch (_distributionValues.Operations.Find(op => op.OperationId == _assychart.OperationId).CriticalType)
                                    {
                                        case 1:
                                            <MudTextField  Class="mt-3" AnchorOrigin="Origin.BottomCenter" ReadOnly Value="'A'" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                                            break;
                                        case 2:
                                            <MudTextField  Class="mt-3" AnchorOrigin="Origin.BottomCenter" ReadOnly Value="'B'" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                                            break;
                                        case 3:
                                            <MudTextField  Class="mt-3" AnchorOrigin="Origin.BottomCenter" ReadOnly Value="'C'" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                                            break;
                                        default:
                                            <MudTextField Class="mt-3" AnchorOrigin="Origin.BottomCenter" ReadOnly Value="@Localizer0["OPCritical"]" Label="@Localizer["ACCriticalLabel"]" Align="Align.Center"></MudTextField>
                                            break;
                                    }
                               
                            }
                        </MudItem>
                    </MudItem>*@

                

                 

                </MudCardContent>

                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["ACUpdate"]</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateAssyChart())">@Localizer["Cancel"]</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>

