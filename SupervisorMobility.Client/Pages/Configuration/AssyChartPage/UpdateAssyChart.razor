@page "/assychart/updateassychart/{assychartId:int}"

@*Title*@
<PageTitle>Supervisor Mobility |@Localizer["ACUpdateAC"]</PageTitle>

@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionServices
@inject IAssyChartService AssyChartServices
@inject IProductService ProductServices
@inject IJSRuntime JsRuntime
@inject IBridgeCDMSService CDMSServices
@inject IStringLocalizer<Resource1> Localizer
@inject NavigationManager NavigationManager


@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


@*Form New Assy Chard*@
<EditForm Model="_assychart" OnValidSubmit="UpdateAssyChartAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localizer["ACUpdate"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["ACUpdate"]</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                @*Mud select of plants *@
                <MudCardContent>
                    
                    <MudSelect T="int" Label="@Localizer["ACLabelPlant"]" Variant="Variant.Text" Placeholder="@Localizer["ACPHPlant"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_assychart.PlantId" For="@(() => _assychart.PlantId)" SelectedValuesChanged="UpdateAreas">
                        <MudSelectItem Disabled="true" Value="0">@Localizer["ACPHPlant"]</MudSelectItem>
                        @foreach (var type in _plants)
                        {
                            <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Mud select of Areas *@

                    <MudSelect T="int" Label="@Localizer["ACLabelArea"]" Variant="Variant.Text" Placeholder="@Localizer["ACPHArea"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_assychart.AreaId" For="@(() => _assychart.AreaId)" SelectedValuesChanged="UpdateDistributions">
                        <MudSelectItem Disabled="true" Value="0">@Localizer["ACPHArea"]</MudSelectItem>
                        @foreach (var type in _areas)
                        {
                            <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Mud select of Distributions *@

                    <MudSelect T="int" Label="@Localizer["ACLabelDistribution"]" Placeholder="@Localizer["ACPHDistribution"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_assychart.DistributionId" For="@(() => _assychart.DistributionId)" SelectedValuesChanged="UpdateOperationProducts">
                        <MudSelectItem Disabled="true" Value="0">@Localizer["ACPHDistribution"]</MudSelectItem>
                        @foreach (var type in _distributions)
                        {
                            <MudSelectItem Value="type.DistributionId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Operation *@
                    <MudSelect T="int" Label="@Localizer["ACLabelOperation"]" Placeholder="@Localizer["ACPHOperation"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_assychart.OperationId" For="@(() => _assychart.OperationId)">
                        <MudSelectItem Disabled="true" Value="0">@Localizer["ACPHOperation"]</MudSelectItem>
                        @foreach (var type in _distributionValues.Operations)
                        {
                            <MudSelectItem Value="type.OperationId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    @*Mud select of Model/Product *@
                    <MudSelect T="int" Label="@Localizer["ACLabelProduct"]" Placeholder="@Localizer["ACPHProduct"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_assychart.ProductId" For="@(() => @_assychart.ProductId)">
                        <MudSelectItem Disabled="true" Value="@_assychart.ProductId">@Localizer["ACPHProduct"]</MudSelectItem>
                        @foreach (var type in _distributionValues.Products)
                        {
                            <MudSelectItem Value="type.ProductId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int" Label="@Localizer["ACCriticalLabel"]" Placeholder="@Localizer["ACPHCritical"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_assychart.CriticalType" For="@(() => @_assychart.CriticalType)">
                        <MudSelectItem Disabled="true" Value="0">@Localizer["ACPHCritical"]</MudSelectItem>

                        <MudSelectItem Value="1">@($"A")</MudSelectItem>
                            <MudSelectItem Value="2">@($"B")</MudSelectItem>
                            <MudSelectItem Value="3">@($"C")</MudSelectItem>

                        </MudSelect>
                    <br>
                    <br>

                    @*GOS*@

                    @if (GOSFolders != null)
                    {
                        @if (rootNodeGOS.TreeItems.Count > 0)
                        {
                            <MudPaper Width="600px" Elevation="0">
                                <MudTextField Label="@Localizer["ACLabelGOSSelect"]" ReadOnly="true"
                                @bind-Value="@_assychart.GOS" For="@(() => @_assychart.GOS)" />
                                <MudTreeView ServerData="LoadServerData" Color="Color.Primary" @bind-SelectedValue="@SelectedNodeGOS" Context="GosContext" Items="rootNodeGOS.TreeItems">
                                    <ItemTemplate>
                                        <MudTreeViewItem Value="@GosContext" @onclick="@(() => { @_assychart.GOS = GosContext.Ruta; })" LoadingIconColor="Color.Info" CanExpand="@GosContext.EsDirectorio" Text="@GosContext.Nombre" EndTextTypo="@Typo.caption" />
                                    </ItemTemplate>
                                </MudTreeView>
                            </MudPaper>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Style="text-align: center">@Localizer["ACGOSDirectory"]</MudAlert>
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                        }
                    }
                    else
                    {
                        if (folderGOSError)
                        {
                            <MudAlert Severity="Severity.Warning" Style="text-align: center"> @Localizer["ServerNotResponse"] </MudAlert>
                        }
                    }


                    @*CCP*@

                    @if (CCPFolders != null)
                    {
                        @if (rootNodeCCP.TreeItems.Count > 0)
                        {

                            <MudPaper Width="600px" Elevation="0">
                                <MudTextField Label="@Localizer["ACLabelCCPSelect"]" ReadOnly="true"
                                @bind-Value="@_assychart.CCP" For="@(() => @_assychart.CCP)" />
                                <MudTreeView ServerData="LoadServerData" Color="Color.Primary" @bind-SelectedValue="@SelectedNodeCCP" Context="CCPContext" Items="rootNodeCCP.TreeItems">
                                    <ItemTemplate>
                                        <MudTreeViewItem Value="@CCPContext" @onclick="@(() => { @_assychart.CCP = CCPContext.Ruta; })" LoadingIconColor="Color.Info" CanExpand="@CCPContext.EsDirectorio" Text="@CCPContext.Nombre" EndTextTypo="@Typo.caption" />
                                    </ItemTemplate>
                                </MudTreeView>
                            </MudPaper>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Style="text-align: center">@Localizer["ACCCPDirectory"]</MudAlert>
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                        }
                    }
                    else
                    {
                        if (folderCCPError)
                        {
                            <MudAlert Severity="Severity.Warning" Style="text-align: center"> @Localizer["ServerNotResponse"] </MudAlert>
                        }
                    }





                    @*    <MudSelect Label="CCP" Variant="Variant.Text" Placeholder="Select a CCP" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_assychart.CCP" For="@(() => _assychart.CCP)">
                    <MudSelectItem Disabled="true" Value="@_assychart.GOS">Select a CCP</MudSelectItem>
                    @foreach (var type in _ccp)
                    {
                    <MudSelectItem Value="type">@($"{type}")</MudSelectItem>
                    }
                    </MudSelect>*@

                    @*HOE*@

                    @if (HOEFolders != null)
                    {
                        @if (rootNodeHOE.TreeItems.Count > 0)
                        {
                            <MudPaper Width="600px" Elevation="0">

                                <MudTextField Label="@Localizer["ACLabelHOESelect"]" ReadOnly="true" Value="@_assychart.HOE.Replace('§', ' ')" />

                                <MudTreeView ServerData="LoadServerData" Color="Color.Primary" @bind-SelectedValue="@SelectedNodeHOE" Context="OtherContext" Items="rootNodeHOE.TreeItems">
                                    <ItemTemplate>
                                        <MudTreeViewItem Value="@OtherContext" @onclick="@(() => { @_assychart.HOE = OtherContext.Ruta; })" LoadingIconColor="Color.Info" CanExpand="@OtherContext.EsDirectorio" Text="@OtherContext.Nombre.Split('§').Last()" EndTextTypo="@Typo.caption" />
                                    </ItemTemplate>
                                </MudTreeView>
                            </MudPaper>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Style="text-align: center">@Localizer["ACHOEDirectory"]</MudAlert>
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                        }

                    }
                    else
                    {
                        if (folderHOEError)
                        {
                            <MudAlert Severity="Severity.Warning" Style="text-align: center"> @Localizer["ServerNotResponse"] </MudAlert>
                        }
                    }



                    @* Is Active *@
                    @*<MudSwitch Class="mt-3" Label="Assy Chart Is active?" @bind-Checked="@_assychart.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                </MudCardContent>

                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["ACUpdate"]</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateAssyChart())">@Localizer["Cancel"]</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>

<MudMessageBox @ref="GOSmbox" Title="@Localizer["ACNoticeGOS"]">
    <MessageContent>
        @Localizer["ACProviderPath"] `@_assychart.GOS`  @Localizer["ACFinalProvider"] <br>
        <b><i>@Localizer["ACPleaseProvider"]</i></b>
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CheckCircleOutline">Ok!</MudButton>
    </YesButton>
</MudMessageBox>

<MudMessageBox @ref="HOEmbox" Title="@Localizer["ACNoticeHOE"]">
    <MessageContent>
        @Localizer["ACProviderPath"] `@_assychart.HOE.Replace('§', ' ')`   @Localizer["ACFinalProvider"] <br>
        <b><i>@Localizer["ACPleaseProvider"]</i></b>
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CheckCircleOutline">Ok!</MudButton>
    </YesButton>
</MudMessageBox>

<MudMessageBox @ref="CCPmbox" Title="@Localizer["ACNoticeCCP"]">
    <MessageContent>
        @Localizer["ACProviderPath" ] `@_assychart.CCP`  @Localizer["ACFinalProvider"] <br>
        <b><i>@Localizer["ACPleaseProvider"]</i></b>
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CheckCircleOutline">Ok!</MudButton>
    </YesButton>
</MudMessageBox>
