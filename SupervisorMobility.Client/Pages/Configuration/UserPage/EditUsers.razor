<MudDialog DisableSidePadding="false" @bind-IsVisible="CompleteAreasView" Options="dialogOptions">
    <DialogContent>
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    @if (optionSuboridinatesReasign == 1 || optionAreasReasign == 1)
                    {
                        <MudText Typo="Typo.h6">Reasignar a otro Supervisor (Heredar Propiedades de Nuevo Supervisor)</MudText>
                    }
                    else if (optionSuboridinatesReasign == 3 || optionAreasReasign == 3)
                    {
                        <MudText Typo="Typo.h6">Mantener Subordinados (Asignar Nueva Area)</MudText>
                    }
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Areas validas</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (optionSuboridinatesReasign == 1 || optionAreasReasign == 1)
                        {
                            @if (_AssignAuxSuperior.UserType == 2)
                            {
                                @foreach (var area in _AssignAuxSuperior.Areas)
                                {
                                    <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@area.Code - @area.Description </MudChip>
                                }
                            }
                            else
                            {
                                <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@_AssignAuxSuperior.Area.Code - @_AssignAuxSuperior.Area.Description </MudChip>
                            }
                        }
                        else if (optionSuboridinatesReasign == 3 || optionAreasReasign == 3)
                        {
                            @if (_user.UserType == 2)
                            {
                                @foreach (var area in _user.Areas)
                                {
                                    <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@area.Code - @area.Description </MudChip>
                                }
                            }
                            else
                            {
                                <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@_user.Area.Code - @_user.Area.Description </MudChip>
                            }
                        }
                    </MudCardContent>
                </MudCard>
                @* Area assignment cards would go here - maintaining existing logic *@
            </MudCardContent>
        </MudCard>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="@(() => SetAreasSave())">Continuar</MudButton>
    </DialogActions>
</MudDialog>
