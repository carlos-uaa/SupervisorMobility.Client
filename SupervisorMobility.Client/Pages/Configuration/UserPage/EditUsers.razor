@page "/usersmanagement/EditUser/{userId:int}"
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage
@using SupervisorMobility.Client.Pages.Configuration.UserPage.Edit_Forms

@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionsServices
@inject IDepartmentService DepartmentServices
@inject IFileUploadAndDownloadService FileUpDoServices
@inject IUserService UsersServices
@inject IGroupService GroupServices
@inject NavigationManager NavigationManager
@inject IUserService UserServices
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource1> Localizer
@inject IStringLocalizer<Resource> Localizer1
@using ObjectCloner;
@using System.ComponentModel.DataAnnotations

<style>
    .dialog { backdrop-filter: blur(10px); }
</style>

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["UsersEdit"]</PageTitle>

@if (showui)
{
    <EditForm Model="_user" OnValidSubmit="UpdateUserAsync">
        <DataAnnotationsValidator />
        <MudGrid>
            @*User info*@
            <MudItem xs="12" sm="6" md="3">
                <MudCard>
                    <MudCardContent Style="justify-content:center">
                        <MudText Align="Align.Center" Typo="Typo.h3"><MudIcon Icon="@Icons.Material.Filled.Person"></MudIcon></MudText>
                        <MudItem Class="d-flex d-flex-column justify-center pa-2">
                            <MudText Typo="Typo.h5" Align="Align.Center" Class="pa-2">@_user.Name</MudText>
                        </MudItem>
                        @if (_user.IsActive == true)
                        {
                            <MudText Align="Align.Center" Class="pt-2">
                                <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["UsersActive"]</MudChip>
                            </MudText>
                        }
                        else
                        {
                            <MudText Align="Align.Center" Class="pa-4">
                                <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["UsersInactive"]</MudChip>
                            </MudText>
                        }
                        <MudItem Class="d-flex d-flex-column justify-center pa-2">
                            <MudButton Href="/usersmanagement" Variant="Variant.Filled" Align="Align.Center">@Localizer["Close"]</MudButton>
                        </MudItem>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            @*User details*@
            <MudItem xs="12" sm="6" md="9">
                <MudGrid>
                    <MudItem xs="12">
                        <MudCard>
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h4" Style="text-align:center" Class="mt-5 pl-16 ml-9">@Localizer["UsersEdit"]</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudChip Variant="Variant.Text" Color="Color.Info" Class="mr-15 mt-5">User ID @_user.UserId</MudChip>
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent Class="pl-15 pr-15">
                                <MudItem>
                                    <MudItem Class="d-flex flex-column justify-center align-self-center">
                                        @if (_user.UserType != 4)
                                        {
                                            <MudTextField Label="@Localizer["UsersObject"]" @bind-Value="@_user.ObjectId" />
                                        }
                                        <MudTextField Label="@Localizer["UsersName"]" @bind-Value="@_user.Name" />
                                    </MudItem>
                                </MudItem>

                                <MudItem>
                                    <MudItem>
                                        <MudText Typo="Typo.h6" Class="mt-5">@Localizer["UsersPermissions"]</MudText>
                                    </MudItem>
                                    <MudItem class="d-flex d-flex-column justify-center">
                                        @switch (_user.UserType)
                                        {
                                            case 1:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary">@Localizer["UsersAdmin"]</MudChip>
                                                </MudPaper>
                                                break;
                                            case 2:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSeniorSupervisor"]</MudChip>
                                                </MudPaper>
                                                break;
                                            case 3:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSupervisor"]</MudChip>
                                                </MudPaper>
                                                break;
                                            case 4:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">@Localizer["UsersOperator"]</MudChip>
                                                </MudPaper>
                                                break;
                                            case 5:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Warning">@Localizer["UsersManager"]</MudChip>
                                                </MudPaper>
                                                break;
                                            case 6:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.Engineering" Color="Color.Info">@Localizer["lineSupport"]</MudChip>
                                                </MudPaper>
                                                break;
                                            case 7:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.PermContactCalendar" Color="Color.Info">@Localizer["headCount"]</MudChip>
                                                </MudPaper>
                                                break;
                                            case 8:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.Accessibility" Color="Color.Info">@Localizer["UsersRTC"]</MudChip>
                                                </MudPaper>
                                                break;
                                        }
                                    </MudItem>

                                    @if(LogedUser.UserId != _user.UserId || LogedUser.UserType == 1){

                                        <MudItem Class="d-flex flex-row flex-wrap align-center justify-center pa-2 ma-2">
                                        @if (LogedUser.UserType <= 1)
                                        {
                                            <MudSwitch Class="ma-1" Label="@Localizer["UsersAdmin"]" @bind-Checked="@IsAdmin" @onclick="@(() => setActiveUser(1))" Color="Color.Primary" UnCheckedColor="Color.Dark" />
                                            <MudSwitch Class="ma-1" Label="@Localizer["UsersManager"]" @bind-Checked="@IsManager" @onclick="@(() => setActiveUser(5))" Color="Color.Warning" UnCheckedColor="Color.Dark" />
                                            <MudSwitch Class="ma-1" Label="@Localizer["UsersRTC"]" @bind-Checked="@IsRTC" @onclick="@(() => setActiveUser(8))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                                            <MudSwitch Class="ma-1" Label="@Localizer["UsersSeniorSupervisor"]" @bind-Checked="@IsSeniorSupervisor" @onclick="@(() => setActiveUser(2))" Color="Color.Secondary" UnCheckedColor="Color.Dark" />
                                        }
                                        @if (LogedUser.UserType <= 2)
                                        {
                                            <MudSwitch Class="ma-1" Label="@Localizer["UsersSupervisor"]" @bind-Checked="@IsSupervisor" @onclick="@(() => setActiveUser(3))" Color="Color.Secondary" UnCheckedColor="Color.Dark" />
                                        }   
                                            <MudSwitch Class="ma-1" Label="@Localizer["UsersOperator"]" @bind-Checked="@IsOperator" @onclick="@(() => setActiveUser(4))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                                            <MudSwitch Class="ma-1" Label="@Localizer["lineSupport"]" @bind-Checked="@IsLineSupport" @onclick="@(() => setActiveUser(6))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                                            <MudSwitch Class="ma-1" Label="@Localizer["headCount"]" @bind-Checked="@IsHeadCount" @onclick="@(() => setActiveUser(7))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                                        </MudItem>
                                    }

                                </MudItem>

                                @if (_user.UserType > 0)
                                {
                                    <MudItem xs="12">
                                        <MudPaper Elevation="2" Class="pa-6 mb-4" Style="border-left: 3px solid #90a4ae; background-color: #fafafa;">
                                            <MudText Typo="Typo.h6" Class="mb-4" Style="color: #546e7a;">
                                                <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                                                @Localizer["UsersGeneralInfo"]
                                            </MudText>
                                            
                                            <MudGrid Spacing="3">
                                                <MudItem xs="12" md="6">
                                                    <MudTextField Label="@Localizer["UsersPayroll"]" 
                                                                  @bind-Value="@_user.Payroll" 
                                                                  For="@(() => _user.Payroll)" 
                                                                  Variant="Variant.Outlined" />
                                                </MudItem>
                                                
                                                @if (_user.UserType != 4 && _user.UserType != 0)
                                                {
                                                    <MudItem xs="12" md="6">
                                                        <MudTextField T="string" 
                                                                      Label="@Localizer["UsersEmail"]"  
                                                                      @bind-Value="@_user.Email"  
                                                                      For="@(() => _user.Email)" 
                                                                      RequiredError="Email is required!"
                                                                      Validation="@(new EmailAddressAttribute() {ErrorMessage = "The email address is invalid"})" 
                                                                      Variant="Variant.Outlined" />
                                                    </MudItem>
                                                }
                                            </MudGrid>
                                        </MudPaper>
                                    </MudItem>
                                }

                                @if (_user.UserType > 1 && _user.UserType != 6 && _user.UserType != 7 && _user.UserType != 8)
                                {
                                    <MudItem xs="12" Class="mt-4 mb-2">
                                        <MudText Typo="Typo.h6" Style="color: #546e7a; border-bottom: 2px solid #90a4ae; padding-bottom: 8px;">
                                            <MudIcon Icon="@Icons.Material.Filled.Badge" Class="mr-2" />
                                            @Localizer["UsersEmployeInfo"]
                                        </MudText>
                                    </MudItem>
                                }

                                @* ============================================== *@
                                @* FORM COMPONENTS - Render based on UserType    *@
                                @* ============================================== *@
                                @switch (_user.UserType)
                                {
                                    case 1: // Admin
                                    case 6: // LineSupport
                                    case 7: // HeadCount
                                    case 8: // RTC
                                        <GeneralUserForm User="_user" />
                                        break;

                                    case 2: // Senior Supervisor (SSV)
                                        <SSVForm 
                                            User="_user" 
                                            Plants="_plants" 
                                            Groups="_groups" 
                                            LogedUser="LogedUser"
                                            InitialPlantId="auxPlant"
                                            InitialGroupId="auxGroup"
                                            OnUpdateSelectAreaContextItem="updateSelectAreaContextItem" />
                                        break;

                                    case 3: // Supervisor
                                        <SupervisorForm 
                                            User="_user" 
                                            LogedUser="LogedUser"
                                            Departments="_departments"
                                            InitialPlantId="auxPlant"
                                            InitialAreaId="auxArea"
                                            InitialDepartmentId="auxDepa"
                                            OnUpdateSelectAreaContextItem="updateSelectAreaContextItem" />
                                        break;

                                    case 4: // Operator
                                        <OperatorForm 
                                            User="_user" 
                                            LogedUser="LogedUser"
                                            Departments="_departments"
                                            InitialPlantId="auxPlant"
                                            InitialAreaId="auxArea"
                                            InitialDepartmentId="auxDepa"
                                            OnDepartmentChanged="@((int value) => departmentId = value)" />
                                        break;

                                    case 5: // Manager
                                        <ManagerForm 
                                            User="_user" 
                                            Plants="_plants" 
                                            LogedUser="LogedUser"
                                            InitialPlantId="auxPlant" />
                                        break;
                                }

                            </MudCardContent>

                            <MudCardActions>
                                <MudButton ButtonType="ButtonType.Submit" Disabled="enableSave" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto mb-10">@Localizer["Save"]</MudButton>
                                <MudButton Href="/usersmanagement" Variant="Variant.Filled" Class="ml-4 mb-10 mr-13">@Localizer["Cancel"]</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudItem>
        </MudGrid>

    </EditForm>

}
else
{
    <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
        <MudItem class="d-flex justify-center align-self-center pa-3 ma-2 ">
            <MudText Typo="Typo.h6" Class="align-item-center center">Loading Form</MudText>
        </MudItem>
        <MudPaper Class="flex d-flex-row pa-3 ma-2" Elevation="0">
            <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
        </MudPaper>
    </MudItem>
}

<MudMessageBox @ref="ReasignUsersBox" Title="@Localizer["UEWarning"]">
    <MessageContent>
        Mantener usuarios, modo
    </MessageContent>
    <YesButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AssignmentInd">
            Todos a un area
        </MudButton>
    </YesButton>
    <CancelButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AssignmentLate">
            Seleccionar Manualmente el area
        </MudButton>
    </CancelButton>
</MudMessageBox>

<MudDialog DisableSidePadding="false" @bind-IsVisible="ReasignUsersView" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    Select New Superior
                </MudText>

                @switch (_usercopy.UserType)
                {
                    case 5:
                        @if (Managers?.Count > 0)
                        {
                            <MudItem class="d-flex flex-column justify-center align-self-center pa-3 ma-2 ">
                                <MudText Typo="Typo.h6" Class="align-item-center center">Manager</MudText>
                                <MudAutocomplete ResetValueOnEmptyText Clearable MaxItems="null" T="User" Label="@Localizer["UsersManager"]" ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer["UsersManager"]}" : $"{e.Name}")" For="@(() => _AssignAuxSuperior)" SearchFunc="@SearchManager" Variant="Variant.Outlined" ShowProgressIndicator="true" ValueChanged="@(item => AssignAuxSuperiorFunction(item))">
                                    <ItemTemplate>
                                        @if (context.PlantId != 0 && context.PlantId != null)
                                        {
                                            <MudText Typo="Typo.button">@context.Name - @context.Plant?.Description</MudText>
                                        }
                                    </ItemTemplate>
                                </MudAutocomplete>
                            </MudItem>
                        }
                        else
                        {
                            <MudPaper Class="flex d-flex-row pa-3 ma-2" Elevation="0">
                                <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
                            </MudPaper>
                        }
                        break;
                    case 2:
                        @if (SeniorsSupervisors?.Count > 0)
                        {
                            <MudItem class="d-flex flex-column justify-center align-self-center pa-3 ma-2 ">
                                <MudText Typo="Typo.h6" Class="align-item-center center">SSV</MudText>
                                <MudAutocomplete ResetValueOnEmptyText Clearable MaxItems="null" T="User" Label="@Localizer["UsersSeniorSupervisor"]" ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer["UsersPHSuperior"]}" : $"{e.Name} ({e.Group?.Description})")" For="@(() => _AssignAuxSuperior)" SearchFunc="@SearchSSV" Variant="Variant.Outlined" ShowProgressIndicator="true" ValueChanged="@(item => AssignAuxSuperiorFunction(item))">
                                    <ItemTemplate>
                                        <MudText Typo="Typo.button">@context.Name - @context.Plant?.Description</MudText>
                                            <div class="font-weight-bold"><b>@Localizer["UsersAssignedArea"]:</b></div>
                                            <div class="d-flex justify-content-between justify-center">
                                                @if (context.Areas != null && context.Areas.Count > 0)
                                                {
                                                    @foreach (var area in context.Areas)
                                                    {
                                                        <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@area.Code - @area.Description </MudChip>
                                                    }
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.button">@Localizer["UsersNoAreasSSV"]</MudText>
                                                }
                                            </div>
                                    </ItemTemplate>
                                </MudAutocomplete>
                            </MudItem>
                        }
                        else
                        {
                            <MudPaper Class="flex d-flex-row pa-3 ma-2" Elevation="0">
                                <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
                            </MudPaper>
                        }
                        break;
                    case 3:
                        @if (Supervisors?.Count > 0)
                        {
                            <MudItem class="d-flex flex-column  justify-center align-self-center pa-3 ma-2 ">
                                <MudText Typo="Typo.h6" Class="align-item-center center">Supervisor</MudText>
                                <MudAutocomplete ResetValueOnEmptyText Clearable MaxItems="null" T="User" Label="@Localizer["UsersSupervisor"]" ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer["UsersPHSupervisor"]}" : $"{e.Name} - {e.Area?.Description} - ({e.Group?.Description})")" For="@(() => _AssignAuxSuperior)" SearchFunc="@SearchSV" Variant="Variant.Outlined" ShowProgressIndicator="true" ValueChanged="@(item => AssignAuxSuperiorFunction(item))">
                                    <ItemTemplate>
                                        <MudText Typo="Typo.button">@context.Name - @context.Plant?.Description</MudText>
                                            <div class="font-weight-bold"><b>@Localizer["UsersAssignedArea"]:</b></div>
                                            <div class="d-flex justify-content-between justify-center">
                                                @if (context.Areas != null && context.Areas.Count > 0)
                                                {
                                                    @foreach (var area in context.Areas)
                                                    {
                                                        <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="pl-5 pr-5">@area.Code - @area.Description </MudChip>
                                                    }
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.button">@Localizer["UsersNoAreasSV"]</MudText>
                                                }
                                            </div>
                                    </ItemTemplate>
                                </MudAutocomplete>
                            </MudItem>
                        }
                        else
                        {
                            <MudPaper Class="flex d-flex-row pa-3 ma-2" Elevation="0">
                                <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
                            </MudPaper>
                        }
                        break;
                }

                <MudText Typo="Typo.h6">
                    Subordinates to Reassign
                </MudText>
            </MudItem>

            @switch (ReasignUsersTypeView)
            {
                case 1:
                    <MudItem Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap; justify-content: center;" Class="gap-4">
                        @foreach (var item in _usercopy.Subordinates)
                        {
                            <MudCard Elevation="1" Class="mr-5" Style="width: 300px; flex: 0 0 calc(28%-1rem);">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.h6">@item.Name</MudText>
                                        <MudText Typo="Typo.body2">@item.Payroll</MudText>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        @switch (item.UserType)
                                        {
                                            case 2:
                                                <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSeniorSupervisor"]</MudChip>
                                                break;
                                            case 3:
                                                <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSupervisor"]</MudChip>
                                                break;
                                            case 4:
                                                <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">@Localizer["UsersOperator"]</MudChip>
                                                break;
                                        }
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent>
                                    @if (item.PlantId != 0 && item.PlantId != null)
                                    {
                                        <MudText Typo="Typo.body2"><b>@Localizer["UsersPlant"]:</b> @item.Plant?.Description</MudText>
                                    }
                                    @if (item.AreaId != 0 && item.AreaId != null)
                                    {
                                        <MudText Typo="Typo.body2"><b>@Localizer["UsersArea"]:</b> @item.Area?.Description</MudText>
                                    }
                                    @if (item.Areas != null && item.Areas.Count > 0)
                                    {
                                        <MudText Typo="Typo.body2"><b>@Localizer["UsersAreas"]:</b></MudText>
                                        <div class="d-flex flex-wrap">
                                            @foreach (var area in item.Areas)
                                            {
                                                <MudChip Size="Size.Small" Color="Color.Info">@area.Code</MudChip>
                                            }
                                        </div>
                                    }
                                    @if (item.GroupId != 0 && item.GroupId != null)
                                    {
                                        <MudText Typo="Typo.body2"><b>@Localizer["UsersGroup"]:</b> @item.Group?.Description</MudText>
                                    }
                                </MudCardContent>
                            </MudCard>
                        }
                    </MudItem>
                    break;

                case 2:
                    <MudItem Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">
                        @foreach (var item in _user.Subordinates)
                        {
                            @if ((item.Areas == null || item.Areas.Count <= 0) || item.Areas.All(s => _user.Areas.All(a => a.AreaId == s.AreaId)))
                            {
                                <MudCard Elevation="1" Class="mr-5" Style="width: 300px; flex: 0 0 calc(28%-1rem);">
                                    <MudCardHeader>
                                        <CardHeaderContent>
                                            <MudText Typo="Typo.h6">@item.Name</MudText>
                                            <MudText Typo="Typo.body2">@item.Payroll</MudText>
                                        </CardHeaderContent>
                                        <CardHeaderActions>
                                            @switch (item.UserType)
                                            {
                                                case 2:
                                                    <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSeniorSupervisor"]</MudChip>
                                                    break;
                                                case 3:
                                                    <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSupervisor"]</MudChip>
                                                    break;
                                                case 4:
                                                    <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">@Localizer["UsersOperator"]</MudChip>
                                                    break;
                                            }
                                        </CardHeaderActions>
                                    </MudCardHeader>
                                    <MudCardContent>
                                        @if (item.PlantId != 0 && item.PlantId != null)
                                        {
                                            <MudText Typo="Typo.body2"><b>@Localizer["UsersPlant"]:</b> @item.Plant?.Description</MudText>
                                        }
                                        @if (item.AreaId != 0 && item.AreaId != null)
                                        {
                                            <MudText Typo="Typo.body2"><b>@Localizer["UsersArea"]:</b> @item.Area?.Description</MudText>
                                        }
                                        @if (item.Areas != null && item.Areas.Count > 0)
                                        {
                                            <MudText Typo="Typo.body2"><b>@Localizer["UsersAreas"]:</b></MudText>
                                            <div class="d-flex flex-wrap">
                                                @foreach (var area in item.Areas)
                                                {
                                                    <MudChip Size="Size.Small" Color="Color.Info">@area.Code</MudChip>
                                                }
                                            </div>
                                        }
                                        @if (item.GroupId != 0 && item.GroupId != null)
                                        {
                                            <MudText Typo="Typo.body2"><b>@Localizer["UsersGroup"]:</b> @item.Group?.Description</MudText>
                                        }
                                    </MudCardContent>
                                </MudCard>
                            }
                        }
                    </MudItem>
                    break;

                case 3:
                    <MudItem Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">
                        @foreach (var item in _ReassignedUsersAreas)
                        {
                            <MudCard Elevation="1" Class="mr-5" Style="width: 300px; flex: 0 0 calc(28%-1rem);">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.h6">@item.Name</MudText>
                                        <MudText Typo="Typo.body2">@item.Payroll</MudText>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        @switch (item.UserType)
                                        {
                                            case 2:
                                                <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSeniorSupervisor"]</MudChip>
                                                break;
                                            case 3:
                                                <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSupervisor"]</MudChip>
                                                break;
                                            case 4:
                                                <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">@Localizer["UsersOperator"]</MudChip>
                                                break;
                                        }
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent>
                                    @if (item.PlantId != 0 && item.PlantId != null)
                                    {
                                        <MudText Typo="Typo.body2"><b>@Localizer["UsersPlant"]:</b> @item.Plant?.Description</MudText>
                                    }
                                    @if (item.AreaId != 0 && item.AreaId != null)
                                    {
                                        <MudText Typo="Typo.body2"><b>@Localizer["UsersArea"]:</b> @item.Area?.Description</MudText>
                                    }
                                    @if (item.Areas != null && item.Areas.Count > 0)
                                    {
                                        <MudText Typo="Typo.body2"><b>@Localizer["UsersAreas"]:</b></MudText>
                                        <div class="d-flex flex-wrap">
                                            @foreach (var area in item.Areas)
                                            {
                                                <MudChip Size="Size.Small" Color="Color.Info">@area.Code</MudChip>
                                            }
                                        </div>
                                    }
                                    @if (item.GroupId != 0 && item.GroupId != null)
                                    {
                                        <MudText Typo="Typo.body2"><b>@Localizer["UsersGroup"]:</b> @item.Group?.Description</MudText>
                                    }
                                </MudCardContent>
                            </MudCard>
                        }
                    </MudItem>
                    break;
            }
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="ReasignUsersDialog" Disabled="@(_AssignAuxSuperior == null ? true : false)">Reasign</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog DisableSidePadding="false" @bind-IsVisible="ReasignUsersOptionsView" Options="dialogOptions">
    <DialogContent>
        <MudCard>
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Aviso: Algunos usuarios se verán afectados por los cambios realizados. Por favor, revísalos y realiza las acciones necesarias.</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudExpansionPanels MultiExpansion="true">
                    <MudExpansionPanel @bind-IsExpanded="isOpen" HideIcon="true" Style="min-width: 100%;">
                        <TitleContent>
                            <div class="d-flex">
                                <MudText>Ver Usuarios Afectados</MudText>
                                <MudIcon Icon="@(isOpen ? Icons.Material.Filled.Close : Icons.Material.Filled.Add)" class="ml-auto"></MudIcon>
                            </div>
                        </TitleContent>
                        <ChildContent>
                            <MudContainer Style="min-width: 100%; display: flex; flex-wrap: wrap; justify-content: center;">
                                @foreach (var item in _usercopy.Subordinates)
                                {
                                    <MudCard Elevation="1" Class="mr-5 mb-3" Style="width: 300px;">
                                        <MudCardHeader>
                                            <CardHeaderContent>
                                                <MudText Typo="Typo.h6">@item.Name</MudText>
                                                <MudText Typo="Typo.body2">@item.Payroll</MudText>
                                            </CardHeaderContent>
                                        </MudCardHeader>
                                        <MudCardContent>
                                            @if (item.PlantId != 0 && item.PlantId != null)
                                            {
                                                <MudText Typo="Typo.body2"><b>@Localizer["UsersPlant"]:</b> @item.Plant?.Description</MudText>
                                            }
                                            @if (item.Areas != null && item.Areas.Count > 0)
                                            {
                                                foreach(var area in item.Areas)
                                                {
                                                    <MudText Typo="Typo.body2"><b>@Localizer["UsersArea"]:</b> @item.Area?.Description</MudText>                                                    
                                                }
                                            }
                                        </MudCardContent>
                                    </MudCard>
                                }
                            </MudContainer>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudCardContent>
        </MudCard>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="@(() => SetReasignSubordinatesOption(1))">Reasignar a otro Supervisor (Heredar Propiedades de Nuevo Supervisor)</MudButton>
        <MudButton Color="Color.Info" OnClick="@(() => SetReasignSubordinatesOption(2))">Reasignar a otro Supervisor (Mantener Propiedades de Usuarios)</MudButton>
        <MudButton Color="Color.Info" OnClick="@(() => SetReasignSubordinatesOption(3))">Mantener Subordinados (Asignar Area)</MudButton>
        <MudButton Color="Color.Info" OnClick="@(() => SetReasignSubordinatesOption(4))">Mantener Subordinados (Sin Asignar Area)</MudButton>
        <MudButton Color="Color.Info" OnClick="@(() => SetReasignSubordinatesOption(5))">No Asignar a nadie (Los deja al aire)</MudButton>
        <MudButton Color="Color.Info" OnClick="@(() => SetReasignSubordinatesOption(-1))">Cancel</MudButton>
    </DialogActions>
</MudDialog>

