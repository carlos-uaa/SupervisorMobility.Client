@page "/usersmanagement/EditUser/{userId:int}"
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage

@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionsServices
@inject IFileUploadAndDownloadService FileUpDoServices
@inject IUserService UsersServices
@inject IGroupService GroupServices
@inject NavigationManager NavigationManager
@inject IUserService UserServices

@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource1> Localizer
@using ObjectCloner;
@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["UsersEdit"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>



@if (showui)
{
    <EditForm Model="_user" OnValidSubmit="UpdateUserAsync">
        <DataAnnotationsValidator />
        <MudGrid>
            @*User info*@
            <MudItem xs="12" sm="6" md="3">
                <MudCard>
                    <MudCardContent Style="justify-content:center">
                        <MudText Align="Align.Center" Typo="Typo.h3"><MudIcon Icon="@Icons.Material.Filled.Person"></MudIcon></MudText>
                        <MudItem Class="d-flex d-flex-column justify-center pa-2">
                            <MudText Typo="Typo.h5" Align="Align.Center" Class="pa-2">@_user.Name</MudText>
                        </MudItem>
                        @if (_user.IsActive == true)
                        {
                            <MudText Align="Align.Center" Class="pt-2">
                                <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["UsersActive"]</MudChip>
                            </MudText>
                        }
                        else
                        {
                            <MudText Align="Align.Center" Class="pa-4">
                                <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["UsersInactive"]</MudChip>
                            </MudText>
                        }
                        <MudItem Class="d-flex d-flex-column justify-center pa-2">
                            <MudButton Href="/usersmanagement" Variant="Variant.Filled" Align="Align.Center">@Localizer["Close"]</MudButton>
                        </MudItem>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            @*User details*@
            <MudItem xs="12" sm="6" md="9">
                <MudGrid>
                    <MudItem xs="12">
                        <MudCard>
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h4" Style="text-align:center" Class="mt-5 pl-16 ml-9">@Localizer["UsersEdit"]</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudChip Variant="Variant.Text" Color="Color.Info" Class="mr-15 mt-5">User ID @_user.UserId</MudChip>
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent Class="pl-15 pr-15">
                                <MudItem>
                                    <MudItem Class="d-flex flex-column justify-center align-self-center">
                                        @if (_user.UserType != 4)
                                        {
                                            <MudTextField Label="@Localizer["UsersObject"]" @bind-Value="@_user.ObjectId" />
                                        }
                                        <MudTextField Label="@Localizer["UsersName"]" @bind-Value="@_user.Name" />
                                    </MudItem>
                                </MudItem>

                                <MudItem>
                                    <MudItem>
                                        <MudText Typo="Typo.h6" Class="mt-5">@Localizer["UsersPermissions"]</MudText>
                                    </MudItem>
                                    <MudItem class="d-flex d-flex-column justify-center">
                                        @switch (_user.UserType)
                                        {
                                            case 1:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary">@Localizer["UsersAdmin"]</MudChip>
                                                </MudPaper>
                                                break;
                                            case 2:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSeniorSupervisor"]</MudChip>
                                                </MudPaper>
                                                break;
                                            case 3:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSupervisor"]</MudChip>
                                                </MudPaper>
                                                break;
                                            case 4:
                                                <MudPaper Elevation="0">
                                                    <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">@Localizer["UsersOperator"]</MudChip>
                                                </MudPaper>
                                                break;
                                        }
                                    </MudItem>

                                    <MudItem Class="d-flex flex-row align-center justify-center pa-2 ma-2">
                                        <MudSwitch Class="ma-1" Label="@Localizer["UsersAdmin"]" @bind-Checked="@IsAdmin" @onclick="@(() => setActiveUser(1))" Color="Color.Primary" UnCheckedColor="Color.Dark" />
                                        <MudSwitch Class="ma-1" Label="@Localizer["UsersSeniorSupervisor"]" @bind-Checked="@IsSeniorSupervisor" @onclick="@(() => setActiveUser(2))" Color="Color.Secondary" UnCheckedColor="Color.Dark" />
                                        <MudSwitch Class="ma-1" Label="@Localizer["UsersSupervisor"]" @bind-Checked="@IsSupervisor" @onclick="@(() => setActiveUser(3))" Color="Color.Secondary" UnCheckedColor="Color.Dark" />
                                        <MudSwitch Class="ma-1" Label="@Localizer["UsersOperator"]" @bind-Checked="@IsOperator" @onclick="@(() => setActiveUser(4))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                                        <MudSwitch Class="ma-1" Label="@Localizer["UsersManager"]" @bind-Checked="@IsManager" @onclick="@(() => setActiveUser(5))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                                    </MudItem>
                                </MudItem>


                                @*
                            <MudItem>
                            <MudItem>
                            <MudText Typo="Typo.h6" Class="mt-5">General Info</MudText>
                            </MudItem>
                            <MudItem class="d-flex flex-column justify-center align-self-center">
                            @if (_user.UserType != 4)
                            {
                            <MudItem>
                            <MudTextField Label="Email" @bind-Value="@_user.Email" />
                            </MudItem>
                            }
                            @if (_user.UserType == 4)
                            {
                            <MudItem>
                            <MudTextField Label="Payroll" @bind-Value="@_user.Payroll" />
                            </MudItem>
                            }
                            </MudItem>
                            </MudItem>*@
                                @if (_user.UserType > 0)
                                {
                                    <MudItem>
                                        <MudText Typo="Typo.h6" Class="mt-5">@Localizer["UsersGeneralInfo"]</MudText>
                                    </MudItem>
                                }
                                @if (_user.UserType == 4)
                                {
                                    <MudTextField Label="@Localizer["UsersPayroll"]" @bind-Value="@_user.Payroll" For="@(() => _user.Payroll)" />
                                }

                                @if (_user.UserType != 4 && _user.UserType != 0)
                                {
                                    <MudTextField Mask="@emailMask" Label="@Localizer["UsersEmail"]" HelperText="@emailMask.Mask"
                                    @bind-Value="@_user.Email" For="@(() => _user.Email)" Variant="@Variant.Text" Clearable />
                                }

                                @if (_user.UserType > 1)
                                {
                                    <MudItem Class="mt-5">
                                        <MudText Typo="Typo.h6">@Localizer["UsersEmployeInfo"]</MudText>
                                    </MudItem>

                                }

                                @if (_user.UserType != 1)
                                {
                                    @if (_user.UserType == 2)
                                    {
                                        @*Mud select of Plants *@
                                        <MudSelect T="int" Label="@Localizer["UsersPlant"]" Variant="Variant.Text" Placeholder="@Localizer["UsersPHPlant"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxPlant" For="@(() => auxPlant)" SelectedValuesChanged="ShowAreasInvokeByPlantSelector">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHPlant"]</MudSelectItem>
                                            @foreach (var type in _plants)
                                            {
                                                <MudSelectItem Value="type.PlantId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                        @*Mud select of Areas *@
                                        @*<MudSelect T="int" Label="Area" Variant="Variant.Text" Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxArea" For="@(() => auxArea)" SelectedValuesChanged="ShowDistributionInvokeByAreasSelector">
                            <MudSelectItem Disabled="true" Value="0">Select an Area</MudSelectItem>
                            @foreach (var type in _areas)
                            {
                            <MudSelectItem Value="type.AreaId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                            }
                            </MudSelect>*@

                                        <MudSelect T="int" Label="@Localizer["UsersGroup"]" Variant="Variant.Text" Placeholder="@Localizer["UsersPHGroup"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxGroup" For="@(() => auxGroup)">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHGroup"]</MudSelectItem>
                                            @foreach (var type in _groups)
                                            {
                                                <MudSelectItem Value="type.GroupId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                    else if (_user.UserType == 3 && LogedUser.UserType == 2)
                                    {
                                        <MudTextField @bind-Value="plantInfo" Label="@Localizer["UsersPlant"]" ReadOnly="true" Variant="Variant.Outlined" />
                                        if (LogedUser.Areas != null)
                                        {
                                            <MudSelect T="int" Label="@Localizer["UsersArea"]" Variant="Variant.Outlined" Placeholder="@Localizer["UsersPHArea"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxArea" For="@(() => auxArea)" SelectedValuesChanged="ShowDistributionInvokeByAreasSelector">
                                                <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHArea"]</MudSelectItem>
                                                @foreach (var type in LogedUser.Areas)
                                                {
                                                    <MudSelectItem Value="type.AreaId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                                }
                                            </MudSelect>
                                        }
                                        else
                                        {
                                            <MudAlert Severity="Severity.Info">
                                                <MudText Style="font-weight: bold;">@Localizer["UsersNoAreasSSV"]</MudText>
                                            </MudAlert>
                                        }
                                        <MudTextField @bind-Value="grupInfo" Label="@Localizer["UsersGroup"]" ReadOnly="true" Variant="Variant.Outlined" />
                                    }
                                    else if (_user.UserType == 3)
                                    {
                                        <MudTextField @bind-Value="plantInfo" Label="@Localizer["UsersPlant"]" ReadOnly="true" Variant="Variant.Outlined" />
                                        if (_user.Superior != null)
                                        {
                                            if (_user.Superior.Areas != null && _user.Superior.Areas.Count > 0)
                                            {
                                                <MudSelect T="int" Label="Area" Variant="Variant.Outlined" Placeholder="@Localizer["UsersPHArea"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxArea" For="@(() => auxArea)" SelectedValuesChanged="ShowDistributionInvokeByAreasSelector">
                                                    <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHArea"]</MudSelectItem>
                                                    @foreach (var type in _user.Superior.Areas)
                                                    {
                                                        <MudSelectItem Value="type.AreaId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            }
                                            else
                                            {
                                                <MudAlert Severity="Severity.Info">
                                                    <MudText Style="font-weight: bold;">@Localizer["UsersNoAreasSSV"]</MudText>
                                                </MudAlert>
                                            }

                                        }

                                        <MudTextField @bind-Value="grupInfo" Label="@Localizer["UsersGroup"]" ReadOnly="true" Variant="Variant.Outlined" />
                                    }
                                    else if (_user.UserType == 4)
                                    {
                                        <MudTextField @bind-Value="plantInfo" Label="@Localizer["UsersPlant"]" ReadOnly="true" Variant="Variant.Outlined" />
                                        <MudTextField @bind-Value="areaInfo" Label="@Localizer["UsersArea"]" ReadOnly="true" Variant="Variant.Outlined" />
                                        <MudTextField @bind-Value="grupInfo" Label="@Localizer["UsersGroup"]" ReadOnly="true" Variant="Variant.Outlined" />
                                    }




                                    @*Mud select of Distribution *@
                                    @if (_user.UserType == 4 && _user.Superior != null)
                                    {
                                        <MudAutocomplete MaxItems="null" T="Distribution" Label="@Localizer["UsersDistribution"]" ToStringFunc="@(e=> e.Description == null || e.Description == "" ? $"{Localizer["UsersPHDistribution"]}" : $"{e.Code} {e.Description}")" SearchFunc="@SearchDistribution" Variant="Variant.Outlined" ShowProgressIndicator="true" ValueChanged="@((item) => SetDistribution(item))" />

                                        @*                                        <MudSelect T="int" Label="@Localizer["UsersDistribution"]" Variant="Variant.Text" Placeholder="@Localizer["UsersPHDistribution"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxDistribution" For="@(() => auxDistribution)">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHDistribution"]</MudSelectItem>
                            @foreach (var type in _distributions)
                            {
                            <MudSelectItem Value="type.DistributionId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                            }
                            </MudSelect>*@
                                    }
                                    @* Areas Managed*@


                                    @if (_user.UserType == 2)
                                    {
                                        <MudItem Class="mt-5">
                                            <MudText Typo="Typo.h6">@Localizer["UsersAreasManage"]</MudText>
                                        </MudItem>
                                        @switch (_user.Areas?.Count)
                                        {
                                            case null:
                                                @if (auxPlant == 0)
                                                {
                                                    <MudItem>
                                                        <MudAlert Severity="Severity.Info">
                                                            @Localizer["UsersFirstPlant"]
                                                        </MudAlert>
                                                    </MudItem>
                                                }
                                                else
                                                {
                                                    @if (_areasManager?.Count > 0)
                                                    {
                                                        <MudItem class="d-flex flex-column justify-center">
                                                            <MudAlert Severity="Severity.Info">
                                                                @Localizer["UsersFirstArea"]
                                                            </MudAlert>
                                                        </MudItem>
                                                    }
                                                    else
                                                    {
                                                        <MudItem class="d-flex flex-column justify-center">
                                                            <MudAlert Severity="Severity.Info">
                                                                @Localizer["UsersPlantNoAreas"]
                                                            </MudAlert>
                                                        </MudItem>
                                                    }


                                                }
                                                break;
                                            case 0:
                                                @if (auxPlant == 0)
                                                {
                                                    <MudItem class="d-flex flex-column justify-center justify-align-center">
                                                        <MudAlert Severity="Severity.Info">
                                                            @Localizer["UsersFirstPlant"]
                                                        </MudAlert>
                                                    </MudItem>
                                                }
                                                else
                                                {
                                                    @if (_areasManager?.Count > 0)
                                                    {
                                                        <MudItem class="d-flex flex-column justify-center">
                                                            <MudAlert Severity="Severity.Info">
                                                                @Localizer["UsersFirstArea"]
                                                            </MudAlert>
                                                        </MudItem>
                                                    }
                                                    else
                                                    {
                                                        <MudItem class="d-flex flex-column justify-center">
                                                            <MudAlert Severity="Severity.Info">
                                                                @Localizer["UsersPlantNoAreas"]
                                                            </MudAlert>
                                                        </MudItem>
                                                    }
                                                }
                                                break;
                                            default:
                                                @if (_user.Areas is not null && _user.Areas?.ToList().Count > 0)
                                                {
                                                    <MudItem class="d-flex flex-column justify-center ma-1">
                                                        <MudItem class="d-flex d-flex-column justify-center">
                                                            @foreach (var itemArea in _user.Areas)
                                                            {
                                                                <MudCard Elevation="1" Class="mr-5" Style="width: 300px;">
                                                                    <MudCardHeader>
                                                                        <CardHeaderContent>
                                                                            <MudText Typo="Typo.subtitle1">
                                                                                <MudIcon Class="pt-2" Icon="@Icons.Material.Filled.Business"></MudIcon>
                                                                                <b>@Localizer["UsersAreaId"]:</b> @itemArea.AreaId
                                                                            </MudText>
                                                                        </CardHeaderContent>
                                                                        <CardHeaderActions>
                                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="() => DeleteAreaFromUserList(itemArea)" />
                                                                        </CardHeaderActions>
                                                                    </MudCardHeader>
                                                                    <MudCardContent>
                                                                        <div class="font-weight-bold"><b>@Localizer["UsersCode"]:</b> @itemArea.Code</div>
                                                                        <div class="font-weight-light"><b>@Localizer["UsersDescription"]:</b> @itemArea.Description</div>
                                                                    </MudCardContent>
                                                                    <MudCardActions></MudCardActions>
                                                                </MudCard>
                                                            }
                                                        </MudItem>
                                                    </MudItem>
                                                }

                                                break;
                                        }
                                        @*Selector Ares*@
                                        @if (_areasManager?.Count > 0 && auxPlant != 0)
                                        {
                                            <MudItem class="d-flex d-flex-column justify-center ma-1">
                                                <MudItem Class="d-flex d-flex-row">
                                                    <MudSelect T="Area" Label="@Localizer["UsersArea"]" SelectedValuesChanged="@OnSelectedAreaToManageFunction" Placeholder="@Localizer["UsersPHArea"]" @bind-Value="@selectedAreaOfList" For="@(() => selectedAreaOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                                        <MudSelectItem Disabled="true" Value="selectedAreaOfList"> @Localizer["UsersPHArea"] </MudSelectItem>
                                                        @foreach (var areaItem in _areasManager)
                                                        {
                                                            <MudSelectItem Value="areaItem">@($"{areaItem.Code}-{areaItem.Description}") </MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                    <MudButton Class="ml-5" Disabled="@ActiveAddArea" OnClick="@(() => AddAreaToUserList(selectedAreaOfList))" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" IconColor="Color.Secondary" Size="Size.Large"> Add Area </MudButton>
                                                </MudItem>
                                            </MudItem>
                                        }
                                    }
                                    @if (_user.UserType == 5)
                                    {
                                        @*Mud select of Plants *@
                                        <MudSelect T="int" Label="@Localizer["UsersPlant"]" Variant="Variant.Text" Placeholder="@Localizer["UsersPHPlant"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxPlant" For="@(() => auxPlant)" SelectedValuesChanged="ShowAreasInvokeByPlantSelector">
                                            <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHPlant"]</MudSelectItem>
                                            @foreach (var type in _plants)
                                            {
                                                <MudSelectItem Value="type.PlantId">
                                                    @(
                                        $"{type.Code}-{type.Description}"
                                        )
                                                </MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                }



                                @if (_user.UserType != 0)
                                {
                                    <MudItem>
                                        <MudItem Class="mt-5">
                                            <MudText Typo="Typo.h6"> @Localizer["UsersHT"] </MudText>
                                        </MudItem>
                                        @*Superiorcard *@
                                        <MudItem Class="d-flex flex-column justify-center ma-1">
                                            @if (_user.Superior != null)
                                            {
                                                <MudItem class="d-flex d-flex-column justify-center">
                                                    <MudText Typo="Typo.h6"> @Localizer["UsersSuperior"] </MudText>
                                                </MudItem>
                                                <MudItem class="d-flex d-flex-column justify-center">

                                                    <MudCard Elevation="1" Class="mr-5" Style="width: 300px; flex: 0 0 calc(28%-1rem);">
                                                        <MudCardHeader>
                                                            <CardHeaderContent>
                                                                @switch (_user.Superior.UserType)
                                                                {
                                                                    case 2:
                                                                    case 3:
                                                                        <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount"> </MudIcon>
                                                                        break;
                                                                    case 4:
                                                                        <MudIcon Icon="@Icons.Material.Filled.Person"> </MudIcon>
                                                                        break;
                                                                }
                                                            </CardHeaderContent>
                                                            <CardHeaderActions>
                                                                @switch (_user.Superior.UserType)
                                                                {
                                                                    case 1:
                                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveSuperiorUser())" />
                                                                        break;
                                                                    case 2:
                                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveSuperiorUser())" />
                                                                        break;
                                                                    case 3:
                                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveSuperiorUser())" />
                                                                        break;
                                                                }
                                                            </CardHeaderActions>
                                                        </MudCardHeader>
                                                        <MudCardContent>

                                                            <div class="font-weight-bold"><b>@Localizer["UsersName"]:</b>  @_user.Superior?.Name</div>

                                                            <div class="font-weight-bold"><b>@Localizer["UsersAssignedArea"]:</b></div>



                                                            <div class="d-flex justify-content-between justify-center">
                                                                @switch (_user.Superior?.UserType)
                                                                {
                                                                    case 1:
                                                                        <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary"> @Localizer["UsersAdmin"] </MudChip>
                                                                        break;
                                                                    case 2:
                                                                        <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"> @Localizer["UsersSeniorSupervisor"] </MudChip>
                                                                        break;
                                                                    case 3:
                                                                        <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"> @Localizer["UsersSupervisor"] </MudChip>
                                                                        break;
                                                                    case 4:
                                                                        <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark"> @Localizer["UsersOperator"] </MudChip>
                                                                        break;
                                                                }
                                                            </div>
                                                        </MudCardContent>


                                                        <MudCardActions>

                                                        </MudCardActions>
                                                    </MudCard>
                                                </MudItem>

                                            }
                                            else
                                            {


                                                @if (_user.UserType > 2 && _user.UserType != 5)
                                                {
                                                    <MudItem class="d-flex d-flex-column justify-center">
                                                        <MudText Typo="Typo.h6"> @Localizer["UsersSuperior"] </MudText>
                                                    </MudItem>
                                                    <MudItem class="d-flex d-flex-column justify-center">
                                                        <MudAlert Severity="Severity.Info">
                                                            @Localizer["UsersFirstSuperior"]
                                                        </MudAlert>
                                                    </MudItem>
                                                }
                                                @*Select Superior *@

                                                @switch (_user.UserType)
                                                {
                                                    case 3:
                                                        @if (SeniorsSupervisors.Count > 0)
                                                        {
                                                            <MudItem Class="d-flex d-flex-row">

                                                                <MudAutocomplete MaxItems="null" T="User" Label="@Localizer["UsersSeniorSupervisor"]" ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer["UsersPHSuperior"]}" : $"{e.Name} ({e.Group?.Description})")" For="@(() => _user.Superior)" SearchFunc="@SearchSSV" Variant="Variant.Outlined" ShowProgressIndicator="true" ValueChanged="@(item => SetSuperiorToUser(item))" />


                                                                @* <MudSelect T="User" Label="SSV" Placeholder="@Localizer["UsersPHSuperior"]" @bind-Value="@_user.Superior"  For="@(() => _user.Superior)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                        <MudSelectItem Disabled="true" Value="selectedSeniorSupervisorOfList"> @Localizer["UsersPHSuperior"]</MudSelectItem>
                                        @foreach (var SS in SeniorsSupervisors)
                                        {
                                        @if (LogedUser.UserType == 1)
                                        {
                                        <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Group?.Description}") </MudSelectItem>
                                        }
                                        else
                                        {
                                        @if (SS.PlantId == _user.PlantId && SS.Areas?.ToList().FindIndex(s => s.AreaId == _user.AreaId) != -1)
                                        {
                                        <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Group?.Description}") </MudSelectItem>
                                        }
                                        }
                                        }
                                        </MudSelect>*@
                                                            </MudItem>
                                                        }
                                                        break;
                                                    case 4:
                                                        @if (Supervisors.Count > 0)
                                                        {
                                                            <MudItem Class="d-flex d-flex-row">

                                                                <MudAutocomplete MaxItems="null" T="User" Label="@Localizer["UsersSupervisor"]" ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer["UsersPHSupervisor"]}" : $"{e.Name}-{e.Area?.Description}-{e.Group?.Description})")" For="@(() => _user.Superior)" SearchFunc="@SearchSV" Variant="Variant.Outlined" ShowProgressIndicator="true" ValueChanged="@(item => SetSuperiorToUser(item))" />


