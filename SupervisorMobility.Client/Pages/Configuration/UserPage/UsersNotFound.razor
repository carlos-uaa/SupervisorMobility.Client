@page "/userNotFound"
@inject IGroupService GroupService
@inject NavigationManager NavigationManager
@inject IUserService UsersServices
@inject IJSRuntime JSRuntime


@*Title*@
<PageTitle>Supervisor Mobility | Users Not Found</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10"  Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@if (_usersNotFound == null)
{
    <MudSimpleTable Class="styled-table table-striped" FixedHeader=true>
        <thead>
            <tr>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>/
            </tr>
        </thead>
        <tbody>

            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /> <MudSpacer />   <MudSkeleton SkeletonType="SkeletonType.Rectangle" /> <MudSpacer />  <MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>

        </tbody>
    </MudSimpleTable>
}
else if (_usersNotFound.Count == 0)
{
    <MudContainer>
        <MudGrid class="d-flex flex-column justify-center align-self-center mt-5">
            <MudItem class="d-flex justify-center align-self-center ">
                <MudText Typo="Typo.h6" Class="align-item-center center">There are no users who tried to log in with an unregistered account.</MudText>
            </MudItem>
        </MudGrid>
       
    </MudContainer>
}
else
{
    <MudTable Items="_usersNotFound" T="UserNotFound" ReadOnly="true" Height="55vh" FixedHeader=true Class="styled-table table-striped"
              SortLabel="Sort By" Filter="new Func<UserNotFound,bool>(FilterFunc)"
          HorizontalScrollbar="true">
        <ToolBarContent>
            <MudGrid class="d-flex flex-column justify-center align-self-center mb-10">
                <MudItem class="d-flex justify-center align-self-center ">
                    <MudText Typo="Typo.h6" Class="align-item-center center">These users tried to log in</MudText>
                </MudItem><MudSpacer />
                <MudItem Class="d-flex">
                    <MudSpacer />
                    <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                    <MudSpacer />
                    <MudButton Href="/usersmanagement/CreateUser" EndIcon="@Icons.Material.Filled.PersonAddAlt1" IconColor="Color.Warning">
                        Create New User
                    </MudButton>
                </MudItem>
            </MudGrid>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<UserNotFound, object>(x=>x?.UserNotFoundId)">User Id</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<UserNotFound, object>(x=>x?.ObjectId)">Username</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<UserNotFound, object>(x=>x?.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="User Id">
                <MudText Align="Align.Center">@context.UserNotFoundId</MudText>
            </MudTd>
            <MudTd DataLabel="Username">
                <MudText Align="Align.Center">@context.ObjectId</MudText>
            </MudTd>
            <MudTd DataLabel="Name">
                <MudText Align="Align.Center">@context.Name</MudText>
            </MudTd>
            <MudTd>
                <MudText Align="Align.Center">
                    <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="@(() =>OpenDeleteDialog(context.UserNotFoundId))"></MudIconButton>
                </MudText>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>

}

@*Delete user modal*@
<MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">Confirm</MudText>
        <MudText Class="mt-4 mb-4">
            Are you sure you want to delete this user?
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">Cancel</MudButton>
        <MudButton @onclick="(() => DeleteUser(deleteUserId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">Delete</MudButton>
    </DialogActions>
</MudDialog>



@code {

    List<UserNotFound> _usersNotFound = new();
    string searchString = "";


    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "#"),
            new BreadcrumbItem("Configuration", href: "/configuration"),
            new BreadcrumbItem("Users Management", href: "usersmanagement"),
            new BreadcrumbItem("Users Not Found", href: "", disabled: true)
        };

    protected async override Task OnInitializedAsync()
    {
        _usersNotFound = await UsersServices.GetUsersNotFound();
    }


    private bool FilterFunc(UserNotFound element)
    {



        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.ObjectId != null){
        if ((bool)element.ObjectId?.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        }
        if ($" {element.ObjectId}".Contains(searchString))
            return true;
        return false;
    }

    async void DeleteUser(int iduser)
    {
        _usersNotFound.RemoveAll(user => user.UserNotFoundId == iduser);
        //await UsersServices.DeleteUser(iduser);
        //await PlantService.DeletePlant(plantId);
        
        //_users = await UsersServices.GetUsersWhitCollections();
        visibleDelete = false;
        StateHasChanged();
    }


    //Delete User
    private bool visibleDelete = false;
    public int deleteUserId = 0;
    private void OpenDeleteDialog(int deleteId)
    {
        deleteUserId = deleteId;
        visibleDelete = true;
    }
    void CloseDeleteModal() => visibleDelete = false;
    private DialogOptions dialogDeleteOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, Position = DialogPosition.TopCenter };

}