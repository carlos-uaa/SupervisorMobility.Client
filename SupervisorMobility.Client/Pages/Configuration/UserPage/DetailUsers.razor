@page "/usersmanagement/DetailUser/{userId:int}"
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage
@inject IUserService UsersServices

@*Title*@
<PageTitle>Supervisor Mobility | Detail Users</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


@if (showui)
{
    <MudGrid>
        @*Guide info*@
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardContent Style="justify-content:center">
                    <MudText Align="Align.Center"><MudIcon Icon="@Icons.Material.Filled.Person"></MudIcon></MudText>
                    <MudText Align="Align.Center">@_user.UserId</MudText>
                    <MudText Typo="Typo.h5" Align="Align.Center">@_user.Name</MudText>
                    @if (_user.IsActive == true)
                    {
                        <MudText Align="Align.Center" Class="pt-2">
                            <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                        </MudText>
                    }
                    else
                    {
                        <MudText Align="Align.Center" Class="pa-4">
                            <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
        @*Guide*@
        <MudItem xs="12" sm="6" md="9">
            <MudGrid>
                <MudItem xs="12">
                    <MudCard>
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h3">User Details</MudText>

                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudItem>
                                <MudItem>
                                    <MudText Typo="Typo.h6">Payroll</MudText>
                                </MudItem>
                                <MudItem class="d-flex flex-column justify-center align-self-center">
                                    <MudTextField Label="Payroll" ReadOnly=true @bind-Value="@_user.Payroll" />

                                </MudItem>
                            </MudItem>

                            <MudItem>
                                <MudItem>
                                    <MudText Typo="Typo.h6">Permissions</MudText>
                                </MudItem>
                                <MudItem class="d-flex flex-column justify-center align-self-center">
                                    @if (_user.IsAdmin)
                                    {
                                        <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary">Admin</MudChip>

                                    }

                                    @if (_user.IsSupervisor)
                                    {
                                        <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">Supervisor</MudChip>

                                    }

                                    @if (_user.IsOperator)
                                    {
                                        <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">Operator</MudChip>

                                    }
                                </MudItem>
                            </MudItem>



                            <MudItem>
                                <MudItem>
                                    <MudText Typo="Typo.h6">General Info</MudText>
                                </MudItem>
                                <MudItem class="d-flex flex-column justify-center align-self-center">
                                    <MudTextField Label="Plant" ReadOnly=true @bind-Value="@_user.Plant.Description" />
                                    <MudTextField Label="Area" ReadOnly=true @bind-Value="@_user.Area.Description" />
                                    <MudTextField Label="Group" ReadOnly=true @bind-Value="@_user.Group.Description" />
                                </MudItem>
                            </MudItem>

                            <MudItem>
                                <MudItem>
                                    <MudText Typo="Typo.h6">More Data Admin</MudText>
                                </MudItem>
                                <MudItem class="d-flex flex-column justify-center align-self-center">
                                    <MudTextField Label="Created Date" ReadOnly=true @bind-Value="@_user.CreatedDate" />
                                    <MudTextField Label="Last Modification Date" ReadOnly=true @bind-Value="@_user.LastUpdated" />
                                    <MudTextField Label="Disable User Date" ReadOnly=true @bind-Value="@_user.DisabledDate" />

                                </MudItem>
                            </MudItem>


                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Href="/usersmanagement" Variant="Variant.Filled" Class="ml-4">Close</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudItem>
    </MudGrid>


}
else
{


    <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
        <MudItem class="d-flex justify-center align-self-center pa-3 ma-2 ">
            <MudText Typo="Typo.h6" Class="align-item-center center">Loading Data</MudText>
        </MudItem>
        <MudPaper Class="flex d-flex-row pa-3 ma-2" Elevation="0">
            <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
        </MudPaper>
    </MudItem>
}




@code {
    [Parameter]
    public int userId { get; set; }

    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "#"),
            new BreadcrumbItem("Configuration", href: "/configuration"),
            new BreadcrumbItem("Users", href: "/usersmanagement"),
            new BreadcrumbItem("Detail Users", href: "", disabled: true),
        };

    private User _user = new User();
    private bool showui = false;

    protected async override Task OnInitializedAsync()
    {

        _user = await UsersServices.GetUserAndCollection(userId);
        showui = true;
    }


}
