@page "/usersmanagement/CreateUser"
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage
@inject IFileUploadAndDownloadService FileUpDoServices
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionsServices
@inject IUserService UserServices
@inject IGroupService GroupServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource1> Localizer
@inject GlobalDataService GlobalData;

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["UsersCreateTitle"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

<MudContainer>

    @*Form*@
    <EditForm Model="_user" OnValidSubmit="CreateUser">
        <DataAnnotationsValidator />
        <MudGrid>
            <MudItem xs="12" >
                <MudCard >
                    <MudCardHeader >
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="ml-10 mt-5">@Localizer["UsersCreateTitle"]</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip Variant="Variant.Text" Color="Color.Success" Class="mr-10">@Localizer["UsersNew"]</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="ml-10 mr-10">

                        <MudItem>
                            <MudItem>
                                <MudText Typo="Typo.h6">@Localizer["UsersPermissions"]</MudText>
                            </MudItem>
                            <MudItem Class="d-flex flex-row align-center justify-center pa-2 ma-2">
                                @if (LogedUser.UserType <= 1)
                                {
                                    <MudSwitch Class="ma-1" Label="@Localizer["UsersAdmin"]" @bind-Checked="@IsAdmin" @onclick="@(() => setActiveUser(1))" Color="Color.Primary" UnCheckedColor="Color.Dark" />
                                    <MudSwitch Class="ma-1" Label="@Localizer["UsersManager"]" @bind-Checked="@IsManager" @onclick="@(() => setActiveUser(5))" Color="Color.Warning" UnCheckedColor="Color.Dark" />
                                    <MudSwitch Class="ma-1" Label="@Localizer["UsersSeniorSupervisor"]" @bind-Checked="@IsSeniorSupervisor" @onclick="@(() => setActiveUser(2))" Color="Color.Secondary" UnCheckedColor="Color.Dark" />
                                }
                                @if (LogedUser.UserType <= 2)
                                {
                                    <MudSwitch Class="ma-1" Label="@Localizer["UsersSupervisor"]" @bind-Checked="@IsSupervisor" @onclick="@(() => setActiveUser(3))" Color="Color.Secondary" UnCheckedColor="Color.Dark" />
                                }
                                <MudSwitch Class="ma-1" Label="@Localizer["UsersOperator"]" @bind-Checked="@IsOperator" @onclick="@(() => setActiveUser(4))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                                <MudSwitch Class="ma-1" Label="@Localizer["lineSupport"]" @bind-Checked="@IsLineSupport" @onclick="@(() => setActiveUser(6))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                            </MudItem>
                            <MudItem class="d-flex d-flex-column justify-center">
                                @switch (_user.UserType)
                                {
                                    case 1:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary">@Localizer["UsersAdmin"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 2:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSeniorSupervisor"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 3:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSupervisor"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 4:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">@Localizer["UsersOperator"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 5:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Warning">@Localizer["UsersManager"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 6:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.Engineering" Color="Color.Info">@Localizer["lineSupport"]</MudChip>
                                        </MudPaper>
                                        break;
                                }
                            </MudItem>

                        </MudItem>

                        @if (_user.UserType > 0)
                        {
                            <MudItem>
                                <MudText Typo="Typo.h6">@Localizer["UsersGeneralInfo"]</MudText>
                            </MudItem>
                            @if(_user.UserType != 4){
                                <MudItem>
                                    <MudTextField Label="@Localizer["UsersObject"]" @bind-value="@_user.ObjectId" For="@(() => _user.ObjectId)" HelperText="E.g. user@compasdcpcs.local" />
                                </MudItem>
                            }
                            <MudTextField Label="@Localizer["UsersName"]" @bind-Value="@_user.Name" For="@(() => _user.Name)" />
                        }
                        @if (_user.UserType == 4)
                        {
                            <MudTextField Label="@Localizer["UsersPayroll"]" @bind-Value="@_user.Payroll" For="@(() => _user.Payroll)" />
                        }

                        @if (_user.UserType != 4 && _user.UserType != 0)
                        {
                                <MudTextField Mask="@emailMask" Label="@Localizer["UsersEmail"]" HelperText="@emailMask.Mask"
                                          @bind-Value="@_user.Email" For="@(() => _user.Email)" Variant="@Variant.Text" Clearable />
                        }

                        @if (_user.UserType > 1)
                        {
                            <MudItem Class="mt-5">
                                <MudText Typo="Typo.h6">@Localizer["UsersEmployeInfo"]</MudText>
                            </MudItem>

                        }

                        @if (_user.UserType == 2 || _user.UserType == 6)
                        {
                            @*Mud select of Plants *@
                            <MudSelect T="int" Label="@Localizer["UsersLabelPlant"]" Variant="Variant.Text" Placeholder="@Localizer["UsersPHPlant"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxPlant" For="@(() => auxPlant)" SelectedValuesChanged="ShowAreasInvokeByPlantSelector">
                                <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHPlant"]</MudSelectItem>
                                @foreach (var type in _plants)
                                {
                                    <MudSelectItem Value="type.PlantId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                            @*Mud select of Areas *@
                            @*<MudSelect T="int" Label="Area" Variant="Variant.Text" Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxArea" For="@(() => auxArea)" SelectedValuesChanged="ShowDistributionInvokeByAreasSelector">
                                <MudSelectItem Disabled="true" Value="0">Select an Area</MudSelectItem>
                                @foreach (var type in _areas)
                                {
                                    <MudSelectItem Value="type.AreaId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>*@

                            <MudSelect T="int" Label="@Localizer["UsersLabelGroup"]" Variant="Variant.Text" Placeholder="@Localizer["UsersPHGroup"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxGroup" For="@(() => auxGroup)">
                                <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHGroup"]</MudSelectItem>
                                @foreach (var type in _groups)
                                {
                                    <MudSelectItem Value="type.GroupId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        else if(_user.UserType == 3 && LogedUser.UserType == 1){
                            <MudTextField @bind-Value="plantInfo" Label="@Localizer["UsersLabelPlant"]" ReadOnly="true" Variant="Variant.Outlined" />
                            if(_user.Superior != null)
                            {
                                if(_user.Superior.Areas != null && _user.Superior.Areas.Count > 0){
                                    <MudSelect T="int" Label="@Localizer["UsersLabelArea"]" Variant="Variant.Outlined" Placeholder="@Localizer["UsersPHArea"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxArea" For="@(() => auxArea)" SelectedValuesChanged="ShowDistributionInvokeByAreasSelector">
                                        <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHArea"]</MudSelectItem>
                                        @foreach (var type in _user.Superior.Areas)
                                        {
                                        <MudSelectItem Value="type.AreaId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Info">
                                        <MudText Style="font-weight: bold;">@Localizer["UsersNoAreasSSV"]</MudText>
                                    </MudAlert>
                                }
                                
                            }

                            <MudTextField @bind-Value="grupInfo" Label="@Localizer["UsersLabelGroup"]" ReadOnly="true" Variant="Variant.Outlined" />
                        }
                        else if(_user.UserType == 3 && LogedUser.UserType == 2){
                            <MudTextField @bind-Value="plantInfo" Label="@Localizer["UserslabelPlant"]" ReadOnly="true" Variant="Variant.Outlined" />
                            if(LogedUser.Areas != null){
                                <MudSelect T="int" Label="@Localizer["UsersLabelArea"]" Variant="Variant.Outlined" Placeholder="@Localizer["UsersPHArea"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxArea" For="@(() => auxArea)" SelectedValuesChanged="ShowDistributionInvokeByAreasSelector">
                                    <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHArea"]</MudSelectItem>
                                @foreach (var type in LogedUser.Areas)
                                    {
                                    <MudSelectItem Value="type.AreaId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info">
                                    <MudText Style="font-weight: bold;">@Localizer["UsersNoAreasSSV"].</MudText>
                                </MudAlert>
                            }
                            <MudTextField @bind-Value="grupInfo" Label="@Localizer["UsersLabelGroup"]" ReadOnly="true" Variant="Variant.Outlined" />
                        }
                        else if (_user.UserType == 4)
                        {
                            <MudTextField @bind-Value="plantInfo" Label="@Localizer["UsersLabelPlant"]" ReadOnly="true" Variant="Variant.Outlined" />
                            <MudTextField @bind-Value="areaInfo" Label="@Localizer["UsersLabelArea"]" ReadOnly="true" Variant="Variant.Outlined" />
                            <MudTextField @bind-Value="grupInfo" Label="@Localizer["UsersLabelGroup"]" ReadOnly="true" Variant="Variant.Outlined" />
                        }
                        else if(_user.UserType == 5){
                            @*Mud select of Plants for Manager*@
                            <MudSelect T="int" Label="@Localizer["UsersLabelPlant"]" Variant="Variant.Text" Placeholder="@Localizer["UsersPHPlant"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxPlant" For="@(() => auxPlant)" SelectedValuesChanged="ShowAreasInvokeByPlantSelector">
                                <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHPlant"]</MudSelectItem>
                                @foreach (var type in _plants)
                                {
                                    <MudSelectItem Value="type.PlantId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }



                        @*Mud select of Distribution *@
                        @if (_user.UserType == 4 && _user.Superior != null)
                        {
                            <MudSelect T="int" Label="@Localizer["UsersLabelDistribution"]" Variant="Variant.Text" Placeholder="@Localizer["UsersPHDistribution"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxDistribution" For="@(() => auxDistribution)">
                                <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHDistribution"]</MudSelectItem>
                                @foreach (var type in _distributions)
                                {
                                    <MudSelectItem Value="type.DistributionId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        @* Areas Managed*@


                        @if (_user.UserType == 2 || _user.UserType == 6)
                        {
                            <MudItem Class="mt-5">
                                <MudText Typo="Typo.h6">@Localizer["UsersManageAreas"]</MudText>
                            </MudItem>
                            @switch (_user.Areas?.Count)
                            {
                                case null:
                                    @if (auxPlant == 0)
                                    {
                                        <MudItem>
                                            <MudAlert Severity="Severity.Info">
                                                @Localizer["UsersFirstPlant"]
                                            </MudAlert>
                                        </MudItem>
                                    }
                                    else
                                    {
                                        @if (_areasManager?.Count > 0)
                                        {
                                            <MudItem class="d-flex flex-column justify-center">
                                                <MudAlert Severity="Severity.Info">
                                                   @Localizer["UsersFirstArea"]
                                                </MudAlert>
                                            </MudItem>
                                        }
                                        else
                                        {
                                            <MudItem class="d-flex flex-column justify-center">
                                                <MudAlert Severity="Severity.Info">
                                                    @Localizer["UsersPlantNoAreas"]
                                                </MudAlert>
                                            </MudItem>
                                        }


                                    }
                                    break;
                                case 0:
                                    @if (auxPlant == 0)
                                    {
                                        <MudItem class="d-flex flex-column justify-center justify-align-center">
                                            <MudAlert Severity="Severity.Info">
                                                @Localizer["UsersFirstPlant"]
                                            </MudAlert>
                                        </MudItem>
                                    }
                                    else
                                    {
                                        @if (_areasManager?.Count > 0)
                                        {
                                            <MudItem class="d-flex flex-column justify-center">
                                                <MudAlert Severity="Severity.Info">
                                                    @Localizer["UsersFirstAddArea"]
                                                </MudAlert>
                                            </MudItem>
                                        }
                                        else
                                        {
                                            <MudItem class="d-flex flex-column justify-center">
                                                <MudAlert Severity="Severity.Info">
                                                    @Localizer["UsersPlantNoAreas"]
                                                </MudAlert>
                                            </MudItem>
                                        }
                                    }
                                    break;
                                default:
                                    @if (_user.Areas is not null && _user.Areas?.ToList().Count > 0)
                                    {
                                        <MudItem class="d-flex flex-column justify-center ma-1">
                                            <MudItem class="d-flex d-flex-column justify-center">
                                                @foreach (var itemArea in _user.Areas)
                                                {
                                                    <MudCard Elevation="1" Class="mr-5" Style="width: 300px;">
                                                        <MudCardHeader>
                                                            <CardHeaderContent>
                                                                <MudText Typo="Typo.subtitle1"><b>@Localizer["UsersAreaId"]:</b> @itemArea.AreaId</MudText>
                                                            </CardHeaderContent>
                                                            <CardHeaderActions>
                                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="() => DeleteAreaFromUserList(itemArea)" />
                                                            </CardHeaderActions>
                                                        </MudCardHeader>
                                                        <MudCardContent>
                                                            <div class="font-weight-bold"><b>@Localizer["UsersCode"]:</b> @itemArea.Code</div>
                                                            <div class="font-weight-light"><b>@Localizer["UsersDescription"]:</b> @itemArea.Description</div>
                                                        </MudCardContent>
                                                        <MudCardActions></MudCardActions>
                                                    </MudCard>
                                                }
                                            </MudItem>
                                        </MudItem>
                                    }

                                    break;
                            }
                            @*Selector Ares*@
                            @if (_areasManager?.Count > 0 && auxPlant != 0)
                            {
                                <MudItem class="d-flex d-flex-column justify-center ma-1">
                                    <MudItem Class="d-flex d-flex-row">
                                        <MudSelect T="Area" Label="@Localizer["UsersLabelArea"]" SelectedValuesChanged="@OnSelectedAreaToManageFunction" Placeholder="@Localizer["UsersPHArea"]" @bind-Value="@selectedAreaOfList" For="@(() => selectedAreaOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                            <MudSelectItem Disabled="true" Value="selectedAreaOfList"> @Localizer["UsersPHArea"] </MudSelectItem>
                                            @foreach (var areaItem in _areasManager)
                                            {
                                                <MudSelectItem Value="areaItem">@($"{areaItem.Code}-{areaItem.Description}") </MudSelectItem>
                                            }
                                        </MudSelect>
                                        <MudButton Class="ml-5" Disabled="@ActiveAddArea" OnClick="@(() => AddAreaToUserList(selectedAreaOfList))" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" IconColor="Color.Secondary" Size="Size.Large"> @Localizer["UsersAddArea"] </MudButton>
                                    </MudItem>
                                </MudItem>
                            }
                        }


                        @if (_user.UserType != 0 && _user.UserType != 6)
                        {
                            <MudItem>
                                <MudItem Class="mt-5">
                                    <MudText Typo="Typo.h6"> @Localizer["UsersHT"] </MudText>
                                </MudItem>
                                @*Superiorcard *@
                                <MudItem Class="d-flex flex-column justify-center ma-1">
                                    @if (_user.Superior != null)
                                    {
                                        <MudItem class="d-flex d-flex-column justify-center">
                                            <MudText Typo="Typo.h6"> @Localizer["UsersSuperior"] </MudText>
                                        </MudItem>
                                        <MudItem class="d-flex d-flex-column justify-center">
                                            <MudCard Elevation="1" Class="m-3" Style="width: 300px;">
                                                <MudCardHeader>
                                                    <CardHeaderContent>
                                                        <MudText Typo="Typo.subtitle1"> @Localizer["UsersSuperior"] </MudText>
                                                    </CardHeaderContent>
                                                    <CardHeaderActions>
                                                        @if(!(LogedUser.UserType == 2 && _user.UserType == 3)){
                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveSuperiorUser())" />
                                                        }
                                                    </CardHeaderActions>
                                                </MudCardHeader>
                                                <MudCardContent>
                                                    <div class="font-weight-bold"> <MudText Typo="Typo.subtitle2"> @Localizer["UsersName"]:</MudText> @_user.Superior.Name </div>
                                                    <div class="font-weight-light"><MudText Typo="Typo.subtitle2"> @Localizer["UsersGroup"]:</MudText> @_user.Superior.Group?.Description </div>
                                                </MudCardContent>
                                                <div class="d-flex justify-content-between justify-center">
                                                    @switch (_user.Superior.UserType)
                                                    {
                                                        case 1:
                                                            <MudPaper Elevation="0">
                                                                <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary"> @Localizer["UsersAdmin"] </MudChip>
                                                            </MudPaper>
                                                            break;
                                                        case 2:
                                                            <MudPaper Elevation="0">
                                                                <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"> @Localizer["UsersSeniorSupervisor"] </MudChip>
                                                            </MudPaper>
                                                            break;
                                                        case 3:
                                                            <MudPaper Elevation="0">
                                                                <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"> @Localizer["UsersSupervisor"] </MudChip>
                                                            </MudPaper>
                                                            break;
                                                        case 4:
                                                            <MudPaper Elevation="0">
                                                                <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark"> @Localizer["UsersOperator"] </MudChip>
                                                            </MudPaper>
                                                            break;
                                                    }
                                                </div>
                                                <MudCardActions>

                                                </MudCardActions>
                                            </MudCard>

                                        </MudItem>

                                    }
                                    else
                                    {
                                        

                                        @if (_user.UserType > 2 && _user.UserType != 5)
                                        {
                                            <MudItem class="d-flex d-flex-column justify-center">
                                                <MudText Typo="Typo.h6"> @Localizer["UsersSuperior"] </MudText>
                                            </MudItem>
                                            <MudItem class="d-flex d-flex-column justify-center">
                                                <MudAlert Severity="Severity.Info">
                                                     @Localizer["UsersFirstSuperior"]
                                                </MudAlert>
                                            </MudItem>
                                        }
                                        @*Select Superior *@

                                        @switch (_user.UserType)
                                        {
                                            case 3:
                                                @if (SeniorsSupervisors.Count > 0)
                                                {
                                                    <MudItem Class="d-flex d-flex-row">
                                                        <MudSelect T="User" Label="SSV" Placeholder="@Localizer["UsersPHSuperior"]" @bind-Value="@_user.Superior" SelectedValuesChanged="SetSuperiorToUser" For="@(() => _user.Superior)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                                            <MudSelectItem Disabled="true" Value="selectedSeniorSupervisorOfList"> @Localizer["UsersPHSuperior"]</MudSelectItem>
                                                            @foreach (var SS in SeniorsSupervisors)
                                                            {
                                                                @if (LogedUser.UserType == 1)
                                                                {
                                                                    <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Group?.Description}") </MudSelectItem>
                                                                }
                                                                else
                                                                {
                                                                    @if (SS.PlantId == _user.PlantId && SS.AreaId == _user.AreaId)
                                                                    {
                                                                        <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Group?.Description}") </MudSelectItem>
                                                                    }
                                                                }
                                                            }
                                                        </MudSelect>
                                                    </MudItem>
                                                }
                                                break;
                                            case 4:
                                                @if (Supervisors.Count > 0)
                                                {
                                                    <MudItem Class="d-flex d-flex-row">
                                                        <MudSelect T="User" Label="@Localizer["UsersSupervisor"]" Placeholder="@Localizer["UsersPHSupervisor"]" @bind-Value="@_user.Superior" For="@(() => _user.Superior)" SelectedValuesChanged="SetSuperiorToUser" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                                            <MudSelectItem Disabled="true" Value="selectedSupervisorOfList"> @Localizer["UsersPHSupervisor"] </MudSelectItem>
                                                            @foreach (var SS in Supervisors)
                                                            {
                                                                @if (LogedUser.UserType == 1)
                                                                {
                                                                    <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area.Description}-{SS.Group?.Description}") </MudSelectItem>
                                                                }
                                                                else if(LogedUser.UserType == 2)
                                                                {
                                                                    @if (SS.PlantId == LogedUser.PlantId && LogedUser.Areas?.ToList().FindIndex(s => s.AreaId == SS.AreaId) != -1)
                                                                    {
                                                                        <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area.Description}-{SS.Group?.Description}") </MudSelectItem>
                                                                    }
                                                                }
                                                            }
                                                        </MudSelect>
                                                    </MudItem>
                                                }
                                                break;
                                        }
                                    }
                                </MudItem>

                                @*Subordinados *@
                                <MudItem Class="d-flex flex-column justify-center">
                                    @if (@_user.UserType != 4)
                                    {
                                        <MudItem class="d-flex d-flex-column justify-center">
                                            <MudText Typo="Typo.h6"> @Localizer["UsersSubordinates"] </MudText>
                                        </MudItem>

                                    }

                                    @switch (_user.Subordinates?.Count)
                                    {
                                        case null:

                                            @if (auxPlant == 0 &&  _user.UserType > 2) 
                                            {
                                                <MudItem class="d-flex flex-column justify-center">
                                                    <MudAlert Severity="Severity.Info">
                                                        @Localizer["UsersFirstSuperior"]
                                                    </MudAlert>
                                                </MudItem>
                                            }
                                            else
                                            {
                                                @switch (_user.UserType)
                                                {
                                                    case 1:
                                                        @if (SeniorsSupervisors?.Count > 0)
                                                        {
                                                            <MudItem class="d-flex flex-column justify-center">
                                                                <MudAlert Severity="Severity.Info">
                                                                   @Localizer["UsersFirstSubordinate"]
                                                                </MudAlert>
                                                            </MudItem>
                                                        }
                                                        else
                                                        {
                                                            <MudItem class="d-flex flex-column justify-center">
                                                                <MudAlert Severity="Severity.Info">
                                                                    @Localizer["UsersPlantNoSSV"]
                                                                </MudAlert>
                                                            </MudItem>
                                                        }
                                                        break;
                                                    case 2:
                                                        @if (Supervisors?.Count > 0)
                                                        {
                                                            @if(_user.Areas?.Count > 0){
                                                                <MudItem class="d-flex flex-column justify-center">
                                                                    <MudAlert Severity="Severity.Info">
                                                                        @Localizer["UsersFirstSubordinate"]
                                                                    </MudAlert>
                                                                </MudItem>
                                                            }else{
                                                                <MudItem class="d-flex flex-column justify-center">
                                                                    <MudAlert Severity="Severity.Info">
                                                                        @Localizer["UsersFirstAddArea"]
                                                                    </MudAlert>
                                                                </MudItem>
                                                            }
                                                        }
                                                        else
                                                        {
