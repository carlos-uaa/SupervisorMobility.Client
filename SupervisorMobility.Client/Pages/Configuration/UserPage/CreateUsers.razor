@page "/usersmanagement/CreateUser"
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage
@inject IFileUploadAndDownloadService FileUpDoServices
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionsServices
@inject IUserService UserServices
@inject IGroupService GroupServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JS



@*Title*@
<PageTitle>Supervisor Mobility | Create Users</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

<MudContainer>

    @*Form*@
    <EditForm Model="_user" OnValidSubmit="CreateUser">
        <DataAnnotationsValidator />
        <MudGrid>
            <MudItem xs="12">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Create User</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip Variant="Variant.Text" Color="Color.Success">New User</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>

                        <MudItem>
                            <MudItem>
                                <MudText Typo="Typo.h6">Permissions</MudText>
                            </MudItem>
                            <MudItem class="d-flex d-flex-column justify-center">
                                @switch (_user.UserType)
                                {
                                    case 1:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary">Admin</MudChip>
                                        </MudPaper>
                                        break;
                                    case 2:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">Senior Supervisor</MudChip>
                                        </MudPaper>
                                        break;
                                    case 3:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">Supervisor</MudChip>
                                        </MudPaper>
                                        break;
                                    case 4:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">Operator</MudChip>
                                        </MudPaper>
                                        break;
                                }
                            </MudItem>
                            <MudItem Class="d-flex flex-row align-center justify-center pa-2 ma-2">
                                @if (LogedUser.UserType <= 1)
                                {
                                    <MudSwitch Class="ma-1" Label="Is Admin?" @bind-Checked="@IsAdmin" @onclick="@(() => setActiveUser(1))" Color="Color.Primary" UnCheckedColor="Color.Dark" />
                                    <MudSwitch Class="ma-1" Label="Is SeniorSupervisor?" @bind-Checked="@IsSeniorSupervisor" @onclick="@(() => setActiveUser(2))" Color="Color.Secondary" UnCheckedColor="Color.Dark" />
                                }
                                @if (LogedUser.UserType <= 2)
                                {
                                    <MudSwitch Class="ma-1" Label="Is Supervisor?" @bind-Checked="@IsSupervisor" @onclick="@(() => setActiveUser(3))" Color="Color.Secondary" UnCheckedColor="Color.Dark" />
                                }
                                <MudSwitch Class="ma-1" Label="Is Operator?" @bind-Checked="@IsOperator" @onclick="@(() => setActiveUser(4))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                            </MudItem>

                        </MudItem>

                        @if (_user.UserType > 0)
                        {
                            <MudItem>
                                <MudText Typo="Typo.h6">General Info</MudText>
                            </MudItem>
                        }
                        @if (_user.UserType != 4 && _user.UserType > 0)
                        {
                            <MudItem Class="d-flex d-flex-row">
                                <MudTextField Label="Azure ID" @bind-Value="@_user.ObjectId" For="@(() => _user.ObjectId)" />
                                <MudTooltip Text="Object Id of Active Directory">
                                    <MudIconButton Icon="@Icons.Material.Filled.HelpOutline" />
                                </MudTooltip>
                            </MudItem>
                        }
                        @if (_user.UserType > 0)
                        {

                            <MudTextField Label="User Name" @bind-Value="@_user.Name" For="@(() => _user.Name)" />
                        }
                        @if (_user.UserType == 4)
                        {
                            <MudTextField Label="User Payroll Number" @bind-Value="@_user.Payroll" For="@(() => _user.Payroll)" />
                        }

                        @if (_user.UserType != 4 && _user.UserType != 0)
                        {
                            <MudItem xs="12" sm="6">
                                <MudTextField Mask="@emailMask" Label="Email Address" HelperText="@emailMask.Mask"
                                          @bind-Value="@_user.Email" For="@(() => _user.Email)" Variant="@Variant.Text" Clearable />
                            </MudItem>
                        }

                        @if (_user.UserType > 1)
                        {
                            <MudItem>
                                <MudText Typo="Typo.h6">Employment Information</MudText>
                            </MudItem>

                        }

                        @if (_user.UserType == 2)
                        {
                            @*Mud select of Plants *@
                            <MudSelect T="int" Label="Plant" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxPlant" For="@(() => auxPlant)" SelectedValuesChanged="ShowAreasInvokeByPlantSelector">
                                <MudSelectItem Disabled="true" Value="0">Select a Plant</MudSelectItem>
                                @foreach (var type in _plants)
                                {
                                    <MudSelectItem Value="type.PlantId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                            @*Mud select of Areas *@
                            @*<MudSelect T="int" Label="Area" Variant="Variant.Text" Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxArea" For="@(() => auxArea)" SelectedValuesChanged="ShowDistributionInvokeByAreasSelector">
                                <MudSelectItem Disabled="true" Value="0">Select an Area</MudSelectItem>
                                @foreach (var type in _areas)
                                {
                                    <MudSelectItem Value="type.AreaId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>*@

                            <MudSelect T="int" Label="Group" Variant="Variant.Text" Placeholder="Select a Group" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxGroup" For="@(() => auxGroup)">
                                <MudSelectItem Disabled="true" Value="0">Select an Group</MudSelectItem>
                                @foreach (var type in _groups)
                                {
                                    <MudSelectItem Value="type.GroupId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        else if(_user.UserType == 3 && LogedUser.UserType == 1){
                            <MudTextField @bind-Value="plantInfo" Label="Plant" ReadOnly="true" Variant="Variant.Outlined" />
                            if(_user.Superior != null)
                            {
                                if(_user.Superior.Areas != null){
                                    <MudSelect T="int" Label="Area" Variant="Variant.Outlined" Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxArea" For="@(() => auxArea)" SelectedValuesChanged="ShowDistributionInvokeByAreasSelector">
                                        <MudSelectItem Disabled="true" Value="0">Select an Area</MudSelectItem>
                                        @foreach (var type in _user.Superior.Areas)
                                        {
                                        <MudSelectItem Value="type.AreaId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Info">
                                        <MudText Style="font-weight: bold;">This superior has no areas yet.</MudText>
                                    </MudAlert>
                                }
                                
                            }

                            <MudTextField @bind-Value="grupInfo" Label="Group" ReadOnly="true" Variant="Variant.Outlined" />
                        }
                        else if(_user.UserType == 3 && LogedUser.UserType == 2){
                            <MudTextField @bind-Value="plantInfo" Label="Plant" ReadOnly="true" Variant="Variant.Outlined" />
                            if(LogedUser.Areas != null){
                                <MudSelect T="int" Label="Area" Variant="Variant.Outlined" Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxArea" For="@(() => auxArea)" SelectedValuesChanged="ShowDistributionInvokeByAreasSelector">
                                    <MudSelectItem Disabled="true" Value="0">Select an Area</MudSelectItem>
                                @foreach (var type in LogedUser.Areas)
                                    {
                                    <MudSelectItem Value="type.AreaId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info">
                                    <MudText Style="font-weight: bold;">This superior has no areas yet.</MudText>
                                </MudAlert>
                            }
                            <MudTextField @bind-Value="grupInfo" Label="Group" ReadOnly="true" Variant="Variant.Outlined" />
                        }
                        else if (_user.UserType == 4)
                        {
                            <MudTextField @bind-Value="plantInfo" Label="Plant" ReadOnly="true" Variant="Variant.Outlined" />
                            <MudTextField @bind-Value="areaInfo" Label="Area" ReadOnly="true" Variant="Variant.Outlined" />
                            <MudTextField @bind-Value="grupInfo" Label="Group" ReadOnly="true" Variant="Variant.Outlined" />
                        }




                        @*Mud select of Distribution *@
                        @if (_user.UserType == 4)
                        {
                            <MudSelect T="int" Label="Distribution" Variant="Variant.Text" Placeholder="Select a Distribution" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxDistribution" For="@(() => auxDistribution)">
                                <MudSelectItem Disabled="true" Value="0">Select an Distribution</MudSelectItem>
                                @foreach (var type in _distributions)
                                {
                                    <MudSelectItem Value="type.DistributionId">@($"{type.Code}-{type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        @* Areas Managed*@


                        @if (_user.UserType == 2)
                        {
                            <MudItem>
                                <MudText Typo="Typo.h6">Managed Areas</MudText>
                            </MudItem>
                            @switch (_user.Areas?.Count)
                            {
                                case null:
                                    @if (auxPlant == 0)
                                    {
                                        <MudItem class="d-flex flex-column justify-center justify-align-center">
                                            <MudAlert Severity="Severity.Info">
                                                <MudText Style="font-weight: bold;">Please select one plant first...</MudText>
                                            </MudAlert>
                                        </MudItem>
                                    }
                                    else
                                    {
                                        @if (_areasManager?.Count > 0)
                                        {
                                            <MudItem class="d-flex flex-column justify-center">
                                                <MudAlert Severity="Severity.Info">
                                                    <MudText Style="font-weight: bold;">Please add areas to manage...</MudText>
                                                </MudAlert>
                                            </MudItem>
                                        }
                                        else
                                        {
                                            <MudItem class="d-flex flex-column justify-center">
                                                <MudAlert Severity="Severity.Info">
                                                    <MudText Style="font-weight: bold;">This plant does not have areas to manage...</MudText>
                                                </MudAlert>
                                            </MudItem>
                                        }


                                    }
                                    break;
                                case 0:
                                    @if (auxPlant == 0)
                                    {
                                        <MudItem class="d-flex flex-column justify-center justify-align-center">
                                            <MudAlert Severity="Severity.Info">
                                                <MudText Style="font-weight: bold;">Please select one plant first...</MudText>
                                            </MudAlert>
                                        </MudItem>
                                    }
                                    else
                                    {
                                        @if (_areasManager?.Count > 0)
                                        {
                                            <MudItem class="d-flex flex-column justify-center">
                                                <MudAlert Severity="Severity.Info">
                                                    <MudText Style="font-weight: bold;">Please add areas to manage...</MudText>
                                                </MudAlert>
                                            </MudItem>
                                        }
                                        else
                                        {
                                            <MudItem class="d-flex flex-column justify-center">
                                                <MudAlert Severity="Severity.Info">
                                                    <MudText Style="font-weight: bold;">This plant does not have areas to manage...</MudText>
                                                </MudAlert>
                                            </MudItem>
                                        }
                                    }
                                    break;
                                default:
                                    @if (_user.Areas is not null && _user.Areas?.ToList().Count > 0)
                                    {
                                        <MudItem class="d-flex flex-column justify-center ma-1">
                                            <MudItem class="d-flex d-flex-column justify-center">
                                                @foreach (var itemArea in _user.Areas)
                                                {
                                                    <MudCard Elevation="1" Class="mr-5" Style="width: 300px;">
                                                        <MudCardHeader>
                                                            <CardHeaderContent>
                                                                <MudText Typo="Typo.subtitle1"><b>Area Id:</b> @itemArea.AreaId</MudText>
                                                            </CardHeaderContent>
                                                            <CardHeaderActions>
                                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="() => DeleteAreaFromUserList(itemArea)" />
                                                            </CardHeaderActions>
                                                        </MudCardHeader>
                                                        <MudCardContent>
                                                            <div class="font-weight-bold"><b>Code:</b> @itemArea.Code</div>
                                                            <div class="font-weight-light"><b>Description:</b> @itemArea.Description</div>
                                                        </MudCardContent>
                                                        <MudCardActions></MudCardActions>
                                                    </MudCard>
                                                }
                                            </MudItem>
                                        </MudItem>
                                    }

                                    break;
                            }
                            @*Selector Ares*@
                            @if (_areasManager?.Count > 0 && auxPlant != 0)
                            {
                                <MudItem class="d-flex d-flex-column justify-center ma-1">
                                    <MudItem Class="d-flex d-flex-row">
                                        <MudSelect T="Area" Label="Areas" SelectedValuesChanged="@OnSelectedAreaToManageFunction" Placeholder="Select Area" @bind-Value="@selectedAreaOfList" For="@(() => selectedAreaOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                            <MudSelectItem Disabled="true" Value="selectedAreaOfList"> Select Area </MudSelectItem>
                                            @foreach (var areaItem in _areasManager)
                                            {
                                                <MudSelectItem Value="areaItem">@($"{areaItem.Code}-{areaItem.Description}") </MudSelectItem>
                                            }
                                        </MudSelect>
                                        <MudButton Class="ml-5" Disabled="@ActiveAddArea" OnClick="@(() => AddAreaToUserList(selectedAreaOfList))" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" IconColor="Color.Secondary" Size="Size.Large"> Add Area </MudButton>
                                    </MudItem>
                                </MudItem>
                            }
                        }


                        @if (_user.UserType != 0)
                        {
                            <MudItem>
                                <MudItem>
                                    <MudText Typo="Typo.h6"> Hierarchy tree </MudText>
                                </MudItem>
                                @*Superiorcard *@
                                <MudItem Class="d-flex flex-column justify-center ma-1">
                                    @if (_user.Superior != null)
                                    {
                                        <MudItem class="d-flex d-flex-column justify-center">
                                            <MudText Typo="Typo.h6"> Superior </MudText>
                                        </MudItem>
                                        <MudItem class="d-flex d-flex-column justify-center">
                                            <MudCard Elevation="1" Class="m-3" Style="width: 300px;">
                                                <MudCardHeader>
                                                    <CardHeaderContent>
                                                        <MudText Typo="Typo.subtitle1"> Superior </MudText>
                                                    </CardHeaderContent>
                                                    <CardHeaderActions>
                                                        @if(LogedUser.UserType != 2){
                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveSuperiorUser())" />
                                                        }
                                                    </CardHeaderActions>
                                                </MudCardHeader>
                                                <MudCardContent>
                                                    <div class="font-weight-bold"> <MudText Typo="Typo.subtitle2"> Name:</MudText> @_user.Superior.Name </div>
                                                    <div class="font-weight-light"><MudText Typo="Typo.subtitle2"> Group:</MudText> @_user.Superior.Group?.Description </div>
                                                </MudCardContent>
                                                <div class="d-flex justify-content-between justify-center">
                                                    @switch (_user.Superior.UserType)
                                                    {
                                                        case 1:
                                                            <MudPaper Elevation="0">
                                                                <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary"> Admin </MudChip>
                                                            </MudPaper>
                                                            break;
                                                        case 2:
                                                            <MudPaper Elevation="0">
                                                                <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"> Senior Supervisor </MudChip>
                                                            </MudPaper>
                                                            break;
                                                        case 3:
                                                            <MudPaper Elevation="0">
                                                                <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"> Supervisor </MudChip>
                                                            </MudPaper>
                                                            break;
                                                        case 4:
                                                            <MudPaper Elevation="0">
                                                                <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark"> Operator </MudChip>
                                                            </MudPaper>
                                                            break;
                                                    }
                                                </div>
                                                <MudCardActions>

                                                </MudCardActions>
                                            </MudCard>

                                        </MudItem>

                                    }
                                    else
                                    {
                                        

                                        @if (_user.UserType > 2)
                                        {
                                            <MudItem class="d-flex d-flex-column justify-center">
                                                <MudText Typo="Typo.h6"> Superior </MudText>
                                            </MudItem>
                                            <MudItem class="d-flex d-flex-column justify-center">
                                                <MudAlert Severity="Severity.Info">
                                                    <MudText Style="font-weight: bold;"> without Superiors Yet...</MudText>
                                                </MudAlert>
                                            </MudItem>
                                        }
                                        @*Select Superior *@

                                        @switch (_user.UserType)
                                        {
                                            case 3:
                                                @if (SeniorsSupervisors.Count > 0)
                                                {
                                                    <MudItem Class="d-flex d-flex-row">
                                                        <MudSelect T="User" Label="SSV" Placeholder="Select Supervisor" @bind-Value="@_user.Superior" SelectedValuesChanged="SetSuperiorToUser" For="@(() => _user.Superior)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                                            <MudSelectItem Disabled="true" Value="selectedSeniorSupervisorOfList"> Select a Supervisor</MudSelectItem>
                                                            @foreach (var SS in SeniorsSupervisors)
                                                            {
                                                                @if (LogedUser.UserType == 1)
                                                                {
                                                                    <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Group?.Description}") </MudSelectItem>
                                                                }
                                                                else
                                                                {
                                                                    @if (SS.PlantId == _user.PlantId && SS.AreaId == _user.AreaId)
                                                                    {
                                                                        <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Group?.Description}") </MudSelectItem>
                                                                    }
                                                                }
                                                            }
                                                        </MudSelect>
                                                    </MudItem>
                                                }
                                                break;
                                            case 4:
                                                @if (Supervisors.Count > 0)
                                                {
                                                    <MudItem Class="d-flex d-flex-row">
                                                        <MudSelect T="User" Label="Supervisors" Placeholder="Select Supervisor" @bind-Value="@_user.Superior" For="@(() => _user.Superior)" SelectedValuesChanged="SetSuperiorToUser" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                                            <MudSelectItem Disabled="true" Value="selectedSupervisorOfList"> Select Supervisor </MudSelectItem>
                                                            @foreach (var SS in Supervisors)
                                                            {
                                                                @if (LogedUser.UserType == 1)
                                                                {
                                                                    <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area.Description}-{SS.Group?.Description}") </MudSelectItem>
                                                                }
                                                                else
                                                                {
                                                                    @if (SS.PlantId == _user.PlantId && SS.AreaId == _user.AreaId)
                                                                    {
                                                                        <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area.Description}-{SS.Group?.Description}") </MudSelectItem>
                                                                    }
                                                                }
                                                            }
                                                        </MudSelect>
                                                    </MudItem>
                                                }
                                                break;
                                        }
                                    }
                                </MudItem>

                                @*Subordinados *@
                                <MudItem Class="d-flex flex-column justify-center ma-8">
                                    @if (@_user.UserType != 4)
                                    {
                                        <MudItem class="d-flex d-flex-column justify-center">
                                            <MudText Typo="Typo.h6"> Subordinates </MudText>
                                        </MudItem>

                                    }

                                    @switch (_user.Subordinates?.Count)
                                    {
                                        case null:
                                            <MudText Style="font-weight: bold;">Caso null.. Plant:{@auxPlant} </MudText>

                                            @if (auxPlant == 0 &&  _user.UserType > 2) 
                                            {
                                                <MudItem class="d-flex flex-column justify-center justify-align-center">
                                                    <MudAlert Severity="Severity.Info">
                                                        <MudText Style="font-weight: bold;">Please Select One Superior First...</MudText>
                                                    </MudAlert>
                                                </MudItem>
                                            }
                                            else
                                            {
                                                @switch (_user.UserType)
                                                {
                                                    case 1:
                                                        @if (SeniorsSupervisors?.Count > 0)
                                                        {
                                                            <MudItem class="d-flex flex-column justify-center">
                                                                <MudAlert Severity="Severity.Info">
                                                                    <MudText Style="font-weight: bold;">Please add SSV subordinated...</MudText>
                                                                </MudAlert>
                                                            </MudItem>
                                                        }
                                                        else
                                                        {
                                                            <MudItem class="d-flex flex-column justify-center">
                                                                <MudAlert Severity="Severity.Info">
                                                                    <MudText Style="font-weight: bold;">This plant does not have SSV...</MudText>
                                                                </MudAlert>
                                                            </MudItem>
                                                        }
                                                        break;
                                                    case 2:
                                                        @if (Supervisors?.Count > 0)
                                                        {
                                                            @if(_user.Areas?.Count > 0){
                                                                <MudItem class="d-flex flex-column justify-center">
                                                                <MudAlert Severity="Severity.Info">
                                                                    <MudText Style="font-weight: bold;">Please add Supervisor subordinated...</MudText>
                                                                </MudAlert>
                                                            </MudItem>
                                                            }else{
                                                                <MudItem class="d-flex flex-column justify-center">
                                                                    <MudAlert Severity="Severity.Info">
                                                                        <MudText Style="font-weight: bold;">Please add areas to manage.....</MudText>
                                                                    </MudAlert>
                                                                </MudItem>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <MudItem class="d-flex flex-column justify-center">
                                                                <MudAlert Severity="Severity.Info">
                                                                    <MudText Style="font-weight: bold;">This plant does not have Supervisors...</MudText>
                                                                </MudAlert>
                                                            </MudItem>
                                                        }
                                                        break;
                                                    case 3:
                                                        @if (Operators?.Count > 0)
                                                        {
                                                            @if (_user.Superior != null)
                                                            {
                                                                <MudItem class="d-flex flex-column justify-center">
                                                                    <MudAlert Severity="Severity.Info">
                                                                        <MudText Style="font-weight: bold;">Please add Operator subordinated...</MudText>
                                                                    </MudAlert>
                                                                </MudItem>
                                                            }
                                                            else
                                                            {
                                                                <MudItem class="d-flex flex-column justify-center">
                                                                    <MudAlert Severity="Severity.Info">
                                                                        <MudText Style="font-weight: bold;">Please Select Superior first.....</MudText>
                                                                    </MudAlert>
                                                                </MudItem>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <MudItem class="d-flex flex-column justify-center">
                                                                <MudAlert Severity="Severity.Info">
                                                                    <MudText Style="font-weight: bold;">This plant / area does not have Operators...</MudText>
                                                                </MudAlert>
                                                            </MudItem>
                                                        }
                                                        break;
                                                }
                                            }
                                            break;
                                        case 0:
                                            <MudText Style="font-weight: bold;">Caso 0... Plant:{@auxPlant}</MudText>

                                            @if (auxPlant == 0 && _user.UserType > 2)
                                            {
                                                <MudItem class="d-flex flex-column justify-center justify-align-center">
                                                    <MudAlert Severity="Severity.Info">
                                                        <MudText Style="font-weight: bold;">Please Select One Superior First...</MudText>
                                                    </MudAlert>
                                                </MudItem>
                                            }
                                            else
                                            {
                                                @switch (_user.UserType)
                                                {
                                                    case 1:
                                                        @if (SeniorsSupervisors?.Count > 0)
                                                        {
                                                            <MudItem class="d-flex flex-column justify-center">
                                                                <MudAlert Severity="Severity.Info">
                                                                    <MudText Style="font-weight: bold;">Please add SSV subordinated...</MudText>
                                                                </MudAlert>
                                                            </MudItem>
                                                        }
                                                        else
                                                        {
                                                            <MudItem class="d-flex flex-column justify-center">
                                                                <MudAlert Severity="Severity.Info">
                                                                    <MudText Style="font-weight: bold;">This plant does not have SSV...</MudText>
                                                                </MudAlert>
                                                            </MudItem>
                                                        }
                                                        break;
                                                    case 2:
                                                        @if (Supervisors?.Count > 0)
                                                        {
                                                            @if (_user.Areas?.Count > 0)
                                                            {
                                                                <MudItem class="d-flex flex-column justify-center">
                                                                    <MudAlert Severity="Severity.Info">
                                                                        <MudText Style="font-weight: bold;">Please add Supervisor subordinated...</MudText>
                                                                    </MudAlert>
                                                                </MudItem>
                                                            }
                                                            else
                                                            {
                                                                <MudItem class="d-flex flex-column justify-center">
                                                                    <MudAlert Severity="Severity.Info">
                                                                        <MudText Style="font-weight: bold;">Please add areas to manage.....</MudText>
                                                                    </MudAlert>
                                                                </MudItem>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <MudItem class="d-flex flex-column justify-center">
                                                                <MudAlert Severity="Severity.Info">
                                                                    <MudText Style="font-weight: bold;">This plant does not have Supervisors...</MudText>
                                                                </MudAlert>
                                                            </MudItem>
                                                        }
                                                        break;
                                                    case 3:
                                                        @if (Operators?.Count > 0)
                                                        {
                                                            @if (_user.Superior != null)
                                                            {
                                                                <MudItem class="d-flex flex-column justify-center">
                                                                    <MudAlert Severity="Severity.Info">
                                                                        <MudText Style="font-weight: bold;">Please add Operator subordinated...</MudText>
                                                                    </MudAlert>
                                                                </MudItem>
                                                            }
                                                            else
                                                            {
                                                                <MudItem class="d-flex flex-column justify-center">
                                                                    <MudAlert Severity="Severity.Info">
                                                                        <MudText Style="font-weight: bold;">Please Select Superior first.....</MudText>
                                                                    </MudAlert>
                                                                </MudItem>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <MudItem class="d-flex flex-column justify-center">
                                                                <MudAlert Severity="Severity.Info">
                                                                    <MudText Style="font-weight: bold;">This plant does not have Operators...</MudText>
                                                                </MudAlert>
                                                            </MudItem>
                                                        }
                                                        break;
                                                }
                                            }
                                            break;
                                        default:
                                    @if (_user.Subordinates is not null && _user.Subordinates?.ToList().Count > 0 )
                                            {
                                                <MudItem class="d-flex d-flex-column justify-center">
                                                    @foreach (var item in _user.Subordinates)
                                                    {
                                                        <MudCard Elevation="1" Class="mr-5" Style="width: 300px; flex: 0 0 calc(28%-1rem);">
                                                            <MudCardHeader>
                                                                <CardHeaderContent>
                                                                    <MudText Typo="Typo.subtitle1"></MudText>
                                                                </CardHeaderContent>
                                                                <CardHeaderActions>
                                                                    @switch (_user.UserType)
                                                                    {
                                                                        case 1:
                                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteSeniorSupervisorFromSubordinateList(item))" />
                                                                            break;
                                                                        case 2:
                                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteSupervisorFromSubordinateList(item))" />
                                                                            break;
                                                                        case 3:
                                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteOperatorFromSubordinateList(item))" />
                                                                            break;
                                                                    }
                                                                </CardHeaderActions>
                                                            </MudCardHeader>
                                                            <MudCardContent>
                                                                <div class="font-weight-bold"> <MudText Typo="Typo.subtitle2"> Name:</MudText> @item.Name </div>
                                                                <div class="font-weight-light"><MudText Typo="Typo.subtitle2"> Group:</MudText> @item.Group?.Description </div>
                                                            </MudCardContent>
                                                            <div class="d-flex justify-content-between justify-center">
                                                                @switch (item.UserType)
                                                                {
                                                                    case 1:
                                                                        <MudPaper Elevation="0">
                                                                            <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary"> Admin </MudChip>
                                                                        </MudPaper>
                                                                        break;
                                                                    case 2:
                                                                        <MudPaper Elevation="0">
                                                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"> Senior Supervisor </MudChip>
                                                                        </MudPaper>
                                                                        break;
                                                                    case 3:
                                                                        <MudPaper Elevation="0">
                                                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"> Supervisor </MudChip>
                                                                        </MudPaper>
                                                                        break;
                                                                    case 4:
                                                                        <MudPaper Elevation="0">
                                                                            <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark"> Operator </MudChip>
                                                                        </MudPaper>
                                                                        break;
                                                                }
                                                            </div>
                                                            <MudCardActions>

                                                            </MudCardActions>
                                                        </MudCard>
                                                    }
                                                </MudItem>
                                            }
                                            break;
                                    }
                                </MudItem>


                                @*Seccion de Selector Subordinados *@
                                <MudItem class="d-flex d-flex-column justify-center ma-1">

                                    <MudItem Class="d-flex d-flex-row">
                                        @switch (_user.UserType)
                                        {
                                            case 1:
                                                @if (SeniorsSupervisors?.Count > 0)
                                                {
                                                    <MudSelect T="User" Label="Senior Supervisors" SelectedValuesChanged="OnSelectedSubordinatedFunction" Placeholder="Select SSV" @bind-Value="@selectedSeniorSupervisorOfList" For="@(() => selectedSeniorSupervisorOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                                        <MudSelectItem Disabled="true" Value="selectedSeniorSupervisorOfList"> Select a subordinate SSV </MudSelectItem>
                                                        @foreach (var SS in SeniorsSupervisors)
                                                        {
                                                            @if (LogedUser.UserType == 1)
                                                            {
                                                                <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}") </MudSelectItem>
                                                            }
                                                            else
                                                            {
                                                                @if (_user.Areas?.ToList().FindIndex(a => a.AreaId == SS.AreaId) != -1)
                                                                {
                                                                    <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}") </MudSelectItem>
                                                                }
                                                            }
                                                        }
                                                    </MudSelect>
                                                    <MudButton Disabled="@ActiveAddSubordinated" OnClick="@(() => AddSeniorSupervisorToSubordinateList(selectedSeniorSupervisorOfList))" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" IconColor="Color.Secondary" Size="Size.Large"> Add subordinate </MudButton>
                                                }
                                                break;
                                            case 2:
                                                @if (Supervisors?.Count > 0 && _user.Areas?.Count > 0)
                                                {
                                                    <MudSelect T="User" Label="Supervisors" SelectedValuesChanged="OnSelectedSubordinatedFunction" Placeholder="Select Supervisor" @bind-Value="@selectedSupervisorOfList" For="@(() => selectedSupervisorOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                                        <MudSelectItem Disabled="true" Value="selectedSupervisorOfList"> Select a subordinate Supervisor </MudSelectItem>
                                                        @foreach (var SS in Supervisors)
                                                        {
                                                            @if (LogedUser.UserType == 1)
                                                            {
                                                                <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}") </MudSelectItem>
                                                            }
                                                            else
                                                            {
                                                                @if (_user.Areas?.ToList().FindIndex(a => a.AreaId == SS.AreaId) != -1)
                                                                {
                                                                    <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}") </MudSelectItem>
                                                                }
                                                            }
                                                        }
                                                    </MudSelect>
                                                    <MudButton Disabled="@ActiveAddSubordinated" OnClick="@(() => AddSupervisorToSubordinateList(selectedSupervisorOfList))" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" IconColor="Color.Secondary" Size="Size.Large"> Add subordinate </MudButton>
                                                }
                                                break;
                                            case 3:
                                                @if (Operators?.Count > 0 && auxPlant != 0)
                                                {
                                                    <MudSelect T="User" Label="Operators" SelectedValuesChanged="OnSelectedSubordinatedFunction" Placeholder="Select Supervisor" @bind-Value="@selectedOperatorOfList" For="@(() => selectedOperatorOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                                        <MudSelectItem Disabled="true" Value="selectedOperatorOfList"> Select an Operator</MudSelectItem>
                                                        @foreach (var SS in Operators)
                                                        {
                                                            @if (LogedUser.UserType == 1)
                                                            {
                                                                <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description} - {SS.Distribution?.Description}") </MudSelectItem>
                                                            }
                                                            else
                                                            {
                                                                @if (_user.Areas?.ToList().FindIndex(a => a.AreaId == SS.AreaId) != -1)
                                                                {
                                                                    <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description} - {SS.Distribution?.Description}") </MudSelectItem>
                                                                }
                                                            }
                                                        }
                                                    </MudSelect>
                                                    <MudButton Disabled="@ActiveAddSubordinated" OnClick="@(() => AddOperatorToSubordinateList(selectedOperatorOfList))" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" IconColor="Color.Secondary" Size="Size.Large"> Add subordinate </MudButton>
                                                }
                                                break;
                                        }
                                    </MudItem>

                                </MudItem>
                            </MudItem>
                        }

                        @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_user.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@

                    </MudCardContent>
                    <MudCardActions>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Create User</MudButton>
                        <MudButton Href="/usersmanagement" Variant="Variant.Filled" Class="ml-4">Cancel Creation</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>


@code {
    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "#"),
            new BreadcrumbItem("Configuration", href: "/configuration"),
            new BreadcrumbItem("Users", href: "/usersmanagement"),
            new BreadcrumbItem("Create Users", href: "", disabled: true),
        };

    public IMask emailMask = RegexMask.Email();

    private User _user = new User();
    private User selectedSeniorSupervisorOfList = new User();
    private User selectedSupervisorOfList = new User();
    private User selectedOperatorOfList = new User();
    private Area selectedAreaOfList = new Area();

    private List<User> _allUsers = new List<User>();
    private List<User> SeniorsSupervisors = new List<User>();
    private List<User> Supervisors = new List<User>();
    private List<User> Operators = new List<User>();

    List<Plant> _plants { get; set; } = new();
    List<Area> _areas = new();
    List<Area> _areasManager = null;
    List<Distribution> _distributions = new();
    List<Group> _groups { get; set; } = new();

    private string json = string.Empty;
    public User LogedUser = new();

    //auxdistribution no null

    private int auxPlant = 0;
    private int auxArea = 0;
    private int auxDistribution = 0;
    private int auxGroup = 0;

    private bool superior = false;

    //Var aux para controlar los switch de permisos
    private bool IsAdmin = false;
    private bool IsSeniorSupervisor = false;
    private bool IsSupervisor = false;
    private bool IsOperator = false;

    //Var On/Off Button Add
    private bool ActiveAddArea = true;
    private bool ActiveAddSubordinated = true;

    //aux strings show info
    private string plantInfo = "Please Select One Superior First";
    private string areaInfo = "Please Select One Superior First";
    private string grupInfo = "Please Select One Superior First";


    protected async override Task OnInitializedAsync()
    {
        json = await JS.InvokeAsync<string>("localStorage.getItem", "user");
        LogedUser = JsonSerializer.Deserialize<User>(json) ?? new();

        _plants = await PlantServices.GetPlants();
        _groups = await GroupServices.GetGroups();
        _allUsers = await UserServices.GetUsersWhitCollections();
    }

    private async void ShowAreasInvokeByPlantSelector()
    {
        SeniorsSupervisors.Clear();
        Supervisors.Clear();
        Operators.Clear();
        if (LogedUser.UserType != 1)
        {
            //Se muestra usuarios en base a la planta
            foreach (User item in _allUsers)
            {
                switch (item.UserType)
                {
                    case 2:
                        if (item.PlantId == auxPlant)
                            SeniorsSupervisors.Add(item);
                        break;
                    case 3:
                        if (item.PlantId == auxPlant)
                            Supervisors.Add(item);
                        break;
                    case 4:
                        //if (item.PlantId == auxPlant)
                            //Operators.Add(item);
                        break;
                }
            }
        }
        else
        {
            //El admin accesa a todo
            foreach (User item in _allUsers)
            {
                switch (item.UserType)
                {
                    case 2:
                        SeniorsSupervisors.Add(item);
                        break;
                    case 3:
                        Supervisors.Add(item);
                        break;
                    case 4:
                        Operators.Add(item);
                        break;
                }
            }
        }

        auxArea = 0;
        auxDistribution = 0;

        if (auxPlant != 0)
        {
            _user.Subordinates?.Clear();
            _user.Areas?.Clear();

            _areas.Clear();
            _areasManager?.Clear();
            _areas = await AreaServices.GetAreas(auxPlant);
            _areasManager = await AreaServices.GetAreas(auxPlant);
        }



        if (auxPlant != 0 && auxArea != 0)
        {
            ShowDistributionInvokeByAreasSelector();
        }

        StateHasChanged();
    }

    private async void ShowDistributionInvokeByAreasSelector()
    {
        _user.DistributionId = 0;
        Operators.Clear();


        foreach (User item in _allUsers)
        {
            if (item.AreaId == auxArea && item.PlantId == auxPlant)
                Operators.Add(item);
        }

        if (auxPlant != 0 && auxArea != 0)
        {
            _distributions = await DistributionsServices.GetDistributions(auxPlant, auxArea);
        }

    }




    private async void OnSelectedAreaToManageFunction()
    {
        if (selectedAreaOfList != new Area())
        {
            ActiveAddArea = false;

        }
        else
        {
            ActiveAddArea = true;
        }
    }


    private async void OnSelectedSubordinatedFunction()
    {

        if (selectedSupervisorOfList != new User() || selectedSeniorSupervisorOfList != new User() || selectedOperatorOfList != new User())
        {
            ActiveAddSubordinated = false;
        }
        else
        {
            ActiveAddSubordinated = true;
        }

    }



    private void setActiveUser(int switchNumber)
    {
        IsAdmin = switchNumber == 1 && !IsAdmin;
        IsSeniorSupervisor = switchNumber == 2 && !IsSeniorSupervisor;
        IsSupervisor = switchNumber == 3 && !IsSupervisor;
        IsOperator = switchNumber == 4 && !IsOperator;

        _user.UserType = !IsAdmin && !IsSeniorSupervisor && !IsSupervisor && !IsOperator ? 0 : switchNumber;

        if (switchNumber == 1 || switchNumber == 2)
        {
            RemoveSuperiorUser();
        }

        if (switchNumber >= 3 && LogedUser.UserType != 1)
        {
            auxPlant = (int)LogedUser.PlantId;
            auxArea = (int)LogedUser.AreaId;
            auxGroup = (int)LogedUser.GroupId;

            _user.SuperiorId = LogedUser.UserId;
            _user.Superior = LogedUser;
            superior = true;

            _user.PlantId = _user.Superior?.PlantId;
            _user.AreaId = _user.Superior?.AreaId;
            _user.GroupId = _user.Superior?.GroupId;

            plantInfo = _user.Superior?.Plant?.Description;
            areaInfo = _user.Superior?.Area?.Description;
            grupInfo = _user.Superior?.Group?.Description;
        }
        else
        {
            auxPlant = 0;
            auxArea = 0;
            _user.GroupId = 0;
        }

        _user.Subordinates?.Clear();
        _user.Areas?.Clear();

        ShowAreasInvokeByPlantSelector();

        StateHasChanged();
    }

    private void SetSuperiorToUser()
    {
        _user.SuperiorId = _user.Superior.SuperiorId;
        superior = true;


        //Idemtificar user
        switch (_user.UserType)
        {
            case 2: break;
            case 3: 
                _user.PlantId =  _user.Superior?.PlantId;
                _user.GroupId =  _user.Superior?.GroupId;

                auxPlant =  (int)_user.Superior?.PlantId;
                auxGroup = (int)_user.Superior?.GroupId;

                plantInfo = _user.Superior?.Plant?.Description;
                grupInfo = _user.Superior?.Group?.Description;

                break;
            case 4: 
                _user.PlantId =  _user.Superior?.PlantId;
                //agrega el area
                _user.GroupId =  _user.Superior?.GroupId;

                auxPlant =  (int)_user.Superior?.PlantId;
                //agrega el area
                auxGroup = (int)_user.Superior?.GroupId;

                plantInfo = _user.Superior?.Plant?.Description;
                //agrega el area
                grupInfo = _user.Superior?.Group?.Description;
                break;
        }


        StateHasChanged();
    }

    private void RemoveSuperiorUser()
    {
        _user.SuperiorId = null;
        _user.Superior = null;
        superior = false;

        switch(LogedUser.UserType){
            case 2:
            plantInfo = "";
            grupInfo = "";
            break;
        }

        StateHasChanged();

    }

    private void DeleteAreaFromUserList(Area element)
    {
        _user.Areas.Remove(element);
        _areasManager.Add(element);
        StateHasChanged();
    }


    private void AddAreaToUserList(Area selection)
    {
        if (_user.Areas == null)
        {
            _user.Areas = new List<Area>();
        }

        if (selectedAreaOfList != null && !_user.Areas.Contains(selection))
        {
            _user.Areas.Add(selection);

            _areasManager.Remove(selection);
            //reset value from selector
            selectedAreaOfList = null;
            ActiveAddArea = true;
        }


        StateHasChanged();
    }


    private void DeleteSeniorSupervisorFromSubordinateList(User selection)
    {
        _user.Subordinates?.Remove(selection);
        SeniorsSupervisors.Add(selection);
        StateHasChanged();
    }

    private void AddSeniorSupervisorToSubordinateList(User selection)
    {
        if (_user.Subordinates == null)
        {
            _user.Subordinates = new List<User>();
        }


        if (selectedSeniorSupervisorOfList != null && !_user.Subordinates.Contains(selection))
        {
            _user.Subordinates.Add(selection);
            SeniorsSupervisors.Remove(selection);
            selectedSeniorSupervisorOfList = null;
            ActiveAddSubordinated = true;
        }
        StateHasChanged();
    }


    private void DeleteSupervisorFromSubordinateList(User selection)
    {
        _user.Subordinates?.Remove(selection);
        Supervisors.Add(selection);
        StateHasChanged();
    }

    private void AddSupervisorToSubordinateList(User selection)
    {
        if (_user.Subordinates == null)
        {
            _user.Subordinates = new List<User>();
        }


        if (selectedSupervisorOfList != null && !_user.Subordinates.Contains(selection))
        {



            _user.Subordinates.Add(selection);

            Supervisors.Remove(selection);

            selectedSupervisorOfList = null;
            ActiveAddSubordinated = true;
        }
        StateHasChanged();
    }

    private void DeleteOperatorFromSubordinateList(User selection)
    {
        _user.Subordinates.Remove(selection);
        Operators.Add(selection);
        StateHasChanged();
    }

    private void AddOperatorToSubordinateList(User selection)
    {
        if (_user.Subordinates == null)
        {
            _user.Subordinates = new List<User>();
        }


        if (selectedOperatorOfList != null && !_user.Subordinates.Contains(selection))
        {
            _user.Subordinates.Add(selection);

            Operators.Remove(selection);

            selectedOperatorOfList = null;
            ActiveAddSubordinated = true;
        }
        StateHasChanged();
    }

    private async void CreateUser()
    {
        _user.IsActive = true;
        _user.CreatedDate = DateTime.Now;
        _user.LastUpdated = DateTime.Now;

        _user.PlantId = auxPlant;
        _user.AreaId = auxArea;
        _user.DistributionId = auxDistribution;
        _user.GroupId = auxGroup;


        var result = await UserServices.CreateUser(_user);
        if (result != null)
            NavigationManager.NavigateTo("/usersmanagement");
        else
            await JS.InvokeVoidAsync("alert", "Error, on create user please call your admin!"); // Alert
    }


}
