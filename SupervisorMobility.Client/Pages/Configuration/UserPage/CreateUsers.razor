@page "/usersmanagement/CreateUser"
@using SupervisorMobility.Client.Data
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage
@inject IFileUploadAndDownloadService FileUpDoServices
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionsServices
@inject IUserService UserServices
@inject IGroupService GroupServices
@inject IDepartmentService DepartmentService
@inject IHCIService HCIServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IStringLocalizer<Resource1> Localizer
@inject GlobalDataService GlobalData;

@using System.ComponentModel.DataAnnotations
@using SupervisorMobility.Client.Pages.Configuration.UserPage.Create_Forms

<style>
    .dialog { backdrop-filter: blur(10px); }
</style>

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["UsersCreateTitle"]</PageTitle>
@*Breadcrumb links*@
@*<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>*@

<MudContainer>

    @*Form*@
    <EditForm Model="_user" OnValidSubmit="CreateUser">
        <DataAnnotationsValidator />
        <MudGrid>
            <MudItem xs="12" >
                <MudCard >
                    <MudCardHeader >
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="ml-10 mt-5">@Localizer["UsersCreateTitle"]</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip Variant="Variant.Text" Color="Color.Success" Class="mr-10">@Localizer["UsersNew"]</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="ml-10 mr-10">

                        <MudItem>
                            <MudItem>
                                <MudText Typo="Typo.h6">@Localizer["UsersPermissions"]</MudText>
                            </MudItem>
                            <MudItem Class="d-flex flex-row flex-wrap align-center justify-center pa-2 ma-2">
                                @if (LogedUser.UserType <= 1)
                                {
                                    <MudSwitch Class="ma-1" Label="@Localizer["UsersAdmin"]" @bind-Checked="@IsAdmin" @onclick="@(() => setActiveUser(1))" Color="Color.Primary" UnCheckedColor="Color.Dark" />
                                    <MudSwitch Class="ma-1" Label="@Localizer["UsersManager"]" @bind-Checked="@IsManager" @onclick="@(() => setActiveUser(5))" Color="Color.Warning" UnCheckedColor="Color.Dark" />
                                    <MudSwitch Class="ma-1" Label="@Localizer["UsersRTC"]" @bind-Checked="@IsRTC" @onclick="@(() => setActiveUser(8))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                                    <MudSwitch Class="ma-1" Label="@Localizer["UsersSeniorSupervisor"]" @bind-Checked="@IsSeniorSupervisor" @onclick="@(() => setActiveUser(2))" Color="Color.Secondary" UnCheckedColor="Color.Dark" />
                                }
                                @if (LogedUser.UserType <= 2)
                                {
                                    <MudSwitch Class="ma-1" Label="@Localizer["UsersSupervisor"]" @bind-Checked="@IsSupervisor" @onclick="@(() => setActiveUser(3))" Color="Color.Secondary" UnCheckedColor="Color.Dark" />
                                }
                                <MudSwitch Class="ma-1" Label="@Localizer["UsersOperator"]" @bind-Checked="@IsOperator" @onclick="@(() => setActiveUser(4))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                                <MudSwitch Class="ma-1" Label="@Localizer["lineSupport"]" @bind-Checked="@IsLineSupport" @onclick="@(() => setActiveUser(6))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                                <MudSwitch Class="ma-1" Label="@Localizer["headCount"]" @bind-Checked="@IsHeadCount" @onclick="@(() => setActiveUser(7))" Color="Color.Info" UnCheckedColor="Color.Dark" />
                            </MudItem>
                            <MudItem class="d-flex d-flex-column justify-center mb-3">
                                @switch (_user.UserType)
                                {
                                    case 1:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary">@Localizer["UsersAdmin"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 2:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSeniorSupervisor"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 3:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer["UsersSupervisor"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 4:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">@Localizer["UsersOperator"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 5:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Warning">@Localizer["UsersManager"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 6:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.Engineering" Color="Color.Info">@Localizer["lineSupport"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 7:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.PermContactCalendar" Color="Color.Info">@Localizer["headCount"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 8:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.Accessibility" Color="Color.Info">@Localizer["UsersRTC"]</MudChip>
                                        </MudPaper>
                                        break;
                                }
                            </MudItem>

                        </MudItem>

                        @switch(_user.UserType)
                        {
                            case 1:
                            case 6:
                            case 7:
                            case 8:
                                <GeneralUserForm _user="_user" OnUserChanged="CreateUser"/>
                                break;
                            case 2:
                                <SeniorSupervisorForm _user="_user" LogedUser="LogedUser" _allUsers="_allUsers" _distributions="_distributions" _plants="_plants" _groups="_groups" _areas="_areas" _areasManager="_areasManager" Managers="Managers" SeniorsSupervisors="SeniorsSupervisors" Supervisors="Supervisors" Operators="Operators" OnUserChanged="OnFormSubmit" />
                                break;
                            case 3:
                                <SupervisorForm _user="_user" LogedUser="LogedUser" _departments="_deparments" _distributions="_distributions" _areasManager="_areasManager" SeniorsSupervisors="SeniorsSupervisors" Supervisors="Supervisors" Operators="Operators" OnUserChanged="OnFormSubmit" />
                                break;
                            case 4:
                                <OperatorForm _user="_user" LogedUser="LogedUser" _deparments="_deparments" _distributions="_distributions" _areas="_areas" _areasManager="_areasManager" Supervisors="Supervisors" OnUserChanged="OnFormSubmit" />
                                break;
                            case 5:
                                <ManagerForm _user="_user" LogedUser="LogedUser" _allUsers="_allUsers" _plants="_plants" SeniorsSupervisors="SeniorsSupervisors" OnUserChanged="OnFormSubmit" />
                                break;
                        }

                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>

@code {
    private List<BreadcrumbItem> _links;


    private User _user = new User();
    private User selectedSeniorSupervisorOfList = new User();
    private User selectedSupervisorOfList = new User();
    private User selectedOperatorOfList = new User();
    private Area selectedAreaOfList = new Area();

    private List<User> _allUsers = new List<User>();
    private List<User> SeniorsSupervisors = new List<User>();
    private List<User> Supervisors = new List<User>();
    private List<User> Operators = new List<User>();
    private List<User> Managers = new List<User>();

    List<Plant> _plants { get; set; } = new();
    List<Department> _deparments { get; set; } = new List<Department>();
    List<Area> _areas = new();
    List<Area> _areasManager = null;
    List<Distribution> _distributions = new();
    List<Group> _groups { get; set; } = new();

    public List<UpdateAreasForSuperiorDto>? _subordinatesToUpdate = null;

    private string json = string.Empty;
    public User LogedUser = new();

    //auxdistribution no null

    private int auxPlant = 0;
    private int auxArea = 0;
    private int auxDepa = 0;
    private int auxDistribution = 0;
    private int auxGroup = 0;

    private bool superior = false;

    //Var aux para controlar los switch de permisos
    private bool IsAdmin = false;
    private bool IsSeniorSupervisor = false;
    private bool IsSupervisor = false;
    private bool IsOperator = false;
    private bool IsManager = false;
    private bool IsLineSupport = false;
    private bool IsHeadCount = false;
    private bool IsRTC = false;


    //Var On/Off Button Add
    private bool ActiveAddArea = true;
    private bool ActiveAddSubordinated = true;

    //aux strings show info
    private string plantInfo = "First select a superior";
    private string areaInfo = "First select a superior";
    private string grupInfo = "First select a superior";

    public Data.Entities.HCI _hci = new ();

    protected async override Task OnInitializedAsync()
    {
        _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem(text:@Localizer["home"] , href: "/"),
            new BreadcrumbItem(text: @Localizer["configuration"], href: "/configuration"),
            new BreadcrumbItem(text: @Localizer["UsersTitle"], href: "/usersmanagement"),
            new BreadcrumbItem(text: @Localizer["UsersNew"], href: "", disabled: true),
        };
        json = await JS.InvokeAsync<string>("localStorage.getItem", "user");
        LogedUser = JsonSerializer.Deserialize<User>(json) ?? new();
        StateHasChanged();

        _plants = await PlantServices.GetPlants();
        _groups = await GroupServices.GetGroups();
        _allUsers = await UserServices.GetUsers(true, false);
        _deparments = await DepartmentService.GetDepartments();
    }

    private async void ShowAreasInvokeByPlantSelector()
    {
        SeniorsSupervisors.Clear();
        Supervisors.Clear();
        Operators.Clear();
        //if (LogedUser.UserType != 1)
        //{
        //    //Se muestra usuarios en base a la planta
        //    foreach (User item in _allUsers)
        //    {
        //        switch (item.UserType)
        //        {
        //            case 2:


        //                //if (item.PlantId == auxPlant){
        //                //    SeniorsSupervisors.Add(item);
        //                //}

        //                break;
        //            case 3:

        //                if (item.PlantId == auxPlant)
        //                    Supervisors.Add(item);
        //                break;
        //            case 4:

        //                //if (item.PlantId == auxPlant)
        //                //    Operators.Add(item);
        //                break;
        //        }
        //    }
        //}
        //else
        //{
        //El admin accesa a todo
        await SegregateAllUsers(_allUsers);
        //}

        auxArea = 0;
        auxDistribution = 0;

        if (auxPlant != 0)
        {
            _user.Subordinates?.Clear();
            _user.Areas?.Clear();

            _areas.Clear();
            _areasManager?.Clear();
            _areas = await AreaServices.GetAreas(auxPlant);
            _areasManager = await AreaServices.GetAreas(auxPlant);
        }



        if (auxPlant != 0 && auxArea != 0)
        {
            ShowDistributionInvokeByAreasSelector();
        }

        StateHasChanged();
    }

    private async Task SegregateAllUsers(List<User> users)
    {
        foreach (User item in users)
        {
            switch (item.UserType)
            {
                case 2:
                    if(LogedUser.UserType == 1){
                        SeniorsSupervisors.Add(item);
                    }
                    else if(item.PlantId == auxPlant){
                        SeniorsSupervisors.Add(item);
                    }
                    break;
                case 3:
                    Supervisors.Add(item);
                    break;
                case 4:
                    Operators.Add(item);
                    break;
                case 5:
                    Managers.Add(item);
                    break;
            }
        }        
    }

    private async void ShowDistributionInvokeByAreasSelector()
    {
        _user.DistributionId = 0;
        Operators.Clear();

        // Filtrar operadores que tengan el área en su colección Areas o en AreaId (compatibilidad)
        foreach (User item in _allUsers)
        {
            if (item.UserType == 4 && item.PlantId == auxPlant && item.GroupId == auxGroup)
            {
                // Verificar si tiene el área en Areas collection o en AreaId
                bool hasArea = (item.Areas != null && item.Areas.Any(a => a.AreaId == auxArea)) || 
                               item.AreaId == auxArea;
                if (hasArea)
                    Operators.Add(item);
            }
        }

        if (auxPlant != 0 && auxArea != 0)
        {
            _distributions = await DistributionsServices.GetDistributions(auxPlant, auxArea);
        }
        StateHasChanged();
    }

    private async void OnSelectedAreaToManageFunction()
    {
        if (selectedAreaOfList != new Area())
        {
            ActiveAddArea = false;

        }
        else
        {
            ActiveAddArea = true;
        }
    }


    private async void OnSelectedSubordinatedFunction()
    {

        if (selectedSupervisorOfList != new User() || selectedSeniorSupervisorOfList != new User() || selectedOperatorOfList != new User())
        {
            ActiveAddSubordinated = false;
        }
        else
        {
            ActiveAddSubordinated = true;
        }

    }

    private async Task setActiveUser(int userType)
    {
        _user = new();
        auxPlant = 0;
        auxArea = 0;
        auxGroup = 0;
        auxDistribution = 0;
        plantInfo = "";
        areaInfo = "";
        grupInfo = "";
        selectedSeniorSupervisorOfList = new User();
        selectedSupervisorOfList = new User();
        selectedOperatorOfList = new User();
        selectedAreaOfList = new Area();


        IsAdmin = userType == 1 && !IsAdmin;
        IsSeniorSupervisor = userType == 2 && !IsSeniorSupervisor;
        IsSupervisor = userType == 3 && !IsSupervisor;
        IsOperator = userType == 4 && !IsOperator;
        IsManager = userType == 5 && !IsManager;
        IsLineSupport = userType == 6 && !IsLineSupport;
        IsHeadCount = userType == 7 && !IsHeadCount;
        IsRTC = userType == 8 && !IsRTC;

        _user.UserType = !IsAdmin && !IsSeniorSupervisor && !IsSupervisor && !IsOperator && !IsManager && !IsLineSupport && !IsHeadCount && !IsRTC ? 0 : userType;


        ShowAreasInvokeByPlantSelector();

        switch (userType)
        {
            case 1: RemoveSuperiorUser(); break;
            case 2: RemoveSuperiorUser(); break;
            case 3: 
                if(LogedUser.UserType == 2){
                    _user.SuperiorId = LogedUser.UserId;
                    _user.Superior = LogedUser;
                    superior = true;
                    _user.PlantId =  _user.Superior?.PlantId;
                    _user.GroupId =  _user.Superior?.GroupId;

                    auxPlant =  (int)_user.Superior?.PlantId;
                    auxGroup = (int)_user.Superior?.GroupId;

                    plantInfo = _user.Superior?.Plant?.Description;
                    grupInfo = _user.Superior?.Group?.Description;
                    
                    // Supervisor usará Areas collection, no AreaId singular
                    // Cargar áreas del SSV logueado
                    if(LogedUser.Areas != null && LogedUser.Areas.Count > 0) {
                        _areasManager = LogedUser.Areas.ToList();
                    } else if(auxPlant != 0) {
                        _areasManager = await AreaServices.GetAreas(auxPlant);
                    }

                }
                else
                {
                    auxPlant = 0;
                    auxArea = 0;
                    _user.GroupId = 0;
                }
                break;
            case 4:
                if(LogedUser.UserType == 3){
                    _user.SuperiorId = LogedUser.UserId;
                    _user.Superior = LogedUser;
                    superior = true;

                    _user.PlantId = _user.Superior?.PlantId;
                    _user.GroupId = _user.Superior?.GroupId;

                    auxPlant = (int)_user.Superior?.PlantId;
                    auxGroup = (int)_user.Superior?.GroupId;

                    plantInfo = _user.Superior?.Plant?.Description;
                    grupInfo = _user.Superior?.Group?.Description;
                    
                    // Operator usará Areas collection del Supervisor
                    // Cargar áreas del SV logueado
                    if(LogedUser.Areas != null && LogedUser.Areas.Count > 0) {
                        _areasManager = LogedUser.Areas.ToList();
                    } else if(auxPlant != 0) {
                        _areasManager = await AreaServices.GetAreas(auxPlant);
                    }
                }
                else{
                    auxPlant = 0;
                    auxArea = 0;
                    auxDepa = 0;
                    _user.GroupId = 0;
                }
                break;
            case 5: RemoveSuperiorUser(); break;
            case 6: RemoveSuperiorUser(); break;
            case 7: RemoveSuperiorUser(); break;
            case 8: RemoveSuperiorUser(); break;

        }


        StateHasChanged();
    }

    private async Task SetSuperiorToUser()
    {
        _user.SuperiorId = _user.Superior.SuperiorId;
        superior = true;


        //Idemtificar user
        switch (_user.UserType)
        {
            case 2: break;
            case 3: 
                _user.PlantId =  _user.Superior?.PlantId;
                _user.GroupId =  _user.Superior?.GroupId;

                auxPlant =  (int)_user.Superior?.PlantId;
                auxGroup = (int)_user.Superior?.GroupId;

                plantInfo = _user.Superior?.Plant?.Description;
                grupInfo = _user.Superior?.Group?.Description;
                
                // Cargar áreas disponibles basadas en el superior (SSV)
                if(auxPlant != 0) {
                    _areasManager?.Clear();
                    if(_user.Superior.Areas != null && _user.Superior.Areas.Count > 0) {
                        // Usar las áreas del superior
                        _areasManager = _user.Superior.Areas.ToList();
                    } else {
                        // Si el superior no tiene áreas, cargar todas de la planta
                        _areasManager = await AreaServices.GetAreas(auxPlant);
                    }
                }

                break;
            case 4: 
                _user.PlantId =  _user.Superior?.PlantId;
                _user.GroupId =  _user.Superior?.GroupId;

                auxPlant =  (int)_user.Superior?.PlantId;
                auxGroup = (int)_user.Superior?.GroupId;

                plantInfo = _user.Superior?.Plant?.Description;
                grupInfo = _user.Superior?.Group?.Description;
                
                // Cargar áreas disponibles basadas en el superior (Supervisor)
                if(auxPlant != 0) {
                    _areasManager?.Clear();
                    if(_user.Superior.Areas != null && _user.Superior.Areas.Count > 0) {
                        // Usar las áreas del superior
                        _areasManager = _user.Superior.Areas.ToList();
                    } else {
                        // Si el superior no tiene áreas, cargar todas de la planta
                        _areasManager = await AreaServices.GetAreas(auxPlant);
                    }
                }
                break;
        }


        StateHasChanged();
    }

    private void RemoveSuperiorUser()
    {
        auxDistribution = 0;
        _distributions = new();
        _user.SuperiorId = null;
        _user.Superior = null;
        superior = false;

        switch(LogedUser.UserType){
            case 1:
            case 2:
            case 5:
            case 6:
            case 7:
            case 8:
                areaInfo = "";
                plantInfo = "";
                grupInfo = "";
                break;
        }

        StateHasChanged();

    }

    private void DeleteAreaFromUserList(Area element)
    {
        _user.Areas.Remove(element);
        _areasManager.Add(element);
        StateHasChanged();
    }


    private void AddAreaToUserList(Area selection)
    {
        if (_user.Areas == null)
        {
            _user.Areas = new List<Area>();
        }

        if (selectedAreaOfList != null && !_user.Areas.Contains(selection))
        {
            _user.Areas.Add(selection);

            _areasManager.Remove(selection);
            //reset value from selector
            selectedAreaOfList = null;
            ActiveAddArea = true;
        }


        StateHasChanged();
    }


    private void DeleteSeniorSupervisorFromSubordinateList(User selection)
    {
        _user.Subordinates?.Remove(selection);
        SeniorsSupervisors.Add(selection);
        StateHasChanged();
    }

    private void AddSeniorSupervisorToSubordinateList(User selection)
    {
        if (_user.Subordinates == null)
        {
            _user.Subordinates = new List<User>();
        }


        if (selectedSeniorSupervisorOfList != null && !_user.Subordinates.Contains(selection))
        {
            _user.Subordinates.Add(selection);
            SeniorsSupervisors.Remove(selection);
            selectedSeniorSupervisorOfList = null;
            ActiveAddSubordinated = true;
        }
        StateHasChanged();
    }


    private void DeleteSupervisorFromSubordinateList(User selection)
    {
        _user.Subordinates?.Remove(selection);
        Supervisors.Add(selection);
        StateHasChanged();
    }

    private void AddSupervisorToSubordinateList(User selection)
    {
        if (_user.Subordinates == null)
        {
            _user.Subordinates = new List<User>();
        }


        if (selectedSupervisorOfList != null && !_user.Subordinates.Contains(selection))
        {



            _user.Subordinates.Add(selection);

            Supervisors.Remove(selection);

            selectedSupervisorOfList = null;
            ActiveAddSubordinated = true;
        }
        StateHasChanged();
    }

    private void DeleteOperatorFromSubordinateList(User selection)
    {
        _user.Subordinates.Remove(selection);
        Operators.Add(selection);
        StateHasChanged();
    }

    private void AddOperatorToSubordinateList(User selection)
    {
        if (_user.Subordinates == null)
        {
            _user.Subordinates = new List<User>();
        }


        if (selectedOperatorOfList != null && !_user.Subordinates.Contains(selection))
        {
            _user.Subordinates.Add(selection);

            Operators.Remove(selection);

            selectedOperatorOfList = null;
            ActiveAddSubordinated = true;
        }
        StateHasChanged();
    }

    public void OnFormSubmit(UserManagmentFormDto result)
    {
        _user = result.User;
        _subordinatesToUpdate = result.Subordinates;

        CreateUser();
    }

    private async void CreateUser()
    {
        // Validar que UserType 2 (SSV), 3 (SV) y 4 (Operator) tengan áreas asignadas
        if((_user.UserType == 2 || _user.UserType == 3 || _user.UserType == 4) && (_user.Areas == null || _user.Areas.Count == 0)){
            Snackbar.Clear();
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Add($"{Localizer["UsersFirstArea"]}!", Severity.Warning);
            return;
        }
        
        if(_user.UserType == 4)
        {
            if(_user.Payroll.ToString() == null || _user.Payroll.ToString() == ""){
                Snackbar.Clear();
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
                Snackbar.Add($"{@Localizer["UsersFirstPayroll"]}!", Severity.Warning);
                return;
            }
            if (_user.Superior == null)
            {
                Snackbar.Clear();
                Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
                Snackbar.Add($"{@Localizer["UsersFirstSuperior"]}", Severity.Warning);
                return;
            }
        }

        // Llamar dialogo de confirmacion antes de realizar las acciones
        var dialogOptions = new DialogOptions() { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, DisableBackdropClick = true, ClassBackground = "dialog" };
        var dialogParameters = new DialogParameters
        {
            { "Title", Localizer["ConfirmationCreation"].Value },
            { "ContentText", Localizer["UsersCreateConfirmText"].Value },
            { "ButtonText", Localizer["ConfirmCreate"].Value },
            { "CancelText", Localizer["Cancel"].Value },
            { "Color", Color.Success },
            { "Icon", Icons.Material.Filled.PersonAdd },
            { "IconColor", Color.Info }
        };
        var dialog = await DialogService.ShowAsync<Confirmation>(Localizer["ConfirmationCreation"].Value, dialogParameters, dialogOptions);
        var dialogResult = await dialog.Result;

        if (dialogResult.Canceled)
               return; // Se cancela la creación

        _user.IsActive = true;
        _user.CreatedDate = DateTime.Now;
        _user.LastUpdated = DateTime.Now;

        if(_user.Superior != null)
        {
            _user.SuperiorId = _user.Superior.UserId;
        }

        var result = await UserServices.CreateUser(_user);
        if (result != null){
            Snackbar.Clear();
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Add($"User {_user.Name} Created Succesfully", Severity.Success);
            if(_user.UserType == 4 && LogedUser.UserType == 3){
                LogedUser = await UserServices.GetUserByObjectIdWithCollections(LogedUser.ObjectId);
                if(LogedUser != null)
                {
                    json = JsonSerializer.Serialize<User>(LogedUser);
                    await JS.InvokeVoidAsync("localStorage.setItem", "user", json);
                }
            }
            _hci.User = await UserServices.GetUser(result.UserId);
            _hci.UserId = result.UserId;

            if (await HCIServices.CreateHCI(_hci))
                Snackbar.Add("HCI Created succesfully", Severity.Success);
            else
                Snackbar.Add("Error", Severity.Error);
            GlobalData.NotifyNotificationsChanged(); // Trigger notification refresh

            // Try to update the subordinates areas if user has any Subordinate
            if(_subordinatesToUpdate != null && _subordinatesToUpdate.Count > 0)
            {
                _subordinatesToUpdate.ForEach(s => s.SuperiorId = result.UserId); // Colocar el ID obtenido del nuevo usuario al ser creado
                ServiceResponse<UpdateUsersAreasResult> updateResponse = await UserServices.UpdateUsersAreas(_subordinatesToUpdate);

                if(updateResponse.Success)
                    Snackbar.Add($"{updateResponse.Message}",(updateResponse.Data.Failed == 0 ? Severity.Success : Severity.Warning));
                else
                    Snackbar.Add($"{updateResponse.Message}", Severity.Error);

                if(updateResponse.Data.Failed > 0 && updateResponse.Data.Errors != null && updateResponse.Data.Errors.Count > 0)
                    foreach(var failed in updateResponse.Data.Errors)
                    {
                        Snackbar.Add($"User: {_allUsers.FirstOrDefault(u => u.UserId == failed.UserId)}. {failed.ErrorType}: {failed.ErrorMessage}", Severity.Error);
                    }
            }

            NavigationManager.NavigateTo("/usersmanagement");
        }
        else
            await JS.InvokeVoidAsync("alert", "Error, on create user please call your admin!"); // Alert
    }
}
