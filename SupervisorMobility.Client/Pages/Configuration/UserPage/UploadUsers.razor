@page "/usersmanagement/UploadUsers"

@using Microsoft.AspNetCore.Components.Forms;
@using MudBlazor;
@using System.Text.RegularExpressions;
@using ClosedXML.Excel;
@using System.Net.Http.Headers;
@using Microsoft.JSInterop;
@inject IFileUploadAndDownloadService FileUpDoServices
@inject IPlantService PlantsServices
@inject IAreaService AreasServices
@inject IGroupService GroupServices
@inject IUserService UsersServices

@*Title*@
<PageTitle>Supervisor Mobility | Upload Users</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>



<MudContainer Fixed="true" Class="py-3">
    <MudGrid>
        <MudItem xs="1" xl="1" class="align-center justify-center mud-width-full">
            <MudImage Src="Images/userup.png" Alt="Imagen Upload Clou" Height="120" Width="120"></MudImage>
        </MudItem>
        <MudItem id="Upload" xs="10" xl="10" class="d-flex flex-column">
            <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">

                <MudSpacer />
                <MudText Typo="Typo.h6">Upload Users</MudText>
                <MudSpacer />

            </MudItem>
            <MudItem Class="d-flex flex-column align-center justify-center">
                @*File Upload*@
                <MudItem Class="d-flex flex-column align-center justify-center mud-width-full">

                    <MudText Typo="Typo.h6" Color="Color.Info" Class="py-5">@ErrorMessageToDisplay </MudText>
                    @if(showResume)
                    {
                        <MudPaper Class="d-flex flex-row flex-grow-1 gap-4" Elevation="0">
                            <MudPaper Class="flex d-flex-row pa-16 ma-2" Elevation="3">
                                <MudItem style="text-align:center">
                                    <img src="Images/useradd.png" Height="100" Width="100" />
                                    <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Users Created: @commitUsersResult.UsersCreated </MudText>
                                </MudItem>
                            </MudPaper>
                            <MudPaper Class="flex d-flex-row pa-16 ma-2" Elevation="3">
                                <MudItem style="text-align:center">
                                    <img src="Images/userexist.png" Height="100" Width="100" />
                                    <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Users Exist: @commitUsersResult.UsersExist </MudText>
                                </MudItem>
                            </MudPaper>
                        </MudPaper>
                    }
                    else
                    {
                        if (activeUpload)
                        {
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                        }
                    }





                </MudItem>
                <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
                    <MudStack Style="width: 80%">
                        <MudFileUpload T="IReadOnlyList<IBrowserFile>" OnFilesChanged="OnInputFileChanged" Hidden="false" Class="flex-1" InputClass="absolute mud-width-full mud-height-full overflow-hidden z-20" InputStyle="opacity:0"
                                       @ondragenter="@SetDragClass" @ondragleave="@ClearDragClass" @ondragend="@ClearDragClass">
                            <ButtonTemplate Context="DragAndDrop">
                                <MudPaper Height="200px" Outlined="true" Class="@DragClass">
                                    <MudText Typo="Typo.h6">Drag and drop file Xlsx/CSV here or click</MudText>
                                    @foreach (var file in fileNames)
                                    {
                                        <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center">
                                            <MudText Typo="Typo.h6">@file.message</MudText>

                                            @switch (file.ftype)
                                            {
                                                case "xls":
                                                    <img src="Images/xls.png" Height="70" Width="70" />
                                                    break;
                                                case "csv":
                                                    <img src="Images/csv.png" Height="70" Width="70" />
                                                    break;
                                                default:
                                                    <img src="Images/error.png" Height="70" Width="70" />
                                                    break;
                                            }

                                            <MudChip Color="Color.Dark" Text="@file.name" />
                                        </MudItem>
                                    }
                                </MudPaper>
                            </ButtonTemplate>
                        </MudFileUpload>
                    </MudStack>
                </MudItem>
            </MudItem>
        </MudItem>
    </MudGrid>
</MudContainer>

<MudContainer Fixed="true" Class="py-10">
    <MudGrid Class="d-flex flex-column align-center justify-center">
        <MudItem Class="d-flex flex-column align-center justify-center">
            @if (showTableInUI)
            {
                <MudTable Items="@dataToShowInTable" T="User" HorizontalScrollbar="true" ReadOnly="true" FixedHeader=true Class="styled-table table-striped">
                    <ToolBarContent>
                        <MudSpacer />
                        <MudText Typo="Typo.h6">Data To Upload</MudText>
                        <MudSpacer />
                        <MudButton @onclick="(() => UploadFunction())" Disabled="@activeUpload">
                            <MudText>Upload users</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.UploadFile" aria-label="Upload" Color="Color.Primary"></MudIcon>
                        </MudButton>
                        <MudSpacer />
                        <MudButton @onclick="(() => CancelFunction())">
                            <MudText>Cancel Upload Users</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.Cancel" aria-label="Cancel" Color="Color.Warning"></MudIcon>
                        </MudButton>
                        <MudSpacer />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>User Name</MudTh>
                        <MudTh>User Payroll</MudTh>
                        <MudTh>Plant</MudTh>
                        <MudTh>Area</MudTh>
                        <MudTh>Grup</MudTh>
                        <MudTh>Permissions</MudTh>
                    </HeaderContent>
                    <RowTemplate>

                        <MudTd DataLabel=" Name">
                            <MudText Align="Align.Center">@context.Name?</MudText>
                        </MudTd>
                        <MudTd DataLabel="Payroll">
                            <MudText Align="Align.Center">@context.Payroll?</MudText>
                        </MudTd>
                        <MudTd DataLabel="Plant">
                            <MudText Align="Align.Center">@context.Plant?.Description</MudText>
                        </MudTd> <MudTd DataLabel="Area">
                            <MudText Align="Align.Center">@context.Area?.Description</MudText>
                        </MudTd> <MudTd DataLabel="Group">
                            <MudText Align="Align.Center">@context.Group?.Description</MudText>
                        </MudTd>
                        <MudTd DataLabel="Permissions">
                            <MudText Align="Align.Center">
                                @if(context.IsAdmin){
                                <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary">Admin</MudChip>

                                }

                                @if(context.IsSupervisor){
                                    <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">Supervisor</MudChip>

                                }

                                @if(context.IsOperator){
                                    <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">Operator</MudChip>

                                }


                            </MudText>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            }
        </MudItem>
    </MudGrid>
</MudContainer>
<MudSpacer></MudSpacer>






@code {

    private static string DefaultDragClass = "d-flex flex-column align-center justify-center relative rounded-lg border-2 border-dashed pa-4 mt-4 mud-width-full mud-height-full z-10";
    private string DragClass = DefaultDragClass;
    private List<FileToDisplay> fileNames = new List<FileToDisplay>();

    private class FileToDisplay
    {
        public string name { get; set; }
        public string ftype { get; set; }
        public string message { get; set; }
    }

    private string FileName;

    private string ErrorMessageToDisplay;
    private string FileErrorMesage;
    private IBrowserFile? FileSource;
    private bool ToCreate = false;

    private bool showResume = false;
    private bool activeUpload = false;
    private bool showTableInUI = false;
    private List<string[]> DataInDocument = new List<string[]>();
    private List<User> dataToShowInTable = new();

    private FileUpload uploadResult = new();
    private UsersUploadResult commitUsersResult = new();

    private List<Plant> _plants = new List<Plant>();
    private List<List<Area>> _areas = new List<List<Area>>();
    private List<Data.Entities.Group> _groups = new List<Data.Entities.Group>();


    protected async override Task OnInitializedAsync()
    {
        _plants = await PlantsServices.GetPlants();

        foreach (var item in _plants)
        {
            _areas.Add(await AreasServices.GetAreas(item.PlantId));
        }

        _groups = await GroupServices.GetGroups();
    }

    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "#"),
            new BreadcrumbItem("Configuration", href: "/configuration"),
            new BreadcrumbItem("Users", href: "/usersmanagement"),
            new BreadcrumbItem("Upload Users", href: "", disabled: true),
        };



    private async void OnInputFileChanged(InputFileChangeEventArgs e)
    {
        await Clear();

        FileName = e.File.Name;

        System.Text.RegularExpressions.Regex fileExtentionExcel = new System.Text.RegularExpressions.Regex(@".+\.xls", System.Text.RegularExpressions.RegexOptions.Compiled);
        System.Text.RegularExpressions.Regex fileExtentionCSV = new System.Text.RegularExpressions.Regex(@".+\.csv", System.Text.RegularExpressions.RegexOptions.Compiled);

        if (!fileExtentionExcel.IsMatch(FileName) && !fileExtentionCSV.IsMatch(FileName))
        {
            fileNames.Add(new FileToDisplay() { name = FileName, ftype = "otro", message = "This not a XLSX/csv file " });
            FileErrorMesage = "This not a XLSX/CSV File";
            FileName = string.Empty;
            FileSource = null;
            ToCreate = false;
        }
        else
        {

            FileErrorMesage = string.Empty;
            FileSource = e.File;
            ToCreate = true;


            var fileContent = new StreamContent(FileSource.OpenReadStream(FileSource.Size));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(FileSource.ContentType);

            MemoryStream ms = new MemoryStream();
            await fileContent.CopyToAsync(ms);
            var outputFileString = System.Text.Encoding.UTF8.GetString(ms.ToArray());
            bool isOkFile = false;

            if (fileExtentionCSV.IsMatch(e.File.Name))
            {
                foreach (var item in outputFileString.Split(Environment.NewLine))
                {
                    var addtolist = SplitCSV(item.ToString());


                    if (!addtolist.All(string.IsNullOrWhiteSpace))
                    {
                        DataInDocument.Add(addtolist);
                    }

                }

                //DataInDocument.RemoveAt(1);
                fileNames.Add(new FileToDisplay() { name = FileName, ftype = "csv" });

            }

            if (fileExtentionExcel.IsMatch(FileName))
            {
                try
                {
                    DataInDocument = await GetDataTableFromExcel(e.File);
                    isOkFile = true;
                    fileNames.Add(new FileToDisplay() { name = FileName, ftype = "xls" });

                }
                catch (Exception ex)
                {
                    Console.WriteLine(ex.ToString());
                }
            }

            showTableInUI = true;

            foreach (string[] row in DataInDocument)
            {
                Console.WriteLine("Linea");

                foreach (var item in row)
                {
                    Console.WriteLine(item);
                }
            }


            foreach (string[] row in DataInDocument)
            {
                try
                {
                    var ToInsertIntoList = new User();
                    ToInsertIntoList.UserId = row[0] != "" ? int.Parse(row[0]) : -1;
                    ToInsertIntoList.Payroll = row[1] != "" ? int.Parse(row[1]) : -1;
                    if (ToInsertIntoList.Payroll == -1)
                    {
                        showTableInUI = false;

                        ErrorMessageToDisplay = "Document Incomplet fields in Payroll";
                        break;
                    }

                    ToInsertIntoList.Name = row[2] != "" ? row[2] : "";
                    if (ToInsertIntoList.Name == "")
                    {
                        showTableInUI = false;

                        ErrorMessageToDisplay = "Document Incomplet fields in Name";
                        break;
                    }


                    ToInsertIntoList.PlantId = row[3] != "" ? int.Parse(row[3]) : -1;
                    ToInsertIntoList.AreaId = row[4] != "" ? int.Parse(row[4]) : -1;
                    ToInsertIntoList.GroupId = row[5] != "" ? int.Parse(row[5]) : -1;

                    ToInsertIntoList.IsAdmin = row[6] != "" ? bool.Parse(row[6]) : false;
                    ToInsertIntoList.IsSupervisor = row[7] != "" ? bool.Parse(row[7]) : false;
                    ToInsertIntoList.IsOperator = row[8] != "" ? bool.Parse(row[8]) : false;

                    try
                    {
                        ToInsertIntoList.CreatedDate = row[9] != "" ? DateTime.Parse(row[9]) : DateTime.Now;

                    }
                    catch (Exception ex)
                    {
                        ToInsertIntoList.CreatedDate = DateTime.Now;

                    }

                    try
                    {
                        ToInsertIntoList.LastUpdated = row[10] != "" ? DateTime.Parse(row[10]) : DateTime.Now;


                    }
                    catch (Exception ex)
                    {
                        ToInsertIntoList.LastUpdated = DateTime.Now;

                    }

                    try
                    {
                        ToInsertIntoList.DisabledDate = row[11] != "" ? DateTime.Parse(row[11]) : DateTime.Now;

                    }
                    catch (Exception ex)
                    {
                        ToInsertIntoList.DisabledDate = DateTime.Now;

                    }


                    ToInsertIntoList.IsActive = row[12] != "" ? bool.Parse(row[12]) : true;

                    try
                    {
                        ToInsertIntoList.Plant = _plants.Find(e => e.PlantId == ToInsertIntoList.PlantId);
                        ToInsertIntoList.Area = _areas[_plants.FindIndex(e => e.PlantId == ToInsertIntoList.PlantId)].Find(a => a.AreaId == ToInsertIntoList.AreaId);
                        ToInsertIntoList.Group = _groups.Find(g => g.GroupId == ToInsertIntoList.GroupId);
                    }
                    catch (Exception ex)
                    {
                        showTableInUI = false;
                        if (ToInsertIntoList.AreaId == -1)
                        {
                            ErrorMessageToDisplay = "Document Incomplet fields in Area";
                        }

                        if (ToInsertIntoList.PlantId == -1)
                        {
                            ErrorMessageToDisplay = "Document Incomplet fields in Plant";
                        }

                        if (ToInsertIntoList.GroupId == -1)
                        {
                            ErrorMessageToDisplay = "Document Incomplet fields in Group";
                        }
                        Console.WriteLine($"{ex.Message}");
                    }

                    dataToShowInTable.Add(ToInsertIntoList);


                }
                catch (Exception ex)
                {

                    Console.WriteLine($"{ex.Message}");
                    showTableInUI = false;
                }
            }
        }

        StateHasChanged();
    }

    public static async Task<List<string[]>> GetDataTableFromExcel(IBrowserFile file)
    {
        List<string[]> DataToReturn = new List<string[]>();
        List<string> RowsInFile = new List<string>();
        using (MemoryStream memStream = new MemoryStream())
        {
            await file.OpenReadStream(file.Size).CopyToAsync(memStream);
            using (XLWorkbook workBook = new XLWorkbook(memStream, XLEventTracking.Disabled))
            {
                //Read the first Sheet from Excel file.
                IXLWorksheet workSheet = workBook.Worksheet(1);

                workSheet.Column("A").Style.Font.Underline = XLFontUnderlineValues.Single;
                workSheet.Column("J").Style.Font.Underline = XLFontUnderlineValues.Single;
                workSheet.Column("K").Style.Font.Underline = XLFontUnderlineValues.Single;
                workSheet.Column("L").Style.Font.Underline = XLFontUnderlineValues.Single;
                bool firstRow = true;
                //Loop through the Worksheet rows.
                foreach (IXLRow row in workSheet.Rows())
                {
                    if (firstRow)
                    {
                        firstRow = false;
                    }
                    else
                    {
                        if (!row.IsEmpty())
                        {
                            RowsInFile.Clear();

                            foreach (IXLCell cell in row.Cells())
                            {
                                string toinsert = cell.Value.ToString();

                                RowsInFile.Add(toinsert);
                            }
                            DataToReturn.Add(RowsInFile.ToArray());
                        }
                    }

                }
            }
        }
        return DataToReturn;
    }

    private string[] SplitCSV(string input)
    {
        //Excludes commas within quotes
        System.Text.RegularExpressions.Regex csvSplit = new System.Text.RegularExpressions.Regex("(?:^|,)(\"(?:[^\"]+|\"\")*\"|[^,]*)", System.Text.RegularExpressions.RegexOptions.Compiled);
        List<string> list = new List<string>();
        string curr = string.Empty;
        foreach (System.Text.RegularExpressions.Match match in csvSplit.Matches(input))
        {
            curr = match.Value;
            if (0 == curr.Length) list.Add("");

            list.Add(curr.TrimStart(','));
        }
        list.RemoveAt(0);

        return list.ToArray();
    }

    void CancelFunction()
    {
        FileName = string.Empty;
        ErrorMessageToDisplay = string.Empty;
        DataInDocument.Clear();
        dataToShowInTable.Clear();
        showTableInUI = false;
        FileSource = null;
    }

    private async Task Clear()
    {
        fileNames.Clear();
        dataToShowInTable.Clear();
        ClearDragClass();
        activeUpload = false;
        showTableInUI = false;
        DataInDocument.Clear();
        await Task.Delay(100);
    }

    private void SetDragClass()
    {
        DragClass = $"{DefaultDragClass} mud-border-primary";
    }

    private void ClearDragClass()
    {
        DragClass = DefaultDragClass;
    }

    async void UploadFunction()
    {
        activeUpload = true;
        using var content = new MultipartFormDataContent();

        if (FileSource is not null)
        {

            var fileContent = new StreamContent(FileSource.OpenReadStream(FileSource.Size));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(FileSource.ContentType);

            content.Add(
            content: fileContent,
            name: "\"file\"",
            fileName: FileSource.Name);

            var fileUploadResult = await FileUpDoServices.UploadUsers(content);

            if (fileUploadResult is not null)
            {
                uploadResult = fileUploadResult;

                UsersUploadResult newDataResults = await UsersServices.ProccedToUploadUsers(uploadResult);

                if (newDataResults is not null)
                {
                    //tiene resultados
                    ErrorMessageToDisplay = "Upload Data Succesfull";


                    showResume = true;
                    FileSource = null;
                    await Clear();
                    commitUsersResult = newDataResults;

                    base.StateHasChanged();

                }
                else
                {
                    ErrorMessageToDisplay = "Fail, Upload Data, pls Call for admin";
                }

            }
            else
            {
                //error al subir el archivo
            }

        }
        else
        {
            ErrorMessageToDisplay = "Fail, Upload Data, pls Call for admin";
        }



    }



}
