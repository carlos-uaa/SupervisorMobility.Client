@page "/usersmanagement/UploadUsers"

@using Microsoft.AspNetCore.Components.Forms;
@using MudBlazor;
@using System.Text.RegularExpressions;
@using ClosedXML.Excel;
@using System.Net.Http.Headers;
@using Microsoft.JSInterop;
@inject IFileUploadAndDownloadService FileUpDoServices
@inject IPlantService PlantsServices
@inject IAreaService AreasServices
@inject IGroupService GroupServices
@inject IUserService UsersServices

@*Title*@
<PageTitle>Supervisor Mobility | Upload Users</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>



<MudContainer Fixed="true" Class="py-3">
    <MudGrid>
        <MudItem xs="1" xl="1" class="align-center justify-center mud-width-full">
            <MudImage Src="Images/userup.png" Alt="Imagen Upload Clou" Height="120" Width="120"></MudImage>
        </MudItem>
        <MudItem id="Upload" xs="9" xl="9" class="d-flex flex-column">
            <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">

                <MudSpacer />
                <MudText Typo="Typo.h6">Upload Users</MudText>
                <MudSpacer />

            </MudItem>
            <MudItem Class="d-flex flex-column align-center justify-center">
                @*File Upload*@

                <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
                    @*All Upload*@

                    <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="All Type Users" OnClick="() => AssignType(1)">

                        <MudItem Class="d-flex flex-column align-center justify-center mud-width-full">

                            <MudText Typo="Typo.h6" Color="Color.Info" Class="py-5">@ErrorMessageToDisplay </MudText>
                            @if (showResume)
                            {
                                <MudPaper Class="d-flex flex-row flex-grow-1 gap-4" Elevation="0">
                                    <MudPaper Class="flex d-flex-row pa-16 ma-2" Elevation="3">
                                        <MudItem style="text-align:center">
                                            <img src="Images/useradd.png" Height="100" Width="100" />
                                            <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Users Created: @commitUsersResult.UsersCreated </MudText>
                                        </MudItem>
                                    </MudPaper>
                                    <MudPaper Class="flex d-flex-row pa-16 ma-2" Elevation="3">
                                        <MudItem style="text-align:center">
                                            <img src="Images/userexist.png" Height="100" Width="100" />
                                            <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Users Exist: @commitUsersResult.UsersExist </MudText>
                                        </MudItem>
                                    </MudPaper>
                                </MudPaper>
                            }
                            else
                            {
                                if (activeUpload)
                                {
                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                }
                            }


                            @if (onloadfile)
                            {
                                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                            }


                        </MudItem>
                    </MudTabPanel>
                    @*SSV Upload*@

                    <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Upload SSV's" OnClick="() => AssignType(2)">

                    </MudTabPanel>
                    @*SUPERVISORS Upload*@
                    <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Upload Supervisors" OnClick="() => AssignType(3)">
                        <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
                            @*Add To SSV Upload*@
                            <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Supervisors" OnClick="() => AssignType(3)">
                            </MudTabPanel>
                            @*Add Supervisors to SSV*@
                            <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Add To SSV's" OnClick="() => AssignType(4)">

                                <MudSelect T="User" Label="SSV" Placeholder="Select SSV" @bind-Value="@selectedSSVOfList" For="@(() => selectedSSVOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                    <MudSelectItem Disabled="true" Value="selectedSSVOfList"> Select a SSV  </MudSelectItem>
                                    @foreach (var SS in _allUsers)
                                    {
                                        @if (SS.UserType == 2)
                                        {
                                            <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}") </MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudTabPanel>
                        </MudTabs>
                    </MudTabPanel>
                    @*Operators Upload Upload*@
                    <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Upload Operators" OnClick="() => AssignType(5)">
                        <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
                            @*Add Operators Upload*@
                            <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Operators" OnClick="() => AssignType(5)">
                            </MudTabPanel>
                            @*Add Supervisors to SSV*@
                            <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Add To Supervisor" OnClick="() => AssignType(6)">

                                <MudSelect T="User" Label="Supervisors" Placeholder="Select Supervisor" @bind-Value="@selectedSupervisorOfList" For="@(() => selectedSupervisorOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                    <MudSelectItem Disabled="true" Value="selectedSupervisorOfList"> Select a Supervisor </MudSelectItem>
                                    @foreach (var SS in _allUsers)
                                    {
                                        @if (SS.UserType == 3)
                                        {
                                            <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}") </MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudTabPanel>
                        </MudTabs>


                    </MudTabPanel>
                </MudTabs>
            </MudItem>
        </MudItem>
        <MudItem xs="2" xl="2" class="align-center justify-center mud-width-full">
            @switch (uploadtype)
            {
                case 1:
                    <MudButton OnClick="DownloadAllFormat"
                       Target="_blank"
                       Variant="Variant.Outlined"
                       EndIcon="@Icons.Material.Filled.FileDownload"
                       Color="Color.Primary" FullWidth="true">
                        <b>All Upload Format</b>
                    </MudButton>
                    break;
                case 2:
                    <MudButton OnClick="DownloadSSVFormat"
                       Target="_blank"
                       Variant="Variant.Outlined"
                       EndIcon="@Icons.Material.Filled.FileDownload"
                       Color="Color.Primary" FullWidth="true">
                        <b>SSV Format</b>
                    </MudButton>
                    break;
                case 3:
                case 4:
                    <MudButton OnClick="DownloadSupervisorsFormat"
                       Target="_blank"
                       Variant="Variant.Outlined"
                       EndIcon="@Icons.Material.Filled.FileDownload"
                       Color="Color.Primary" FullWidth="true">
                        <b>Supervisors Format</b>
                    </MudButton>
                    break;
                case 5:
                case 6:
                    <MudButton OnClick="DownloadOperatorsFormat"
                       Target="_blank"
                       Variant="Variant.Outlined"
                       EndIcon="@Icons.Material.Filled.FileDownload"
                       Color="Color.Primary" FullWidth="true">
                        <b>Operators Format</b>
                    </MudButton>
                    break;
            }
        </MudItem>


    </MudGrid>
</MudContainer>

@*Unique File Uploader*@
<MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
    <MudStack Style="width: 80%">
        <MudFileUpload T="IReadOnlyList<IBrowserFile>" OnFilesChanged="OnInputFileChanged" Hidden="false" Class="flex-1" InputClass="absolute mud-width-full mud-height-full overflow-hidden z-20" InputStyle="opacity:0"
                       @ondragenter="@SetDragClass" @ondragleave="@ClearDragClass" @ondragend="@ClearDragClass">
            <ButtonTemplate Context="DragAndDrop">
                <MudPaper Height="200px" Outlined="true" Class="@DragClass">
                    <MudText Typo="Typo.h6">Drag and drop file Xlsx/CSV here or click</MudText>
                    @foreach (var file in fileNames)
                    {
                        <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center">
                            <MudText Typo="Typo.h6">@file.message</MudText>

                            @switch (file.ftype)
                            {
                                case "xls":
                                    <img src="Images/xls.png" Height="70" Width="70" />
                                    break;
                                case "csv":
                                    <img src="Images/csv.png" Height="70" Width="70" />
                                    break;
                                default:
                                    <img src="Images/error.png" Height="70" Width="70" />
                                    break;
                            }

                            <MudChip Color="Color.Info" Text="@file.name" />
                        </MudItem>
                    }
                </MudPaper>
            </ButtonTemplate>
        </MudFileUpload>
    </MudStack>
</MudItem>


@*Tabla unica para cualquier tipo de usuario *@
<MudContainer Fixed="true" Class="py-10">
    <MudGrid Class="d-flex flex-column align-center justify-center">
        <MudItem Class="d-flex flex-column align-center justify-center">
            @if (showTableInUI)
            {
                <MudTable Items="@dataToShowInTable" T="User" HorizontalScrollbar="true" ReadOnly="true" FixedHeader=true Class="styled-table table-striped">
                    <ToolBarContent>
                        <MudSpacer />
                        <MudText Typo="Typo.h6">Data To Upload</MudText>
                        <MudSpacer />
                        <MudButton @onclick="(() => UploadFunction())" Disabled="@activeUpload">
                            <MudText>Upload users</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.UploadFile" aria-label="Upload" Color="Color.Primary"></MudIcon>
                        </MudButton>
                        <MudSpacer />
                        <MudButton @onclick="(() => CancelFunction())">
                            <MudText>Cancel Upload Users</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.Cancel" aria-label="Cancel" Color="Color.Warning"></MudIcon>
                        </MudButton>
                        <MudSpacer />
                    </ToolBarContent>
                    <HeaderContent>

                        @if (uploadtype > 1 && uploadtype < 5)
                        {
                            <MudTh>Object Id</MudTh>
                        }

                        @if (uploadtype > 4)
                        {
                            <MudTh>Payroll</MudTh>
                        }

                        <MudTh>User Name</MudTh>



                        @if (uploadtype > 1 && uploadtype < 5)
                        {
                            <MudTh>Email</MudTh>
                        }

                        @if (uploadtype > 2)
                        {
                            <MudTh>Superior</MudTh>

                        }

                        <MudTh>Plant</MudTh>

                        @if (uploadtype > 1 && uploadtype < 3)
                        {
                            <MudTh>Areas Manage</MudTh>
                        }
                        else if (uploadtype > 2 && uploadtype < 5)
                        {
                            <MudTh>Assigned Area</MudTh>
                        }
                        else
                        {
                            <MudTh>Area</MudTh>
                        }


                        @if (uploadtype > 4)
                        {
                            <MudTh>Distribution</MudTh>
                        }


                        <MudTh>Group</MudTh>

                        @if (uploadtype == 1)
                        {
                            <MudTh>Role</MudTh>
                        }


                    </HeaderContent>
                    <RowTemplate>
                        @if (uploadtype > 1 && uploadtype < 5)
                        {
                            <MudTd DataLabel="ObjectId">
                                <MudText Align="Align.Center">@context.ObjectId</MudText>
                            </MudTd>
                        }

                        @if (uploadtype > 4)
                        {
                            <MudTd DataLabel="Payroll">
                                <MudText Align="Align.Center">@context.Payroll</MudText>
                            </MudTd>
                        }

                        <MudTd DataLabel=" Name">
                            <MudText Align="Align.Center">@context.Name</MudText>
                        </MudTd>

                        @if (uploadtype > 1 && uploadtype < 5)
                        {
                            <MudTd DataLabel="Email">
                                <MudText Align="Align.Center">@context.Email</MudText>
                            </MudTd>
                        }

                        @switch (uploadtype)
                        {
                            case 3:
                                @if (@context.Superior is null)
                                {
                                    <MudSelect T="User" Label="SSV" Placeholder="Select SSV" @bind-Value="@context.Superior" For="@(() => @context.Superior)" SelectedValuesChanged="@(() => UpdateContextItem(@context))"  Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                        <MudSelectItem Disabled="true" Value="@context.Superior"> Select a SSV  </MudSelectItem>
                                        @foreach (var SS in _allUsers)
                                        {
                                            @if (SS.UserType == 2)
                                            {
                                                <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}") </MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                }
                                else
                                {
                                    <MudTd DataLabel="Superior SSV">
                                        <MudText Align="Align.Center">@context.Superior?.Name</MudText>
                                    </MudTd>
                                }

                                break;
                            case 4:
                                <MudTd DataLabel="Superior SSV">
                                    <MudText Align="Align.Center">@selectedSSVOfList?.Name</MudText>
                                </MudTd>
                                break;
                            case 5:
                                <MudTd DataLabel="Superior Supervisor">
                                    <MudText Align="Align.Center">@context.Superior?.Name</MudText>
                                </MudTd>
                                break;
                            case 6:
                                <MudTd DataLabel="Superior SSV">
                                    <MudText Align="Align.Center">@context.Superior?.Name</MudText>

                                </MudTd>
                                break;

                        }

                        <MudTd DataLabel="Plant">
                            <MudText Align="Align.Center">@context.Plant?.Description</MudText>
                        </MudTd>

                        @if (uploadtype > 1 && uploadtype < 3)
                        {
                            <MudTd DataLabel="Area">
                                @if (context.Areas?.Count > 0)
                                {
                                    @foreach (var item in context.Areas)
                                    {
                                        <MudText Align="Align.Center">@item.Description</MudText>
                                    }
                                }

                            </MudTd>

                        }
                        else if (uploadtype > 2 && uploadtype < 5)
                        {
                            @if (context.Area != null)
                            {
                                <MudTd DataLabel="Assigned Area">
                                    <MudText Align="Align.Center">@context.Area?.Description</MudText>
                                </MudTd>
                            }
                            else
                            {
                                @if (@context.Superior is null)
                                {
                                    <MudTd DataLabel="Assigned Area">
                                        <MudText Align="Align.Center">Please Select a Superior</MudText>
                                    </MudTd>
                                }
                                else
                                {
                                    <MudTd DataLabel="Assigned Area">
                                        @if (_areas[_plants.FindIndex(e => e.PlantId == context.Superior.PlantId)] is not null)
                                        {
                                            <MudSelect T="Area" Label="SSV" Placeholder="Assign Area" @bind-Value="@context.Area" For="@(() => @context.Area)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter" >
                                                <MudSelectItem Disabled="true" Value="@context.Area"> Assign Area  </MudSelectItem>
                                                @foreach (var item in _areas[_plants.FindIndex(e => e.PlantId == context.Superior.PlantId)])
                                                {
                                                     <MudSelectItem Value="item">@($"{item.Code}-{item.Description}") </MudSelectItem>
                                                }
                                            </MudSelect>
                                        }
                                    </MudTd>
                                }

                            }
                        }
                        else
                        {
                            <MudTd DataLabel="Area">
                                <MudText Align="Align.Center">@context.Area?.Description</MudText>
                            </MudTd>
                        }

                        @if (uploadtype > 4)
                        {
                            <MudTd DataLabel="Distribution">
                                <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
                            </MudTd>
                        }


                        <MudTd DataLabel="Group">
                            <MudText Align="Align.Center">@context.Group?.Description</MudText>
                        </MudTd>

                        @if (uploadtype == 1)
                        {
                            <MudTd DataLabel="Permissions">
                                <MudText Align="Align.Center">
                                    @*@if(context.IsAdmin){
                            <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary">Admin</MudChip>

                            }

                            @if(context.IsSupervisor){
                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">Supervisor</MudChip>

                            }

                            @if(context.IsOperator){
                            <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">Operator</MudChip>

                            }*@


                                </MudText>
                            </MudTd>
                        }

                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            }
        </MudItem>
    </MudGrid>
</MudContainer>
<MudSpacer></MudSpacer>






@code {

    private static string DefaultDragClass = "d-flex flex-column align-center justify-center relative rounded-lg border-2 border-dashed pa-4 mt-4 mud-width-full mud-height-full z-10";
    private string DragClass = DefaultDragClass;
    private List<FileToDisplay> fileNames = new List<FileToDisplay>();

    private class FileToDisplay
    {
        public string name { get; set; }
        public string ftype { get; set; }
        public string message { get; set; }
    }


    private int uploadtype = 1;
    private string FileName;

    private string ErrorMessageToDisplay;
    private string FileErrorMesage;
    private IBrowserFile? FileSource;
    private bool ToCreate = false;
    private bool onloadfile = false;

    private bool showResume = false;
    private bool activeUpload = false;
    private bool showTableInUI = false;
    private List<string[]> DataInDocument = new List<string[]>();
    private List<User> dataToShowInTable = new();

    private FileUpload uploadResult = new();
    private UsersUploadResult commitUsersResult = new();

    private List<Plant> _plants = new List<Plant>();
    private List<List<Area>> _areas = new List<List<Area>>();
    private List<Data.Entities.Group> _groups = new List<Data.Entities.Group>();

    private List<User> _allUsers = new List<User>();
    private User selectedSSVOfList = new();
    private User selectedSupervisorOfList = new();
    protected async override Task OnInitializedAsync()
    {
        _plants = await PlantsServices.GetPlants();

        foreach (var item in _plants)
        {
            _areas.Add(await AreasServices.GetAreas(item.PlantId));
        }

        _groups = await GroupServices.GetGroups();

        _allUsers = await UsersServices.GetUsersWhitCollections();
    }

    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "#"),
            new BreadcrumbItem("Configuration", href: "/configuration"),
            new BreadcrumbItem("Users", href: "/usersmanagement"),
            new BreadcrumbItem("Upload Users", href: "", disabled: true),
        };


    private async void AssignType(int value)
    {
        uploadtype = value;
        await CancelFunction();
        StateHasChanged();
    }

    private void UpdateContextItem(User ItemContext)
    {
        ItemContext.PlantId = ItemContext.Superior?.PlantId;
        ItemContext.GroupId = ItemContext.Superior?.GroupId;

        ItemContext.Group = ItemContext.Superior?.Group;
        ItemContext.Plant = ItemContext.Superior?.Plant;

        StateHasChanged();
    }


    private async void OnInputFileChanged(InputFileChangeEventArgs e)
    {
        onloadfile = true;
        await Clear();

        FileName = e.File.Name;

        System.Text.RegularExpressions.Regex fileExtentionExcel = new System.Text.RegularExpressions.Regex(@".+\.xls", System.Text.RegularExpressions.RegexOptions.Compiled);
        System.Text.RegularExpressions.Regex fileExtentionCSV = new System.Text.RegularExpressions.Regex(@".+\.csv", System.Text.RegularExpressions.RegexOptions.Compiled);

        if (!fileExtentionExcel.IsMatch(FileName) && !fileExtentionCSV.IsMatch(FileName))
        {
            fileNames.Add(new FileToDisplay() { name = FileName, ftype = "otro", message = "This not a XLSX/csv file " });
            FileErrorMesage = "This not a XLSX/CSV File";
            FileName = string.Empty;
            FileSource = null;
            ToCreate = false;
        }
        else
        {

            FileErrorMesage = string.Empty;
            FileSource = e.File;
            ToCreate = true;


            var fileContent = new StreamContent(FileSource.OpenReadStream(FileSource.Size));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(FileSource.ContentType);

            MemoryStream ms = new MemoryStream();
            await fileContent.CopyToAsync(ms);
            var outputFileString = System.Text.Encoding.UTF8.GetString(ms.ToArray());
            bool isOkFile = false;

            if (fileExtentionCSV.IsMatch(e.File.Name))
            {
                foreach (var item in outputFileString.Split(Environment.NewLine))
                {
                    var addtolist = SplitCSV(item.ToString());


                    if (!addtolist.All(string.IsNullOrWhiteSpace))
                    {
                        DataInDocument.Add(addtolist);
                    }

                }

                //DataInDocument.RemoveAt(1);
                fileNames.Add(new FileToDisplay() { name = FileName, ftype = "csv" });

            }

            if (fileExtentionExcel.IsMatch(FileName))
            {
                try
                {
                    switch (uploadtype)
                    {
                        case 1:
                            DataInDocument = await GetDataTableFromExcel(e.File);
                            break;
                        case 2:
                            DataInDocument = await GetDataTableFromExcelSSV(e.File);
                            break;
                        case 3:
                        case 4:
                            DataInDocument = await GetDataTableFromExcelSupervisors(e.File);
                            break;
                        case 5:
                        case 6:
                            DataInDocument = await GetDataTableFromExcelOperators(e.File);
                            break;
                    }

                    isOkFile = true;
                    fileNames.Add(new FileToDisplay() { name = FileName, ftype = "xls" });

                }
                catch (Exception ex)
                {
                    Console.WriteLine(ex.ToString());
                }
            }

            switch (uploadtype)
            {
                case 1:
                    string[] lineall = DataInDocument[0];
                    if (lineall[0] != "UserId")
                    {
                        isOkFile = false;
                        showTableInUI = false;
                        ErrorMessageToDisplay = "This document does not belong to this section. ";
                    }else{
                        isOkFile = true;
                        dataToShowInTable = CreateUsersAllArray(DataInDocument);
                    } 
                    break;
                case 2:
                    string[] lineSSV = DataInDocument[0];
                    if (lineSSV[0] != "UserId SSV")
                    {
                        isOkFile = false;
                        showTableInUI = false;
                        ErrorMessageToDisplay = "This document does not belong to this section. ";
                    }
                    else
                    {
                        isOkFile = true;
                        dataToShowInTable = CreateUsersSSV(DataInDocument);
                    }
                    break;
                case 3:
                case 4:
                    string[] lineSup = DataInDocument[0];
                    if (lineSup[0] != "UserId Supervisor")
                    {
                        isOkFile = false;
                        showTableInUI = false;
                        ErrorMessageToDisplay = "This document does not belong to this section. ";
                    }
                    else
                    {
                        isOkFile = true;
                        dataToShowInTable = CreateUsersSupervisors(DataInDocument);
                    }
                    break;
                case 5:
                case 6:
                    string[] lineOpe = DataInDocument[0];
                    if (lineOpe[0] != "UserId Operator")
                    {
                        isOkFile = false;
                        showTableInUI = false;
                        ErrorMessageToDisplay = "This document does not belong to this section. ";
                    }
                    else
                    {
                        isOkFile = true;
                        dataToShowInTable = CreateUsersOperators(DataInDocument);
                    }
                    break;
            }

            if (isOkFile)
            {
                ErrorMessageToDisplay = "";
                showTableInUI = true;
            }
        }



        onloadfile = false;
        StateHasChanged();
    }

    public List<User> CreateUsersAllArray(List<string[]> DataInDocument)
    {
        List<User> ListtoReturn = new List<User>();
        foreach (string[] row in DataInDocument)
        {
            try
            {
                var ToInsertIntoList = new User();
                ToInsertIntoList.UserId = row[0] != "" ? int.Parse(row[0]) : -1;
                ToInsertIntoList.Payroll = row[1] != "" ? int.Parse(row[1]) : -1;
                if (ToInsertIntoList.Payroll == -1)
                {
                    showTableInUI = false;

                    ErrorMessageToDisplay = "Document Incomplet fields in Payroll";
                    break;
                }

                ToInsertIntoList.Name = row[2] != "" ? row[2] : "";
                if (ToInsertIntoList.Name == "")
                {
                    showTableInUI = false;

                    ErrorMessageToDisplay = "Document Incomplet fields in Name";
                    break;
                }


                ToInsertIntoList.PlantId = row[3] != "" ? int.Parse(row[3]) : -1;
                ToInsertIntoList.AreaId = row[4] != "" ? int.Parse(row[4]) : -1;
