@page "/usersmanagement/UploadUsers"

@using Microsoft.AspNetCore.Components.Forms;
@using MudBlazor;
@using System.Text.RegularExpressions;
@using ClosedXML.Excel;
@using System.Net.Http.Headers;
@using Microsoft.JSInterop;
@inject IFileUploadAndDownloadService FileUpDoServices
@inject IPlantService PlantsServices
@inject IAreaService AreasServices
@inject IDistributionService DistributionServices
@inject IGroupService GroupServices
@inject IUserService UsersServices
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject IStringLocalizer<Resource1> Localizer1
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<style>
    .mtc {
        overflow: hidden;
    }
</style>

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer1["UsersUploadTitle"]</PageTitle>
@*Breadcrumb links*@
@*<MudBreadcrumbs Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>*@


<MudContainer Class="d-flex flex-grow-1 gap-4 flex-row align-center justify-center py-3">

    <MudItem class="align-center justify-center">
        <MudImage Src="Images/userup.png" Alt="Imagen Upload Clou" Height="120" Width="120"></MudImage>
    </MudItem>
    <MudItem id="Upload" class="d-flex flex-column ma-5">
        <MudItem Class="d-flex flex-row align-center justify-center">
            <MudSpacer />
            <MudText Typo="Typo.h6">@Localizer1["UsersUploadTitle"]</MudText>
            <MudSpacer />
        </MudItem>


        @*ErrorMsg, Resume and animation Upload File*@
        <MudItem Class="d-flex flex-column align-center justify-center mud-width-full">

            <MudText Typo="Typo.h6" Color="Color.Info" Class="py-5">@ErrorMessageToDisplay </MudText>
            @if (showResume)
            {
                <MudPaper Class="d-flex flex-row flex-grow-1 gap-4" Elevation="0">
                    <MudPaper Class="flex d-flex-row pa-16 ma-2" Elevation="3">
                        <MudItem style="text-align:center">
                            <img src="Images/useradd.png" Height="100" Width="100" />
                            <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer1["UsersResumeCreated"]: @commitUsersResult.UsersCreated </MudText>
                        </MudItem>
                    </MudPaper>
                    <MudPaper Class="flex d-flex-row pa-16 ma-2" Elevation="3">
                        <MudItem style="text-align:center">
                            <img src="Images/userexist.png" Height="100" Width="100" />
                            <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer1["UsersResumeExist"]: @commitUsersResult.UsersExist </MudText>
                        </MudItem>
                    </MudPaper>
                    <MudPaper Class="flex d-flex-row pa-16 ma-2" Elevation="3">
                        <MudItem style="text-align:center">
                            <img src="Images/userupdate.png" Height="100" Width="100" />
                            <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer1["UsersResumeUpdate"]: @commitUsersResult.UsersUpdated </MudText>
                        </MudItem>
                    </MudPaper>
                </MudPaper>
            }
            else
            {
                if (activeUpload)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                }
            }


            @if (onloadfile)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
            }


        </MudItem>
        <MudItem Class="flex-grow-1 d-flex flex-column align-center justify-center my-3 ">

            @if (loggedUser.UserType == 1 || loggedUser.UserType == 5)
            {
            @*Principal TABS*@
                <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
                    @*All Upload*@

                    <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="@Localizer1["UsersAll"]" OnClick="() => AssignType(1)">
                    </MudTabPanel>
                    @*SSV Upload*@
                    <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="@Localizer1["UsersSSV"]" OnClick="() => AssignType(2)">

                    </MudTabPanel>

                    @*SUPERVISORS Upload*@
                    <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="@Localizer1["UsersSupervisors"]" OnClick="() => AssignType(3)">
                        <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
                            @*Add To SSV Upload*@
                            <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="@Localizer1["Supervisors"]" OnClick="() => AssignType(3)">
                            </MudTabPanel>
                            @*Add Supervisors to SSV*@
                            <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="@Localizer1["UsersAddToSsv"]" OnClick="() => AssignType(4)">

                                <MudSelect T="User" Label="@Localizer1["UsersLabelSSV"]" Placeholder="@Localizer1["UsersPHSSV"]" SelectedValuesChanged="@(() => UpdateSelectSSVforSupervisors())" @bind-Value="@selectedSSVOfList" For="@(() => selectedSSVOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                    <MudSelectItem Disabled="true" Value="selectedSSVOfList"> @Localizer1["UsersPHSSV"]</MudSelectItem>
                                    @foreach (var SS in _allUsers)
                                    {
                                        @if (SS.UserType == 2)
                                        {
                                            <MudSelectItem Value="SS">@(
                                                  $"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}"
                                                  ) </MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudTabPanel>
                        </MudTabs>
                    </MudTabPanel>
                    @*Operators Upload Upload*@
                    <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="@Localizer1["UsersOperators"]" OnClick="() => AssignType(5)">
                        <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
                            @*Add Operators Upload*@
                            <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="@Localizer1["UsersOperators"]" OnClick="() => AssignType(5)">
                            </MudTabPanel>
                            @*Add Supervisors to SSV*@
                            <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="@Localizer1["UsersAddToSV"]" OnClick="() => AssignType(6)">
                                <MudSelect T="User" Label="@Localizer1["UsersSupervisors"]" Placeholder="@Localizer1["UsersPHSV"]" SelectedValuesChanged="@(() => UpdateSelectSupervisorForOperators())" @bind-Value="@selectedSupervisorOfList" For="@(() => selectedSupervisorOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                    <MudSelectItem Disabled="true" Value="selectedSupervisorOfList"> @Localizer1["UsersPHSV"]</MudSelectItem>
                                    @foreach (var SS in _allUsers)
                                    {
                                        @if (SS.UserType == 3)
                                        {
                                            <MudSelectItem Value="SS">@(
                                                  $"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}"
                                                  ) </MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudTabPanel>
                        </MudTabs>
                    </MudTabPanel>
            </MudTabs>
            }
            else if(loggedUser.UserType == 3){
                <MudTabs Rounded="true" Color="@Color.Info" MinimumTabWidth="55vw">
                    @*Add Operators Upload*@
                    <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="@Localizer1["UsersOperators"]" OnClick="() => AssignType(5)">
                    </MudTabPanel>
                </MudTabs>
            }
        </MudItem>
    </MudItem>
    <MudItem class="align-center justify-center mud-width-full">
        @switch (uploadtype)
        {
            case 1:
                <MudButton OnClick="DownloadAllFormat"
                           Target="_blank"
                           Variant="Variant.Outlined"
                           EndIcon="@Icons.Material.Filled.FileDownload"
                           Color="Color.Primary"
                           Class="mb-2">
                    <b>@Localizer1["UsersAllFormat"]</b>
                </MudButton>

                <MudButton OnClick="DownloadAllExample"
                           Target="_blank"
                           Variant="Variant.Outlined"
                           EndIcon="@Icons.Material.Filled.FileDownload"
                           Color="Color.Primary">
                    <b>@Localizer1["UsersAllExampleFormat"]</b>
                </MudButton>
                break;
            case 2:
                <MudButton OnClick="DownloadSSVFormat"
                           Target="_blank"
                           Variant="Variant.Outlined"
                           EndIcon="@Icons.Material.Filled.FileDownload"
                           Color="Color.Primary"
                           Class="mb-2">
                    <b>@Localizer1["UsersSSVFormat"]</b>
                </MudButton>
                <MudButton OnClick="DownloadSSVExample"
                           Target="_blank"
                           Variant="Variant.Outlined"
                           EndIcon="@Icons.Material.Filled.FileDownload"
                           Color="Color.Primary">
                    <b>@Localizer1["UsersSSVExampleFormat"]</b>
                </MudButton>
                break;
            case 3:
            case 4:
                <MudButton OnClick="DownloadSupervisorsFormat"
                           Target="_blank"
                           Variant="Variant.Outlined"
                           EndIcon="@Icons.Material.Filled.FileDownload"
                           Color="Color.Primary"
                           Class="mb-2">
                    <b>@Localizer1["UsersSVFormat"]</b>
                </MudButton>

                <MudButton OnClick="DownloadSVExample"
                           Target="_blank"
                           Variant="Variant.Outlined"
                           EndIcon="@Icons.Material.Filled.FileDownload"
                           Color="Color.Primary">
                    <b>@Localizer1["UsersSVExFormat"]</b>
                </MudButton>
                break;
            case 5:
            case 6:
                <MudButton OnClick="DownloadOperatorsFormat"
                           Target="_blank"
                           Variant="Variant.Outlined"
                           EndIcon="@Icons.Material.Filled.FileDownload"
                           Color="Color.Primary" FullWidth="true" Class="mb-2">
                    <b>@Localizer1["UsersOPFormat"]</b>
                </MudButton>
                <MudButton OnClick="DownloadOperatorsExample"
                           Target="_blank"
                           Variant="Variant.Outlined"
                           EndIcon="@Icons.Material.Filled.FileDownload"
                           Color="Color.Primary">
                    <b>@Localizer1["UsersOPExampleFormat"]</b>
                </MudButton>
                break;
        }
    </MudItem>

</MudContainer>



@*File Upload*@
<MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
    <MudStack Style="width: 80%">
         @if (ShowLoading)
                    {
                        <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
                            <ItemTemplate>
                                <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                                    <MudItem class="d-flex flex-column justify-center align-self-center">
                                        <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                                    </MudItem>
                                    @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                                    <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
                                </div>
                            </ItemTemplate>
                        </MudCarousel>
                    }else{
        <MudFileUpload T="IReadOnlyList<IBrowserFile>" OnFilesChanged="OnInputFileChanged" Hidden="false" Class="flex-1" InputClass="absolute mud-width-full mud-height-full overflow-hidden z-20" InputStyle="opacity:0"
        @ondragenter="@SetDragClass" @ondragleave="@ClearDragClass" @ondragend="@ClearDragClass">
            <ButtonTemplate Context="DragAndDrop">
                <MudPaper Height="200px" Outlined="true" Class="@DragClass">
                    <MudText Typo="Typo.h6">@Localizer1["UsersDragAndDrop"]</MudText>
                    @foreach (var file in fileNames)
                    {
                        <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center">
                            <MudText Typo="Typo.h6">@file.message</MudText>

                            @switch (file.ftype)
                            {
                                case "xls":
                                    <img src="Images/xls.png" Height="70" Width="70" />
                                    break;
                                case "csv":
                                    <img src="Images/csv.png" Height="70" Width="70" />
                                    break;
                                default:
                                    <img src="Images/error.png" Height="70" Width="70" />
                                    break;
                            }

                            <MudChip Color="Color.Info" Text="@file.name" />
                        </MudItem>
                    }
                </MudPaper>
            </ButtonTemplate>
        </MudFileUpload>

                    }

    </MudStack>
</MudItem>


@*Tabla unica para cualquier tipo de usuario *@
<MudContainer Fixed="true" Class="py-10">
    <MudGrid Class="d-flex flex-column align-center justify-center">
        <MudItem Class="d-flex flex-column align-center justify-center">
            @if (showTableInUI)
            {
                <MudTable Items="@dataToShowInTable" T="User" HorizontalScrollbar="true" ReadOnly="true" FixedHeader=true Class="styled-table table-striped">
                    <ToolBarContent>
                        <MudSpacer />
                        <MudText Typo="Typo.h6">Data To Upload</MudText>
                        <MudSpacer />
                        <MudButton @onclick="(() => UploadFunction())" Disabled="@activeUpload">
                            <MudText>@Localizer1["UsersUploadTitle"]</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.UploadFile" aria-label="Upload" Color="Color.Primary"></MudIcon>
                        </MudButton>
                        <MudSpacer />
                        <MudButton @onclick="(() => CancelFunction())">
                            <MudText>@Localizer1["UsersCancelUpload"]</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.Cancel" aria-label="Cancel" Color="Color.Warning"></MudIcon>
                        </MudButton>
                        <MudSpacer />
                    </ToolBarContent>
                    <HeaderContent>

                        @if (uploadtype == 1)
                        {
                            <MudTh>@Localizer1["UsersName"]</MudTh>
                            <MudTh>@Localizer1["UsersType"]</MudTh>
                            <MudTh>@Localizer1["UsersPlant"]</MudTh>
                            <MudTh>@Localizer1["UsersArea"]</MudTh>
                            <MudTh>@Localizer1["UsersGroup"]</MudTh>
                            <MudTh Style="width:230px">@Localizer1["UsersExtra"]</MudTh>
                        }
                        else
                        {
                            @if (uploadtype > 4)
                            {
                                <MudTh>@Localizer1["UsersPayroll"]</MudTh>
                            }

                            <MudTh>@Localizer1["UsersName"]</MudTh>

                            @if (uploadtype > 1 && uploadtype < 5)
                            {
                                <MudTh>@Localizer1["UsersObject"]</MudTh>
                                <MudTh>@Localizer1["UsersEmail"]</MudTh>
                            }

                            @if (uploadtype > 2)
                            {
                                <MudTh>@Localizer1["UsersSuperior"]</MudTh>

                            }

                            <MudTh>@Localizer1["UsersPlant"]</MudTh>

                            @if (uploadtype > 1 && uploadtype < 3)
                            {
                                <MudTh>@Localizer1["UsersAreasManage"]</MudTh>
                            }
                            else if (uploadtype > 2 && uploadtype < 5)
                            {
                                <MudTh>@Localizer1["UsersAssignedArea"]</MudTh>
                            }
                            else
                            {
                                <MudTh>@Localizer1["UsersArea"]</MudTh>
                            }


                            @if (uploadtype > 4)
                            {
                                <MudTh>@Localizer1["UsersDistribution"]</MudTh>
                            }


                            <MudTh>@Localizer1["UsersGroup"]</MudTh>


                        }


                    </HeaderContent>
                    <RowTemplate>

                        @if (uploadtype == 1)
                        {
                            <MudTd DataLabel="Name">
                                <MudText Align="Align.Center">@context.Name</MudText>
                            </MudTd>
                            <MudTd>
                                @switch (context.UserType)
                                {
                                    case 1:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary">@Localizer1["UsersAdmin"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 2:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer1["UsersSeniorSupervisor"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 3:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer1["UsersSupervisor"]</MudChip>
                                        </MudPaper>
                                        break;
                                    case 4:
                                        <MudPaper Elevation="0">
                                            <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">@Localizer1["UsersOperator"]</MudChip>
                                        </MudPaper>
                                        break;
                                }
                            </MudTd>

                            <MudTd DataLabel="@Localizer1["UsersPlant"]">
                                @if (context.UserType != 1)
                                {
                                    <MudItem Class="d-flex justify-content-center align-items-center">
                                        <MudTextField Value="context.Plant?.Description" ReadOnly=true Variant="Variant.Outlined" Margin="Margin.Dense" Style="cursor:pointer"></MudTextField>
                                    </MudItem>
                                }

                            </MudTd>

                            <MudTd DataLabel="@Localizer1["UsersArea"]">
                                @switch (context.UserType)
                                {
                                    case 1:
                                        break;
                                    case 2:
                                        @if (context.Areas?.Count > 0)
                                        {

                                            <MudItem Style="text-align: center;">
                                                <MudMenu Dense=true MaxHeight="300" ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                                    <ActivatorContent>
                                                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">@Localizer1["UsersShowAreas"]</MudButton>
                                                    </ActivatorContent>
                                                    <ChildContent>
                                                        @foreach (var area in context.Areas)
                                                        {
                                                            <MudMenuItem><MudButton StartIcon="@Icons.Material.Filled.Business" IconColor="Color.Info">@area.Code - @area.Description</MudButton></MudMenuItem>
                                                        }
                                                    </ChildContent>
                                                </MudMenu>

                                            </MudItem>
                                        }
                                        break;
                                    default:
                                        <MudItem Class="d-flex justify-content-center align-items-center">
                                            <MudTextField Value="context.Area?.Description" ReadOnly=true Variant="Variant.Outlined" Margin="Margin.Dense" Style="cursor:pointer"></MudTextField>
                                        </MudItem>
                                        break;
                                }


                            </MudTd>
                            <MudTd DataLabel="@Localizer1["UsersGroup"]">
                                @if (context.UserType != 1)
                                {
                                    <MudItem Class="d-flex justify-content-center align-items-center">
                                        <MudTextField Value="context.Group?.Description" ReadOnly=true Variant="Variant.Outlined" Margin="Margin.Dense" Style="cursor:pointer"></MudTextField>
                                    </MudItem>
                                }

                            </MudTd>
                            <MudTd>

                                @switch (context.UserType)
                                {
                                    case 1:
                                        <MudMenu Dense=true MaxHeight="300" ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                            <ActivatorContent>
                                                <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">@Localizer1["UsersShowMoreInfo"]</MudButton>
                                            </ActivatorContent>
                                            <ChildContent>
                                                <MudExpansionPanels Elevation="0">
                                                    <MudExpansionPanel Text="@Localizer1["UsersEmail"]">
                                                        <MudItem class="d-flex flex-column justify-center ma-1">
                                                            <MudItem class="d-flex d-flex-column justify-center">
                                                                <MudPaper Elevation="0">
                                                                    <div class="font-weight-bold"> @context.Email</div>
                                                                </MudPaper>
                                                            </MudItem>
                                                        </MudItem>
                                                    </MudExpansionPanel>
                                                    <MudExpansionPanel Text="@Localizer1["UsersObject"]">
                                                        <MudItem class="d-flex flex-column justify-center ma-1">
                                                            <MudItem class="d-flex d-flex-column justify-center">
                                                                <MudPaper Elevation="0">
                                                                    <div class="font-weight-bold"> @context.ObjectId</div>
                                                                </MudPaper>
                                                            </MudItem>
                                                        </MudItem>
                                                    </MudExpansionPanel>
                                                </MudExpansionPanels>
                                            </ChildContent>
                                        </MudMenu>


                                        break;
                                    case 2:
                                        <MudMenu Dense=true MaxHeight="300" ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                            <ActivatorContent>
                                                <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">@Localizer1["UsersShowMoreInfo"]</MudButton>
                                            </ActivatorContent>
                                            <ChildContent>
                                                <MudExpansionPanels Elevation="0">
                                                    <MudExpansionPanel Text="@Localizer1["UsersEmail"]">
                                                        <MudItem class="d-flex flex-column justify-center ma-1">
                                                            <MudItem class="d-flex d-flex-column justify-center">
                                                                <MudPaper Elevation="0">
                                                                    <div class="font-weight-bold"> @context.Email</div>
                                                                </MudPaper>
                                                            </MudItem>
                                                        </MudItem>
                                                    </MudExpansionPanel>
                                                    <MudExpansionPanel Text="@Localizer1["UsersObject"]">
                                                        <MudItem class="d-flex flex-column justify-center ma-1">
                                                            <MudItem class="d-flex d-flex-column justify-center">
                                                                <MudPaper Elevation="0">
                                                                    <div class="font-weight-bold"> @context.ObjectId</div>
                                                                </MudPaper>
                                                            </MudItem>
                                                        </MudItem>
                                                    </MudExpansionPanel>
                                                    @if (context.Subordinates?.Count > 0)
                                                    {
                                                        <MudExpansionPanel Text="@Localizer1["UsersSubordinates"]" MaxHeight="300">

                                                            <MudItem class="d-flex flex-column justify-center ma-1">
                                                                <MudItem class="d-flex d-flex-column justify-center">
                                                                    @foreach (var sub in context.Subordinates)
                                                                    {
                                                                        <MudCard Elevation="1" Class="mr-5" Style="width: 300px;">
                                                                            <MudCardHeader>
                                                                                <CardHeaderContent>
                                                                                    @switch (sub.UserType)
                                                                                    {
                                                                                        case 1:
                                                                                            <MudPaper Elevation="0">
                                                                                                <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary">@Localizer1["UsersAdmin"]</MudChip>
                                                                                            </MudPaper>
                                                                                            break;
                                                                                        case 2:
                                                                                            <MudPaper Elevation="0">
                                                                                                <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer1["UsersSeniorSupervisor"]</MudChip>
                                                                                            </MudPaper>
                                                                                            break;
                                                                                        case 3:
                                                                                            <MudPaper Elevation="0">
                                                                                                <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary">@Localizer1["UsersSupervisor"]</MudChip>
                                                                                            </MudPaper>
                                                                                            break;
                                                                                        case 4:
                                                                                            <MudPaper Elevation="0">
                                                                                                <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark">@Localizer1["UsersOperator"]</MudChip>
                                                                                            </MudPaper>
                                                                                            break;
                                                                                    }

                                                                                </CardHeaderContent>
                                                                                <CardHeaderActions>

                                                                                </CardHeaderActions>
                                                                            </MudCardHeader>
                                                                            <MudCardContent>
                                                                                <div class="font-weight-bold"><b>@Localizer1["UsersName"]:</b> @sub.Name</div>
                                                                                <div class="font-weight-light"><b>@Localizer1["UsersAssignedArea"]:</b> @sub.Area.Description</div>
                                                                            </MudCardContent>
                                                                            <MudCardActions></MudCardActions>
                                                                        </MudCard>
                                                                    }
                                                                </MudItem>
                                                            </MudItem>

                                                        </MudExpansionPanel>
                                                    }


                                                </MudExpansionPanels>
                                            </ChildContent>
                                        </MudMenu>

                                        break;
                                    case 3:

                                        <MudMenu Dense=true MaxHeight="300" ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                            <ActivatorContent>
                                                <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">@Localizer1["UsersShowMoreInfo"]</MudButton>
                                            </ActivatorContent>
                                            <ChildContent>
                                                <MudExpansionPanels Elevation="0">
