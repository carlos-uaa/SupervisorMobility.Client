        _areasManager = new List<Area>(_areas[_plants.FindIndex(e => e.PlantId == ContextItem.PlantId)]);
        if (ContextItem.Area is not null)
        {
            foreach (var item in _areasManager)
            {

                if (ContextItem.Areas.Contains(item))
                {
                    _areasManager.Remove(item);
                }
            }

        }

        AuxDialogUser = ContextItem;
        StateHasChanged();
    }
