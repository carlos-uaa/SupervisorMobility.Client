@page "/usersmanagement/UploadUsers"

@using Microsoft.AspNetCore.Components.Forms;
@using MudBlazor;
@using System.Text.RegularExpressions;
@using ClosedXML.Excel;
@using System.Net.Http.Headers;
@using Microsoft.JSInterop;
@inject IFileUploadAndDownloadService FileUpDoServices
@inject IPlantService PlantsServices
@inject IAreaService AreasServices
@inject IDistributionService DistributionServices
@inject IGroupService GroupServices
@inject IUserService UsersServices
@inject IDialogService DialogService

<style>
    .mud-table-cell{
    overflow: hidden;
}
</style>

@*Title*@
<PageTitle>Supervisor Mobility | Upload Users</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


<MudContainer Class="d-flex flex-grow-1 gap-4 flex-row align-center justify-center py-3">

    <MudItem class="align-center justify-center">
        <MudImage Src="Images/userup.png" Alt="Imagen Upload Clou" Height="120" Width="120"></MudImage>
    </MudItem>
    <MudItem id="Upload" class="d-flex flex-column ma-5">
        <MudItem Class="d-flex flex-row align-center justify-center">
            <MudSpacer />
            <MudText Typo="Typo.h6">Upload Users</MudText>
            <MudSpacer />
        </MudItem>


        @*ErrorMsg, Resume and animation Upload File*@
        <MudItem Class="d-flex flex-column align-center justify-center mud-width-full">

            <MudText Typo="Typo.h6" Color="Color.Info" Class="py-5">@ErrorMessageToDisplay </MudText>
            @if (showResume)
            {
                <MudPaper Class="d-flex flex-row flex-grow-1 gap-4" Elevation="0">
                    <MudPaper Class="flex d-flex-row pa-16 ma-2" Elevation="3">
                        <MudItem style="text-align:center">
                            <img src="Images/useradd.png" Height="100" Width="100" />
                            <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Users Created: @commitUsersResult.UsersCreated </MudText>
                        </MudItem>
                    </MudPaper>
                    <MudPaper Class="flex d-flex-row pa-16 ma-2" Elevation="3">
                        <MudItem style="text-align:center">
                            <img src="Images/userexist.png" Height="100" Width="100" />
                            <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Users Exist: @commitUsersResult.UsersExist </MudText>
                        </MudItem>
                    </MudPaper>
                    <MudPaper Class="flex d-flex-row pa-16 ma-2" Elevation="3">
                        <MudItem style="text-align:center">
                            <img src="Images/userupdate.png" Height="100" Width="100" />
                            <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Users Created: @commitUsersResult.UsersUpdated </MudText>
                        </MudItem>
                    </MudPaper>
                </MudPaper>
            }
            else
            {
                if (activeUpload)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                }
            }


            @if (onloadfile)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
            }


        </MudItem>
        <MudItem Class="flex-grow-1 d-flex flex-column align-center justify-center my-3 ">

            @*Principal TABS*@
            <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
                @*All Upload*@
                <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="All Type Users" OnClick="() => AssignType(1)">
                </MudTabPanel>
                @*SSV Upload*@
                <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="SSV's" OnClick="() => AssignType(2)">

                </MudTabPanel>
                @*SUPERVISORS Upload*@
                <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Supervisors" OnClick="() => AssignType(3)">
                    <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
                        @*Add To SSV Upload*@
                        <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Supervisors" OnClick="() => AssignType(3)">
                        </MudTabPanel>
                        @*Add Supervisors to SSV*@
                        <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Add To SSV's" OnClick="() => AssignType(4)">

                            <MudSelect T="User" Label="SSV" Placeholder="Select SSV" SelectedValuesChanged="@(() => UpdateSelectSSVforSupervisors())" @bind-Value="@selectedSSVOfList" For="@(() => selectedSSVOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                <MudSelectItem Disabled="true" Value="selectedSSVOfList"> Select a SSV  </MudSelectItem>
                                @foreach (var SS in _allUsers)
                                {
                                    @if (SS.UserType == 2)
                                    {
                                        <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}") </MudSelectItem>
                                    }
                                }
                            </MudSelect>
                        </MudTabPanel>
                    </MudTabs>
                </MudTabPanel>
                @*Operators Upload Upload*@
                <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Operators" OnClick="() => AssignType(5)">
                    <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
                        @*Add Operators Upload*@
                        <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Operators" OnClick="() => AssignType(5)">
                        </MudTabPanel>
                        @*Add Supervisors to SSV*@
                        <MudTabPanel Icon="@Icons.Material.Filled.BubbleChart" Text="Add To Supervisor" OnClick="() => AssignType(6)">

                            <MudSelect T="User" Label="Supervisors" Placeholder="Select Supervisor" SelectedValuesChanged="@(() => UpdateSelectSupervisorForOperators())" @bind-Value="@selectedSupervisorOfList" For="@(() => selectedSupervisorOfList)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                <MudSelectItem Disabled="true" Value="selectedSupervisorOfList"> Select a Supervisor </MudSelectItem>
                                @foreach (var SS in _allUsers)
                                {
                                    @if (SS.UserType == 3)
                                    {
                                        <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}") </MudSelectItem>
                                    }
                                }
                            </MudSelect>
                        </MudTabPanel>
                    </MudTabs>


                </MudTabPanel>
            </MudTabs>
        </MudItem>
    </MudItem>
    <MudItem class="align-center justify-center mud-width-full">
        @switch (uploadtype)
        {
            case 1:
                <MudButton OnClick="DownloadAllFormat"
                   Target="_blank"
                   Variant="Variant.Outlined"
                   EndIcon="@Icons.Material.Filled.FileDownload"
                   Color="Color.Primary">
                    <b>All Upload Format</b>
                </MudButton>
                break;
            case 2:
                <MudButton OnClick="DownloadSSVFormat"
                   Target="_blank"
                   Variant="Variant.Outlined"
                   EndIcon="@Icons.Material.Filled.FileDownload"
                   Color="Color.Primary">
                    <b>SSV Format</b>
                </MudButton>
                break;
            case 3:
            case 4:
                <MudButton OnClick="DownloadSupervisorsFormat"
                   Target="_blank"
                   Variant="Variant.Outlined"
                   EndIcon="@Icons.Material.Filled.FileDownload"
                   Color="Color.Primary">
                    <b>Supervisors Format</b>
                </MudButton>
                break;
            case 5:
            case 6:
                <MudButton OnClick="DownloadOperatorsFormat"
                   Target="_blank"
                   Variant="Variant.Outlined"
                   EndIcon="@Icons.Material.Filled.FileDownload"
                   Color="Color.Primary" FullWidth="true">
                    <b>Operators Format</b>
                </MudButton>
                break;
        }
    </MudItem>

</MudContainer>

@*File Upload*@
<MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
    <MudStack Style="width: 80%">
        <MudFileUpload T="IReadOnlyList<IBrowserFile>" OnFilesChanged="OnInputFileChanged" Hidden="false" Class="flex-1" InputClass="absolute mud-width-full mud-height-full overflow-hidden z-20" InputStyle="opacity:0"
                       @ondragenter="@SetDragClass" @ondragleave="@ClearDragClass" @ondragend="@ClearDragClass">
            <ButtonTemplate Context="DragAndDrop">
                <MudPaper Height="200px" Outlined="true" Class="@DragClass">
                    <MudText Typo="Typo.h6">Drag and drop file Xlsx/CSV here or click</MudText>
                    @foreach (var file in fileNames)
                    {
                        <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center">
                            <MudText Typo="Typo.h6">@file.message</MudText>

                            @switch (file.ftype)
                            {
                                case "xls":
                                    <img src="Images/xls.png" Height="70" Width="70" />
                                    break;
                                case "csv":
                                    <img src="Images/csv.png" Height="70" Width="70" />
                                    break;
                                default:
                                    <img src="Images/error.png" Height="70" Width="70" />
                                    break;
                            }

                            <MudChip Color="Color.Info" Text="@file.name" />
                        </MudItem>
                    }
                </MudPaper>
            </ButtonTemplate>
        </MudFileUpload>
    </MudStack>
</MudItem>


@*Tabla unica para cualquier tipo de usuario *@
<MudContainer Fixed="true" Class="py-10">
    <MudGrid Class="d-flex flex-column align-center justify-center">
        <MudItem Class="d-flex flex-column align-center justify-center">
            @if (showTableInUI)
            {
                <MudTable Items="@dataToShowInTable" T="User" HorizontalScrollbar="true" ReadOnly="true" FixedHeader=true Class="styled-table table-striped">
                    <ToolBarContent>
                        <MudSpacer />
                        <MudText Typo="Typo.h6">Data To Upload</MudText>
                        <MudSpacer />
                        <MudButton @onclick="(() => UploadFunction())" Disabled="@activeUpload">
                            <MudText>Upload users</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.UploadFile" aria-label="Upload" Color="Color.Primary"></MudIcon>
                        </MudButton>
                        <MudSpacer />
                        <MudButton @onclick="(() => CancelFunction())">
                            <MudText>Cancel Upload Users</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.Cancel" aria-label="Cancel" Color="Color.Warning"></MudIcon>
                        </MudButton>
                        <MudSpacer />
                    </ToolBarContent>
                    <HeaderContent>



                        @if (uploadtype > 4)
                        {
                            <MudTh>Payroll</MudTh>
                        }

                        <MudTh>User Name</MudTh>



                        @if (uploadtype > 1 && uploadtype < 5)
                        {
                            <MudTh>Email</MudTh>
                        }

                        @if (uploadtype > 2)
                        {
                            <MudTh>Superior</MudTh>

                        }

                        <MudTh>Plant</MudTh>

                        @if (uploadtype > 1 && uploadtype < 3)
                        {
                            <MudTh>Areas Manage</MudTh>
                        }
                        else if (uploadtype > 2 && uploadtype < 5)
                        {
                            <MudTh>Assigned Area</MudTh>
                        }
                        else
                        {
                            <MudTh>Area</MudTh>
                        }


                        @if (uploadtype > 4)
                        {
                            <MudTh>Distribution</MudTh>
                        }


                        <MudTh>Group</MudTh>

                        @if (uploadtype == 1)
                        {
                            <MudTh>Role</MudTh>
                        }


                    </HeaderContent>
                    <RowTemplate>

                        @if (uploadtype > 4)
                        {
                            <MudTd DataLabel="Payroll">
                                <MudText Align="Align.Center">@context.Payroll</MudText>
                            </MudTd>
                        }

                        <MudTd DataLabel=" Name">
                            <MudText Align="Align.Center">@context.Name</MudText>
                        </MudTd>

                        @if (uploadtype > 1 && uploadtype < 5)
                        {
                            <MudTd DataLabel="Email">
                                <MudText Align="Align.Center">@context.Email</MudText>
                            </MudTd>
                        }

                        @switch (uploadtype)
                        {
                            case 3:
                                @if (@context.Superior is null)
                                {
                                    <MudTd DataLabel="Superior SSV">

                                        <MudSelect T="User" Label="SSV" Placeholder="Select SSV" @bind-Value="@context.Superior" For="@(() => @context.Superior)" SelectedValuesChanged="@(() => UpdateSelectSuperiorContextItem(@context))" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                            <MudSelectItem Disabled="true" Value="@context.Superior"> Select a SSV  </MudSelectItem>
                                            @foreach (var SS in _allUsers)
                                            {
                                                @if (SS.UserType == 2)
                                                {
                                                    <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}") </MudSelectItem>
                                                }
                                            }
                                        </MudSelect>
                                    </MudTd>
                                }
                                else
                                {
                                    <MudTd DataLabel="Superior SSV">
                                        <MudItem Class="d-flex justify-content-center align-items-center">
                                            <MudTextField @bind-Value="@context.Superior.Name" ReadOnly=true Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Edit" OnAdornmentClick="@(() => RemoveSelectedSuperiorContextItem(context))" Style="cursor:pointer"></MudTextField>
                                        </MudItem>
                                    </MudTd>


                                }


                                break;
                            case 4:
                                @if (selectedSSVOfList is null)
                                {
                                    <MudTd DataLabel="Superior SSV">
                                        <MudText Align="Align.Center">Please Select Superior of List</MudText>
                                    </MudTd>
                                }
                                else
                                {
                                    <MudTd DataLabel="Superior SSV">
                                        <MudText Align="Align.Center">@selectedSSVOfList?.Name</MudText>
                                    </MudTd>
                                }
                                break;
                            case 5:

                                @if (@context.Superior is null)
                                {
                                    <MudTd DataLabel="Superior Supervisor">

                                        <MudSelect T="User" Label="Supervisor" Placeholder="Select Supervisor" @bind-Value="@context.Superior" For="@(() => @context.Superior)" SelectedValuesChanged="@(() => UpdateSelectSuperiorContextItem(@context))" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                            <MudSelectItem Disabled="true" Value="@context.Superior"> Select a Supervisor  </MudSelectItem>
                                            @foreach (var SS in _allUsers)
                                            {
                                                @if (SS.UserType == 3)
                                                {
                                                    <MudSelectItem Value="SS">@($"{SS.Name}-{SS.Area?.Description}-{SS.Group?.Description}") </MudSelectItem>
                                                }
                                            }
                                        </MudSelect>
                                    </MudTd>
                                }
                                else
                                {
                                    <MudTd DataLabel="Superior Supervisor">
                                        <MudItem Class="d-flex justify-content-center align-items-center">
                                            <MudTextField @bind-Value="@context.Superior.Name" ReadOnly=true Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Edit" OnAdornmentClick="@(() => RemoveSelectedSuperiorContextItem(context))" Style="cursor:pointer"></MudTextField>
                                        </MudItem>
                                    </MudTd>


                                }


                                break;
                            case 6:
                                @if (selectedSupervisorOfList is null)
                                {
                                    <MudTd DataLabel="Supervisor">
                                        <MudText Align="Align.Center">Please Select Superior of List</MudText>
                                    </MudTd>
                                }
                                else
                                {
                                    <MudTd DataLabel="Supervisor">
                                        <MudText Align="Align.Center">@selectedSupervisorOfList?.Name</MudText>
                                    </MudTd>
                                }
                                break;

                        }




                        <MudTd DataLabel="Plant">
                            @if (context.Plant is null)
                            {
                                @switch (uploadtype)
                                {
                                    case 2:
                                        <MudSelect SelectedValuesChanged="@(() => updateSelectPlantContextItem(context))" T="Plant" Label="Plant" Placeholder="Assign Plant" @bind-Value="@context.Plant" For="@(() => @context.Plant)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                            <MudSelectItem Disabled="true" Value="@context.Plant"> Assign Plant  </MudSelectItem>
                                            @foreach (var item in _plants)
                                            {
                                                <MudSelectItem Value="item">@($"{item.Code}-{item.Description}") </MudSelectItem>
                                            }
                                        </MudSelect>
                                        break;
                                    case 3:
                                    case 4:
                                    case 5:
                                    case 6:
                                        <MudText Align="Align.Center" class="marquee">This field is inherited by the supervisor </MudText>
                                        break;
                                }
                            }
                            else
                            {
                                <MudItem Class="d-flex justify-content-center align-items-center">
                                    <MudTextField @bind-Value="@context.Plant.Description" ReadOnly=true Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Edit" OnAdornmentClick="@(() => RemoveSelectedPlantContextItem(context))" Style="cursor:pointer"></MudTextField>
                                </MudItem>


                            }
                        </MudTd>

                        @if (uploadtype == 2)
                        {

                            <MudTd DataLabel="Areas Manage">
                                @if (context.Areas?.Count > 0)
                                {
                                    <MudToolBar>

                                        <MudExpansionPanels>
                                            <MudExpansionPanel Text="Areas Manage" MaxHeight="150" Class="activador" id="ExpansionPanel">

                                                <MudItem class="d-flex flex-column justify-center ma-1">
                                                    <MudItem class="d-flex d-flex-column justify-center">
                                                        @foreach (var itemArea in context.Areas)
                                                        {
                                                            <MudCard Elevation="1" Class="mr-5" Style="width: 300px;">
                                                                <MudCardHeader>
                                                                    <CardHeaderContent>
                                                                        <MudText Typo="Typo.subtitle1"><b>Area Id:</b> @itemArea.AreaId</MudText>
                                                                    </CardHeaderContent>
                                                                    <CardHeaderActions>
                                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="() => DeleteAreaFromContextItem(itemArea, context)" />
                                                                    </CardHeaderActions>
                                                                </MudCardHeader>
                                                                <MudCardContent>
                                                                    <div class="font-weight-bold"><b>Code:</b> @itemArea.Code</div>
                                                                    <div class="font-weight-light"><b>Description:</b> @itemArea.Description</div>
                                                                </MudCardContent>
                                                                <MudCardActions></MudCardActions>
                                                            </MudCard>
                                                        }
                                                    </MudItem>
                                                </MudItem>

                                            </MudExpansionPanel>

                                        </MudExpansionPanels>
                                        <MudSpacer />
                                        <MudIconButton Icon="@Icons.Material.Outlined.Edit" OnClick="(() => OpenDialog(context))" />
                                    </MudToolBar>
                                }
                                else
                                {
                                    if (context.Plant != null)
                                    {
                                        <MudToolBar>
                                            <MudText Typo="Typo.button">no areas to show</MudText>
                                            <MudSpacer />
                                            <MudIconButton Icon="@Icons.Material.Outlined.Edit" OnClick="(() => OpenDialog(context))" />
                                        </MudToolBar>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.button" Align="Align.Center">first select a plant</MudText>
                                    }
                                }
                            </MudTd>
                        }
                        else if (uploadtype == 3 || uploadtype == 4)
                        {

                            @switch (uploadtype)
                            {
                                case 3:
                                    @if (@context.Superior is null)
                                    {
                                        <MudTd DataLabel="Assigned Area">
                                            <MudText Align="Align.Center">Please Select a Superior</MudText>
                                        </MudTd>
                                    }
                                    else
                                    {
                                        <MudTd DataLabel="Assigned Area">
                                            @if (context.Superior.Areas is not null)
                                            {
                                                if (context.Superior.Areas.Count > 0)
                                                {
                                                    <MudSelect SelectedValuesChanged="@(() => updateSelectAreaContextItem(context))" T="Area" Label="Area" Placeholder="Area" @bind-Value="@context.Area" For="@(() => @context.Area)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                                        <MudSelectItem Disabled="true" Value="@context.Area"> Assign Area  </MudSelectItem>
                                                        @foreach (var item in context.Superior.Areas)
                                                        {
                                                            <MudSelectItem Value="item">@($"{item.Code}-{item.Description}") </MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.button">no areas to show</MudText>
                                                }
                                            }
                                        </MudTd>
                                    }
                                    break;
                                case 4:
                                    @if (selectedSSVOfList is null)
                                    {
                                        <MudTd DataLabel="Assigned Area">
                                            <MudText Align="Align.Center">Please Select a Superior</MudText>
                                        </MudTd>
                                    }
                                    else
                                    {

                                        <MudTd DataLabel="Assigned Area">
                                            @if (selectedSSVOfList.Areas is not null)
                                            {
                                                if (selectedSSVOfList.Areas.Count > 0)
                                                {
                                                    <MudSelect T="Area" SelectedValuesChanged="@(() => updateSelectAreaContextItem(context))" Label="Area" Placeholder="Area" @bind-Value="@context.Area" For="@(() => @context.Area)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                                        <MudSelectItem Disabled="true" Value="@context.Area"> Assign Area  </MudSelectItem>
                                                        @foreach (var item in selectedSSVOfList.Areas)
                                                        {
                                                            <MudSelectItem Value="item">@($"{item.Code}-{item.Description}") </MudSelectItem>
                                                        }
                                                    </MudSelect>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.button">no areas to show</MudText>
                                                }
                                            }
                                        </MudTd>
                                    }
                                    break;
                            }

                        }
                        else
                        {
                            //area asignada al operador por el superior
                            @if (context.Area is null)
                            {
                                <MudTd DataLabel="Area">
                                    <MudText Align="Align.Center" class="marquee">This field is inherited by the supervisor</MudText>
                                </MudTd>
                            }
                            else
                            {
                                <MudTd DataLabel="Area">
                                    <MudItem Class="d-flex justify-content-center align-items-center">
                                        <MudTextField @bind-Value="@context.Area.Description" ReadOnly=true Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Edit" OnAdornmentClick="@(() => RemoveSelectedPlantContextItem(context))" Style="cursor:pointer"></MudTextField>
                                    </MudItem>
                                </MudTd>
                            }
                        }

                        @if (uploadtype > 4)
                        {
                            <MudTd DataLabel="Distribution">

                                @if (context.Distribution is not null)
                                {
                                    <MudItem Class="d-flex justify-content-center align-items-center">
                                        <MudTextField Value="@context.Distribution?.Description" ReadOnly=true Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Edit" OnAdornmentClick="@(() => RemoveSelectedDistributionContextItem(context))" Style="cursor:pointer"></MudTextField>
                                    </MudItem>
                                }
                                else
                                {
                                    @if (context.PlantId != null && context.AreaId != null)
                                    {
                                        @if (_distributions[(int)context.PlantId][(int)context.AreaId].Count > 0)
                                        {
                                            <MudSelect T="Distribution" Label="Distribution" Placeholder="Distribution" @bind-Value="@context.Distribution" For="@(() => @context.Distribution)" Class="mt-3" Variant="Variant.Text" AnchorOrigin="Origin.BottomCenter">
                                                <MudSelectItem Disabled="true" Value="@context.Distribution"> Assign Area  </MudSelectItem>
                                                @foreach (var item in _distributions[(int)context.PlantId][(int)context.AreaId])
                                                {
                                                    <MudSelectItem Value="item">@($"{item.Code}-{item.Description}") </MudSelectItem>
                                                }
                                            </MudSelect>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.button" class="marquee">this combination of floor plan and area does not have any distributions</MudText>
                                        }
                                    }
                                    else
                                    {
                                        <MudText Align="Align.Center" class="marquee">This field is inherited by the supervisor</MudText>
                                    }

                                }
                            </MudTd>

                        }


                        <MudTd DataLabel="Group">
                            @if (context.Group is null)
                            {
                                @switch (uploadtype)
                                {
                                    case 3:
