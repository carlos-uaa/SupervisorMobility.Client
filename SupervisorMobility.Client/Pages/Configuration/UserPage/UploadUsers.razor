                        }

                    }
                    else
                    {
                        ErrorMessageToDisplay = "Fail Upload file to system, pls Call for admin";
                    }

                    break;
                case 2:
                case 3:
                case 5:
                    
                        UsersUploadResult ResultMassiveUpload = await UsersServices.UploadUsers(dataToShowInTable);

