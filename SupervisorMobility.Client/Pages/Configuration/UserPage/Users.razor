@page "/usersmanagement"
@inject IGroupService GroupService
@inject NavigationManager NavigationManager
@inject IUserService UsersServices
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource1> Localizer
@inject IStringLocalizer<Resource> Localizer0
@inject IHCIService HCIsServices
@inject IDialogService DialogService
@using FuzzyString;

<style>
    .dialog { backdrop-filter: blur(10px); }
</style>

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["UsersTitle"]</PageTitle>

@*Breadcrumb links*@
@* <MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs> *@

@if (_users == null)
{

    <MudContainer>
        <MudGrid class="d-flex flex-column justify-center align-self-center">
            <MudItem class="d-flex justify-center align-self-center ">
                <MudText Typo="Typo.h6" Class="align-item-center center">@Localizer["UsersNoFound"]</MudText>
            </MudItem>
            <MudItem Class="d-flex">
                <MudSpacer />
                @if (loggedUser.UserType == 1)
                {
                    <MudButton Href="/userNotFound" EndIcon="@Icons.Material.Filled.PersonSearch" IconColor="Color.Primary">
                        @Localizer["UsersUnregister"]
                    </MudButton>
                    <MudSpacer />
                }
                <MudButton Href="/usersmanagement/UploadUsers" EndIcon="@Icons.Material.Filled.CloudDownload" IconColor="Color.Primary">
                    @Localizer["UsersUpload"]
                </MudButton>
                <MudSpacer />
                <MudButton Href="/usersmanagement/BulkUsers" EndIcon="@Icons.Material.Filled.CloudDownload" IconColor="Color.Warning">
                    @Localizer["UsersBulk"]
                </MudButton>
                <MudSpacer />
                <MudButton Href="/usersmanagement/CreateUser" EndIcon="@Icons.Material.Filled.PersonAddAlt1" IconColor="Color.Warning">
                    @Localizer["UsersNew"]
                </MudButton>
            </MudItem>
        </MudGrid>

    </MudContainer>

    <MudSimpleTable Class="styled-table table-striped" FixedHeader=true>
        <thead>
            <tr>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
            </tr>
        </thead>
        <tbody>

            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /> <MudSpacer />   <MudSkeleton SkeletonType="SkeletonType.Rectangle" /> <MudSpacer />  <MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>

        </tbody>
    </MudSimpleTable>
}
else if (_users.Count == 0)
{
    <MudContainer>
        <MudGrid class="d-flex flex-column justify-center align-self-center">
            <MudItem class="d-flex justify-center align-self-center ">
              <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
            <MudItem class="d-flex justify-center align-self-center pa-3 ma-2 ">
                <MudText Typo="Typo.h6" Class="align-item-center center">Loading Data</MudText>
            </MudItem>
            <MudPaper Class="flex d-flex-row pa-3 ma-2" Elevation="0">
                <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
            </MudPaper>
        </MudItem>
            </MudItem>
            <MudItem Class="d-flex">
                <MudSpacer />
                @if (loggedUser.UserType == 1)
                {
                    <MudButton Href="/userNotFound" EndIcon="@Icons.Material.Filled.PersonSearch" IconColor="Color.Primary">
                        @Localizer["UsersUnregister"]
                    </MudButton>
                    <MudSpacer />
                }
                <MudButton Href="/usersmanagement/UploadUsers" EndIcon="@Icons.Material.Filled.CloudDownload" IconColor="Color.Primary">
                    @Localizer["UsersUpload"]
                </MudButton>
                <MudSpacer />
                <MudButton Href="/usersmanagement/BulkUsers" EndIcon="@Icons.Material.Filled.CloudDownload" IconColor="Color.Warning">
                    @Localizer["UsersBulk"]
                </MudButton>
                <MudSpacer />
                <MudButton Href="/usersmanagement/CreateUser" EndIcon="@Icons.Material.Filled.PersonAddAlt1" IconColor="Color.Warning">
                    @Localizer["UsersNew"]
                </MudButton>
            </MudItem>
        </MudGrid>

    </MudContainer>

}
else
{
    <MudTable Items="_users" T="User" ReadOnly="true" Height="75vh" FixedHeader=true Class="styled-table table-striped mt-10"
              SortLabel="Sort By" Filter="new Func<User,bool>(FilterFunc)" Style="height: 80%"  RowsPerPage="15"
                  HorizontalScrollbar="true" Virtualize="true"  RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" OnRowClick="RowClickEvent">
        <ToolBarContent>
            <MudGrid class="d-flex flex-column justify-center align-self-center mb-6">
                <MudItem Class="d-flex">
                    <MudSpacer />
                    <MudTextField Immediate @bind-Value="searchString" Placeholder="@Localizer["Search"]" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                    <MudSpacer />
                    @if (loggedUser.UserType == 1)
                    {
                        <MudButton Href="/userNotFound" EndIcon="@Icons.Material.Filled.PersonSearch" IconColor="Color.Primary">
                            @Localizer["UsersUnregister"]
                        </MudButton>
                        <MudSpacer />
                    }
                    <MudButton Href="/usersmanagement/UploadUsers" EndIcon="@Icons.Material.Filled.CloudDownload" IconColor="Color.Primary">
                        @Localizer["UsersUpload"]
                    </MudButton>
                    <MudSpacer />
                    <MudButton Href="/usersmanagement/BulkUsers" EndIcon="@Icons.Material.Filled.CloudDownload" IconColor="Color.Warning">
                        @Localizer["UsersBulk"]
                    </MudButton>
                    <MudSpacer />
                    <MudButton Href="/usersmanagement/CreateUser" EndIcon="@Icons.Material.Filled.PersonAddAlt1" IconColor="Color.Warning">
                        @Localizer["UsersNew"]
                    </MudButton>
                </MudItem>
            </MudGrid>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.UserId)">@Localizer["UsersId"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.Name)">@Localizer["UsersName"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.UserType)">@Localizer["UsersType"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.Plant?.Description)">@Localizer["UsersPlant"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.Area?.Description)">@Localizer["UsersArea"]</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.Group?.Description)">@Localizer["UsersGroup"]</MudTableSortLabel></MudTh>
            <MudTh>@Localizer["Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@Localizer["UsersId"]">
                <MudText Align="Align.Center">@context.UserId</MudText>
            </MudTd>
            <MudTd DataLabel="@Localizer["UsersName"]">
                <MudText Align="Align.Center">@context.Name</MudText>
            </MudTd>
            <MudTd DataLabel="@Localizer["UsersType"]" Style="text-align:center;">
                <MudItem Class="d-flex justify-center">
                    @switch (context.UserType)
                    {
                        case 1:
                            <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary"></MudIcon>
                            <MudText Class="pl-2">@Localizer["UsersAdmin"]</MudText>
                            break;
                        case 2:
                            <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"></MudIcon>
                            <MudText Class="pl-2">SSV</MudText>
                            break;
                        case 3:
                            <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"></MudIcon>
                            <MudText Class="pl-2">Supervisor</MudText>
                            break;
                        case 4:
                            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Dark"></MudIcon>
                            <MudText Class="pl-2">@Localizer["UsersOperator"]</MudText>
                            break;
                        case 5:
                            <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Warning"></MudIcon>
                            <MudText Class="pl-2">@Localizer["UsersManager"]</MudText>
                            break;
                        case 6:
                            <MudIcon Icon="@Icons.Material.Filled.Engineering" Color="Color.Info"></MudIcon>
                            <MudText Class="pl-2">@Localizer["lineSupport"]</MudText>
                            break;        
                        case 7:
                            <MudIcon Icon="@Icons.Material.Filled.PermContactCalendar" Color="Color.Info"></MudIcon>
                            <MudText Class="pl-2">@Localizer["headCount"]</MudText>
                            break;       
                    }
                </MudItem>
            </MudTd>
            <MudTd DataLabel="@Localizer["UsersPlant"]">
                <MudText Align="Align.Center">@context.Plant?.Description</MudText>
            </MudTd>
            @if (context.UserType == 2 || context.UserType == 3 || context.UserType == 4 || context.UserType == 5)
            {
                <MudTd DataLabel="@Localizer["UsersArea"]">
                    <MudItem Style="text-align: center;">
                        @if (context.Areas?.Count > 0)
                        {
                            <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                <ActivatorContent>
                                    <MudButton FullWidth=true EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small">@Localizer["UsersShowAreas"]</MudButton>
                                </ActivatorContent>
                                <ChildContent>
                                    @foreach (var area in context.Areas)
                                    {
                                        <MudMenuItem Icon="@Icons.Material.Filled.Business" IconColor="Color.Info">@area.Code - @area.Description</MudMenuItem>
                                    }

                                </ChildContent>
                            </MudMenu>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Dense ContentAlignment="HorizontalAlignment.Center">
                                @Localizer["UsersNoAreas"]
                            </MudAlert>
                        }
                    </MudItem>
                </MudTd>
            }
            else
            {
                <MudTd DataLabel="@Localizer["UsersArea"]">
                    <MudText Align="Align.Center">@context.Area?.Description</MudText>
                </MudTd>
            }
            <MudTd DataLabel="@Localizer["UsersGroup"]">
                <MudText Align="Align.Center">@context.Group?.Description</MudText>
            </MudTd>

            <MudTd DataLabel="@Localizer["Actions"]">
                <MudText Align="Align.Center">

                    <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                        <ActivatorContent>
                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() =>  UserDetails(context.UserId))" OnTouch="(() =>  UserDetails(context.UserId))">@Localizer["UsersDetails"]</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="()=>EditUser(context.UserId)" OnTouch="()=>EditUser(context.UserId)">@Localizer["UsersEdit"] </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="@(() =>OpenDeleteDialog(context.UserId))" OnTouch="@(() =>OpenDeleteDialog(context.UserId))">@Localizer["UsersDelete"] </MudMenuItem>
                            @if (!_HCIs.Any(h => h.UserId == context.UserId))
                            {
                                <MudMenuItem Icon="@Icons.Material.Filled.PersonAddAlt1" IconColor="Color.Primary" @onclick="@(() =>CreateHci(context.UserId))" OnTouch="@(() =>CreateHci(context.UserId))">@Localizer0["create"] @Localizer0["hci"] </MudMenuItem>
                            }
                        
                        </ChildContent>
                    </MudMenu>
                </MudText>
            </MudTd>
        </RowTemplate>
        <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 15, 25, 50, 100, int.MaxValue }"  />
        </PagerContent>
    </MudTable>

}