@page "/usersmanagement"
@inject IGroupService GroupService
@inject NavigationManager NavigationManager
@inject IUserService UsersServices
@inject IJSRuntime JSRuntime


@*Title*@
<PageTitle>Supervisor Mobility | Users Management</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@if (_users == null)
{
    <MudSimpleTable Class="styled-table table-striped" FixedHeader=true>
        <thead>
            <tr>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>
                <th><MudSkeleton SkeletonType="SkeletonType.Text" /></th>/
            </tr>
        </thead>
        <tbody>

            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>
            <tr>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /> <MudSpacer />   <MudSkeleton SkeletonType="SkeletonType.Rectangle" /> <MudSpacer />  <MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
            </tr>

        </tbody>
    </MudSimpleTable>
}
else if (_users.Count == 0)
{
    <MudContainer>
        <MudGrid class="d-flex flex-column justify-center align-self-center">
            <MudItem class="d-flex justify-center align-self-center ">
                <MudText Typo="Typo.h6" Class="align-item-center center">No Users Found</MudText>
            </MudItem>
            <MudItem Class="d-flex">
                <MudSpacer />
                @if (loggedUser.UserType == 1)
                {
                    <MudButton Href="/userNotFound" EndIcon="@Icons.Material.Filled.PersonSearch" IconColor="Color.Primary">
                        Unregistered Users
                    </MudButton>
                    <MudSpacer />
                }
                <MudButton Href="/usersmanagement/UploadUsers" EndIcon="@Icons.Material.Filled.CloudDownload" IconColor="Color.Primary">
                    Upload Users
                </MudButton>
                <MudSpacer />
                <MudButton Href="/usersmanagement/BulkUsers" EndIcon="@Icons.Material.Filled.CloudDownload" IconColor="Color.Warning">
                    Bulk Users
                </MudButton>
                <MudSpacer />
                <MudButton Href="/usersmanagement/CreateUser" EndIcon="@Icons.Material.Filled.PersonAddAlt1" IconColor="Color.Warning">
                    Create New User
                </MudButton>
            </MudItem>
        </MudGrid>

    </MudContainer>
}
else
{
    <MudTable Items="_users" T="User" ReadOnly="true" Height="55vh" FixedHeader=true Class="styled-table table-striped"
              SortLabel="Sort By" Filter="new Func<User,bool>(FilterFunc)"
              HorizontalScrollbar="true">
        <ToolBarContent>
            <MudGrid class="d-flex flex-column justify-center align-self-center mb-10">
                <MudItem class="d-flex justify-center align-self-center ">
                    <MudText Typo="Typo.h6" Class="align-item-center center">Users</MudText>
                </MudItem><MudSpacer />
                <MudItem Class="d-flex">
                    <MudSpacer />
                    <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                    <MudSpacer />
                    @if(loggedUser.UserType == 1)
                    {
                        <MudButton Href="/userNotFound" EndIcon="@Icons.Material.Filled.PersonSearch" IconColor="Color.Primary">
                            Unregistered Users
                        </MudButton>
                        <MudSpacer />
                    }
                    <MudButton Href="/usersmanagement/UploadUsers" EndIcon="@Icons.Material.Filled.CloudDownload" IconColor="Color.Primary">
                        Upload Users
                    </MudButton>
                    <MudSpacer />
                    <MudButton Href="/usersmanagement/BulkUsers" EndIcon="@Icons.Material.Filled.CloudDownload" IconColor="Color.Warning">
                        Bulk Users
                    </MudButton>
                    <MudSpacer />
                    <MudButton Href="/usersmanagement/CreateUser" EndIcon="@Icons.Material.Filled.PersonAddAlt1" IconColor="Color.Warning">
                        Create New User
                    </MudButton>
                </MudItem>
            </MudGrid>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.UserId)">User Id</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.UserType)">Type</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.Plant?.Description)">Plant</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.Area?.Description)">Area</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x?.Group?.Description)">Group</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="UserId">
                <MudText Align="Align.Center">@context.UserId</MudText>
            </MudTd>
            <MudTd DataLabel="Area">
                <MudText Align="Align.Center">@context.Name</MudText>
            </MudTd>
            <MudTd DataLabel="Permission" Style="text-align:center;">
                <MudItem Class="d-flex justify-center">
                    @switch (context.UserType)
                    {
                        case 1:
                            <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary"></MudIcon>
                            <MudText Class="pl-2">Admin</MudText>
                            break;
                        case 2:
                            <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"></MudIcon>
                            <MudText Class="pl-2">SSV</MudText>
                            break;
                        case 3:
                            <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary"></MudIcon>
                            <MudText Class="pl-2">Supervisor</MudText>
                            break;
                        case 4:
                            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Dark"></MudIcon>
                            <MudText Class="pl-2">Operator</MudText>
                            break;
                    }
                </MudItem>
            </MudTd>
            <MudTd DataLabel="Plant">
                <MudText Align="Align.Center">@context.Plant?.Description</MudText>
            </MudTd>
            @if (context.UserType == 2)
            {
                <MudTd DataLabel="Areas">
                    <MudItem Style="text-align: center;">
                        <MudMenu Dense=true MaxHeight="300" ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                            <ActivatorContent>
                                <MudButton FullWidth=true EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small">Show Areas</MudButton>
                            </ActivatorContent>
                            <ChildContent>
                                @foreach (var area in context.Areas)
                                {
                                    <MudMenuItem><MudButton StartIcon="@Icons.Material.Filled.Business" IconColor="Color.Info">@area.Code - @area.Description</MudButton></MudMenuItem>
                                }
                            </ChildContent>
                        </MudMenu>

                    </MudItem>
                </MudTd>
            }
            else
            {
                <MudTd DataLabel="Area">
                    <MudText Align="Align.Center">@context.Area?.Description</MudText>
                </MudTd>
            }
            <MudTd DataLabel="Group">
                <MudText Align="Align.Center">@context.Group?.Description</MudText>
            </MudTd>

            <MudTd>
                <MudText Align="Align.Center">

                    <MudMenu Dense=true MaxHeight="300" ActivationEvent="@MouseEvent.MouseOver" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                        <ActivatorContent>
                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() =>  UserDetails(context.UserId))">User Details</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="()=>EditUser(context.UserId)">Edit User </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="@(() =>OpenDeleteDialog(context.UserId))">Delete User </MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                    @*
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() =>  UserDetails(context.UserId))"> </MudIconButton>
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="()=>EditUser(context.UserId)">@*Edit</MudIconButton>
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="@(() =>OpenDeleteDialog(context.UserId))"></MudIconButton>

                *@
                </MudText>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>

}

@*Delete user modal*@
<MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">Confirm</MudText>
        <MudText Class="mt-4 mb-4">
            Are you sure you want to delete this user?
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">Cancel</MudButton>
        <MudButton @onclick="(() => DeleteUser(deleteUserId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">Delete</MudButton>
    </DialogActions>
</MudDialog>



@code {

    List<User> _users = new List<User>();
    List<User> allUsers = new List<User>();
    string searchString = "";

    //User
    private string json = string.Empty;
    public User loggedUser = new();


    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "#"),
            new BreadcrumbItem("Configuration", href: "/configuration"),
            new BreadcrumbItem("Users Management", href: "", disabled: true)
        };

    protected async override Task OnInitializedAsync()
    {
        allUsers = await UsersServices.GetUsersWhitCollections();


        await GetUserAsync();

        if (loggedUser != null)
        {
            if (loggedUser.UserType == 1)
            {
                _users = allUsers;
            }
            else
            {

                foreach(User usr in allUsers)
                {
                    if(usr.UserId == loggedUser.UserId || usr.SuperiorId == loggedUser.UserId || usr.Superior?.SuperiorId == loggedUser.UserId)
                    {
                        _users.Add(usr);
                    }

                }

            }
        }

    }

    //Local storage user
    private async Task GetUserAsync()
    {
        if (!await TryGetAsync())
            loggedUser = new();
    }

    private async Task<bool> TryGetAsync()
    {
        bool hasProperty = await HasPropertyAsync();
        if (hasProperty)
        {
            json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "user");
            loggedUser = JsonSerializer.Deserialize<User>(json) ?? new();
        }
        return hasProperty;
    }

    private async Task<bool> HasPropertyAsync()
        => await JSRuntime.InvokeAsync<bool>("localStorage.hasOwnProperty", "user");


    // Plant details
    void PlantDetails(int plantId)
    {
        NavigationManager.NavigateTo($"plants/{plantId}");
    }


    void EditUser(int userId)
    {
        NavigationManager.NavigateTo($"/usersmanagement/EditUser/{userId}");
    }

    async void DeleteUser(int iduser)
    {
        _users.RemoveAll(user => user.UserId == iduser);
        await UsersServices.DeleteUser(iduser);
        //await PlantService.DeletePlant(plantId);
        _users.Clear();


        allUsers = await UsersServices.GetUsersWhitCollections();


        await GetUserAsync();

        if (loggedUser != null)
        {
            if (loggedUser.UserType == 1)
            {
                _users = allUsers;
            }
            else
            {

                foreach (User usr in allUsers)
                {
                    if (usr.UserId == loggedUser.UserId || usr.SuperiorId == loggedUser.UserId)
                    {
                        _users.Add(usr);
                    }

                }

            }
        }


        visibleDelete = false;
        StateHasChanged();
    }

    void UserDetails(int userId)
    {
        NavigationManager.NavigateTo($"/usersmanagement/DetailUser/{userId}");
    }

    private bool FilterFunc(User element)
    {



        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.ObjectId != null)
        {
            if ((bool)element.ObjectId?.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (element.Email != null)
        {
            if ((bool)element.Email?.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Payroll != null)
        {
            if ((bool)element.Payroll?.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (element.Plant != null)
        {
            if ((bool)element.Plant?.Description.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (element.Area != null)
        {
            if ((bool)element.Area?.Description.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if (element.Group != null)
        {
            if ((bool)element.Group?.Description.Contains(searchString, StringComparison.OrdinalIgnoreCase))
                return true;
        }
        if ($"{element.UserId} {element.Payroll} {element.Name} {element.Plant?.Description} {element.Area?.Description} {element.Group?.Description} {element.ObjectId} {element.Email}".Contains(searchString))
            return true;
        return false;
    }

    //Delete User
    private bool visibleDelete = false;
    public int deleteUserId = 0;
    private void OpenDeleteDialog(int deleteId)
    {
        deleteUserId = deleteId;
        visibleDelete = true;
    }
    void CloseDeleteModal() => visibleDelete = false;
    private DialogOptions dialogDeleteOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, Position = DialogPosition.TopCenter };

}