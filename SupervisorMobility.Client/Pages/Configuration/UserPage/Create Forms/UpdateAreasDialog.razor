@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudItem Class="d-flex">
            <MudIcon Icon="@Icons.Material.Filled.EditLocationAlt" Color="Color.Primary" Size="Size.Large" Class="me-2" />
            <MudText Typo="Typo.h5"> <b>Update Areas</b></MudText>
        </MudItem>
    </TitleContent>
    <DialogContent>
        <MudCard Elevation="2" Style="border-radius: 8px; background-color: #f9faf9; margin-top: 15px; width: 400px;">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Warning">@GetAvatar(Superior.UserType)</MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6"><b>Superior</b></MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1"><b>Name: </b> @(string.IsNullOrEmpty(Superior.Name) ? "No Name setted yet" : Superior.Name)</MudText>
                <MudText Typo="Typo.subtitle1"><b>Group: </b> @(string.IsNullOrEmpty(Superior.Group?.Description) ? "No Group setted yet" : Superior.Group?.Description)</MudText>
            </MudCardContent>
        </MudCard>

        <MudCard Elevation="2" Style="border-radius: 8px; background-color: #f9faf9; margin-top: 15px; width: 400px;">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Primary">@GetAvatar(Subordinate.UserType)</MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6"><b>Subordinate</b></MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.subtitle1"><b>Name: </b> @Subordinate.Name</MudText>
                <MudText Typo="Typo.subtitle1"><b>Group: </b>@Subordinate.Group?.Description</MudText>
            </MudCardContent>
        </MudCard>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2"><b>Select Areas to Assign:</b></MudText>
        <MudItem Class="d-flex">
            <MudSelect T="int" Label="Areas" @bind-value="areaIdAux" Dense="true" Style="width: 300px;" Disabled="@((Subordinate.UserType == 4 && SubordinateToUpdate.AreaIds.Count > 0))">
                <MudSelectItem T="int" Value="0" Disabled="true">-- Select an Area --</MudSelectItem>
                @foreach (var area in Areas)
                {
                    if(SubordinateToUpdate.AreaIds.Contains(area.AreaId))
                    {
                        continue;
                    }
                    <MudSelectItem T="int" Value="@area.AreaId"><b>@area.Code:</b> @area.Description</MudSelectItem>
                }
            </MudSelect>
            @if(!(Subordinate.UserType == 4 && SubordinateToUpdate.AreaIds.Count > 0))
            {
                <MudIconButton Color="Color.Secondary" Variant="Variant.Text" Class="mt-2" OnClick="AddAreaToSubordinate" Icon="@Icons.Material.Filled.Add" />
            }
        </MudItem>
        <MudItem>
            @foreach (var areaId in SubordinateToUpdate.AreaIds)
            {
                if(Areas.Any(a => a.AreaId == areaId))
                {
                    var area = Areas.FirstOrDefault(a => a.AreaId == areaId);
                    if (area != null)
                    {
                        <MudChip Variant="Variant.Text" Color="Color.Secondary" CloseIcon="@Icons.Material.Filled.Delete" OnClose="() => { SubordinateToUpdate.AreaIds.Remove(areaId); StateHasChanged(); }"><b>@area.Code: </b> @area.Description</MudChip>
                    }
                }
            }
            <br/>
            @foreach(var area in SubordinateToUpdate.AreaIds)
            {
                if(Subordinate.Areas.Any(a => a.AreaId == area) && !Areas.Any(a => a.AreaId == area))
                {
                    var areaToShow = Subordinate.Areas.FirstOrDefault(a => a.AreaId == area);
                    if (areaToShow != null)
                    {
                        <MudChip Variant="Variant.Text" Color="Color.Warning" CloseIcon="@Icons.Material.Filled.Delete" OnClose="() => { SubordinateToUpdate.AreaIds.Remove(area); StateHasChanged(); }"><b>@areaToShow.Code: </b> @areaToShow.Description</MudChip>
                    }
                }
            }
        </MudItem>
        <MudItem><MudChip Color="Color.Info" Variant="Variant.Outlined" Class="mt-2">Total Areas Assigned: @SubordinateToUpdate.AreaIds.Count</MudChip></MudItem>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Submit</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Outlined" OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public MudDialogInstance MudDialog { get; set; }
    [Parameter] public List<Area> Areas { get; set; }
    [Parameter] public User Superior { get; set; }
    [Parameter] public User Subordinate { get; set; }

    private UpdateAreasForSuperiorDto SubordinateToUpdate = new UpdateAreasForSuperiorDto();
    private int areaIdAux = 0;

    protected override async Task OnInitializedAsync()
    {
        SubordinateToUpdate = new UpdateAreasForSuperiorDto
        {
            UserId = Subordinate.UserId,
            SuperiorId = Superior.UserId,
            AreaIds = Subordinate.Areas?.Select(a => a.AreaId).ToList() ?? new List<int>()
        };
    }

    private async Task Submit()
    {
        // Validar si el Subordinate es de tipo Operator (4) y tiene exactamente un área asignada
        if (Subordinate.UserType == 4 && SubordinateToUpdate.AreaIds.Count != 1)
        {
            Snackbar.Add("An Operator must have exactly one area assigned.", Severity.Warning);
            return;
        }
        //Validar si Subordinate.AreaIds no está vacío
        if (SubordinateToUpdate.AreaIds.Count == 0)
        {
            Snackbar.Add("At least one area must be assigned to the subordinate.", Severity.Warning);
            return;
        }
        // Validar si Subordinate.AreaIds conitene áreas que correspondan a Areas
        foreach (var areaId in SubordinateToUpdate.AreaIds)
        {
            if (!Areas.Any(a => a.AreaId == areaId))
            {
                Snackbar.Add($"The superior does not have an area with ID {areaId}.", Severity.Warning);
                return;
            }
        }

        MudDialog.Close(DialogResult.Ok(SubordinateToUpdate));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private string GetAvatar(int userType) => userType switch
    {
        1 => "Adm",
        2 => "SSV",
        3 => "SV",
        4 => "Op",
        5 => "Mg",
        6 => "LS",
        7 => "HC",
        8 => "RTC",
        _ => "??"
    };

    private void AddAreaToSubordinate()
    {
        if (Subordinate.Areas == null)
            Subordinate.Areas = new List<Area>();
        if (areaIdAux != 0 && !SubordinateToUpdate.AreaIds.Contains(areaIdAux))
        {
            SubordinateToUpdate.AreaIds.Add(areaIdAux);
            if(!Subordinate.Areas.Any(a => a.AreaId == areaIdAux))
                Subordinate.Areas.Add(Areas.FirstOrDefault(a => a.AreaId == areaIdAux));
        }
        areaIdAux = 0;
        StateHasChanged();
    }
}
