@* SupervisorForm.razor - Para Supervisor (tipo 3) *@
@* Incluye: Planta (readonly), Área, Departamento, Grupo (readonly), Superior (SSV), Subordinados (Operadores) *@

@using SupervisorMobility.Client.Data.Entities

@inject IAreaService AreaServices
@inject IDepartmentService DepartmentServices
@inject IUserService UsersServices
@inject IDistributionService DistributionsServices
@inject IStringLocalizer<Resource1> Localizer

@* 📋 SECCIÓN 1: INFORMACIÓN BÁSICA *@
<MudPaper Elevation="2" Class="pa-6 mb-4" Style="border-left: 3px solid #90a4ae; background-color: #fafafa;">
    <MudText Typo="Typo.h6" Class="mb-4" Style="color: #546e7a;">
        <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
        Información Básica
    </MudText>
    @switch (LogedUser.UserType)
    {
        case 1:
        case 2:
        default:
            <MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="plantInfo" Label="@Localizer["UsersPlant"]" ReadOnly="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="grupInfo" Label="@Localizer["UsersGroup"]" ReadOnly="true" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            break;
    }
</MudPaper>

@* 🏭 SECCIÓN 2: ÁREAS MANEJADAS *@
<MudPaper Elevation="2" Class="pa-6 mb-4" Style="border-left: 3px solid #90a4ae; background-color: #fafafa;">
    <MudText Typo="Typo.h6" Class="mb-4" Style="color: #546e7a;">
        <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />
        @Localizer["UsersManageAreas"]
    </MudText>

    @if (auxPlant != 0)
    {
        <MudGrid Spacing="2" Class="mb-3">
            <MudItem xs="12" md="9">
                <MudSelect T="Area" 
                           Label="@Localizer["UsersLabelArea"]" 
                           ValueChanged="@OnSelectedAreaToManageFunction" 
                           Placeholder="@Localizer["UsersPHArea"]" 
                           Value="@selectedAreaOfList" 
                           Variant="Variant.Outlined" 
                           AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem Disabled="true" Value="selectedAreaOfList">@Localizer["UsersPHArea"]</MudSelectItem>
                    @if (User.Superior != null && User.Superior.Areas != null && User.Superior.Areas.Count > 0)
                    {
                        @foreach (var areaItem in User.Superior.Areas)
                        {
                            <MudSelectItem Value="areaItem">@($"{areaItem.Code} - {areaItem.Description}")</MudSelectItem>
                        }
                    }
                    else if (_areas != null && _areas.Count > 0)
                    {
                        @foreach (var areaItem in _areas)
                        {
                            <MudSelectItem Value="areaItem">@($"{areaItem.Code} - {areaItem.Description}")</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudButton Disabled="@ActiveAddArea" 
                           OnClick="@(() => AddAreaToUserList(selectedAreaOfList))" 
                           Variant="Variant.Filled" 
                           Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.Add" 
                           FullWidth="true"> 
                    @Localizer["UsersAddArea"] 
                </MudButton>
            </MudItem>
        </MudGrid>
    }

    @* Lista de Áreas Asignadas *@
    @switch (User.Areas?.Count)
    {
        case null:
        case 0:
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                @if (auxPlant == 0)
                {
                    <text>@Localizer["UsersFirstPlant"]</text>
                }
                else
                {
                    <text>@Localizer["UsersFirstAddArea"]</text>
                }
            </MudAlert>
            break;
        default:
            <MudGrid Spacing="2">
                @foreach (var itemArea in User.Areas)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="1" Style="border-radius: 8px; border: 1px solid #e0e0e0;">
                            <MudCardHeader Style="padding: 12px; background-color: #f5f5f5; border-bottom: 1px solid #e0e0e0;">
                                <CardHeaderContent>
                                    <MudText Typo="Typo.body2" Style="color: #546e7a;">
                                        <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" /> 
                                        ID: @itemArea.AreaId
                                    </MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                   Color="Color.Error" 
                                                   Size="Size.Small"
                                                   @onclick="() => DeleteAreaFromUserList(itemArea)" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent Class="py-3">
                                <MudText Typo="Typo.body2" Class="mb-1">
                                    <strong>@Localizer["UsersCode"]:</strong> @itemArea.Code
                                </MudText>
                                <MudText Typo="Typo.body2">
                                    <strong>@Localizer["UsersDescription"]:</strong> @itemArea.Description
                                </MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
            break;
    }
</MudPaper>

@* 👤 SECCIÓN 3: SUPERIOR - JERARQUÍA *@
<MudPaper Elevation="2" Class="pa-6 mb-4" Style="border-left: 3px solid #90a4ae; background-color: #fafafa;">
    <MudText Typo="Typo.h6" Class="mb-4" Style="color: #546e7a;">
        <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Class="mr-2" />
        @Localizer["UsersSuperior"]
    </MudText>

    @if (User.Superior != null)
    {
        @* Superior Asignado *@
        <MudCard Elevation="1" Style="border-radius: 8px; border: 1px solid #e0e0e0;">
            <MudCardHeader Style="padding: 16px; background-color: #f5f5f5; border-bottom: 1px solid #e0e0e0;">
                <CardHeaderContent>
                    <MudText Typo="Typo.h6" Style="color: #546e7a;">
                        <MudIcon Icon="@Icons.Material.Filled.SupervisorAccount" Size="Size.Medium" />
                        @User.Superior?.Name
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                   Color="Color.Error" 
                                   OnClick="@RemoveSuperiorUser" />
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-4">
                @if (User.Superior?.Areas != null && User.Superior?.Areas.Count > 0)
                {
                    <MudText Typo="Typo.body2" Class="mb-2">
                        <strong>@Localizer["UsersAreasManage"]:</strong>
                    </MudText>
                    <div style="display: flex; flex-wrap: wrap; gap: 4px; max-width: 100%;">
                        @foreach (var area in User.Superior?.Areas)
                        {
                            <MudChip Icon="@Icons.Material.Filled.Business" 
                                     Color="Color.Info" 
                                     Size="Size.Small" 
                                     Variant="Variant.Outlined">
                                @area.Code - @area.Description
                            </MudChip>
                        }
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">@Localizer["UsersNoAreasSSV"]</MudText>
                }

                <MudDivider Class="my-3" />

                <MudStack Row="true" Justify="Justify.FlexStart">
                    <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary" Size="Size.Small">@Localizer["UsersSeniorSupervisor"]</MudChip>
                </MudStack>
            </MudCardContent>
        </MudCard>
    }
    else
    {
        @* Sin Superior - Selector *@
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
            @Localizer["UsersFirstSuperior"]
        </MudAlert>

        @if (SeniorsSupervisors.Count > 0)
        {
            <MudAutocomplete ResetValueOnEmptyText 
                             Clearable 
                             MaxItems="null" 
                             T="User" 
                             Label="@Localizer["UsersSeniorSupervisor"]" 
                             ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer["UsersPHSuperior"]}" : $"{e.Name} ({e.Group?.Description})")" 
                             For="@(() => User.Superior)" 
                             SearchFunc="@SearchSSV" 
                             Variant="Variant.Outlined" 
                             ShowProgressIndicator="true" 
                             ValueChanged="@SetSuperiorToUser">
                <ItemTemplate Context="e">
                    <MudStack Spacing="2" Class="pa-2">
                        <MudStack Row="true" Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
                            @switch (e.UserType)
                            {
                                case 1:
                                    <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary" Size="Size.Small">@Localizer["UsersAdmin"]</MudChip>
                                    break;
                                case 2:
                                    <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary" Size="Size.Small">@Localizer["UsersSeniorSupervisor"]</MudChip>
                                    break;
                                case 3:
                                    <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary" Size="Size.Small">@Localizer["UsersSupervisor"]</MudChip>
                                    break;
                                case 4:
                                    <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark" Size="Size.Small">@Localizer["UsersOperator"]</MudChip>
                                    break;
                                case 5:
                                    <MudChip Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Warning" Size="Size.Small">@Localizer["UsersManager"]</MudChip>
                                    break;
                            }
                        </MudStack>
                        <MudText Typo="Typo.body2">
                            <strong>@Localizer["UserId"]:</strong> @e.UserId | <strong>@Localizer["UsersName"]:</strong> @e.Name
                        </MudText>
                        @if (e.UserType == 2)
                        {
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                @foreach (var area in e.Areas)
                                {
                                    <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">@area.Code - @area.Description</MudChip>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">
                                <strong>@Localizer["UsersArea"]:</strong> @e.Area?.Description
                            </MudText>
                        }
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>
        }
    }
</MudPaper>

@* 👥 SECCIÓN 4: SUBORDINADOS (OPERADORES) *@
<MudPaper Elevation="2" Class="pa-6 mb-4" Style="border-left: 3px solid #90a4ae; background-color: #fafafa;">
    <MudText Typo="Typo.h6" Class="mb-4" Style="color: #546e7a;">
        <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />
        @Localizer["UsersSubordinates"]
    </MudText>

    @switch (User.Subordinates?.Count)
    {
        case null:
        case 0:
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                @if (Operators?.Count > 0)
                {
                    @if (User.Superior != null)
                    {
                        <text>@Localizer["UsersFirstSubordinate"]</text>
                    }
                    else
                    {
                        <text>@Localizer["UsersFirstSuperior"]</text>
                    }
                }
                else
                {
                    <text>@Localizer["UsersPlantNoOP"]</text>
                }
            </MudAlert>
            break;
        default:
            <MudGrid Spacing="2">
                @foreach (var item in User.Subordinates)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="1" Style="border-radius: 8px; border: 1px solid #e0e0e0;">
                            <MudCardHeader Style="padding: 12px; background-color: #f5f5f5; border-bottom: 1px solid #e0e0e0;">
                                <CardHeaderContent>
                                    <MudText Typo="Typo.body2" Style="color: #546e7a;">
                                        <MudIcon Icon="@Icons.Material.Filled.PersonOutline" Size="Size.Small" /> 
                                        @item.Name
                                    </MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                   Color="Color.Error" 
                                                   Size="Size.Small"
                                                   OnClick="@(() => DeleteOperatorFromSubordinateList(item))" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent Class="py-3">
                                <MudText Typo="Typo.body2" Class="mb-2">
                                    <strong>@Localizer["UserId"]:</strong> @item.UserId
                                </MudText>

                                @if (item.Areas != null && item.Areas.Count > 0)
                                {
                                    <MudText Typo="Typo.body2" Class="mb-1">
                                        <strong>@Localizer["UsersAssignedArea"]:</strong>
                                    </MudText>
                                    <MudSelect T="Area" 
                                               SelectedValuesChanged="@(() => UpdateSelectAreaContextItem(item))" 
                                               Label="Area" 
                                               Placeholder="Area" 
                                               @bind-Value="@item.Area" 
                                               For="@(() => @item.Area)" 
                                               Variant="Variant.Outlined" 
                                               Dense="true"
                                               AnchorOrigin="Origin.BottomCenter">
                                        @foreach(var area in item.Areas)
                                        {
                                            <MudSelectItem Value="@area">@($"{area.Code} - {area.Description}")</MudSelectItem>
                                        }
                                        <MudSelectItem Value="Reassign">Reassign</MudSelectItem>
                                    </MudSelect>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Default">@Localizer["UsersNoAreasSSV"]</MudText>
                                }

                                <MudChip Icon="@Icons.Material.Filled.PersonOutline" 
                                         Color="Color.Dark" 
                                         Size="Size.Small" 
                                         Class="mt-2">
                                    @Localizer["UsersOperator"]
                                </MudChip>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
            break;
    }

    @* Selector de Operadores *@
    @if (Operators?.Count > 0 && auxPlant != 0)
    {
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.subtitle1" Class="mb-3">Agregar Subordinado</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" md="9">
                <MudAutocomplete ResetValueOnEmptyText 
                                 Clearable 
                                 T="User" 
                                 Label="@Localizer["UsersOperator"]" 
                                 ValueChanged="@OnSelectedOperatorFunction"
                                 Value="@selectedOperatorOfList"
                                 SearchFunc="@SearchOP" 
                                 ToStringFunc="@(e=> e.Name == null || e.Name == "" ? $"{Localizer["UsersPHOperator"]}" : $"[{e.UserId}] - {e.Name} [{e.Payroll}] - {e.Area?.Description} - {e.Distribution?.Description}")"
                                 Variant="Variant.Outlined" 
                                 AdornmentIcon="@Icons.Material.Filled.Person"
                                 ShowProgressIndicator="true" 
                                 MaxItems="null">
                    <ItemTemplate Context="e">
                        <MudStack Spacing="2" Class="pa-2">
                            <MudStack Row="true" Justify="Justify.FlexStart" AlignItems="AlignItems.Center">
                                @switch (e.UserType)
                                {
                                    case 1:
                                        <MudChip Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Primary" Size="Size.Small">@Localizer["UsersAdmin"]</MudChip>
                                        break;
                                    case 2:
                                        <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary" Size="Size.Small">@Localizer["UsersSeniorSupervisor"]</MudChip>
                                        break;
                                    case 3:
                                        <MudChip Icon="@Icons.Material.Filled.SupervisorAccount" Color="Color.Secondary" Size="Size.Small">@Localizer["UsersSupervisor"]</MudChip>
                                        break;
                                    case 4:
                                        <MudChip Icon="@Icons.Material.Filled.PersonOutline" Color="Color.Dark" Size="Size.Small">@Localizer["UsersOperator"]</MudChip>
                                        break;
                                    case 5:
                                        <MudChip Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Warning" Size="Size.Small">@Localizer["UsersManager"]</MudChip>
                                        break;
                                }
                            </MudStack>
                            <MudText Typo="Typo.body2">
                                <strong>@Localizer["UserId"]:</strong> @e.UserId | <strong>@Localizer["UsersName"]:</strong> @e.Name
                            </MudText>
                            @if (e.UserType == 2)
                            {
                                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                    @foreach (var area in e.Areas)
                                    {
                                        <MudChip Icon="@Icons.Material.Filled.Business" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">@area.Code - @area.Description</MudChip>
                                    }
                                </MudStack>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">
                                    <strong>@Localizer["UsersArea"]:</strong> @e.Area?.Description
                                </MudText>
                            }
                        </MudStack>
                    </ItemTemplate>
                </MudAutocomplete>
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudButton Disabled="@ActiveAddSubordinated" 
                           OnClick="@(() => AddOperatorToSubordinateList(selectedOperatorOfList))" 
                           Variant="Variant.Filled" 
                           Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.Add" 
                           FullWidth="true"> 
                    Add subordinate 
                </MudButton>
            </MudItem>
        </MudGrid>
    }
</MudPaper>

@code {
    [Parameter] public User User { get; set; } = new();
    [Parameter] public User LogedUser { get; set; } = new();
    [Parameter] public List<Department> Departments { get; set; } = new();
    [Parameter] public int InitialPlantId { get; set; }
    [Parameter] public int InitialAreaId { get; set; }
    [Parameter] public int InitialDepartmentId { get; set; }
    [Parameter] public EventCallback<User> OnUpdateSelectAreaContextItem { get; set; }

    private List<User> SeniorsSupervisors = new();
    private List<User> Operators = new();
    private List<Area> _areas = new();
    private List<Department> _departments = new();
    private List<Distribution> _distributions = new();

    private int auxPlant = 0;
    private int auxArea = 0;
    private int auxDepa = 0;
    private bool ActiveAddSubordinated = true;
    private bool ActiveAddArea = true;
    private User? selectedOperatorOfList = null;
    private Area selectedAreaOfList = null;
    private Area Reassign = new Area { AreaId = -2 };

    private string plantInfo = "First select a superior";
    private string grupInfo = "First select a superior";

    protected override async Task OnInitializedAsync()
    {
        _departments = Departments;
        auxPlant = InitialPlantId;
        auxArea = InitialAreaId;
        auxDepa = InitialDepartmentId;

        await LoadData();
    }

    private async Task LoadData()
    {
        // Cargar SSVs
        if (LogedUser.UserType == 1)
        {
            SeniorsSupervisors = await UsersServices.GetUsersByType(2, true, false);
        }
        else if (auxPlant != 0)
        {
            SeniorsSupervisors = await UsersServices.GetUsersByUserTypeInPlant(auxPlant, 2, true, false);
        }

        // Cargar áreas si hay planta
        if (auxPlant != 0)
        {
            _areas = await AreaServices.GetAreas(auxPlant);
        }

        // Cargar operadores
        await LoadOperators();

        // Actualizar info de planta/grupo
        UpdatePlantGroupInfo();

        // Remover duplicados
        SeniorsSupervisors.RemoveAll(s => s.UserId == User.UserId);
    }

    private async Task LoadOperators()
    {
        if (LogedUser.UserType == 1)
        {
            if (User.PlantId != null)
            {
                Operators = await UsersServices.GetUsersByUserTypeInPlant((int)User.PlantId, 4, true, false);
            }
            else
            {
                Operators = await UsersServices.GetUsersByType(4, true, false);
            }
        }
        else
        {
            if (User.Areas != null && User.Areas.Count > 0 && User.PlantId != null)
            {
                foreach (var area in User.Areas)
                {
                    var ops = await UsersServices.GetUsersByUserTypeInPlantAndArea((int)User.PlantId, area.AreaId, 4, true, false);
                    Operators.AddRange(ops);
                }
                Operators = Operators.Distinct().ToList();
            }
            else if (User.PlantId != null)
            {
                Operators = await UsersServices.GetUsersByUserTypeInPlant((int)User.PlantId, 4, true, false);
            }
            else
            {
                Operators = await UsersServices.GetUsersByType(4, true, false);
            }
        }

        // Remover subordinados ya asignados y al propio usuario
        if (User.Subordinates != null)
        {
            foreach (var sub in User.Subordinates.ToList())
            {
                Operators.RemoveAll(o => o.UserId == sub.UserId);
            }
        }
        Operators.RemoveAll(o => o.UserId == User.UserId);
    }

    private void UpdatePlantGroupInfo()
    {
        if (User.Superior != null)
        {
            plantInfo = User.Superior.Plant?.Description ?? "N/A";
            grupInfo = User.Superior.Group?.Description ?? "N/A";
        }
    }

    private async Task SetSuperiorToUser(User? ItemSelected)
    {
        if (ItemSelected == null) return;

        User.Superior = ItemSelected;
        User.SuperiorId = ItemSelected.UserId;
        User.PlantId = ItemSelected.PlantId;
        User.GroupId = ItemSelected.GroupId;
        auxPlant = ItemSelected.PlantId ?? 0;

        await LoadOperators();
        UpdatePlantGroupInfo();
        StateHasChanged();
    }

    private void RemoveSuperiorUser()
    {
        User.Superior = null;
        User.SuperiorId = null;
        plantInfo = "First select a superior";
        grupInfo = "First select a superior";
    }

    private async void ShowDistributionInvokeByAreasSelector()
    {
        User.AreaId = auxArea;
        User.DepartmentId = auxDepa;

        if (auxPlant != 0 && auxArea != 0)
        {
            _distributions = await DistributionsServices.GetDistributions(auxPlant, auxArea);
        }
        StateHasChanged();
    }

    private async Task<IEnumerable<User>> SearchSSV(string value)
    {
        if (string.IsNullOrEmpty(value))
            return SeniorsSupervisors;
        return SeniorsSupervisors.Where(x => x.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task<IEnumerable<User>> SearchOP(string value)
    {
        if (string.IsNullOrEmpty(value))
            return Operators;
        return Operators.Where(x => x.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private void OnSelectedOperatorFunction(User selectedUser)
    {
        selectedOperatorOfList = selectedUser;
        ActiveAddSubordinated = selectedUser == null;
    }

    private void AddOperatorToSubordinateList(User selection)
    {
        if (User.Subordinates == null)
            User.Subordinates = new List<User>();

        if (selectedOperatorOfList != null && !User.Subordinates.Any(s => s.UserId == selection.UserId))
        {
            User.Subordinates.Add(selection);
            Operators.Remove(selection);
            selectedOperatorOfList = null;
            ActiveAddSubordinated = true;
        }
    }

    private void DeleteOperatorFromSubordinateList(User selection)
    {
        User.Subordinates?.Remove(selection);
        Operators.Add(selection);
    }

    private void OnSelectedAreaToManageFunction(Area item)
    {
        selectedAreaOfList = item;
        ActiveAddArea = item == null;
    }

    private void AddAreaToUserList(Area selection)
    {
        if (User.Areas == null) User.Areas = new List<Area>();

        if (selectedAreaOfList != null && !User.Areas.Any(x => x.AreaId == selection.AreaId))
        {
            User.Areas.Add(selection);
            selectedAreaOfList = null;
            ActiveAddArea = true;
        }
    }

    private void DeleteAreaFromUserList(Area item)
    {
        User.Areas?.Remove(item);
    }

    private async Task UpdateSelectAreaContextItem(User item)
    {
        await OnUpdateSelectAreaContextItem.InvokeAsync(item);
    }
}
