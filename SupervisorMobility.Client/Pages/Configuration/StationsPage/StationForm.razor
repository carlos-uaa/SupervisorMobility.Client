@page "/Station/Create"
@page "/Station/Update/{StationID:int?}"
@page "/Station/Details/{StationID:int?}"

@inject IStationService StationsServices
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IBreadcrumbService BreadcrumbService

<EditForm Model="_Station" class="mt-10" OnValidSubmit="ExectStationAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6"> 
                            @switch (PageState)
                            {
                                case 1:
                                    @Localizer["create"]
                                    break; 
                                case 2:
                                    @Localizer["details"]
                                break; 
                            case 3:
                                    @Localizer["update"]
                                break; 
                            }&nbsp;
                            @Localizer["Station"]</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip Variant="Variant.Text" Color="Color.Info"> @switch (PageState)
                            {
                                case 1:
                                    @Localizer["create"]
                                    break; 
                                case 2:
                                    @Localizer["details"]
                                break; 
                            case 3:
                                    @Localizer["update"]
                                break; 
                            } &nbsp;
                            @Localizer["Station"]</MudChip>
                        </CardHeaderActions> 
                    <CardHeaderActions>
                          @switch (PageState)
                            {
                               
                                case 2:
                                <MudChip @onclick="()=>EditStation((int)StationID)" @ontouchstart="()=>EditStation((int)StationID)" Variant="Variant.Filled" Class="ml-auto mr-13 mb-10" Icon="@Icons.Material.Filled.Edit" Color="Color.Info">@Localizer["EditStation"]</MudChip>
                                break; 
                           
                            }
                    </CardHeaderActions>
                        
                    </MudCardHeader>
                    <MudCardContent>
                    <MudTextField Label=@Localizer["description"] ReadOnly="@(PageState == 2)"
                                      @bind-Value="_Station.Description" For="@(() => _Station.Description)" />
                    <MudTextField Label=@Localizer["code"] Class="mt-3" ReadOnly="@(PageState == 2)"
                                      @bind-Value="_Station.Code" For="@(() => _Station.Code)" />
                    @if (user.UserType == 1)
                    {
                        <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_Station.IsActive" ReadOnly="@(PageState == 2)" Color="Color.Info" UnCheckedColor="Color.Dark" />
                    }
                    </MudCardContent>
                    <MudCardActions>
                    @if (PageState != 2)
                    {
                        <MudButton ButtonType="ButtonType.Submit" Disabled="ExecBtnPress" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@(PageState == 1 ? Localizer["create"] : Localizer["save"])</MudButton>
                    }
                    <MudButton Href="/Station" Variant="Variant.Filled" Class="ml-4">@Localizer["cancel"]</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </EditForm>