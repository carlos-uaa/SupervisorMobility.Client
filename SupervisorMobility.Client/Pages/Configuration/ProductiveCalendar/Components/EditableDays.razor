@inject ICalendarProductiveService CalendarProductiveServices

@if (ImportedHolidays.Count == 0)
{
    <MudText>No se ha cargado ningún día feriado.</MudText>
}
else
{
    <MudTable Items="ImportedHolidays" Dense="true">
        <HeaderContent>
            <MudTh>Fecha</MudTh>
            <MudTh>Descripción</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Date.ToString("yyyy-MM-dd")</MudTd>
            <MudTd>@context.Description</MudTd>
            <MudTd>
                <MudIconButton Icon="mdi-delete" Color="Color.Error" OnClick="@(() => RemoveHoliday(context))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<Holiday> ImportedHolidays = new List<Holiday>();

    protected override async void OnInitialized()
    {
        ImportedHolidays = CalendarProductiveServices.GetHolidaysInService();

     
    }

    private void OnRowEditCommit(Holiday item)
    {
        StateHasChanged();
    }

    private void RemoveHoliday(Holiday holiday)
    {
        ImportedHolidays.Remove(holiday);
    }
}
