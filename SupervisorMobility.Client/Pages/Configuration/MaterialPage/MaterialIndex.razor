@page "/Material"
@inject IMaterialService MaterialsServices
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IBreadcrumbService BreadcrumbService

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["Material"]</PageTitle>

@*Breadcrumb links*@
@* <MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>
 *@
@*Checklist categories table*@
<MudTable Items="_Materials" Hover="true" T="Material" SortLabel="Sort By" Height="80vh"
          RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" OnRowClick="RowClickEvent"
          Filter="new Func<Material,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true>
    <ToolBarContent>
        <MudGrid class="d-flex flex-column justify-center align-self-center mb-10">
            <MudItem class="d-flex justify-center align-self-center ">
                <MudText Typo="Typo.h6" Class="align-item-center center">@Localizer["jobstructure"]</MudText>
            </MudItem>
            <MudItem Class="d-flex">
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>

                <MudSpacer />
                <MudButton Href="/Material/Create">
                    <MudText>@Localizer["newMaterial"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary"></MudIcon>
                </MudButton>
                <MudSpacer />
            </MudItem>
        </MudGrid>
    </ToolBarContent>
    <HeaderContent>
        @if (user.UserType == 1)
        {
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Material, object>(x=>x?.MaterialId)">Material Id</MudTableSortLabel>
            </MudTh>
        }
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Material, object>(x=>x?.key)">Key</MudTableSortLabel>
        </MudTh>

        <MudTh>
            <MudTableSortLabel SortBy="new Func<Material, object>(x=>x?.PartName)">Name</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Material, object>(x=>x?.PartNumber)">Number</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Actions</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="MaterialId">
            <MudText Align="Align.Center">@context.MaterialId</MudText>
        </MudTd>
        <MudTd DataLabel="Key">
            <MudText Align="Align.Center">@context.key</MudText>
        </MudTd>
        <MudTd DataLabel="Name">
            <MudText Align="Align.Center">@context.PartName</MudText>
        </MudTd>
        <MudTd DataLabel="Number">
            <MudText Align="Align.Center">@context.PartNumber</MudText>
        </MudTd>

        <MudTd>
            <MudText Align="Align.Center">
                <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                    <ActivatorContent>
                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                    </ActivatorContent>
                    <ChildContent>

                        <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => MaterialDetails(context.MaterialId))" OnTouch="(() => MaterialDetails(context.MaterialId))">Details</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdateMaterial(context.MaterialId))" OnTouch="(() => UpdateMaterial(context.MaterialId))">Edit </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => DeleteMaterial(context.MaterialId))" OnTouch="(() => DeleteMaterial(context.MaterialId))">Delete </MudMenuItem>
                    </ChildContent>
                </MudMenu>


            </MudText>
        </MudTd>
    </RowTemplate>
</MudTable>
@code {
    // Breadcrumb links
    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>();

    // Objects
    public List<Material> _Materials { get; set; } = new();

    //User
    private string json = string.Empty;
    public User user = new();
    public bool logged = false;

    // Initialization
    protected async override Task OnInitializedAsync()
    {


        _Materials = await MaterialsServices.GetMaterials();

        await GetUserAsync();
        logged = await HasPropertyAsync();
        if (!logged)
        {
            Snackbar.Clear();
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Add($"Error You have to log in", Severity.Error);
            NavigationManager.NavigateTo($"/");
        }

        _links = new List<BreadcrumbItem>
             {
                 new BreadcrumbItem(text: Localizer["home"], href: "/"),
                 new BreadcrumbItem(text: Localizer["configuration"], href: "/configuration"),
                            new BreadcrumbItem(text: Localizer["Materials"], href: "", disabled: true)
                        };
        BreadcrumbService.UpdateBreadcrumbs(_links);

    }

    //Local storage user
    private async Task GetUserAsync()
    {
        if (!await TryGetAsync())
            user = new();
    }

    private async Task<bool> TryGetAsync()
    {
        bool hasProperty = await HasPropertyAsync();
        if (hasProperty)
        {
            json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "user");
            user = JsonSerializer.Deserialize<User>(json) ?? new();
        }
        return hasProperty;
    }

    private async Task<bool> HasPropertyAsync()
        => await JSRuntime.InvokeAsync<bool>("localStorage.hasOwnProperty", "user");

    private string searchString = "";

    private bool FilterFunc(Material element)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.MaterialId.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.key.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.PartName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.PartNumber.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private int selectedRowNumber = -1;
    private MudTable<Material> SelectTableEvent;

    private void RowClickEvent(TableRowClickEventArgs<Material> args)
    {
        var visibleItems = SelectTableEvent.FilteredItems.ToList();
        var rowIndex = visibleItems.IndexOf(args.Item);

        if (selectedRowNumber == rowIndex)
        {
            
                MaterialDetails(args.Item.MaterialId);
        }
        else
        {
            SelectTableEvent.SelectedItem = args.Item;
            selectedRowNumber = rowIndex;
            StateHasChanged();
        }
    }

    private string SelectedRowClassFunc(Material element, int rowNumber)
    {
        var visibleItems = SelectTableEvent.FilteredItems.ToList();

        if (selectedRowNumber == rowNumber)
        {
            return "selected"; // Marca la fila seleccionada
        }
        else if (SelectTableEvent.SelectedItem != null && SelectTableEvent.SelectedItem.Equals(element))
        {
            selectedRowNumber = visibleItems.IndexOf(element);  // Usa el índice filtrado
            return "selected";
        }
        else
        {
            return string.Empty;
        }
    }

    void MaterialDetails(int MaterialId)
    {
        NavigationManager.NavigateTo($"Material/Details/{MaterialId}");
    }

    // Delete Material
    async Task DeleteMaterial(int MaterialId)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this Material?");

        if (confirm)
        {
            _Materials.RemoveAll(Material => Material.MaterialId == MaterialId);
            await MaterialsServices.DeleteMaterial(MaterialId);
        }
    }

    // Update Material
    void UpdateMaterial(int MaterialId)
    {
        NavigationManager.NavigateTo($"Material/Update/{MaterialId}");
    }

}
