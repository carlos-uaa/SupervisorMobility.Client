@page "/groups"
@inject IGroupService GroupService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime


@*Title*@
<PageTitle>Supervisor Mobility | Groups</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Groups table*@
<MudTable Items="_groups" Hover="true" T="Group" SortLabel="Sort By" Filter="new Func<Group,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true>

    <ToolBarContent>
        <MudGrid class="d-flex flex-column justify-center align-self-center mb-10">
            <MudItem class="d-flex justify-center align-self-center ">
                <MudText Typo="Typo.h6" Class="align-item-center center">Groups</MudText>
            </MudItem>
            <MudItem Class="d-flex">
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                <MudSpacer />

                <MudButton @onclick="(() => CreateGroup())">
                    <MudText>Create Group</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Plant" Color="Color.Primary"></MudIcon>
                </MudButton>

                <MudSpacer />
            </MudItem>
        </MudGrid>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Group, object>(x=>x?.GroupId)">Group Id</MudTableSortLabel>

        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Group, object>(x=>x?.Code)">Code</MudTableSortLabel>

        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Group, object>(x=>x?.Description)">Description</MudTableSortLabel>

        </MudTh>
       
        <MudTh>
            <MudText Align="Align.Center">Actions</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="GroupId">
            <MudText Align="Align.Center">@context.GroupId</MudText>
        </MudTd>
        <MudTd DataLabel="Code">
            <MudText Align="Align.Center">@context.Code</MudText>
        </MudTd>
        <MudTd DataLabel="Description">
            <MudText Align="Align.Center">@context.Description</MudText>
        </MudTd>
       
        <MudTd>
            <MudText Align="Align.Center">
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => UpdateGroup(context.GroupId))"></MudIconButton>
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => DeleteGroup(context.GroupId))"></MudIconButton>
            </MudText>
        </MudTd>
    </RowTemplate>
</MudTable>
