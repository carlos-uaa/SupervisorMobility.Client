@page "/groups"
@inject IGroupService GroupService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource1> Localizer


@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["GroupTitle"]</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Groups table*@
<MudTable Items="_groups" Hover="true" T="Group" SortLabel="Sort By" Filter="new Func<Group,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true>

    <ToolBarContent>
        <MudGrid class="d-flex flex-column justify-center align-self-center mb-10">
            <MudItem class="d-flex justify-center align-self-center ">
                <MudText Typo="Typo.h6" Class="align-item-center center">@Localizer["GroupTitle"]</MudText>
            </MudItem>
            <MudItem Class="d-flex">
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="@Localizer["Search"]" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                <MudSpacer />

                <MudButton @onclick="(() => CreateGroup())" @ontouchstart="(() => CreateGroup())">
                    <MudText>
                        @Localizer["CreateGroup"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Plant" Color="Color.Primary"></MudIcon>
                </MudButton>

                <MudSpacer />
            </MudItem>
        </MudGrid>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Group, object>(x=>x?.GroupId)">@Localizer["GroupId"]</MudTableSortLabel>

        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Group, object>(x=>x?.Code)">@Localizer["Code"]</MudTableSortLabel>

        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Group, object>(x=>x?.Description)" InitialDirection="SortDirection.Ascending">@Localizer["Description"]</MudTableSortLabel>

        </MudTh>

        <MudTh>
            <MudText Align="Align.Center">@Localizer["Actions"]</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@Localizer["GroupId"]">
            <MudText Align="Align.Center">@context.GroupId</MudText>
        </MudTd>
        <MudTd DataLabel="@Localizer["Code"]">
            <MudText Align="Align.Center">@context.Code</MudText>
        </MudTd>
        <MudTd DataLabel="@Localizer["Description"]">
            <MudText Align="Align.Center">@context.Description</MudText>
        </MudTd>

        <MudTd>

            <MudText Align="Align.Center">
                <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                    <ActivatorContent>
                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                    </ActivatorContent>
                    <ChildContent>
                        @*<MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() =>  OpenDialog2(context.JobObservationId))" @ontouchstart="(() =>  OpenDialog2(context.JobObservationId))"> Details</MudMenuItem>*@
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdateGroup(context.GroupId))" @ontouchstart="(() => UpdateGroup(context.GroupId))">@Localizer["EditGroup"] </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => OpenDeleteDialog(context.GroupId))" @ontouchstart="(() => OpenDeleteDialog(context.GroupId))  ">@Localizer["EditGroup"]</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </MudText>


        </MudTd>
    </RowTemplate>
</MudTable>

@*Delete Gruoup modal*@
<MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["Confirm"]</MudText>
        <MudText Class="mt-4 mb-4">
            @Localizer["msgDeleteGroup"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">@Localizer["Cancel"]</MudButton>
        <MudButton @onclick="(() => DeleteGroup(deleteGroupId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">@Localizer["Delete"]</MudButton>
    </DialogActions>
</MudDialog>
