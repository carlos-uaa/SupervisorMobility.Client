    private Func<HeadCountProcess, bool> _quickFilterProcess => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (x.HeadCountProcessId.ToString().Contains(_searchString.ToLower(), StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.Process.ToLower().Contains(_searchString.ToLower(), StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    };

