        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro StartedEditing : {ex.Message}");
        }
        finally
        {
            showLoading = false;
            tabs.ActivatePanel(panel03_Edit);
        }

    }
    private void StartedEditingProcess(HeadCountProcess item)
    {
        Console.WriteLine($"Ediciones vrgs");

        try
        {
            showLoading = true;
            _IdUpdateProcess = item.HeadCountProcessId;
            ProcessSelected = ObjectCloner.ObjectCloner.DeepClone(item);
