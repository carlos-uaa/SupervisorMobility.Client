    private async Task<AsyncVoidMethodBuilder> InstanceData()
    {

        try
        {
            showLoading = true;
            if (HeadCountData?.Count == 0)
            {
                HeadCountData = await HeadCountServices.GetAllHeadCout();
            }
            else if (_AfterUpdate)
            {
                var indexHead = HeadCountData.FindIndex(h => h.HeadCountId == _headCountUpdate.HeadCountId);
                HeadCountData[indexHead] = _headCountUpdate;
                _AfterUpdate = false;
                _IdUpdate = -1;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro Instance Function: {ex.Message}");
        }
        finally
        {
            showLoading = false;
        }

        return new AsyncVoidMethodBuilder();
    }


