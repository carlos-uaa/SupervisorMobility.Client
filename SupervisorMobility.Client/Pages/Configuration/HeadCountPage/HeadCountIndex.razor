                            <col />
                            <col />
                            <col />
                        </ColGroup>
                        <ToolBarContent>
            <MudText Typo="Typo.h6" Align="Align.Center"></MudText>
            <MudSpacer />
            <MudTextField @bind-Value="@_searchString" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-2"></MudTextField>
            <MudSpacer />
            <MudText Typo="Typo.h6" Align="Align.Center"></MudText>
        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.HeadCountId)" Enabled="true">@Localizer1["HCId"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.Codigo)" Enabled="true">@Localizer1["HCSSFF"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.CO)" Enabled="true">@Localizer1["HCCO"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.ID_Area)" Enabled="true">@Localizer1["HCIDAreaCompas"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.Nombre_Area)" Enabled="true">@Localizer1["HCNameAreaCompas"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.Cost_center)" Enabled="true">@Localizer1["HCCostCenter"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.ID_Departamento)" Enabled="true">@Localizer1["HCIDDepartamentoCompas"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.Nombre_Departamento)" Enabled="true">@Localizer1["HCNameDepartamentoCompas"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.ID_subarea)" Enabled="true">@Localizer1["HCIDSubAreaCompas"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.nombre_subarea)" Enabled="true">@Localizer1["HCNameSubAreaCompas"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.Fuction_Type)" Enabled="true">@Localizer1["HCFuncionCompas"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.Nivel)" Enabled="true">@Localizer1["HCNivelEmpleado"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.Group)" Enabled="true">@Localizer1["HCGrupo"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.BUDGET)" Enabled="true">@Localizer1["HCROR/Offline"]</MudTableSortLabel>                            </MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.RTO)" Enabled="true">@Localizer1["HCRTO"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.HC)" Enabled="true">@Localizer1["HCSSF"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.Comentarios)" Enabled="true">@Localizer1["HCComentario"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.LABOR_TYPE)" Enabled="true">@Localizer1["HCTipoContratacion"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.Fecha_de_alta)" Enabled="true">@Localizer1["HCFechaAlta"]</MudTableSortLabel></MudTh>
                            <MudTh>                                <MudTableSortLabel SortBy="new Func<HeadCount, object>(x=>x.UserUploadId)" Enabled="true">@Localizer1["HCUserAlta"]</MudTableSortLabel></MudTh>
                        </HeaderContent>
                        <GroupHeaderTemplate>
                            <MudTh Class="mud-table-cell-custom-group" colspan="20">@($"{context.GroupName}: {context.Key}") </MudTh>
                        </GroupHeaderTemplate>
                        <RowTemplate>
                            <MudTd DataLabel="@Localizer1["HCId"]">@context.HeadCountId </MudTd>
                            <MudTd DataLabel="@Localizer1["HCSSFF"]">@context.Codigo </MudTd>
                            <MudTd DataLabel="@Localizer1["HCCO"]">@context.CO </MudTd>
                            <MudTd DataLabel="@Localizer1["HCIDAreaCompas"]">@context.ID_Area </MudTd>
                            <MudTd DataLabel="@Localizer1["HCNameAreaCompas"]">@context.Nombre_Area </MudTd>
                            <MudTd DataLabel="@Localizer1["HCCostCenter"]">@context.Cost_center </MudTd>
                            <MudTd DataLabel="@Localizer1["HCIDDepartamentoCompas"]">@context.ID_Departamento </MudTd>
                            <MudTd DataLabel="@Localizer1["HCNameDepartamentoCompas"]">@context.Nombre_Departamento </MudTd>
