    private async Task GetUserAsync()
    {
        if (!await TryGetAsync())
            loggedUser = new();
    }

    private async Task<bool> TryGetAsync()
    {
        bool hasProperty = await HasPropertyAsync();
        if (hasProperty)
        {
            json = await JS.InvokeAsync<string>("localStorage.getItem", "user");
            loggedUser = JsonSerializer.Deserialize<User>(json) ?? new();
        }
        return hasProperty;
    }

    private async Task<bool> HasPropertyAsync()
        => await JS.InvokeAsync<bool>("localStorage.hasOwnProperty", "user");

    async Task OnChange(InputFileChangeEventArgs e)
    {
        showUpload = true;
        //Clear Data
        FileName = string.Empty;
        FileSource = null;
        await Clear();

        //Assign new data
        FileName = e.File.Name;
        FileSource = e.File;

        fileNames.Add(new FileToDisplay() { name = FileName, ftype = FileName.Split(".").Last() });


        using var content = new MultipartFormDataContent();

        var fileContent = new StreamContent(e.File.OpenReadStream(509600000));
        fileContent.Headers.ContentType = new MediaTypeHeaderValue(e.File.ContentType);

        MemoryStream ms = new MemoryStream();
        await fileContent.CopyToAsync(ms);

        showUpload = false;


    }//end function on change

    async void UploadFunction(bool overlord)
    {

        showLoading = true;
        base.StateHasChanged();
        await Task.Delay(50);
        using var content = new MultipartFormDataContent();

        if (FileSource is not null)
        {

            var fileContent = new StreamContent(FileSource.OpenReadStream(509600000));
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(FileSource.ContentType);

            content.Add(
            content: fileContent,
            name: "\"file\"",
            fileName: FileSource.Name);

            var newUploadResults = await HeadCountServices.UploadHeadCount(content, loggedUser.UserId);

            if (newUploadResults is not null)
            {

                ErrorMessageToDisplay = "Upload Data Succesfull";

                showLoading = false;
                showUpload = false;
                DialgUploadDocumentOk = true;

                base.StateHasChanged();

                //aqui va el dialogo para mostrar al usuario

                //Se esta procesando el documento
                //se notificara mediante notificacion de supervisor y se enviara un correo (Mostrar correo)


                // InstanceData();
                // tabs.ActivatePanel(panel02_View);
            }
            else
            {
                ErrorMessageToDisplay = $"{@Localizer1["HCFailUpload"]}";

                //error al subir el archivo
            }

        }
        else
        {
            ErrorMessageToDisplay = $"{@Localizer1["HCSourceNull"]}";
        }



    }//upload function

    private async Task Clear()
    {

        fileNames.Clear();
        ClearDragClass();
        await Task.Delay(100);
