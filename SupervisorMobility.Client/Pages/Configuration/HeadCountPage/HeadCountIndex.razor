                        </tr>
                        <tr>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
                        </tr>
                        <tr>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
                        </tr>
                        <tr>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /><MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
                        </tr>
                        <tr>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Text" /></td>
                            <td><MudSkeleton SkeletonType="SkeletonType.Rectangle" /> <MudSpacer />   <MudSkeleton SkeletonType="SkeletonType.Rectangle" /> <MudSpacer />  <MudSkeleton SkeletonType="SkeletonType.Rectangle" /></td>
                        </tr>

                    </tbody>
                </MudSimpleTable>

            }
            else
            {
                @if (HeadCountData?.Count == 0)
                {
                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full mt-10">
                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                            <img src="Images/navegador.png" Height="140" Width="140" />
                        </MudItem>

                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name">@Localizer1["NoHCDataTitle"]</MudText>

                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer1["NoHCDataMsg"]</MudText>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                }
                else
                {
                    <MudTable SortLabel="SortBy" Hover="true" Breakpoint="Breakpoint.Sm"
                              Items="@HeadCountData" Filter="@_quickFilter"
                              GroupBy="@_groupDefinition"
                              GroupHeaderStyle="background-color:var(--mud-palette-background-grey)"
                              GroupFooterClass="mb-4"
                              Dense="true" FixedHeader="true"
                              Virtualize="true" 
                              RowClassFunc="@SelectedRowClassFunc" @ref="ReferenceGrid"
                              Height="65vh" HorizontalScrollbar="true" Class="mud-width-full styled-table table-striped">
                        <ColGroup>
                            <col style="width: 60px;" />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
                            <col />
