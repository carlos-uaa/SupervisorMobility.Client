    <MudTabPanel @ref="panel03_Edit" Icon="@Icons.Material.Filled.Edit" Text="@Localizer1["EditHeadCout"]" BadgeData='"🡣"' BadgeColor="Color.Warning">
        <ChildContent>
            @if (_IdUpdate != -1)
            {
                <MudPaper Class="pa-6" Elevation="1" MaxHeight="70vh" Style="overflow-x: scroll;">
                    <EditForm Model="_headCountUpdate" OnValidSubmit="UpdateHeadCountFunc" @bind-IsValid="@success">
                        <MudTextField T="int" Label="@Localizer1["HCId"]" Required="true" RequiredError="@Localizer1["HCIdError"]" Validation="@(new Func<int, string>(IntGreaterThanZero))"
                        @bind-Value="_headCountUpdate.Codigo" For="@(() => _headCountUpdate.Codigo)" />
                        <MudTextField T="string" Label="@Localizer1["HCCO"]" Required="true" RequiredError="@Localizer1["HCCOError"]" Validation="@(new Func<string, string>(StringNoNull))"
                        @bind-Value="_headCountUpdate.CO" For="@(() => _headCountUpdate.CO)" />

                        <MudTextField T="int?" Label="@Localizer1["HCIDAreaCompas"]" Required="true" RequiredError="@Localizer1["HCIDAreaCompasError"]" Validation="@(new Func<int, string>(IntGreaterThanZero))"
                        @bind-Value="_headCountUpdate.ID_Area" For="@(() => _headCountUpdate.ID_Area)" />
                        <MudTextField T="string" Label="@Localizer1["HCNameAreaCompas"]" Required="true" RequiredError="@Localizer1["HCNameAreaCompasError"]" Validation="@(new Func<string, string>(StringNoNull))"
                        @bind-Value="_headCountUpdate.Nombre_Area" For="@(() => _headCountUpdate.Nombre_Area)" />


                        <MudTextField T="int?" Label="@Localizer1["HCCostCenter"]" Required="true" RequiredError="@Localizer1["HCCostCenterError"]" Validation="@(new Func<int, string>(IntGreaterThanZero))"
                        @bind-Value="_headCountUpdate.Cost_center" For="@(() => _headCountUpdate.Cost_center)" />
                        <MudTextField T="string" Label="@Localizer1["HCIDDepartamentoCompas"]" Required="true" RequiredError="@Localizer1["HCIDDepartamentoCompasError"]" Validation="@(new Func<string, string>(StringNoNull))"
                        @bind-Value="_headCountUpdate.ID_Departamento" For="@(() => _headCountUpdate.ID_Departamento)" />
                        <MudTextField T="string" Label="@Localizer1["HCNameDepartamentoCompas"]" Required="true" RequiredError="@Localizer1["HCNameDepartamentoCompasError"]" Validation="@(new Func<string, string>(StringNoNull))"
                        @bind-Value="_headCountUpdate.Nombre_Departamento" For="@(() => _headCountUpdate.Nombre_Departamento)" />

                        <MudTextField T="int?" Label="@Localizer1["HCIDSubAreaCompas"]" Required="true" RequiredError="@Localizer1["HCIDSubAreaCompasError"]" Validation="@(new Func<int, string>(IntGreaterThanZero))"
                        @bind-Value="_headCountUpdate.ID_subarea" For="@(() => _headCountUpdate.ID_subarea)" />
