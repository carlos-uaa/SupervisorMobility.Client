    private void RowClickedProcess(DataGridRowClickEventArgs<HeadCountProcess> args)
    {
        
        if (selectedRowNumber == args.RowIndex)
        {

            selectedRowNumber = -1;

            if (ReferenceGridProcess.SelectedItem != null && ReferenceGridProcess.SelectedItem.Equals(args.Item))
            {
                ProcessSelected = ObjectCloner.ObjectCloner.DeepClone(args.Item);
                tabsProcess.ActivatePanel(panel02_ViewEditProcess);
            }

        }
        else if (ReferenceGridProcess.SelectedItem != null && ReferenceGridProcess.SelectedItem.Equals(args.Item))
        {
            _IdUpdateProcess = args.Item.HeadCountProcessId;
            ProcessSelected = ObjectCloner.ObjectCloner.DeepClone(args.Item);
            selectedRowNumber = args.RowIndex;
        }
        else
        {
            _IdUpdateProcess = -1;
            selectedRowNumber = -1;
        }

    }

   

