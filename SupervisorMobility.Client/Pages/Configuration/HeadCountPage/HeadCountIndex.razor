        }

    }

    private string StringNoNull(string arg)
    {
        if (arg.Trim() == "")
            return $"{@Localizer1["HCValidationString"]}";

        return null;
    }

    private string IntGreaterThanZero(int arg)
    {
        if (arg < 0)
            return $"{@Localizer1["HCValidationInt"]}";


        return null;
    }

    private async void UpdateHeadCountFunc()
    {
        success = false;

        _headCountUpdate.UserUploadId = loggedUser.UserId;
        _headCountUpdate.Usuario_de_alta = loggedUser.Name;
        _headCountUpdate.Fecha_de_alta = DateTime.Now;

        var updateResponse = await HeadCountServices.UpdateHeadCount(_headCountUpdate, _IdUpdate);


        if (updateResponse)
        {
            _searchString = _headCountUpdate.Codigo.ToString();
            _AfterUpdate = true;
            await InstanceData();
            tabs.ActivatePanel(panel02_View);
            StateHasChanged();
        }
        else
        {
            //error
        }


    }

    private async Task<AsyncVoidMethodBuilder> StartProcess()
    {
        try
        {

            showLoading = true;
            ProcessUpdate = false;
            if (_allProcess?.Count == 0)
            {
                _allProcess = await HeadCountServices.GetAllHeadCountProcesses();
            }


        }
        finally
        {
            showLoading = false;
            base.StateHasChanged();
        }

        return new AsyncVoidMethodBuilder();
    }

    private async void CreateProcess()
    {
        var createResponse = await HeadCountServices.CreateHeadCountPorcess(ProcessToCreate);


        if (createResponse != null)
        {
            _allProcess.Add(createResponse);
            ProcessToCreate = new();
            base.StateHasChanged();
            tabsProcess.ActivatePanel(panel01_SeeAllProcess);
        }
        else
        {
            //Mensaje de error
        }
    }



    private async void UpdateProcess()
    {

        var updateResponse = await HeadCountServices.UpdateHeadCountProcesses(ProcessSelected, ProcessSelected.HeadCountProcessId);

        if (updateResponse)
        {

            var indexHead = _allProcess.FindIndex(h => h.HeadCountProcessId == ProcessSelected.HeadCountProcessId);
            _allProcess[indexHead] = ProcessSelected;

            _IdUpdateProcess = -1;

            ProcessUpdate = false;
            base.StateHasChanged();
            tabsProcess.ActivatePanel(panel01_SeeAllProcess);
            //mensaje de sucess
        }
        else
        {
            //mensaje de error
        }

    }

