    private int selectedRowNumber = -1;
    private MudDataGrid<HeadCount> ReferenceGrid;

    private void RowClicked(DataGridRowClickEventArgs<HeadCount> args)
    {

        if (selectedRowNumber == args.RowIndex)
        {

            selectedRowNumber = -1;

            if (ReferenceGrid.SelectedItem != null && ReferenceGrid.SelectedItem.Equals(args.Item))
            {
                _headCountUpdate = ObjectCloner.ObjectCloner.DeepClone(args.Item);
                tabs.ActivatePanel(panel03_Edit);
            }

        }
        else if (ReferenceGrid.SelectedItem != null && ReferenceGrid.SelectedItem.Equals(args.Item))
        {
            _IdUpdate = args.Item.HeadCountId;
            _headCountUpdate = ObjectCloner.ObjectCloner.DeepClone(args.Item);
            selectedRowNumber = args.RowIndex;
        }
        else
        {
            _IdUpdate = -1;
            selectedRowNumber = -1;
        }

    }

