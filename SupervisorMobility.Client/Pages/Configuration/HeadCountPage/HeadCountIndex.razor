@page "/headCount"

@using System.Net.Http.Headers;
@using System.Runtime.CompilerServices;
@inject IStringLocalizer<Resource> Localizer
@inject IStringLocalizer<Resource1> Localizer1
@inject IHeadCountService HeadCountServices
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer1["HeadcountTitle"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-2" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

<MudTabs @ref="tabs" Elevation="4" Color="@Color.Info" TabPanelClass="px-10 mx-10" Rounded="true" ApplyEffectsToContainer="true" Centered="true">

    <MudTabPanel @ref="panel01_Upload" Icon="@Icons.Material.Filled.UploadFile" Text="@Localizer1["UploadHeadCount"]" BadgeData='"🡩"' BadgeColor="Color.Success">
        <ChildContent>
            <MudContainer Fixed="true" Class="py-3 mt-10">
                <MudGrid>
                    <MudItem xs="2" xl="2" class="align-center justify-center mud-width-full">
                        <MudImage Src="Images/uploadcloud.png" Alt="Imagen Upload Clou" Height="120" Width="120"></MudImage>

                    </MudItem>
                    <MudItem id="Upload" xs="10" xl="10" class="d-flex flex-column">
                        <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">


                            <MudSpacer />
                            <MudItem class="d-flex flex-column flex-column justify-center" style="height:100% ;     max-width: 60vw;    min-width: 40vw;">


                                @if (showLoading)
                                {
                                    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
                                        <ItemTemplate>
                                            <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                                                <MudItem class="d-flex flex-column justify-center align-self-center">
                                                    <MudProgressCircular Color="@_Colors[context.IndexOf(context)]" Style="height:70px;width:70px;" Indeterminate="true" />
                                                </MudItem>
                                                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                                                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@context</MudText>
                                            </div>
                                        </ItemTemplate>
                                    </MudCarousel>
                                }
                                @if (showUpload)
                                {
                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                }
                            </MudItem>
                            <MudSpacer />


                        </MudItem>
                        <MudItem Class="d-flex flex-column align-center justify-center">
                            @*File Upload*@
                            <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
                                <InputFile id="input" OnChange="@OnChange" hidden single></InputFile>



                            </MudItem>
                            <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
                                <MudTextField Class="flex-initial d-flex flex-grow-1 px-9" Width="60%" @bind-Value="@FileName" Label="File Name" Variant="Variant.Outlined" Disabled="true" />
                                <MudButton Class="flex-initial d-flex flex-grow-0 px-9 py-2" Width="20%"
                                           HtmlTag="label"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.CloudUpload"
                                           for="input">
                                    @Localizer1["ACUploadFiles"]
                                </MudButton>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                </MudGrid>

                <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
                    <MudStack Style="width: 80%">
                        <MudFileUpload T="IReadOnlyList<IBrowserFile>" OnFilesChanged="OnChange" Hidden="false" Class="flex-1" InputClass="absolute mud-width-full mud-height-full overflow-hidden z-20" InputStyle="opacity:0"
                        @ondragenter="@SetDragClass" @ondragleave="@ClearDragClass" @ondragend="@ClearDragClass">
                            <ButtonTemplate Context="DragAndDrop">
                                <MudPaper Height="200px" Outlined="true" Class="@DragClass">
                                    <MudText Typo="Typo.h6">@Localizer1["DragAndDrop"]</MudText>
                                    @foreach (var file in fileNames)
                                    {
                                        <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center">
                                            <MudText Typo="Typo.h6">@file.message</MudText>

                                            @switch (file.ftype)
                                            {
                                                case "xls":
                                                    <img src="Images/xls.png" Height="70" Width="70" />
                                                    break;
                                                case "xlsx":
                                                    <img src="Images/xlsx.png" Height="70" Width="70" />
                                                    break;
                                                case "csv":
                                                    <img src="Images/csv.png" Height="70" Width="70" />
                                                    break;
                                                default:
                                                    <img src="Images/error.png" Height="70" Width="70" />
                                                    break;
                                            }

                                            <MudChip Color="Color.Info" Text="@file.name" />
                                        </MudItem>
                                    }
                                </MudPaper>
                            </ButtonTemplate>
                        </MudFileUpload>
                    </MudStack>
                </MudItem>
                <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
                    <MudStack Style="width: 80%">
                        <MudToolBar DisableGutters="true" Class="gap-4">
                            <MudButton OnClick="@(() => UploadFunction(showUpload = true))" Disabled="@(!fileNames.Any())" Color="Color.Primary" Variant="Variant.Filled">@Localizer1["UploadHeadCount"]</MudButton>
                            <MudButton OnClick="Clear" Disabled="@(!fileNames.Any())" Color="Color.Error" Variant="Variant.Filled">@Localizer1["ClearFileHeadCount"]</MudButton>
                        </MudToolBar>
                    </MudStack>
                </MudItem>


            </MudContainer>
        </ChildContent>
    </MudTabPanel>
    <MudTabPanel @ref="panel02_View" Icon="@Icons.Material.Filled.BubbleChart" Text="@Localizer1["ViewHeadCount"]" OnClick="InstanceData">
        <ChildContent>

            @if (showLoading)
            {

                <MudCarousel Class="mud-width-full styled-table table-striped" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
                    <ItemTemplate>
                        <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                            <MudItem class="d-flex flex-column justify-center align-self-center">
                                <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                            </MudItem>
                            @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                            <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
