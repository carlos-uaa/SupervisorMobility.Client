@page "/checklistcategories"
@inject IChecklistService ChecklistService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@*Title*@
<PageTitle>Supervisor Mobility | Checklist Categories</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Checklist categories table*@
<MudTable Items="_checklistCategories" Hover="true" T="ChecklistCategory" SortLabel="Sort By" Filter="new Func<ChecklistCategory,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true>
    <ToolBarContent>
        <MudGrid class="d-flex flex-column justify-center align-self-center mb-10">
            <MudItem class="d-flex justify-center align-self-center ">
                <MudText Typo="Typo.h6" Class="align-item-center center">Checklist categories</MudText>
            </MudItem>
            <MudItem Class="d-flex">
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    
                <MudSpacer />
                <MudButton Href="/checklistcategory/createcategory">
                    <MudText>Create Checklist Category</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Plant" Color="Color.Primary"></MudIcon>
                </MudButton>
                <MudSpacer />
                <MudButton Href="/checklistcategories/sequence">
                    <MudText>Re order</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Reorder" aria-label="Create Plant" Color="Color.Primary"></MudIcon>
                </MudButton>
                <MudSpacer />
            </MudItem>
        </MudGrid>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<ChecklistCategory, object>(x=>x?.Code)">Category Id</MudTableSortLabel>

        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<ChecklistCategory, object>(x=>x?.Code)">Code</MudTableSortLabel>

        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<ChecklistCategory, object>(x=>x?.Description)">Description</MudTableSortLabel>

        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<ChecklistCategory, object>(x=>x?.Sequence)">Sequence</MudTableSortLabel>

        </MudTh>
       @* <MudTh>

            <MudTableSortLabel SortBy="new Func<ChecklistCategory, object>(x=>x?.IsActive)">Status</MudTableSortLabel>

        </MudTh>*@
        <MudTh>
            <MudText Align="Align.Center">Actions</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="CategoryId">
            <MudText Align="Align.Center">@context.ChecklistCategoryId</MudText>
        </MudTd>
        <MudTd DataLabel="Code">
            <MudText Align="Align.Center">@context.Code</MudText>
        </MudTd>
        <MudTd DataLabel="Description">
            <MudText Align="Align.Center">@context.Description</MudText>
        </MudTd>
        <MudTd DataLabel="Sequence">
            <MudText Align="Align.Center">@context.Sequence</MudText>
        </MudTd>
      @*  <MudTd DataLabel="Status">
            @if (context.IsActive == true)
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                </MudText>
            }
            else
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                </MudText>
            }
        </MudTd>*@
        <MudTd>
            <MudText Align="Align.Center">
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => CategoryDetails(context.ChecklistCategoryId))"></MudIconButton>
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => UpdateCategory(context.ChecklistCategoryId))"></MudIconButton>
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => DeleteCategory(context.ChecklistCategoryId))"></MudIconButton>
            </MudText>
        </MudTd>
    </RowTemplate>
</MudTable>