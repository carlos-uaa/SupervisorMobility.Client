@page "/checklistcategories/category/updatecategory/{categoryId:int}"
@inject IChecklistService ChecklistService
@inject NavigationManager NavigationManager

@*Title*@
<PageTitle>Supervisor Mobility | Update Category</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == "UpdateCategory")
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">Update @_checklistCategory.Description</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_checklistCategory" OnValidSubmit="UpdateCategory">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Category details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Info">Update category</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="Plant description"
                                  @bind-Value="_checklistCategory.Description" For="@(() => _checklistCategory.Description)" />
                    <MudTextField Label="Code" Class="mt-3"
                                  @bind-Value="_checklistCategory.Code" For="@(() => _checklistCategory.Code)" />
                    <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_checklistCategory.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Href="/checklistcategories" Variant="Variant.Filled" Class="ml-4">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>