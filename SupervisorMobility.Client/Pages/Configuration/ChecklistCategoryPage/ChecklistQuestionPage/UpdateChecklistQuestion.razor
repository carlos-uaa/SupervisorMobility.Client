@page "/checklistcategories/category/{categoryId:int}/updatequestion/{questionId:int}"
@inject IChecklistService ChecklistService
@inject IQuestionTypeService QuestionTypeService
@inject NavigationManager NavigationManager
@inject IPillarService PillarsService
@inject IStringLocalizer<Resource> Localizer

@*Title*@
<PageTitle>Supervisor Mobility | Update Question</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == "CategoryDetail")
        {
            <MudButton @onclick="(() => CancelCreateOrUpdate())" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@_checklistCategory.Description</MudButton>
        }
        else if (item.Text == "UpdateQuestion") 
        {
            <MudButton Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">Update @_question.Prompt</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_question" OnValidSubmit="UpdateQuestionAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Question details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Info">Update question</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="Question Prompt"
                    @bind-Value="_question.Prompt" For="@(() => _question.Prompt)" />
                    @*Mud select for Pillar for Admin*@
                    <MudSelect T="int" Label=@Localizer["pillar"] Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_question.PillarId" For="@(() => _question.PillarId)">
                        <MudSelectItem Disabled="true" Value="0">@Localizer["selectAPillar"]</MudSelectItem>
                        @foreach (var type in _pillars)
                        {
                            <MudSelectItem Value="type.PillarId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                        }
                    </MudSelect>
                    <MudTextField Label="Question Not Good" Class="mt-3"
                    @bind-Value="_question.NotGood" For="@(() => _question.NotGood)" />
                    @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_question.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>