@page "/product/{productId:int}/distributions/createdistribution"
@inject IProductService ProductService
@inject IProductOperationService ProductOperationService
@inject IProductDistributionService ProductDistributionService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@*Title*@
<PageTitle>Supervisor Mobility | Create Distribution</PageTitle>
<MudText>Hola</MudText>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == "ProductsDetail")
        {
            <MudButton @onclick="(() => GoToProduct())" Variant="Variant.Text" Color="Color.Info">@_product.Description</MudButton>
        }
        else if (item.Text == "CreateDistribution")
        {
            <MudButton Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_distribution" OnValidSubmit="CreateDistributionAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Distribution details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">New distribution</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="Distribution description"
                                  @bind-Value="_distribution.Description" For="@(() => _distribution.Description)" />
                    <MudTextField Label="Code" Class="mt-3"
                                  @bind-Value="_distribution.Code" For="@(() => _distribution.Code)" />
                    <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_distribution.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>