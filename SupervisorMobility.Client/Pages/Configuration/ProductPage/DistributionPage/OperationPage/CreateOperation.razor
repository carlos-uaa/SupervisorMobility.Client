@page "/product/{productId:int}/distributions/{distributionId:int}/createoperation"
@inject IProductService ProductService
@inject IProductOperationService ProductOperationService
@inject IProductDistributionService ProductDistributionService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@*Title*@
<PageTitle>Supervisor Mobility | Create Operation</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == "ProductDetail")
        {
            <MudButton @onclick="(() => GoToProducts())" Variant="Variant.Text" Color="Color.Info">@_product.Description</MudButton>
        }
        else if (item.Text == "DistributionDetail")
        {
            <MudButton @onclick="(() => GoToDistribution())" Variant="Variant.Text" Color="Color.Info">@_distribution.Description</MudButton>
        }
        else if (item.Text == "CreateOperation")
        {
            <MudButton Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs>
@*Form*@
<EditForm Model="_operation" OnValidSubmit="CreateOperationAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Operation details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">New operation</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="Operation description"
                                  @bind-Value="_operation.Description" For="@(() => _operation.Description)" />
                    <MudTextField Label="Code" Class="mt-3"
                                  @bind-Value="_operation.Code" For="@(() => _operation.Code)" />
                    <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_operation.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>