@page "/products/{productId:int}/AddDistributionInProducts"
@inject IProductService ProductServices
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource1> Localizer
@inject IBreadcrumbService BreadcrumbService

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["DistributionAddExistTitle"]</PageTitle>
@*Breadcrumb links*@
@* <MudBreadcrumbs Class="mb-1" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs> *@

    <EditForm Model="_distribution" class="mt-10" OnValidSubmit="AddingDistributionAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6"> @Localizer["DistributionAddExistTitle"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success"> @Localizer["DistributionExist"]</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Class="d-flex flex-row mb-5">
                        <MudSelect T="int" Label="@Localizer["UsersLabelPlant"]" Variant="Variant.Text"Placeholder="@Localizer["UsersPHPlant"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@PlantId" For="@(() => PlantId)" SelectedValuesChanged="UpdateAreas">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHPlant"]</MudSelectItem>
                            @foreach (var plant in _plants)
                            {
                                <MudSelectItem Value="plant.PlantId">@($"{plant.Code} - {plant.Description}")</MudSelectItem>
                            }
                        </MudSelect>

                        @*Mud select of Areas *@

                        <MudSelect T="int" Label="@Localizer["UsersLabelArea"]" Variant="Variant.Text" Placeholder="@Localizer["UsersPHArea"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@AreaId" For="@(() => AreaId)" SelectedValuesChanged="UpdateDistributions">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHArea"]</MudSelectItem>
                            @foreach (var area in _areas)
                            {
                                <MudSelectItem Value="area.AreaId">@($"{area.Code} - {area.Description}")</MudSelectItem>
                            }
                        </MudSelect>
                        @*Mud select of distributions *@

                        <MudSelect T="int" Label="@Localizer["UsersLabelDistribution"]" Placeholder="@Localizer["UsersPHDistribution"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@DistributionId" For="@(() => DistributionId)" SelectedValuesChanged="UpdateDistributionDisplay">
                            <MudSelectItem Disabled="true" Value="0">@Localizer["UsersPHDistribution"]</MudSelectItem>
                            @foreach (var type in _distributions)
                            {
                                <MudSelectItem Value="type.DistributionId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                            }
                        </MudSelect>

                    </MudGrid>
                   
                    @if(DistributionId != 0)
                    {
                        <MudGrid Class="d-flex flex-column justify-center align-self-center">
                            <MudItem>
                                <MudText Typo="Typo.h6">@Localizer["DistributionDetailsText"]</MudText>
                                
                            </MudItem>
                            <MudItem>
                                @if (useButton)
                                {
                                    <MudText Typo="Typo.h6">@Localizer["DistributionNoAdd"]</MudText>
                                }
                            </MudItem>
                            <MudItem>
                                <MudTextField Label="@Localizer["DistributionDescription"]" Disabled
                                          @bind-Value="_distribution.Description" For="@(() => _distribution.Description)" />
                                <MudTextField Label="@Localizer["DistributionCode"]" Class="mt-3" Disabled
                                          @bind-Value="_distribution.Code" For="@(() => _distribution.Code)" />
                                <MudSwitch Class="mt-3" Label="@Localizer["IsActive"]" Disabled @bind-Checked="_distribution.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />

                            </MudItem>

                        </MudGrid>
                        
                    }

                      </MudCardContent>
                <MudCardActions>
                   
                    <MudButton ButtonType="ButtonType.Submit" Disabled="useButton" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["DistributionAdd"]</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">@Localizer["Cancel"]</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>


@code {
    [Parameter]
    public int ProductId { get; set; }

    public int PlantId { get; set; }
    public int AreaId { get; set; }
    public int DistributionId { get; set; } = 0;

    public bool useButton = false;

    public Product _product { get; set; }
    public Distribution _distribution = new();


    public List<Plant> _plants { get; set; } = new List<Plant>();
    public List<Area> _areas { get; set; } = new List<Area>();
    public List<Distribution> _distributions { get; set; } = new List<Distribution>();


    protected override async Task OnParametersSetAsync()
    {
        _product = await ProductServices.GetProductAndCollection(ProductId);
        _plants = await PlantServices.GetPlants();


        _links.Add(new BreadcrumbItem($"{@Localizer["home"]}", href: $"/"));
        _links.Add(new BreadcrumbItem($"{@Localizer["configuration"]}", href: $"/configuration"));
        _links.Add(new BreadcrumbItem($"{@Localizer["products"]}", href: $"/products"));
        _links.Add(new BreadcrumbItem($"{_product.Description}", href: $"/products/{ProductId}"));
        _links.Add(new BreadcrumbItem(text: @Localizer["DistributionAddExistTitle"], href: "", disabled: true));
        BreadcrumbService.UpdateBreadcrumbs(_links);
    }

    // Breadcrumb links
    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>();


    // Cancel submit form
    void CancelCreateOrUpdate()
    {
        NavigationManager.NavigateTo($"products/{ProductId}");
    }

    async void UpdateAreas()
    {
        AreaId = 0;
        DistributionId = 0;
        _areas = await AreaServices.GetAreas(PlantId);
    }

    private async void UpdateDistributions()
    {
        DistributionId = 0;

        _distributions = await DistributionServices.GetDistributions(PlantId, AreaId);
    }

    private void UpdateDistributionDisplay()
    {

        _distribution = _distributions[_distributions.FindIndex(d => d.DistributionId == DistributionId)];

        if (_product.Distributions.Exists(d => d.DistributionId == _distribution.DistributionId) )
        {
            useButton = true;
        }
        else
        {
            useButton = false;
        }
    }

 
    // Create distribution
    async void AddingDistributionAsync()
    {
        var result = await ProductServices.AddDistribution(ProductId, PlantId, AreaId, _distribution);

        if (result != null)
        {
            NavigationManager.NavigateTo($"products/{ProductId}");
        }

    }

}
