@page "/products/{productId:int}/distribution/{distributionId:int}"
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage
@inject IUserService UsersServices
@inject IProductService ProductServices
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource1> Localizer
@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["DistributionDetailsText"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


@if (showui)
{
    <MudGrid>
        @*Guide info*@
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardContent Style="justify-content:center">
                    <MudText Align="Align.Center" Typo="Typo.h3"><MudIcon Icon="@Icons.Material.Filled.CarRepair"></MudIcon></MudText>
                  
                        <MudText Typo="Typo.h6" Align="Align.Center" Class="pa-2">@_product.Description</MudText>
                        <MudText Typo="Typo.h5" Align="Align.Center" Class="pa-2">@_product.Code</MudText>

                    @if (_product.IsActive == true)
                    {
                        <MudText Align="Align.Center" Class="pt-2">
                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["UsersActive"]</MudChip>
                        </MudText>
                    }
                    else
                    {
                        <MudText Align="Align.Center" Class="pa-4">
                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["UsersInective"]</MudChip>
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
        @*Guide*@
        <MudItem xs="12" sm="6" md="9">
            <MudGrid>
                <MudItem xs="12">
                    <MudCard>
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h5">@Localizer["DistributionDetailsText"]</MudText>

                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudItem>
                                <MudItem>
                                    <MudText Typo="Typo.h6">@Localizer["Code"]</MudText>
                                </MudItem>
                                <MudItem class="d-flex flex-column justify-center align-self-center">
                                    <MudTextField Label="@Localizer["Code"]" ReadOnly=true @bind-Value="@_distribution.Code" />
                                </MudItem>
                            </MudItem>


                            <MudItem>
                                <MudItem>
                                    <MudText Typo="Typo.h6">@Localizer["Description"]</MudText>
                                </MudItem>
                                <MudItem class="d-flex flex-column justify-center align-self-center">
                                    <MudTextField Label="@Localizer["Description"]" ReadOnly=true @bind-Value="@_distribution.Description" />
                                </MudItem>
                            </MudItem>

                            @if (_distribution.IsActive == true)
                            {
                                <MudText Align="Align.Center" Class="pt-2">
                                    <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["UsersActive"]</MudChip>
                                </MudText>
                            }
                            else
                            {
                                <MudText Align="Align.Center" Class="pa-4">
                                    <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["UsersInactive"]</MudChip>
                                </MudText>
                            }

                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => Close())">@Localizer["Close"]</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudItem>
    </MudGrid>


}
else
{


    <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
        <MudItem class="d-flex justify-center align-self-center pa-3 ma-2 ">
            <MudText Typo="Typo.h6" Class="align-item-center center">@Localizer["LoadingData"]</MudText>
        </MudItem>
        <MudPaper Class="flex d-flex-row pa-3 ma-2" Elevation="0">
            <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
        </MudPaper>
    </MudItem>
}




@code {
        [Parameter]
        public int ProductId { get; set; }
        [Parameter]
        public int DistributionId { get; set; }

    private bool showui = false;

    public Product _product { get; set; }
    public Distribution _distribution = new();
    // Breadcrumb links
    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>();


    protected override async Task OnParametersSetAsync()
    {
        _product = await ProductServices.GetProductAndCollection(ProductId);
        _distribution = _product.Distributions.Find(d => d.DistributionId == DistributionId);
        _links.Add(new BreadcrumbItem($"{@Localizer["home"]}", href: $"/"));
        _links.Add(new BreadcrumbItem($"{@Localizer["configuration"]}", href: $"/configuration"));
        _links.Add(new BreadcrumbItem($"{@Localizer["Products"]}", href: $"/products"));
        _links.Add(new BreadcrumbItem($"{_product.Description}", href: $"/products/{ProductId}"));
        _links.Add(new BreadcrumbItem($"Distributions", href: $"/products/{ProductId}"));
        _links.Add(new BreadcrumbItem($"{_distribution.Description}", href: "", disabled: true));
        showui = true;
    }


    void Close()
    {
        NavigationManager.NavigateTo($"products/{ProductId}");
    }
  


}
