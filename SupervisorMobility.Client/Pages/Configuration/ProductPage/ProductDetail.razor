@page "/products/productDetail/{productId:int}"
<h1>Product Detail @ProductId</h1>
@inject IPlantService PlantService
@inject IAreaService AreaService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@*Title*@
<PageTitle>Supervisor Mobility | @_plant.Description</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == "PlantDetail")
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@_plant.Description</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs>

@*Dashboard grid*@
<MudGrid>
    @*Plant info*@
    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent Style="justify-content:center">
                <MudText Align="Align.Center"><MudIcon Icon="@Icons.Filled.Business"></MudIcon></MudText>
                <MudText Align="Align.Center">@_plant.Code</MudText>
                <MudText Typo="Typo.h5" Align="Align.Center">@_plant.Description</MudText>
                @if (_plant.IsActive == true)
                {
                    <MudText Align="Align.Center" Class="pt-2">
                        <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                    </MudText>
                }
                else
                {
                    <MudText Align="Align.Center" Class="pa-4">
                        <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                    </MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
    @*Related areas*@
    <MudItem xs="12" sm="6" md="9">
        <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
            <MudTabPanel Icon="@Icons.Material.Filled.Build" Text="Areas">
                @if (_areas.Count > 0)
                {
                    <MudTable Items="_areas" Hover="true" T="Area">
                        <ToolBarContent>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Add" aria-label="add" @onclick="(() => CreateArea(ProductId))"></MudIconButton>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>
                                <MudText Align="Align.Center">Area Id</MudText>
                            </MudTh>
                            <MudTh>
                                <MudText Align="Align.Center">Code</MudText>
                            </MudTh>
                            <MudTh>
                                <MudText Align="Align.Center">Description</MudText>
                            </MudTh>
                            <MudTh>
                                <MudText Align="Align.Center">Status</MudText>
                            </MudTh>
                            <MudTh>
                                <MudText Align="Align.Center">Actions</MudText>
                            </MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="PlantId">
                                <MudText Align="Align.Center">@context.AreaId</MudText>
                            </MudTd>
                            <MudTd DataLabel="Code">
                                <MudText Align="Align.Center">@context.Code</MudText>
                            </MudTd>
                            <MudTd DataLabel="Code">
                                <MudText Align="Align.Center">@context.Description</MudText>
                            </MudTd>
                            <MudTd DataLabel="Status">
                                @if (context.IsActive == true)
                                {
                                    <MudText Align="Align.Center">
                                        <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                                    </MudText>
                                }
                                else
                                {
                                    <MudText Align="Align.Center">
                                        <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                                    </MudText>
                                }
                            </MudTd>
                            <MudTd>
                                <MudText Align="Align.Center">
                                    <MudIconButton Icon="@Icons.Material.Filled.Info" aria-label="info" @onclick="(() => AreaDetails(ProductId, context.AreaId))"></MudIconButton>
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit" @onclick="(() => UpdateArea(ProductId, context.AreaId))"></MudIconButton>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="delete" @onclick="(() => DeleteArea(context.AreaId))"></MudIconButton>
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">There are no areas created for this plant.</MudText>
                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">
                        <MudButton Color="Color.Info" @onclick="(() => CreateArea(ProductId))">Create a new area</MudButton>
                    </MudText>
                }
            </MudTabPanel>
        </MudTabs>
    </MudItem>
</MudGrid>
