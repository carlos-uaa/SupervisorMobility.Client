@page "/products/{productId:int}"
@inject IProductService ProductService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource1> Localizer
@inject IBreadcrumbService BreadcrumbService

@*Title*@
<PageTitle>Supervisor Mobility | @_product.Description</PageTitle>

@*Breadcrumb links*@
@* <MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == "ProductsDetail")
        {
            <MudButton Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@_product.Description</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs> *@

@*Dashboard grid*@
<MudGrid Class="mt-10">
    @*Area info*@
    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent Style="justify-content:center">
                <MudText Align="Align.Center"><MudIcon Icon="@Icons.Material.Filled.Business"></MudIcon></MudText>
                <MudText Align="Align.Center">@_product.Code</MudText>
                <MudText Typo="Typo.h5" Align="Align.Center">@_product.Description</MudText>
                @if (_product.IsActive == true)
                {
                    <MudText Align="Align.Center" Class="pt-2">
                        <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["UsersActive"]</MudChip>
                    </MudText>
                }
                else
                {
                    <MudText Align="Align.Center" Class="pa-4">
                        <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["UsersInactive"]</MudChip>
                    </MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
    @*Related distributions*@
    <MudItem xs="12" sm="6" md="9">
        <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
            <MudTabPanel Icon="@Icons.Material.Filled.ContentPaste" Text="@Localizer["ProductsDistributions"]">
                @if (_product.Distributions.Count > 0)
                {
                    <MudTable Height="80vh" Items="_product.Distributions" Hover="true" T="Distribution" RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" OnRowClick="RowClickEvent" Filter="new Func<Distribution,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true>
                        <ToolBarContent>
                            <MudGrid class="d-flex flex-column justify-center align-self-center">

                                <MudItem Class="d-flex">
                                    <MudSpacer />
                                    <MudTextField @bind-Value="searchString" Placeholder="@Localizer["Search"]" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                                    <MudSpacer />

                                    <MudButton @onclick="(() => CreateDistribution())">
                                        <MudText>@Localizer["ProductsCreateDistribution"]</MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.Downloading" Color="Color.Warning"></MudIcon>
                                    </MudButton>
                                    <MudSpacer />
                                    <MudButton @onclick="(() => AddExistDistribution())">
                                        <MudText>@Localizer["ProductsAddDistribution"]</MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.NoteAdd" Color="Color.Warning"></MudIcon>
                                    </MudButton>
                                    <MudSpacer />

                                </MudItem>
                            </MudGrid>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<Distribution, object>(x=>x.DistributionId)">
                                    @Localizer["DistributionId"]
                                </MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<Distribution, object>(x=>x.Code)">
                                    @Localizer["DistributionCode"]
                                </MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<Distribution, object>(x=>x.Description)" InitialDirection="SortDirection.Ascending">
                                    @Localizer["DistributionDescription"]
                                </MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<Distribution, object>(x=>x.IsActive)" >
                                    @Localizer["DistributionStatus"]
                                </MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudText Align="Align.Center">@Localizer["Actions"]</MudText>
                            </MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@Localizer["DistributionId"]">
                                <MudText Align="Align.Center">@context.DistributionId</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localizer["DistributionCode"]">
                                <MudText Align="Align.Center">@context.Code</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localizer["DistributionDescriprion"]">
                                <MudText Align="Align.Center">@context.Description</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localizer["DistributionStatus"]">
                                @if (context.IsActive == true)
                                {
                                    <MudText Align="Align.Center">
                                        <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["UsersActive"]</MudChip>
                                    </MudText>
                                }
                                else
                                {
                                    <MudText Align="Align.Center">
                                        <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["UsersInactive"]</MudChip>
                                    </MudText>
                                }
                            </MudTd>
                            <MudTd>
                                <MudText Align="Align.Center">
                                    <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                        <ActivatorContent>
                                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                        </ActivatorContent>
                                        <ChildContent>
                                            <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => DistributionDetails(context.DistributionId))" @ontouchstart="(() => DistributionDetails(context.DistributionId))">@Localizer["DistributionDetails"]</MudMenuItem>
                                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdateDistribution(context.DistributionId))" @ontouchstart="(() => UpdateDistribution(context.DistributionId))">@Localizer["DistributionEdit"] </MudMenuItem>
                                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => DeleteDistribution(context.DistributionId))" @ontouchstart="(() => DeleteDistribution(context.DistributionId))">@Localizer["DistributionDelete"]</MudMenuItem>
                                        </ChildContent>
                                    </MudMenu>
                                    @*
                                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => DistributionDetails(context.DistributionId))"></MudIconButton>
                                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => UpdateDistribution(context.DistributionId))"></MudIconButton>
                                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => DeleteDistribution(context.DistributionId))"></MudIconButton>*@
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">There are no distributions created for this distribution.</MudText>
                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">
                        <MudButton Color="Color.Info" @onclick="(() => CreateDistribution())">Create a new distribution</MudButton>
                        <MudSpacer />
                        <MudButton Color="Color.Info" @onclick="(() => AddExistDistribution())">Adding a exist distribution</MudButton>

                    </MudText>
                }
            </MudTabPanel>

        </MudTabs>
    </MudItem>
</MudGrid>