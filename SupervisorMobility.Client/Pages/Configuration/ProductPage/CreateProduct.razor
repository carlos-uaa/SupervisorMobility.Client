@page "/products/createproduct"
@inject IProductService ProductService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource1> Localizer
@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["ProductsCreate"]</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_product" OnValidSubmit="CreateProductAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localizer["ProductsDetailsTitle"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["ProductsNew"]</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="@Localizer["ProductsDescription"]"
                                  @bind-Value="_product.Description" For="@(() => _product.Description)" />
                    <MudTextField Label="@Localizer["ProductsCode"]" Class="mt-3"
                                  @bind-Value="_product.Code" For="@(() => _product.Code)" />
                    @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_product.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["Save"]</MudButton>
                    <MudButton Href="/products" Variant="Variant.Filled" Class="ml-4">@Localizer["Cancel"]</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>