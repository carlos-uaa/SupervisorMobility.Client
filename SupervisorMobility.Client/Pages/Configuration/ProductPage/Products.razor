@page "/products"
@inject IProductService ProductService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource1> Localizer
@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["Products"]</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="ma-2" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


@*Products table*@
<MudTable Height="55vh" Items="_products" Hover="true" T="Product" Filter="new Func<Product,bool>(FilterFunc)" Class="styled-table table-striped mt-10" FixedHeader=true>
    <ToolBarContent>
        <MudGrid class="d-flex flex-column justify-center align-self-center mb-9">
            <MudItem class="d-flex justify-center align-self-center ">
                <MudText Typo="Typo.h6" Class="align-item-center center">@Localizer["ProductsTitle"]</MudText>
            </MudItem>
            <MudItem Class="d-flex">
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="@Localizer["Search"]" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0">Create Product</MudTextField>
                <MudSpacer />
                <MudButton @onclick="(() => CreateProduct())">
                    <MudText>@Localizer["ProductsCreate"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Add"  Color="Color.Primary"></MudIcon>
                </MudButton>
                <MudSpacer />
            </MudItem>
        </MudGrid>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Product, object>(x=>x?.ProductId)">@Localizer["ProductsId"]</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Product, object>(x=>x?.Code)">@Localizer["ProductsCode"]</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Product, object>(x=>x?.Description)">@Localizer["ProductsDescription"]</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">@Localizer["Actions"]</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@Localizer["ProductsId"]">
            <MudText Align="Align.Center">@context.ProductId</MudText>
        </MudTd>
        <MudTd DataLabel="@Localizer["ProductsCode"]">
            <MudText Align="Align.Center">@context.Code</MudText>
        </MudTd>
        <MudTd DataLabel="@Localizer["ProductsDescription"]">
            <MudText Align="Align.Center">@context.Description</MudText>
        </MudTd>
        
        <MudTd>
            <MudText Align="Align.Center">
                <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                    <ActivatorContent>
                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => ProductDetails(context.ProductId))" @ontouchstart="(() => ProductDetails(context.ProductId))">@Localizer["ProductsDetails"]</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => EditProduct(context.ProductId))" @ontouchstart="(() => EditProduct(context.ProductId))">@Localizer["ProductsEdit"] </MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => OpenDeleteDialog(context.ProductId))" @ontouchstart="(() => OpenDeleteDialog(context.ProductId))">@Localizer["ProductsDelete"]</MudMenuItem>
                    </ChildContent>
                </MudMenu>
                @*<MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => ProductDetails(context.ProductId))"></MudIconButton>
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" @onclick="(() => EditProduct(context.ProductId))"></MudIconButton>
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => OpenDeleteDialog(context.ProductId))"></MudIconButton>*@
            </MudText>
        </MudTd>
    </RowTemplate>
</MudTable>

@*Delete Product modal*@
<MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">Confirm</MudText>
        <MudText Class="mt-4 mb-4">
            @Localizer["ProductsMsgDelete"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">@Localizer["Cancel"]</MudButton>
        <MudButton @onclick="(() => DeleteProduct(deleteProductId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">@Localizer["Delete"]</MudButton>
    </DialogActions>
</MudDialog>