@page "/products"
@inject IProductService ProductService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@*Title*@
<PageTitle>Supervisor Mobility | Products</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Products table*@
<MudTable Items="_products" Hover="true" T="Product">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Products</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Add" aria-label="add" @onclick="(() => CreateProduct())"></MudIconButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudText Align="Align.Center">Product Id</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Code</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Description</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Status</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Actions</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ProductId">
            <MudText Align="Align.Center">@context.ProductId</MudText>
        </MudTd>
        <MudTd DataLabel="Code">
            <MudText Align="Align.Center">@context.Code</MudText>
        </MudTd>
        <MudTd DataLabel="Description">
            <MudText Align="Align.Center">@context.Description</MudText>
        </MudTd>
        <MudTd DataLabel="Status">
            @if (context.IsActive == true)
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                </MudText>
            }
            else
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                </MudText>
            }
        </MudTd>
        <MudTd>
            <MudText Align="Align.Center">
                 <MudIconButton Icon="@Icons.Material.Filled.Info" aria-label="info" @onclick="(() => ProductDetails(context.ProductId))"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit" @onclick="(() => EditProduct(context.ProductId))"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="delete" @onclick="(() => DeleteProduct(context.ProductId))"></MudIconButton>
            </MudText>
        </MudTd>
    </RowTemplate>
</MudTable>