@page "/Tool"
@inject IToolService ToolsServices
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IBreadcrumbService BreadcrumbService

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["Tool"]</PageTitle>

    @*Breadcrumb links*@
    @* <MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>
 *@
    @*Checklist categories table*@
    <MudTable Items="_Tools" Hover="true" T="Tool" SortLabel="Sort By" Height="80vh"
              RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" OnRowClick="RowClickEvent"
              Filter="new Func<Tool,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true>
        <ToolBarContent>
            <MudGrid class="d-flex flex-column justify-center align-self-center mb-10">
                <MudItem class="d-flex justify-center align-self-center ">
                    <MudText Typo="Typo.h6" Class="align-item-center center">@Localizer["jobstructure"]</MudText>
                </MudItem>
                <MudItem Class="d-flex">
                    <MudSpacer />
                    <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>

                    <MudSpacer />
                    <MudButton Href="/Tool/Create">
                        <MudText>@Localizer["newTool"]</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary"></MudIcon>
                    </MudButton>
                    <MudSpacer />
                </MudItem>
            </MudGrid>
        </ToolBarContent>
        <HeaderContent>
            @if (user.UserType == 1)
        {
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Tool, object>(x=>x?.ToolId)">Tool Id</MudTableSortLabel>
            </MudTh>
        }
        <MudTh>
            <MudTableSortLabel SortBy="new Func<Tool, object>(x=>x?.ToolCode)">Code</MudTableSortLabel>
        </MudTh>

        <MudTh>
            <MudTableSortLabel SortBy="new Func<Tool, object>(x=>x?.ToolName)">Name</MudTableSortLabel>

        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Actions</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ToolId">
            <MudText Align="Align.Center">@context.ToolId</MudText>
            </MudTd>
            <MudTd DataLabel="Code">
                <MudText Align="Align.Center">@context.ToolCode</MudText>
            </MudTd>
            <MudTd DataLabel="Description">
                <MudText Align="Align.Center">@context.ToolName</MudText>
            </MudTd>


            <MudTd>
                <MudText Align="Align.Center">
                    <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                        <ActivatorContent>
                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                        </ActivatorContent>
                        <ChildContent>

                            <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => ToolDetails(context.ToolId))" @ontouchstart="(() => ToolDetails(context.ToolId))">Details</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdateTool(context.ToolId))" @ontouchstart="(() => UpdateTool(context.ToolId))">Edit </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => DeleteTool(context.ToolId))" @ontouchstart="(() => DeleteTool(context.ToolId))">Delete </MudMenuItem>
                        </ChildContent>
                    </MudMenu>


                </MudText>
            </MudTd>
        </RowTemplate>
    </MudTable>
    @code {
    // Breadcrumb links
    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>();

    // Objects
    public List<Tool> _Tools { get; set; } = new();

    //User
    private string json = string.Empty;
    public User user = new();
    public bool logged = false;

    // Initialization
    protected async override Task OnInitializedAsync()
    {


        _Tools = await ToolsServices.GetTools();

        await GetUserAsync();
        logged = await HasPropertyAsync();
        if (!logged)
        {
            Snackbar.Clear();
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Add($"Error You have to log in", Severity.Error);
            NavigationManager.NavigateTo($"/");
        }

        _links = new List<BreadcrumbItem>
             {
                 new BreadcrumbItem(text: Localizer["home"], href: "/"),
                 new BreadcrumbItem(text: Localizer["configuration"], href: "/configuration"),
                            new BreadcrumbItem(text: Localizer["Tools"], href: "", disabled: true)
                        };
        BreadcrumbService.UpdateBreadcrumbs(_links);

    }

    //Local storage user
    private async Task GetUserAsync()
    {
        if (!await TryGetAsync())
            user = new();
    }

    private async Task<bool> TryGetAsync()
    {
        bool hasProperty = await HasPropertyAsync();
        if (hasProperty)
        {
            json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "user");
            user = JsonSerializer.Deserialize<User>(json) ?? new();
        }
        return hasProperty;
    }

    private async Task<bool> HasPropertyAsync()
        => await JSRuntime.InvokeAsync<bool>("localStorage.hasOwnProperty", "user");

    private string searchString = "";

    private bool FilterFunc(Tool element)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.ToolId.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.ToolCode.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.ToolName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private int selectedRowNumber = -1;
    private MudTable<Tool> SelectTableEvent;

    private void RowClickEvent(TableRowClickEventArgs<Tool> tableRowClickEventArgs)
    {
    }

    private string SelectedRowClassFunc(Tool element, int rowNumber)
    {
        if (selectedRowNumber == rowNumber)
        {
            selectedRowNumber = -1;
            if (SelectTableEvent.SelectedItem != null && SelectTableEvent.SelectedItem.Equals(element))
            {
                ToolDetails(element.ToolId);
            }
            return string.Empty;
        }
        else if (SelectTableEvent.SelectedItem != null && SelectTableEvent.SelectedItem.Equals(element))
        {
            selectedRowNumber = rowNumber;
            return "selected";
        }
        else
        {
            return string.Empty;
        }
    }

    void ToolDetails(int ToolId)
    {
        NavigationManager.NavigateTo($"Tool/Details/{ToolId}");
    }

    // Delete Tool
    async Task DeleteTool(int ToolId)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this Tool?");

        if (confirm)
        {
            _Tools.RemoveAll(Tool => Tool.ToolId == ToolId);
            await ToolsServices.DeleteTool(ToolId);
        }
    }

    // Update Tool
    void UpdateTool(int ToolId)
    {
        NavigationManager.NavigateTo($"Tool/Update/{ToolId}");
    }

}
