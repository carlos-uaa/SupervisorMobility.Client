@page "/jobobservationtypes/createjobobservationtype"
@inject IJobObservationTypeService JobObservationTypeService
@inject NavigationManager NavigationManager

@*Title*@
<PageTitle>Supervisor Mobility | Create Job Observation Type</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_jobObservationType" OnValidSubmit="CreateJobObservationTypeAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Job observation type details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">New Job Observation Type</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="Job observation type description"
                                  @bind-Value="_jobObservationType.Description" For="@(() => _jobObservationType.Description)" />
                    <MudTextField Label="Code" Class="mt-3"
                                  @bind-Value="_jobObservationType.Code" For="@(() => _jobObservationType.Code)" />
                    <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_jobObservationType.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Href="/jobobservationtypes" Variant="Variant.Filled" Class="ml-4">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>