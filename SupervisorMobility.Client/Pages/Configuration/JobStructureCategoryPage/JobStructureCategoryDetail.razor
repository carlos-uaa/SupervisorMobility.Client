@page "/checklistcategories/category/{categoryId:int}"
@inject IJobStructureService JobStructureCategoriesService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService

@*Title*@
<PageTitle>Supervisor Mobility | @_checklistCategory.Description</PageTitle>

@*Breadcrumb links*@
@* <MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == "CategoryDetail")
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@_checklistCategory.Description</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs> *@

@*Dashboard grid*@
    <MudGrid class="mt-2">
    @*Plant info*@
    <MudItem xs="12" sm="6" md="3">
        <MudCard>
            <MudCardContent Style="justify-content:center">
                <MudText Align="Align.Center"><MudIcon Icon="@Icons.Filled.ViewList"></MudIcon></MudText>
                <MudText Align="Align.Center">@_checklistCategory.Code</MudText>
                <MudText Typo="Typo.h5" Align="Align.Center">@_checklistCategory.Description</MudText>
                @if (_checklistCategory.IsActive == true)
                {
                    <MudText Align="Align.Center" Class="pt-2">
                        <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                    </MudText>
                }
                else
                {
                    <MudText Align="Align.Center" Class="pa-4">
                        <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                    </MudText>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
    @*Related questions*@
    <MudItem xs="12" sm="6" md="9">
        <MudTabs Elevation="4" Rounded="true" Color="@Color.Info">
            <MudTabPanel Icon="@Icons.Material.Filled.Checklist" Text="Questions">
                @if (_checklistQuestions.Count() > 0)
                {
                    <MudTable Items="_checklistQuestions" Hover="true" T="ChecklistQuestion" Class="styled-table table-striped"
                              Height="70vh" RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" OnRowClick="RowClickEvent"
                    FixedHeader=true Filter="new Func<ChecklistQuestion,bool>(FilterFunc)">
                        <ToolBarContent>
                            <MudSpacer />
                            <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Clearable></MudTextField>
    
                            <MudSpacer />
                            <MudButton @onclick="(() => CreateQuestion(CategoryId))">
                                <MudText>Create Checklist Questions</MudText>
                                <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Plant" Color="Color.Primary"></MudIcon>
                            </MudButton>
                            <MudSpacer />
                            <MudButton @onclick="(() => QuestionSequence(CategoryId))">
                                <MudText>Re order</MudText>
                                <MudIcon Icon="@Icons.Material.Filled.Reorder" aria-label="Create Plant" Color="Color.Primary"></MudIcon>
                            </MudButton>
                        </ToolBarContent>
                        <HeaderContent>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<ChecklistQuestion, object>(x=>x?.QuestionID)">Question Id</MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<ChecklistQuestion, object>(x=>x?.Pillars)">Pillars</MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<ChecklistQuestion, object>(x=>x?.Prompt)">Prompt</MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<ChecklistQuestion, object>(x=>x?.NotGood)">Not Good</MudTableSortLabel>
                            </MudTh>
                            <MudTh>
                                <MudTableSortLabel SortBy="new Func<ChecklistQuestion, object>(x=>x?.CategorySequence)">Sequence</MudTableSortLabel>
                            </MudTh>
                           @* <MudTh>
                                <MudText Align="Align.Center">Status</MudText>
                            </MudTh>*@
                            <MudTh>
                                <MudText Align="Align.Center">Actions</MudText>
                            </MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="QuestionId">
                                <MudText Align="Align.Center">@context.QuestionID</MudText>
                            </MudTd>
                            <MudTd DataLabel="QuestionId">
                                @foreach(var item in context.Pillars){
                                @switch (item)
                                {
                                    case 1:
                                        <MudText Align="Align.Center">S & E</MudText>
                                        break;
                                    case 2:
                                        <MudText Align="Align.Center">Q</MudText>
                                        break;
                                    case 3:
                                        <MudText Align="Align.Center">D</MudText>
                                        break;
                                    case 4:
                                        <MudText Align="Align.Center">C</MudText>
                                        break;
                                    case 5:
                                        <MudText Align="Align.Center">@Localizer["other"]</MudText>
                                        break;
                                }
                                }
                            </MudTd>
                            <MudTd DataLabel="Prompt">
                                <MudText Align="Align.Center">@(currentLanguage == "es-ES" ? context.Prompt : context.PromptEN)</MudText>
                            </MudTd>
                            <MudTd DataLabel="Not Good">
                                <MudText Align="Align.Center">@(currentLanguage == "es-ES" ? context.NotGood : context.NotGoodEN)</MudText>
                            </MudTd>
                            <MudTd DataLabel="Sequence">
                                <MudText Align="Align.Center">@context.CategorySequence</MudText>
                            </MudTd>
                           @* <MudTd DataLabel="Status">
                                @if (context.IsActive == true)
                                {
                                    <MudText Align="Align.Center">
                                        <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                                    </MudText>
                                }
                                else
                                {
                                    <MudText Align="Align.Center">
                                        <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                                    </MudText>
                                }
                            </MudTd>*@
                            <MudTd DataLabel="Actions">
                                <MudText Align="Align.Center">
                                    <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                        <ActivatorContent>
                                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                                        </ActivatorContent>
                                        <ChildContent>
                                            @*<MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary">Details</MudMenuItem>*@
                                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" @onclick="(() => UpdateQuestion(CategoryId, context.QuestionID))" @ontouchstart="(() => UpdateQuestion(CategoryId, context.QuestionID))">Edit </MudMenuItem>
                                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => DeleteQuestion(CategoryId, context.QuestionID))" @ontouchstart="(() => DeleteQuestion(CategoryId, context.QuestionID))">Delete </MudMenuItem>
                                        </ChildContent>
                                    </MudMenu>




                                </MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">There are no questions created for this category.</MudText>
                    <MudText Align="Align.Center" Typo="Typo.h6" Class="mt-4">
                        <MudButton Color="Color.Info" @onclick="(() => CreateQuestion(CategoryId))">Create a new question</MudButton>
                    </MudText>
                }
            </MudTabPanel>
        </MudTabs>
    </MudItem>
</MudGrid>
