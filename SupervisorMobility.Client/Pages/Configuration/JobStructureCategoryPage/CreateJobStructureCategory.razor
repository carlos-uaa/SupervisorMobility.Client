@page "/checklistcategory/createcategory"
@inject IJobStructureService JobStructureCategoriesService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource1> Localizer1

@*Title*@
<PageTitle>Supervisor Mobility | Create Category</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_checklistCategory" OnValidSubmit="CreateCategoryAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Category details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">New category</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="Category description"
                                  @bind-Value="_checklistCategory.Description" For="@(() => _checklistCategory.Description)" />
                    <MudTextField Label="Code" Class="mt-3"
                                  @bind-Value="_checklistCategory.Code" For="@(() => _checklistCategory.Code)" />
                    <MudSelect T="StructureType" Label="@Localizer1["TypeStrucureLabel"]" Variant="Variant.Text" Placeholder="@Localizer1["TypeStrucurePH"]" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_checklistCategory.Type" For="@(() => _checklistCategory.Type)">

                        <MudSelectItem Value="(StructureType)(-1)">Select Type</MudSelectItem>

                        @if (!HasTitularCategory() || _checklistCategory.Type == StructureType.Titular )
                        {
                            <MudSelectItem Value="StructureType.Titular">@GetStructureTypeText(StructureType.Titular)</MudSelectItem>
                        }

                        @if (_checklistCategory.Type != StructureType.Checklist)
                        {
                            <MudSelectItem Value="StructureType.Checklist">@GetStructureTypeText(StructureType.Checklist)</MudSelectItem>
                        }

                        @if (!HasLUPCategory() || _checklistCategory.Type == StructureType.LUP)
                        {
                            <MudSelectItem Value="StructureType.LUP">@GetStructureTypeText(StructureType.LUP)</MudSelectItem>
                        }

                        @if (!HasTimerCategory() || _checklistCategory.Type == StructureType.Timer)
                        {
                            <MudSelectItem Value="StructureType.Timer">@GetStructureTypeText(StructureType.Timer)</MudSelectItem>
                        }

                        @if (!HasSignatureCategory() || _checklistCategory.Type == StructureType.Signature)
                        {
                            <MudSelectItem Value="StructureType.Signature">@GetStructureTypeText(StructureType.Signature)</MudSelectItem>
                        }

                    </MudSelect>
                    @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_checklistCategory.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Href="/checklistcategories" Variant="Variant.Filled" Class="ml-4">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>