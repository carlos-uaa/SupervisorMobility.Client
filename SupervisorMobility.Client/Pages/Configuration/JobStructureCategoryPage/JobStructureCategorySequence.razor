@page "/checklistcategories/sequence"
@inject IChecklistService ChecklistService

@*Title*@
<PageTitle>Supervisor Mobility | Checklist Categories Sequence</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Sequence container*@
<MudDropContainer T="JobCategoryStructure" Items="_checklistCategories" ItemsSelector="@((item,dropzone) => item.Container == dropzone)" ItemDropped="ItemUpdated" Class="d-flex flex-wrap flex-grow-1">
    <ChildContent>
        <MudDropZone T="JobCategoryStructure" Identifier="CategoryContainer" Class="rounded mud-background-gray pa-6 ma-8 flex-grow-1"  AllowReorder="true" CanDrop="@((item) => item.Type != StructureType.Titular)">
            <MudText Typo="Typo.h6" Class="mb-4">
                Reorder categories
            </MudText>
        </MudDropZone>
    </ChildContent>
    <ItemRenderer >
            <MudPaper Elevation="25" Class="pa-4 my-4">
                @($"{context.Description} ")
            </MudPaper>
    </ItemRenderer>
</MudDropContainer>