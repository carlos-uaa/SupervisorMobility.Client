@*Form*@
<EditForm Model="_question" class="mt-10" OnValidSubmit="UpdateQuestionAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localizer["Question"] @Localizer["update"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Info">Update question</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="Question Prompt"
                    @bind-Value="_question.Prompt" For="@(() => _question.Prompt)" /> 
                    
                    <MudTextField Label="Question Prompt EN"
                    @bind-Value="_question.PromptEN" For="@(() => _question.PromptEN)" />
                    @*Mud select for Pillar for Admin*@
                    <!--    ///     -->
                    <MudText> @Localizer["pillar"] </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Success" aria-label="add" OnClick="()=>AddPillar()"></MudIconButton>
                    @foreach (var item in _question.Pillars.Select((id, index) => new { index, id }))
                    {
                        <MudPaper>
                            <MudSelect T="int" Label=@Localizer["pillar"] Variant="Variant.Text" Class="mt-3 mr-4" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_question.Pillars[item.index]" For="@(() => _question.Pillars[item.index])">
                                <MudSelectItem Disabled="true" Value="0">@Localizer["selectAPillar"]</MudSelectItem>
                                @foreach (var type in _pillars)
                                {
                                    <MudSelectItem Value="type.PillarId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            </MudSelect>
                            <MudIconButton Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" aria-label="remove" OnClick="()=>RemovePillar(item.index)"></MudIconButton>
                        </MudPaper>
                    }
                    <!--    ///     -->
                    <MudTextField Label="Question Not Good" Class="mt-3"
                    @bind-Value="_question.NotGood" For="@(() => _question.NotGood)" />
                    <MudTextField Label="Question Not Good EN" Class="mt-3"
                    @bind-Value="_question.NotGoodEN" For="@(() => _question.NotGoodEN)" />
                    @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_question.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>