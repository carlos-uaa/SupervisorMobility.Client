@page "/checklistcategories/category/{categoryId:int}/createquestion"
@inject IJobStructureService JobStructureCategoriesService
@inject IQuestionTypeService QuestionTypeService
@inject IPillarService PillarsService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService
@inject IDialogService DialogService

@*Title*@
<PageTitle>Supervisor Mobility | Create Question</PageTitle>

@*Breadcrumb links*@
