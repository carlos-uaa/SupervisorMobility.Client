@page "/pillars/Create"
@page "/pillars/Update/{pillarID:int?}"
@page "/pillars/Details/{pillarID:int?}"

@inject IPillarService PillarsServices
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IBreadcrumbService BreadcrumbService

<EditForm Model="_pillar" class="mt-10" OnValidSubmit="ExectPillarAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6"> 
                            @switch (PageState)
                            {
                                case 1:
                                    @Localizer["create"]
                                    break; 
                                case 2:
                                    @Localizer["details"]
                                break; 
                            case 3:
                                    @Localizer["update"]
                                break; 
                            }&nbsp;
                            @Localizer["pillar"]</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip Variant="Variant.Text" Color="Color.Info"> @switch (PageState)
                            {
                                case 1:
                                    @Localizer["create"]
                                    break; 
                                case 2:
                                    @Localizer["details"]
                                break; 
                            case 3:
                                    @Localizer["update"]
                                break; 
                            } &nbsp;
                            @Localizer["pillar"]</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                    <MudTextField Label=@Localizer["description"] ReadOnly="@(PageState == 2)"
                                      @bind-Value="_pillar.Description" For="@(() => _pillar.Description)" />
                    <MudTextField Label=@Localizer["code"] Class="mt-3" ReadOnly="@(PageState == 2)"
                                      @bind-Value="_pillar.Code" For="@(() => _pillar.Code)" />
                    @if (user.UserType == 1)
                    {
                        <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_pillar.IsActive" ReadOnly="@(PageState == 2)" Color="Color.Info" UnCheckedColor="Color.Dark" />
                    }
                    </MudCardContent>
                    <MudCardActions>
                    @if (PageState != 2)
                    {
                        <MudButton ButtonType="ButtonType.Submit" Disabled="ExecBtnPress" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@(PageState == 1 ? Localizer["create"] : Localizer["save"])</MudButton>
                    }
                    <MudButton Href="/pillars" Variant="Variant.Filled" Class="ml-4">@Localizer["cancel"]</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </EditForm>