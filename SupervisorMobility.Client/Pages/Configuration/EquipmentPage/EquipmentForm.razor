@page "/Equipment/Create"
@page "/Equipment/Update/{EquipmentID:int?}"
@page "/Equipment/Details/{EquipmentID:int?}"

@inject IEquipmentService EquipmentsServices
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IBreadcrumbService BreadcrumbService

<EditForm Model="_Equipment" class="mt-10" OnValidSubmit="ExectEquipmentAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6"> 
                            @switch (PageState)
                            {
                                case 1:
                                    @Localizer["create"]
                                    break; 
                                case 2:
                                    @Localizer["details"]
                                break; 
                            case 3:
                                    @Localizer["update"]
                                break; 
                            }&nbsp;
                            @Localizer["Equipment"]</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip Variant="Variant.Text" Color="Color.Info"> @switch (PageState)
                            {
                                case 1:
                                    @Localizer["create"]
                                    break; 
                                case 2:
                                    @Localizer["details"]
                                break; 
                            case 3:
                                    @Localizer["update"]
                                break; 
                            } &nbsp;
                            @Localizer["Equipment"]</MudChip>
                        </CardHeaderActions> 
                    <CardHeaderActions>
                          @switch (PageState)
                            {
                               
                                case 2:
                                <MudChip @onclick="()=>EditEquipment((int)EquipmentID)" @ontouchstart="()=>EditEquipment((int)EquipmentID)" Variant="Variant.Filled" Class="ml-auto mr-13 mb-10" Icon="@Icons.Material.Filled.Edit" Color="Color.Info">@Localizer["EditEquipment"]</MudChip>
                                break; 
                           
                            }
                    </CardHeaderActions>
                        
                    </MudCardHeader>
                    <MudCardContent>
                    <MudTextField Label=@Localizer["Code"] ReadOnly="@(PageState == 2)"
                                  @bind-Value="_Equipment.EquipmentCode" For="@(() => _Equipment.EquipmentCode)" />

                    <MudTextField Label=@Localizer["Name"] ReadOnly="@(PageState == 2)"
                                  @bind-Value="_Equipment.EquipmentName" For="@(() => _Equipment.EquipmentName)" />
                  
                    @if (user.UserType == 1)
                    {
                        <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_Equipment.IsActive" ReadOnly="@(PageState == 2)" Color="Color.Info" UnCheckedColor="Color.Dark" />
                    }
                    </MudCardContent>
                    <MudCardActions>
                    @if (PageState != 2)
                    {
                        <MudButton ButtonType="ButtonType.Submit" Disabled="ExecBtnPress" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@(PageState == 1 ? Localizer["create"] : Localizer["save"])</MudButton>
                    }
                    @if (string.IsNullOrEmpty(EquipmentName))
                    {
                        <MudButton Href="/Equipment" Variant="Variant.Filled" Class="ml-4">@Localizer["cancel"]</MudButton>
                    }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </EditForm>