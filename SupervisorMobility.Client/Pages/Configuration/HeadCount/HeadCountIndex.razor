                                                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@context</MudText>
                                            </div>
                                        </ItemTemplate>
                                    </MudCarousel>
                                }
                                @if (showUpload)
                                {
                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                }
                            </MudItem>
                            <MudSpacer />


                        </MudItem>
                        <MudItem Class="d-flex flex-column align-center justify-center">
                            @*File Upload*@
                            <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
                                <InputFile id="input" OnChange="@OnChange" hidden single></InputFile>



                            </MudItem>
                            <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
                                <MudTextField Class="flex-initial d-flex flex-grow-1 px-9" Width="60%" @bind-Value="@FileName" Label="File Name" Variant="Variant.Outlined" Disabled="true" />
                                <MudButton Class="flex-initial d-flex flex-grow-0 px-9 py-2" Width="20%"
                                           HtmlTag="label"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.CloudUpload"
                                           for="input">
                                    @Localizer1["ACUploadFiles"]
                                </MudButton>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                </MudGrid>

                <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
                    <MudStack Style="width: 80%">
                        <MudFileUpload T="IReadOnlyList<IBrowserFile>" OnFilesChanged="OnChange" Hidden="false" Class="flex-1" InputClass="absolute mud-width-full mud-height-full overflow-hidden z-20" InputStyle="opacity:0"
                        @ondragenter="@SetDragClass" @ondragleave="@ClearDragClass" @ondragend="@ClearDragClass">
                            <ButtonTemplate Context="DragAndDrop">
                                <MudPaper Height="200px" Outlined="true" Class="@DragClass">
                                    <MudText Typo="Typo.h6">@Localizer["DragAndDrop"]</MudText>
                                    @foreach (var file in fileNames)
                                    {
                                        <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center">
                                            <MudText Typo="Typo.h6">@file.message</MudText>

                                            @switch (file.ftype)
                                            {
                                                case "xls":
                                                    <img src="Images/xls.png" Height="70" Width="70" />
                                                    break;
                                                case "xlsx":
                                                    <img src="Images/xlsx.png" Height="70" Width="70" />
                                                    break;
                                                case "csv":
                                                    <img src="Images/csv.png" Height="70" Width="70" />
                                                    break;
                                                default:
                                                    <img src="Images/error.png" Height="70" Width="70" />
                                                    break;
                                            }

                                            <MudChip Color="Color.Info" Text="@file.name" />
                                        </MudItem>
                                    }
                                </MudPaper>
                            </ButtonTemplate>
                        </MudFileUpload>
                    </MudStack>
                </MudItem>
                <MudItem Class="d-flex flex-row align-center justify-center mud-width-full">
                    <MudStack Style="width: 80%">
                        <MudToolBar DisableGutters="true" Class="gap-4">
                            <MudButton OnClick="@(() => UploadFunction(showUpload = true))" Disabled="@(!fileNames.Any())" Color="Color.Primary" Variant="Variant.Filled">Upload</MudButton>
                            <MudButton OnClick="Clear" Disabled="@(!fileNames.Any())" Color="Color.Error" Variant="Variant.Filled">Clear</MudButton>
                        </MudToolBar>
                    </MudStack>
                </MudItem>


            </MudContainer>
        </ChildContent>
