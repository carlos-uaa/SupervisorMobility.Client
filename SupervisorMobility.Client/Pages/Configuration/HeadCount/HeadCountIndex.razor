<MudTabs Elevation="4" Color="@Color.Info" TabPanelClass="px-10 mx-10" Rounded="true" ApplyEffectsToContainer="true" Centered="true">

    <MudTabPanel Icon="@Icons.Material.Filled.UploadFile" Text="@Localizer1["Upload"]" BadgeData='"🡩"' BadgeColor="Color.Success" >
