@page "/configuration"

@*Title*@
<PageTitle>Supervisor Mobility | Configuration</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Dashboard grid*@
<MudGrid>
    @*Plants*@

    <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
        <MudButton Href="/plants" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
            <MudItem style="text-align:center">
                <img src="Images/fabrica.png" Height="100" Width="100" />
                <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Plants</MudText>
            </MudItem>
        </MudButton>
    </MudItem>
    @*Products*@
    <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
        <MudButton Href="/products" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
            <MudItem style="text-align:center">
                <img src="Images/clave.png" Height="100" Width="100" />
                <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Products</MudText>
            </MudItem>
        </MudButton>
    </MudItem>
    @*Groups*@
    <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
        <MudButton Href="/groups" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
            <MudItem style="text-align:center">
                <img src="Images/comunidad.png" Height="100" Width="100" />
                <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Groups</MudText>
            </MudItem>
        </MudButton>
    </MudItem>
    @*Job observation types*@
    <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
        <MudButton Href="/jobobservationtypes" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
            <MudItem style="text-align:center">
                <img src="Images/vision.png" Height="100" Width="100" />
                <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Job Observation Types</MudText>
            </MudItem>
        </MudButton>
    </MudItem>
    @*Doc types*@
    <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
        <MudButton Href="/documenttypes" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
            <MudItem style="text-align:center">
                <img src="Images/documentos.png" Height="100" Width="100" />
                <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Document Types</MudText>
            </MudItem>
        </MudButton>
    </MudItem>

    @*Checklists*@
    <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
        <MudButton Href="/checklistcategories" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
            <MudItem style="text-align:center">
                <img src="Images/portapapeles.png" Height="100" Width="100" />
                <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Checklist categories</MudText>
            </MudItem>
        </MudButton>
    </MudItem>


    @*Assy Chart*@
    <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
        <MudButton Href="/assychart" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
            <MudItem style="text-align:center">
                <img src="Images/assy.png" Height="100" Width="100" />
                <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Assy Chart</MudText>
            </MudItem>
        </MudButton>
    </MudItem>
    
    @*User *@
    <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
        <MudButton Href="/usersmanagement" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
            <MudItem style="text-align:center">
                <img src="Images/users.png" Height="100" Width="100" />
                <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info"> Users Management</MudText>
            </MudItem>
        </MudButton>
    </MudItem>

    @*Guides *@
    <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
        <MudButton Href="/GuidesManagement" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
            <MudItem style="text-align:center">
                <img src="Images/guide.png" Height="100" Width="100" />
                <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Guides</MudText>
            </MudItem>
        </MudButton>
    </MudItem>

    @*Glosary *@
    <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
        <MudButton Href="/glosary" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
            <MudItem style="text-align:center">
                <img src="Images/glosary.png" Height="100" Width="100" />
                <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Glosary</MudText>
            </MudItem>
        </MudButton>
    </MudItem>

</MudGrid>