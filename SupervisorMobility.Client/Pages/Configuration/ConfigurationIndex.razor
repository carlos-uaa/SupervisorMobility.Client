@page "/configuration"

@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService


<style>

    .menu-card {
        width: 100%;
        box-shadow: 5px 5px 5px rgb(218, 214, 213 );
        border-radius: 10px;
        transition: all 0.3s ease-out;
        cursor: default;
    }

    .menu-card .header {
        border-radius: 10px 10px 0 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background-color: #f1f5f9;
    }


    .menu-card .content {
        text-align: justify;
        height: 16vh;
        overflow-x: scroll;
    }

    .menu-card .content::-webkit-scrollbar {
        width: 4px;
    }

    .menu-card .footer {
        border-radius: 0 0 10px 10px;
        background-color: #f1f5f9;
    }

    .menu-card:hover {
        box-shadow: #9ad8f3 0px 2px 4px;
        transform: scale(1.005);
    }

</style>

@if (logged == true)
{
    @*Title*@
    <PageTitle>Supervisor Mobility | @Localizer["configuration"]</PageTitle>
    @*Breadcrumb links*@
  @*   <MudBreadcrumbs Items="_links">
        <ItemTemplate Context="item">
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        </ItemTemplate>
    </MudBreadcrumbs> *@

    @*Dashboard grid*@
    <MudGrid Class="pb-10">
        @if (user.UserType == 1)
        {
            @*Plants*@
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                    <MudItem Class="pa-2 header">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">PLANTS</MudChip>
                        <MudText>@Localizer["plants"]</MudText>
                        <MudImage Src="Images/fabrica.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["plantsConfigDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="plants" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="plants/createplant" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>


            @*Products*@
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                    <MudItem Class="pa-2 header">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">PRODS</MudChip>
                        <MudText>@Localizer["products"]</MudText>
                        <MudImage Src="Images/clave.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["productsConfigDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="products" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="products/createproduct" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>


            @*Groups*@
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                     <MudItem Class="pa-2 header">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">GROUPS</MudChip>
                        <MudText>@Localizer["groups"]</MudText>
                        <MudImage Src="Images/comunidad.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["groupsConfigDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="groups" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="groups/creategroup" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>

            @*Assy Chart*@
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                     <MudItem Class="pa-2 header">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">AC</MudChip>
                        <MudText>@Localizer["assyChart"]</MudText>
                        <MudImage Src="Images/assy.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["assyChartConfigDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="assychart" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="assychart/createassychart" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>
            @*Checklists*@
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                     <MudItem Class="pa-2 header">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">AC</MudChip>
                         <MudText>@Localizer["checklistCategories"]</MudText>
                        <MudImage Src="Images/portapapeles.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["ChecklistCategoriesConfigDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="checklistcategories" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>
            @*Paths*@
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                     <MudItem Class="pa-2 header">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">PATH</MudChip>
                        <MudText>@Localizer["Paths"]</MudText>
                        <MudImage Src="Images/paths.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["PathsConfigDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="PathsRoute" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="PathsRoute/PathCreate" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>
           
        }
        @if (user.UserType == 1 || user.UserType == 3)
        {
            @*User *@
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                     <MudItem Class="pa-2 header">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">USER</MudChip>
                        <MudText>@Localizer["usersManagment"]</MudText>
                        <MudImage Src="Images/users.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["usersManagmentConfigDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="usersmanagement" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="usersmanagement/CreateUser" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>


        }
        @if (user.UserType == 1)
        {
            @*Guides *@
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                     <MudItem Class="pa-2 header">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">GUIDES</MudChip>
                        <MudText>@Localizer["guides"]</MudText>
                        <MudImage Src="Images/guide.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["guidesConfigDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="GuidesManagement" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="GuidesManagement/CreateGuide" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>


            @*Glosary *@
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                     <MudItem Class="pa-2 header">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">GL</MudChip>
                        <MudText>@Localizer["glosary"]</MudText>
                        <MudImage Src="Images/guide.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem Class="content">
                        <MudText Class="pa-4">
                            @Localizer["glosaryConfigDescription"]
                        </MudText>
                    </MudItem>
                    <MudItem Class="pa-3 footer">
                        <MudButton Href="glosary" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>
        }

    </MudGrid>
}