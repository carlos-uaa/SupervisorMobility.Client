@page "/configuration"

@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer

@if (logged == true)
{
    @*Title*@
    <PageTitle>Supervisor Mobility | @Localizer["configuration"]</PageTitle>
    @*Breadcrumb links*@
    <MudBreadcrumbs Class="mb-10" Items="_links">
        <ItemTemplate Context="item">
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        </ItemTemplate>
    </MudBreadcrumbs>

    @*Dashboard grid*@
    <MudGrid>
        @*Plants*@

        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="/plants" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                    <MudItem style="text-align:center">
                        <img src="Images/fabrica.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer["plants"]</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>
        @*Products*@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="/products" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                    <MudItem style="text-align:center">
                        <img src="Images/clave.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer["products"]</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>
        @*Groups*@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="/groups" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                    <MudItem style="text-align:center">
                        <img src="Images/comunidad.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer["groups"]</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>
        @*Job observation types*@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="/jobobservationtypes" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                    <MudItem style="text-align:center">
                        <img src="Images/vision.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer["jobObservationTypes"]</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>
        @*Doc types*@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="/documenttypes" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                    <MudItem style="text-align:center">
                        <img src="Images/documentos.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer["documentTypes"]</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>

        @*Checklists*@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="/checklistcategories" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                    <MudItem style="text-align:center">
                        <img src="Images/portapapeles.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer["checklistCategories"]</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>


        @*Assy Chart*@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="/assychart" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                    <MudItem style="text-align:center">
                        <img src="Images/assy.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer["assyChart"]</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>

        @*User *@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="/usersmanagement" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                    <MudItem style="text-align:center">
                        <img src="Images/users.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer["usersManagment"]</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>

        @*Guides *@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="/GuidesManagement" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                    <MudItem style="text-align:center">
                        <img src="Images/guide.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer["guides"]</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>

        @*Glosary *@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="/glosary" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center" Style="height:100%">
                    <MudItem style="text-align:center">
                        <img src="Images/glosary.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">@Localizer["glosary"]</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>

    </MudGrid>
}