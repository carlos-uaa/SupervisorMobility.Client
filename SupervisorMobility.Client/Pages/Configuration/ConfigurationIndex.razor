@page "/configuration"

@*Title*@
<PageTitle>Supervisor Mobility | Configuration</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Dashboard grid*@
<MudGrid>
    @*Plants*@
    <MudItem xs="12" sm="6" md="3">
        <div style="text-align:center">
            <img src="Images/fabrica.png" Height="100" Width="100" />
        </div>
        <a href="/plants">
            <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Info">Plants</MudButton>
        </a>
    </MudItem>
    @*Products*@
    <MudItem xs="12" sm="6" md="3">
        <div style="text-align:center">
            <img src="Images/clave.png" Height="100" Width="100" />
        </div>
        <a href="/products">
            <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Info">Products</MudButton>
        </a>
    </MudItem>
    @*Groups*@
    <MudItem xs="12" sm="6" md="3">
        <div style="text-align:center">
            <img src="Images/comunidad.png" Height="100" Width="100" />
        </div>
        <a href="/groups">
            <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Info">Groups</MudButton>
        </a>
    </MudItem>
    @*Job observation types*@
    <MudItem xs="12" sm="6" md="3">
        <div style="text-align:center">
            <img src="Images/vision.png" Height="100" Width="100" />
        </div>
        <a href="/jobobservationtypes">
            <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Info">Job Observation Types</MudButton>
        </a>
    </MudItem>
    @*Doc types*@
    <MudItem xs="12" sm="6" md="3">
        <div style="text-align:center">
            <img src="Images/documentos.png" Height="100" Width="100" />
        </div>
        <a href="/documenttypes">
            <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Info">Document Types</MudButton>
        </a>
    </MudItem>
    @*Checklists*@
    <MudItem xs="12" sm="6" md="3">
        <div style="text-align:center">
            <img src="Images/portapapeles.png" Height="100" Width="100" />
        </div>
        <a href="/checklistcategories">
            <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Info">Checklist categories</MudButton>
        </a>
    </MudItem>
    @*Assy Chart*@
    <MudItem xs="12" sm="6" md="3">
        <div style="text-align:center">
            <img src="Images/assy.png" Height="100" Width="100" />
        </div>
        <a href="/assychart">
            <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Info">Assy Chart</MudButton>
        </a>
    </MudItem>
</MudGrid>