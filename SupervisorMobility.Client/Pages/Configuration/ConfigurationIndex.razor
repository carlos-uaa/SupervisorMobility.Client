@page "/configuration"

@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer

@if (logged == true)
{
    @*Title*@
    <PageTitle>Supervisor Mobility | @Localizer["configuration"]</PageTitle>
    @*Breadcrumb links*@
    <MudBreadcrumbs Items="_links">
        <ItemTemplate Context="item">
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        </ItemTemplate>
    </MudBreadcrumbs>

    @*Dashboard grid*@
    <MudGrid Class="pb-10">
        @if (user.UserType == 1)
        {
            @*Plants*@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">PLANTS</MudChip>
                        <MudText>@Localizer["plants"]</MudText>
                        <MudImage Src="Images/fabrica.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="plants" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="plants/createplant" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>


            @*Products*@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">PRODS</MudChip>
                        <MudText>@Localizer["products"]</MudText>
                        <MudImage Src="Images/clave.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="products" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="products/createproduct" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>


            @*Groups*@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">GROUPS</MudChip>
                        <MudText>@Localizer["groups"]</MudText>
                        <MudImage Src="Images/comunidad.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="groups" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="groups/creategroup" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>

            @*Assy Chart*@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">AC</MudChip>
                        <MudText>@Localizer["assyChart"]</MudText>
                        <MudImage Src="Images/assy.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="assychart" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="assychart/createassychart" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>

            @*Paths*@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">PATH</MudChip>
                        <MudText>@Localizer["Paths"]</MudText>
                        <MudImage Src="Images/paths.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="PathsRoute" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="PathsRoute/PathCreate" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>

        }
        @if (user.UserType == 1 || user.UserType == 3)
        {
            @*User *@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">USER</MudChip>
                        <MudText>@Localizer["usersManagment"]</MudText>
                        <MudImage Src="Images/users.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="usersmanagement" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="usersmanagement/CreateUser" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>


        }
        @if (user.UserType == 1)
        {
            @*Guides *@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">GUIDES</MudChip>
                        <MudText>@Localizer["guides"]</MudText>
                        <MudImage Src="Images/guide.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="GuidesManagement" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton Href="GuidesManagement/CreateGuide" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>


            @*Glosary *@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">GL</MudChip>
                        <MudText>@Localizer["glosary"]</MudText>
                        <MudImage Src="Images/guide.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="glosary" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>
        }

    </MudGrid>
}