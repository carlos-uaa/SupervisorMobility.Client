@page "/documenttypes/createsupportdoctype"
@inject ISupportDocumentTypeService SupportDocumentTypeService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource1> Localizer

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["SDTTitle"]</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_supportDocumentType" OnValidSubmit="CreateSupportDocumentTypeAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localizer["SDTDetails"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["SDTNew"]</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="@Localizer["SDTDescription"]"
                                  @bind-Value="_supportDocumentType.Description" For="@(() => _supportDocumentType.Description)" />
                    <MudTextField Label="@Localizer["SDTCode"]" Class="mt-3"
                                  @bind-Value="_supportDocumentType.Code" For="@(() => _supportDocumentType.Code)" />
                    @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_supportDocumentType.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["Save"]</MudButton>
                    <MudButton Href="/documenttypes" Variant="Variant.Filled" Class="ml-4">@Localizer["Cancel"]</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>
