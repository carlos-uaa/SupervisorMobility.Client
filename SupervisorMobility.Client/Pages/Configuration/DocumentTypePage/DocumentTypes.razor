@page "/documenttypes"
@inject ISupportDocumentTypeService SupportDocumentTypeService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@*Title*@
<PageTitle>Supervisor Mobility | Document Types</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Plants table*@
<MudTable Items="_supportDocumentTypes" Hover="true" T="SupportDocumentType" SortLabel="Sort By" Filter="new Func<SupportDocumentType,bool>(FilterFunc)" Class="styled-table table-striped" FixedHeader=true>
    <ToolBarContent>
        <MudGrid class="d-flex flex-column justify-center align-self-center">
            <MudItem class="d-flex justify-center align-self-center ">
                <MudText Typo="Typo.h6" Class="align-item-center center">Support document types</MudText>
            </MudItem>
            <MudItem Class="d-flex">
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Add" aria-label="add" @onclick="(() => CreateSupportDocType())"></MudIconButton>
                <MudSpacer />
            </MudItem>
        </MudGrid>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<SupportDocumentType, object>(x=>x?.SupportDocumentTypeId)">Document Id</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<SupportDocumentType, object>(x=>x?.Code)">Code</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<SupportDocumentType, object>(x=>x?.Description)">Description</MudTableSortLabel>
        </MudTh>
     @*   <MudTh>
            <MudTableSortLabel SortBy="new Func<SupportDocumentType, object>(x=>x?.IsActive)">Status</MudTableSortLabel>
        </MudTh>*@
        <MudTh>
            <MudText Align="Align.Center">Actions</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="PlantId">
            <MudText Align="Align.Center">@context.SupportDocumentTypeId</MudText>
        </MudTd>
        <MudTd DataLabel="Code">
            <MudText Align="Align.Center">@context.Code</MudText>
        </MudTd>
        <MudTd DataLabel="Description">
            <MudText Align="Align.Center">@context.Description</MudText>
        </MudTd>
       @* <MudTd DataLabel="Status">
            @if (context.IsActive == true)
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                </MudText>
            }
            else
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                </MudText>
            }
        </MudTd>*@
        <MudTd>
            <MudText Align="Align.Center">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit" @onclick="(() => UpdateSupportDocType(context.SupportDocumentTypeId))"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="edit" @onclick="(() => DeleteSupportDocumentType(context.SupportDocumentTypeId))"></MudIconButton>
            </MudText>
        </MudTd>
    </RowTemplate>
</MudTable>