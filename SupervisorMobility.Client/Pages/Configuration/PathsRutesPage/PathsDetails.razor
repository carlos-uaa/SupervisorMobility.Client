@page "/PathsRoute/PathDetails/{PathId:int}"


@using SupervisorMobility.Client.Data.Entities.TreeStruct;
@using SupervisorMobility.Client.Pages.Configuration.AssyChartPage
@using System.Text.RegularExpressions;
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IChecklistService ChecklistService
@inject IAssyChartService AssyChartServices
@inject ISnackbar Snackbar
@inject IBridgeCDMSService CDMSServices
@inject IProductService ProductsServices
@inject IPlantService PlantsServices
@inject IAreaService AreasServices
@inject IDistributionService DistributionsServices
@inject ITreeService TreeServices
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer


<MudGrid>
    <MudItem xs="12">
        @if (ShowLoading)
        {
            <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
                <ItemTemplate>
                    <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                        <MudItem class="d-flex flex-column justify-center align-self-center">
                            <MudProgressCircular Color="@_Colors[context.IndexOf(context)]" Style="height:70px;width:70px;" Indeterminate="true" />
                        </MudItem>
                        @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                        <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@context</MudText>
                    </div>
                </ItemTemplate>
            </MudCarousel>
        }
        else if (SosCode != null)
        {
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localizer1["PathDetails"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip @onclick="()=>EditCodePath(PathId)" @ontouchstart="()=>EditCodePath(PathId)" Variant="Variant.Filled" Class="ml-auto mr-13 mb-10" Icon="@Icons.Material.Filled.Edit" Color="Color.Info">@Localizer1["CPEdit"]</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>

                    <MudCard>
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@Localizer1["ACDetails"]</MudText>
                            </CardHeaderContent>

                        </MudCardHeader>
                        <MudCardContent>
                            <MudItem Style="max-height: 70vh; min-width: 70vw; display: flex; flex-wrap: wrap; justify-content: center;" Class="gap-4">

                                <MudCard>
                                    <MudCardContent Style="justify-content:center">
                                        <MudText Align="Align.Center"><MudIcon Icon="@Icons.Filled.Business"></MudIcon></MudText>
                                        <MudText Align="Align.Center">@SosCode.AssyChart?.Plant?.Code</MudText>
                                        <MudText Typo="Typo.h5" Align="Align.Center">@SosCode.AssyChart?.Plant?.Description</MudText>
                                        @if (SosCode.AssyChart?.Plant?.IsActive == true)
                                        {
                                            <MudText Align="Align.Center" Class="pt-2">
                                                <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                                            </MudText>
                                        }
                                        else
                                        {
                                            <MudText Align="Align.Center" Class="pa-4">
                                                <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                                            </MudText>
                                        }
                                    </MudCardContent>
                                </MudCard>
                                <MudText Typo="Typo.h4" Style="text-align:center; align-self: center;">
                                    <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowRight"></MudIcon>
                                </MudText>
                                <MudCard>
                                    <MudCardContent Style="justify-content:center">
                                        <MudText Align="Align.Center"><MudIcon Icon="@Icons.Material.Filled.HomeWork"></MudIcon></MudText>
                                        <MudText Align="Align.Center">@SosCode.AssyChart?.Area?.Code</MudText>
                                        <MudText Typo="Typo.h5" Align="Align.Center">@SosCode.AssyChart?.Area?.Description</MudText>
                                        @if (SosCode.AssyChart?.Area?.IsActive == true)
                                        {
                                            <MudText Align="Align.Center" Class="pt-2">
                                                <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                                            </MudText>
                                        }
                                        else
                                        {
                                            <MudText Align="Align.Center" Class="pa-4">
                                                <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                                            </MudText>
                                        }
                                    </MudCardContent>
                                </MudCard>
                                <MudText Typo="Typo.h4" Style="text-align:center; align-self: center;">
                                    <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowRight"></MudIcon>
                                </MudText>
                                <MudCard>
                                    <MudCardContent Style="justify-content:center">
                                        <MudText Align="Align.Center"><MudIcon Icon="@Icons.Material.Filled.Workspaces"></MudIcon></MudText>
                                        <MudText Align="Align.Center">@SosCode.AssyChart?.Distribution?.Code</MudText>
                                        <MudText Typo="Typo.h5" Align="Align.Center">@SosCode.AssyChart?.Distribution?.Description</MudText>
                                        @if (SosCode.AssyChart?.Distribution?.IsActive == true)
                                        {
                                            <MudText Align="Align.Center" Class="pt-2">
                                                <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                                            </MudText>
                                        }
                                        else
                                        {
                                            <MudText Align="Align.Center" Class="pa-4">
                                                <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                                            </MudText>
                                        }
                                    </MudCardContent>
                                </MudCard>




                                <MudText Typo="Typo.h4" Style="text-align:center; align-self: center;">
                                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome"></MudIcon>
                                </MudText>
                                <MudCard>
                                    <MudCardContent Style="justify-content:center">
                                        <MudText Align="Align.Center"><MudIcon Icon="@Icons.Material.Filled.DirectionsCar" Color="Color.Primary"></MudIcon></MudText>
                                        <MudText Align="Align.Center">@SosCode.Product?.Code</MudText>
                                        <MudText Typo="Typo.h5" Align="Align.Center">@SosCode.Product?.Description</MudText>
                                        @if (SosCode.Product?.IsActive == true)
                                        {
                                            <MudText Align="Align.Center" Class="pt-2">
                                                <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>

                                            </MudText>
                                        }
                                        else
                                        {
                                            <MudText Align="Align.Center" Class="pa-4">
                                                <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                                            </MudText>
                                        }
                                    </MudCardContent>
                                </MudCard>


                            </MudItem>


                        </MudCardContent>
                    </MudCard>

                    <MudButton OnClick="@(e => OpenDialogCodePath())" FullWidth="false" Class="d-flex justify-center" Style="height:100%;">
                        <MudCard Elevation="3" Outlined="true">

                            <MudCardHeader>

                                <CardHeaderContent>
                                    <MudText Typo="Typo.h5">@SosCode.Code</MudText>
                                </CardHeaderContent>

                            </MudCardHeader>

                            <MudCardContent Style="max-height: 70vh; min-width: 80vw; display: flex; flex-wrap: wrap; flex-direction: column;" Class="gap-4">
                                <MudTextField Label="@Localizer1["ACLabelHOESelect"]" ReadOnly="true" Value="@Regex.Replace(SosCode.HOE, @"/(.*?)§", "/").Replace('§', ' ')" />
                                @if (SosCode.CommonDirectionHOE != "")
                                {
                                    <MudTextField Label="@Localizer1["ACLabelHOESelectCD"]" ReadOnly="true" Value="@Regex.Replace(SosCode.CommonDirectionHOE, @"/(.*?)§", "/").Replace('§', ' ')" />
                                }
                                <MudTextField Label="@Localizer1["ACLabelCCPSelect"]" ReadOnly="true" @bind-Value="@SosCode.CCP" />
                                @if (SosCode.CommonDirectionCCP != "")
                                {
                                    <MudTextField Label="@Localizer1["ACLabelCCPSelectCD"]" ReadOnly="true" @bind-Value="@SosCode.CommonDirectionCCP" />
                                }
                                <MudTextField Label="@Localizer1["ACLabelGOSSelect"]" ReadOnly="true" @bind-Value="@SosCode.GOS" />
                                @if (SosCode.CommonDirectionGOS != "")
                                {
                                    <MudTextField Label="@Localizer1["ACLabelGOSSelectCD"]" ReadOnly="true" @bind-Value="@SosCode.CommonDirectionGOS" />
                                }
                            </MudCardContent>
                        </MudCard>
                    </MudButton>


                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CloseDetails())">@Localizer["Close"]</MudButton>
                </MudCardActions>
            </MudCard>
        }
        else
        {
            <div class="d-flex flex-column flex-column justify-center" style="height:100%">

                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">ERROR </MudText>
            </div>
        }

    </MudItem>
</MudGrid>


<MudDialog @bind-IsVisible="ModalCodePathDisplay" Options="dialogOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@SosCode.Code</MudText>
        <MudText Class="mt-4 mb-4">

        </MudText>

        <MudItem Style="min-height: 75vh;" Class="gap-4">


            <MudCard Elevation="3" Outlined="true">

                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudChip Color="Color.Info">@SosCode.Product?.Code</MudChip>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.body1">@SosCode.Product?.Description</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Style="max-height: 67vh; min-height: 65vh; display: flex; flex-wrap: wrap;" Class="gap-4">

                    <MudTabs Outlined="true" Position="Position.Left" Rounded="true" Border="true"
                             ApplyEffectsToContainer="true" Class="mt-8" PanelClass="pa-6" Style="max-height: 60vh; min-height: 55vh" >
                        @if (SosCode.HOE != "")
                        {
                            <MudTabPanel>
                                <TabContent>
                                    <MudChip Icon="@Icons.Material.Filled.Folder" Style="display: flex;" Color="Color.Warning"> HOE</MudChip>

                                </TabContent>
                                <ChildContent>
                                    <MudCard Elevation="1" Class="mr-5" Style="min-width: 400px;     overflow-x: scroll;    overflow-y: scroll;">
                                        <MudCardHeader Style=" display: flex;  flex-wrap: wrap;  align-content: center;   flex-direction: column;">
                                            <CardHeaderActions>
                                                <MudText Typo="Typo.h6">
                                                    @Localizer1["ACHOERute"]: @Regex.Replace(SosCode.HOE, @"/(.*?)§", "/").Replace('§', ' ')
                                                </MudText>
                                            </CardHeaderActions>
                                        </MudCardHeader>
                                        <MudCardContent Style="max-width: 75vw; min-width: 70vw;    display: flex;    flex-wrap: wrap;    justify-content: center; ">
                                            @if (HoeFilesInFolder != null)
                                            {
                                                @if (HoeFilesInFolder.operation.Count() > 0)
                                                {

                                                    <MudTable Items="HoeFilesInFolder.operation" Height="60vh" T="HOEDocument" ReadOnly="true" FixedHeader=true Class="styled-table table-striped"
                                                              SortLabel="Sort By" Filter="new Func<HOEDocument,bool>(FilterFuncDocumentsHOE)"
                                                              HorizontalScrollbar="true">
                                                        <ToolBarContent>
                                                            <MudGrid class="d-flex flex-column justify-center align-self-center">
                                                                <MudItem Class="d-flex">
                                                                    <MudSpacer />
                                                                    <MudTextField @bind-Value="searchString" Placeholder="@Localizer["Search"]" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                                                                    <MudSpacer />
                                                                </MudItem>
                                                            </MudGrid>
                                                        </ToolBarContent>
                                                        <HeaderContent>
                                                            <MudTh><MudTableSortLabel SortBy="new Func<HOEDocument, object>(x=>x?.ID_DOC)"> @Localizer["ID_Doc"]</MudTableSortLabel></MudTh>
                                                           <MudTh><MudTableSortLabel SortBy="new Func<HOEDocument, object>(x=>x?.Nombre)">@Localizer["DownloadFile"]</MudTableSortLabel></MudTh>
                                                        </HeaderContent>
                                                        <RowTemplate>

                                                            <MudTd DataLabel="@Localizer["ID_Doc"]">
                                                                <MudText Align="Align.Center">@context.ID_DOC</MudText>
                                                            </MudTd>
                                                         
                                                            <MudTd DataLabel="@Localizer["DownloadFile"]">
                                                                <MudText Align="Align.Center">
                                                                    <MudTooltip Text=@Localizer["Download"] Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true">
                                                                        <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center">
                                                                            <MudButton @onclick="@(() =>  DownloadFileFromURL_HOE(context.URL, context.Nombre) )">

                                                                                @switch (context.Extension)
                                                                                {
                                                                                    case "pdf":
                                                                                        <img src="Images/pdf.png" Height="20" Width="20" />

                                                                                        break;
                                                                                    case "doc":
                                                                                        // Para documentos Word con extensión .doc
                                                                                        <img src="Images/doc.png" Height="20" Width="20" />
                                                                                        break;

                                                                                    case "docx":
                                                                                        <img src="Images/docx.png" Height="20" Width="20" />
                                                                                        // Para documentos Word con extensión .docx
                                                                                        break;

                                                                                    case "ppt":
                                                                                        <img src="Images/ppt.png" Height="20" Width="20" />

                                                                                        // Para presentaciones PowerPoint con extensión .ppt
                                                                                        break;

                                                                                    case "pptx":
                                                                                        <img src="Images/pptx.png" Height="20" Width="20" />
                                                                                        // Para presentaciones PowerPoint con extensión .pptx
                                                                                        break;

                                                                                    case "xls":
                                                                                        // Para hojas de cálculo Excel con extensión .xls
                                                                                        <img src="Images/xls.png" Height="20" Width="20" />
                                                                                        break;

                                                                                    case "xlsx":
                                                                                        // Para hojas de cálculo Excel con extensión .xlsx
                                                                                        <img src="Images/xlsx.png" Height="20" Width="20" />
                                                                                        break;

                                                                                    case "jpg":
                                                                                        <img src="Images/jpg.png" Height="20" Width="20" />
                                                                                        break;

                                                                                    case "jpeg":
                                                                                        // Para imágenes JPEG con extensión .jpg o .jpeg
                                                                                        <img src="Images/jpg.png" Height="20" Width="20" />
                                                                                        break;

                                                                                    case "png":
                                                                                        // Para imágenes PNG con extensión .png
                                                                                        <img src="Images/png.png" Height="20" Width="20" />
                                                                                        break;

                                                                                    case "gif":
                                                                                        // Para imágenes GIF con extensión .gif
                                                                                        <img src="Images/gif.png" Height="20" Width="20" />
                                                                                        break;
                                                                                    default:
                                                                                        <img src="Images/error.png" Height="20" Width="20" />
                                                                                        break;
                                                                                }
                                                                                <MudItem>
                                                                                    <MudChip Size="Size.Small" Class="ml-4" Variant="Variant.Text" Style="cursor:pointer" Icon="@Icons.Material.Filled.Download" Color="Color.Info">
                                                                                            @context.Nombre
                                                                                        </MudChip>
                                                                                      
                                                                                </MudItem>
                                                                            </MudButton>
                                                                        </MudItem>
                                                                    </MudTooltip>
                                                                </MudText>
                                                            </MudTd>
                                                        </RowTemplate>
                                                        <PagerContent>
                                                            <MudTablePager />
                                                        </PagerContent>
                                                    </MudTable>

                                                    @foreach (HOEDocument DocFile in HoeFilesInFolder.operation)
                                                    {
                                                        <MudPaper Class="mr-5 mt-5" style="flex: 0 0 calc(28% - 1rem);">
                                                            <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center mt-5">
                                                                @switch (DocFile.Extension)
                                                                {
                                                                    case "pdf":
                                                                        <img src="Images/pdf.png" Height="70" Width="70" />

                                                                        break;
                                                                    case "doc":
                                                                        // Para documentos Word con extensión .doc
                                                                        <img src="Images/doc.png" Height="70" Width="70" />
                                                                        break;

                                                                    case "docx":
                                                                        <img src="Images/docx.png" Height="70" Width="70" />
                                                                        // Para documentos Word con extensión .docx
                                                                        break;

                                                                    case "ppt":
                                                                        <img src="Images/ppt.png" Height="70" Width="70" />

                                                                        // Para presentaciones PowerPoint con extensión .ppt
                                                                        break;

                                                                    case "pptx":
                                                                        <img src="Images/pptx.png" Height="70" Width="70" />
                                                                        // Para presentaciones PowerPoint con extensión .pptx
                                                                        break;

                                                                    case "xls":
                                                                        // Para hojas de cálculo Excel con extensión .xls
                                                                        <img src="Images/xls.png" Height="70" Width="70" />
                                                                        break;

                                                                    case "xlsx":
                                                                        // Para hojas de cálculo Excel con extensión .xlsx
                                                                        <img src="Images/xlsx.png" Height="70" Width="70" />
                                                                        break;

                                                                    case "jpg":
                                                                        <img src="Images/jpg.png" Height="70" Width="70" />
                                                                        break;

                                                                    case "jpeg":
                                                                        // Para imágenes JPEG con extensión .jpg o .jpeg
                                                                        <img src="Images/jpg.png" Height="70" Width="70" />
                                                                        break;

                                                                    case "png":
                                                                        // Para imágenes PNG con extensión .png
                                                                        <img src="Images/png.png" Height="70" Width="70" />
                                                                        break;

                                                                    case "gif":
                                                                        // Para imágenes GIF con extensión .gif
                                                                        <img src="Images/gif.png" Height="70" Width="70" />
                                                                        break;
                                                                    default:
                                                                        <img src="Images/error.png" Height="70" Width="70" />
                                                                        break;
                                                                }
                                                                <MudTooltip Text="Download" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true">
                                                                    <MudButton @onclick="() => DownloadFileFromURL_HOE(DocFile.URL, DocFile.Nombre)">
                                                                        <MudItem>
                                                                            <MudChip Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer;max-width: 315px" Icon="@Icons.Material.Filled.Download" Color="Color.Info">
                                                                                @if (DocFile.Nombre.Length > 10)
                                                                                {
                                                                                    <span class="marquee">@DocFile.Nombre</span>
                                                                                }
                                                                                else
                                                                                {
                                                                                    @DocFile.Nombre
                                                                                }
                                                                            </MudChip>

                                                                        </MudItem>
                                                                    </MudButton>
                                                                </MudTooltip>
                                                            </MudItem>

                                                        </MudPaper>

                                                    }
                                                }
                                                else if (HoeFilesInFolder.operation.Count == 0 && !folderErrorHOE)
                                                {

                                                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                                                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                                                            <img src="Images/navegador.png" Height="140" Width="140" />
                                                        </MudItem>

                                                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["NoFilesDirectory"]</MudText>
                                                            </MudItem>
                                                        </MudItem>
                                                    </MudItem>
                                                }
                                                else
                                                {
                                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                                }
                                            }
                                            else
                                            {
                                                if (folderErrorHOE)
                                                {
                                                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                                                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                                                            <img src="Images/dialogerror.png" Height="140" Width="140" />
                                                        </MudItem>

                                                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name"> @Localizer["ServerNotResponse"]</MudText>
                                                            </MudItem>
                                                        </MudItem>
                                                    </MudItem>
                                                }
                                                else
                                                {
                                                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                                                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                                                            <img src="Images/dialogerror.png" Height="140" Width="140" />
                                                        </MudItem>

                                                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                                                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["Alert"] </MudText>

                                                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["DataNotFound"]</MudText>
                                                            </MudItem>
                                                        </MudItem>
                                                    </MudItem>
                                                }
                                            }

                                        </MudCardContent>
                                    </MudCard>
                                </ChildContent>
                            </MudTabPanel>

                        }

                        @if (SosCode.CommonDirectionHOE != "")
                        {
                            <MudTabPanel>
                                <TabContent>
                                    <MudChip Icon="@Icons.Material.Filled.Folder" Style="display: flex;" Color="Color.Warning">HOE  Common Direction</MudChip>
                                </TabContent>
                                <ChildContent>
                                    <MudCard Elevation="1" Class="mr-5" Style="min-width: 400px;     overflow-x: scroll;    overflow-y: scroll;">
                                        <MudCardHeader Style=" display: flex;  flex-wrap: wrap;  align-content: center;   flex-direction: column;">
                                            <CardHeaderActions>
                                                <MudText Typo="Typo.h6">
                                                    @Localizer1["ACHOERuteCD"]: @Regex.Replace(SosCode.CommonDirectionHOE, @"/(.*?)§", "/").Replace('§', ' ')
                                                </MudText>
                                            </CardHeaderActions>
                                        </MudCardHeader>
                                        <MudCardContent Style="max-width: 75vw; min-width: 70vw;    display: flex;    flex-wrap: wrap;    justify-content: center; ">
                                            @if (HoeFilesInFolderCD != null)
                                            {
                                                @if (HoeFilesInFolderCD.operation.Count() > 0)
                                                {
                                                    @foreach (HOEDocument DocFile in HoeFilesInFolderCD.operation)
                                                    {
                                                        <MudPaper Class="mr-5 mt-5" style="flex: 0 0 calc(28% - 1rem);">
                                                            <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center mt-5">
                                                                @switch (DocFile.Extension)
                                                                {
                                                                    case "pdf":
                                                                        <img src="Images/pdf.png" Height="70" Width="70" />

                                                                        break;
                                                                    case "doc":
                                                                        // Para documentos Word con extensión .doc
                                                                        <img src="Images/doc.png" Height="70" Width="70" />
                                                                        break;

                                                                    case "docx":
                                                                        <img src="Images/docx.png" Height="70" Width="70" />
                                                                        // Para documentos Word con extensión .docx
                                                                        break;

                                                                    case "ppt":
                                                                        <img src="Images/ppt.png" Height="70" Width="70" />

                                                                        // Para presentaciones PowerPoint con extensión .ppt
