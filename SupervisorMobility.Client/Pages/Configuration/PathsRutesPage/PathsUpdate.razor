                                    {
                                        <MudText Align="Align.Center">@_distribution.Code</MudText>
                                    }

                                    @if (IndexPlant != -1 && IndexArea != -1)
                                    {
                                        <MudSelect T="int" Label=@Localizer["distribution"] Variant="Variant.Text" Class="mt-3 mr-4 h5" AnchorOrigin="Origin.BottomCenter" @bind-Value="@IndexDistr" For="@(() => IndexDistr)" SelectedValuesChanged="UpdateDistribution">
                                            <MudSelectItem Value="-1">@Localizer["selectADistributionFirst"]</MudSelectItem>

                                            @for (var i = 0; i < _distributions.ElementAt(IndexPlant).Value.ElementAt(IndexArea).Value.Count; i++)
                                            {
                                                var type = _distributions.ElementAt(IndexPlant).Value.ElementAt(IndexArea).Value[i];


                                                <MudSelectItem Value="i">@($"{type.Description}")</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }

                                    @if (_distribution.IsActive == true && IndexDistr != -1)
                                    {
                                        <MudText Align="Align.Center" Class="pt-2">
                                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                                        </MudText>
                                    }
                                    else if (IndexDistr != -1)
                                    {
                                        <MudText Align="Align.Center" Class="pa-4">
                                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                                        </MudText>
                                    }
                                </MudCardContent>
                            </MudCard>
                        

                       
                            <MudCard>
                                <MudCardContent Style="justify-content:center">
                                    <MudText Align="Align.Center"><MudIcon Icon="@Icons.Material.Filled.DirectionsCar"></MudIcon></MudText>
                                    @if (IndexProd != -1)
                                    {
                                        <MudText Align="Align.Center">@_product.Code</MudText>
                                    }
                                    else
                                    {
                                        <MudAlert Severity="Severity.Info">
                                            @Localizer["selectAProduct"]
                                        </MudAlert>
                                    }

                                    <MudSelect T="int" Label=@Localizer["product"] Variant="Variant.Text" Class="mt-3 mr-4 h5" AnchorOrigin="Origin.BottomCenter" @bind-Value="@IndexProd" For="@(() => IndexProd)" SelectedValuesChanged="UpdateProduct">
                                        <MudSelectItem Value="-1">@Localizer["selectAProduct"]</MudSelectItem>

                                        @for (var i = 0; i < _products.Count; i++)
                                        {
                                            var type = _products[i];
                                            <MudSelectItem Value="i">@($"{type.Description}")</MudSelectItem>
                                        }
                                    </MudSelect>
                                    @if (_product.IsActive == true && IndexProd != -1)
                                    {
                                        <MudText Align="Align.Center" Class="pt-2">
                                            <MudChip Variant="Variant.Text" Color="Color.Success">@Localizer["active"]</MudChip>
                                        </MudText>
                                    }
                                    else if (IndexProd != -1)
                                    {
                                        <MudText Align="Align.Center" Class="pa-4">
                                            <MudChip Variant="Variant.Text" Color="Color.Error">@Localizer["inactive"]</MudChip>
                                        </MudText>
                                    }
                                </MudCardContent>
                            </MudCard>
                        


                    </MudCardContent>
                </MudCard>




            </MudItem>
       

        <MudItem Style="max-height: 70vh; min-width: 90vw; overflow-y: scroll;" Class="gap-4">


            <MudCard Elevation="3" Outlined="true">

                <MudCardHeader>


                </MudCardHeader>
                <MudCardContent Style="min-width: 60vw; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">


                    <MudCard Elevation="1" Class="mr-5" Style="min-width: 55vw;">
                        <MudCardHeader>
                            <CardHeaderActions>
                                <MudChip Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Info" Variant="Variant.Outlined">HOE</MudChip>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteHOERoute())" />
                            </CardHeaderActions>

                        </MudCardHeader>
                        <MudCardContent>

                            @if (HOEFolders != null)
                            {
                                @if (rootNodeHOE.TreeItems.Count > 0)
                                {
                                    <MudPaper Elevation="0">

                                        <MudTextField Label="@Localizer1["ACLabelHOESelect"]" ReadOnly="true" Value="@Regex.Replace(SosCode.HOE, @"/(.*?)§", "/").Replace('§', ' ')" />

                                        <MudTreeView ServerData="LoadServerData" Color="Color.Primary" @bind-SelectedValue="@SelectedNodeHOE" Context="OtherContext" Items="rootNodeHOE.TreeItems">
                                            <ItemTemplate>
                                                <MudTreeViewItem Value="@OtherContext" @onclick="@((e) => ApplyHOE(OtherContext.Ruta))" LoadingIconColor="Color.Info" CanExpand="@OtherContext.EsDirectorio" Text="@OtherContext.Nombre.Split('§').Last()" EndTextTypo="@Typo.caption" />
                                            </ItemTemplate>
                                        </MudTreeView>
                                    </MudPaper>
