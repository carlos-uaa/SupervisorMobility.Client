                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                                }

                            }
                            else
                            {
                                if (folderHOEError)
                                {
                                    <MudAlert Severity="Severity.Warning" Style="text-align: center"> @Localizer1["ServerNotResponse"] </MudAlert>
                                }
                            }
                        </MudCardContent>
                    </MudCard>



                </MudCardContent>
            </MudCard>




        </MudItem>

    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseHOEModal" Variant="Variant.Filled">@Localizer1["Close"]</MudButton>
    </DialogActions>
</MudDialog>


