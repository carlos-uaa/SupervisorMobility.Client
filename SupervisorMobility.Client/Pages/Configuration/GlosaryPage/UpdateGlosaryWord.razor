@page "/glosary/updateglosaryword/{glosarywordId:int}"
@inject IGroupService GroupService
@inject IGlosaryService GlosaryService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Resource1> Localizer
@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["GlosaryUpdateTitle"]</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        @if (item.Text == "Update Glosary Word")
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">Update @_glosary.Description</MudButton>
        }
        else
        {
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        }
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_glosary" OnValidSubmit="UpdateGlosaryWordAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localizer["GlosaryWordDetails"]</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Info">@Localizer["GlosaryUpdateTitle"]</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="@Localizer["GlosaryDescription"]"
                                  @bind-Value="_glosary.Description" For="@(() => _glosary.Description)" />
                    <MudTextField Label="@Localizer["GlosaryName"]" Class="mt-3"
                                  @bind-Value="_glosary.Name" For="@(() => _glosary.Name)" />
                    @*<MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_glosary.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />*@
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">@Localizer["Save"]</MudButton>
                    <MudButton Href="/glosary" Variant="Variant.Filled" Class="ml-4">@Localizer["Cancel"]</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>