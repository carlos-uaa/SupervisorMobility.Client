@page "/glosary/createglosaryWord"
@inject IGroupService GroupService
@inject IGlosaryService GlosaryService
@inject NavigationManager NavigationManager

@*Title*@
<PageTitle>Supervisor Mobility | Create Glosary Word</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_glosaryWord" OnValidSubmit="CreateGlosaryWordAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Glosary Word Details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">New Glosary Word</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="Description"
                                  @bind-Value="_glosaryWord.Description" For="@(() => _glosaryWord.Description)" />
                    <MudTextField Label="Word" Class="mt-3"
                                  @bind-Value="_glosaryWord.Name" For="@(() => _glosaryWord.Name)" />
                    <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_glosaryWord.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Href="/glosary" Variant="Variant.Filled" Class="ml-4">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>