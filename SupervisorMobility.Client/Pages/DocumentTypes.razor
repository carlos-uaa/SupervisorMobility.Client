@page "/documenttypes"
@inject ISupportDocumentTypeService SupportDocumentTypeService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@*Title*@
<PageTitle>Supervisor Mobility | Document Types</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Plants table*@
<MudTable Items="_supportDocumentTypes" Hover="true" T="SupportDocumentType">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Support document types</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Add" aria-label="add" @onclick="(() => CreateSupportDocType())"></MudIconButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudText Align="Align.Center">Document Id</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Code</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Description</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Status</MudText>
        </MudTh>
        <MudTh>
            <MudText Align="Align.Center">Actions</MudText>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="PlantId">
            <MudText Align="Align.Center">@context.SupportDocumentTypeId</MudText>
        </MudTd>
        <MudTd DataLabel="Code">
            <MudText Align="Align.Center">@context.Code</MudText>
        </MudTd>
        <MudTd DataLabel="Description">
            <MudText Align="Align.Center">@context.Description</MudText>
        </MudTd>
        <MudTd DataLabel="Status">
            @if (context.IsActive == true)
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                </MudText>
            }
            else
            {
                <MudText Align="Align.Center">
                    <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                </MudText>
            }
        </MudTd>
        <MudTd>
            <MudText Align="Align.Center">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit" @onclick="(() => UpdateSupportDocType(context.SupportDocumentTypeId))"></MudIconButton>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" aria-label="edit" @onclick="(() => DeleteSupportDocumentType(context.SupportDocumentTypeId))"></MudIconButton>
            </MudText>
        </MudTd>
    </RowTemplate>
</MudTable>