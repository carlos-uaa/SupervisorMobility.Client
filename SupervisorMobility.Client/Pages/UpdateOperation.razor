@page "/plants/{plantId:int}/areas/{areaId:int}/updateoperation/{operationId:int}"
@inject IOperationService OperationService
@inject NavigationManager NavigationManager

@*Title*@
<PageTitle>Supervisor Mobility | Update Operation</PageTitle>

@*Form*@
<EditForm Model="_operation" OnValidSubmit="UpdateOperationAsync">
    <DataAnnotationsValidator />
    <MudGrid>
        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Operation details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">Create operation</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudTextField Label="Question description"
                                  @bind-Value="_operation.Description" For="@(() => _operation.Description)" />
                    <MudTextField Label="Code" Class="mt-3"
                                  @bind-Value="_operation.Code" For="@(() => _operation.Code)" />
                    <MudSwitch Class="mt-3" Label="Is active?" @bind-Checked="_operation.IsActive" Color="Color.Info" UnCheckedColor="Color.Dark" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Variant="Variant.Filled" Class="ml-4" @onclick="(() => CancelCreateOrUpdate())">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>