@page "/PAT/{patID:int}"
@inject IUserService UsersServices
@inject IAreaService AreasServices
@inject IOperationService OperationsServices
@inject IPATService PATsServices
@inject IJSRuntime JS
@inject IILUService ILUServices

@*Title*@
<PageTitle>Supervisor Mobility | PAT Details</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


<style>
    .merged-cell {
        vertical-align: middle;
    }

    .table-container {
        overflow-x: auto;
    }

    table {
        border-collapse: collapse;
        width: auto;
        min-width: 100%;
        table-layout: fixed;
    }

    th,
    td {
        padding: 8px;
        border: 1px solid black;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .fixed-column {
        position: sticky;
        left: 0;
        z-index: 2;
        background-color: #f0f0f0;
    }

    .dynamic-left {
        left: 0;
    }

    .mud-typography.mud-typography-body1 {
        overflow: hidden;
    }
</style>


@if (ShowTable)
{
    <div class="table-container">
        <div class="scrollable-columns">

            <table>
                <thead>
                    <tr>
                        <th colspan="3" class="fixed-column dynamic-left">Operadores Por Operacion</th>
                        <th colspan="2" rowspan="4" class="fixed-column dynamic-left"> Nombre de operador</th>
                        @foreach (var usr in _UserOfArea)
                        {
                            <th rowspan="4" colspan="2">@usr.Name</th>
                        }
                    </tr>
                    <tr>
                        <th colspan="3" class="fixed-column dynamic-left">___ % EN 1 x ___ </th>
                    </tr>
                    <tr>
                        <th colspan="3" class="fixed-column dynamic-left">Operadores Por operacion</th>
                    </tr>
                    <tr>
                        <th colspan="3" class="fixed-column dynamic-left">___ % EN 2 x ___ </th>
                    </tr>

                </thead>
                <tbody>
                    <tr>

                        <th colspan="1" class="fixed-column dynamic-left"></th>
                        <th colspan="1" class="fixed-column dynamic-left"></th>
                        <th colspan="3" class="fixed-column dynamic-left">Numero de nomina</th>
                        @foreach (var usr in _UserOfArea)
                        {
                            <th colspan="2">@usr.Payroll</th>
                        }
                    </tr>
                    <tr>
                        <th class="fixed-column dynamic-left" style="max-width:60px;width:50px">No</th>
                        <th class="fixed-column dynamic-left" colspan="3">Nombre de La Operacion</th>
                        <th class="fixed-column dynamic-left">No. SOS DIST</th>
                        @foreach (var usr in _UserOfArea)
                        {

                            <th>Fecha</th>
                            <th>Nivel</th>

                        }
                    </tr>
                    @foreach (var op in _operations)
                    {
                        <tr>
                            <td style="max-width:60px;width:50px" class="fixed-column">@op.OperationId</td>
                            <td colspan="3" class="fixed-column dynamic-left">@op.Description</td>
                            <td class="fixed-column dynamic-left"></td>
                            @foreach (var usr in _UserOfArea)
                            {
                                <td style="text-align: end;" colspan="2" >

                                    <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="" Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                        <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar">
                                            Plan job observation
                                        </MudMenuItem>
                                        <MudMenuItem Class="animationContainer" Style="max-width:300px" Icon="@Icons.Material.Filled.Add" OnClick="@( () => OpenDialogAddILU(op.OperationId, usr.UserId))">
                                            <MudText  Class="animationtext">New ILU for @usr.Name in Operation @op.Description </MudText>
                                        </MudMenuItem>
                                    </MudMenu>

                                @if (ILU_Matrix.TryGetValue((op.OperationId, usr.UserId), out var context))
                                {
                                    <table>
                                        <tbody>
                                            @if (context != null)
                                            {
                                                @*@foreach (var register in context)
                                                {
                                                <tr>
                                                <td>@register.AcquisitionDate</td>
                                                <td>Level</td>
                                                <td>@register.OtherProperty</td>
                                                <!-- Agrega más celdas según tus propiedades de ILURegister -->
                                                </tr>
                                                }*@
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td>OPid: @op.OperationId</td>
                                                    <td>usrid: @usr.UserId</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                                </td>

                            }
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
    
}
else
{
    <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
}

<MudDialog DisableSidePadding="false" @bind-IsVisible="AddILUVisibleDialog" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    Add New ILU Level
                </MudText>
            </MudItem>

            <MudItem Class="d-flex flex-column justify-center ma-1">
                <MudSelect T="int" Label="ILU" Variant="Variant.Text" Placeholder="Select a Level" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxILU_Level" For="@(() => auxILU_Level)" SelectedValuesChanged="updateILULevel">
                    <MudSelectItem Disabled="true" Value="0">Select a Level</MudSelectItem>
                    @foreach (var type in _LevelsILU)
                    {
                        <MudSelectItem Value="type.ILULevelId">@($"{type.ILULevelCode}-{type.ILULevelDescription}")</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="AddILUClose">Add</MudButton>
    </DialogActions>
</MudDialog>



@code {
    [Parameter]
    public int patID { get; set; }

    private PAT? _pat { get; set; } = new();
    private List<Operation> _operations { get; set; } = new();
    private List<User> _UserOfArea { get; set; } = new();
    private List<ILULevel> _LevelsILU { get; set; } = new();
    //private ILURegister[,] ILU_Matrix { get; set; } = new ILURegister[0,0];
    private Dictionary<(int, int), List<ILURegister>?> ILU_Matrix { get; set; } = new Dictionary<(int, int), List<ILURegister>?>();

    bool ShowTable = false;

    //dialog
    bool AddILUVisibleDialog = false;
    private ILURegister newIlu { get; set; } = new();
    private int auxILU_Level = 0;


    protected async override Task OnInitializedAsync()
    {
        _pat = await PATsServices.getPat(patID);


        _operations = await OperationsServices.GetOperations(_pat.PlantId, _pat.AreaId, _pat.DistributionId);
        //_UserOfArea = await UsersServices.GetSubordinates((int)_pat.Supervisor.UserId);
        _UserOfArea = await UsersServices.GetUsersWhitCollections();
        _LevelsILU = await ILUServices.GetLevelsILU();

        //Operacion //Operador

        //int numOperations = _operations.Count;
        //int numUsers = _UserOfArea.Count;

        //ILU_Matrix = new ILURegister[numOperations,numUsers];


        foreach (var op in _operations)
        {
            foreach (var usr in _UserOfArea)
            {
                // Obtener los registros correspondientes a la operación y usuario actual
                var matchingRegisters = usr.ILURegisers?
                    .Where(r => r.OperationId == op.OperationId && r.OperatorId == usr.UserId)
                    .OrderByDescending(r => r.AcquisitionDate)
                    .ToList();

                ILU_Matrix.Add((op.OperationId, usr.UserId), matchingRegisters);
                // Almacenar los registros en la
                //ILU_Matrix[op.OperationId, usr.UserId] = matchingRegisters;
            }
        }


        ShowTable = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("blazorUtils.setDynamicLeft");

    }

    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "#"),
            new BreadcrumbItem("PAT", href: "/PAT"),
            new BreadcrumbItem("PAT Details", href: "", disabled: true),
        };


    private void updateILULevel()
    {
        newIlu.ILULevelId = auxILU_Level;
    }

    private async void OpenDialogAddILU(int ID_Operation, int ID_User)
    {
        AddILUVisibleDialog = true;
        newIlu.OperationId = ID_Operation;
        newIlu.OperatorId = ID_User;

        StateHasChanged();
    }

    private async void AddILUClose()
    {

        var result = await ILUServices.AddRegisterForUser(newIlu, (int)newIlu.OperatorId);
        if(result != null)
        {
            //aqui un mensaje bonito 
        }

        AddILUVisibleDialog = false;
        StateHasChanged();
    }

    private DialogOptions dialogOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large, FullWidth = true };

}
