@page "/PAT/{patID:int}"

@using System.Net.Http.Json
@using MudBlazor
@using System.Globalization;

@inject NavigationManager NavigationManager
@inject IUserService UsersServices
@inject IAreaService AreasServices
@inject IOperationService OperationsServices
@inject IPATService PATsServices
@inject IJSRuntime JSRuntime
@inject IILUService ILUServices
@inject ISnackbar Snackbar

@*Title*@
<PageTitle>Supervisor Mobility | PAT Details</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>


<style>
    .merged-cell {
        vertical-align: middle;
    }

    .table-container {
        box-shadow: var(--mud-elevation-1);
        overflow-x: auto;
        border-radius: var(--mud-default-borderradius);
    }

        .table-container:hover {
            box-shadow: var(--mud-elevation-2);
        }

    table {
        border-collapse: collapse;
        width: auto;
        min-width: 100%;
        table-layout: fixed;
        border-radius: var(--mud-default-borderradius);
    }

    th,
    td {
        padding: 8px;
        border: 1px solid #DEDEDF;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .fixed-column {
        position: sticky;
        left: 0;
        z-index: 2;
        background-color: #f0f0f0;
    }

    .dynamic-left {
        left: 0;
    }

    .mud-typography.mud-typography-body1 {
        overflow: hidden;
    }
</style>


@if (ShowTable)
{
    <MudItem Class="d-flex justify-content-between mb-5" Style="align-items: center;">
        <MudText Typo="Typo.h6">PAT Details </MudText>
        <MudItem Style="justify-content: end" Class="ml-auto">
            <MudItem Class="d-flex">
                @if ((user.UserType == 1 || user.UserType == 2) && _pat?.Status == 1)
                {
                <MudChip Class="mr-10" Icon="@Icons.Material.Filled.PlaylistPlay" Color="Color.Warning" Variant="Variant.Text">
                    New
                </MudChip>
                }
                @if ((user.UserType == 1 || user.UserType == 2) && _pat?.Status != 2)
                {
                    <MudButton @onclick="(() => OpenSignComment())" StartIcon="@Icons.Material.Filled.BorderColor" IconColor="Color.Info">Approve PAT</MudButton>
                }
                else if(_pat?.Status == 2)
                {
                    <MudChip Class="mr-10" Icon="@Icons.Material.Filled.PlaylistAddCheck" Color="Color.Success" Variant="Variant.Text">
                        Approved!
                    </MudChip>
                }
            </MudItem>
        </MudItem>
    </MudItem>
    <MudSimpleTable Class="mb-5 calendar-table rounded" Style="overflow-x: auto;" Dense>
    <thead>
        <tr>
            <th>
                <MudItem Class="d-flex">
                    <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
                    <MudText Class="ml-2">Area</MudText>
                </MudItem>
            </th>
            <th style="width:20vw">
                <MudItem Class="d-flex">
                    <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
                    <MudText Class="ml-2">Distribution</MudText>
                </MudItem>
            </th>
            <th>Application Year</th>
            <th>Supervisor</th>
            <th>SSV</th>
            <th>Date</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>
                @_pat?.Area?.Code - @_pat?.Area?.Description

            </td>
            <td>
                @_pat?.Distribution?.Code - @_pat?.Distribution?.Description
            </td>
            <td>@_pat?.AplicationYear</td>
            <td>@_pat?.Supervisor?.Name</td>
            <td>@_pat?.SSVresponsible?.Name</td>
            <td>@_pat?.CreationDate?.ToShortDateString()</td>
        </tr>
    </tbody>
</MudSimpleTable>
    <div class="table-container mb-10">
        <div class="scrollable-columns">

            <table>
                <thead>
                    <tr>
                        <th colspan="3" class="fixed-column dynamic-left">Operadores Por Operacion</th>
                        <th colspan="2" rowspan="4" class="fixed-column dynamic-left"> Nombre de operador</th>
                        @foreach (var usr in _UserOfArea)
                        {
                            @if (User_Knolowed[usr.UserId])
                            {
                                <th rowspan="4" colspan="2">
                                    <div style="text-align: end;">
                                        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="@usr.Name" AnchorOrigin="Origin.BottomCenter">
                                            <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" OnClick="(() => OpenHistoryILU(usr.UserId))" @ontouchstart="(() => OpenHistoryILU(usr.UserId))">
                                                History ILU
                                            </MudMenuItem>
                                        </MudMenu>
                                    </div>
                                </th>
                            }
                            else
                            {
                                <th rowspan="4" colspan="2" style="background-color:#fbe8ce;color:#ff9800">
                                    @usr.Name
                                </th>
                            }
                        }
                    </tr>
                    <tr>
                        <th colspan="3" class="fixed-column dynamic-left">___ % EN 1 x ___ </th>
                    </tr>
                    <tr>
                        <th colspan="3" class="fixed-column dynamic-left">Operadores Por operacion</th>
                    </tr>
                    <tr>
                        <th colspan="3" class="fixed-column dynamic-left">___ % EN 2 x ___ </th>
                    </tr>

                </thead>
                <tbody>
                    <tr>

                        <th colspan="1" class="fixed-column dynamic-left"></th>
                        <th colspan="1" class="fixed-column dynamic-left"></th>
                        <th colspan="3" class="fixed-column dynamic-left">Numero de nomina</th>
                        @foreach (var usr in _UserOfArea)
                        {
                            <th colspan="2">@usr.Payroll</th>
                        }
                    </tr>
                    <tr>
                        <th class="fixed-column dynamic-left" style="max-width:60px;width:50px">No</th>
                        <th class="fixed-column dynamic-left" colspan="3">Nombre de La Operacion</th>
                        <th class="fixed-column dynamic-left">No. SOS DIST</th>
                        @foreach (var usr in _UserOfArea)
                        {

                            <th>Fecha</th>
                            <th>Nivel</th>

                        }
                    </tr>
                    @foreach (var op in _operations)
                    {
                        <tr>

                            @if (Operations_Knolowed[op.OperationId])
                            {
                                <td style="max-width:60px;width:50px" class="fixed-column">@op.OperationId</td>
                                <td colspan="3" class="fixed-column dynamic-left">
                                    <div style="text-align: end;">
                                        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="@op.Description" AnchorOrigin="Origin.BottomCenter">
                                            <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" OnClick="(() => OpenHistoryILU_Operation(op.OperationId))" @ontouchstart="(() => OpenHistoryILU_Operation(op.OperationId))">
                                                History ILU
                                            </MudMenuItem>
                                        </MudMenu>
                                    </div>
                                </td>
                                <td class="fixed-column dynamic-left"></td>
                            }
                            else
                            {

                                <td style="max-width:60px;width:50px; background-color: #f9dad8; color: #f44336;" class="fixed-column">
                                    @op.OperationId
                                </td>
                                <td style="background-color: #f9dad8; color: #f44336;" colspan="3" class="fixed-column dynamic-left">
                                    @op.Description
                                </td>
                                <td class="fixed-column dynamic-left"></td>
                            }

                            @foreach (var usr in _UserOfArea)
                            {
                                <td style="text-align: end;" colspan="2">

                                    <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="" Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                        <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="(() => CreateJobObservation(op.OperationId, usr.UserId))" @ontouchstart="(() => CreateJobObservation(op.OperationId, usr.UserId))">
                                            Create job observation
                                        </MudMenuItem>
                                        <MudMenuItem Class="animationContainer" Style="max-width:300px" Icon="@Icons.Material.Filled.Add" OnClick="@( () => OpenDialogAddILU(op.OperationId, usr.UserId))" @ontouchstart="( () => OpenDialogAddILU(op.OperationId, usr.UserId))">
                                            <MudText Class="animationtext">New ILU for @usr.Name in Operation @op.Description </MudText>
                                        </MudMenuItem>
                                    </MudMenu>

                                    @if (ILU_Matrix.TryGetValue((op.OperationId, usr.UserId), out var context))
                                    {

                                        <table style="border: none">
                                            <tbody>
                                                @{
                                                    var latestContext = context.OrderByDescending(c => c.AcquisitionDate).FirstOrDefault();
                                                    char ILULevelNumber = '§';
                                                    @if (latestContext != null)
                                                    {
                                                        ILULevelNumber = _LevelsILU.Find(u => u.ILULevelId == latestContext.ILULevelId).ILULevelCode;
                                                    }
                                                }

                                                @if (context.Count > 0 && latestContext != null)
                                                {
                                                    <tr style="border: none">
                                                        <td style="border: none">@latestContext.AcquisitionDate?.ToString("dd/MM/yyyy")</td>
                                                        @if (ILULevelNumber != '§')
                                                        {
                                                            <td style="border: none">
                                                                <MudText Typo="Typo.subtitle1"> <b>  @ILULevelNumber </b> </MudText>
                                                            </td>
                                                        }
                                                    </tr>
                                                }
                                                else
                                                {

                                                }
                                            </tbody>
                                        </table>
                                    }
                                </td>

                            }
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

}
else
{
    <MudItem Style="text-align:center;">
        <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
        <MudText Typo="Typo.h6">Loading PAT Details...</MudText>

    </MudItem>
}

<MudDialog DisableSidePadding="false" @bind-IsVisible="AddILUVisibleDialog" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap; flex-direction:column" Class="gap-4">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h5">
                    Add New ILU Level
                </MudText>
            </MudItem>

            <MudItem xs="12" sm="12" lg="12" md="12" Style="display: flex; flex-wrap: wrap; flex-direction:row">
                <MudItem xs="12" sm="12" lg="12" md="12" >
                    <MudText Typo="Typo.h6">
                        Operator Info
                    </MudText>
                </MudItem>
                <MudTextField ReadOnly Style="max-width: 100px;" Label="Payroll" Value="_UserOfArea.Find(u => u.UserId == _newIlu.OperatorId).Payroll"></MudTextField>
                <MudTextField ReadOnly Label="Operator Name" Value="_UserOfArea.Find(u => u.UserId == _newIlu.OperatorId).Name"></MudTextField>
            </MudItem>

                <MudItem xs="12" sm="12" lg="12" md="12" Style="display: flex; flex-wrap: wrap; flex-direction:row">
                <MudItem xs="12" sm="12" lg="12" md="12">
                    <MudText Typo="Typo.h6">
                        Operation Info
                    </MudText>
                </MudItem>
              
            <MudTextField ReadOnly Label="Operation Name" Value="_operations.Find(u => u.OperationId == _newIlu.OperationId).Description"></MudTextField>
            </MudItem>


            <MudItem Class="d-flex flex-column justify-center ma-1">
                <MudSelect T="int" Label="ILU" Variant="Variant.Text" Placeholder="Select a Level" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@auxILU_Level" For="@(() => auxILU_Level)" SelectedValuesChanged="updateILULevel">
                    <MudSelectItem Disabled="true" Value="0">Select a Level</MudSelectItem>
                    @foreach (var type in _LevelsILU)
                    {
                        <MudSelectItem Value="type.ILULevelId">@($"{type.ILULevelCode}-{type.ILULevelDescription}")</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" Disabled="@(auxILU_Level != 0 ? false : true)" OnClick="AddILUClose">Add ILU Level</MudButton>
    </DialogActions>
</MudDialog>


<MudDialog DisableSidePadding="false" @bind-IsVisible="ILUHistoryDialog" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap; flex-direction:row" Class="gap-4">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    ILU History Of Operations In User
                </MudText>
            </MudItem>
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudTextField ReadOnly="true" Value="@_UserOfArea.Find(u => u.UserId == auxILU_UseId).Name" Label="Name"> </MudTextField>
                <MudTextField ReadOnly="true" Value="@_UserOfArea.Find(u => u.UserId == auxILU_UseId).Payroll" Label="Payroll"> </MudTextField>
            </MudItem>

            @if (AllRegistersOperationsInUser?.Count > 0)
            {
                <MudTable Hover="true" Breakpoint="Breakpoint.Sm" FixedHeader="true"
                      Items="@AllRegistersOperationsInUser"
                      GroupBy="@OperationsInUser"
                      GroupHeaderStyle="background-color:var(--mud-palette-background-grey)"
                      GroupFooterClass="mb-4">
                    <ColGroup>

                        <col />
                        <col />
                        <col />
                        <col />
                    </ColGroup>
                    <HeaderContent>
                        <MudTh>Id</MudTh>
                        <MudTh>Level</MudTh>
                        <MudTh>Description Level</MudTh>
                        <MudTh>Adquisition Date</MudTh>
                    </HeaderContent>
                    <GroupHeaderTemplate>
                        <MudTh Class="mud-table-cell-custom-group" colspan="4">
                            @($"{context.GroupName}: {_operations.Find(o => o.OperationId == (int)context.Key).Description}")
                        </MudTh>
                    </GroupHeaderTemplate>
                    <RowTemplate>
                        <MudTd DataLabel="Id">@context.ILURegisterid</MudTd>
                        <MudTd DataLabel="level">
                            <MudText Typo="Typo.subtitle1">
                                <b>
                                    @_LevelsILU.Find(u => u.ILULevelId == context.ILULevelId).ILULevelCode
                                </b>
                            </MudText>
                        </MudTd>
                        <MudTd DataLabel="Description Level" Class="animationContainer">
                            <MudText Class="animationtext">
                                @_LevelsILU.Find(u => u.ILULevelId == context.ILULevelId).ILULevelDescription
                            </MudText>
                        </MudTd>
                        <MudTd DataLabel="Adquisition Date">@context.AcquisitionDate?.ToString("dd/MM/yyyy")</MudTd>
                    </RowTemplate>
                    <GroupFooterTemplate>
                        <MudTh Class="mud-table-cell-custom-group mud-table-cell-custom-group-footer" colspan="4">Most recent registration to @_operations.Find(o => o.OperationId == (int)context.Key).Description is: @context.Items.OrderByDescending(e => e.AcquisitionDate).First().AcquisitionDate?.ToString("dd/MM/yyyy") </MudTh>
                    </GroupFooterTemplate>
                </MudTable>

            }

        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="CloseHistoryILU">Close</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog DisableSidePadding="false" @bind-IsVisible="ILUHistoryOperationDialog" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap; flex-direction:row" Class="gap-4">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
