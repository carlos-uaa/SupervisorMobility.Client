                var latestContext = context.OrderByDescending(c => c.AcquisitionDate);

                if (latestContext?.Count() > 0)
                {
                    AllRegistersUsersInOperation.AddRange(latestContext);
                }
            }
        }
        ILUHistoryOperationDialog = true;
        StateHasChanged();
    }

