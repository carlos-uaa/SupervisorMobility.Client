@page "/PAT/{patID:int}"
@inject IUserService UsersServices
@inject IAreaService AreasServices
@inject IOperationService OperationsServices
@inject IPATService PATsServices

@*Title*@
<PageTitle>Supervisor Mobility | PAT Details</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>





@code {
    [Parameter]
    public int patID { get; set; }


    private Data.Entities.PAT? _pat { get; set; } = new();
    private List<Operation> _operations { get; set; } = new();
    private List<User> _allUsers { get; set; } = new();
    private List<User> _UserOfArea { get; set; } = new();
    private Dictionary<int, Dictionary<int, ILURegister>> ILU_Matrix = new();

    protected async override Task OnInitializedAsync()
    {
        _pat = await PATsServices.getPat(patID);
        _operations = await OperationsServices.GetOperations(_pat.Area.PlantId, _pat.AreaId, _pat.DistributionId);
        _allUsers = await UsersServices.GetUsersWhitCollections();

        foreach(User userInList in _allUsers)
        {
            if(userInList.AreaId == _pat.AreaId)
                _UserOfArea?.Add(userInList);
        }
        //Operacion //Operador

        foreach(var op in _operations){

            foreach(var usr in _UserOfArea)
            {
                var reg = usr.ILURegisers.Where(r => r.OperationId == op.OperationId && r.OperatorId == usr.UserId)
                    .OrderByDescending(r => r.AcquisitionDate)
                    .First();

                if(reg != null)
                {
                    //ILU_Matrix.Add(new Dictionary(op.OperationId, new Dictionary(usr.UserId, reg)));
                }

                
            }
        }


    }

    private List<BreadcrumbItem> _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "#"),
            new BreadcrumbItem("PAT", href: "/PAT"),
            new BreadcrumbItem("PAT Details", href: "", disabled: true),
        };



}
