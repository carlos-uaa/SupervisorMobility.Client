@page "/PAT/createPat"

@inject NavigationManager NavigationManager
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IDistributionService DistributionService
@inject IOperationService OperationService
@inject IPATService PATsServices
@inject IJSRuntime JSRuntime
@inject IUserService UsersService
@inject ISnackbar Snackbar

@*Title*@
<PageTitle>Supervisor Mobility | Create PAT</PageTitle>

@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@*Form*@
<EditForm Model="_pat" OnValidSubmit="CreatePatAsync">
    <DataAnnotationsValidator />
    <MudGrid Class="d-flex " Style="flex-direction: column; align-content: center;">
        <MudItem>
            <MudCard Style="min-width: 50vw">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">PAT Details</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Variant="Variant.Text" Color="Color.Success">New PAT</MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (user.UserType == 1)
                    {
                        @*Mud select for Plants for Admin*@
                        <MudSelect T="int" Label="Plant" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.PlantId" For="@(() => _pat.PlantId)" SelectedValuesChanged="ShowAreas">
                            <MudSelectItem Disabled="true" Value="0">Select a Plant</MudSelectItem>
                            @foreach (var type in _plants)
                            {
                                <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        @*Mud select for Plants *@
                        <MudSelect T="int" Label="Plant" Variant="Variant.Text" Placeholder="Select a Plant" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.PlantId" For="@(() => _pat.PlantId)" SelectedValuesChanged="ShowAreas">
                            @foreach (var type in _plants)
                            {
                                if (type.PlantId == user.PlantId)
                                {
                                    <MudSelectItem Value="type.PlantId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    }


                    @if (_pat.PlantId != 0 && user.UserType == 1)
                    {
                        @*Mud select for Areas for Admin *@
                        <MudSelect T="int" Label="Area" Variant="Variant.Text" Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.AreaId" For="@(() => _pat.AreaId)" SelectedValuesChanged="ShowDistributions">
                            <MudSelectItem Disabled="true" Value="0">Select an Area</MudSelectItem>
                            @foreach (var type in _areas)
                            {
                                <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (_pat.PlantId != 0 && user.UserType == 2)
                    {
                        @*Mud select for Areas for SSV *@
                        <MudSelect T="int" Label="Area" Variant="Variant.Text" Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.AreaId" For="@(() => _pat.AreaId)" SelectedValuesChanged="ShowDistributions">
                            <MudSelectItem Disabled="true" Value="0">Select an Area</MudSelectItem>
                            @foreach (var type in user.Areas)
                            {
                                <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (_pat.PlantId != 0)
                    {
                        @*Mud select for Areas for SV *@
                        <MudSelect T="int" Label="Area" Variant="Variant.Text" Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.AreaId" For="@(() => _pat.AreaId)" SelectedValuesChanged="ShowDistributions">
                            <MudSelectItem Disabled="true" Value="0">Select an Area</MudSelectItem>
                            @foreach (var type in _areas)
                            {
                                if (type.AreaId == user.AreaId)
                                {
                                    <MudSelectItem Value="type.AreaId">@($"{type.Code} - {type.Description}")</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    }
                    else
                    {
                        @*Mud select for Areas *@
                        <MudSelect T="int" Label="Area" Variant="Variant.Text" Disabled Placeholder="Select an Area" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.AreaId" For="@(() => _pat.AreaId)" SelectedValuesChanged="ShowDistributions">
                            <MudSelectItem Disabled="true" Value="0">First Select a Plant</MudSelectItem>
                        </MudSelect>
                    }

                    @*Mud select for Distribution *@
                    @if (_pat.AreaId != 0)
                    {
                        <MudSelect T="int" Label="Distribution" Variant="Variant.Text" Placeholder="Select a Distribution" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.DistributionId" For="@(() => _pat.DistributionId)">
                            <MudSelectItem Disabled="true" Value="0">Select a Distribution</MudSelectItem>
                            @foreach (var type in _distributions)
                            {
                                <MudSelectItem Value="type.DistributionId">
                                    @(
                                $"{type.Code} - {type.Description}"
                                )
                                </MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        <MudSelect T="int" Label="Distribution" Disabled Variant="Variant.Text" Placeholder="Select a Distribution" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_pat.DistributionId" For="@(() => _pat.DistributionId)">
                            <MudSelectItem Disabled="true" Value="0">First Select an Area</MudSelectItem>
                        </MudSelect>
                    }

                    <MudDatePicker @bind-Date="_pat.AplicationDate" Label="Application Date" PickerVariant="PickerVariant.Dialog" OpenTo="OpenTo.Year" Color="Color.Info" AdornmentColor="Color.Info" Class="mt-3" />

                    @if(user.UserType == 1){

                    }
                    else if(user.UserType == 3){
                        <MudTextField T="string" @bind-Value="user.Name" Label="Supervisor" Class="mt-3" />
                        <MudTextField T="string" @bind-Value="SupervisorName" Label="SSV" Class="mt-3" />

                    }

                </MudCardContent>
                <MudCardActions>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Info" Class="ml-auto">Save</MudButton>
                    <MudButton Href="/plants" Variant="Variant.Filled" Class="ml-4">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>