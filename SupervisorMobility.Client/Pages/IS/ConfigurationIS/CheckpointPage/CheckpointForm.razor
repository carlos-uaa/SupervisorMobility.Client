@page "/configurationIS/Checkpoint/Create"
@page "/configurationIS/Checkpoint/Details/{CheckpointId:int}"
@page "/configurationIS/Checkpoint/Update/{CheckpointId:int}"

@inject ICheckPointService _CheckPointServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject ISnackbar Snackbar
@inject IBreadcrumbService BreadcrumbService

<style>
    .loading-container {
        height: 100%;
        background-color: rgba(var(--mud-palette-surface-rgb), 0.7);
    }

    .checkpoint-card {
        height: 100%;
        width: 100%;
        transition: transform 0.2s;
        border: 1px solid var(--mud-palette-divider);
    }

    .checkpoint-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--mud-elevation-4);
    }

    .image-scroll-container {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        justify-content: center;
        gap: 16px;
        max-height: 50vh;
        overflow-y: auto;
        padding: 10px;
    }

    .image-preview-item {
        position: relative;
        transition: opacity 0.2s;
    }

    .delete-btn-overlay {
        position: absolute;
        top: -10px;
        right: -10px;
        z-index: 10;
        background: var(--mud-palette-surface);
        border-radius: 50%;
    }

    .styled-table {
        border-radius: 8px;
        overflow: hidden;
    }
</style>

@if (ShowLoading)
{
    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel"
                 AutoCycle="true" Style="height:300px;" ShowArrows="false"
                 ShowBullets="false" EnableSwipeGesture="false">
        <ItemTemplate>
            <div class="d-flex flex-column align-center justify-center loading-container">
                <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]"
                                     Size="Size.Large" Indeterminate="true" Class="mb-4" />
                <MudText Typo="Typo.h6" Color="Color.Primary">@Carousel</MudText>
            </div>
        </ItemTemplate>
    </MudCarousel>
}
else
{
    @if (PageType.Details == pageType)
    {
        <MudGrid Class="mt-4" Spacing="3">
            @* Lado Izquierdo: Información del Checkpoint *@
            <MudItem xs="12" md="4" lg="3">
                <MudButton Variant="Variant.Text" @onclick="(() => CheckpointUpdate((int)CheckpointId))" FullWidth="true" Class="pa-0">
                    <MudCard Class="checkpoint-card">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">ID: @_Checkpoint.CheckpointId</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <div class="d-flex flex-column align-center">
                                <MudIcon Icon="@Icons.Filled.ViewList" Size="Size.Large" Color="Color.Info" Class="mb-2" />
                                <MudText Typo="Typo.h5" Align="Align.Center">@_Checkpoint.CheckpointTitle</MudText>
                                <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary mb-4">@_Checkpoint.CheckpointDescription</MudText>
                                
                                <MudChip Variant="Variant.Filled" Color="@(_Checkpoint.IsActive == true ? Color.Success : Color.Error)" Size="Size.Small">
                                    @(_Checkpoint.IsActive == true ? "Active" : "Inactive")
                                </MudChip>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudButton>

                <div class="image-scroll-container mt-4">
                    @foreach (var (image, index) in CheckpointImages.Select((image, index) => (image, index)))
                    {
                        <MudImage ObjectFit="ObjectFit.Cover" 
                                  Style="cursor:pointer; width: 120px; height: 80px;" 
                                  Src="@image.src" Alt="Sketch" 
                                  Elevation="4" Class="rounded-lg" 
                                  @onclick="() => OpenSketchDialog(index, 0)" />
                    }
                </div>
            </MudItem>

            @* Lado Derecho: Tablas y Contenido Principal *@
            <MudItem xs="12" md="8" lg="9">
                <MudTabs Elevation="2" Rounded="true" Color="@Color.Info" ApplyEffectsToContainer="true" PanelClass="pa-4">
                    <MudTabPanel Icon="@Icons.Material.Filled.Checklist" Text="Standards">
                        @if (_Checkpoint.Standars?.Any() == true)
                        {
                            <MudTable Items="_Checkpoint.Standars" Hover="true" T="CheckpointNorm" 
                                      Class="styled-table" Height="65vh" FixedHeader="true"
                                      RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" 
                                      OnRowClick="RowClickEvent" Filter="new Func<CheckpointNorm,bool>(FilterFunc)">
                                <ToolBarContent>
                                    <MudText Typo="Typo.h6">List of Standards</MudText>
                                    <MudSpacer />
                                    <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" 
                                                 AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Clearable />
                                    <MudSpacer />
                                    <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                                        <MudButton StartIcon="@Icons.Material.Filled.Add" OnClick="(() => CreateStandars((int)CheckpointId))">Create</MudButton>
                                        <MudButton StartIcon="@Icons.Material.Filled.Reorder" OnClick="(() => StandarsSequence((int)CheckpointId))">Re-order</MudButton>
                                    </MudButtonGroup>
                                </ToolBarContent>
                                <HeaderContent>
                                    @if (user.UserType == 1)
                                    {
                                        <MudTh><MudTableSortLabel SortBy="new Func<CheckpointNorm, object>(x=>x?.CheckpointNormId)">ID</MudTableSortLabel></MudTh>
                                    }
                                    <MudTh><MudTableSortLabel SortBy="new Func<CheckpointNorm, object>(x=>x?.Standard)">Standard Name</MudTableSortLabel></MudTh>
                                    <MudTh><MudTableSortLabel InitialDirection="SortDirection.Ascending" SortBy="new Func<CheckpointNorm, object>(x=>x?.ItemOrder)">Sequence</MudTableSortLabel></MudTh>
                                    @if (user.UserType == 1)
                                    {
                                        <MudTh>Status</MudTh>
                                    }
                                    <MudTh Style="text-align:center">Actions</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    @if (user.UserType == 1)
                                    {
                                        <MudTd DataLabel="ID">@context.CheckpointNormId</MudTd>
                                    }
                                    <MudTd DataLabel="Standard">@context.Standard</MudTd>
                                    <MudTd DataLabel="Sequence">@context.ItemOrder</MudTd>
                                    @if (user.UserType == 1)
                                    {
                                        <MudTd DataLabel="Status">
                                            <MudChip Size="Size.Small" Variant="Variant.Text" Color="@(context.IsActive == true ? Color.Success : Color.Error)">
                                                @(context.IsActive == true ? "Active" : "Inactive")
                                            </MudChip>
                                        </MudTd>
                                    }
                                    <MudTd Style="text-align:center">
                                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" OnClick="(() => UpdateStandars((int)CheckpointId, context.CheckpointNormId))">Edit</MudMenuItem>
                                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="(() => DeleteStandars((int)CheckpointId, context.CheckpointNormId))">Delete</MudMenuItem>
                                        </MudMenu>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="d-flex flex-column align-center py-10">
                                <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Size="Size.Large" Color="Color.Default" />
                                <MudText Typo="Typo.h6" Class="mud-text-secondary">No standards found.</MudText>
                                <MudButton Variant="Variant.Filled" Color="Color.Info" Class="mt-4" OnClick="(() => CreateStandars((int)CheckpointId))">Create New Standard</MudButton>
                            </div>
                        }
                    </MudTabPanel>
                </MudTabs>
            </MudItem>
        </MudGrid>
    }
    else
    {
        @* Formulario Mejorado *@
        <EditForm Model="_Checkpoint" OnValidSubmit="SubmitOperations">
            <DataAnnotationsValidator />
            <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
                <MudCard Elevation="4" Class="rounded-lg">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h5" Color="Color.Primary" Class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
                                @switch (pageType)
                                {
                                    case PageType.Create: @Localizer["CheckpointCreate"] break;
                                    case PageType.Update: @Localizer["CheckpointUpdate"] break;
                                    default: @Localizer["CheckpointDetails"] break;
                                }
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                             <MudChip Variant="Variant.Filled" Color="Color.Success">@pageType.ToString()</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12" sm="8">
                                <MudTextField Label="@Localizer1["CheckpointTitle"]" @bind-Value="_Checkpoint.CheckpointTitle" For="@(() => _Checkpoint.CheckpointTitle)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" />
                                <MudTextField Label="@Localizer1["CheckpointDescription"]" @bind-Value="_Checkpoint.CheckpointDescription" For="@(() => _Checkpoint.CheckpointDescription)" Variant="Variant.Outlined" Lines="3" />
                                
                                @if (user.UserType == 1)
                                {
                                    <MudSwitch Label="Status Active" @bind-Checked="_Checkpoint.IsActive" Color="Color.Success" Class="mt-4" />
                                }
                            </MudItem>

                            <MudItem xs="12" sm="4" Class="d-flex flex-column align-center justify-center">
                                <div class="d-flex gap-2 mb-4">
                                    <InputFile id="previousSketch" OnChange="@((e) => UploadFiles(e, 1))" hidden multiple accept=".jpg, .jpeg, .gif, .svg, .png" />
                                    <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload" for="previousSketch">
                                        Upload
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.AddAPhoto" OnClick="() => OpenCameraDialog(1)">
                                        Camera
                                    </MudButton>
                                </div>
                                
                                <div class="image-scroll-container border-2 mud-border-primary rounded-lg" style="width: 100%; min-height: 150px; background: var(--mud-palette-background-grey);">
                                    @foreach (var (image, index) in CheckpointImages.Select((image, index) => (image, index)))
                                    {
                                        <div class="image-preview-item">
                                            <div class="delete-btn-overlay">
                                                <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" OnClick="() => OpenDeleteDialog(index, true, false)" />
                                            </div>
                                            <MudImage ObjectFit="ObjectFit.Cover" Height="60" Width="90" Src="@image.src" Class="rounded-sm shadow-sm" @onclick="() => OpenSketchDialog(index, 0)" />
                                        </div>
                                    }
                                </div>
                            </MudItem>

                            <MudItem xs="12">
                                <div class="d-flex align-center mb-4">
                                    <MudText Typo="Typo.h6">Norms & Standards</MudText>
                                    <MudSpacer />
                                    <MudButton StartIcon="@Icons.Material.Filled.AddCircle" Variant="Variant.Outlined" Color="Color.Info" Disabled="AddNormStandar" OnClick="AddOneMoreNormStandar">
                                        @Localizer1["AddDP_NormStandar"]
                                    </MudButton>
                                </div>

                                <MudTable Items="_Checkpoint.Standars" T="CheckpointNorm" Class="styled-table" Elevation="0" 
                                          Breakpoint="Breakpoint.Sm" RowEditPreview="BackupItem" RowEditCancel="ResetItemToOriginalValues" RowEditCommit="ItemHasBeenCommitted">
                                    <HeaderContent>
                                        @if (user.UserType == 1) { <MudTh>ID</MudTh> }
                                        <MudTh>Specification</MudTh>
                                        @if (user.UserType == 1) { <MudTh Style="text-align:center">Active</MudTh> }
                                        <MudTh Style="text-align:right">Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate Context="specContext">
                                        @if (user.UserType == 1) { <MudTd>@(specContext.CheckpointNormId < 0 ? "NEW" : specContext.CheckpointNormId)</MudTd> }
                                        <MudTd>@specContext.Standard</MudTd>
                                        @if (user.UserType == 1) { 
                                            <MudTd Style="text-align:center"><MudCheckBox @bind-Checked="specContext.IsActive" ReadOnly Color="Color.Primary" Size="Size.Small" /></MudTd> 
                                        }
                                        <MudTd Style="text-align:right">
                                            @if (specContext.CheckpointNormId > 0) {
                                                <MudIconButton Icon="@Icons.Material.Filled.ImageSearch" Color="Color.Info" OnClick="(() => OpenImagesEditor(specContext.CheckpointNormId))" Size="Size.Small" />
                                            }
                                        </MudTd>
                                    </RowTemplate>
                                    <RowEditingTemplate Context="specContext">
                                        @if (user.UserType == 1) { <MudTd>ID</MudTd> }
                                        <MudTd><MudTextField @bind-Value="@specContext.Standard" Required Margin="Margin.Dense" /></MudTd>
                                        @if (user.UserType == 1) { 
                                            <MudTd Style="text-align:center"><MudSwitch @bind-Checked="specContext.IsActive" Color="Color.Success" /></MudTd> 
                                        }
                                    </RowEditingTemplate>
                                </MudTable>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>

                    <MudCardActions Class="pa-4 bg-light">
                        <MudSpacer />
                        <MudButton Href="/configurationIS/Checkpoint" Variant="Variant.Text" Class="mr-2">@Localizer["Cancel"]</MudButton>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save">
                            @(pageType == PageType.Create ? Localizer["create"] : Localizer["save"])
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudContainer>
        </EditForm>
    }
}

@*Camera Modal*@
<MudDialog DisableSidePadding="true" @bind-IsVisible="visibleCamera" Options="dialogCameraOptions">
    <TitleContent>
        <MudText Typo="Typo.h5" Align="Align.Center" Class="pt-4">Kaizen Sketch</MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer MaxWidth="MaxWidth.Medium">
            <MudPaper Elevation="4" Class="relative d-flex flex-column align-center justify-center overflow-hidden" Style="border-radius: 16px; background: #000;">
                <CameraStreamer @ref=CameraStreamerReference
                                Width=1280
                                Height=720
                                OnRendered=OnRenderedHandler
                                OnFrame=OnFrameHandler
                                Style="width: 100%; max-height: 60vh; object-fit: cover;"
                                CameraID=@cameraId
                                Autostart />
                
                @* Overlay de controles sobre la cámara *@
                <div class="pa-4 w-100 d-flex justify-center" style="background: rgba(0,0,0,0.5)">
                    <MudButton @onclick=GetCurrentFrame
                               Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.PhotoCamera"
                               Color="Color.Info"
                               Size="Size.Large"
                               Disabled="@(frameCount <= 0)"
                               Class="rounded-pill px-8">
                        @Localizer["Take Photo"]
                    </MudButton>
                </div>
            </MudPaper>
        </MudContainer>
    </DialogContent>
</MudDialog>


@*Sketch Modal*@
<MudDialog @bind-IsVisible="visibleSketch" Options="dialogSketchOptions">
    <DialogContent>
        <MudTabs @bind-ActivePanelIndex="selectedSketch"
                 Centered="true"
                 Color="Color.Info"
                 SliderColor="Color.Info"
                 ApplyEffectsToContainer="true"
                 PanelClass="pa-4">
            
            <MudTabPanel Icon="@Icons.Material.Filled.Collections" Text="Sketches">
                @if (CheckpointImages.Any())
                {
                    <MudCarousel Class="mud-width-full rounded-xl"
                                 Style="height: 65vh;"
                                 ShowArrows="true"
                                 ShowBullets="true"
                                 AutoCycle="false"
                                 TData="object"
                                 @bind-SelectedIndex=@photoIndex>
                        <PreviousButtonTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowBackIosNew" Color="Color.Default" Class="ma-2" Style="background: rgba(255,255,255,0.3); backdrop-filter: blur(4px);" />
                        </PreviousButtonTemplate>
                        <NextButtonTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.ArrowForwardIos" Color="Color.Default" Class="ma-2" Style="background: rgba(255,255,255,0.3); backdrop-filter: blur(4px);" />
                        </NextButtonTemplate>
                        <ChildContent>
                            @foreach (var Sketch in CheckpointImages)
                            {
                                <MudCarouselItem Transition="Transition.Fade">
                                    <div class="d-flex justify-center align-center h-100 bg-darker">
                                        <MudImage ObjectFit="ObjectFit.Contain"
                                                  Src=@Sketch.src
                                                  Class="rounded-lg shadow-lg"
                                                  Style="max-height: 100%; max-width: 100%;" />
                                    </div>
                                </MudCarouselItem>
                            }
                        </ChildContent>
                    </MudCarousel>
                }
                else
                {
                    <div class="d-flex flex-column align-center justify-center" style="height: 50vh">
                        <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Size="Size.Large" Color="Color.Default" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary">@Localizer["No sketches available"]</MudText>
                    </div>
                }
            </MudTabPanel>
            @* ... Repetir lógica similar para el panel de "Just added" ... *@
        </MudTabs>
    </DialogContent>
</MudDialog>

@* Dialog Delete Image *@
<MudDialog @bind-IsVisible="visibleDelete" Options="dialogSketchOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
        <MudText Class="mt-4 mb-4">
            <span style="color: #2196f3; text-align:justify">@user.Name</span>,
            @Localizer["Are you sure you want to delete this Image?"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
        <MudButton @onclick="(() => RemoveImage())" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">@Localizer["delete"]</MudButton>
    </DialogActions>
</MudDialog>
@* Manage ImagesItems *@

<MudDialog @bind-IsVisible="seeImgManager" Options="dialogDeleteOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Manage Images</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="4">
            @* Botones de Acción Superiores *@
            <div class="d-flex justify-center gap-4 py-2">
                <InputFile id="previousSketch" OnChange="@((e) => UploadFiles(e, 1, ckStd_id))" hidden multiple />
                <MudButton HtmlTag="label" for="previousSketch" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.CloudUpload">
                    Upload
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.AddAPhoto" OnClick="() => OpenCameraDialog(1, ckStd_id)">
                    Take Photo
                </MudButton>
            </div>

            <MudDivider DividerType="DividerType.Middle" Class="my-2" />

            @* Grid de Imágenes *@
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 16px; max-height: 50vh; overflow-y: auto;" class="pa-2">
                @foreach (var (image, index) in StandarImages[ckStd_id].Select((img, i) => (img, i)))
                {
                    <div class="relative shadow-md rounded-lg overflow-hidden border-2 border-transparent hover:border-info transition-all" style="aspect-ratio: 1/1;">
                        <MudImage ObjectFit="ObjectFit.Cover" Src="@image.src" Width="120" Height="120" @onclick="() => OpenSketchDialog(index, 0)" Style="cursor:pointer" />
                        
                        <div class="absolute top-0 right-0">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Class="ma-1"
                                           Style="background: white;"
                                           OnClick="() => OpenDeleteDialog(index, true, false, image.imgId)" />
                        </div>
                    </div>
                }
            </div>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseImagesEditor" Variant="Variant.Text">@Localizer["Close"]</MudButton>
    </DialogActions>
</MudDialog>