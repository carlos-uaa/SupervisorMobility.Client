@page "/configurationIS/Parts/Create"
@page "/configurationIS/Parts/Details/{PartId:int}"
@page "/configurationIS/Parts/Update/{PartId:int}"

@inject IPartServices PartsServices
@inject IProductService ProductsServices
@inject IFileUploadAndDownloadService FilesServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject ISnackbar Snackbar
@inject IBreadcrumbService BreadcrumbService
@inject IDialogService DialogService

<style>
    .image-container {
        position: relative;
        display: inline-block;
    }
    .image-container:hover .delete-btn {
        display: block;
    }
    .delete-btn {
        position: absolute;
        top: -10px;
        right: -10px;
        background-color: white !important;
        box-shadow: 0px 2px 4px rgba(0,0,0,0.2);
        display: none;
    }
</style>


<MudDialog @bind-IsVisible="visibleMain">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(pageType == PageType.Create ? Icons.Material.Filled.AddBox : Icons.Material.Filled.Edit)" Class="mr-2 mb-n1" />
            @switch (pageType)
            {
                case PageType.Create: @Localizer["PartCreate"] break;
                case PageType.Update: @Localizer["PartUpdate"] break;
                case PageType.Details: @Localizer["PartDetails"] break;
            }
        </MudText>
    </TitleContent>

    <DialogContent>
        @if (ShowLoading)
        {
            <div class="d-flex flex-column align-center justify-center py-10">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                <MudText Class="mt-4">@_sourceMsgLoading.FirstOrDefault()</MudText>
            </div>
        }
        else
        {
            <EditForm id="partForm" Model="_Part" OnValidSubmit="SubmitOperations">
                <DataAnnotationsValidator />
                <MudGrid>
                    @* --- SECCIÓN: INFORMACIÓN GENERAL --- *@
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">Información de la Parte</MudText>
                        <MudDivider Class="mb-4" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField Label="@Localizer1["PartName"]" 
                                      Variant="Variant.Outlined"
                                      ReadOnly="@(pageType == PageType.Details)" 
                                      @bind-Value="_Part.PartName" 
                                      For="@(() => _Part.PartName)" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudTextField Label="@Localizer1["PartNumber"]" 
                                      Variant="Variant.Outlined"
                                      ReadOnly="@(pageType == PageType.Details)" 
                                      @bind-Value="_Part.PartNumber" 
                                      For="@(() => _Part.PartNumber)" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudSelect T="int" Label=@Localizer["product"] 
                                   ReadOnly="@(pageType == PageType.Details)" 
                                   Variant="Variant.Outlined" 
                                   AdornmentIcon="@Icons.Material.Filled.DirectionsCar" 
                                   @bind-Value="@_Part.ModelId">
                            <MudSelectItem Value="0">@Localizer["selectAProduct"]</MudSelectItem>
                            @foreach (var type in _products)
                            {
                                <MudSelectItem Value="type.ProductId">@type.Code</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @if (user.UserType == 1)
                    {
                        <MudItem xs="12">
                            <MudSwitch Label="¿Está activo?" 
                                       ReadOnly="@(pageType == PageType.Details)" 
                                       @bind-Checked="_Part.IsActive" 
                                       Color="Color.Success" />
                        </MudItem>
                    }

                    @* --- SECCIÓN: MULTIMEDIA --- *@
                    <MudItem xs="12" Class="mt-4">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">Evidencia y Sketches</MudText>
                        <MudDivider Class="mb-4" />
                        
                        @if (pageType != PageType.Details)
                        {
                            <MudStack Row="true" Spacing="2" Class="mb-4">
                                <InputFile id="fileInput" OnChange="@((e) => UploadFiles(e, 1))" hidden multiple accept=".jpg,.jpeg,.png" />
                                <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" 
                                           StartIcon="@Icons.Material.Filled.CloudUpload" for="fileInput">
                                    Subir Imagen
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Info" 
                                           StartIcon="@Icons.Material.Filled.AddAPhoto" OnClick="() => OpenCameraDialog(1)">
                                    Cámara
                                </MudButton>
                            </MudStack>
                        }

                        @* Galería de Imágenes *@
                        <div class="d-flex flex-wrap gap-4 mt-2" style="max-height: 300px; overflow-y: auto;">
                            @foreach (var (image, index) in partImages.Select((img, i) => (img, i)))
                            {
                                <div class="image-container">
                                    <MudImage Src="@image" Width="120" Height="80" ObjectFit="ObjectFit.Cover" 
                                              Class="rounded-lg shadow-sm cursor-pointer" @onclick="() => OpenEvidenceDialog(index, 0)" />
                                    @if (pageType != PageType.Details)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                       Class="delete-btn" OnClick="() => OpenDeleteDialog(index, true, false)" />
                                    }
                                </div>
                            }
                            @* (Repetir mismo bloque para tempCapturedImages) *@
                        </div>
                    </MudItem>
                </MudGrid>
            </EditForm>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">@Localizer["Cancel"]</MudButton>
        @if (pageType != PageType.Details && !ShowLoading)
        {
            <MudButton ButtonType="ButtonType.Submit" form="partForm" Variant="Variant.Filled" 
                       Color="Color.Primary" Class="px-10">
                @(pageType == PageType.Create ? Localizer["create"] : Localizer["save"])
            </MudButton>
        }
    </DialogActions>
</MudDialog>