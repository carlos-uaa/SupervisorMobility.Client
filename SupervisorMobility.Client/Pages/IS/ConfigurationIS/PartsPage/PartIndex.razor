@page "/configurationIS/Parts"



@inject IPartServices PartsServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject ISnackbar Snackbar
@inject IBreadcrumbService BreadcrumbService
@inject IDialogService DialogService

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["Parts"]</PageTitle>


@if (ShowLoading)
{
    @* Loading simplificado y elegante *@
    <div class="d-flex flex-column align-center justify-center mud-width-full" style="height:400px;">
        <MudProgressCircular Color="Color.Primary" Style="height:80px;width:80px;" Indeterminate="true" />
        <MudText Typo="Typo.h6" Color="Color.Primary" Class="mt-4 animate-pulse">Cargando catálogo de partes...</MudText>
    </div>
}
else if (_Parts == null || _Parts.Count == 0)
{
    @* Empty State con diseño de "Caja" *@
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
        <MudPaper Elevation="3" Class="pa-10 d-flex flex-column align-center justify-center mud-background-gray rounded-xl"
                  Style="border: 3px dashed var(--mud-palette-divider);">
            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Default" Style="font-size: 6rem;" Class="mb-4 opacity-50" />
            <MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true">@Localizer["thereAreNoPartsCreated"]</MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary" Class="mb-6">
                @Localizer["noPartsFound"]
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="CreateParts" Class="rounded-pill px-8">
                @Localizer["createParts"]
            </MudButton>
        </MudPaper>
    </MudContainer>
}
else
{
    @* Tabla Rediseñada *@
    <MudTable Items="_Parts" Hover="true" T="Part" Height="75vh" FixedHeader="true"
              Elevation="4" Class="rounded-lg overflow-hidden"
              RowClassFunc="@SelectedRowClassFunc" @ref="SelectTableEvent" OnRowClick="RowClickEvent"
              Filter="new Func<Part,bool>(FilterFunc)">
        
        <ToolBarContent>
            <div class="d-flex align-center gap-4 mud-width-full py-3">
                <div class="d-flex flex-column">
                    <MudText Typo="Typo.h5" Color="Color.Primary" Class="fw-bold">Gestión de Partes</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Administre el catálogo de componentes</MudText>
                </div>
                
                <MudSpacer />
                
                <MudTextField @bind-Value="searchString"
                              Placeholder="Buscar por nombre o número..."
                              Clearable="true"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Style="max-width: 350px; background: var(--mud-palette-background-grey);" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="CreateParts"
                           Class="px-6 py-2 ml-2">
                    @Localizer1["NewDataPanel"]
                </MudButton>
            </div>
        </ToolBarContent>

        <HeaderContent>
            @if (user.UserType == 1)
            {
                <MudTh><MudTableSortLabel SortBy="new Func<Part, object>(x => x.PartId)">ID</MudTableSortLabel></MudTh>
            }
            <MudTh><MudTableSortLabel SortBy="new Func<Part, object>(x => x.PartName)">Nombre de Parte</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Part, object>(x => x.PartNumber)">Número de Parte</MudTableSortLabel></MudTh>
            @if (user.UserType == 1)
            {
                <MudTh Style="text-align:center">Estado</MudTh>
            }
            <MudTh Style="text-align:right">Acciones</MudTh>
        </HeaderContent>

        <RowTemplate>
            @if (user.UserType == 1)
            {
                <MudTd DataLabel="ID">
                    <MudText Typo="Typo.body2" Class="mud-text-secondary font-monospace">#@context.PartId</MudText>
                </MudTd>
            }
            <MudTd DataLabel="Name">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.SettingsInputComponent" Size="Size.Small" Color="Color.Info" Class="mr-2" />
                    <MudText Typo="Typo.body1" Class="fw-medium">@context.PartName</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="Number">
                <MudChip Variant="Variant.Text" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.Tag">
                    @context.PartNumber
                </MudChip>
            </MudTd>
            @if (user.UserType == 1)
            {
                <MudTd DataLabel="Status" Style="text-align:center">
                    <MudChip Size="Size.Small"
                             Variant="Variant.Filled"
                             Color="@(context.IsActive == true ? Color.Success : Color.Error)"
                             Class="px-4">
                        @(context.IsActive == true ? "Activo" : "Inactivo")
                    </MudChip>
                </MudTd>
            }
            <MudTd Style="text-align:right">
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopRight" Dense="true">
                    <MudMenuItem Icon="@Icons.Material.Filled.Visibility" IconColor="Color.Primary" OnClick="(() => PartsDetails(context.PartId))">Ver Detalles</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" IconColor="Color.Info" OnClick="(() => PartUpdate(context.PartId))">Editar Parte</MudMenuItem>
                    <MudDivider Class="my-2" />
                    <MudMenuItem Icon="@Icons.Material.Filled.DeleteForever" IconColor="Color.Error" OnClick="(() => DeleteParts(context.PartId))">Eliminar</MudMenuItem>
                </MudMenu>
            </MudTd>
        </RowTemplate>

        <PagerContent>
            <MudTablePager InfoFormat="{first_item}-{last_item} de {all_items}" RowsPerPageString="Resultados por página:" />
        </PagerContent>
    </MudTable>
}