@page "/configurationIS/ProblemDefect/Create"
@page "/configurationIS/ProblemDefect/Details/{ProblemDefectId:int}"
@page "/configurationIS/ProblemDefect/Update/{ProblemDefectId:int}"

@inject IProblemDefectServices ProblemDefectsServices
@inject IProductService ProductsServices
@inject IFileUploadAndDownloadService FilesServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject ISnackbar Snackbar
@inject IBreadcrumbService BreadcrumbService


<MudDialog>
    <TitleContent>
        <div class="d-flex align-center justify-space-between mud-width-full">
            <MudText Typo="Typo.h6">
                @switch (pageType)
                {
                    case PageType.Create:
                        @Localizer["ProblemDefectCreate"]
                        break;
                    case PageType.Update:
                        @Localizer["ProblemDefectUpdate"]
                        break;
                    case PageType.Details:
                        @Localizer["ProblemDefectDetails"]
                        break;
                }
            </MudText>
            
            @switch (pageType)
            {
                case PageType.Details:
                    <MudChip Variant="Variant.Text" Class="mr-6" Color="Color.Info" OnClick="ChangeToUpdateMode">
                        @Localizer["edit"]
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"></MudIcon>
                    </MudChip>
                    break;
                case PageType.Create:
                    <MudChip Variant="Variant.Text" Class="mr-6" Color="Color.Success">@Localizer["create"]</MudChip>
                    break;
                case PageType.Update:
                    <MudChip Variant="Variant.Text" Class="mr-6" Color="Color.Primary">@Localizer["update"]</MudChip>
                    break;
            }
        </div>
    </TitleContent>

    <DialogContent>
        @if (ShowLoading)
        {
            <div class="d-flex flex-column justify-center align-center" style="height:200px;">
                <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
                <MudText Color="Color.Primary" Class="mt-3">Cargando...</MudText>
            </div>
        }
        else
        {
            <EditForm id="defectForm" Model="_ProblemDefect" OnValidSubmit="SubmitOperations">
                <DataAnnotationsValidator />
                
                <MudTextField Label="@Localizer1["ProblemDefectDescription"]"
                              ReadOnly="@(pageType == PageType.Details)"
                              Variant="Variant.Outlined"
                              @bind-Value="_ProblemDefect.DefectDescription"
                              For="@(() => _ProblemDefect.DefectDescription)" 
                              AdornmentIcon="@Icons.Material.Filled.Description"
                              Adornment="Adornment.Start"
                              AdornmentColor="Color.Tertiary"/>

                @if (user?.UserType == 1)
                {
                    <MudSwitch Class="mt-3" Label="Is active?"
                               ReadOnly="@(pageType == PageType.Details)"
                               @bind-Checked="_ProblemDefect.IsActive"
                               Color="Color.Info" UnCheckedColor="Color.Dark" />
                }
            </EditForm>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Color="Color.Default">@Localizer["Cancel"]</MudButton>
        
        @if (pageType != PageType.Details && !ShowLoading)
        {
            @* El atributo form="defectForm" enlaza este botón con el EditForm de arriba *@
            <MudButton ButtonType="ButtonType.Submit" form="defectForm" Variant="Variant.Filled" Color="Color.Info">
                @(pageType == PageType.Create ? Localizer["create"] : Localizer["save"])
            </MudButton>
        }
    </DialogActions>
</MudDialog>