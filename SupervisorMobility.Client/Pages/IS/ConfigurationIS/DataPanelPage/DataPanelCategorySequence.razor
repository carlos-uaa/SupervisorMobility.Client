@page "/configurationIS/DataPanels/sequence"

@inject IJobStructureService JobStructureCategoriesService
@inject IDataPanelService DataPanelServices
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService

@*Title*@
<PageTitle>Supervisor Mobility | Data Panels Sequence</PageTitle>

@*Sequence container*@
<MudDropContainer T="DataPanel" Items="_datapanelCategories" ItemsSelector="@((item,dropzone) => item.Container == dropzone)" ItemDropped="ItemUpdated" Class="d-flex flex-wrap flex-grow-1">
    <ChildContent>
        <MudDropZone T="DataPanel" Identifier="CategoryContainer" Class="rounded mud-background-gray pa-6 ma-8 flex-grow-1" AllowReorder="true" >
            <MudText Typo="Typo.h6" Class="mb-4">
                Reorder categories
            </MudText>
        </MudDropZone>
    </ChildContent>
    <ItemRenderer >
            <MudPaper Elevation="25" Class="pa-4 my-4">
                @($"{context.DataTitle} ")
            </MudPaper>
    </ItemRenderer>
</MudDropContainer>