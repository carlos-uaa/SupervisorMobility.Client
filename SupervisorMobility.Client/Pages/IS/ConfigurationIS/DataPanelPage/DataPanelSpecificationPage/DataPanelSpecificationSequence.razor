@page "/configurationIS/DataPanels/Details/{DataPanelId:int}/Sequence"

@inject IDataPanelService DataPanelServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject ISnackbar Snackbar
@inject IBreadcrumbService BreadcrumbService


@if (ShowLoading)
{
    <MudCarousel Class="mud-width-full" ItemsSource="@_sourceMsgLoading" Context="Carousel" AutoCycle="true" Style="height:200px;" ShowArrows="false" ShowBullets="false" EnableSwipeGesture="false">
        <ItemTemplate>
            <div class="d-flex flex-column flex-column justify-center" style="height:100%">
                <MudItem class="d-flex flex-column justify-center align-self-center">
                    <MudProgressCircular Color="@_Colors[Carousel.IndexOf(Carousel)]" Style="height:70px;width:70px;" Indeterminate="true" />
                </MudItem>
                @*<MudIcon Class="mx-auto" Icon="@Icons.Custom.Brands.MudBlazor" Size="@Size.Large" />*@
                <MudText Align="@Align.Center" Color="Color.Primary" Class="mx-auto">@Carousel</MudText>
            </div>
        </ItemTemplate>
    </MudCarousel>
}
else
{
    <MudGrid class="mt-2">
        @*Plant info*@
        <MudItem xs="12" sm="6" md="3">
            <MudButton @onclick="(() => UpdateCategory(DataPanelId))" @ontouchstart="(() => UpdateCategory(DataPanelId))" FullWidth="true" Class="d-flex justify-center">
                <MudCard Style="height:100%; width: 100%">
                    <MudCardHeader>
                        <CardHeaderActions>
                        </CardHeaderActions>
                        <CardHeaderContent>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"></MudIcon>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Style="justify-content:center">
                        <MudText Align="Align.Center"><MudIcon Icon="@Icons.Filled.ViewList"></MudIcon></MudText>
                        <MudText Align="Align.Center">@_DataPanel.DataPanelId</MudText>
                        <MudText Typo="Typo.h5" Align="Align.Center">@_DataPanel.DataTitle</MudText>
                        @if (_DataPanel.IsActive == true)
                        {
                            <MudText Align="Align.Center" Class="pt-2">
                                <MudChip Variant="Variant.Text" Color="Color.Success">Active</MudChip>
                            </MudText>
                        }
                        else
                        {
                            <MudText Align="Align.Center" Class="pa-4">
                                <MudChip Variant="Variant.Text" Color="Color.Error">Inactive</MudChip>
                            </MudText>
                        }
                    </MudCardContent>
                </MudCard>
            </MudButton>

        </MudItem>
        @*Related questions*@
        <MudItem xs="12" sm="6" md="9">
           
    <MudDropContainer T="DataPanelSpecification" Items="_DataPanel.Specifications" ItemsSelector="@((item,dropzone) => item.Container == dropzone)" ItemDropped="ItemUpdated" Class="d-flex flex-wrap flex-grow-1">
        <ChildContent>
            <MudDropZone T="DataPanelSpecification" Identifier="CategoryContainer" Class="rounded mud-background-gray pa-6 ma-8 flex-grow-1" AllowReorder="true">
                <MudText Typo="Typo.h6" Class="mb-4">
                    Reorder Specifications
                </MudText>
            </MudDropZone>
        </ChildContent>
        <ItemRenderer>
            <MudPaper Elevation="25" Class="pa-4 my-4">
                @($"{context.DataSpecification} ")
            </MudPaper>
        </ItemRenderer>
    </MudDropContainer>

        </MudItem>
    </MudGrid>




   
}



