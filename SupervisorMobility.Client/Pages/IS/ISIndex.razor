@page "/IS"

@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Resource> Localizer
@inject IBreadcrumbService BreadcrumbService


<style>

    .menu-card {
    width: 100%;
    box-shadow: 5px 5px 5px rgb(218, 214, 213 );
    border-radius: 10px;
    transition: all 0.3s ease-out;
    cursor: default;
    }

    .menu-card .header {
    border-radius: 10px 10px 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: #f1f5f9;
    }


    .menu-card .content {
    text-align: justify;
    height: 16vh;
    overflow-x: scroll;
    }

    .menu-card .content::-webkit-scrollbar {
    width: 4px;
    }

    .menu-card .footer {
    border-radius: 0 0 10px 10px;
    background-color: #f1f5f9;
    }

    .menu-card:hover {
    box-shadow: #9ad8f3 0px 2px 4px;
    transform: scale(1.005);
    }

</style>

@if (logged == true)
{
    @*Title*@
    <PageTitle>Supervisor Mobility | @Localizer["IS"]</PageTitle>
    @*Breadcrumb links*@
    @*   <MudBreadcrumbs Items="_links">
        <ItemTemplate Context="item">
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        </ItemTemplate>
    </MudBreadcrumbs> *@

    @*Dashboard grid*@
    <MudGrid Class="pb-10">
        @*HCI *@
        <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
            <MudPaper Class="menu-card">
                <MudItem Class="pa-2 header">
                    <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">HCI</MudChip>
                    <MudText>@Localizer["HCITitle"]</MudText>
                    <MudImage Src="Images/historial-de-trabajo.png" Height="25" Width="25" />
                </MudItem>
                <MudItem Class="content">
                    <MudText Class="pa-4">
                        @Localizer["HCIDescription"]
                    </MudText>
                </MudItem>
                <MudItem Class="pa-3 footer">
                    <MudButton Href="hci" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                </MudItem>
            </MudPaper>
        </MudItem>

        @*Apariencia Plantilla*@
        <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
            <MudPaper Class="menu-card">
                <MudItem Class="pa-2 header">
                    <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">APP</MudChip>
                    <MudText>@Localizer["Appearance"]</MudText>
                    <MudImage Src="Images/admin.png" Height="25" Width="25" />
                </MudItem>
                <MudItem Class="content">
                    <MudText Class="pa-4">
                        @Localizer["AppeareanceDescription"]
                    </MudText>
                </MudItem>
                <MudItem Class="pa-3 footer">
                    <MudButton Href="appearance/createAppearance" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                </MudItem>
            </MudPaper>
        </MudItem>
        @*Configuration IS - Apariencia Plantilla*@
        @if (user.UserType < 4 && user.UserType != 3)
        {
            <MudItem xs="12" sm="6" md="6" lg="4" xl="3" xxl="2" Class="d-flex">
                <MudPaper Class="menu-card">
                <MudItem Class="pa-2 header">
                    <MudChip Label Color="Color.Dark" Style="background-color: #6c757d; font-weight:bold" Variant="Variant.Filled" Size="Size.Small">CONFIG IS</MudChip>
                    <MudText>@Localizer["configurationIS"]</MudText>
                    <MudImage Src="Images/admin.png" Height="25" Width="25" />
                </MudItem>
                <MudItem Class="content">
                    <MudText Class="pa-4">
                        @Localizer["configurationISDescription"]
                    </MudText>
                </MudItem>
                <MudItem Class="pa-3 footer">
                    <MudButton Href="configurationIS" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                </MudItem>
            </MudPaper>
        </MudItem>
        }
    </MudGrid>
}