@page "/"
@using System.Text.RegularExpressions
@using System.ComponentModel.DataAnnotations

@if(logged)
{
    @*Title*@
    <PageTitle>Supervisor Mobility | Home</PageTitle>
    @*Breadcrumb links*@
    <MudBreadcrumbs Class="mb-10" Items="_links">
        <ItemTemplate Context="item">
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        </ItemTemplate>
    </MudBreadcrumbs>


    @*Dashboard grid*@
    <MudGrid>
        @*Observation schedule*@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="jobobservationschedule" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
                    <MudItem style="text-align:center">
                        <img src="Images/interfaz.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Job Observations Schedule</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>

        @*Job observations*@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="jobobservation" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
                    <MudItem style="text-align:center">
                        <img src="Images/servicio.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Job Observations</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>

        @*LUP*@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="lup" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
                    <MudItem style="text-align:center">
                        <img src="Images/mecanografia.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">To Do (LUP)</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>
        @*Configuration*@
        <MudItem xs="12" sm="6" md="3" Class="d-flex justify-center">
            <MudPaper Style="width: 100%">
                <MudButton Href="configuration" id="ProductsBtn" FullWidth="true" Class="d-flex justify-center">
                    <MudItem style="text-align:center">
                        <img src="Images/admin.png" Height="100" Width="100" />
                        <MudText FullWidth="true" Variant="Variant.Text" Color="Color.Info">Configuration</MudText>
                    </MudItem>
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
else{
    @*Title*@
    <PageTitle>Supervisor Mobility | Login</PageTitle>
    @*Breadcrumb links*@
    <MudBreadcrumbs Class="mb-10" Items="_login">
        <ItemTemplate Context="item">
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        </ItemTemplate>
    </MudBreadcrumbs>
    @* Login Form*@
    <EditForm Model="_userLogin" OnValidSubmit="Login">
        <DataAnnotationsValidator />
        <MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
            <MudSimpleTable Style="overflow-x: auto;" Bordered=true Outlined=false>
                <tbody>
                    <tr>
                        <td style="text-align:center">
                            <MudItem Style="text-align:center">
                                <MudImage Src="Images/logo.png" Alt="Logo image" Style="max-height: 120px" Fluid=true Class="align-center justify-center"> </MudImage>
                            </MudItem>
                            <MudTextField @bind-Value="_userLogin.Username" Class="mt-10 pl-10 pr-10" Label="Username" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Person"></MudTextField>
                            <MudTextField @bind-Value="_userLogin.Password" Class="mt-5 pl-10 pr-10" Label="Password" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="@PasswordInput" Adornment="Adornment.End" AdornmentIcon="@PasswordInputIcon" OnAdornmentClick="ButtonTestclick" AdornmentAriaLabel="Show Password"></MudTextField>
                            <MudButton Disabled="@_processing" Class="mt-10 mb-10" OnClick="ProcessSomething" Variant="Variant.Filled" Color="Color.Info">
                                @if (_processing)
                                {
                                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                    <MudText Class="ms-2">Processing</MudText>
                                }
                                else
                                {
                                    <MudText>Sign in</MudText>
                                }
                            </MudButton>
                        </td>  
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudGrid>
    </EditForm>
}