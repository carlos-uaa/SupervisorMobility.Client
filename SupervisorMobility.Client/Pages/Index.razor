@page "/"
@using System.Text.RegularExpressions
@using System.ComponentModel.DataAnnotations

@inject IJSRuntime js
@inject ILoginService UserLoginService
@inject IUserService UsersService
@inject ISnackbar Snackbar
@inject GlobalDataService GlobalData;
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager

@if(logged)
{
    @*Title*@
    <PageTitle>Supervisor Mobility | @Localizer["home"]</PageTitle>
    @*Breadcrumb links*@
    <MudBreadcrumbs Items="_links">
        <ItemTemplate Context="item">
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        </ItemTemplate>
    </MudBreadcrumbs>



    @*Dashboard grid*@
    <MudGrid>

        @if (user.UserType != 7)
        {

            @if (user.UserType != 5)
            {
                @*SOS Review Program*@
                <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                    <MudPaper Style="width: 100%;">
                        <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                            <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">SRP</MudChip>
                            <MudText>@Localizer["sosProgram"]</MudText>
                            <MudImage Src="Images/documento.png" Height="25" Width="25" />
                        </MudItem>
                        <MudItem>
                            <MudText Class="pa-4">
                                Create, Update and mange job observations forms for
                                zones and staff working within a manufacturing plant.
                            </MudText>
                        </MudItem>
                        <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                            <MudButton Href="sosProgram" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                            <MudButton Href="sosProgram/createSosReview" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                        </MudItem>
                    </MudPaper>
                </MudItem>
            }
            @*Job Observation Schedule*@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">JOS</MudChip>
                        <MudText>@Localizer["jobObservationProgram"]</MudText>
                        <MudImage Src="Images/interfaz.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="jobobservationschedule" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>

            @*Job Observation*@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">JO</MudChip>
                        <MudText>@Localizer["jobObservations"]</MudText>
                        <MudImage Src="Images/servicio.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="jobobservation" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        <MudButton @onclick="(() => CreateJobObservation())" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Create</MudButton>
                        <MudButton @onclick="(() => PlanJobObservation())" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">Plan</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>

            @*Lup*@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">LUP</MudChip>
                        <MudText>@Localizer["toDoLup"]</MudText>
                        <MudImage Src="Images/mecanografia.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="lup" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>

            @if (user.UserType != 5)
            {
                @*PAT*@
                <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                    <MudPaper Style="width: 100%;">
                        <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                            <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">PAT</MudChip>
                            <MudText>PAT</MudText>
                            <MudImage Src="Images/prueba.png" Height="25" Width="25" />
                        </MudItem>
                        <MudItem>
                            <MudText Class="pa-4">
                                Create, Update and mange job observations forms for
                                zones and staff working within a manufacturing plant.
                            </MudText>
                        </MudItem>
                        <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                            <MudButton Href="PAT" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        </MudItem>
                    </MudPaper>
                </MudItem>
            }
            @if (user.UserType == 1 || user.UserType == 3)
            {

                @*Configuration*@
                <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                    <MudPaper Style="width: 100%;">
                        <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                            <MudChip Label Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">CONFIG</MudChip>
                            <MudText>@Localizer["configuration"]</MudText>
                            <MudImage Src="Images/admin.png" Height="25" Width="25" />
                        </MudItem>
                        <MudItem>
                            <MudText Class="pa-4">
                                Create, Update and mange job observations forms for
                                zones and staff working within a manufacturing plant.
                            </MudText>
                        </MudItem>
                        <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                            <MudButton Href="configuration" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                        </MudItem>
                    </MudPaper>
                </MudItem>
            }
        }
        @if (user.UserType == 1 || user.UserType == 7)
        {
            @*HeadCount*@
            <MudItem xs="12" sm="6" md="6" lg="4" Class="d-flex">
                <MudPaper Style="width: 100%;">
                    <MudItem Style="display: flex; align-items: center; justify-content: space-between; background-color: #f2f9fe;" Class="pa-2">
                        <MudChip Label
                                 Color="Color.Dark" Style="background-color: #6c757d" Variant="Variant.Filled" Size="Size.Small">HC</MudChip>
                        <MudText>@Localizer["HeadCount"]</MudText>
                        <MudImage Src="Images/contar.png" Height="25" Width="25" />
                    </MudItem>
                    <MudItem>
                        <MudText Class="pa-4">
                            Create, Update and mange job observations forms for
                            zones and staff working within a manufacturing plant.
                        </MudText>
                    </MudItem>
                    <MudItem Style="background-color: #f2f9fe;" Class="pa-3">
                        <MudButton Href="headCount" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small" Class="ma-1">View all</MudButton>
                    </MudItem>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}
else{
    @*Title*@
    <PageTitle>Supervisor Mobility | @Localizer["login"]</PageTitle>
@*Breadcrumb links*@
    <MudBreadcrumbs Class="mb-5" Items="_login">
        <ItemTemplate Context="item">
            <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
        </ItemTemplate>
    </MudBreadcrumbs>
@* Login Form*@
    <EditForm Model="_userLogin" OnValidSubmit="Login">
        <DataAnnotationsValidator />
        <MudGrid Justify="Justify.Center" Style="margin-bottom: 70px">
            <MudSimpleTable Style="overflow-x: auto;" Bordered=true Outlined=false Elevation="0">
                <tbody>
                    <tr>
                        <td style="text-align:center">


                            <MudItem Style="text-align:center">
                                <MudImage Src="Images/logo.png" Alt="Logo image" Style="max-height: 110px" Fluid=true Class="align-center justify-center"> </MudImage>
                            </MudItem>
                            <MudPaper Elevation="3">
                                <MudText Typo="Typo.h6" Class="pt-5 mt-5">
                                    @Localizer["login"]
                                </MudText>
                                <MudTextField @bind-Value="_userLogin.Username" Class="mt-5 pl-10 pr-10" Label=@Localizer["username"] Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Person" OnAdornmentClick="OpenDeleteDialog"></MudTextField>
                                <ValidationMessage For="@(() => _userLogin.Username)" style="color: red; font-size: 12px"/>
                                <MudTextField @bind-Value="_userLogin.Password" Class="mt-5 pl-10 pr-10" Label=@Localizer["password"] Variant="Variant.Outlined" Margin="Margin.Dense" InputType="@PasswordInput" Adornment="Adornment.End" AdornmentIcon="@PasswordInputIcon" OnAdornmentClick="ButtonTestclick" AdornmentAriaLabel="Show Password"></MudTextField>
                                <ValidationMessage For="@(() => _userLogin.Password)" style="color: red; font-size: 12px"/>
                                <MudButton Disabled="@_processing" Class="mt-10 mb-10" Variant="Variant.Filled" Color="Color.Info" ButtonType="ButtonType.Submit">
                                    @if (_processing)
                                    {
                                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                        <MudText Class="ms-2">@Localizer["authenticating"]</MudText>
                                    }
                                    else
                                    {
                                        <MudText>@Localizer["signIn"]</MudText>
                                    }
                                </MudButton>
                            </MudPaper>
                        </td>  
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudGrid>
    </EditForm>
}


@*Delete observation modal*@
<MudDialog @bind-IsVisible="visibleText" Options="dialogTextOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["help"]</MudText>
        <MudText Class="mt-4 mb-4">
            @Localizer["enterTheActiveDirectoryUserName"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseModal" Variant="Variant.Filled">@Localizer["accept"]</MudButton>
    </DialogActions>
</MudDialog>