@page "/sosProgram"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using System.Globalization;
@using System.Net.Http.Json;

@inject IJSRuntime JSRuntime
@inject IGroupService GroupService
@inject IChecklistService ChecklistService
@inject IDialogService DialogService
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IJobObservationService JobObservationService
@inject IUserService UsersService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager


@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["sosProgram"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

    <MudItem Class="d-flex justify-content-between mb-5" Style="align-items: center;">
    <MudText Typo="Typo.h6">@Localizer["sosProgram"] </MudText>
        <MudItem Style="justify-content: end" Class="ml-auto">
            <MudItem Class="d-flex">
                <img src="Images/logo.png" Height="50"/>
            </MudItem>
        </MudItem>
    </MudItem>
    <MudSimpleTable Class="mb-5 calendar-table rounded" Style="overflow-x: auto;" Dense>
    <thead>
        <tr>
            <th>
                <MudItem Class="d-flex">
                    <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
                    <MudText Class="ml-2">@Localizer["area"]</MudText>
                </MudItem>
            </th>
            <th style="width:20vw">
                <MudItem Class="d-flex">
                    <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
                    <MudText Class="ml-2">@Localizer["distribution"]</MudText>
                </MudItem>
            </th>
            <th>@Localizer["applicationYear"]</th>
            <th>Supervisor</th>
            <th>SSV</th>
            <th>@Localizer["date"]</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>
            </td>
            <td>
            </td>
            <td></td>
            <td></td>
            <td></td>
            <td></td>
        </tr>
    </tbody>
</MudSimpleTable>