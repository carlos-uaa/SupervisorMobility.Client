@page "/sosProgram"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using System.Globalization;
@using System.Net.Http.Json;

@inject IJSRuntime JSRuntime
@inject IGroupService GroupService
@inject IChecklistService ChecklistService
@inject IDialogService DialogService
@inject IPlantService PlantServices
@inject IAreaService AreaServices
@inject IJobObservationService JobObservationService
@inject IUserService UsersService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> Localizer
@inject NavigationManager NavigationManager


@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["sosProgram"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

@if (_Sos == null)
{
    <text>
        @Localizer["loading"] ...
    </text>
}
else if (_Sos.Count == 0)
{
    <MudContainer>

        <MudText Align="Align.Center">
            <h4>@Localizer["thereAreNoPATsCreated"]</h4>
            <MudSpacer></MudSpacer>
            <MudButton @onclick="(() => CreatePat())">
                <MudText>@Localizer["createPAT"]</MudText>
                <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Pat" Color="Color.Primary"></MudIcon>
            </MudButton>
        </MudText>
    </MudContainer>
}
else
{
    <MudTable SortLabel="SortBy" Class="styled-table table-striped" FixedHeader=true Height="55vh"
              Items="@_Sos" Hover Striped="true" Filter="new Func<PAT,bool>(FilterFunc1)">
        <PagerContent>
            <MudTablePager />
        </PagerContent>
        <ToolBarContent>
            <MudText Typo="Typo.h6" Align="Align.Center">PAT</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="@searchString1" Placeholder=@Localizer["search"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-2"></MudTextField>
            <MudSpacer />
            @if (user.UserType == 1 || user.UserType == 3)
            {
                <MudButton @onclick="(() => CreatePat())">
                    <MudText>@Localizer["createPAT"]</MudText>
                    <MudIcon Icon="@Icons.Material.Filled.Add" aria-label="Create Pat" Color="Color.Primary"></MudIcon>
                </MudButton>

            }
        </ToolBarContent>
        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<PAT, object>(x=>x.PATid)" Enabled="true">PAT ID</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<PAT, object>(x=>x.AplicationYear)"><MudText>@Localizer["year"]</MudText></MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<PAT, object>(x=>x.SSVresponsible?.Name)">SSV</MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<PAT, object>(x=>x.Supervisor?.Name)"><MudText>Supervisor</MudText></MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<PAT, object>(x=>x.Area?.Description)"><MudText>@Localizer["area"]</MudText></MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<PAT, object>(x=>x.Distribution?.Description)"><MudText>@Localizer["distribution"]</MudText></MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<PAT, object>(x=>x.Status)"><MudText>@Localizer["status"]</MudText></MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudText Align="Align.Center">@Localizer["actions"]</MudText>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="PAT ID">
                <MudText Align="Align.Center">@context.PATid</MudText>
            </MudTd>
            <MudTd DataLabel=@Localizer["year"]>
                <MudText Align="Align.Center">@context.AplicationYear</MudText>
            </MudTd>
            <MudTd DataLabel="SSV">
                <MudText Align="Align.Center">@context.SSVresponsible?.Name</MudText>
            </MudTd>
            <MudTd DataLabel="Supervisor">
                <MudText Align="Align.Center">@context.Supervisor?.Name</MudText>
            </MudTd>
            <MudTd DataLabel=@Localizer["area"]>
                <MudText Align="Align.Center">@context.Area?.Description</MudText>
            </MudTd>
            <MudTd DataLabel=@Localizer["distribution"]>
                <MudText Align="Align.Center">@context.Distribution?.Description</MudText>
            </MudTd>
            <MudTd DataLabel=@Localizer["status"]>
                <MudText Align="Align.Center">
                    @switch (context.Status)
                    {
                        case 1:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlaylistPlay" Color="Color.Warning" Size="Size.Small" Style="cursor:pointer">@Localizer["new"]</MudChip>
                            break;
                        case 2:
                            <MudChip Variant="Variant.Text" Icon="@Icons.Material.Filled.PlaylistAddCheck" Color="Color.Success" Size="Size.Small" Style="cursor:pointer">@Localizer["approved"]</MudChip>
                            break;
                    }
                </MudText>
            </MudTd>
            <MudTd DataLabel=@Localizer["actions"]>
                <MudText Align="Align.Center">
                    <MudMenu Dense=true MaxHeight="300" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                        <ActivatorContent>
                            <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Settings" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Style="background:white" Variant="Variant.Filled" Size="Size.Small"></MudButton>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem Icon="@Icons.Material.Filled.Info" IconColor="Color.Primary" @onclick="(() => PatDetails(context.PATid))" @ontouchstart="(() => PatDetails(context.PATid))">@Localizer["PATDetails"]</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" @onclick="(() => OpenDeleteDialog(context.PATid))" @ontouchstart="(() => OpenDeleteDialog(context.PATid))">@Localizer["delete"] PAT</MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                    @* <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Primary" @onclick="(() => PatDetails(context.PATid))"></MudIconButton>
                <MudIconButton Variant="Variant.Filled" Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" @onclick="(() => OpenDeleteDialog(context.PATid))"></MudIconButton>*@
                </MudText>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@*Delete Pat modal*@
<MudDialog @bind-IsVisible="visibleDelete" Options="dialogDeleteOptions">
    <DialogContent>
        <MudText Typo="Typo.h6">@Localizer["confirm"]</MudText>
        <MudText Class="mt-4 mb-4">
            @Localizer["areYouSueYourWantToDeleteThisPAT"]
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteModal" Variant="Variant.Filled">@Localizer["cancel"]</MudButton>
        <MudButton @onclick="(() => DeletePat(deletePatId))" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Variant="Variant.Filled">@Localizer["delete"]</MudButton>
    </DialogActions>
</MudDialog>