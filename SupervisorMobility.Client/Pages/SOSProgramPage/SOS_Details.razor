<MudDialog DisableSidePadding="false" @bind-IsVisible="HoeDialog" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap;" Class="gap-4">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    HOE @Localizer["rute"]: @HOErute.Replace('§',' ')
                </MudText>
            </MudItem>
            @if (HoeFilesInFolder != null)
            {
                @if (HoeFilesInFolder.operation.Count() > 0)
                {
                    @foreach (HOEDocument DocFile in HoeFilesInFolder.operation)
                    {
                        <MudPaper Class="mr-5 mt-5" style="flex: 0 0 calc(28% - 1rem);">
                            <MudItem style="text-align:center" Class="d-flex justify-center flex-column align-content-center align-center mt-5">
                                @switch (DocFile.Extension)
                                {
                                    case "pdf":
                                        <img src="Images/pdf.png" Height="70" Width="70" />

                                        break;
                                    case "doc":
                                        // Para documentos Word con extensión .doc
                                        <img src="Images/doc.png" Height="70" Width="70" />
                                        break;

                                    case "docx":
                                        <img src="Images/docx.png" Height="70" Width="70" />
                                        // Para documentos Word con extensión .docx
                                        break;

                                    case "ppt":
                                        <img src="Images/ppt.png" Height="70" Width="70" />

                                        // Para presentaciones PowerPoint con extensión .ppt
                                        break;

                                    case "pptx":
                                        <img src="Images/pptx.png" Height="70" Width="70" />
                                        // Para presentaciones PowerPoint con extensión .pptx
                                        break;

                                    case "xls":
                                        // Para hojas de cálculo Excel con extensión .xls
                                        <img src="Images/xls.png" Height="70" Width="70" />
                                        break;

                                    case "xlsx":
                                        // Para hojas de cálculo Excel con extensión .xlsx
                                        <img src="Images/xlsx.png" Height="70" Width="70" />
                                        break;

                                    case "jpg":
                                        <img src="Images/jpg.png" Height="70" Width="70" />
                                        break;

                                    case "jpeg":
                                        // Para imágenes JPEG con extensión .jpg o .jpeg
                                        <img src="Images/jpg.png" Height="70" Width="70" />
                                        break;

                                    case "png":
                                        // Para imágenes PNG con extensión .png
                                        <img src="Images/png.png" Height="70" Width="70" />
                                        break;

                                    case "gif":
                                        // Para imágenes GIF con extensión .gif
                                        <img src="Images/gif.png" Height="70" Width="70" />
                                        break;
                                    default:
                                        <img src="Images/error.png" Height="70" Width="70" />
                                        break;
                                }
                                <MudTooltip Text=@Localizer["download"] Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="true">
                                    <MudButton @onclick="() => DownloadFileFromURL_HOE(DocFile.URL, DocFile.Nombre)">
                                        <MudItem>
                                            <MudChip Size="Size.Small" Variant="Variant.Text" Style="cursor:pointer;max-width: 315px" Icon="@Icons.Material.Filled.Download" Color="Color.Info">
                                                @if (DocFile.Nombre.Length > 10)
                                                {
                                                    <span class="marquee">@DocFile.Nombre</span>
                                                }
                                                else
                                                {
                                                    @DocFile.Nombre
                                                }
                                            </MudChip>

                                        </MudItem>
                                    </MudButton>
                                </MudTooltip>
                            </MudItem>

                        </MudPaper>

                    }
                }
                else
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
                }
            }
            else
            {
                if (folderError)
                {
                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                            <img src="Images/dialogerror.png" Height="140" Width="140" />
                        </MudItem>

                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["alert"] </MudText>

                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["serverNotResponse"]</MudText>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                }
                else
                {
                    <MudItem Align="Align.Center" Class="d-flex align-center justify-center  mud-width-full">
                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">
                            <img src="Images/dialogerror.png" Height="140" Width="140" />
                        </MudItem>

                        <MudItem Align="Align.Center" Class="flex d-flex-row align-center justify-center">

                            <MudText Typo="Typo.h4" Align="Align.Center" Label="Name"> @Localizer["alert"] </MudText>

                            <MudItem Class="d-flex flex-column align-center justify-center pa-3 ma-2">
                                <MudText Typo="Typo.h6" Align="Align.Center" Label="Name">@Localizer["dataNotFound"]</MudText>
                            </MudItem>
                        </MudItem>
                    </MudItem>
                }
            }

        </MudContainer>
    </DialogContent>
    <DialogActions>
        @*<MudIconButton @onclick="(() => JobObservationUpdate(jobId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>*@
        <MudButton Color="Color.Info" OnClick="CloseHoe">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>


@code {
    [Parameter]
    public int sosId { get; set; }

    private List<BreadcrumbItem> _links;
    private List<Distribution> _distributions = new();
    private List<AssyChart> _assyCharts = new();
    private SOSReviewProgram SOS_Review = new();
    private JobObservation _NewJobObservation = new();
    private SOSRegisterJobObservation _NewRegister = new();

    private List<SOSRegisterJobObservation> _SosRegisters = new();

    private Dictionary<(int, int), List<SOSRegisterJobObservation>?> SOS_Registers_Matrix { get; set; } = new Dictionary<(int, int), List<SOSRegisterJobObservation>?>();

    //User
    private string json = string.Empty;
    public User user = new();
    public bool logged = false;
    public bool ShowTable = false;

    private bool SeeDialogCreateJobObservation = false;
    private DialogOptions dialogOptions = new() { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large, FullWidth = true, DisableBackdropClick = true, CloseButton = true };


    protected async override Task OnInitializedAsync()
    {

        _links = new List<BreadcrumbItem>
        {
            new BreadcrumbItem(text: Localizer["home"], href: "#"),
            new BreadcrumbItem(text: Localizer["sosProgram"], href: "/sosProgram"),
            new BreadcrumbItem(text: Localizer["sosDetails"], href: "", disabled: true),
        };
        logged = await HasPropertyAsync();
        if (!logged)
        {
            Snackbar.Clear();
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Add(Localizer["errorYouHaveToLogIn"], Severity.Error);
            NavigationManager.NavigateTo($"/");
        }
        else
        {

            SOS_Review = await SOSServices.GetSOSById(sosId, true);
            _distributions = await DistributionServices.GetDistributions((int)SOS_Review.PlantId, (int)SOS_Review.AreaId);
            _assyCharts = await AssyChartsServices.GetAssyChartsByArea((int)SOS_Review.PlantId, (int)SOS_Review.AreaId);
            await PrepareDataTable();
            StateHasChanged();
        }



    }


    //Local storage user
    private async Task GetUserAsync()
    {
        if (!await TryGetAsync())
        {
            user = new();
        }
    }

    private async Task PrepareDataTable()
    {
        SOS_Registers_Matrix?.Clear();
        _SosRegisters?.Clear();
             

        
        _SosRegisters = await SOSServices.GetSOSRegisters(SOS_Review.SOSid);
   

        foreach (var dist in _distributions)
        {
            for (int i = 1; i < 13; i++)
            {
                var matchingRegisters = _SosRegisters?
                   .Where(r => r.DistributionId == dist.DistributionId && r.Year <= SOS_Review.AplicationYear)
                   .ToList();
               

                SOS_Registers_Matrix.Add((dist.DistributionId, i), matchingRegisters);

            }
        }
                Console.WriteLine("end");

        ShowTable = true;
        StateHasChanged();
    }

    private async Task<bool> TryGetAsync()
    {
        bool hasProperty = await HasPropertyAsync();
        if (hasProperty)
        {
            json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "user");
            user = JsonSerializer.Deserialize<User>(json) ?? new();

        }
        return hasProperty;
    }

    private async Task<bool> HasPropertyAsync()
        => await JSRuntime.InvokeAsync<bool>("localStorage.hasOwnProperty", "user");

    private async void OpenDialogCreateJobObservation(int month, int DistributionId)
    {
        _NewRegister.DistributionId = DistributionId;
        _NewRegister.Month = month;
        _NewRegister.Year = (int)SOS_Review.AplicationYear;

        SeeDialogCreateJobObservation = true;
        StateHasChanged();
    }

    private void CloseCreateJobObservation()
    {
        //limpiar todo lo usado
        SeeDialogCreateJobObservation = false;

    }

    private async void CreateJobObservation()
    {
        SeeDialogCreateJobObservation = false;

        _NewJobObservation.PlantId = (int)SOS_Review.PlantId;
        _NewJobObservation.AreaId = (int)SOS_Review.AreaId;
        _NewJobObservation.DistributionId = (int)_NewRegister.DistributionId;

        _NewJobObservation.SupervisorId = (int)SOS_Review.Supervisorid;


        _NewJobObservation.OperationId = 0;

        _NewJobObservation.Option = 2;
        _NewJobObservation.Type = 3;
        _NewJobObservation.Status = 7;
        _NewJobObservation.IsActive = true;


        var result = await SOSServices.CreateSOSRegister(SOS_Review.SOSid, _NewRegister.Month, _NewRegister.Year, _NewJobObservation);
        if (result != null)
        {
            ShowTable = false;
            StateHasChanged();
            await PrepareDataTable();

            Console.WriteLine("Se añadio");
            //aqui un mensaje bonito
        }


    }


