    //Local storage user
    private async Task GetUserAsync()
    {
        if (!await TryGetAsync())
        {
            user = new();
        }
    }

    private async Task PrepareDataTable()
    {
        SOS_Registers_Matrix?.Clear();
        _SosRegisters?.Clear();



        _SosRegisters = await SOSServices.GetSOSRegisters(SOS_Review.SOSid);


        foreach (var dist in _distributions)
        {
            for (int i = 1; i < 13; i++)
            {
                int currentindex = i;
                var matchingRegisters = _SosRegisters?
                   .Where(r => r.DistributionId == dist.DistributionId && r.Year <= SOS_Review.AplicationYear && r.Month == currentindex)
                   .ToList();


                SOS_Registers_Matrix.Add((dist.DistributionId, currentindex), matchingRegisters);

            }
        }
        _Subordinates = await UsersServices.GetSubordinates(SOS_Review.Supervisor.UserId);

        ShowTable = true;
        StateHasChanged();
    }

    private async Task<bool> TryGetAsync()
    {
        bool hasProperty = await HasPropertyAsync();
        if (hasProperty)
        {
            json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "user");
            user = JsonSerializer.Deserialize<User>(json) ?? new();

        }
        return hasProperty;
    }

    private async Task<bool> HasPropertyAsync()
        => await JSRuntime.InvokeAsync<bool>("localStorage.hasOwnProperty", "user");

    private async void OpenDialogCreateJobObservation(int month, int DistributionId)
    {
        AddOperation = false;
        AddOperator = false;

        _Operations = await OperationsServices.GetOperations(SOS_Review.PlantId, SOS_Review.AreaId, DistributionId);

        _NewRegister.DistributionId = DistributionId;
        _NewRegister.Month = month;
        _NewRegister.Year = (int)SOS_Review.AplicationYear;

        _NewJobObservation.PlantId = (int)SOS_Review.PlantId;
        _NewJobObservation.Plant = SOS_Review.Plant;
        _NewJobObservation.AreaId = (int)SOS_Review.AreaId;
        _NewJobObservation.Area = SOS_Review.Area;
        _NewJobObservation.DistributionId = (int)_NewRegister.DistributionId;
        _NewJobObservation.Distribution = _distributions.Find(d => d.DistributionId == (int)_NewRegister.DistributionId);

        _NewJobObservation.SupervisorId = (int)SOS_Review.Supervisorid;
        _NewJobObservation.Supervisor = SOS_Review.Supervisor;


        _NewJobObservation.Option = 2;
        _NewJobObservation.Type = 3;
        _NewJobObservation.Status = 7;
        _NewJobObservation.IsActive = true;

        if (month < 10)
        {
            string dateString = $"01/0{month}/{(int)SOS_Review.AplicationYear}";
            DateTime parsedDate = DateTime.ParseExact(dateString, "dd/MM/yyyy", CultureInfo.InvariantCulture);
            _NewJobObservation.StartDate = parsedDate;

        }
        else
        {
            string dateString = $"01/{month}/{(int)SOS_Review.AplicationYear}";
            DateTime parsedDate = DateTime.ParseExact(dateString, "dd/MM/yyyy", CultureInfo.InvariantCulture);
            _NewJobObservation.StartDate = parsedDate;
        }



        SeeDialogCreateJobObservation = true;
        StateHasChanged();
    }

    private void CloseCreateJobObservation()
    {
        //limpiar todo lo usado
        SeeDialogCreateJobObservation = false;

    }

    private async void CreateJobObservation()
    {
        SeeDialogCreateJobObservation = false;


        var result = await SOSServices.CreateSOSRegister(SOS_Review.SOSid, _NewRegister.Month, _NewRegister.Year, _NewJobObservation);
        if (result != null)
        {
            ShowTable = false;
            await PrepareDataTable();

            Snackbar.Clear();
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Add($"SOS Review Job Observation Created", Severity.Info);
            StateHasChanged();
        }


    }


