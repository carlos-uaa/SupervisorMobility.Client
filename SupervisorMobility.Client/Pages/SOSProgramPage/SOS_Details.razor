                                        <MudButton FullWidth=true StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">Show AssyCharts</MudButton>
                                    </ActivatorContent>
                                    <ChildContent>
                                        <MudExpansionPanels>

                                            @foreach (AssyChart _assychart in _AssyChartsForThisDistribution)
                                            {

                                                <MudExpansionPanel>
                                                    <TitleContent>
                                                        <div class="d-flex">
                                                            <MudText Class="mt-1">@_assychart.Operation?.Description</MudText>
