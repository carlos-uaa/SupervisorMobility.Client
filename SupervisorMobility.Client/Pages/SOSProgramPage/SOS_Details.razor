@page "/SOSDetails/{sosId:int}"

@using System.Net.Http.Json
@using MudBlazor
@using System.Globalization;

@inject NavigationManager NavigationManager
@inject IUserService UsersServices
@inject IAreaService AreasServices
@inject IOperationService OperationsServices
@inject IPATService PATsServices
@inject IJSRuntime JSRuntime
@inject IJSRuntime JS
@inject IILUService ILUServices
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource1> Localizer1
@inject IStringLocalizer<Resource> Localizer
@inject IDistributionService DistributionServices
@inject ISOSReviewService SOSServices
@inject IAssyChartService AssyChartsServices
@inject IBridgeCDMSService CDMSServices


<style>

    .vertical-text {
        vertical-align: middle;
    }

    .vertical-content {
        writing-mode: vertical-lr;
        white-space: nowrap;
        word-wrap: break-word;
        max-width: 100%;
    }


    .scroll1::-webkit-scrollbar {
        width: 4px;
        touch-action: pan-y;
    }

</style>

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["sosDetails"]</PageTitle>
@*Breadcrumb links*@
<div style="display: flex; align-items: center; justify-content: space-between;">
    <MudItem>
        <MudBreadcrumbs Class="mb-2" Items="_links">
            <ItemTemplate Context="item">
                <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
            </ItemTemplate>
        </MudBreadcrumbs>
    </MudItem>
    <MudItem Style="text-align: end">
        <img src="Images/logo.png" Height="50" />
    </MudItem>
</div>

@if (ShowTable)
{

    <MudSimpleTable Dense>
    <tbody>
        <tr>

            <td colspan="2" rowspan="2">
                <MudItem Class="d-flex justify-content-between mb-5" Style="align-items: center;">
                    <MudText Typo="Typo.h6">@Localizer["sosDetails"] </MudText>
                </MudItem>
            </td>
            <td colspan="2">
                <MudItem Class="d-flex">
                    <MudIcon Icon="@Icons.Material.Filled.BusinessCenter"> </MudIcon>
                    <MudText Class="ml-2">@Localizer["area"]</MudText>
                </MudItem>
            </td>
            <td colspan="2">
                <MudItem Class="d-flex">
                    <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
                    <MudText Class="ml-2">@Localizer["plant"]</MudText>
                </MudItem>
            </td>
        </tr>
        <tr>
            <td rowspan="2" colspan="2">
                @SOS_Review.Area?.Description
            </td>
            <td rowspan="2" colspan="2">
                @SOS_Review.Plant?.Description
            </td>
        </tr>
    </tbody>
</MudSimpleTable>
    <MudSimpleTable Class="mb-5 calendar-table rounded" Style="overflow-x: auto;" Dense Bordered=false>
        <thead>
            <tr>
            </tr>
            <tr>
                <th rowspan="2">
                    Item
                </th>
                <th rowspan="2">
                    <MudItem Class="d-flex">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree"> </MudIcon>
                        <MudText Class="ml-2">@Localizer["distribution"]</MudText>
                    </MudItem>
                </th>
                <th rowspan="2">
                    Nombre de control
                </th>
                <th rowspan="2" class="vertical-text">

                    <div class="vertical-content">
                        Programacion
                    </div>
                </th>
                <th colspan="12">
                    @SOS_Review.AplicationYear
                </th>
                <th colspan="3" rowspan="2">
                    Notas
                </th>

            </tr>

            <tr>
                @for (var i = 1; i <= 12; i++)
                {
                    <th style="text-align: center">
                        @textInfo.ToTitleCase(CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i))
                    </th>
                }
            </tr>

            @* <tr>
        <th>
        <MudItem Class="d-flex">
        <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
        <MudText Class="ml-2">@Localizer["area"]</MudText>
        </MudItem>
        </th>
        <th style="width:20vw">
        <MudItem Class="d-flex">
        <MudIcon Icon="@Icons.Material.Filled.Business"> </MudIcon>
        <MudText Class="ml-2">@Localizer["distribution"]</MudText>
        </MudItem>
        </th>
        <th>@Localizer["applicationYear"]</th>
        <th>Supervisor</th>
        <th>SSV</th>
        <th>@Localizer["date"]</th>
        </tr>*@
        </thead>
        <tbody>

            @foreach (Distribution Distribution_Item in _distributions)
            {
                <tr>
                    <td rowspan="2">
                        No
                    </td>
                    <td rowspan="2">
                        @Distribution_Item.Description
                    </td>
                    <td rowspan="2">
                        @if (_assyCharts?.Where(r => r.DistributionId == Distribution_Item.DistributionId).ToList().Count > 0)
                        {
                            var _assychart = _assyCharts?
                            .Where(r => r.DistributionId == Distribution_Item.DistributionId).FirstOrDefault();

                            <MudItem Style="text-align: start">
                                @if (_assychart != null)
                                {
                                    <MudItem Class="d-flex flex-row align-start justify-center">

                                        @if (_assychart.RoutesProductsAssyChart?.Count > 0)
                                        {
                                            <MudMenu Dense=true AnchorOrigin="Origin.BottomCenter" Style="display: flex" TransformOrigin="Origin.TopCenter">
                                                <ActivatorContent>
                                                    <MudButton FullWidth="true" StartIcon="@Icons.Material.Filled.Info" Color="Color.Info" Variant="Variant.Filled" Size="Size.Small">Directorys</MudButton>
                                                </ActivatorContent>
                                                <ChildContent>
                                                    <MudExpansionPanels Elevation="0">

                                                        @foreach (RouteProductAssyChart item in _assychart.RoutesProductsAssyChart)
                                                        {

                                                            <MudExpansionPanel>
                                                                <TitleContent>
                                                                    <MudSimpleTable Elevation="0">
                                                                        <MudText Class="mt-1">@item.Product?.Description</MudText>
                                                                    </MudSimpleTable>
                                                                </TitleContent>
                                                                <ChildContent>
                                                                    <MudItem class="d-flex flex-column justify-center ma-1">
                                                                        <MudItem class="d-flex d-flex-column justify-center">

                                                                            @if (item.GOS != "")
                                                                            {
                                                                                <MudPaper Elevation="0">
                                                                                    <MudButton @onclick="(() => OpenDialogGOS(item.GOS))" @ontouchstart="(() => OpenDialogGOS(item.GOS))" Style="padding: 0px;" Color="Color.Error">
                                                                                        <MudTooltip Text=@Localizer1["openGOSFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialogGOS(item.GOS))" @ontouchstart="(() => OpenDialogGOS(item.GOS))">
                                                                                            <MudTooltip Text="@item.GOS" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.GOS.Split('/').Last()</MudChip>
                                                                                            </MudTooltip>
                                                                                        </MudTooltip>
                                                                                    </MudButton>

                                                                                </MudPaper>
                                                                            }
                                                                            else
                                                                            {
                                                                                <MudPaper Elevation="0">

                                                                                    <MudAlert Severity="Severity.Info">@Localizer1["noGOSPath"]</MudAlert>
                                                                                </MudPaper>
                                                                            }

                                                                            @if (@item.CCP != "")
                                                                            {
                                                                                <MudPaper Elevation="0">
                                                                                    <MudButton @onclick="(() => OpenDialogCcp(item.CCP))" @ontouchstart="(() => OpenDialogCcp(item.CCP))" Style="padding: 0px;" Color="Color.Error">
                                                                                        <MudTooltip Text=@Localizer1["openCCPFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialogCcp(item.CCP))" @ontouchstart="(() => OpenDialogCcp(item.CCP))">
                                                                                            <MudTooltip Text="@item.CCP" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.CCP.Split('/').Last()</MudChip>
                                                                                            </MudTooltip>
                                                                                        </MudTooltip>
                                                                                    </MudButton>
                                                                                </MudPaper>
                                                                            }
                                                                            else
                                                                            {
                                                                                <MudPaper Elevation="0">
                                                                                    <MudAlert Severity="Severity.Info">@Localizer1["noCCPPath"]</MudAlert>
                                                                                </MudPaper>
                                                                            }

                                                                            @if (item.HOE != "")
                                                                            {
                                                                                <MudPaper Elevation="0">
                                                                                    <MudButton @onclick="(() => OpenDialogHoe(item.HOE))" @ontouchstart="(() => OpenDialogHoe(item.HOE))" Style="padding: 0px;" Color="Color.Error">
                                                                                        <MudTooltip Text=@Localizer1["openHOEFolder"] Color="Color.Primary" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialogHoe(item.HOE))" @ontouchstart="(() => OpenDialogHoe(item.HOE))">
                                                                                            <MudTooltip Text="@item.HOE.Replace('§',' ')" Color="Color.Primary" Placement="Placement.Top" Arrow="true" ShowOnFocus="false">
                                                                                                <MudChip Icon="@Icons.Material.Filled.SnippetFolder" Variant="Variant.Text" Color="Color.Primary" Style="font-size: 10px">@item.HOE.Split('§').Last()</MudChip>
                                                                                            </MudTooltip>
                                                                                        </MudTooltip>
                                                                                    </MudButton>
                                                                                </MudPaper>
                                                                            }
                                                                            else
                                                                            {
                                                                                <MudPaper Elevation="0">
                                                                                    <MudAlert Severity="Severity.Info">@Localizer1["noHOEPath"]</MudAlert>
                                                                                </MudPaper>
                                                                            }

                                                                        </MudItem>
                                                                    </MudItem>

                                                                </ChildContent>
                                                            </MudExpansionPanel>
                                                        }



                                                    </MudExpansionPanels>
                                                </ChildContent>
                                            </MudMenu>
                                        }
                                        else
                                        {
                                            <MudAlert Severity="Severity.Info">
                                                @Localizer1["ACNoProducts"]
                                            </MudAlert>
                                        }
                                    </MudItem>
                                }
                                else
                                {
                                    if (_assychart is null)
                                    {
                                        <MudItem class="d-flex flex-column justify-center align-self-start">
                                            <MudPaper Elevation="0">
                                                <MudAlert Severity="Severity.Info">
                                                    No AssyCharts Found
                                                </MudAlert>
                                            </MudPaper>
                                        </MudItem>
                                    }
                                    else
                                    {
                                        <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
                                    }


                                }

                            </MudItem>
                        }
                    </td>

                    <td>Programada</td>

                    @for (int i = 1; i < 13; i++)
                    {
                        int currentIndex = i;
                        <td style="text-align: end; width:160px; max-height:160px">

                            @if (SOS_Registers_Matrix.TryGetValue((Distribution_Item.DistributionId, currentIndex), out var context))
                            {
                                @if (context?.Count() > 0 && context.FindIndex(j => j.JobObservation?.Status == 7) != -1)
                                {
                                    @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                    {
                                        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="" Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                            <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="(() => OpenDialogCreateJobObservation(currentIndex, Distribution_Item.DistributionId))" @ontouchstart="(() => OpenDialogCreateJobObservation(currentIndex, Distribution_Item.DistributionId))">
                                                @Localizer["createJobObservation"]
                                            </MudMenuItem>
                                        </MudMenu>

                                    }

                                    <div style="min-height: 8vh; overflow-y: scroll; max-height: 8vh; scroll-behavior: smooth;" class="scroll scroll1">

                                        @foreach (SOSRegisterJobObservation jobobs in context)
                                        {

                                            //Finalized
                                            if (jobobs.JobObservation?.Status == 7)
                                            {
                                                var jobId = (int)jobobs.JobObservation?.JobObservationId;
                                                <MudTooltip Text="@jobobs.JobObservation?.JobObservationId.ToString()" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog3(jobId))">
                                                    <MudButton @onclick="(() => OpenDialog3(jobId))" Style="padding: 0px;" Color="Color.Warning">
                                                        <span style="font-size: 11px; cursor:pointer">
                                                            <span style="font-weight: bold; font-size: 13px">
                                                                @jobobs.JobObservation?.JobObservationId
                                                            </span> .  @jobobs.JobObservation?.Operator?.Name
                                                        </span>
                                                        <MudIcon Icon="@Icons.Outlined.Info" />
                                                    </MudButton>
                                                </MudTooltip>


                                            }
                                        }

                                    </div>
                                    @if (context.Where(j => j.JobObservation?.Status == 7).ToList().Count() > 2)
                                    {
                                        <MudButton @onclick="(() => OpenDialog4(Distribution_Item.DistributionId, currentIndex, 1))" FullWidth=true Style="text-align:center; height: 5px;" Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.KeyboardArrowDown"></MudButton>
                                    }

                                }
                                else
                                {
                                    @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
                                    {
                                        <MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="" Color="Color.Info" AnchorOrigin="Origin.BottomCenter">
                                            <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="(() => OpenDialogCreateJobObservation(currentIndex, Distribution_Item.DistributionId))" @ontouchstart="(() => OpenDialogCreateJobObservation(currentIndex, Distribution_Item.DistributionId))">
                                                @Localizer["createJobObservation"]
                                            </MudMenuItem>
                                        </MudMenu>
                                    }

                                }

                            }
                        </td>

                    }

                    <td rowspan="2"></td>
                </tr>
                <tr>
                    <td>Real</td>
                    @for (int i = 1; i < 13; i++)
                    {
                        int currentIndex = i;
                        <td style="min-width: 12vw">
                            @*<MudMenu EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Label="" Color="Color.Info" AnchorOrigin="Origin.BottomCenter">


                <MudMenuItem Icon="@Icons.Material.Filled.EditCalendar" @onclick="(() => OpenDialogCreateJobObservation(currentIndex, Distribution_Item.DistributionId))" @ontouchstart="(() => OpenDialogCreateJobObservation(currentIndex, Distribution_Item.DistributionId))">
                @Localizer["createJobObservation"]
                </MudMenuItem>



                </MudMenu>*@


                            @if (SOS_Registers_Matrix.TryGetValue((Distribution_Item.DistributionId, currentIndex), out var context))
                            {
                                @if (context?.Count() > 0)
                                {
                                    <div style="min-height: 10vh; overflow-y: scroll; max-height: 10vh; scroll-behavior: smooth;" class="scroll scroll1">
                                        @foreach (SOSRegisterJobObservation jobobs in context)
                                        {
                                            if (jobobs.JobObservation?.Status == 1)

                                            {
                                                <MudTooltip Text="@jobobs.JobObservation?.JobObservationId.ToString()" Color="Color.Warning" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                                    <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))" Style="padding: 0px;" Color="Color.Warning">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" Style="font-size: 10px"> @jobobs.JobObservation?.StartDate?.ToShortDateString()</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.PlayCircle" />
                                                    </MudButton>
                                                    <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservation?.JobObservationId</span>.  @jobobs.JobObservation?.Operator?.Name</span>
                                                </MudTooltip>
                                            }
                                            //In Progress
                                            else if (jobobs.JobObservation?.Status == 2)
                                            {
                                                <MudTooltip Text="@jobobs.JobObservation?.JobObservationId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                                    <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))" Style="padding: 0px;" Color="Color.Info">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@jobobs.JobObservation?.StartDate?.ToShortDateString()</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.StopCircle" />
                                                    </MudButton>
                                                    <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservation?.JobObservationId</span>.  @jobobs.JobObservation?.Operator?.Name</span>
                                                </MudTooltip>
                                            }

                                            //Late job observations
                                            else if (jobobs.JobObservation?.Status == 3)
                                            {
                                                <MudTooltip Text="@jobobs.JobObservation?.JobObservationId.ToString()" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                                    <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))" Style="padding: 0px;" Color="Color.Error">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px">@jobobs.JobObservation?.StartDate?.ToShortDateString()</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" />
                                                    </MudButton>
                                                    <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservation?.JobObservationId</span>.  @jobobs.JobObservation?.Operator?.Name</span>
                                                </MudTooltip>
                                            }

                                            //Under Review job observations
                                            else if (jobobs.JobObservation?.Status == 4)
                                            {
                                                <MudTooltip Text="@jobobs.JobObservation?.JobObservationId.ToString()" Color="Color.Info" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                                    <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))" Style="padding: 0px;" Color="Color.Info">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Style="font-size: 10px">@jobobs.JobObservation?.StartDate?.ToShortDateString()</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.IncompleteCircle" />
                                                    </MudButton>
                                                    <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservation?.JobObservationId</span>.  @jobobs.JobObservation?.Operator?.Name</span>
                                                </MudTooltip>
                                            }

                                            //Rejected job observations
                                            else if (jobobs.JobObservation?.Status == 5)
                                            {
                                                <MudTooltip Text="@jobobs.JobObservation?.JobObservationId.ToString()" Color="Color.Error" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                                    <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))" Style="padding: 0px;" Color="Color.Error">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="font-size: 10px">@jobobs.JobObservation?.StartDate?.ToShortDateString()</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.Cancel" />
                                                    </MudButton>
                                                    <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservation?.JobObservationId</span>.  @jobobs.JobObservation?.Operator?.Name</span>
                                                </MudTooltip>
                                            }
                                            //Finalized
                                            else if (jobobs.JobObservation?.Status == 6)
                                            {
                                                <MudTooltip Text="@jobobs.JobObservation?.JobObservationId.ToString()" Color="Color.Success" Placement="Placement.Bottom" Arrow="true" ShowOnFocus="false" @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))">
                                                    <MudButton @onclick="(() => OpenDialog2(jobobs.JobObservation.JobObservationId))" Style="padding: 0px;" Color="Color.Success">
                                                        <MudChip Icon="@Icons.Material.Filled.AccessTime" Variant="Variant.Text" Color="Color.Success" Size="Size.Small" Style="font-size: 10px">@jobobs.JobObservation?.StartDate?.ToShortDateString()</MudChip>
                                                        <MudIcon Icon="@Icons.Material.Filled.Circle" />
                                                    </MudButton>
                                                    <span style="font-size: 11px; cursor:pointer"><span style="font-weight: bold; font-size: 13px">@jobobs.JobObservation?.JobObservationId</span>.  @jobobs.JobObservation?.Operator?.Name</span>
                                                </MudTooltip>
                                            }



                                        }

                                    </div>
                                    @if (context.Where(j => j.JobObservation?.Status != 7).ToList().Count() > 2)
                                    {
                                        <MudButton @onclick="(() => OpenDialog4(Distribution_Item.DistributionId, currentIndex, 2))" FullWidth=true Style="text-align:center; height: 5px;" Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.KeyboardArrowDown"></MudButton>
                                    }
                                }

                            }
                        </td>

                    }
                </tr>

            }

        </tbody>
    </MudSimpleTable>
}
else
{
    <MudItem Style="text-align:center;">
        <MudProgressCircular Color="Color.Primary" Style="height:70px;width:70px;" Indeterminate="true" />
        <MudText Typo="Typo.h6">Cargando...</MudText>
    </MudItem>
}



<MudDialog DisableSidePadding="false" @bind-IsVisible="visible" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 75vh; overflow-y: scroll">
            <SupervisorMobility.Client.Pages.JobObservationPage.JobObservationDetails JobObservationId="jobId"></SupervisorMobility.Client.Pages.JobObservationPage.JobObservationDetails>

        </MudContainer>
    </DialogContent>
    <DialogActions>
        @if (user.UserType == 1 || user.UserType == 2 || user.UserType == 3)
        {
            <MudIconButton @onclick="(() => JobObservationUpdate(jobId))" Color="Color.Info" Icon="@Icons.Material.Filled.Edit"></MudIconButton>
        }
        <MudButton Color="Color.Info" OnClick="Close">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>


<MudDialog DisableSidePadding="false" @bind-IsVisible="visible2" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 75vh; overflow-y: scroll">
            <SupervisorMobility.Client.Pages.JobObservationPage.ProgrammedJobObservationDetails JobObservationId="@jobId2" LoggedUser="@user"
                                                                                                IsVisible="@visible2" IsVisibleChanged="HandleVisibleChanged"></SupervisorMobility.Client.Pages.JobObservationPage.ProgrammedJobObservationDetails>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Info" OnClick="Close2">@Localizer["close"]</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog DisableSidePadding="false" @bind-IsVisible="SeeDialogCreateJobObservation" Options="dialogOptions">
    <DialogContent>
        <MudContainer Style="max-height: 80vh; overflow-y: scroll; display: flex; flex-wrap: wrap; flex-direction:row" Class="gap-4">
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    @Localizer["createJobObservation"]
                </MudText>
            </MudItem>
            <MudItem xs="12" sm="12" lg="12" md="12" Style="text-align: center">
                <MudText Typo="Typo.h6">
                    Details
                </MudText>
                @*<MudSimpleTable Dense="@dense" Hover="@hover" ReadOnly="@ronly"*@
                <MudSimpleTable HorizontalScrollbar="true">
                    <tbody>
                        <tr>
                            <td style="width:50%">
                                @*Mud select of Plants*@
                                <MudSelect T="int" Label=@Localizer["plant"] Variant="Variant.Text" Class="mt-3" AnchorOrigin="Origin.BottomCenter" @bind-Value="@_NewJobObservation.PlantId">
                                    <MudSelectItem Disabled="true" Value="@_NewJobObservation.PlantId">@_NewJobObservation.Plant?.Code - @_NewJobObservation.Plant?.Description</MudSelectItem>
                                </MudSelect>
                            </td>
