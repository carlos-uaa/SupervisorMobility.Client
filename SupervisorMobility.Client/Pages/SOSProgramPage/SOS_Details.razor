    </thead>
    <tbody>

        @foreach (Distribution Distribution_Item in _distributions)
            {
                <tr>
                    <td rowspan="2">
                        No
                    </td>
                    <td rowspan="2">
                        @Distribution_Item.Description
                    </td>
                    <td rowspan="2">
