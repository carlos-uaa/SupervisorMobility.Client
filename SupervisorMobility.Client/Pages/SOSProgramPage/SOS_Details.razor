<style>

    .vertical-text {
        vertical-align: middle;
    }

    .vertical-content {
        writing-mode: vertical-lr;
        white-space: nowrap;
        word-wrap: break-word;
        max-width: 100%;
    }

</style>

@*Title*@
<PageTitle>Supervisor Mobility | @Localizer["sosDetails"]</PageTitle>
@*Breadcrumb links*@
<MudBreadcrumbs Class="mb-10" Items="_links">
    <ItemTemplate Context="item">
        <MudButton Href="@item.Href" Variant="Variant.Text" Color="Color.Info" Disabled="item.Disabled">@item.Text</MudButton>
    </ItemTemplate>
</MudBreadcrumbs>

<MudItem Class="d-flex justify-content-between mb-5" Style="align-items: center;">
    <MudText Typo="Typo.h6">@Localizer["sosDetails"] </MudText>

</MudItem>

