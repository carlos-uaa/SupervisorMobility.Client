                                                            {

                                                                @switch (_assychart.Operation?.CriticalType)
                                                                {
                                                                    case 1:
                                                                        <MudItem style="text-align:center">
                                                                            <img src="Images/A.png" Height="30" Width="30" />
                                                                        </MudItem>
                                                                        break;
